; uplift-high-grammar-goal.form — the goal + exit proof for raising the body from raw-primitive
; recipes to HIGH-GRAMMAR semantic abstraction (BML class-hierarchy / template / generic /
; attribute), behavior-preserving and measured. Placed 2026-06-29. Companion to
; re-architecture-stones.form — those stones BUILD the constructs; this goal LIFTS the body into them.

(uplift-high-grammar-goal

  ; ── GROUND (measured 2026-06-29, origin/main) ──
  (ground
    (body          "286 recipes (*.fk, excluding walkers/ + tests)")
    (high-grammar  "95 (~33%) touch a semantic-abstraction construct; 191 are raw-primitive Form (cons/head/arithmetic)")
    (definition    "HIGH-GRAMMAR = altitude of abstraction (class hierarchy, template, generic, attribute —
                    the BML / Field-Model grammar: grammars/bmf-core.fk + grammars/field-domain-grammars.form),
                    NOT .fk-vs-.c file language. A .fk written in raw primitives is LOW-grammar.")
    (measure       "git ls-files '*.fk' | grep -L 'class|inherit|template|generic|attribute|interface|blueprint|grammar|extends|trait'
                    → the low-grammar set; count / total = the share")
    (proof-of-shape "cursor-seed P2 (#44) IS the pattern: form-eval's binop dispatch went from two hand-written
                     if-chains to ONE table-as-DATA (fef-optable, rows of (name tag arity)) — adding an op is now a row"))

  ; ── THE BENEFIT-RANKED BACKLOG (size × repeated-structure × low-grammar) ──
  (backlog
    (B1 "observe/ sensing family"        "~10 recipes (~1500 lines), one sensor->feature->reading->fusion shape"
        "-> ONE sensor-organ template/class-hierarchy: world-sensor-floor as the base; each sensor a thin attribute-declaration")
    (B2 "model/jit-tensor-emit.fk"       "727 lines, hand-written per-op/per-ISA emitter"
        "-> the data-driven model/tensor-ir.fk (ISA-as-DATA); retire the hand-emitter, byte-identical output")
    (B3 "form-cli/form-cli-gguf-cell.fk" "808 lines, 87 hand-coded defns parsing a structured format"
        "-> a schema/grammar-driven parser (the GGUF format as DATA)")
    (B4 "substrate/form-fs.fk"           "196 lines filesystem CRUD"          "-> the resource-port abstraction")
    (B5 "grammars/line-grammar.fk + learn/ family"  "patterns"                "-> their domain grammars"))

  ; ── INVARIANTS (every uplift holds ALL — else it is not an uplift) ──
  (invariants
    (construct-grounded "uplifts into a high-grammar construct that EXISTS and is proven (--src + four-way where it
                         applies); if the construct is absent, BUILD+prove it first — never fake an uplift in raw Form")
    (behavior-identical "the uplifted recipe's fkwu --src result == the original's, verdict/byte-identical (the HARD GATE);
                         a changed result is a FAILED uplift, never shipped")
    (grammar-lifted     "the recipe now USES the semantic construct (verifiable by the high-grammar measure),
                         not re-inlined primitives under a nicer name")
    (reduced            "lines/defns after < before (measured), OR N recipes collapse into 1 template + N thin declarations")
    (receipted          "each uplift lands a receipt on origin/main: before->after lines, the diff=0 / identical-verdict
                         proof, the construct used"))

  ; ── EXIT PROOF (STOP when ALL hold; each checkable from origin/main, no human judgment) ──
  (exit-proof
    (E1 "CONSTRUCTS PROVEN" "BML expresses class-hierarchy + template + attribute, each with a --src/four-way receipt in
                             receipts/ (gate 0 — the sensing-family uplift is testing this now; if a construct cannot be
                             built, E1 is met by a named-wall receipt deriving the minimal construct from an axiom)")
    (E2 "BACKLOG DONE"      "every backlog recipe (B1..B5) is EITHER uplifted-with-passing-receipt OR carries a NAMED-WALL
                             receipt stating exactly which abstraction BML cannot yet express (honest stop, not a skip)")
    (E3 "SHARE RECORDED"    "the high-grammar share + retired-low-grammar line-count, measured by the ground command on
                             origin/main BEFORE & AFTER, improvement recorded (target: >= +10 points from 33%; honest if
                             the backlog yields less — the recorded number is the proof, not a threshold to game)")
    (E4 "NO REGRESSION"     "the four-way floor + the cursor-seed reducer proof still pass (fkwu proof/four-way-run.tbl -> 0;
                             the P1/P2 cursor-seed recipes still run); nothing the uplift touched broke")
    (E5 "SELF-CONSISTENT"   "this cell + re-architecture-stones.form + docs/inheritance/INHERITANCE.md read the same share
                             number — no drift"))

  ; ── HONEST FLOOR ──
  (honest-floor "a precise NAMED WALL ('BML cannot yet express generic-over-attribute; here is the minimal construct it
                 would need, derived from axiom-N') IS a valid exit for that recipe. Pending is honest; a fake uplift is
                 not. The goal stops at the proof or the wall — never at a vibe."))
