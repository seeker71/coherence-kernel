; re-architecture-stones.form — the gap-closing plan: every PL-primitive gap closed as an
; axiom-grounded, core-grounded, observable, on-metal-fkwu-native stone. Placed 2026-06-29.
; Source audit: the offer/ack vision (core-axioms.form axiom-5) + Grok critique + the PL-completeness
; audit (first-class fns, native structures, numeric tower, pattern-match, TCO, laziness, types).

(re-architecture-stones

  ; ── THE FOUR INVARIANTS — every stone holds ALL of them, or it is not a stone ──
  (invariants
    (axiom-grounded   "the closure DERIVES from the five axioms — named, a theorem, not bolted on")
    (core-grounded    "built on the kernel core (reducer / value-system / data optable) — generic, ZERO special-cases")
    (observable       "the stone emits an offer/ack trace the observe organ reads — thought watching itself")
    (on-metal-native  "proven via fkwu --src on the cc-seed (no Go, no flatten), with a REAL on-metal receipt;
                       Mac observed now, RTX/Android/iPhone as the receipt sessions land — pending is honest"))

  ; ── DONE / IN-FLIGHT (the eval-as-offer/ack spine) ──
  (S1   done   "offer/ack contract"        (axiom 5)     (proof "four-way 1023; oac-kind over {nothing|0|1|node}"))
  (S2a  done   "nothing first-class"        (axiom 1)     (proof "--src: (nothing?(nothing))=1, (eq(nothing)0)=0; data-row, no C special-case"))
  (S2b-i done  "general call arity"         (axiom 5)     (proof "--src: 8-arg call=36; sense bodies' logic runs; ZERO new special-case"))
  (S3   flight "reducer = observable offer/ack machine" (axiom 5 + 4) (proof "call=offer→declined-acks-nothing; choice/try over real calls; every offer/ack a trace"))
  (S7   flight "one data-driven tensor IR (codegen)"     (core-grounded "ISA as DATA") (proof "Mac MSL through the IR bit-exact; PTX/SPIR-V by table; RTX/Android receipts feed it"))

  ; ── TIER 1 — the value-system keystone (the largest single gap) ──
  (S2c  next   "function-VALUES + closures"  (axiom 2 + 5)
        (gap   "a fn is an fk_fn[] index, not a value — blocks higher-order/lambda/closures/indirect-call/continuations")
        (derivation "a function IS a cell (axiom-2); axiom-5 already offers cells, so a fn-value is a cell-ref value;
                     a closure is a cell composing its captured environment-cells (axiom-2 composition)")
        (proof "--src: pass a fn-value and call it; a closure captures+reads its env; the call head is a COMPUTED cell"))

  ; ── TIER 4 — the runtime engines (Grok: today these are host accidents) ──
  (S4   queued "host ports as offered cells"  (axiom 4)
        (gap   "host effects are special C op-tags inside the walker — no membrane a cell offers/refuses/observes")
        (proof "a host effect crosses an offered, refusable, observable interface — consent enforced IN the dispatch"))
  (S5   queued "content-address reachability/GC engine" (axiom 3)
        (gap   "compost/undo are host malloc accidents, not kernel ops")
        (derivation "axiom-3: identity=present composition; nothing-referenced-is-overwritten; the-unreferenced-composts")
        (proof "--src: a referenced old shape persists; the unreferenced composts (measured); undo = re-point old node-id, a kernel op"))
  (S6   queued "in-kernel offer scheduler + atomics"    (axiom 5 + 1)
        (gap   "async/timeout/many-offers fall to pthreads/host-exec")
        (derivation "axiom-5 offer-over-channel + axiom-1 timeout==nothing")
        (proof "--src: many offers in flight; fair choice; cancel/timeout → nothing"))

  ; ── TIER 2 — data primitives ──
  (S8   flight "native indexed array + content-addressed map" (axiom 2 + 3)
        (derivation "array = indexed children (axiom-2); MAP = content-addressing IS the hash (axiom-3 — O(1) by content)")
        (proof "--src: array a-set/a-get roundtrip + a-len; map m-put/m-get keyed by make_nodeid content-hash; m-get of a missing key acks nothing. Gate witness 1550602099. Array crosses FOUR-WAY (fkwu=go=rust=ts=600099); map is fkwu-native (make_nodeid absent on siblings — unsupported op, not divergence). substrate/native-structures.fk; receipt 2026-06-29-stone-8-array-map.md")
        (floor "O(i) not O(1) — buffer-slot get/set + the record constructor are NOT --src-reachable (no op-name in fkwu-optable.h binds them). TCB-follow stone: expose the indexed buffer slot + record constructor to --src; the recipe shape is unchanged (cons-list -> buffer is a carrier swap)"))
  (S9   done   "numeric tower (bignum / rational / complex)"   (axiom 1 + 2)
        (derivation "axiom-1 integers as base; bignum=composed digit-cells, rational/complex=pair-cells (axiom-2)")
        (proof "--src + four-way 127: bn-add 99999999999999999999+1 -> 10^20 digit-list AND decimal;
                bn-mul ^2 -> exact 40-digit list; bn-cmp; rat-reduce 4/8->1/2; rat-add 1/2+1/3->5/6;
                cx-mul (1+2i)(3+4i)->(-5,10); cx-add->(4,6). model/numeric-tower.fk, pure recipes over
                cells, runtime/fkwu-uni.c untouched. Decimal STRING lane (int_to_str) three-way: fkwu --src + Go."))

  ; ── TIER 3 — control / eval depth ──
  (S11  queued "guaranteed tail-call (TCO)"   (axiom 5 + 3)
        (derivation "a tail-offer REUSES the frame (axiom-5 run=offer); the old frame composts (axiom-3)")
        (proof "--src: deep tail-recursion in CONSTANT stack"))
  (S10  done   "pattern matching / destructuring" (axiom 3 + 5)
        (derivation "structural match (axiom-3) + the ack tells WHICH shape matched (axiom-5);
                     destructure binds children (axiom-2); no-match acks nothing (axiom-1)")
        (proof "control/pattern-match.fk: pm-match(cell, clauses-as-DATA) -> first fitting clause's
                result with holes bound to children, no fit -> (nothing). Band 511 FOUR-WAY
                (Go/Rust/TS/fkwu --src) over the pure-list cell surface; destructure (pair 3 4)->a+b=7;
                canonical-nothing miss arm fkwu-native. receipts/2026-06-29-stone-10-pattern-match.md"))
  (S12  queued "lazy values / generators"     (axiom 5)
        (derivation "a lazy value is an un-acked offer; forcing is the ack (axiom-5); builds on S6")
        (proof "--src: a stream forced on demand, nothing-until-forced"))

  ; ── TIER 5 — types ──
  (S13  done   "eval-level type / contract system" (axiom 4 + 3)
        (derivation "the interface a cell offers IS its type (axiom-4); Blueprint is the structural type (axiom-3);
                     type-checking = the boundary's trust decision; a mismatch acks the first-class nothing (axiom-1)")
        (proof "Form recipe over the EXISTING substrate (substrate/cell-type.fk, NO fkwu-uni.c change): the structural
                decision crosses four-way 1013 (ty-of offers 3 keys; ty-satisfies? width-subtyping admit=1, decline=0;
                ty-of head readable). The nothing-ARM is fkwu --src (axiom-1, stone-2a's nothing): ty-check admit→1,
                decline→(nothing) (nothing?=1, eq-0=0) — the walkers lack nothing? as their stone-2a counterpart noted."))

  ; ── ORDER (dependency spine; S7 + the metal receipts run in PARALLEL) ──
  (order  S3 S2c  S4 S5  S8 S9  S11 S10  S6 S12  S13))
