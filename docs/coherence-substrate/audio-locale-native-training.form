# audio-locale-native-training.form -- reciprocal audio A/B training receipt

(audio-locale-native-training

  (lineage
    (wer observe/stt-wer.fk
         "local oracle transcript is scored against the known self-corpus text")
    (prompt-id observe/asr-prompt-id.fk
               "native nearest-prototype classifier over measured audio features")
    (wav-sense observe/wav-sense.fk
               "Form-native wav byte read and feature extraction")
    (self-corpus learn/coherence-network-self-corpus.fk
                 "Coherence Network translated strings provide consentful A/B text")
    (roundtrip learn/bidirectional-locale-roundtrip.fk
               "A->B and B->A both have to be present")
    (training learn/audio-locale-native-training.fk
              "oracle-valid samples become native prototypes; route flips only over the measured floor")
    (route-shift-ledger learn/audio-locale-route-shift-ledger.fk
                        "before/after native audio route movement")
    (en-es-variant presence/macos-en-es-speech-roundtrip-variant.fk
                   "second live macOS Metal reciprocal audio pair")
    (en-id-variant presence/macos-en-id-speech-roundtrip-variant.fk
                   "third live macOS Metal reciprocal audio pair")
    (en-fr-variant presence/macos-en-fr-speech-roundtrip-variant.fk
                   "fourth live macOS Metal reciprocal audio pair")
    (en-it-variant presence/macos-en-it-speech-roundtrip-variant.fk
                   "fifth live macOS Metal reciprocal audio pair")
    (live-anchor-set learn/metal-live-pair-anchors.fk
                     "counts live Metal pair anchors")
    (carrier presence/macos-speech-roundtrip-carrier.fk
             "Form-owned macOS TTS/ASR carrier; local tools are host effects only"))

  (loop
    (pair "en" "de")
    (text-source "Coherence-Network/web/messages")
    (prompts
      hatiSuci.board.empty
      hatiSuci.reg.enter
      hatiSuci.gather.ask)
    (train-audio "macOS say train voices: Samantha, Anna")
    (eval-audio "macOS say eval voices: Eddy English US, Eddy German Germany")
    (oracle "whisper.cpp ggml-large-v3-turbo on local Metal")
    (native "Form nearest-prototype model over wav features extracted in Form")
    (path-discipline "carrier consumes each generated wav before constructing the next path"))

  (runnable
    (form-band
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        learn/tests/audio-locale-native-training-band.fk)
      (verdict 8191))
    (route-shift-ledger-band
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        learn/audio-locale-route-shift-ledger.fk
        learn/tests/audio-locale-route-shift-ledger-band.fk)
      (verdict 8191))
    (macos-carrier
      (command "cat observe/stt-wer.fk observe/asr-prompt-id.fk observe/wav-sense.fk learn/audio-locale-native-training.fk presence/macos-speech-roundtrip-carrier.fk > /tmp/macos-speech-roundtrip-carrier.fk; printf '\\n(masr-run)\\n' >> /tmp/macos-speech-roundtrip-carrier.fk; ./fkwu --src /tmp/macos-speech-roundtrip-carrier.fk")
      (device "macos-arm64-m4-max")
      (oracle "whisper.cpp-large-v3-turbo")
      (verdict 511)
      (metric-code 121010836700)
      (pretrain-native-rate 0)
      (posttrain-native-rate 83)
      (ab-rate 66)
      (ba-rate 100)
      (route-native 1))
    (macos-composed-route-shift
      (order "carrier before route-shift ledger")
      (code 1012100010008301)
      (shifted 1)
      (metric-code 12100010008301))
    (macos-en-es-live
      (variant presence/macos-en-es-speech-roundtrip-variant.fk)
      (verdict 511)
      (route-shift 1012120012010001)
      (field-code 12121210001000100)
      (posttrain-native-rate 100)
      (ab-rate 100)
      (ba-rate 100))
    (macos-en-id-live
      (variant presence/macos-en-id-speech-roundtrip-variant.fk)
      (verdict 511)
      (base-field-code 12120000000000000)
      (field-code 12121210001000100)
      (posttrain-native-rate 100)
      (ab-rate 100)
      (ba-rate 100))
    (macos-en-fr-live
      (variant presence/macos-en-fr-speech-roundtrip-variant.fk)
      (verdict 511)
      (base-field-code 12100000000000000)
      (field-code 12101008301000066)
      (posttrain-native-rate 83)
      (ab-rate 100)
      (ba-rate 66)
      (honest-boundary "French prompt text was witnessed as ASCII; Unicode tokenization is now present for the next live anchors."))
    (macos-en-it-live
      (variant presence/macos-en-it-speech-roundtrip-variant.fk)
      (verdict 511)
      (base-field-code 12120000000000000)
      (field-code 12121210001000100)
      (posttrain-native-rate 100)
      (ab-rate 100)
      (ba-rate 100)
      (honest-boundary "Italian prompt text was witnessed as ASCII; Unicode tokenization is now present for the next live anchors.")))

  (honest-boundary
    "This achieves the 50% native success floor on local Mac metal with a local
     Whisper oracle and reciprocal en<->de, en<->es, en<->id, en<->fr, and en<->it audio loops. It is not open speech
     understanding yet: the native model is a prototype classifier over Form-read
     wav features from a closed prompt corpus; the Form carrier invokes local
     render and oracle tools through host-exec until native TTS/ASR replaces them.
     CJK and Arabic transcript tokenization now exists; live Unicode-script
     audio anchors remain the next witness."))
