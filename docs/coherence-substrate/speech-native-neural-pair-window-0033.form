# speech-native-neural-pair-window-0033.form -- fr<->ar neural pair window

(speech-native-neural-pair-window-0033

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "fr")
    (b "ar")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "fr->ar, ar->fr, fr->fr, ar->ar"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (french
      (voice "Thomas")
      (truth "je suis")
      (heard "Je suis")
      (wer 0)
      (wav-bytes 17908)
      (cksum 3224208913))
    (arabic
      (voice "Majed")
      (truth "أنا")
      (heard "أنا.")
      (wer 0)
      (wav-bytes 10906)
      (cksum 3840888175)))

  (result
    (cumulative-neural-pairs 33)
    (cumulative-directed-routes 66)
    (epochs 33)
    (native-neural-params 33)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0033-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0033.fk
      learn/tests/speech-native-neural-pair-window-0033-band.fk)
    (verdict 32767)))
