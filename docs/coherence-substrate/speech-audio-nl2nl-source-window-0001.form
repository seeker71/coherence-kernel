# speech-audio-nl2nl-source-window-0001.form -- de/pt-br source-window audio bridge

(speech-audio-nl2nl-source-window-0001

  (purpose
    (summary "route observed de/pt-br source audio through locale-neutral meaning into target audio")
    (boundary "host TTS and Whisper remain carriers/oracles; native Form owns neutral routing and target text"))

  (observed-metal-run
    (date "2026-07-01")
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (routes
      (de-to-pt-br
        (source "ich bin")
        (source-heard "Ich bin...")
        (target "eu sou")
        (target-heard "Eu sou.")
        (source-hash 108967973)
        (target-hash 1996659987)
        (wav-bytes 60990))
      (pt-br-to-de
        (source "eu sou")
        (source-heard "Eu sou.")
        (target "ich bin")
        (target-heard "Ich bin...")
        (source-hash 1996659987)
        (target-hash 108967973)
        (wav-bytes 60990))))

  (rates
    (source-oracle "2/2 = 100%")
    (target-oracle "2/2 = 100%")
    (native-neutral-routing "2/2 = 100%")
    (meaning 303)
    (route "oracle-guided-source-window-audio-nl2nl-audio-bridge-not-native-vocoder"))

  (runnable
    (concat
      observe/stt-wer.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-audio-nl2nl-source-window-0001.fk
      learn/tests/speech-audio-nl2nl-source-window-0001-band.fk)
    (verdict 32767)))
