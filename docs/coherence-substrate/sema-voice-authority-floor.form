# sema-voice-authority-floor.form -- nonzero Sema voice training floor

(sema-voice-authority-floor

  (purpose
    (summary "prevent Sema voice authority from collapsing to a 0/0 reading")
    (boundary "global live authority is not promoted by the scoped trial window"))

  (live-authority
    (source learn/speech-oracle-native-backlog.fk)
    (oracle "1/1 = 100%")
    (native "0/1 = 0%")
    (wer 100)
    (route "oracle-guide")
    (status "global-live-authority-not-promoted"))

  (scoped-training-row
    (source learn/sema-voice-trial-window-0002.fk)
    (candidate "tcav-two-window-cumulative")
    (oracle "2/2 = 100%")
    (native "2/2 = 100%")
    (wer 0)
    (scope "scoped-training-floor-not-global-authority"))

  (combined-floor
    (oracle "3/3 = 100%")
    (native "2/3 = 66%")
    (status "nonzero-training-floor-live-authority-still-held")
    (next-action "render-next-live-sema-sample-and-oracle")
    (zero-denominator-rule "block-zero-denominator-voice-gate"))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/sema-voice-trial-window.fk
      learn/sema-voice-trial-window-0002.fk
      learn/sema-voice-authority-floor.fk
      learn/tests/sema-voice-authority-floor-band.fk)
    (verdict 32767)))
