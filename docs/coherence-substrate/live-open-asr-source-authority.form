# live-open-asr-source-authority.form -- open dictation miss trains source ASR

(live-open-asr-source-authority

  (lineage
    (open-dictation learn/open-dictation-transcript-learning.fk
                    "live open transcript rows carry side-channel truth, local oracle text, native candidate text, WER, and controls")
    (macos-open-carrier presence/macos-open-dictation-carrier.fk
                        "local say -> wav -> Whisper Metal witnessed oracle WER 0 and native WER 100")
    (ctc observe/open-asr-ctc.fk
         "frame-token streams can collapse into free transcript tokens")
    (acoustic-emitter observe/acoustic-token-emitter.fk
                      "native acoustic features can emit CTC frame tokens")
    (segmented-source learn/segmented-acoustic-token-learning.fk
                      "oracle-aligned wav/envelope segments teach source token prototypes")
    (authority learn/live-open-asr-source-authority.fk
               "the live open-dictation miss becomes a segmented source-ASR training action"))

  (runnable
    (authority-band
      (concat
        learn/live-open-asr-source-authority.fk
        learn/tests/live-open-asr-source-authority-band.fk)
      (verdict 32767))
    (source-open-dictation-band
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        form/form-stdlib/observed-auto-learning.fk
        learn/open-dictation-transcript-learning.fk
        learn/tests/open-dictation-transcript-learning-band.fk)
      (verdict 16383))
    (segmented-source-band
      (concat
        observe/stt-wer.fk
        observe/speech-token-stream.fk
        observe/open-asr-ctc.fk
        observe/acoustic-token-emitter.fk
        learn/sanskrit-locale-baseline.fk
        learn/segmented-acoustic-token-learning.fk
        learn/tests/segmented-acoustic-token-learning-band.fk)
      (verdict 32767)))

  (authority
    (live-open-dictation "observed")
    (oracle-wer 0)
    (native-wer 100)
    (action "train-live-segmented-open-asr-source")
    (candidate "native-segmented-acoustic-learning")
    (authority "oracle-guide")
    (selector-verdict 134217727)
    (selected-asr "prototype-asr"))

  (honest-boundary
    "This is not native open microphone ASR yet. It turns the live local
     open-dictation oracle/native gap into an executable segmented source-ASR
     training action. Native open-ASR source authority promotes only after a
     local native transcript succeeds under the WER, consent, audio, and control
     gates."))
