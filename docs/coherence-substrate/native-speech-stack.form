# native-speech-stack.form -- STT/TTS grounded on real metal

(native-speech-stack

  (lineage
    (stt-score observe/stt-agree.fk
               "native transcript agreement against trusted truth; set-overlap floor")
    (stt-wer observe/stt-wer.fk
             "sequence-aligned word error rate; catches order/repeat errors overlap can miss")
    (normalization presence/text-normalize.fk
                   "numbers to words before g2p; locale-as-data")
    (g2p presence/g2p.fk
         "one grapheme-to-phoneme engine, locale tables as data")
    (timing presence/phoneme-timing.fk
            "phoneme duration from stress + base")
    (contour presence/prosody-contour.fk
             "phrase melody: declarative/question/exclamation contour")
    (phrasing presence/voice-phrasing.fk
              "pause and emphasis from grounding/newness")
    (prosody presence/voice-prosody.fk
             "inner state to pace/steadiness/warmth/lift")
    (speaker presence/speaker-embed.fk
             "native nearest-by-cosine decision over oracle embeddings")
    (formant-vocoder presence/formant-vocoder.fk
                     "first native source-filter waveform carrier")
    (prompt-id-asr observe/asr-prompt-id.fk
                   "closed-set native ASR over measured loopback features")
    (open-dictation learn/open-dictation-transcript-learning.fk
                    "free transcript receipt gate for live open ASR candidates")
    (speech-token-stream observe/speech-token-stream.fk
                         "special tokens plus voice-side metadata")
    (open-asr-ctc observe/open-asr-ctc.fk
                  "native CTC frame-token collapse to open transcript stream")
    (speech-promotion learn/speech-loopback-promotion.fk
                      "rolling receipt window for native authority")
    (carrier-receipt presence/speech-loopback-carrier-receipt.fk
                     "real local carrier measurements admitted into promotion"))

  (real-metal-witness
    (machine "Darwin arm64, local Mach-O fkwu")
    (ground observe/native-vs-rented.fk 11111)
    (socket form/form-stdlib/tests/fkwu-src-socket-loopback-band.fk 111111111)
    (observed-auto-learning form/form-stdlib/tests/observed-auto-learning-band.fk 4095)
    (stt observe/tests/stt-agree-band.fk 127)
    (text-normalize presence/tests/text-normalize-band.fk 255)
    (speaker-embed presence/tests/speaker-embed-band.fk 255)
    (presence-feature observe/tests/presence-feature-band.fk 15)
    (stt-wer observe/tests/stt-wer-band.fk 255)
    (stt-tokenize-unicode observe/tests/stt-tokenize-unicode-band.fk 4095)
    (native-speech-stack presence/tests/native-speech-stack-band.fk 2047)
    (formant-vocoder presence/tests/formant-vocoder-band.fk 511)
    (asr-prompt-id observe/tests/asr-prompt-id-band.fk 255)
    (native-speech-loopback presence/tests/native-speech-loopback-band.fk 1023)
    (speech-loopback-promotion learn/tests/speech-loopback-promotion-band.fk 2047)
    (speech-loopback-carrier-receipt presence/tests/speech-loopback-carrier-receipt-band.fk 4095)
    (open-dictation-transcript learn/tests/open-dictation-transcript-learning-band.fk 16383)
    (speech-token-stream observe/tests/speech-token-stream-band.fk 32767)
    (open-asr-ctc observe/tests/open-asr-ctc-band.fk 32767)
    (macos-open-dictation presence/tests/macos-open-dictation-carrier-band.fk 511))

  (what-is-native-now
    (stt-evaluation "native overlap scoring, Unicode-aware tokenization, and sequence-aligned WER of transcript candidates against truth")
    (tts-pre-acoustic "normalization, g2p, timing, contour, phrasing, prosody")
    (tts-carrier "first native formant/source-filter waveform carrier")
    (closed-set-asr "prompt-ID recognition from measured loopback features")
    (open-dictation-receipt "free transcript rows can be scored and promoted without closed prompt IDs")
    (speech-token-stream "special tokens carry provenance, route, controls, evidence, memory/scope, and voice-side metadata")
    (open-asr-decoder "native CTC token collapse can emit free transcript text into the open-dictation gate")
    (promotion "rolling receipt windows shift authority native only after clean success")
    (carrier-contract "local TTS/STT loopback facts have a Form-verified receipt shape")
    (speaker-decision "native decision over supplied embeddings")
    (control "observed-auto-learning can A/B these recipes from live receipts"))

  (honest-boundary
    (stt-model "closed-set prompt ASR exists; open transcript receipts and a native CTC decoder exist; live acoustic frame-token emission is not yet one path")
    (speaker-embedding-carrier "embedding vectors still come from an oracle; only the recognition decision is native")
    (tts-sound "a simple formant vocoder exists; natural acoustic model + neural vocoder remain pending")
    (voice-honesty "prosody is a faithful function of calibration input, not proof that calibration itself is true"))

  (next-improvements
    (stt-open-dictation "feed live acoustic frame tokens into the native CTC decoder and open-dictation promotion gate")
    (stt-promotion "wire WER + agreement windows into observed-auto-learning promotion gates")
    (stt-live-loop "wire mic/audio frames -> mel/formant features -> candidate transcript -> agreement/WER receipt -> A/B promotion")
    (tts-lexical "add lexical stress, punctuation/acronym/heteronym data before g2p")
    (tts-acoustic "add segment-to-acoustic model: coarticulation, formant glides, vowel reduction, context duration")
    (tts-vocoder "lift from simple formant samples toward source-filter/acoustic-model quality")
    (perception-receipt "hold text fixed, vary earned confidence, and verify listeners perceive intended uncertainty"))

  (runnable
    (cell presence/native-speech-stack.fk)
    (band presence/tests/native-speech-stack-band.fk)
    (concat
      observe/stt-agree.fk
      observe/stt-wer.fk
      presence/text-normalize.fk
      presence/g2p.fk
      presence/phoneme-timing.fk
      presence/prosody-contour.fk
      presence/voice-phrasing.fk
      presence/voice-prosody.fk
      presence/speaker-embed.fk
      presence/native-speech-stack.fk
      presence/tests/native-speech-stack-band.fk)
    (verdict 2047)))
