# speech-open-asr-trial-window-0008.form -- de/it scoped open-ASR source window

(speech-open-asr-trial-window-0008

  (purpose
    (summary "add the eighth scoped open-ASR source window with local de/it loopback evidence")
    (boundary "routes native only inside the trial window; global open microphone authority remains oracle-held"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (german
      (voice "Anna")
      (truth "ich bin")
      (heard "Ich bin")
      (wer 0)
      (wav-bytes 16068)
      (cksum 3773526825)
      (language "de"))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)
      (language "it")))

  (scoped-result
    (scoped-open-asr-rows "14 -> 16")
    (oracle "16/16 = 100%")
    (native "16/16 = 100%")
    (native-rate 100)
    (route "native inside trial window")
    (observed-wav-bytes 32774))

  (authority-boundary
    (global-open-dictation "oracle 4/4, native 0/4, oracle-guide")
    (scope "trial-window-native-not-global-authority")
    (c-seed-growth 0))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/speech-open-asr-trial-window-0002.fk
      learn/speech-open-asr-trial-window-0003.fk
      learn/speech-open-asr-trial-window-0004.fk
      learn/speech-open-asr-trial-window-0005.fk
      learn/speech-open-asr-trial-window-0006.fk
      learn/speech-open-asr-trial-window-0007.fk
      learn/speech-open-asr-trial-window-0008.fk
      learn/tests/speech-open-asr-trial-window-0008-band.fk)
    (verdict 32767)))
