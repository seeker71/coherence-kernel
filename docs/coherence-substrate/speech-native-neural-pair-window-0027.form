# speech-native-neural-pair-window-0027.form -- zh<->pt-br neural pair window

(speech-native-neural-pair-window-0027

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "zh")
    (b "pt-br")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "zh->pt-br, pt-br->zh, zh->zh, pt-br->pt-br"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (chinese
      (voice "Tingting")
      (truth "我在")
      (heard "我在。")
      (wer 0)
      (wav-bytes 15064)
      (cksum 3568659029))
    (portuguese-brazil
      (voice "Flo (Portuguese (Brazil))")
      (truth "eu sou")
      (heard "Eu sou.")
      (wer 0)
      (wav-bytes 31774)
      (cksum 1996659987)))

  (result
    (cumulative-neural-pairs 27)
    (cumulative-directed-routes 54)
    (epochs 27)
    (native-neural-params 27)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0027-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0027.fk
      learn/tests/speech-native-neural-pair-window-0027-band.fk)
    (verdict 32767)))
