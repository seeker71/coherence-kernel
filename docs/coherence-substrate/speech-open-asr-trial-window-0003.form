# speech-open-asr-trial-window-0003.form -- third scoped open-ASR challenger window

(speech-open-asr-trial-window-0003

  (scheduler learn/speech-next-trial-scheduler.fk)
  (previous-window learn/speech-open-asr-trial-window-0002.fk)
  (baseline learn/sanskrit-locale-baseline.fk)

  (trial
    (id "trial-open-asr-0001")
    (incumbent "prototype-asr")
    (challenger "native-segmented-acoustic-learning")
    (recipe "segmented-open-asr-source-window-v1")
    (scope "third trial window, not global live ASR authority"))

  (window-0003
    (added-locales "ar, zh")
    (meaning 303)
    (baseline "aham asmi")
    (samples "ana / wo shi")
    (oracle "2/2")
    (native "2/2")
    (controls "choice, cut, fail, undo, timeout clean"))

  (cumulative-trial-window
    (locales "en, de, es, fr, ar, zh")
    (oracle "6/6")
    (native "6/6")
    (native-rate 100)
    (floor 50)
    (route "native")
    (action "cut-challenger-for-trial-window")
    (authority "open authority false"))

  (oracle "whisper.cpp-large-v3-turbo-metal")
  (device "macos-arm64-m4-max")

  (boundary
    (native-form true)
    (neural-ready false)
    (status "trial-window-native-not-global-authority")
    (meaning "this widens scoped source learning; it does not promote global live open ASR"))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/speech-open-asr-trial-window-0002.fk
      learn/speech-open-asr-trial-window-0003.fk
      learn/tests/speech-open-asr-trial-window-0003-band.fk)
    (verdict 32767)))
