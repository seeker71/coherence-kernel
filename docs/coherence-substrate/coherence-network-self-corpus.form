# coherence-network-self-corpus.form -- our translated body as training material

(coherence-network-self-corpus

  (lineage
    (source-repo "~/source/Coherence-Network")
    (web-messages "web/messages/{en,de,es,fr,id,pt-br}.json"
                  "2019 aligned key paths per locale, observed on disk")
    (cli-messages "cli/lib/messages/{en,de,es,fr,id,pt-br}.json"
                  "45 aligned key paths per locale, observed on disk")
    (source-loader "~/source/Coherence-Network/form/form-stdlib/i18n.fk"
                   "loader shape: key-path as meaning cell, locale string as surface")
    (kernel-row learn/coherence-network-self-corpus.fk
                "readiness, counts, backfill targets, pair readiness"))

  (principle
    (self-corpus "the Coherence Network body is ours and already translated")
    (consent "owned/licensed/attributed source rows can train without scraping others")
    (meaning-pivot "shared JSON key path is the neutral meaning id")
    (not-ready-is-honest "valuable languages are backfill targets until translated rows land")
    (roundtrip "ready locale pairs can feed A->B and B->A text/voice loopbacks"))

  (ready-now
    (locales en de es fr id pt-br)
    (keypaths 2064)
    (en-to-other-pairs 10320)
    (example-ready-pair de id))

  (backfill-targets
    (zh "high-diversity target; no Coherence Network translated bundle yet")
    (ar "high-diversity target; no Coherence Network translated bundle yet")
    (la "classical/Romance target; no Coherence Network translated bundle yet"))

  (held-pending
    (nv "specific Indigenous row; consentful corpus pending")
    (chr "specific Indigenous row; consentful corpus pending"))

  (runnable
    (concat
      learn/coherence-network-self-corpus.fk
      learn/tests/coherence-network-self-corpus-band.fk)
    (verdict 8191))

  (honest-boundary
    "This proves corpus readiness and target selection from observed local files.
     It does not yet read the JSON values through fkwu in this repo, generate the
     missing locale bundles, or run the audio/text roundtrip receipt over those
     rows. Those are the next carriers."))
