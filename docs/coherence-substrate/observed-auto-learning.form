# observed-auto-learning.form -- live observation as the learning algorithm

(observed-auto-learning

  (lineage
    (somatic-loop somatic-coherence-loop.form
                  "ground, attune, consent, move small, integrate, witness before action")
    (router form-cli-router.fk
            "a-priori route choice over sovereignty, trust, capability, confidence")
    (sufficiency form-cli-sufficiency.fk
                 "posterior accept/retry/escalate after the local lane speaks")
    (ab learn/champion-challenger.fk
        "lineage for promoting a Form-native challenger only after proven head-to-head evidence")
    (control control/offer-ack-core.fk
             "fail, stop/cut, choice, try/undo, async/timeout are one offer/ack family"))

  (claim
    "Yes: auto-ML and auto-research with live observation change the algorithm.
     The learner is no longer a batch optimizer that chooses the highest score.
     It is an online experimental controller whose action depends on witnessed
     state, reversible controls, and A/B receipts.")

  (loop
    (sense     "read the live field: body state, route evidence, posterior quality, A/B window")
    (gate      "scl-next can halt everything at ground/attune/consent/integrate/witness")
    (control   "choice-open/fail/cut/undo/timeout can hold, stop, prune, roll back, or treat silence as nothing")
    (route     "fcr-route names the likely lane before work starts")
    (judge     "fsuf-verdict accepts, retries, or escalates after local output exists")
    (compete   "oal-ab-authority promotes the challenger only when lowered A/B counts reach the champion over a trusted window")
    (act       "oal-next returns the next controller action")
    (receipt   "oal-receipt records mode, somatic gate, control gate, route, sufficiency, A/B authority, action")
    (learn     "the next observation becomes the next route/sufficiency/A-B window input"))

  (actions
    (ground)
    (attune)
    (ask-consent)
    (move-small)
    (integrate)
    (witness)
    (hold-choice)
    (fail-stop)
    (undo-last-change)
    (cut-branch)
    (timeout-as-nothing)
    (ab-promote-challenger)
    (retry-local)
    (ask-oracle)
    (run-local))

  (algorithm-shift
    (without-live-observation "batch-search")
    (with-live-observation "online-reversible-ab")
    (why
      "The search space includes the controller state itself: a timeout, undo, failed arm,
       cut branch, closed choice, or new A/B window changes what the learner is allowed to
       do next. That is not just new data for the same optimizer; it is a different
       control law."))

  (runnable
    (cell form/form-stdlib/observed-auto-learning.fk)
    (band form/form-stdlib/tests/observed-auto-learning-band.fk)
    (concat
      form/form-stdlib/somatic-coherence-loop.fk
      form/form-stdlib/form-cli-router.fk
      form/form-stdlib/form-cli-sufficiency.fk
      form/form-stdlib/observed-auto-learning.fk
      form/form-stdlib/tests/observed-auto-learning-band.fk)
    (verdict 4095))

  (honest-seam
    "This is now executable recipe-level wiring. The direct-source cell consumes
     the A/B window as integer counts, while learn/champion-challenger.fk remains
     the richer lineage body. The live carrier that feeds real
     timeout clocks, undo journals, route receipts, and A/B windows into this cell
     is still the next integration step; until then the band passes explicit observed
     flags and histories."))
