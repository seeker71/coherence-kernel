# speech-host-device-receipt-intake.form -- host/device observations into live receipts

(speech-host-device-receipt-intake

  (purpose
    (summary "lower local host/device speech observations into the global live receipt law")
    (boundary "closed-prompt loopback evidence trains, but does not count as open dictation or Sema live voice")
    (shared-device "a row from a shared Android device must be shared-safe before it can promote"))

  (current-observations
    (android-closed-prompt
      (platform android-arm64)
      (evidence "AAudio capture learning receipt")
      (audio-hash 446225)
      (scope "training evidence only; not global open dictation"))
    (macos-sema-live-voice
      (platform macos-arm64)
      (oracle "whisper.cpp-large-v3-turbo-metal")
      (wer 100)
      (scope "valid observation shape, no native success credit"))
    (android-shared-open-dictation
      (platform android-arm64)
      (shared-safe 0)
      (scope "observed row rejected from promotion while the device is shared")))

  (current-global-counts
    (live-open-dictation "0/3")
    (sema-live-voice "0/3")
    (authority "oracle-guide"))

  (demo-clean-device-window
    (open-dictation "3/3 mixed Mac/Android clean rows -> native-open-asr-source")
    (sema-live-voice "3/3 mixed Mac/Android clean rows -> native-sema-voice")
    (controls "local, consented, shared-safe, audio-present, fail=0, timeout=0, undo=0")
    (thresholds "WER <= 25, confidence >= 80, latency <= 2000 ms"))

  (composition
    (live-receipt-law learn/speech-live-receipt-intake.fk)
    (global-authority learn/speech-global-authority-update.fk)
    (model-selection learn/speech-authority-model-selection.fk)
    (host-device-bridge learn/speech-host-device-receipt-intake.fk)
    (test learn/tests/speech-host-device-receipt-intake-band.fk)
    (verdict 32767))

  (meaning
    (model-size "0 admitted native neural parameters")
    (native-vs-oracle "current global ASR/TTS native 0/2; demo clean device rows native 2/2")
    (next "replace the demo rows with real local Mac/Android rows as carriers emit consented audio receipts")))
