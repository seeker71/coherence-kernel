# sema-voice-trial-window-0003.form -- third scoped Sema voice challenger

(sema-voice-trial-window-0003

  (purpose
    (summary "add a third scoped TCAV voice sample with real local loopback oracle evidence")
    (boundary "moves the scoped training floor, not global live Sema voice authority"))

  (observed-local-oracle
    (render "macos say Samantha")
    (normalize "ffmpeg 16 kHz mono wav")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (device "macos-arm64-m4-max")
    (truth "Speech becomes clearer.")
    (transcript "Speech becomes clearer.")
    (wer 0)
    (wav-bytes 43638)
    (cksum 1616552855))

  (scoped-window
    (candidate "tcav-local-loopback-clearer-v3-window")
    (recipe "text-conditioned-acoustic-vocoder")
    (oracle "3/3 = 100%")
    (native "3/3 = 100%")
    (voice-quality "F0 165, warmth 82, cadence 64, breath 18")
    (route "native-sema-voice-trial-window")
    (scope "trial-window-native-not-global-live-voice"))

  (authority-boundary
    (live-sema-voice "oracle 1/1, native 0/1, native WER 100, oracle-guide")
    (combined-floor "oracle 4/4 = 100%, native 3/4 = 75%")
    (next-action "render-next-live-sema-sample-and-oracle"))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/sema-voice-trial-window.fk
      learn/sema-voice-trial-window-0002.fk
      learn/sema-voice-trial-window-0003.fk
      learn/tests/sema-voice-trial-window-0003-band.fk)
    (verdict 32767)))
