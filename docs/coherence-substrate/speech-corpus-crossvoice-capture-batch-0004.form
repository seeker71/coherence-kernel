# speech-corpus-crossvoice-capture-batch-0004.form -- screened two-voice acquisition shard

(speech-corpus-crossvoice-capture-batch-0004

  (purpose
    (summary "grow the consentful speech corpus in the host-ready cross-voice lane")
    (boundary "screened acquisition rows, not model promotion, native ASR, or native TTS authority"))

  (source
    (self-corpus "Coherence Network web/messages")
    (keys "hatiSuci.reg.enter hatiSuci.invite.heading hatiSuci.add.detailPlaceholder hatiSuci.add.button hatiSuci.market.heading")
    (locales "en de es fr pt-br")
    (voices-per-locale 2)
    (voices "Flo/Eddy local macOS voices"))

  (live-witness
    (candidate-wavs 50)
    (local-oracle-clean 35)
    (local-oracle-rejected 15)
    (observed-wav-bytes 2150026)
    (max-wer 250)
    (shards "en 10/10, de 5/10, es 7/10, fr 4/10, pt-br 9/10")
    (local-oracle "whisper.cpp large-v3-turbo on local Metal"))

  (aggregate-after
    (live-wav-rows 191)
    (observed-wav-bytes 6806882)
    (captured-corpus-admitted-rows 99)
    (data-sufficient-training false)
    (native-neural-parameters 0))

  (runnable
    (static-band
      (concat
        observe/stt-wer.fk
        observe/wav-sense.fk
        learn/macos-sema-teacher-acoustic-learning.fk
        learn/coherence-network-self-corpus.fk
        learn/speech-model-metrics-report.fk
        learn/speech-learning-data-sufficiency.fk
        learn/speech-corpus-acquisition-window.fk
        learn/tests/speech-corpus-crossvoice-capture-batch-0004-band.fk)
      (verdict 8191))
    (live-shard-summaries
      (encoding "count*1e15 + ok*1e12 + max_wer*1e9 + wav_bytes")
      (en 10010025000451904)
      (de 10005250000468296)
      (es 10007166000404394)
      (fr 10004133000350394)
      (pt-br 10009033000475038))))
