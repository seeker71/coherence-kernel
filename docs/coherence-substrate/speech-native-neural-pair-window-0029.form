# speech-native-neural-pair-window-0029.form -- zh<->es neural pair window

(speech-native-neural-pair-window-0029

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "zh")
    (b "es")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "zh->es, es->zh, zh->zh, es->es"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (chinese
      (voice "Tingting")
      (truth "我在")
      (heard "我在。")
      (wer 0)
      (wav-bytes 15064)
      (cksum 3568659029))
    (spanish
      (voice "Eddy (Spanish (Spain))")
      (truth "yo soy")
      (heard "Yo soy.")
      (wer 0)
      (wav-bytes 26644)
      (cksum 889626998)))

  (result
    (cumulative-neural-pairs 29)
    (cumulative-directed-routes 58)
    (epochs 29)
    (native-neural-params 29)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0029-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0029.fk
      learn/tests/speech-native-neural-pair-window-0029-band.fk)
    (verdict 32767)))
