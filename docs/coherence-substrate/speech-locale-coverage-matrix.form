# speech-locale-coverage-matrix.form -- per-locale speech coverage

(speech-locale-coverage-matrix

  (locale-counts
    (total 13)
    (ready 11)
    (live-anchor-or-carrier-live 8)
    (consent-pending 2))

  (live-anchors
    (en-de "100% native")
    (en-es "100% native")
    (en-id "100% native")
    (en-fr "100% native")
    (en-it "100% native")
    (en-zh "10/12 = 83% native")
    (en-ar "12/12 = 100% native"))

  (seeded-native
    (zh-ar "seeded multiseed native")
    (sa-la "seeded multiseed native")
    (fr-id "seeded multiseed native"))

  (oracle-held
    (live-open-dictation "native 0/4, oracle-guide")
    (sema-live-voice "oracle 1/1, native 0/1, native WER 100, oracle-guide"))

  (consent
    (nv "pending consentful corpus")
    (chr "pending consentful corpus"))

  (runnable
    (concat
      learn/speech-locale-coverage-matrix.fk
      learn/tests/speech-locale-coverage-matrix-band.fk)
    (verdict 32767)))
