# speech-native-neural-pair-window-0021.form -- es<->id neural pair window

(speech-native-neural-pair-window-0021

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "es")
    (b "id")
    (meaning 301)
    (baseline "sarve-bhavantu-sukhinah")
    (directions "es->id, id->es, es->es, id->id"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (spanish
      (voice "Flo (Spanish (Mexico))")
      (truth "que todos sean felices")
      (heard "Que todos seamos felices")
      (wer 25)
      (wav-bytes 54628))
    (indonesian
      (voice "Damayanti")
      (truth "semoga semua bahagia")
      (heard "Semoga semua bahagia")
      (wer 0)
      (wav-bytes 53790)))

  (result
    (cumulative-neural-pairs 21)
    (cumulative-directed-routes 42)
    (epochs 21)
    (native-neural-params 21)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0021-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0021.fk
      learn/tests/speech-native-neural-pair-window-0021-band.fk)
    (verdict 32767)))
