# multilocale-audio2audio-acoustic-sweep.form -- diverse decoded audio to target acoustic frames

(multilocale-audio2audio-acoustic-sweep

  (lineage
    (baseline learn/sanskrit-locale-baseline.fk
              "ready locale-neutral rows for sa/en/de/es/fr/id/pt-br/la/zh/ar")
    (bridge learn/native-audio2audio-acoustic-bridge.fk
            "decoded source tokens become target-locale acoustic frames")
    (target-vocoder learn/text-conditioned-acoustic-vocoder.fk
                    "target locale tokens render as metadata-conditioned source-filter frames")
    (sweep learn/multilocale-audio2audio-acoustic-sweep.fk
           "five reciprocal baseline pairs share the same local-oracle route rule"))

  (pairs
    (pair "en<->de")
    (pair "en<->es")
    (pair "zh<->ar")
    (pair "fr<->id")
    (pair "sa<->la"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      observe/speech-token-stream.fk
      learn/sanskrit-locale-baseline.fk
      learn/text-conditioned-acoustic-vocoder.fk
      learn/native-audio2audio-acoustic-bridge.fk
      learn/multilocale-audio2audio-acoustic-sweep.fk
      learn/tests/multilocale-audio2audio-acoustic-sweep-band.fk)
    (verdict 32767))

  (honest-boundary
    "This is still decoded-token audio2audio, not live open microphone
     authority. It broadens the target acoustic bridge over diverse baseline
     pairs with local-oracle source and target transcript gates, while live
     segmented source-audio receipts remain the next authority step."))
