# metal-live-pair-anchors.form -- live macOS Metal anchor set

(metal-live-pair-anchors

  (lineage
    (carrier presence/macos-speech-roundtrip-carrier.fk
             "base Form-owned macOS local speech carrier")
    (en-es-variant presence/macos-en-es-speech-roundtrip-variant.fk
                   "overrides the base carrier to observe English <-> Spanish")
    (en-id-variant presence/macos-en-id-speech-roundtrip-variant.fk
                   "overrides the base carrier to observe English <-> Indonesian")
    (en-fr-variant presence/macos-en-fr-speech-roundtrip-variant.fk
                   "overrides the base carrier to observe English <-> French")
    (en-it-variant presence/macos-en-it-speech-roundtrip-variant.fk
                   "overrides the base carrier to observe English <-> Italian")
    (en-zh-variant presence/macos-en-zh-speech-roundtrip-variant.fk
                   "overrides the base carrier to observe English <-> Chinese")
    (bridge learn/metal-observed-sweep-bridge.fk
            "anchor readiness law")
    (anchors learn/metal-live-pair-anchors.fk
             "counts live reciprocal Metal pair anchors"))

  (anchors
    (en-de
      (samples 12)
      (oracle-ok 10)
      (before-native-rate 0)
      (after-native-rate 83)
      (a-to-b-rate 66)
      (b-to-a-rate 100)
      (shifted 1))
    (en-es
      (samples 12)
      (oracle-ok 12)
      (before-native-rate 0)
      (after-native-rate 100)
      (a-to-b-rate 100)
      (b-to-a-rate 100)
      (shifted 1))
    (en-id
      (samples 12)
      (oracle-ok 12)
      (before-native-rate 0)
      (after-native-rate 100)
      (a-to-b-rate 100)
      (b-to-a-rate 100)
      (shifted 1))
    (en-fr
      (samples 12)
      (oracle-ok 10)
      (before-native-rate 0)
      (after-native-rate 83)
      (a-to-b-rate 100)
      (b-to-a-rate 66)
      (shifted 1))
    (en-it
      (samples 12)
      (oracle-ok 12)
      (before-native-rate 0)
      (after-native-rate 100)
      (a-to-b-rate 100)
      (b-to-a-rate 100)
      (shifted 1))
    (en-zh
      (samples 12)
      (oracle-ok 10)
      (before-native-rate 0)
      (after-native-rate 83)
      (a-to-b-rate 66)
      (b-to-a-rate 100)
      (shifted 1)))

  (authority
    (observed-live-pairs 6)
    (target-live-pairs 6)
    (next-live-needed 0)
    (route "full-metal-native")
    (scope "closed-prompt local audio-locale carrier")
    (still-pending "live Arabic-script anchor, open dictation, and native neural ASR/TTS"))

  (runnable
    (form-band
      (concat
        learn/metal-observed-sweep-bridge.fk
        learn/metal-live-pair-anchors.fk
        learn/tests/metal-live-pair-anchors-band.fk)
      (verdict 32767))
    (live-en-es
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        presence/macos-speech-roundtrip-carrier.fk
        presence/macos-en-es-speech-roundtrip-variant.fk)
      (verdict 511)
      (route-shift 1012120012010001)
      (field-code 12121210001000100))
    (live-en-id
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        presence/macos-speech-roundtrip-carrier.fk
        presence/macos-en-id-speech-roundtrip-variant.fk)
      (verdict 511)
      (base-field-code 12120000000000000)
      (field-code 12121210001000100)
      (honest-boundary "Indonesian train/eval use the same local Damayanti voice on this device."))
    (live-en-fr
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        presence/macos-speech-roundtrip-carrier.fk
        presence/macos-en-fr-speech-roundtrip-variant.fk)
      (verdict 511)
      (base-field-code 12100000000000000)
      (field-code 12101008301000066)
      (honest-boundary "French prompts were witnessed as ASCII; Unicode tokenization is now present for the next live anchors."))
    (live-en-it
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        presence/macos-speech-roundtrip-carrier.fk
        presence/macos-en-it-speech-roundtrip-variant.fk)
      (verdict 511)
      (base-field-code 12120000000000000)
      (field-code 12121210001000100)
      (honest-boundary "Italian prompts were witnessed as ASCII; Unicode tokenization is now present for the next live anchors."))
    (live-en-zh
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        presence/macos-speech-roundtrip-carrier.fk
        presence/macos-en-zh-speech-roundtrip-variant.fk)
      (verdict 511)
      (field-code 121010836700)
      (posttrain-native-rate 83)
      (ab-rate 66)
      (ba-rate 100)
      (honest-boundary "Chinese uses local Tingting train and Eddy zh_CN eval voices; Arabic remains pending on this Mac until a local voice or carrier exists.")))

  (honest-boundary
    "Six live reciprocal audio pairs have crossed the floor on local Apple
     Metal, so the closed-prompt audio-locale carrier can route
     full-metal-native. This is not open dictation and does not remove the
     pending live Arabic-script anchor and native neural speech work."))
