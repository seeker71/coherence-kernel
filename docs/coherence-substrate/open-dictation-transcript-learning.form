# open-dictation-transcript-learning.form -- free transcript ASR receipts

(open-dictation-transcript-learning

  (lineage
    (wer observe/stt-wer.fk
         "Unicode-aware tokenization and sequence WER over free transcript text")
    (promotion learn/speech-loopback-promotion.fk
               "oracle/native transcript windows route native only after clean evidence")
    (observed-auto-learning form/form-stdlib/observed-auto-learning.fk
                            "choice, cut, fail, undo, timeout, and reversible A/B mode")
    (learning learn/open-dictation-transcript-learning.fk
              "Form-owned law for side-channel truth, local oracle transcript, optional native candidate, and route")
    (token-stream observe/speech-token-stream.fk
                  "special tokens and voice-side metadata can accompany the transcript")
    (native-ctc observe/open-asr-ctc.fk
                "native CTC frame-token collapse lowers into this receipt")
    (live-source-authority learn/live-open-asr-source-authority.fk
                           "live oracle/native WER gap trains segmented source ASR")
    (multilocale-source-window learn/multilocale-segmented-source-window.fk
                               "diverse reciprocal segmented source-ASR window for the training target")
    (macos-carrier presence/macos-open-dictation-carrier.fk
                   "local say -> wav -> Whisper Metal open transcript receipt"))

  (receipt-shape
    (truth "side-channel utterance text, consentful and explicit")
    (oracle "local free transcript from Whisper on device Metal")
    (native "optional native open-ASR transcript candidate; absent today")
    (audio "nonzero audio hash, sample rate, and channel count")
    (controls "choice-open, cut, fail, timeout, undo")
    (route "oracle until a native local transcript candidate wins a clean window"))

  (runnable
    (form-band
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        form/form-stdlib/observed-auto-learning.fk
        learn/open-dictation-transcript-learning.fk
        learn/tests/open-dictation-transcript-learning-band.fk)
      (verdict 16383))
    (carrier-contract-band
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        form/form-stdlib/observed-auto-learning.fk
        learn/open-dictation-transcript-learning.fk
        presence/macos-open-dictation-carrier.fk
        presence/tests/macos-open-dictation-carrier-band.fk)
      (verdict 511))
    (live-macos-metal
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        form/form-stdlib/observed-auto-learning.fk
        learn/open-dictation-transcript-learning.fk
        presence/macos-open-dictation-carrier.fk)
      (call modc-run)
      (verdict 511)
      (field-code 440000100)
      (meaning "4 rows, 4 oracle successes, 0 native successes, oracle WER 0, native WER 100"))
    (live-open-asr-source-authority
      (concat
        learn/live-open-asr-source-authority.fk
        learn/tests/live-open-asr-source-authority-band.fk)
      (verdict 32767)
      (action "train-live-segmented-open-asr-source"))
    (multilocale-segmented-source-window
      (concat
        observe/stt-wer.fk
        observe/speech-token-stream.fk
        observe/open-asr-ctc.fk
        observe/acoustic-token-emitter.fk
        learn/sanskrit-locale-baseline.fk
        learn/segmented-acoustic-token-learning.fk
        learn/multilocale-segmented-source-window.fk
        learn/tests/multilocale-segmented-source-window-band.fk)
      (verdict 32767)))

  (honest-boundary
    "This is open transcript ingestion and live local oracle measurement, not
     native open ASR. It removes the closed prompt-ID assumption from the
     receipt shape and now turns the live oracle/native WER gap into a segmented
     source-ASR training action with a multilocale source window ready to receive
     that training. Native authority still waits for a local native
     transcript or token stream that lowers to passing text."))
