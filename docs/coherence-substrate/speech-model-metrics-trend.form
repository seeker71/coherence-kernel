# speech-model-metrics-trend.form -- before/after speech model movement

(speech-model-metrics-trend

  (rows
    (mac-metal-reciprocal-audio
      (before-native 0)
      (after-native 83)
      (route "oracle-guide -> native"))
    (multiseed-nl-audio
      (before-native 0)
      (after-native 100)
      (route "oracle-guide -> native"))
    (live-open-dictation
      (local-oracle 100)
      (native 0)
      (route "oracle-guide"))
    (sema-live-voice
      (local-oracle 100)
      (native 0)
      (wer 100)
      (route "oracle-guide")))

  (aggregate
    (rows 4)
    (shifted-native 2)
    (oracle-held 2)
    (average-native-rate 45)
    (neural-ready 0))

  (runnable
    (concat
      learn/speech-model-metrics-trend.fk
      learn/tests/speech-model-metrics-trend-band.fk)
    (verdict 32767))

  (honest-boundary
    "Native authority has shifted where the rows are reciprocal, closed, or
     seeded. Live open dictation and the live Sema voice remain oracle-guided."))
