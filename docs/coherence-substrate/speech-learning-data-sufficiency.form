# speech-learning-data-sufficiency.form -- current data is too small

(speech-learning-data-sufficiency

  (purpose
    (summary "prevent tiny live speech receipts from being mistaken for real model training")
    (boundary "current rows prove observation and prototype plumbing, not data-sufficient ASR/TTS/NL/audio authority"))

  (current
    (live-wav-rows 141)
    (live-locales 6)
    (held-out-repeat-rows 7)
    (cross-phrase-rows 6)
    (cross-voice-rows 6)
    (native-neural-parameters 0))

  (minimum-floor
    (live-teacher-wavs 12000)
    (live-teacher-locales 6)
    (held-out-rows 1200)
    (cross-phrase-rows 1000)
    (cross-voice-rows 300))

  (status
    (data-sufficient-training false)
    (name "tiny-corpus-not-data-sufficient-training")
    (next "expand consentful captured wav rows, held-out rows, cross-phrase rows, and cross-voice rows before claiming real training"))

  (scale-gap
    (wav-deficit 11859)
    (wav-floor-basis-points 117)
    (held-out-deficit 1193)
    (cross-phrase-deficit 994)
    (cross-voice-deficit 294)
    (promotion false)
    (meaning "instrumentation smoke, not model learning"))

  (runnable
    (concat
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/tests/speech-learning-data-sufficiency-band.fk)
    (verdict 65535)))
