# speech-learning-data-sufficiency.form -- current data is too small

(speech-learning-data-sufficiency

  (purpose
    (summary "prevent tiny live speech receipts from being mistaken for real model training")
    (boundary "current rows prove observation and prototype plumbing, not data-sufficient ASR/TTS/NL/audio authority"))

  (current
    (live-wav-rows 35)
    (live-locales 6)
    (held-out-repeat-rows 1)
    (cross-phrase-rows 0)
    (cross-voice-rows 0)
    (native-neural-parameters 0))

  (minimum-floor
    (live-teacher-wavs 300)
    (live-teacher-locales 5)
    (held-out-rows 30)
    (cross-phrase-rows 20)
    (cross-voice-rows 10))

  (status
    (data-sufficient-training false)
    (name "plumbing-smoke-not-data-sufficient-training")
    (next "expand captured wav rows and held-out/cross-phrase/cross-voice rows before claiming real training"))

  (runnable
    (concat
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/tests/speech-learning-data-sufficiency-band.fk)
    (verdict 32767)))
