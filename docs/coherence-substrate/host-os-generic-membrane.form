# host-os-generic-membrane.form

(host-os-generic-membrane

  (lineage
    (target-catalog form/form-stdlib/hati-os-targets.fk
      "supported target triples and per-OS carrier mappings")
    (membrane form/form-stdlib/host-os-membrane.fk
      "the Form-owned platform/carrier/seed-shrink authority")
    (band form/form-stdlib/tests/host-os-membrane-band.fk
      "direct-source witness for the membrane")
    (speech-contract presence/speech-loopback-carrier-receipt.fk
      "local TTS/STT loopback facts accepted by the body")
    (bootstrap-runtime runtime/fkwu-uni.c
      "temporary checkout witness and shrink target"))

  (principle
    (body-is-form "policy, routing, receipt law, promotion, rejection, and target status live in Form")
    (carrier-is-host "OS driver/kernel/API calls are swappable resource carriers behind typed doors")
    (metal-is-observed "a platform row promotes only by running on the device and returning a receipt")
    (c-seed-shrinks "C remains a checkout witness until Form-native source runner and per-target emitters retire it"))

  (supported-platforms
    (macos-arm64
      (metal observed)
      (direct-source observed)
      (carrier-family CoreAudio AVFoundation Metal POSIX)
      (speech-loopback concrete-carrier-pending))
    (windows-amd64
      (metal observed)
      (direct-source observed)
      (carrier-family Win32 Winsock WinMM AVICap WinHTTP)
      (speech-loopback concrete-carrier-pending))
    (windows-arm64
      (target named)
      (metal receipt-pending)
      (carrier-family Win32 WASAPI MediaFoundation DirectML)
      (speech-loopback concrete-carrier-pending))
    (android-arm64
      (metal observed)
      (direct-source observed)
      (carrier-family POSIX AAudio AudioRecord AudioTrack Camera2 SensorManager)
      (speech-loopback concrete-carrier-pending)))

  (doors
    (host:file storage-port-file local-only)
    (http:request http-client-exchange local-or-network)
    (audio:pcm16 host-os-local-audio-receipt local-only)
    (video:rgba-time host-os-local-video-receipt local-only)
    (speech:loopback speech-loopback-carrier-receipt local-only))

  (seed-shrink
    (checkout-c-seed
      (status temporary)
      (keeps fresh-checkout-grounding)
      (next direct-source-runner-in-form))
    (input-byte-eof-guard
      (status bounded-checkout-repair)
      (why Android table-loop EOF must return 0 like macOS and Windows)
      (next form-owned-staged-input))
    (native-walker
      (status destination)
      (c-owned false)
      (next form-macho-elf-pe-bootstrap)))

  (runnable
    (concat
      form/form-stdlib/hati-os-targets.fk
      form/form-stdlib/host-os-membrane.fk
      form/form-stdlib/tests/host-os-membrane-band.fk)
    (verdict 8191))

  (honest-boundary
    "This brings the platform membrane home as Form law and repairs the Android staged-input EOF
     carrier in the temporary C seed, and Android arm64 direct source has now emitted a fresh
     phone-metal receipt. It does not claim that CoreAudio/WASAPI/AAudio, native Whisper/Piper,
     or Windows-on-ARM have emitted fresh loopback receipts yet. Those promote only by device-metal
     receipts through this membrane."))
