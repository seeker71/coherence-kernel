# speech-corpus-crossphrase-learning.form -- controlled cross-phrase transfer

(speech-corpus-crossphrase-learning

  (purpose
    (summary "prove a first controlled same-locale different-phrase acoustic transfer")
    (boundary "native Form beats explicit controls on scoped rows; this is not open ASR, cross-voice authority, native TTS, or global speech authority"))

  (live-witness
    (pairs 6)
    (oracle "6/6")
    (native "6/6")
    (max-wer 25)
    (observed-wav-bytes 712626)
    (local-oracle "whisper.cpp large-v3-turbo on local Metal")
    (native-test "eval phrase envelope is closer to same-locale different-phrase prototype than to explicit different-locale control"))

  (aggregate-after
    (live-wav-rows 123)
    (observed-wav-bytes 3901796)
    (cross-phrase-rows 6)
    (cross-phrase-floor 1000)
    (cross-voice-rows 0)
    (native-neural-parameters 0)
    (data-sufficient-training false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-corpus-crossphrase-learning.fk
      learn/tests/speech-corpus-crossphrase-learning-band.fk)
    (verdict 65535)))
