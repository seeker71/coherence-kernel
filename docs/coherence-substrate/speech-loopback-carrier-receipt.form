# speech-loopback-carrier-receipt.form -- contract for real local TTS/STT loopback

(speech-loopback-carrier-receipt

  (lineage
    (wer observe/stt-wer.fk
         "sequence-aligned transcript error")
    (promotion learn/speech-loopback-promotion.fk
               "rolling native/oracle authority windows")
    (carrier-receipt presence/speech-loopback-carrier-receipt.fk
                     "local audio metadata + oracle/native transcripts -> promotion sample")
    (carrier-run presence/speech-loopback-carrier-run.fk
                 "platform readiness + native loopback + carrier receipt + A/B run row")
    (capture-learning learn/speech-loopback-capture-learning.fk
                      "real on-device render/capture evidence moves native toward the oracle prompt")
    (host-membrane form/form-stdlib/host-os-membrane.fk
                   "per-platform audio/speech doors, observed rows, and pending carriers"))

  (carrier-responsibility
    (render-local "local TTS only: say, Piper, or another local carrier; no cloud")
    (capture-local "speaker/mic or virtual loopback capture on the same machine")
    (hash-audio "stable nonzero audio hash, sample rate, channel count")
    (oracle-local "local STT oracle only: whisper.cpp, MLX Whisper, or equivalent local carrier")
    (pass-facts "truth words, oracle words, native words, confidence, latency, fail, timeout, undo"))

  (platform-carriers
    (macos-arm64 "CoreAudio/AVFoundation render + capture; concrete loopback receipt pending")
    (windows-amd64 "WASAPI/MediaFoundation or existing WinMM-family carrier; concrete loopback receipt pending")
    (windows-arm64 "WASAPI/MediaFoundation target row; first metal receipt pending")
    (android-arm64 "AAudio render/capture learning receipt observed; open ASR and app carrier still pending"))

  (body-responsibility
    (reject-cloud "tts-local and stt-local must both be 1")
    (reject-missing-audio "audio hash, sample rate, and channel count must be present")
    (score "oracle and native WER are computed in Form")
    (control "fail, timeout, undo become promotion control debt")
    (promote "valid clean windows can route native; invalid windows route oracle")
    (run-row "carrier readiness and recipe A/B decisions stay inspectable as Form data"))

  (runnable
    (cell presence/speech-loopback-carrier-receipt.fk)
    (band presence/tests/speech-loopback-carrier-receipt-band.fk)
    (concat
      observe/stt-wer.fk
      learn/speech-loopback-promotion.fk
      presence/speech-loopback-carrier-receipt.fk
      presence/tests/speech-loopback-carrier-receipt-band.fk)
    (verdict 4095)
    (carrier-run
      (concat
        form/form-stdlib/hati-os-targets.fk
        form/form-stdlib/host-os-membrane.fk
        observe/stt-wer.fk
        presence/formant-vocoder.fk
        observe/asr-prompt-id.fk
        presence/native-speech-loopback.fk
        learn/speech-loopback-promotion.fk
        presence/speech-loopback-carrier-receipt.fk
        presence/speech-loopback-carrier-run.fk
        presence/tests/speech-loopback-carrier-run-band.fk)
      (verdict 511))
    (carrier-run-ab
      (concat
        form/form-stdlib/hati-os-targets.fk
        form/form-stdlib/host-os-membrane.fk
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        presence/speech-loopback-carrier-receipt.fk
        learn/speech-loopback-recipe-ab.fk
        presence/speech-loopback-carrier-run.fk
        learn/tests/speech-loopback-carrier-run-ab-band.fk)
      (verdict 2047))
    (capture-learning
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        learn/speech-loopback-capture-learning.fk
        learn/tests/speech-loopback-capture-learning-band.fk)
      (verdict 8191)))

  (honest-boundary
    "This does not implement CoreAudio/AVFoundation, WASAPI, Piper, say, or
     whisper.cpp invocation. Android AAudio render/capture now has a closed-prompt
     learning receipt; open ASR and natural TTS remain pending."))
