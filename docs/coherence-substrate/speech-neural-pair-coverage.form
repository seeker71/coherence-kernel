# speech-neural-pair-coverage.form -- neural pair coverage boundary

(speech-neural-pair-coverage

  (purpose
    (summary "separate locale A => neural => locale B from Form-native reciprocal learning windows")
    (boundary "no seeded pair, live anchor, prototype window, or oracle-guided bridge counts as neural training"))

  (neural-coverage
    (trained-unordered-pairs 36)
    (trained-directed-pairs 72)
    (neural-training-epochs 36)
    (native-neural-parameters 36)
    (broad-ready-pair-space 55)
    (broad-ready-directed-space 110)
    (coverage-basis-points 6545))

  (form-native-coverage
    (seeded-reciprocal-pair-windows 8)
    (directed-cross-locale-directions 16)
    (roundtrip-lanes "32 A->B, B->A, A->A, and B->B lanes across NL and audio windows")
    (ready-rate 100)
    (broad-ready-coverage-basis-points 1454)
    (sanskrit-baseline-pair-space 55)
    (sanskrit-baseline-directed-space 110)
    (sanskrit-baseline-coverage-basis-points 1454)
    (status "Form-native/prototype/closed-set learning, not neural"))

  (observed-pairs
    (form-windows "zh<->ar, en<->id, sa<->la, fr<->id, pt-br<->zh, en<->de, en<->es, en<->fr")
    (segmented-source "sa<->la, en<->zh, ar<->en")
    (live-metal-anchors "en<->de, en<->es, en<->id, en<->fr, en<->it, en<->zh, en<->ar")
    (audio-nl2nl-bridges "12 oracle-guided A/B routes, not native vocoder and not neural"))

  (trained-neural-pairs
    (micro-pair-windows "en<->fr, en<->pt-br, en<->id, en<->zh, en<->ar, en<->la, en<->de, en<->es, en<->sa, zh<->ar, sa<->la, zh<->sa, ar<->sa, zh<->la, ar<->la, de<->es, de<->fr, de<->id, de<->pt-br, es<->fr, es<->id, es<->pt-br, fr<->pt-br, id<->pt-br, fr<->id, fr<->zh, zh<->pt-br, zh<->de, zh<->es, zh<->id, en<->it, de<->it, fr<->ar, fr<->sa, fr<->la, fr<->it")
    (files "learn/speech-native-neural-pair-window-0001.fk, learn/speech-native-neural-pair-window-0002.fk, learn/speech-native-neural-pair-window-0003.fk, learn/speech-native-neural-pair-window-0004.fk, learn/speech-native-neural-pair-window-0005.fk, learn/speech-native-neural-pair-window-0006.fk, learn/speech-native-neural-pair-window-0007.fk, learn/speech-native-neural-pair-window-0008.fk, learn/speech-native-neural-pair-window-0009.fk, learn/speech-native-neural-pair-window-0010.fk, learn/speech-native-neural-pair-window-0011.fk, learn/speech-native-neural-pair-window-0012.fk, learn/speech-native-neural-pair-window-0013.fk, learn/speech-native-neural-pair-window-0014.fk, learn/speech-native-neural-pair-window-0015.fk, learn/speech-native-neural-pair-window-0016.fk, learn/speech-native-neural-pair-window-0017.fk, learn/speech-native-neural-pair-window-0018.fk, learn/speech-native-neural-pair-window-0019.fk, learn/speech-native-neural-pair-window-0020.fk, learn/speech-native-neural-pair-window-0021.fk, learn/speech-native-neural-pair-window-0022.fk, learn/speech-native-neural-pair-window-0023.fk, learn/speech-native-neural-pair-window-0024.fk, learn/speech-native-neural-pair-window-0025.fk, learn/speech-native-neural-pair-window-0026.fk, learn/speech-native-neural-pair-window-0027.fk, learn/speech-native-neural-pair-window-0028.fk, learn/speech-native-neural-pair-window-0029.fk, learn/speech-native-neural-pair-window-0030.fk, learn/speech-native-neural-pair-window-0031.fk, learn/speech-native-neural-pair-window-0032.fk, learn/speech-native-neural-pair-window-0033.fk, learn/speech-native-neural-pair-window-0034.fk, learn/speech-native-neural-pair-window-0035.fk, learn/speech-native-neural-pair-window-0036.fk")
    (boundary "non-zero trained pair coverage, not full open ASR/TTS authority"))

  (runnable
    (concat
      learn/speech-neural-pair-coverage.fk
      learn/tests/speech-neural-pair-coverage-band.fk)
    (verdict 32767)))
