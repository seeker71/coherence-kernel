# speech-neural-pair-coverage.form -- neural pair coverage boundary

(speech-neural-pair-coverage

  (purpose
    (summary "separate locale A => neural => locale B from Form-native reciprocal learning windows")
    (boundary "no seeded pair, live anchor, prototype window, or oracle-guided bridge counts as neural training"))

  (neural-coverage
    (trained-unordered-pairs 3)
    (trained-directed-pairs 6)
    (neural-training-epochs 3)
    (native-neural-parameters 3)
    (broad-ready-pair-space 55)
    (broad-ready-directed-space 110)
    (coverage-basis-points 545))

  (form-native-coverage
    (seeded-reciprocal-pair-windows 8)
    (directed-cross-locale-directions 16)
    (roundtrip-lanes "32 A->B, B->A, A->A, and B->B lanes across NL and audio windows")
    (ready-rate 100)
    (broad-ready-coverage-basis-points 1454)
    (sanskrit-baseline-pair-space 45)
    (sanskrit-baseline-directed-space 90)
    (sanskrit-baseline-coverage-basis-points 1777)
    (status "Form-native/prototype/closed-set learning, not neural"))

  (observed-pairs
    (form-windows "zh<->ar, en<->id, sa<->la, fr<->id, pt-br<->zh, en<->de, en<->es, en<->fr")
    (segmented-source "sa<->la, en<->zh, ar<->en")
    (live-metal-anchors "en<->de, en<->es, en<->id, en<->fr, en<->it, en<->zh, en<->ar")
    (audio-nl2nl-bridges "12 oracle-guided A/B routes, not native vocoder and not neural"))

  (trained-neural-pairs
    (micro-pair-windows "en<->fr, en<->pt-br, en<->id")
    (files "learn/speech-native-neural-pair-window-0001.fk, learn/speech-native-neural-pair-window-0002.fk, learn/speech-native-neural-pair-window-0003.fk")
    (boundary "non-zero trained pair coverage, not full open ASR/TTS authority"))

  (runnable
    (concat
      learn/speech-neural-pair-coverage.fk
      learn/tests/speech-neural-pair-coverage-band.fk)
    (verdict 32767)))
