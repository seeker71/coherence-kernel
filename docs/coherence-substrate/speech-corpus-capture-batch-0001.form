# speech-corpus-capture-batch-0001.form -- first captured self-corpus audio rows

(speech-corpus-capture-batch-0001

  (purpose
    (summary "render and oracle-check six consentful self-corpus rows as real local audio")
    (boundary "captured corpus audio, not data-sufficient training and not model promotion"))

  (rows
    (en common.tryAgain "Try again" "Flo (English (US))" "en")
    (de common.tryAgain "Erneut versuchen" "Flo (German (Germany))" "de")
    (es nav.search "Buscar" "Flo (Spanish (Spain))" "es")
    (fr nav.vision "Vision" "Amélie" "fr")
    (id common.tryAgain "Coba lagi" "Damayanti" "id")
    (pt-br common.tryAgain "Tentar novamente" "Flo (Portuguese (Brazil))" "pt"))

  (observed-live
    (captured-rows 6)
    (oracle-accepted-rows 6)
    (max-wer 0)
    (wav-bytes 212524)
    (locales 6)
    (status "captured-corpus-audio-not-training-sufficient"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/coherence-network-self-corpus.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-corpus-acquisition-window.fk
      learn/speech-corpus-capture-batch-0001.fk
      learn/tests/speech-corpus-capture-batch-0001-band.fk)
    (contract-verdict 4095)
    (live-verdict 4095)
    (live-verdict-function sccb-run-verdict)))
