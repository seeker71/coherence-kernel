# speech-authority-model-selection.form -- live-authority model arm selector

(speech-authority-model-selection

  (purpose
    (summary "make global live receipt authority choose the ASR/TTS model arms")
    (boundary "scoped trial windows may train and cut challengers, but do not promote global speech authority")
    (native-neural-weight-parameters-admitted 0))

  (current-selection
    (asr "prototype-asr")
    (asr-authority "oracle-guide")
    (tts "sema-voice-sample-loop")
    (tts-authority "oracle-guide")
    (nl2nl "closed-set-locale-form")
    (nl2nl-authority "native-form-anchor")
    (audio2audio "native-source-window-audio2audio-acoustic")
    (audio2audio-authority "metal-scoped-native")
    (global-speech-native "0/2")
    (missing-real-live-receipts 6)
    (selected-arms 4))

  (promotion-demo
    (asr "native-open-asr-source")
    (tts "native-sema-voice")
    (condition "3/3 clean real live receipts per speech lane")
    (thresholds "WER <= 25, confidence >= 80, latency <= 2000 ms")
    (controls "choice, cut, fail, undo, timeout clean")
    (global-speech-native "2/2")
    (missing-real-live-receipts 0))

  (composition
    (metrics learn/speech-model-metrics-report.fk)
    (authority-update learn/speech-global-authority-update.fk)
    (selector learn/speech-authority-model-selection.fk)
    (test learn/tests/speech-authority-model-selection-band.fk)
    (verdict 32767))

  (meaning
    (current "0 native neural parameters and 0/2 live speech authority, while native Form organs stay present")
    (success "when live receipts satisfy the same law, ASR/TTS move to native routes without changing C seed")
    (next "feed real local device receipts into live receipt intake so current selection, not demo selection, moves")))
