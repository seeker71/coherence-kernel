# speech-native-neural-pair-window-0028.form -- zh<->de neural pair window

(speech-native-neural-pair-window-0028

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "zh")
    (b "de")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "zh->de, de->zh, zh->zh, de->de"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (chinese
      (voice "Tingting")
      (truth "我在")
      (heard "我在。")
      (wer 0)
      (wav-bytes 15064)
      (cksum 3568659029))
    (german
      (voice "Eddy (German (Germany))")
      (truth "ich bin")
      (heard "Ich bin")
      (wer 0)
      (wav-bytes 29216)
      (cksum 2691094203)))

  (result
    (cumulative-neural-pairs 28)
    (cumulative-directed-routes 56)
    (epochs 28)
    (native-neural-params 28)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0028-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0028.fk
      learn/tests/speech-native-neural-pair-window-0028-band.fk)
    (verdict 32767)))
