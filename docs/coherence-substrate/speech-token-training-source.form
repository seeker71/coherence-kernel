# speech-token-training-source.form -- provenance for special speech tokens

(speech-token-training-source

  (sources
    (local-oracle
      "local Whisper/ASR over measured audio can label transcript words,
       confidence, WER grade, audio provenance, and receipt tokens")
    (consentful-corpus
      "translated corpus rows such as the Sanskrit baseline or Coherence Network
       bundles can label text words, locale scope, source, and route tokens")
    (internal-state
      "runtime state can infer voice-side metadata, controls, evidence, and
       memory/scope labels; it is metadata-only and not transcript truth"))

  (token-classes
    (identity-provenance <NODE> <SOURCE>)
    (route-contract <CHANNEL> <INTERFACE>)
    (control <CHOICE> <FAIL> <UNDO> <TIMEOUT> <CUT>)
    (evidence <OBSERVE> <GRADE> <FEEDBACK> <REPAIR> <RECEIPT>)
    (memory-scope <STATE> <MEMORY> <SCOPE>)
    (words <WORD>))

  (inference-policy
    (confidence "from measured success/route state or internal confidence")
    (warmth "from valence/frequency state")
    (cadence "from hardness/pace state")
    (hesitation "inverse confidence plus hardness")
    (excitement "from surprise/activation")
    (attunement "from groundedness plus warmth")
    (boundary "internal inference can train metadata, never transcript truth"))

  (runnable
    (concat
      observe/speech-token-stream.fk
      learn/speech-token-training-source.fk
      learn/tests/speech-token-training-source-band.fk)
    (verdict 32767)))
