# speech-model-auto-selection.form -- model search and AutoML for native speech

(speech-model-auto-selection

  (lineage
    (observed-auto-learning form/form-stdlib/observed-auto-learning.fk
                            "live observation, choice, cut, fail, undo, timeout, and A/B authority")
    (champion-challenger learn/champion-challenger.fk
                         "native challenger earns authority over the oracle champion")
    (prototype-asr observe/asr-prompt-id.fk
                   "nearest-prototype closed-set ASR over measured features")
    (open-dictation learn/open-dictation-transcript-learning.fk
                    "free transcript WER/promotion receipt for open ASR candidates")
    (token-stream observe/speech-token-stream.fk
                  "special speech tokens and voice-side metadata")
    (native-open-asr-ctc observe/open-asr-ctc.fk
                         "CTC frame-token collapse to free transcript token stream")
    (acoustic-token-emitter observe/acoustic-token-emitter.fk
                            "supervised wav/envelope feature prototypes emit CTC frames")
    (segmented-acoustic-learning learn/segmented-acoustic-token-learning.fk
                                 "segmented local-oracle wav/envelope rows teach token prototypes")
    (live-open-asr-source-authority learn/live-open-asr-source-authority.fk
                                    "live open-dictation WER miss trains segmented source ASR")
    (multilocale-segmented-source-window learn/multilocale-segmented-source-window.fk
                                         "diverse reciprocal source-ASR window over sa/la/en/zh/ar")
    (formant-vocoder presence/formant-vocoder.fk
                     "deterministic source-filter vocoder")
    (sema-voice-loop learn/sema-voice-sample-loop.fk
                     "target-fit, listener, WER, latency A/B loop over generated samples")
    (sema-voice-local-oracle learn/sema-voice-local-oracle-receipt.fk
                             "local STT bar for generated Sema voice samples")
    (sema-voice-miss-learning learn/sema-voice-oracle-miss-learning.fk
                              "live WER-100 voice miss becomes the next acoustic/vocoder training action")
    (text-conditioned-acoustic-vocoder learn/text-conditioned-acoustic-vocoder.fk
                                       "target tokens plus voice metadata become native vocoder frames")
    (native-audio2audio-acoustic-bridge learn/native-audio2audio-acoustic-bridge.fk
                                        "decoded source-audio tokens route through neutral meaning to target acoustic frames")
    (multilocale-audio2audio-acoustic-sweep learn/multilocale-audio2audio-acoustic-sweep.fk
                                            "diverse reciprocal decoded-token audio2audio rows share the target acoustic bridge")
    (metal-audio2audio-acoustic-authority learn/metal-audio2audio-acoustic-authority.fk
                                          "sweep summaries plus seven live Metal anchors select the native acoustic arm")
    (source-window-audio2audio-authority learn/source-window-audio2audio-authority.fk
                                         "segmented source-ASR window plus Metal acoustic target authority")
    (live-segmented-feature-carrier presence/live-segmented-feature-carrier.fk
                                    "observed wav/envelope rows feed native open-ASR candidate windows")
    (transformer-train model/transformer-corpus-train.fk
                       "trainable Form transformer path, not yet selected for speech")
    (selector learn/speech-model-auto-selection.fk
              "receipt-backed model family selection"))

  (selected-now
    (asr "prototype-asr" "nearest-l1-wav-feature-prototype")
    (tts "sema-voice-sample-loop" "target-fit-listener-wer-ab-formant-vocoder")
    (nl2nl "closed-set-locale-form" "token-overlap-to-neutral-meaning")
    (audio2audio "native-source-window-audio2audio-acoustic" "segmented source window -> neutral Form -> metal-witnessed acoustic target"))

  (not-selected-yet
    (native-open-asr-ctc "native decoder exists; live segmented acoustic receipts have not crossed yet")
    (native-acoustic-token-emitter "native supervised emitter exists; live segmented audio receipts have not crossed yet")
    (native-segmented-acoustic-learning "native supervised segmentation learner exists; live open-dictation now trains it, but it has not won ASR authority yet")
    (live-open-asr-source-authority "live Metal open-dictation miss now trains the segmented source path, but keeps ASR authority on the prototype")
    (multilocale-segmented-source-window "diverse reciprocal source-ASR window promotes its own receipt, but does not displace prototype ASR yet")
    (live-segmented-feature-carrier "feature-row carrier exists; real live capture windows have not displaced prototype ASR yet")
    (transformer "trainable and Form-native, but not live-selected for speech until receipts beat the closed-set route")
    (diffusion "named candidate only; no Form-native executable diffusion/codec kernel or receipt yet")
    (raw-formant-vocoder "still the native carrier, now judged through Sema's target/sample loop")
    (raw-formant-audio2audio "still present as a lower-scoring carrier route")
    (text-conditioned-acoustic-vocoder "now executable as a Form micro-kernel; not selected until local-oracle receipts improve")
    (prototype-asr-sema-voice-audio2audio "still present, now displaced by the source-window metal-witnessed acoustic route")
    (native-audio2audio-acoustic-vocoder "still present, now displaced by the integrated source-window authority row")
    (oracle "macOS say + whisper.cpp-large-v3-turbo is a local teacher/carrier, not native authority"))

  (auto-learning
    (mode "online-reversible-ab")
    (controls "choice, cut, fail, undo, timeout are first-class")
    (promotion "A/B authority can promote challenger only over a witnessed window")
    (voice-miss-action "train-text-conditioned-acoustic-vocoder while authority remains oracle-guide")
    (search "auto-research keeps candidate families visible; AutoML chooses the current arm by quality, latency, cost, and uncertainty"))

  (runnable
    (concat
      form/form-stdlib/somatic-coherence-loop.fk
      form/form-stdlib/form-cli-router.fk
      form/form-stdlib/form-cli-sufficiency.fk
      form/form-stdlib/observed-auto-learning.fk
      learn/sema-voice-local-oracle-receipt.fk
      learn/sema-voice-oracle-miss-learning.fk
      learn/live-open-asr-source-authority.fk
      learn/speech-model-auto-selection.fk
      learn/tests/speech-model-auto-selection-band.fk)
    (verdict 536870911))

  (honest-boundary
    "The selected native model today is not diffusion and not a full neural
     Whisper/Piper replacement. It is a staged native speech stack: closed-set
     ASR prototypes, open-dictation transcript receipts, native CTC/token-stream
     decoding, neutral Form meaning, a deterministic formant vocoder, and
     Sema's target-fit sample loop for choosing generated voice candidates
     in both direct TTS and audio-to-audio target rendering. The local-oracle
     Sema voice receipt defines the bar generated samples must pass before
     authority shifts. The first live Sema formant miss now changes the search:
     AutoML names a text-conditioned acoustic/vocoder bridge as the next native
     candidate, and that bridge now exists as a deterministic Form kernel while
     keeping authority on oracle-guide until transcript receipts pass. The next
     native audio2audio acoustic bridge also exists now, has a five-pair
     multilocale sweep, and now composes with the segmented source-ASR window
     into the selected source-window, metal-witnessed audio2audio arm. Open microphone source
     authority now has a live segmented feature-row carrier contract, but ASR
     selection still waits for real live source-audio receipt windows. The
     live open-dictation miss now trains that source path explicitly and the
     multilocale segmented source window proves the same source-ASR training
     shape across sa<->la, en<->zh, and ar<->en.
     Local Metal oracle receipts teach until stronger native candidates win A/B
     windows."))
