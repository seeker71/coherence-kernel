# speech-loopback-promotion.form -- witnessed native authority over speech windows

(speech-loopback-promotion

  (lineage
    (loopback presence/native-speech-loopback.fk
              "single-sample native vocoder -> prompt-ASR -> WER route")
    (promotion learn/speech-loopback-promotion.fk
               "rolling window authority: native only after clean receipts reach oracle")
    (carrier-receipt presence/speech-loopback-carrier-receipt.fk
                     "real local loopback measurements lower into promotion samples")
    (recipe-ab learn/speech-loopback-recipe-ab.fk
               "A/B recipe cutover over measured local receipt windows")
    (observed-auto-learning form/form-stdlib/observed-auto-learning.fk
                            "same algorithmic law: observed control state changes the route"))

  (window-law
    (sample "native-success oracle-success fail timeout undo")
    (native-credit "counts only clean native-success")
    (oracle-credit "counts only clean oracle-success")
    (control-debt "fail, timeout, or undo")
    (promote "samples >= min, control debt <= max, native + margin >= oracle")
    (regress "native score below floor or control debt above ceiling")
    (route-native "promote passes and regression is absent")
    (route-oracle "short window, failed window, timeout, undo, or regression"))

  (runnable
    (cell learn/speech-loopback-promotion.fk)
    (band learn/tests/speech-loopback-promotion-band.fk)
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      observe/asr-prompt-id.fk
      presence/native-speech-loopback.fk
      learn/speech-loopback-promotion.fk
      learn/tests/speech-loopback-promotion-band.fk)
    (verdict 2047))

  (carrier-contract
    (cell presence/speech-loopback-carrier-receipt.fk)
    (band presence/tests/speech-loopback-carrier-receipt-band.fk)
    (verdict 4095))

  (recipe-ab-contract
    (cell learn/speech-loopback-recipe-ab.fk)
    (band learn/tests/speech-loopback-recipe-ab-band.fk)
    (verdict 2047))

  (honest-boundary
    "This promotes the closed-set native speech lane over a receipt window. It does not
     claim open dictation, natural TTS, or live microphone/speaker carrier integration yet."))
