# speech-open-asr-trial-window-0002.form -- second scoped open-ASR challenger window

(speech-open-asr-trial-window-0002

  (scheduler learn/speech-next-trial-scheduler.fk)
  (previous-window learn/speech-open-asr-trial-window.fk)
  (baseline learn/sanskrit-locale-baseline.fk)

  (trial
    (id "trial-open-asr-0001")
    (incumbent "prototype-asr")
    (challenger "native-segmented-acoustic-learning")
    (recipe "segmented-open-asr-source-window-v1")
    (scope "second trial window, not global live ASR authority"))

  (before
    (source "speech-oracle-native-backlog")
    (local-oracle "4/4 = 100%")
    (native "0/4 = 0%")
    (route "oracle-guide"))

  (window-0002
    (added-locales "es, fr")
    (meaning 303)
    (baseline "aham asmi")
    (samples "soy / je suis")
    (oracle "2/2")
    (native "2/2")
    (controls "choice, cut, fail, undo, timeout clean"))

  (cumulative-trial-window
    (oracle "4/4")
    (native "4/4")
    (native-rate 100)
    (floor 50)
    (route "native")
    (action "cut-challenger-for-trial-window")
    (authority "open authority false"))

  (oracle "whisper.cpp-large-v3-turbo-metal")
  (device "macos-arm64-m4-max")

  (boundary
    (native-form true)
    (neural-ready false)
    (status "trial-window-native-not-global-authority")
    (meaning "this removes the scoped zero gap; it does not promote global live open ASR"))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/speech-open-asr-trial-window-0002.fk
      learn/tests/speech-open-asr-trial-window-0002-band.fk)
    (verdict 32767)))
