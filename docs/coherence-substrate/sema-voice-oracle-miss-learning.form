# sema-voice-oracle-miss-learning.form -- WER miss becomes model search

(sema-voice-oracle-miss-learning

  (lineage
    (live-probe presence/macos-sema-voice-local-oracle-carrier.fk
                "target-derived Sema formant waveform, local Whisper Metal, WER 100")
    (local-oracle-gate learn/sema-voice-local-oracle-receipt.fk
                       "the authority bar the sample failed")
    (learning learn/sema-voice-oracle-miss-learning.fk
              "turns the measured miss into an AutoML action"))

  (observed-input
    (verdict 479)
    (field-code 110100002)
    (oracle-wer 100)
    (route "oracle-guide"))

  (learning-action
    (authority "oracle-guide")
    (action "train-text-conditioned-acoustic-vocoder")
    (candidate "text-conditioned-acoustic-vocoder")
    (recipe "g2p -> phoneme-timing -> prosody-contour -> acoustic-token-emitter -> segmented-acoustic-learning -> Sema voice loop")
    (priority 125))

  (runnable
    (concat
      learn/sema-voice-local-oracle-receipt.fk
      learn/sema-voice-oracle-miss-learning.fk
      learn/tests/sema-voice-oracle-miss-learning-band.fk)
    (verdict 32767))

  (honest-boundary
    "This does not make Sema's current formant waveform pass STT. It makes the
     failure executable: native authority stays guided, and AutoML now has a
     concrete next candidate and recipe to train against the same local oracle."))
