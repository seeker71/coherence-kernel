# speech-corpus-heldout-repeat-learning.form -- scoped corpus held-out repeats

(speech-corpus-heldout-repeat-learning

  (purpose
    (summary "train on corpus phrase wavs and evaluate separately rendered transformed repeats")
    (boundary "scoped held-out repeat learning, not cross-phrase, cross-voice, or global speech authority"))

  (live-run
    (train-wavs 6)
    (eval-wavs 6)
    (locales "en de es fr id pt-br")
    (oracle-accepted 6)
    (native-accepted 6)
    (train-eval-hashes-differ 6)
    (observed-wav-bytes 302968)
    (neural-parameters 0)
    (status "scoped-heldout-repeat-not-global-authority"))

  (aggregate-after-run
    (live-wav-rows 47)
    (observed-wav-bytes 1368250)
    (held-out-repeat-rows 7)
    (cross-phrase-rows 0)
    (cross-voice-rows 0)
    (data-sufficient-training false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-corpus-heldout-repeat-learning.fk
      learn/tests/speech-corpus-heldout-repeat-learning-band.fk)
    (verdict 16383)))
