# native-audio2audio-acoustic-bridge.form -- decoded source audio to target acoustic frames

(native-audio2audio-acoustic-bridge

  (lineage
    (segmented-source learn/segmented-acoustic-token-learning.fk
                      "upstream source audio can decode to source tokens and neutral meaning")
    (baseline learn/sanskrit-locale-baseline.fk
              "neutral meaning and target locale tokens")
    (target-vocoder learn/text-conditioned-acoustic-vocoder.fk
                    "target tokens and voice metadata become native source-filter frames")
    (bridge learn/native-audio2audio-acoustic-bridge.fk
            "decoded source token rows become target acoustic frame receipts")
    (multilocale-sweep learn/multilocale-audio2audio-acoustic-sweep.fk
                       "five reciprocal baseline pairs reuse the same bridge")
    (metal-authority learn/metal-audio2audio-acoustic-authority.fk
                     "stable sweep summaries plus seven live Metal anchors select the native acoustic arm"))

  (model-layout
    (input "decoded source-audio tokens + neutral meaning + target locale + voice metadata")
    (source-gate "source oracle transcript must match decoded source tokens")
    (target-gate "target oracle transcript must match target locale tokens")
    (output "target-locale text-conditioned acoustic frames and native sample list")
    (authority "reciprocal A/B and B/A rows decide native vs oracle-guide"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      observe/speech-token-stream.fk
      learn/sanskrit-locale-baseline.fk
      learn/text-conditioned-acoustic-vocoder.fk
      learn/native-audio2audio-acoustic-bridge.fk
      learn/tests/native-audio2audio-acoustic-bridge-band.fk)
    (verdict 32767))

  (multilocale-runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      observe/speech-token-stream.fk
      learn/sanskrit-locale-baseline.fk
      learn/text-conditioned-acoustic-vocoder.fk
      learn/native-audio2audio-acoustic-bridge.fk
      learn/multilocale-audio2audio-acoustic-sweep.fk
      learn/tests/multilocale-audio2audio-acoustic-sweep-band.fk)
    (pairs "en<->de en<->es zh<->ar fr<->id sa<->la")
    (verdict 32767))

  (metal-authority-runnable
    (concat
      learn/metal-audio2audio-acoustic-authority.fk
      learn/tests/metal-audio2audio-acoustic-authority-band.fk)
    (route "metal-witnessed-audio2audio-acoustic")
    (selector "native-audio2audio-acoustic-vocoder")
    (verdict 32767))

  (honest-boundary
    "This is not live open microphone authority. The source side consumes a
     decoded token row from ASR/segmentation; the bridge proves that row can
     now be carried through neutral meaning into target-locale acoustic frames
     with local-oracle source and target transcript gates. The Metal authority
     row selects this arm only for the decoded-token, metal-witnessed scope."))
