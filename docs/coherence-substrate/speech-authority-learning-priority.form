# speech-authority-learning-priority.form -- authority gaps outrank pair drift

(speech-authority-learning-priority

  (purpose
    (summary "make open ASR and Sema voice gaps part of the executable learning priority")
    (boundary "this chooses the next authority-learning action; it does not promote open ASR or Sema voice authority"))

  (current-state
    (trained-neural-pairs 41)
    (directed-neural-routes 82)
    (native-neural-parameters 41)
    (background-pair-window "0042 sa<->it")
    (open-asr-gap 100)
    (sema-voice-gap 100)
    (sema-voice-native "0/1")
    (sema-voice-oracle "1/1")
    (sema-voice-training-floor "oracle 6/6, native 5/6; live authority still held"))

  (selected-authority-action
    (trial "trial-open-asr-0001")
    (gap "live-open-dictation")
    (action "train-live-segmented-open-asr-source")
    (target "native-segmented-acoustic-learning")
    (route "oracle-guide")
    (promote "native-rate>=50-and-wer<=25-clean-controls")
    (control "choice-cut-fail-undo-timeout"))

  (meaning
    "Pair windows remain available as coverage growth, but measured authority
     gaps at 100 force the next learning priority back to open ASR/voice
     receipts until open native evidence passes.")

  (runnable
    (concat
      learn/speech-neural-pair-coverage.fk
      learn/speech-pair-training-next-action.fk
      learn/speech-open-asr-tts-target-model.fk
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-authority-learning-priority.fk
      learn/tests/speech-authority-learning-priority-band.fk)
    (verdict 32767)))
