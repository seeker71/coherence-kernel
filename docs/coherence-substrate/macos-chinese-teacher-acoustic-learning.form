# macos-chinese-teacher-acoustic-learning.form -- Chinese teacher wav trains native ASR

(macos-chinese-teacher-acoustic-learning

  (purpose
    (summary "extend live teacher acoustic learning to a short Chinese baseline line")
    (boundary "scoped prototype ASR learning, not neural acoustic encoder and not native TTS authority")
    (baseline-meaning 303)
    (teacher-text "我在"))

  (live-path
    (render "learn/macos-chinese-teacher-acoustic-learning.fk renders Eddy Chinese voice with local say")
    (normalize "ffmpeg writes 16 kHz mono PCM wav")
    (oracle "whisper.cpp large-v3-turbo on local Metal transcribes the wav with -l zh")
    (sense "observe/wav-sense.fk reads the generated wav and extracts the envelope in Form")
    (learn "Form trains Chinese acoustic token prototypes from wav-envelope segment rows")
    (decode "Form CTC collapse decodes learned Chinese frames back to text"))

  (model
    (kind "supervised Form-native acoustic token prototypes")
    (native-neural-parameters 0)
    (token-features 3)
    (prototype-count 3)
    (live-confidence 96)
    (target "native decoded Chinese transcript equals the witnessed teacher transcript"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/macos-chinese-teacher-acoustic-learning.fk
      learn/tests/macos-chinese-teacher-acoustic-learning-band.fk)
    (contract-verdict 16383)
    (live-verdict 16383)
    (live-wer 0)
    (live-verdict-function mztal-run-verdict)
    (live-wer-function mztal-run-wer))

  (observed-boundary
    (short-line "Eddy/Flo/Meijia Chinese voices passed the local oracle bar for 我在")
    (long-lines "truth-wins and all-be-happy Chinese baseline phrases remain local-oracle misses")
    (next "use the short pass and long misses as A/B evidence for Chinese phrase shaping")))
