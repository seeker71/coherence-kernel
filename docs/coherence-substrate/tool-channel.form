# tool-channel.form - native tool/channel planning surface

(tool-channel
  (lineage
    (rests-on host-kernel.form kernel-self-composition.form tool-grammar.form)
    (recipe form/form-stdlib/tool-channel.fk)
    (grammar form/form-stdlib/tool-channel-grammar.fk)
    (proof form/form-stdlib/tests/tool-channel-band.fk -> 255)
    (grammar-proof form/form-stdlib/tests/tool-channel-grammar-band.fk -> 255))

  (purpose
    "Cells and recipes discover tool options as Form-native rows, then receive an explicit invocation plan."
    "This surface does not execute host processes, read files, send HTTP, or call routes.")

  (floor
    "The catalog and grammar surface plan explicit tool/channel invocations with protocol, provider, capability, operation, projection, input, output, and refusal witnesses."
    "GPU, DSP, and MLX/equivalent accelerator lanes are present as capability-gated planning rows before active native dispatch proof exists.")

  (north-star
    "Every host OS call, external API, kernel call, route, stream, store, mesh presence, model, sensor, audio/video surface, and shell applet is a constructible native protocol row with typed receipts, floor/north-star metadata, and no ambient host access.")
    "Host OS data such as process tables and utilization samples moves through direct host OS/kernel calls as the destination; command-carried receipts stay labeled as floor carriers.")

  (protocols
    (host:exec    (provider host)   (capability cap.host.exec)    (native 0) (effect process))
    (host:process (provider host)   (capability cap.host.process) (native 1) (effect process-table))
    (host:usage   (provider host)   (capability cap.host.usage)   (native 1) (effect resource-usage))
    (host:file    (provider host)   (capability cap.host.file)    (native 0) (effect filesystem))
    (gpu:compute  (provider accelerator) (capability cap.compute.gpu) (native 1) (effect parallel-compute))
    (dsp:signal   (provider accelerator) (capability cap.compute.dsp) (native 1) (effect signal-kernel))
    (mlx:array    (provider accelerator) (capability cap.compute.mlx) (native 1) (effect apple-array-compute))
    (http:request (provider http)   (capability cap.http.request) (native 1) (effect network))
    (kernel:call  (provider kernel) (capability cap.kernel.call)  (native 1) (effect call))
    (kernel:route (provider kernel) (capability cap.kernel.route) (native 1) (effect route))
    (hati.mesh:presence (provider mesh) (capability cap.mesh.presence) (native 1) (effect organ-presence))
    (stream:read  (provider stream) (capability cap.stream.read)  (native 1) (effect stream))
    (store:query  (provider store)  (capability cap.store.query)  (native 1) (effect store)))

  (providers
    (host   host:exec    cap.host.exec)
    (process host:process cap.host.process)
    (usage   host:usage   cap.host.usage)
    (file   host:file    cap.host.file)
    (gpu    gpu:compute  cap.compute.gpu)
    (dsp    dsp:signal   cap.compute.dsp)
    (mlx    mlx:array    cap.compute.mlx)
    (http   http:request cap.http.request)
    (kernel kernel:call  cap.kernel.call)
    (route  kernel:route cap.kernel.route)
    (mesh   hati.mesh:presence cap.mesh.presence)
    (stream stream:read  cap.stream.read)
    (store  store:query  cap.store.query))

  (options
    (protocol-tools exec processes usage file gpu-kernel dsp-kernel mlx-kernel http call route announce-organ stream query)
    (shell-applets grep find awk fields group xpath xmlpath)
    (catalog-tools words providers queries which plan))

  (applets
    (processes host:process cap.host.process process-snapshot)
    (usage     host:usage   cap.host.usage   usage-sample)
    (gpu-kernel gpu:compute cap.compute.gpu dispatch)
    (dsp-kernel dsp:signal cap.compute.dsp dispatch)
    (mlx-kernel mlx:array cap.compute.mlx dispatch)
    (grep    stream:read cap.stream.read grep)
    (find    host:file   cap.host.file   find)
    (awk     stream:read cap.stream.read awk)
    (fields  stream:read cap.stream.read fields)
    (group   store:query cap.store.query group)
    (xpath   kernel:call cap.kernel.call path-select)
    (xmlpath kernel:call cap.kernel.call path-select))

  (planning
    (helpers tc-plan-tool tc-plan-request tc-which tc-protocol-carries? tc-native-option?)
    (status-ok tool/plan)
    (status-refusal tool/no-plan)
    (refusal-witnesses missing-tool missing-capability)
    (wrong-or-missing-capability returns-tool/no-plan))

  (language-surface
    (forms protocol-declaration provider-declaration tool-declaration capability-declaration plan-expression offer-expression)
    (lowers-to same-catalog-rows)
    (offer-shape explicit-plan-over-tool/channel))

  (invariant
    (no-python-runtime-carrier)
    (no-ambient-host-access)
    (cli-applets-are-projections-not-duplicate-semantics)
    (capabilities-are-explicit-and-plannable)))
