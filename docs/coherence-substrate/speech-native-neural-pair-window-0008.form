# speech-native-neural-pair-window-0008.form -- eighth trained neural pair

(speech-native-neural-pair-window-0008

  (purpose
    (summary "train the eighth native neural micro-pair window")
    (boundary "this grows trained neural pair coverage, but is not full open ASR/TTS authority"))

  (pair
    (a en)
    (b es)
    (meaning 302)
    (baseline "satyam-eva-jayate")
    (pair-increment 1)
    (directed-increment 2)
    (cumulative-trained-pairs 8)
    (cumulative-directed-routes 16)
    (epochs 8)
    (native-neural-parameters 8))

  (result
    (neural-rate "0 -> 100")
    (form-nl-rate 100)
    (form-audio-rate 100)
    (bootstrap-loss "1 -> 0")
    (route-shifted true)
    (oracle true)
    (native-form true)
    (open-authority false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0008.fk
      learn/tests/speech-native-neural-pair-window-0008-band.fk)
    (verdict 32767)))
