# speech-native-neural-pair-window-0037.form -- es<->it neural pair window

(speech-native-neural-pair-window-0037

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "es")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "es->it, it->es, es->es, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (spanish
      (voice "Monica")
      (truth "yo soy")
      (heard "Yo soy.")
      (wer 0)
      (wav-bytes 21760)
      (cksum 3069302771))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 37)
    (cumulative-directed-routes 74)
    (epochs 37)
    (native-neural-params 37)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0037-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0037.fk
      learn/tests/speech-native-neural-pair-window-0037-band.fk)
    (verdict 32767)))
