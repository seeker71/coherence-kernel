# speech-native-neural-bootstrap.form -- enabled native neural micro-kernel

(speech-native-neural-bootstrap

  (purpose
    (summary "admit one executable Form-native neural bootstrap slot")
    (boundary "this enables training routes; it is not locale-pair neural authority"))

  (model
    (enabled-slots 1)
    (native-neural-parameters 1)
    (training-epochs 1)
    (sample-count 1)
    (weight "1 -> 2")
    (prediction "1 -> 2")
    (loss "1 -> 0"))

  (authority
    (oracle-rate 100)
    (native-scoped-rate 100)
    (trained-locale-pairs 0)
    (bootstrap-ready true)
    (route-enabled true)
    (native-form true))

  (runnable
    (concat
      learn/speech-native-neural-bootstrap.fk
      learn/tests/speech-native-neural-bootstrap-band.fk)
    (verdict 32767)))
