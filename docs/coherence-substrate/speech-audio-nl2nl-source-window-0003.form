# speech-audio-nl2nl-source-window-0003.form -- fi/ja source-window audio bridge

(speech-audio-nl2nl-source-window-0003

  (purpose
    (summary "route observed fi/ja source audio through locale-neutral presence meaning into target audio")
    (boundary "host TTS and Whisper remain carriers/oracles; native Form owns neutral routing and target text"))

  (observed-metal-run
    (date "2026-07-02")
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (routes
      (fi-to-ja
        (source "minä olen")
        (source-heard "Minä olen.")
        (target "私はいます")
        (target-heard "私はいます。")
        (source-hash 2803940054)
        (target-hash 704718359)
        (wav-bytes 83506))
      (ja-to-fi
        (source "私はいます")
        (source-heard "私はいます。")
        (target "minä olen")
        (target-heard "Minä olen.")
        (source-hash 704718359)
        (target-hash 2803940054)
        (wav-bytes 83506))))

  (rates
    (source-oracle "2/2 = 100%")
    (target-oracle "2/2 = 100%")
    (native-neutral-routing "2/2 = 100%")
    (meaning 602)
    (route "oracle-guided-source-window-audio-nl2nl-audio-bridge-not-native-vocoder"))

  (runnable
    (concat
      observe/stt-wer.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-audio-nl2nl-source-window-0003.fk
      learn/tests/speech-audio-nl2nl-source-window-0003-band.fk)
    (verdict 32767)))
