# source-window-audio2audio-authority.form -- source ASR window feeds acoustic audio2audio

(source-window-audio2audio-authority

  (lineage
    (source-window learn/multilocale-segmented-source-window.fk
                   "three reciprocal segmented source-ASR pairs prove native source tokens")
    (target-authority learn/metal-audio2audio-acoustic-authority.fk
                      "five-pair acoustic sweep plus seven Metal anchors prove target acoustic route")
    (authority learn/source-window-audio2audio-authority.fk
               "scalar composition: native source window + metal acoustic target")
    (selector learn/speech-model-auto-selection.fk
              "AutoML now selects the integrated source-window audio2audio arm"))

  (model-layout
    (source "segmented source speech -> native token prototypes -> source transcript")
    (middle "source tokens -> Sanskrit/locale-neutral Form meaning")
    (target "neutral meaning -> target locale tokens -> acoustic frames")
    (evidence "local oracle WER, reciprocal source pairs, acoustic sweep, and Metal anchors")
    (route "native-source-window-audio2audio-acoustic"))

  (runnable
    (concat
      learn/source-window-audio2audio-authority.fk
      learn/tests/source-window-audio2audio-authority-band.fk)
    (verdict 32767))

  (selector
    (selected-audio2audio "native-source-window-audio2audio-acoustic")
    (selector-verdict 536870911))

  (honest-boundary
    "This composes witnessed source-ASR and target acoustic authority into one
     audio2audio arm. It still does not claim live microphone streaming, an
     unconstrained open ASR model, or native neural speech generation. The
     source window and target acoustic route are native Form receipts guided by
     local Metal oracle evidence."))
