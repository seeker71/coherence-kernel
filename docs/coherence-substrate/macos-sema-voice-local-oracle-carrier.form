# macos-sema-voice-local-oracle-carrier.form -- live Sema formant oracle probe

(macos-sema-voice-local-oracle-carrier

  (lineage
    (voice-target learn/sema-voice-sample-loop.fk
                  "Sema's warm grounded target profile")
    (local-oracle-gate learn/sema-voice-local-oracle-receipt.fk
                       "audio hash, local oracle WER, clean controls, and route authority")
    (carrier presence/macos-sema-voice-local-oracle-carrier.fk
             "target-derived waveform render plus local Whisper on Apple Metal"))

  (carrier-shape
    (render "Form builds the ffmpeg aevalsrc expression from Sema's target f0/formants")
    (oracle "whisper.cpp-large-v3-turbo runs locally on Apple Metal")
    (receipt "the measured transcript is submitted to the Sema voice local-oracle gate")
    (route "success routes native-sema-voice; miss routes oracle-guide"))

  (learning
    (cell learn/sema-voice-oracle-miss-learning.fk)
    (action "train-text-conditioned-acoustic-vocoder")
    (authority "oracle-guide"))

  (observed-live
    (device "macos-arm64-m4-max")
    (wav-bytes 57678)
    (verdict 479)
    (field-code 110100002)
    (oracle-wer 100)
    (route "oracle-guide"))

  (runnable
    (contract
      (concat
        observe/stt-wer.fk
        presence/formant-vocoder.fk
        learn/sema-voice-sample-loop.fk
        learn/sema-voice-local-oracle-receipt.fk
        presence/macos-sema-voice-local-oracle-carrier.fk
        presence/tests/macos-sema-voice-local-oracle-carrier-band.fk)
      (verdict 2047))
    (live
      (entrypoints msvlc-run msvlc-run-field-code msvlc-run-oracle-wer)
      (observed 479 110100002 100)))

  (honest-boundary
    "This closes the live carrier gap but not the intelligibility gap. The
     current target-derived formant waveform renders locally and is transcribed
     by local Whisper on Metal, but it does not yet pass the STT bar for the
     target utterance. It is now a measured learning failure, not an assumption."))
