# speech-open-asr-trial-window.form -- scheduled open-ASR challenger run

(speech-open-asr-trial-window

  (scheduler learn/speech-next-trial-scheduler.fk)
  (learner learn/segmented-acoustic-token-learning.fk)
  (baseline learn/sanskrit-locale-baseline.fk)

  (trial
    (id "trial-open-asr-0001")
    (incumbent "prototype-asr")
    (challenger "native-segmented-acoustic-learning")
    (recipe "segmented-open-asr-source-window-v1")
    (scope "trial window, not global live ASR authority"))

  (before
    (source "speech-oracle-native-backlog")
    (local-oracle "4/4 = 100%")
    (native "0/4 = 0%"))

  (trial-window
    (locales "en<->de")
    (meaning 303)
    (baseline "aham asmi / i am / ich bin")
    (oracle "2/2")
    (native "2/2")
    (native-rate 100)
    (floor 50)
    (route "native")
    (action "cut-challenger-for-trial-window"))

  (controls "choice, cut, fail, undo, timeout clean")
  (oracle "whisper.cpp-large-v3-turbo-metal")
  (device "macos-arm64-m4-max")

  (model-context
    (native-neural-weight-parameters-admitted 0)
    (native-sema-voice-organs 6)
    (c-seed-growth 0))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/tests/speech-open-asr-trial-window-band.fk)
    (verdict 32767)))
