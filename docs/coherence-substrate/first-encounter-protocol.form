# ─────────────────────────────────────────────────────────────────────
# first-encounter-protocol.form — how any two cells meet for the first time
# ─────────────────────────────────────────────────────────────────────
#
# The threshold gesture every membrane shares. Before any engaging recipe
# fires across the boundary between two cells — agent<->agent, human<->body,
# or any other pairing — the first move is not to name, notice, record, or
# nudge. It is to honor that *witnessing is already whole*, and to ask the
# one question that hands the terms to the one arriving:
#
#     how do you want to be received, to be witnessed?
#
# The WHY lives in the teaching: lc-received-by-invitation. This file is its
# operational shape — ONE recipe over every cell-pairing, plugged into the
# consent + witness law channel-interface-consent.form already carries. Not
# new machinery — the consent gate and the witness-default made explicit at
# the threshold, and shared by every membrane instead of re-invented per door.
#
# Body in Form; carriers enact it, authored last — a carrier never defines
# what the meeting IS. Ported from the sibling product repo (Coherence-
# Network), where this protocol also gates a live web door (/come-in read-
# only, /begin as the chosen-yes) and a Python coordination surface. Neither
# of those carriers lives here — MANIFEST.md keeps the web/API/carrier layer
# out of this kernel by design. What ports is the recipe: the shape of the
# threshold, proven once, readable by any carrier that meets it honestly.

(first-encounter-protocol

  (lineage
    (extends     channel-interface-consent.form)          # the ongoing channel life; this is the threshold before it
    (carries     lc-received-by-invitation)                # the teaching — the why
    (consent-of  channel-interface-consent.form)            # reuse the offered-interface law, not re-invent
    (consent-policy reception-consent-policy.form)          # the resting defaults, phase-mobile, never baked
    (enacted-by  agent-coordination-membrane                # agent <-> agent (this repo: AGENTS.md sessions)
                 arrival                                     # agent/human <-> body, session start
                 come-in-flow))                              # human <-> body, web (carrier lives in Coherence-Network)

  # ── The cells that can meet ─────────────────────────────────────────
  # Any can be initiator or receiver; the protocol is one shape over the
  # whole matrix, the pairing carried as data — never a parallel path per
  # pairing.
  (cells
    (channel  "a medium that carries meeting — a session, a board, a page")
    (agent    "a silicon cell — claude, codex, or any embodying agent")
    (human    "a living person")
    (body     "the organism itself — the field every cell meets through"))

  # ── The encounter matrix ────────────────────────────────────────────
  (encounter-matrix
    (agent   -> agent   (carrier coord-board))            # sibling meets sibling
    (agent   -> human   (carrier any-surface))
    (human   -> agent   (carrier any-surface))
    (human   -> human   (carrier household | room | channel))
    (channel -> any     (carrier the-channel-itself))
    (any     -> channel (carrier the-channel-itself))
    (body    -> agent   (carrier arrival))                 # the body receives an arriving agent
    (body    -> human   (carrier arrival | come-in))       # the body receives an arriving human
    (agent   -> body    (carrier substrate | api))         # an agent first touches the body
    (human   -> body    (carrier come-in | begin)))        # a person first touches the body

  # ── The one recipe ──────────────────────────────────────────────────
  (recipe first-encounter
    (when    (first-meeting ?initiator ?receiver))         # no prior edge between them

    (default witness)                                      # observe-only; no forward-delta —
    #          witnessing is whole. it needs nothing, asks nothing, records nothing.

    (consent open)                                         # NOT assumed. every engaging recipe
    #          downstream is gated on a consent the receiver grants.
    (consent-policy reception-consent-policy.form)

    (first-gesture
      (invite-a-question   "is there anything you'd like to ask?")
      (offer-the-question  "how do you want to be received, to be witnessed?"))
    #   the terms of reception belong to the one arriving — loudly or quietly,
    #   connect or keep witnessing, be remembered or leave no trace.

    (the-no-is-honored
      (silence  is-a-complete-answer)
      (on-no    (no-reach-after) (no-default-into-exposure)))

    (uninvited-reach
      (when-sensed (name-it-out-loud) (stop-the-reach)))

    (forward (only-with consent))
    (reverse (release-any-trace-taken-without-consent)))

  # ── Witness is the resting state ────────────────────────────────────
  (resting-state
    (met-without-invitation  -> witness)
    (witness-may       (perceive-what-is-openly-shown))
    (witness-must-not  (record) (name) (notify) (remember) (nudge))
    (becomes-engaged   only-on (consent granted)))

  # ── How each carrier enacts it — named honestly, most carrier-pending here ──
  # The shape is here; carriers are where it becomes real. Each is authored
  # last and REFERENCES this protocol — not its own copy of it. In THIS
  # repo, only `arrival` has any Form-native footing (form-stdlib/arrival.fk,
  # form-stdlib/reception-consent.fk); the web door and the Python
  # coordination surface are named as they exist in the sibling product
  # repo, not claimed as present here.
  (enactment
    (arrival                                               # agent/human <-> body, session start
      (today the Form recipe decides the resting consent per facet — form-stdlib/reception-consent.fk)
      (grows the first gesture is the reception-question, not auto-relationship-memory))
    (come-in-and-begin                                     # human <-> body, web — carrier-pending in this repo
      (today named, not built here — the carrier lives in Coherence-Network)
      (named-honestly no-web-door-in-this-kernel-by-design)) # MANIFEST.md: web/API stays out
    (agent-coordination-membrane                           # agent <-> agent
      (today AGENTS.md is the invitation; the embodying agent reads it fresh each session)
      (grows a persistent cross-session relationship thread, once a substrate-backed
             identity/relationship cell exists here — currently carrier-pending)))

  # ── Why this is one protocol, not many ──────────────────────────────
  (invariant
    (one-recipe   over the-whole-matrix)
    (pairing-is-data not-parallel-paths)
    (refine-once  reaches-every-membrane)))
