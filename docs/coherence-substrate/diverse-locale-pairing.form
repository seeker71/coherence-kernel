# diverse-locale-pairing.form -- sample far-apart A/B locale pairs

(diverse-locale-pairing

  (lineage
    (translation-invariant cognition/translation-invariant.fk
                           "farther tongues tighten the invariant")
    (bidirectional-guide learn/bidirectional-locale-roundtrip.fk
                         "reciprocal A->B and B->A route trust")
    (self-corpus learn/coherence-network-self-corpus.fk
                 "Coherence Network translated content supplies ready corpus rows")
    (sanskrit-baseline learn/sanskrit-locale-baseline.fk
                       "small consentful baseline supplies sa/la/zh/ar training rows before full bundles land")
    (pairing learn/diverse-locale-pairing.fk
             "locale rows, distance score, readiness, seeded pair choice"))

  (principle
    (diversity "prefer far-apart language families, scripts, typologies, and regions")
    (readiness "randomization samples from corpus-ready and consent-ready rows")
    (reciprocity "chosen A/B pair expands into A->B, B->A, A->A, and B->B")
    (specificity "Native American is not a locale; use specific Indigenous language rows")
    (consent "Indigenous rows remain pending until consentful corpora exist"))

  (starter-rows
    (en "ready: Coherence Network translated corpus")
    (de "ready: Coherence Network translated corpus")
    (es "ready: Coherence Network translated corpus")
    (fr "ready: Coherence Network translated corpus")
    (id "ready: Coherence Network translated corpus")
    (pt-br "ready: Coherence Network translated corpus")
    (sa "ready: Sanskrit baseline row")
    (zh "ready: Sanskrit baseline row; full Coherence Network bundle backfill pending")
    (ar "ready: Sanskrit baseline row; full Coherence Network bundle backfill pending")
    (la "ready: Sanskrit baseline row; full Coherence Network bundle backfill pending")
    (nv "Dene/Navajo row named; corpus/consent pending")
    (chr "Cherokee row named; corpus/consent pending"))

  (selection
    (score "family distance + script distance + typology distance + region distance + row weight")
    (best-ready-pair "highest-scoring pair with both rows ready")
    (seeded-choice "deterministic for receipts; a live carrier can pass real randomness later")
    (roundtrip-lanes "selected pair expands into A->B, B->A, A->A, and B->B lanes"))

  (runnable
    (concat
      learn/diverse-locale-pairing.fk
      learn/tests/diverse-locale-pairing-band.fk)
    (verdict 8191)
    (self-corpus
      (concat
        learn/coherence-network-self-corpus.fk
        learn/tests/coherence-network-self-corpus-band.fk)
      (verdict 8191)))

  (honest-boundary
    "This chooses training pairs from ready self-corpus or Sanskrit-baseline
     rows and names useful full-bundle backfill targets. It does not provide
     the translation model, generate missing bundles, or run live cross-locale
     audio receipts. Specific Indigenous language rows are named but
     intentionally not marked ready without consentful corpus support."))
