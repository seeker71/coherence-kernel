# speech-form-pair-window-0008.form -- en<->fr Form pair window

(speech-form-pair-window-0008

  (purpose
    (summary "execute the next selected Form-native reciprocal pair window")
    (boundary "this expands Form-native closed-set evidence, not neural training"))

  (pair
    (a en)
    (b fr)
    (meaning 304)
    (baseline "lokah-samastah-sukhino-bhavantu")
    (lanes "A->B, B->A, A->A, B->B for both NL and audio"))

  (result
    (nl-before 0)
    (nl-after 100)
    (audio-before 0)
    (audio-after 100)
    (route-before oracle-guide)
    (route-after native)
    (shifted true)
    (native-form true)
    (neural false)
    (diffusion false))

  (coverage-effect
    (form-pair-windows "7 -> 8")
    (directed-cross-locale-directions "14 -> 16")
    (roundtrip-lanes "28 -> 32")
    (neural-pair-windows "0 -> 0"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-form-pair-window-0008.fk
      learn/tests/speech-form-pair-window-0008-band.fk)
    (verdict 32767)))
