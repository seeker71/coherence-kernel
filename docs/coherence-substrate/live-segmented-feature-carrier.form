# live-segmented-feature-carrier.form -- observed wav/envelope rows into open ASR

(live-segmented-feature-carrier

  (lineage
    (wav-sense observe/wav-sense.fk
               "carrier-produced wavs can be sensed in Form as energy envelopes")
    (open-dictation learn/open-dictation-transcript-learning.fk
                    "free transcript WER and promotion gate")
    (token-stream observe/speech-token-stream.fk
                  "words and voice-side metadata")
    (ctc observe/open-asr-ctc.fk
         "CTC token collapse into transcript text")
    (emitter observe/acoustic-token-emitter.fk
             "feature rows emit blank/nonblank CTC frames")
    (carrier presence/live-segmented-feature-carrier.fk
             "local wav/envelope facts lower into feature rows and open-ASR promotion"))

  (receipt-shape
    (input "sample id, locale, truth, local oracle transcript, eight-window envelope, audio hash, latency, metadata")
    (feature-lowering "envelope -> four Form feature rows")
    (native-candidate "feature rows -> acoustic-token frames -> CTC transcript")
    (promotion "four passing native rows can route native through open-dictation promotion")
    (controls "fail, timeout, undo, missing consent, and missing local audio block readiness")
    (authority "candidate surface only; ASR selection stays prototype-asr until live windows win"))

  (runnable
    (concat
      observe/stt-wer.fk
      learn/speech-loopback-promotion.fk
      form/form-stdlib/observed-auto-learning.fk
      learn/open-dictation-transcript-learning.fk
      observe/speech-token-stream.fk
      observe/open-asr-ctc.fk
      observe/acoustic-token-emitter.fk
      presence/live-segmented-feature-carrier.fk
      presence/tests/live-segmented-feature-carrier-band.fk)
    (verdict 32767))

  (selector
    (candidate "live-segmented-feature-carrier")
    (selector-verdict 536870911)
    (selected-asr "prototype-asr"))

  (honest-boundary
    "This is the live feature-row carrier membrane, not a live microphone
     implementation. The body can now accept observed wav/envelope facts and
     lower them into native open-ASR candidate rows. Real CoreAudio, AAudio, or
     WASAPI capture still has to emit this row over winning live windows before
     ASR authority moves."))
