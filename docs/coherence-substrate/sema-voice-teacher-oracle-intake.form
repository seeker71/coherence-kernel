# sema-voice-teacher-oracle-intake.form -- passing local teacher oracle evidence

(sema-voice-teacher-oracle-intake

  (source presence/macos-sema-voice-teacher-carrier.fk)
  (intake learn/sema-voice-teacher-oracle-intake.fk)

  (observed-metal-run
    (date "2026-07-01")
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (voice "Flo (English (US))")
    (truth "Open speech flows.")
    (audio-hash 497318870)
    (verdict 255)
    (wer 0))

  (rates
    (oracle "1/1 = 100%")
    (native "0/1 = 0%")
    (route "oracle-teacher-positive-native-held"))

  (boundary
    (native-form true)
    (neural-ready false)
    (authority "not native Sema voice authority")
    (meaning "admit the passing voice-side oracle sample as teacher evidence without promoting the native vocoder"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      learn/sema-voice-sample-loop.fk
      learn/sema-voice-local-oracle-receipt.fk
      presence/macos-sema-voice-teacher-carrier.fk
      learn/speech-live-receipt-intake.fk
      learn/sema-voice-teacher-oracle-intake.fk
      learn/tests/sema-voice-teacher-oracle-intake-band.fk)
    (verdict 32767)))
