# speech-native-neural-pair-window-0041.form -- ar<->it neural pair window

(speech-native-neural-pair-window-0041

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "ar")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "ar->it, it->ar, ar->ar, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (arabic
      (voice "Majed")
      (truth "أنا")
      (heard "أنا.")
      (wer 0)
      (wav-bytes 10906)
      (cksum 3840888175))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 41)
    (cumulative-directed-routes 82)
    (epochs 41)
    (native-neural-params 41)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0041-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0041.fk
      learn/tests/speech-native-neural-pair-window-0041-band.fk)
    (verdict 32767)))
