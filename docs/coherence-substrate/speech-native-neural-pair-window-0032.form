# speech-native-neural-pair-window-0032.form -- de<->it neural pair window

(speech-native-neural-pair-window-0032

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "de")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "de->it, it->de, de->de, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (german
      (voice "Anna")
      (truth "ich bin")
      (heard "Ich bin")
      (wer 0)
      (wav-bytes 16068)
      (cksum 3773526825))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 32)
    (cumulative-directed-routes 64)
    (epochs 32)
    (native-neural-params 32)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0032-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0032.fk
      learn/tests/speech-native-neural-pair-window-0032-band.fk)
    (verdict 32767)))
