# speech-native-neural-pair-window-0017.form -- seventeenth trained neural pair

(speech-native-neural-pair-window-0017

  (purpose
    (summary "train the seventeenth native neural micro-pair window")
    (boundary "this grows trained neural pair coverage, but is not full open ASR/TTS authority"))

  (pair
    (a de)
    (b fr)
    (meaning 301)
    (baseline "sarve-bhavantu-sukhinah")
    (pair-increment 1)
    (directed-increment 2)
    (cumulative-trained-pairs 17)
    (cumulative-directed-routes 34)
    (epochs 17)
    (native-neural-parameters 17))

  (result
    (neural-rate "0 -> 100")
    (form-nl-rate 100)
    (form-audio-rate 100)
    (bootstrap-loss "1 -> 0")
    (route-shifted true)
    (oracle true)
    (native-form true)
    (open-authority false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0017.fk
      learn/tests/speech-native-neural-pair-window-0017-band.fk)
    (verdict 32767)))
