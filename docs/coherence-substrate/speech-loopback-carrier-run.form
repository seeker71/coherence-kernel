# speech-loopback-carrier-run.form -- platform carrier run row

(speech-loopback-carrier-run

  (lineage
    (host-membrane form/form-stdlib/host-os-membrane.fk
                   "platform support, direct-source status, and speech loopback door")
    (native-loopback presence/native-speech-loopback.fk
                     "formant vocoder fingerprint -> closed-set ASR -> WER route")
    (carrier-receipt presence/speech-loopback-carrier-receipt.fk
                     "local-only audio metadata and transcript facts")
    (recipe-ab learn/speech-loopback-recipe-ab.fk
               "incumbent/challenger choice under fail, timeout, and undo controls")
    (carrier-run presence/speech-loopback-carrier-run.fk
                 "one auditable run row over platform readiness and measured windows")
    (capture-learning learn/speech-loopback-capture-learning.fk
                      "AAudio render/capture facts become a learned native route toward the oracle"))

  (run-row
    (capability "target, render, capture, oracle, local-only, sample-rate, channels, shared-safe")
    (ready "target is membrane-supported and direct-source observed, speech door is Form-owned, local carrier facts pass")
    (receipt "native loopback transcript and confidence lower into speech-loopback-carrier-receipt")
    (route "clean ready windows can route native; short, unready, failed, timed-out, or undone windows route oracle")
    (decision "A/B cut happens only through the same carrier-ready receipt windows"))

  (android-metal-witness
    (device "Galaxy S23 Ultra SM-S918U1, arm64-v8a, SDK 36")
    (adb-serial "R5CW20DK17A")
    (temp-dir "/data/local/tmp/codex-408b-next-PuMYUf")
    (speech-loopback-carrier-run 511)
    (speech-loopback-carrier-run-ab 2047)
    (speech-loopback-capture-learning 8191)
    (cleanup "temp dir removed after witness"))

  (android-e2e-capture-learning
    (device "Galaxy S23 Ultra SM-S918U1, arm64-v8a, SDK 36")
    (adb-serial "R5CW20DK17A")
    (temp-dir "/data/local/tmp/codex-e2e-capture-SOe4xk")
    (input "AAudio microphone, 16000 Hz, 1 channel")
    (output "AAudio speaker prompt, amplitude 9000")
    (measured "frames 23200, nonzero 23109, energy 3006571, peak 561, hash 811960308")
    (loopback "on 1491283, off 1045058, lag 4, score 446225")
    (form-call "(scl-on-device-check 16000 1 23200 23109 3006571 561 811960308 1491283 1045058 4 446225 129 9000 1)")
    (verdict 8191)
    (cleanup "temp dir removed after witness; raw audio was not written"))

  (runnable
    (carrier-run
      (concat
        form/form-stdlib/hati-os-targets.fk
        form/form-stdlib/host-os-membrane.fk
        observe/stt-wer.fk
        presence/formant-vocoder.fk
        observe/asr-prompt-id.fk
        presence/native-speech-loopback.fk
        learn/speech-loopback-promotion.fk
        presence/speech-loopback-carrier-receipt.fk
        presence/speech-loopback-carrier-run.fk
        presence/tests/speech-loopback-carrier-run-band.fk)
      (verdict 511))
    (carrier-run-ab
      (concat
        form/form-stdlib/hati-os-targets.fk
        form/form-stdlib/host-os-membrane.fk
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        presence/speech-loopback-carrier-receipt.fk
        learn/speech-loopback-recipe-ab.fk
        presence/speech-loopback-carrier-run.fk
        learn/tests/speech-loopback-carrier-run-ab-band.fk)
      (verdict 2047))
    (capture-learning
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        learn/speech-loopback-capture-learning.fk
        learn/tests/speech-loopback-capture-learning-band.fk)
      (verdict 8191)))

  (honest-boundary
    "The Android row now has a concrete AAudio render/capture learning receipt.
     It is still closed-prompt learning, not open dictation, natural neural TTS,
     Piper, say, whisper.cpp, CoreAudio, or WASAPI. The checkout C witness must
     keep this stack in bounded slices; an all-in-one speech aggregate crosses the
     current seed function table and should be solved by the native walker, not by
     growing the C seed."))
