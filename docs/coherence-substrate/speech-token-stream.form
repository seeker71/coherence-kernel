# speech-token-stream.form -- structural speech tokens plus voice metadata

(speech-token-stream

  (lineage
    (stream observe/speech-token-stream.fk
            "Form-native token rows for words, identity, route, control, evidence, memory, and voice-side metadata")
    (ctc observe/open-asr-ctc.fk
         "native CTC-style frame-token collapse emits this stream before lowering to open-dictation receipts")
    (acoustic-token-emitter observe/acoustic-token-emitter.fk
                            "supervised acoustic features emit the frame tokens the CTC layer consumes")
    (segmented-acoustic-learning learn/segmented-acoustic-token-learning.fk
                                 "learned segmented source tokens can route through this stream")
    (open-dictation learn/open-dictation-transcript-learning.fk
                    "the decoded transcript and confidence lower into the existing promotion gate"))

  (special-tokens
    (identity-provenance <NODE> <SOURCE>)
    (route-contract <CHANNEL> <INTERFACE>)
    (control <CHOICE> <FAIL> <UNDO> <TIMEOUT> <CUT>)
    (evidence <OBSERVE> <GRADE> <FEEDBACK> <REPAIR> <RECEIPT>)
    (memory-scope <STATE> <MEMORY> <SCOPE>)
    (word <WORD>))

  (voice-side-meta
    (confidence "earned confidence used by ASR/native promotion")
    (warmth "voice/prosody warmth side channel")
    (cadence "rhythm/timing side channel")
    (hesitation "uncertainty/hesitation side channel")
    (excitement "activation/lift side channel")
    (attunement "relational fit/listening side channel"))

  (runnable
    (stream-band
      (concat
        observe/speech-token-stream.fk
        observe/tests/speech-token-stream-band.fk)
      (verdict 32767))
    (ctc-band
      (concat
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        form/form-stdlib/observed-auto-learning.fk
        learn/open-dictation-transcript-learning.fk
        observe/speech-token-stream.fk
        observe/open-asr-ctc.fk
        observe/tests/open-asr-ctc-band.fk)
      (verdict 32767))
    (acoustic-token-emitter-band
      (concat
        observe/wav-sense.fk
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        form/form-stdlib/observed-auto-learning.fk
        learn/open-dictation-transcript-learning.fk
        observe/speech-token-stream.fk
        observe/open-asr-ctc.fk
        observe/acoustic-token-emitter.fk
        observe/tests/acoustic-token-emitter-band.fk)
      (verdict 32767))
    (segmented-acoustic-token-learning-band
      (concat
        observe/stt-wer.fk
        observe/speech-token-stream.fk
        observe/open-asr-ctc.fk
        observe/acoustic-token-emitter.fk
        learn/sanskrit-locale-baseline.fk
        learn/segmented-acoustic-token-learning.fk
        learn/tests/segmented-acoustic-token-learning-band.fk)
      (verdict 32767)))

  (honest-boundary
    "The token stream, CTC collapse decoder, and supervised acoustic token
     emitter are native Form. They do not claim a finished acoustic encoder:
     live audio still has to become segmented feature rows on device before this
     decoder can be live-selected over the current closed-prompt prototype ASR."))
