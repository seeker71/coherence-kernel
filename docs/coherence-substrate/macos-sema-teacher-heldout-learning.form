# macos-sema-teacher-heldout-learning.form -- held-out teacher repeat learning

(macos-sema-teacher-heldout-learning

  (purpose
    (summary "train on one local teacher wav and decode a separately rendered same-text wav")
    (boundary "same voice and same phrase; proves held-out repeat transfer, not new phrase or cross-voice authority"))

  (live-path
    (train "Flo renders Open speech flows. to teacher-984711.wav")
    (eval "Flo renders the same phrase separately to teacher-984712.wav with ffmpeg volume 0.98")
    (oracle "whisper.cpp large-v3-turbo on Apple Metal transcribes the eval wav")
    (learn "Form trains acoustic token prototypes from train wav-envelope rows")
    (decode "Form decodes eval wav-envelope rows through the trained prototypes and CTC collapse"))

  (model
    (kind "Form-native supervised acoustic prototype learner")
    (train-samples 1)
    (held-out-samples 1)
    (effective-epochs 1)
    (native-neural-parameters 0)
    (eval-volume 0.98)
    (max-distance 2)
    (min-confidence 80))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/macos-sema-teacher-heldout-learning.fk
      learn/tests/macos-sema-teacher-heldout-learning-band.fk)
    (contract-verdict 65535)
    (live-verdict 65535)
    (live-verdict-function msth-run-verdict))

  (next
    (cross-phrase "train on one phrase and test on another related phrase")
    (cross-voice "train on Flo and test another consented English voice")
    (multilocale "add held-out repeats for Arabic and Chinese short-line learners")))
