# speech-loopback-capture-learning.form -- Android on-device capture learning

(speech-loopback-capture-learning

  (lineage
    (wer observe/stt-wer.fk
         "word error rate before and after capture-driven learning")
    (promotion learn/speech-loopback-promotion.fk
               "clean learned windows route native")
    (capture-learning learn/speech-loopback-capture-learning.fk
                      "measured render/capture features update the closed-prompt native center")
    (bidirectional-locale learn/bidirectional-locale-roundtrip.fk
                          "A->B and B->A grow reciprocal trust through transcript and Form meaning")
    (self-corpus learn/coherence-network-self-corpus.fk
                 "translated Coherence Network content gives consentful text pairs")
    (diverse-pairing learn/diverse-locale-pairing.fk
                     "sample distant locale pairs so the invariant does not overfit one corridor")
    (carrier-run presence/speech-loopback-carrier-run.fk
                 "platform carrier readiness and recipe A/B context"))

  (android-device-receipt
    (device "Galaxy S23 Ultra SM-S918U1, arm64-v8a, SDK 36")
    (adb-serial "R5CW20DK17A")
    (temp-dir "/data/local/tmp/codex-e2e-capture-SOe4xk")
    (render "AAudio output, 16000 Hz, amplitude 9000, closed prompt 'we are'")
    (capture "AAudio input, 16000 Hz, one channel, 23200 frames")
    (facts
      (nonzero 23109)
      (energy 3006571)
      (avg-energy 129)
      (peak 561)
      (hash 811960308)
      (loopback-on 1491283)
      (loopback-off 1045058)
      (loopback-lag 4)
      (loopback-score 446225)
      (loopback 1))
    (form-call
      "(scl-on-device-check 16000 1 23200 23109 3006571 561 811960308 1491283 1045058 4 446225 129 9000 1)")
    (verdict 8191))

  (learning-law
    (before "untrained native transcript is away from the oracle prompt")
    (update "captured feature becomes the learned closed-prompt center")
    (after "learned native transcript equals the local oracle prompt")
    (improvement "feature distance decreases and WER improves to zero")
    (promotion "four clean learned samples route native")
    (reciprocity "cross-locale route trust expands only after A->B and B->A both improve"))

  (runnable
    (concat
      observe/stt-wer.fk
      learn/speech-loopback-promotion.fk
      learn/speech-loopback-capture-learning.fk
      learn/tests/speech-loopback-capture-learning-band.fk)
    (verdict 8191)
    (bidirectional-locale-roundtrip
      (concat
        learn/bidirectional-locale-roundtrip.fk
        learn/tests/bidirectional-locale-roundtrip-band.fk)
      (verdict 2047))
    (diverse-locale-pairing
      (concat
        learn/diverse-locale-pairing.fk
        learn/tests/diverse-locale-pairing-band.fk)
      (verdict 8191))
    (coherence-network-self-corpus
      (concat
        learn/coherence-network-self-corpus.fk
        learn/tests/coherence-network-self-corpus-band.fk)
      (verdict 8191)))

  (honest-boundary
    "This is a real Android render/capture receipt and a real Form learning
     receipt. It is closed-prompt learning with a local prompt-label oracle,
     not open dictation, cloud STT, whisper.cpp, or natural neural TTS. Raw
     audio was not retained."))
