# speech-corpus-training-intake-0003.form -- screened phrase batch enters training

(speech-corpus-training-intake-0003

  (purpose
    (summary "admit the third screened, local-oracle-clean self-corpus batch into native prototype training")
    (boundary "training floor expands; data sufficiency and global ASR/TTS/Sema voice authority remain false"))

  (source
    (previous-intake learn/speech-corpus-training-intake-0002.fk)
    (capture-batch learn/speech-corpus-capture-batch-0003.fk)
    (screened-candidate-rows 60)
    (captured-rows 34)
    (local-oracle-accepted 34)
    (max-wer 25)
    (observed-wav-bytes 1272388)
    (locales "en, de, es, fr, id, pt-br"))

  (training-intake
    (batch-rows-admitted 34)
    (batch-rate "34/34 = 100%")
    (cumulative-rows-admitted 64)
    (cumulative-rate "64/64 = 100%")
    (cumulative-observed-source-bytes 2065622)
    (route "native-prototype-training-intake")
    (data-sufficient false)
    (minimum-wav-floor 12000)
    (global-authority false)
    (status "screened-corpus-training-intake-expanded-not-data-sufficient"))

  (runnable
    (concat
      learn/speech-corpus-training-intake-0001.fk
      learn/speech-corpus-training-intake-0002.fk
      learn/speech-corpus-training-intake-0003.fk
      learn/tests/speech-corpus-training-intake-0003-band.fk)
    (verdict 32767)))
