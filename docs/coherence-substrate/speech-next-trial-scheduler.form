# speech-next-trial-scheduler.form -- next oracle-to-native speech trial

(speech-next-trial-scheduler

  (source
    (backlog learn/speech-oracle-native-backlog.fk)
    (rule "local oracle teaches native A/B recipes until receipts promote"))

  (next-trial
    (id "trial-open-asr-0001")
    (gap "live-open-dictation")
    (incumbent "prototype-asr")
    (challenger "native-segmented-acoustic-learning")
    (recipe "segmented-open-asr-source-window-v1")
    (source "oracle-passing-live-dictation-window")
    (oracle "4/4 = 100%, WER 0")
    (native "0/4 = 0%, WER 100")
    (action "train-live-segmented-open-asr-source")
    (promote "native-rate >= 50, WER <= 25, clean controls"))

  (queued-trial
    (id "trial-sema-voice-0001")
    (gap "sema-live-voice")
    (incumbent "sema-voice-sample-loop")
    (challenger "text-conditioned-acoustic-vocoder")
    (recipe "tcav-warm-mid-cadence-v1")
    (source "local-render-stt-oracle-candidate-window")
    (oracle "1/1 = 100%, WER 0")
    (native "0/1 = 0%, WER 100")
    (action "render-and-oracle-next")
    (promote "oracle WER <= 25, then candidate-search promote"))

  (controls "choice, cut, fail, undo, timeout")

  (model-context
    (native-neural-weight-parameters-admitted 0)
    (pending-neural-weight-lanes 2)
    (native-sema-voice-organs 6)
    (selected-arms 4)
    (major-form-components 14)
    (c-seed-growth 0))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/tests/speech-next-trial-scheduler-band.fk)
    (verdict 32767)))
