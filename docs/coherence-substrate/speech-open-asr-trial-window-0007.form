# speech-open-asr-trial-window-0007.form -- en/it scoped open-ASR source window

(speech-open-asr-trial-window-0007

  (purpose
    (summary "add a real local Metal en/it loopback window to the scoped open-ASR source learner")
    (boundary "routes native only inside the trial window; global open microphone authority remains oracle-held"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (render-path "say -> ffmpeg -> whisper-cli")
    (english
      (voice "Samantha")
      (truth "i am")
      (heard "I am.")
      (wer 0)
      (wav-bytes 18170)
      (cksum 3569739330))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (scoped-open-asr-rows "12 -> 14")
    (oracle "14/14 = 100%")
    (native "14/14 = 100%")
    (observed-wav-bytes 34876)
    (route "native inside trial window"))

  (authority-boundary
    (global-open-dictation "oracle 4/4, native 0/4, oracle-guide")
    (open-authority false)
    (c-seed-growth 0))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/speech-open-asr-trial-window-0002.fk
      learn/speech-open-asr-trial-window-0003.fk
      learn/speech-open-asr-trial-window-0004.fk
      learn/speech-open-asr-trial-window-0005.fk
      learn/speech-open-asr-trial-window-0006.fk
      learn/speech-open-asr-trial-window-0007.fk
      learn/tests/speech-open-asr-trial-window-0007-band.fk)
    (verdict 32767)))
