# sema-voice-local-oracle-receipt.form -- local STT bar for Sema samples

(sema-voice-local-oracle-receipt

  (lineage
    (token-wer observe/stt-wer.fk
               "shared Unicode tokenization and sequence-aligned WER")
    (formant-carrier presence/formant-vocoder.fk
                     "native deterministic source-filter waveform carrier")
    (sema-voice-loop learn/sema-voice-sample-loop.fk
                     "target, rendered sample, score, and A/B promotion")
    (receipt learn/sema-voice-local-oracle-receipt.fk
             "local oracle transcript bar for generated Sema voice samples"))

  (pass-condition
    (locality "oracle STT is local and sample audio is local")
    (audio "audio hash, sample rate, and channels are present")
    (consistency "receipt audio hash matches the Sema voice sample hash")
    (truth "oracle transcript WER is below the requested threshold against side-channel truth")
    (control "fail, timeout, undo, cloud, and missing audio block authority")
    (promotion "A/B promotion requires the local oracle bar plus the Sema voice sample loop"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      learn/sema-voice-sample-loop.fk
      learn/sema-voice-local-oracle-receipt.fk
      learn/tests/sema-voice-local-oracle-receipt-band.fk)
    (verdict 32767))

  (honest-boundary
    "This proves the Form-owned local-oracle STT bar for Sema-generated
     samples. It does not claim that a fresh Sema-formant wav has already been
     rendered on host metal and transcribed by local Whisper. That live carrier
     receipt is the next witness."))
