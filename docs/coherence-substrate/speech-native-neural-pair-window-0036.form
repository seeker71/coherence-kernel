# speech-native-neural-pair-window-0036.form -- fr<->it neural pair window

(speech-native-neural-pair-window-0036

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (scheduler-correction
    (previous-target "0036 fr<->de")
    (reason "de<->fr already exists in speech-native-neural-pair-window-0017")
    (chosen "0036 fr<->it"))

  (pair
    (a "fr")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "fr->it, it->fr, fr->fr, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (french
      (voice "Thomas")
      (truth "je suis")
      (heard "Je suis")
      (wer 0)
      (wav-bytes 17908)
      (cksum 3224208913))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 36)
    (cumulative-directed-routes 72)
    (epochs 36)
    (native-neural-params 36)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0036-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0036.fk
      learn/tests/speech-native-neural-pair-window-0036-band.fk)
    (verdict 32767)))
