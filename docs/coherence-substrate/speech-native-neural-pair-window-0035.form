# speech-native-neural-pair-window-0035.form -- fr<->la neural pair window

(speech-native-neural-pair-window-0035

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "fr")
    (b "la")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "fr->la, la->fr, fr->fr, la->la"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (french
      (voice "Thomas")
      (truth "je suis")
      (heard "Je suis")
      (wer 0)
      (wav-bytes 17908)
      (cksum 3224208913))
    (latin-baseline-carrier
      (voice "Daniel (English (UK))")
      (truth "ego sum")
      (heard "Ego sum.")
      (wer 0)
      (wav-bytes 25994)
      (cksum 163923376)
      (boundary "Latin baseline phrase carried by host voice")))

  (result
    (cumulative-neural-pairs 35)
    (cumulative-directed-routes 70)
    (epochs 35)
    (native-neural-params 35)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0035-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0035.fk
      learn/tests/speech-native-neural-pair-window-0035-band.fk)
    (verdict 32767)))
