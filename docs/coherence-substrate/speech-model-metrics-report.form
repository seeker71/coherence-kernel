# speech-model-metrics-report.form -- current native speech metrics

(speech-model-metrics-report

  (model-size
    (native-neural-weight-parameters-admitted 0)
    (selected-arms 4)
    (major-form-components 14)
    (native-sema-voice-organs 6)
    (c-seed-growth 0)
    (layout "deterministic prototypes + Form micro-kernels + local-oracle receipts"))

  (composition
    (asr "prototype-asr")
    (tts "sema-voice-sample-loop")
    (nl2nl "closed-set-locale-form")
    (audio2audio "native-source-window-audio2audio-acoustic")
    (support "sanskrit-locale-baseline, text-conditioned-acoustic-vocoder, sema-voice-vocoder-oracle-bridge, live-segmented-feature-carrier"))

  (success-rates
    (closed-prompt-metal-anchors "7/7 = 100%")
    (en-zh-live-anchor "10/12 = 83%")
    (en-ar-live-anchor "12/12 = 100%")
    (live-open-dictation-oracle "4/4 = 100%")
    (live-open-dictation-native "0/4 = 0%")
    (sema-live-voice-live-native-pass "0/1 = 0%")
    (sema-native-voice-machinery "present; live sample not passing"))

  (voice-quality
    (target "warm mid, rounded/grounded, honest")
    (f0 165)
    (warmth 82)
    (cadence 64)
    (steadiness 76)
    (breath 18)
    (live-state "current formant voice WER 100, oracle-guide"))

  (native-vs-local-oracle
    (closed-prompt "native and oracle both 7/7 at anchor level")
    (open-dictation "local oracle 4/4, native 0/4")
    (sema-live-voice "native voice machinery exists; live rendered sample does not pass the local oracle bar")
    (authority "oracle teaches until native receipts win"))

  (trend-report
    (file learn/speech-model-metrics-trend.fk)
    (verdict 32767)
    (movement "2 native-shifted lanes, 2 oracle-held lanes, average native rate 45"))

  (locale-coverage
    (file learn/speech-locale-coverage-matrix.fk)
    (verdict 32767)
    (coverage "13 locales tracked, 11 ready, 8 live-anchor/carrier-live, 10 native pair rows, 2 oracle-guided rows"))

  (oracle-native-backlog
    (file learn/speech-oracle-native-backlog.fk)
    (verdict 32767)
    (gap "live open dictation local-oracle 4/4 but native 0/4; Sema live voice local-oracle 0/1 and native 0/1")
    (meaning "native neural weights are 0 admitted; native speech organs are present"))

  (runnable
    (concat
      learn/speech-model-metrics-report.fk
      learn/tests/speech-model-metrics-report-band.fk)
    (verdict 32767)))
