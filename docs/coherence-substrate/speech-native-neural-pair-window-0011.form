# speech-native-neural-pair-window-0011.form -- eleventh trained neural pair

(speech-native-neural-pair-window-0011

  (purpose
    (summary "train the eleventh native neural micro-pair window")
    (boundary "this grows trained neural pair coverage, but is not full open ASR/TTS authority"))

  (pair
    (a sa)
    (b la)
    (meaning 304)
    (baseline "lokah-samastah-sukhino-bhavantu")
    (pair-increment 1)
    (directed-increment 2)
    (cumulative-trained-pairs 11)
    (cumulative-directed-routes 22)
    (epochs 11)
    (native-neural-parameters 11))

  (result
    (neural-rate "0 -> 100")
    (form-nl-rate 100)
    (form-audio-rate 100)
    (bootstrap-loss "1 -> 0")
    (route-shifted true)
    (oracle true)
    (native-form true)
    (open-authority false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0011.fk
      learn/tests/speech-native-neural-pair-window-0011-band.fk)
    (verdict 32767)))
