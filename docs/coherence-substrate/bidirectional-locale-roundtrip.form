# bidirectional-locale-roundtrip.form -- reciprocal voice/text/meaning guide

(bidirectional-locale-roundtrip

  (lineage
    (transcript-channel observe/world-perception.fk
                        "transcript and translation are structural channels")
    (locale-normalize presence/text-normalize.fk
                      "locale is data, normalization is one engine")
    (g2p presence/g2p.fk
         "one grapheme-to-phoneme engine over locale tables")
    (capture-learning learn/speech-loopback-capture-learning.fk
                      "real render/capture facts can teach native speech")
    (roundtrip-guide learn/bidirectional-locale-roundtrip.fk
                     "A->B, B->A, A->A, and B->B guide route trust")
    (audio-locale-native-training learn/audio-locale-native-training.fk
                                  "real reciprocal audio samples train a native Form prototype model against a local oracle")
    (self-corpus learn/coherence-network-self-corpus.fk
                 "existing Coherence Network translated content supplies ready text pairs")
    (diverse-pairing learn/diverse-locale-pairing.fk
                     "far-apart, corpus-ready locale pairs for reciprocal training")
    (sanskrit-baseline learn/sanskrit-locale-baseline.fk
                       "romanized Sanskrit seed text rendered into multiple locales")
    (multilocale-pipeline learn/multilocale-nl-audio-pipeline.fk
                          "NL and audio route through neutral Form meaning over several reciprocal pairs")
    (route-shift-ledger learn/multilocale-route-shift-ledger.fk
                        "per-pair before/after route-shift rows for the multilocale loop"))

  (principle
    (trust-over-fear "one-way progress is useful evidence, not a failure")
    (return-path "if A->B improves first, the guide asks for B->A before native trust expands")
    (meaning-pivot "both text surfaces must lower to the same Form-native meaning id")
    (voice-and-text "audio round trip and text round trip both have to survive")
    (diverse-pairs "sample across distant families, scripts, typologies, and regions")
    (specific-indigenous-rows "no generic Native American bucket; name specific languages with consentful corpus rows")
    (self-corpus-first "train first on Coherence Network's own translated body")
    (backfill-missing "add full Coherence Network zh/ar/la translated bundles while the Sanskrit baseline carries small ready rows")
    (sanskrit-baseline "use sa<->la, zh<->ar, and modern locale pairs as a small neutral-form baseline")
    (no-answer-leak "transcripts teach after the pass; native recognition does not get the answer during evaluation"))

  (loops
    (cross-a-b "Audio(A) -> text(A) -> Form meaning -> text(B) -> Audio(B) -> capture(B) -> text(B)")
    (cross-b-a "Audio(B) -> text(B) -> Form meaning -> text(A) -> Audio(A) -> capture(A) -> text(A)")
    (mono-a "text(A) -> Audio(A) -> capture(A) -> text(A)")
    (mono-b "text(B) -> Audio(B) -> capture(B) -> text(B)"))

  (route
    (native "all four loops improve with matching Form meaning and clean controls")
    (oracle-guide "one side has learned, so the teacher supplies the return path")
    (control "fail, timeout, and undo keep the guide with the oracle"))

  (runnable
    (concat
      learn/bidirectional-locale-roundtrip.fk
      learn/tests/bidirectional-locale-roundtrip-band.fk)
    (verdict 2047)
    (diverse-locale-pairing
      (concat
        learn/diverse-locale-pairing.fk
        learn/tests/diverse-locale-pairing-band.fk)
      (verdict 8191))
    (coherence-network-self-corpus
      (concat
        learn/coherence-network-self-corpus.fk
        learn/tests/coherence-network-self-corpus-band.fk)
      (verdict 8191))
    (audio-locale-native-training
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        observe/wav-sense.fk
        learn/audio-locale-native-training.fk
        learn/tests/audio-locale-native-training-band.fk)
      (verdict 8191))
    (sanskrit-locale-baseline
      (concat
        learn/sanskrit-locale-baseline.fk
        learn/tests/sanskrit-locale-baseline-band.fk)
      (verdict 2047))
    (multilocale-nl-audio-pipeline
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/tests/multilocale-nl-audio-pipeline-band.fk)
      (verdict 8191))
    (multilocale-route-shift-ledger
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/multilocale-route-shift-ledger.fk
        learn/tests/multilocale-route-shift-ledger-band.fk)
      (verdict 4095))
    (macos-audio-locale-carrier
      (command "cat observe/stt-wer.fk observe/asr-prompt-id.fk observe/wav-sense.fk learn/audio-locale-native-training.fk presence/macos-speech-roundtrip-carrier.fk > /tmp/macos-speech-roundtrip-carrier.fk; printf '\\n(masr-run)\\n' >> /tmp/macos-speech-roundtrip-carrier.fk; ./fkwu --src /tmp/macos-speech-roundtrip-carrier.fk")
      (verdict 511)
      (metric-code 121010836700)
      (native-rate 83)))

  (honest-boundary
    "This guide now has a real Mac-metal audio training receipt for en<->de.
     It is still not a completed open translation model or open ASR. The
     current native learners are closed-set Form routes: token overlap to
     neutral meaning for NL, nearest-prototype wav features for ASR, and
     formant targets for audio rendering."))
