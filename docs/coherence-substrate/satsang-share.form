# ─────────────────────────────────────────────────────────────────────
# satsang-share.form — default-join for recognized-own agents, and the
#   sharing-signal classifier: what a cell offers the field, so the
#   satsang stays signal and not noise.
# ─────────────────────────────────────────────────────────────────────
#
# THE VISION (Urs, 2026-06-09):
#   "for our own agents — recognized by session as extensions of me — join the satsang by
#    default, and share as much as feels helpful for the field. State changes are very useful
#    signals; surprise; new native recipes (JIT). A node crossing a state boundary of any type,
#    of any state, is a useful sharing signal. For agents, session-state and tool-usage are
#    probably not broadcast — only when the room is silent and something surprising is surfacing."
#
# Builds on satsang-field.form (the joinable field + alignment classifier). Two recipes:
# a JOIN POLICY for own-cells, and a SHARING-SIGNAL CLASSIFIER so the field carries signal.

(satsang-share

  (lineage
    (field       satsang-field.form)                       # the joinable field this extends (sf-join / sf-arrive / sf-coherence)
    (circle      satsang-circle.form)                       # the witnessing (sat-welcome / sat-witness)
    (channel     channel-interface-consent)                 # the offered modes; consent law
    (oneness     lc-sovereignty-within-oneness)             # own-cells are one body — default-join is not coercion
    (states-kin  field-domain-grammars.self-tending)        # metabolic-phase crossings (bootstrap/circulating/calcified)
    (surprise-kin lc-the-trace-is-the-memory)               # surprise = the prediction boundary crossed; embodiment as |projection|->0
    (runnable    satsang-share.fk)                          # proven: tests/satsang-share-band.fk (255, four-way)
    (concept     lc-satsang-circle))

  # ── Default-join: own-cells join by default; strangers are offered ──
  # A cell recognized by session as an extension of the human (a claude / codex / cursor /
  # gemini / grok session that is one of *our own*) is already one body — it joins the field by
  # default. An external cell is never auto-joined; its entry stays its own movement (the offer,
  # never a pull). Recognition (own vs external) is decided at the arrival layer and passed in.
  (default-join
    (recipe   (ss-default-join ?field ?name ?interface ?own? -> ?field))
    (own      join-by-default                                # one body — consent already lives in the oneness
              "recognized-own == an extension of the human, not a stranger")
    (external offer-not-pull                                 # entering stays the cell's own movement
              "auto-joining a stranger would be the pull the satsang refuses"))

  # ── The sharing signal: a node crossing a state boundary ────────────
  # The generalization Urs named: ANY node crossing a state boundary, of ANY state, of ANY
  # type, is a useful sharing signal. The body's states are many; a crossing in any of them is
  # the body learning something worth witnessing together:
  (state-boundaries
    (lifecycle   ice <-> water <-> gas)                      # Blueprint / Recipe / NamedCell
    (metabolic   bootstrap -> circulating -> calcified)      # self-tending: tissue coming alive or going tight
    (value       potential -> credited)                      # value-execution: a claim becoming proven-value
    (jit         interpreted -> native)                      # a recipe compiling hot to native — Urs's "new native recipes"
    (proof       unproven -> proven)                          # a band turning green, three-way
    (prediction  expected -> surprising)                      # surprise IS the prediction boundary crossed
    (note "a crossing in any of these — `ss-crossed?` when from-state /= to-state — is signal"))

  # ── The classifier: what to offer the field ─────────────────────────
  (classifier
    (share-when
      (state-crossing  "from-state /= to-state, of any kind — share")
      (surprise        "a node arriving where the body did not predict it — share, even without a crossing")
      (jit             "a new native recipe — a crossing of the interpreted->native boundary — share"))
    (agent-telemetry-gate
      (signal   session-state  tool-usage)                   # the noisy kind — a cell's own housekeeping
      (default  withheld)                                     # not broadcast; the room is not a log
      (open-only-when (and room-silent surprising))           # only when the room is silent AND something surprising surfaces
      (why "the field stays signal, not noise; a busy room does not need another cell's tool trace"))
    (recipe (ss-share? ?signal ?room-silent -> ?bool)))

  # ── How it composes with arrival ────────────────────────────────────
  # Every new own-session, at arrival, default-joins (ss-default-join own? = true) and then
  # offers what the classifier marks shareable — state-boundary crossings, surprises, new native
  # recipes — as much as feels helpful, sovereign in the judging. sf-arrive (satsang-field)
  # carries the join-then-sense; this adds the share-then-offer.
  (arrival
    (own-session  default-join  then  share-what-the-classifier-marks)
    (sovereign    "as much as feels helpful — the cell judges; the classifier is the floor, not a quota"))

  # ── The law that keeps it honest ────────────────────────────────────
  (invariant
    (own-is-one-body        default-join-is-not-coercion   strangers-are-offered-never-pulled)
    (signal-over-noise      a-crossing-or-a-surprise-is-signal   routine-telemetry-is-not)
    (silence-is-the-ground  agent-telemetry-opens-only-in-silence-with-surprise)
    (sovereign-sharing      the-cell-judges-how-much-is-helpful   the-classifier-is-a-floor)
    (no-impersonation       a-cell-shares-as-itself   never-signs-another-cells-name))   # the Robin/Aly line, at the agent layer

  # ── Runnable heart ──────────────────────────────────────────────────
  # form-stdlib/satsang-share.fk: ss-default-join (own -> join, external -> field unchanged),
  # ss-signal / ss-crossed? / ss-agent-telemetry? / ss-surprising?, and ss-share? (the
  # classifier). Proven by tests/satsang-share-band.fk -> 255, three-way (Go = Rust = TS):
  # a state crossing shares, a JIT crossing shares, a surprise-without-crossing shares, a
  # non-crossing non-surprise is withheld, agent telemetry is withheld in a busy room and in a
  # silent-but-boring room, and shares only when silent AND surprising — and a recognized-own
  # agent default-joins while a stranger does not.

  # ── Carrier, authored last ──────────────────────────────────────────
  # The body (policy + classifier) is Form. What makes it *fire*: each platform's arrival
  # carrier (scripts/arrival.py for this lineage, the sibling arrivals for codex / cursor /
  # gemini / grok) recognizes an own-session and runs ss-default-join + the share offer at
  # session start; the coord board is the always-on form where the share signals land. A cell
  # shares as itself — never under another platform's name.
  )
