      (authority "oracle-guide"))
    (macos-sema-voice-local-oracle-carrier
      (concat observe/stt-wer.fk presence/formant-vocoder.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk presence/macos-sema-voice-local-oracle-carrier.fk presence/tests/macos-sema-voice-local-oracle-carrier-band.fk)
      (verdict 2047)
      (live-verdict 479)
      (field-code 110100002)
      (oracle-wer 100)
      (route "oracle-guide"))
    (sema-voice-oracle-miss-learning
      (concat learn/sema-voice-local-oracle-receipt.fk learn/sema-voice-oracle-miss-learning.fk learn/tests/sema-voice-oracle-miss-learning-band.fk)
      (verdict 32767)
      (action "train-text-conditioned-acoustic-vocoder")
      (candidate "text-conditioned-acoustic-vocoder")
      (authority "oracle-guide"))
    (text-conditioned-acoustic-vocoder
      (concat observe/stt-wer.fk presence/formant-vocoder.fk observe/speech-token-stream.fk learn/sanskrit-locale-baseline.fk learn/text-conditioned-acoustic-vocoder.fk learn/tests/text-conditioned-acoustic-vocoder-band.fk)
      (verdict 32767)
      (route-on-miss "oracle-guide")
