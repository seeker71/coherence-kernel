# native-vocoder-asr-loopback.form -- first native speech loopback

(native-vocoder-asr-loopback

  (lineage
    (vocoder presence/formant-vocoder.fk
             "source-filter/formant waveform samples from phoneme frames")
    (prompt-asr observe/asr-prompt-id.fk
                "closed-set prompt recognition by nearest measured feature vector")
    (wer observe/stt-wer.fk
         "sequence-aligned transcript error")
    (loopback presence/native-speech-loopback.fk
              "vocoder fingerprint -> prompt ASR -> WER route gate")
    (promotion learn/speech-loopback-promotion.fk
               "receipt windows that shift authority from oracle to native")
    (carrier-receipt presence/speech-loopback-carrier-receipt.fk
                     "real local TTS/STT loopback facts admitted into the same promotion guide")
    (carrier-run presence/speech-loopback-carrier-run.fk
                 "platform readiness and recipe A/B wrapped around the same loopback guide")
    (capture-learning learn/speech-loopback-capture-learning.fk
                      "real on-device render/capture facts improve closed-prompt native toward oracle")
    (live-open-asr-source-authority learn/live-open-asr-source-authority.fk
                                    "live open-dictation miss trains segmented open-ASR source authority")
    (audio-locale-native-training learn/audio-locale-native-training.fk
                                  "reciprocal audio locale samples train native prototypes against a local oracle")
    (speech-locale-learning-window learn/speech-locale-learning-window.fk
                                   "selected diverse baseline pair becomes an observed numeric NL/audio learning window")
    (model-selector learn/speech-model-auto-selection.fk
                    "AutoML selects the current ASR/TTS/NL/audio model arms from receipts")
    (sema-live-oracle-carrier presence/macos-sema-voice-local-oracle-carrier.fk
                              "target-derived Sema formant waveform measured by local Whisper on Apple Metal")
    (sema-miss-learning learn/sema-voice-oracle-miss-learning.fk
                        "WER-100 live miss becomes the next acoustic/vocoder training action")
    (text-conditioned-acoustic-vocoder learn/text-conditioned-acoustic-vocoder.fk
                                       "target tokens plus voice metadata become native source-filter frames")
    (native-audio2audio-acoustic-bridge learn/native-audio2audio-acoustic-bridge.fk
                                        "decoded source-audio token rows become target-locale acoustic frames")
    (multilocale-audio2audio-acoustic-sweep learn/multilocale-audio2audio-acoustic-sweep.fk
                                            "five reciprocal baseline pairs run through the target acoustic bridge")
    (metal-audio2audio-acoustic-authority learn/metal-audio2audio-acoustic-authority.fk
                                          "seven live Metal anchors select the decoded-token acoustic arm"))

  (borrowed-shape
    (espeak-world "explicit source, duration, pitch, formant envelope, and waveform measurement")
    (whisper-local-oracle "local ASR remains a teacher/carrier for open speech, not native authority")
    (piper-or-say "local TTS remains a teacher/carrier for natural sound, not native authority"))

  (why-this-first
    "A tiny formant carrier is less natural than a neural vocoder, but it is inspectable:
     every sample comes from phoneme, duration, pitch, amplitude, and formant data. A
     closed-set ASR prompt route is less general than dictation, but it can earn real
     authority on measured loopback before native open ASR exists.")

  (native-now
    (formant-vocoder 511)
    (asr-prompt-id 255)
    (native-speech-loopback 1023)
    (speech-loopback-promotion 2047)
    (speech-loopback-carrier-receipt 4095)
    (speech-loopback-carrier-run 511)
    (speech-loopback-carrier-run-ab 2047)
    (speech-loopback-capture-learning 8191)
    (audio-locale-native-training 8191)
    (audio-locale-route-shift-ledger 8191)
    (speech-locale-learning-window 16383)
    (macos-audio-locale-carrier 511)
    (speech-model-auto-selection 268435455)
    (acoustic-token-emitter 32767)
    (segmented-acoustic-token-learning 32767)
    (live-open-asr-source-authority 32767)
    (multilocale-segmented-source-window 32767)
    (macos-sema-voice-local-oracle-carrier 2047)
    (sema-voice-oracle-miss-learning 32767)
    (text-conditioned-acoustic-vocoder 32767)
    (native-audio2audio-acoustic-bridge 32767)
    (multilocale-audio2audio-acoustic-sweep 32767)
    (metal-audio2audio-acoustic-authority 32767)
    (source-window-audio2audio-authority 32767))

  (route-shift-guide
    (native-route "confidence passes, WER <= floor, no timeout/fail")
    (oracle-route "ambiguous feature, high WER, timeout, fail, or unseen prompt")
    (promotion "observed-auto-learning can aggregate these loopback receipts over windows")
    (window-promotion "speech-loopback-promotion.fk makes that aggregation executable now"))

  (honest-boundary
    (sound-quality "synthetic/formant, not natural neural speech")
    (asr-scope "closed prompt set; open transcript receipts, CTC decode, and supervised acoustic token emission now live separately")
    (carrier "Android microphone/speaker capture has a closed-prompt learning receipt; live segmented open-ASR carriers remain pending"))

  (runnable
    (formant-vocoder
      (concat presence/formant-vocoder.fk presence/tests/formant-vocoder-band.fk)
      (verdict 511))
    (asr-prompt-id
      (concat observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk observe/tests/asr-prompt-id-band.fk)
      (verdict 255))
    (native-speech-loopback
      (concat observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk presence/native-speech-loopback.fk presence/tests/native-speech-loopback-band.fk)
      (verdict 1023))
    (speech-loopback-promotion
      (concat observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk presence/native-speech-loopback.fk learn/speech-loopback-promotion.fk learn/tests/speech-loopback-promotion-band.fk)
      (verdict 2047))
    (speech-loopback-carrier-receipt
      (concat observe/stt-wer.fk learn/speech-loopback-promotion.fk presence/speech-loopback-carrier-receipt.fk presence/tests/speech-loopback-carrier-receipt-band.fk)
      (verdict 4095))
    (speech-loopback-carrier-run
      (concat form/form-stdlib/hati-os-targets.fk form/form-stdlib/host-os-membrane.fk observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk presence/native-speech-loopback.fk learn/speech-loopback-promotion.fk presence/speech-loopback-carrier-receipt.fk presence/speech-loopback-carrier-run.fk presence/tests/speech-loopback-carrier-run-band.fk)
      (verdict 511))
    (speech-loopback-carrier-run-ab
      (concat form/form-stdlib/hati-os-targets.fk form/form-stdlib/host-os-membrane.fk observe/stt-wer.fk learn/speech-loopback-promotion.fk presence/speech-loopback-carrier-receipt.fk learn/speech-loopback-recipe-ab.fk presence/speech-loopback-carrier-run.fk learn/tests/speech-loopback-carrier-run-ab-band.fk)
      (verdict 2047))
    (speech-loopback-capture-learning
      (concat observe/stt-wer.fk learn/speech-loopback-promotion.fk learn/speech-loopback-capture-learning.fk learn/tests/speech-loopback-capture-learning-band.fk)
      (verdict 8191))
    (audio-locale-native-training
      (concat observe/stt-wer.fk observe/asr-prompt-id.fk observe/wav-sense.fk learn/audio-locale-native-training.fk learn/tests/audio-locale-native-training-band.fk)
      (verdict 8191))
    (audio-locale-route-shift-ledger
      (concat observe/stt-wer.fk observe/asr-prompt-id.fk observe/wav-sense.fk learn/audio-locale-native-training.fk learn/audio-locale-route-shift-ledger.fk learn/tests/audio-locale-route-shift-ledger-band.fk)
      (verdict 8191))
    (speech-locale-learning-window
      (concat observe/stt-wer.fk observe/asr-prompt-id.fk learn/diverse-locale-pairing.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-locale-learning-window.fk learn/tests/speech-locale-learning-window-band.fk)
      (verdict 16383))
    (speech-model-auto-selection
      (concat form/form-stdlib/somatic-coherence-loop.fk form/form-stdlib/form-cli-router.fk form/form-stdlib/form-cli-sufficiency.fk form/form-stdlib/observed-auto-learning.fk learn/sema-voice-local-oracle-receipt.fk learn/sema-voice-oracle-miss-learning.fk learn/live-open-asr-source-authority.fk learn/speech-model-auto-selection.fk learn/tests/speech-model-auto-selection-band.fk)
      (selected-asr "prototype-asr")
      (selected-tts "sema-voice-sample-loop")
      (selected-nl2nl "closed-set-locale-form")
      (selected-audio2audio "native-source-window-audio2audio-acoustic")
      (voice-miss-action "train-text-conditioned-acoustic-vocoder")
      (diffusion "candidate-not-ready")
      (open-asr-action "train-live-segmented-open-asr-source")
      (source-window "multilocale-segmented-source-window")
      (verdict 268435455))
    (acoustic-token-emitter
      (concat observe/wav-sense.fk observe/stt-wer.fk learn/speech-loopback-promotion.fk form/form-stdlib/observed-auto-learning.fk learn/open-dictation-transcript-learning.fk observe/speech-token-stream.fk observe/open-asr-ctc.fk observe/acoustic-token-emitter.fk observe/tests/acoustic-token-emitter-band.fk)
      (verdict 32767))
    (segmented-acoustic-token-learning
      (concat observe/stt-wer.fk observe/speech-token-stream.fk observe/open-asr-ctc.fk observe/acoustic-token-emitter.fk learn/sanskrit-locale-baseline.fk learn/segmented-acoustic-token-learning.fk learn/tests/segmented-acoustic-token-learning-band.fk)
      (verdict 32767))
    (live-open-asr-source-authority
