# speech-native-neural-pair-window-0042.form -- sa<->it neural pair window

(speech-native-neural-pair-window-0042

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "sa")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "sa->it, it->sa, sa->sa, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (sanskrit-baseline-romanized
      (voice "Rishi (English (India))")
      (truth "aham asmi")
      (heard "Aham Asmi.")
      (wer 0)
      (wav-bytes 27510)
      (cksum 2808389783)
      (boundary "romanized baseline carrier; not a native Sanskrit OS voice"))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 42)
    (cumulative-directed-routes 84)
    (epochs 42)
    (native-neural-params 42)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0042-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0042.fk
      learn/tests/speech-native-neural-pair-window-0042-band.fk)
    (verdict 32767)))
