# sema-voice-candidate-search.form -- ranked local voice candidates

(sema-voice-candidate-search

  (lineage
    (live-miss learn/sema-voice-oracle-miss-learning.fk
               "live Sema formant carrier: WER 100, route oracle-guide")
    (oracle-bar learn/sema-voice-local-oracle-receipt.fk
                "local Whisper transcript bar and consent/control gates")
    (sample-loop learn/sema-voice-sample-loop.fk
                 "target fit, listener grade, intelligibility, WER, latency"))

  (what-it-adds
    (search-space "Form-native candidate recipes, not host scripts")
    (ranking "oracle WER improvement + target fit + intelligibility + listener grade + latency")
    (controls "local, consented, clean rows only; fail/timeout/undo cannot win")
    (authority "candidate may render next or promote only through the same local oracle bar"))

  (candidate-recipes
    (text-conditioned-acoustic-vocoder
      (layout "text+voice-meta-to-source-filter-frames")
      (native-form 1)
      (neural-ready 0))
    (formant-retune
      (layout "target-profile-to-source-filter-frames")
      (native-form 1)
      (neural-ready 0))
    (neural-vocoder-pending
      (layout "external-neural-vocoder-placeholder")
      (native-form 0)
      (neural-ready 1)
      (admitted 0)))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      learn/sema-voice-sample-loop.fk
      learn/sema-voice-local-oracle-receipt.fk
      learn/sema-voice-oracle-miss-learning.fk
      learn/sema-voice-candidate-search.fk
      learn/tests/sema-voice-candidate-search-band.fk)
    (verdict 32767))

  (honest-boundary
    "This does not claim the current live Sema voice passes STT. It gives the
     body a native search/ranking membrane for the next local render+oracle
     samples, and keeps neural vocoder authority pending until witnessed."))
