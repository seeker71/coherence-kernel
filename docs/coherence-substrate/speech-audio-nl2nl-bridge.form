# speech-audio-nl2nl-bridge.form -- oracle-guided audio to neutral to audio

(speech-audio-nl2nl-bridge

  (purpose
    (summary "witness reciprocal audio A -> neutral corpus key -> text/audio B routes")
    (boundary "native Form owns neutral routing and target text; host TTS and local Whisper remain carrier/oracle"))

  (routes
    (count 6)
    (pairs "en->de de->en es->pt-br pt-br->es fr->id id->fr")
    (neutral-key "common.no")
    (neutral-meaning 404)
    (source-oracle-accepted 6)
    (target-oracle-accepted 6)
    (native-neutral-routing-accepted 6)
    (observed-wav-bytes 243348)
    (native-vocoder 0)
    (native-neural-parameters 0)
    (status "oracle-guided-audio-nl2nl-audio-bridge-not-native-vocoder"))

  (aggregate-after-run
    (live-wav-rows 59)
    (observed-wav-bytes 1611598)
    (bridge-routes 6)
    (data-sufficient-training false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-audio-nl2nl-bridge.fk
      learn/tests/speech-audio-nl2nl-bridge-band.fk)
    (verdict 4095)))
