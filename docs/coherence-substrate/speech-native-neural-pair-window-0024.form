# speech-native-neural-pair-window-0024.form -- id<->pt-br neural pair window

(speech-native-neural-pair-window-0024

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "id")
    (b "pt-br")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "id->pt-br, pt-br->id, id->id, pt-br->pt-br"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (indonesian
      (voice "Damayanti")
      (truth "saya")
      (heard "Saya.")
      (wer 0)
      (wav-bytes 18496)
      (cksum 1333292974))
    (portuguese-brazil
      (voice "Flo (Portuguese (Brazil))")
      (truth "eu sou")
      (heard "Eu sou.")
      (wer 0)
      (wav-bytes 31774)
      (cksum 1996659987)))

  (result
    (cumulative-neural-pairs 24)
    (cumulative-directed-routes 48)
    (epochs 24)
    (native-neural-params 24)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0024-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0024.fk
      learn/tests/speech-native-neural-pair-window-0024-band.fk)
    (verdict 32767)))
