# multilocale-nl-audio-pipeline.form -- NL/audio through neutral Form meaning

(multilocale-nl-audio-pipeline

  (lineage
    (sanskrit-baseline learn/sanskrit-locale-baseline.fk
                       "romanized Sanskrit seed phrases with locale renderings")
    (wer observe/stt-wer.fk
         "text/audio outputs are scored by sequence WER")
    (prompt-id observe/asr-prompt-id.fk
               "audio features can route to a closed prompt/meaning id")
    (pipeline learn/multilocale-nl-audio-pipeline.fk
              "text/audio lower to neutral meaning and render back to target locale")
    (route-shift-ledger learn/multilocale-route-shift-ledger.fk
                        "per-pair before/after NL and audio route-shift witness")
    (learning-window learn/speech-locale-learning-window.fk
                     "selected diverse pair becomes a numeric observed learning window")
    (multiseed-sweep learn/multiseed-speech-learning-sweep.fk
                     "several seeded windows are counted under one native route-shift receipt")
    (metal-bridge learn/metal-observed-sweep-bridge.fk
                  "one live Metal audio anchor gates the multiseed sweep without claiming all pairs live")
    (live-anchor-set learn/metal-live-pair-anchors.fk
                     "counts live reciprocal Metal pair anchors toward full-metal-native")
    (selector learn/speech-model-auto-selection.fk
              "model families are chosen by receipt-backed AutoML"))

  (baseline
    (source "romanized Sanskrit phrases as a small local seed")
    (ready-locales "sa en de es fr id pt-br la zh ar")
    (bundle-backfill "full Coherence Network zh/ar bundles remain pending; this baseline has ready rows")
    (not-ready "specific Indigenous rows stay pending until consentful corpora exist"))

  (loops
    (nl-to-nl "text(A) -> neutral Form meaning -> text(B)")
    (audio-to-audio "audio(A) features -> neutral Form meaning -> audio(B) target")
    (reciprocal-pairs "en<->de, en<->es, zh<->ar, fr<->id, sa<->la")
    (metadata "audio target rows preserve confidence, attunement, excitement, cadence")
    (shift-ledger "each pair carries before/after NL rate, audio rate, route, and shifted flag")
    (selected-window "seeded sa<->la window carries before/after rates, route codes, control-clean, and A/B promotion"))
    (multiseed-sweep "seeds 0..4 cover zh<->ar, en<->id, sa<->la, fr<->id, and pt-br<->zh as one readiness receipt"))
    (metal-native-route "live macOS Metal en<->de, en<->es, en<->id, en<->fr, en<->it, en<->zh, and en<->ar audio anchors route full-metal-native for the closed-prompt carrier"))

  (model-layout-now
    (nl "token-overlap-to-neutral-meaning, closed-set, Form-native")
    (asr "nearest-l1-wav-feature-prototype, closed-set, Form-native")
    (tts "source-filter-formant-frames, deterministic Form-native vocoder")
    (audio2audio "prototype ASR -> neutral Form -> formant target")
    (diffusion "candidate only; no Form-native executable diffusion kernel is selected"))

  (runnable
    (sanskrit-baseline
      (concat
        learn/sanskrit-locale-baseline.fk
        learn/tests/sanskrit-locale-baseline-band.fk)
      (verdict 2047))
    (multilocale-pipeline
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/tests/multilocale-nl-audio-pipeline-band.fk)
      (verdict 8191))
    (route-shift-ledger
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/multilocale-route-shift-ledger.fk
        learn/tests/multilocale-route-shift-ledger-band.fk)
      (verdict 4095))
    (speech-locale-learning-window
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/diverse-locale-pairing.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/speech-locale-learning-window.fk
        learn/tests/speech-locale-learning-window-band.fk)
      (verdict 16383))
    (multiseed-speech-learning-sweep
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/diverse-locale-pairing.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/speech-locale-learning-window.fk
        learn/multiseed-speech-learning-sweep.fk
        learn/tests/multiseed-speech-learning-sweep-band.fk)
      (verdict 32767))
    (metal-observed-sweep-bridge
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/diverse-locale-pairing.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/speech-locale-learning-window.fk
        learn/multiseed-speech-learning-sweep.fk
        learn/metal-observed-sweep-bridge.fk
        learn/tests/metal-observed-sweep-bridge-band.fk)
      (verdict 32767))
    (metal-live-pair-anchors
      (concat
        learn/metal-observed-sweep-bridge.fk
        learn/metal-live-pair-anchors.fk
        learn/tests/metal-live-pair-anchors-band.fk)
      (verdict 32767)))

  (honest-boundary
    "This is end-to-end NL-to-NL and audio-to-audio as a closed-set Form
     training loop, not native open ASR and not a neural speech model. The
     local oracle can run on Apple Metal; the selected native learners are
     transparent Form recipes. The selected-pair learning window is numeric
     because the current direct-source lane does not safely retain every
     string-rich ledger inside one larger composition. Native neural ASR/vocoder
     lowering to Metal remains a named candidate, not a claimed result."))
