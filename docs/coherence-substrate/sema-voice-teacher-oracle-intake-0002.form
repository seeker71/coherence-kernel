# sema-voice-teacher-oracle-intake-0002.form -- second local teacher oracle row

(sema-voice-teacher-oracle-intake-0002

  (purpose
    (summary "admit one more real local Metal teacher row for Sema voice training")
    (boundary "host teacher evidence trains the acoustic/vocoder search; it does not promote native Sema TTS authority"))

  (observed
    (render "say -v Samantha -> ffmpeg wav")
    (text "Truth alone triumphs.")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (device "macos-arm64-m4-max")
    (transcript "Truth alone triumphs.")
    (wer 0)
    (wav-bytes 41694)
    (cksum 1857953984))

  (movement
    (teacher-oracle "1/1 -> 2/2")
    (teacher-native-authority "0/1 -> 0/2")
    (live-sema-authority "still oracle 1/1, native 0/1")
    (route "oracle-teacher-positive-native-held"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      learn/sema-voice-sample-loop.fk
      learn/sema-voice-local-oracle-receipt.fk
      learn/speech-live-receipt-intake.fk
      learn/sema-voice-teacher-oracle-intake-0002.fk
      learn/tests/sema-voice-teacher-oracle-intake-0002-band.fk)
    (verdict 32767)))
