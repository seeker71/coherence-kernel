# speech-native-neural-pair-window-0026.form -- fr<->zh neural pair window

(speech-native-neural-pair-window-0026

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "fr")
    (b "zh")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "fr->zh, zh->fr, fr->fr, zh->zh"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (french
      (voice "Flo (French (France))")
      (truth "je suis")
      (heard "Je suis...")
      (wer 0)
      (wav-bytes 32292)
      (cksum 3056443609))
    (chinese
      (voice "Tingting")
      (truth "我在")
      (heard "我在。")
      (wer 0)
      (wav-bytes 15064)
      (cksum 3568659029)))

  (result
    (cumulative-neural-pairs 26)
    (cumulative-directed-routes 52)
    (epochs 26)
    (native-neural-params 26)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0026-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0026.fk
      learn/tests/speech-native-neural-pair-window-0026-band.fk)
    (verdict 32767)))
