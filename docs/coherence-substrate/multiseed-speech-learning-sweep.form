# multiseed-speech-learning-sweep.form -- seeded multi-pair native speech sweep

(multiseed-speech-learning-sweep

  (lineage
    (pair-guide learn/diverse-locale-pairing.fk
                "deterministic seed choice over diverse consent/corpus-ready locales")
    (baseline learn/sanskrit-locale-baseline.fk
              "small locale-neutral Sanskrit baseline rows for sa/la/zh/ar and existing translated locales")
    (pipeline learn/multilocale-nl-audio-pipeline.fk
              "NL/audio samples lower to neutral meaning and render back to target locale")
    (selected-window learn/speech-locale-learning-window.fk
                     "one seeded pair produces a numeric route-shift learning receipt")
    (sweep learn/multiseed-speech-learning-sweep.fk
           "five seeded windows are counted as one observable oracle-to-native movement"))

  (sweep
    (seeds "0 1 2 3 4")
    (pairs "zh<->ar, en<->id, sa<->la, fr<->id, pt-br<->zh")
    (coverage-code 2725)
    (lanes "each selected pair includes A->B, B->A, A->A, and B->B")
    (floor 50)
    (oracle "whisper.cpp-large-v3-turbo")
    (device "macos-arm64-m4-max")
    (route "native when the ready-rate reaches the requested floor")
    (controls "choice/cut/fail/undo/timeout debt must stay clean")
    (promotion "A/B recipe evidence must promote every window")
    (pending "neural Metal and diffusion stay explicitly pending"))

  (runnable
    (form-band
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/diverse-locale-pairing.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/speech-locale-learning-window.fk
        learn/multiseed-speech-learning-sweep.fk
        learn/tests/multiseed-speech-learning-sweep-band.fk)
      (verdict 32767)))

  (honest-boundary
    "This is a multi-window closed-set Form learner and route-shift receipt. It
     proves that several diverse reversible locale windows can move together
     under the same oracle/native gates. It is not open ASR, not open
     translation, and not a native neural speech model."))
