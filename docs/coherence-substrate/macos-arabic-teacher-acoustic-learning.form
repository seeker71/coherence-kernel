# macos-arabic-teacher-acoustic-learning.form -- Arabic teacher wav trains native ASR

(macos-arabic-teacher-acoustic-learning

  (purpose
    (summary "extend live teacher acoustic learning to Arabic, a non-Latin right-to-left locale")
    (boundary "scoped prototype ASR learning, not neural acoustic encoder and not native TTS authority")
    (baseline-meaning 302)
    (teacher-text "الحقيقة وحدها تنتصر"))

  (live-path
    (render "learn/macos-arabic-teacher-acoustic-learning.fk renders Majed voice with local say")
    (normalize "ffmpeg writes 16 kHz mono PCM wav")
    (oracle "whisper.cpp large-v3-turbo on local Metal transcribes the wav with -l ar")
    (sense "observe/wav-sense.fk reads the generated wav and extracts the envelope in Form")
    (learn "Form trains Arabic acoustic token prototypes from wav-envelope segment rows")
    (decode "Form CTC collapse decodes learned Arabic frames back to text"))

  (model
    (kind "supervised Form-native acoustic token prototypes")
    (native-neural-parameters 0)
    (token-features 3)
    (prototype-count 4)
    (live-confidence 96)
    (target "native decoded Arabic transcript equals teacher transcript"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/macos-arabic-teacher-acoustic-learning.fk
      learn/tests/macos-arabic-teacher-acoustic-learning-band.fk)
    (contract-verdict 16383)
    (live-verdict 16383)
    (live-wer 0)
    (live-verdict-function matal-run-verdict)
    (live-wer-function matal-run-wer))

  (observed-boundary
    (arabic "Majed + whisper.cpp/Metal passed WER 0")
    (chinese-at-time "longer Eddy Chinese baseline probes did not yet pass the exact local oracle bar")
    (next "use the Arabic pass and Chinese phrase misses as A/B evidence for the next diverse locale learner")))
