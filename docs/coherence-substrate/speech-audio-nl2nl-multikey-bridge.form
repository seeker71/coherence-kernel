# speech-audio-nl2nl-multikey-bridge.form -- audio to neutral keys to audio

(speech-audio-nl2nl-multikey-bridge

  (purpose
    (summary "expand oracle-guided audio NL2NL beyond one neutral key")
    (boundary "native Form owns neutral routing and target text; host TTS and local Whisper remain carrier/oracle, not native vocoder or ASR authority"))

  (routes
    (neutral-keys "nav.search nav.vision")
    (count 6)
    (pairs "de->es es->de en->fr fr->en id->pt-br pt-br->id")
    (source-oracle "6/6")
    (target-oracle "6/6")
    (native-neutral-routing "6/6")
    (observed-wav-bytes 305184))

  (aggregate-after
    (live-wav-rows 71)
    (observed-wav-bytes 1916782)
    (audio-nl2nl-bridge-routes 12)
    (audio-nl2nl-bridge-wav-bytes 548532)
    (native-vocoder 0)
    (native-neural-parameters 0)
    (data-sufficient-training false)
    (data-floor-wavs 12000)
    (status "tiny-corpus-not-data-sufficient-training"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-audio-nl2nl-multikey-bridge.fk
      learn/tests/speech-audio-nl2nl-multikey-bridge-band.fk)
    (verdict 8191)))
