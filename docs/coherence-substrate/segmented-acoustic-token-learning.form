# segmented-acoustic-token-learning.form -- wav segments teach locale token ASR

(segmented-acoustic-token-learning

  (lineage
    (segmentation learn/segmented-acoustic-token-learning.fk
                  "8-window wav/envelope rows become segmented acoustic feature rows")
    (emitter observe/acoustic-token-emitter.fk
             "oracle-aligned token features become CTC frame-token prototypes")
    (ctc observe/open-asr-ctc.fk
         "learned frame tokens collapse into source transcript text")
    (baseline learn/sanskrit-locale-baseline.fk
              "decoded source tokens route through neutral meaning to target locale tokens")
    (selector learn/speech-model-auto-selection.fk
              "AutoML sees segmented acoustic learning but does not live-select it yet"))

  (what-it-proves
    (segment "a wav/envelope feature stream can be segmented in Form")
    (learn "consentful oracle-valid token segments intern acoustic token prototypes")
    (decode "trained prototypes decode source speech tokens through CTC")
    (neutral-form "decoded source tokens map to locale-neutral meaning rows")
    (target "the neutral meaning renders target-locale tokens with voice-side metadata")
    (reciprocal "sa->la and la->sa directions must both be present before native route")
    (controls "bad oracle, timeout, and missing consent block learning/native credit"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/speech-token-stream.fk
      observe/open-asr-ctc.fk
      observe/acoustic-token-emitter.fk
      learn/sanskrit-locale-baseline.fk
      learn/segmented-acoustic-token-learning.fk
      learn/tests/segmented-acoustic-token-learning-band.fk)
    (verdict 32767))

  (optional-lowering
    (wav-path "include observe/wav-sense.fk when calling satl-wav-feature-stream over a real wav path")
    (open-dictation "include learn/open-dictation-transcript-learning.fk when calling satl-open-row; promotion windows remain covered by the narrower open-dictation and CTC bands"))

  (honest-boundary
    "This is native supervised segmentation and token-prototype learning over
     consentful local-oracle samples. It is not a neural acoustic encoder and
     not yet a live mic stream. It makes the next carrier contract precise:
     provide local wav/audio facts; Form owns segmentation, token learning,
     neutral meaning, target tokens, and receipts."))
