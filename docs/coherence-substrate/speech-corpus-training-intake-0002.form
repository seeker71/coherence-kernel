# speech-corpus-training-intake-0002.form -- second captured batch enters training

(speech-corpus-training-intake-0002

  (purpose
    (summary "admit the second clean captured self-corpus batch into native prototype training")
    (boundary "training floor expands; data sufficiency and global ASR/TTS authority remain false"))

  (source
    (previous-intake learn/speech-corpus-training-intake-0001.fk)
    (capture-batch learn/speech-corpus-capture-batch-0002.fk)
    (captured-rows 24)
    (local-oracle-accepted 24)
    (max-wer 0)
    (observed-wav-bytes 580710)
    (locales "en, de, es, fr, id, pt-br"))

  (training-intake
    (batch-rows-admitted 24)
    (batch-rate "24/24 = 100%")
    (cumulative-rows-admitted 30)
    (cumulative-rate "30/30 = 100%")
    (cumulative-observed-source-bytes 793234)
    (route "native-prototype-training-intake")
    (data-sufficient false)
    (minimum-wav-floor 12000)
    (global-authority false)
    (status "captured-corpus-training-intake-expanded-not-data-sufficient"))

  (runnable
    (concat
      learn/speech-corpus-training-intake-0001.fk
      learn/speech-corpus-training-intake-0002.fk
      learn/tests/speech-corpus-training-intake-0002-band.fk)
    (verdict 32767)))
