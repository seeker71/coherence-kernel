# speech-loopback-recipe-ab.form -- recipe A/B over witnessed speech loopback

(speech-loopback-recipe-ab

  (lineage
    (carrier-receipts presence/speech-loopback-carrier-receipt.fk
                      "local audio loopback rows with WER, latency, and controls")
    (promotion learn/speech-loopback-promotion.fk
               "native/oracle authority over clean receipt windows")
    (recipe-ab learn/speech-loopback-recipe-ab.fk
               "incumbent/challenger recipe choice with fail/timeout/undo override")
    (carrier-run presence/speech-loopback-carrier-run.fk
                 "carrier readiness turns missing render/capture/oracle facts into fail control"))

  (decision-law
    (arm "recipe-id + measured receipt window + promotion summary + latency score")
    (eligible-challenger "challenger route must already be native")
    (score-win "challenger native score beats incumbent")
    (latency-tie-break "equal native score can cut to lower measured latency")
    (control-override "fail, timeout, or undo keeps incumbent before any cut")
    (cloud-debt "nonlocal/cloud rows become debt and block challenger cutover"))

  (runnable
    (cell learn/speech-loopback-recipe-ab.fk)
    (band learn/tests/speech-loopback-recipe-ab-band.fk)
    (concat
      observe/stt-wer.fk
      learn/speech-loopback-promotion.fk
      presence/speech-loopback-carrier-receipt.fk
      learn/speech-loopback-recipe-ab.fk
      learn/tests/speech-loopback-recipe-ab-band.fk)
    (verdict 2047)
    (carrier-gated
      (concat
        form/form-stdlib/hati-os-targets.fk
        form/form-stdlib/host-os-membrane.fk
        observe/stt-wer.fk
        learn/speech-loopback-promotion.fk
        presence/speech-loopback-carrier-receipt.fk
        learn/speech-loopback-recipe-ab.fk
        presence/speech-loopback-carrier-run.fk
        learn/tests/speech-loopback-carrier-run-ab-band.fk)
      (verdict 2047)))

  (honest-boundary
    "This chooses between grouped recipe receipt windows and now has a carrier-gated
     run row. It does not yet run the OS audio carrier or mutate a live recipe registry;
     it returns the measured cut/keep decision the host or form-cli shell can apply."))
