# speech-corpus-acquisition-window.form -- audio rows from the self-corpus

(speech-corpus-acquisition-window

  (purpose
    (summary "turn the translated Coherence Network self-corpus into enough planned audio rows to meet the speech data floor")
    (boundary "this is an acquisition window; only live receipts count captured wavs, and captured wavs are still not trained authority"))

  (source
    (self-corpus learn/coherence-network-self-corpus.fk)
    (ready-locales 6)
    (ready-keypaths 2064)
    (en-parallel-pairs 10320)
    (consent "owned translated Coherence Network body"))

  (window
    (selected-keypaths 2000)
    (locales "en de es fr id pt-br")
    (voices-per-locale 1)
    (planned-wavs 12000)
    (planned-held-out-rows 1200)
    (macos-voices "Flo en/de/es/fr/pt-br, Damayanti id"))

  (floor-check
    (required-wavs 12000)
    (required-locales 6)
    (required-held-out-rows 1200)
    (meets-wav-floor true)
    (meets-locale-floor true)
    (meets-held-out-floor true)
    (captured "batches 0001 through 0003 have 64 admitted rows; full 12000-row acquisition window not captured")
    (status "corpus-scale-window-open-not-trained"))

  (runnable
    (concat
      learn/coherence-network-self-corpus.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-corpus-acquisition-window.fk
      learn/tests/speech-corpus-acquisition-window-band.fk)
    (verdict 32767)))
