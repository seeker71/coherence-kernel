# speech-current-status-ledger.form -- global authority and scoped trial status

(speech-current-status-ledger

  (model-size
    (native-neural-weight-parameters-admitted 30)
    (selected-arms 4)
    (major-form-components-plus-trial-windows 39)
    (native-sema-voice-organs 6)
    (scoped-native-trial-windows 9)
    (c-seed-growth 0))

  (composition
    (asr "prototype-asr + native-segmented-acoustic-learning")
    (tts "sema-voice-sample-loop + text-conditioned-acoustic-vocoder")
    (nl2nl "closed-set-locale-form")
    (audio2audio "native-source-window-audio2audio-acoustic + speech-audio-nl2nl-source-window-0002")
    (baseline "sanskrit-locale-baseline")
    (learning "local-oracle-guided A/B trials"))

  (global-live-authority
    (open-dictation "oracle 4/4, native 0/4, oracle-guide")
    (sema-live-voice "oracle 1/1, native 0/1, native WER 100, oracle-guide")
    (aggregate "oracle 5/5 = 100%, native 0/5 = 0%"))

  (scoped-trial-windows
    (open-asr "oracle 14/14, native 14/14, native rate 100")
    (sema-voice "oracle 2/2, native 2/2, WER 0")
    (aggregate "oracle 16/16 = 100%, native 16/16 = 100%")
    (scope "trial-window native, not global live authority"))

  (voice-quality
    (target "F0 165, warmth 82, cadence 64, breath 18")
    (tcav-window "F0 165, warmth 82, cadence 64, breath 18"))

  (runnable
    (concat
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/sema-voice-trial-window.fk
      learn/sema-voice-trial-window-0002.fk
      learn/speech-current-status-ledger.fk
      learn/tests/speech-current-status-ledger-band.fk)
    (verdict 32767)))
