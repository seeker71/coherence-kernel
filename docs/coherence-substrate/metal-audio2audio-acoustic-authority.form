# metal-audio2audio-acoustic-authority.form -- Metal summaries select native audio2audio acoustic authority

(metal-audio2audio-acoustic-authority

  (lineage
    (acoustic-sweep learn/multilocale-audio2audio-acoustic-sweep.fk
                    "decoded-token audio2audio rows pass five reciprocal locale pairs")
    (live-metal-anchors learn/metal-live-pair-anchors.fk
                        "seven live reciprocal local audio pairs route full-metal-native")
    (authority learn/metal-audio2audio-acoustic-authority.fk
               "stable scalar summaries from those witnesses select a metal-witnessed acoustic guide"))

  (runnable
    (authority-band
      (concat
        learn/metal-audio2audio-acoustic-authority.fk
        learn/tests/metal-audio2audio-acoustic-authority-band.fk)
      (verdict 32767))
    (acoustic-source-band
      (concat
        observe/stt-wer.fk
        presence/formant-vocoder.fk
        observe/speech-token-stream.fk
        learn/sanskrit-locale-baseline.fk
        learn/text-conditioned-acoustic-vocoder.fk
        learn/native-audio2audio-acoustic-bridge.fk
        learn/multilocale-audio2audio-acoustic-sweep.fk
        learn/tests/multilocale-audio2audio-acoustic-sweep-band.fk)
      (verdict 32767))
    (live-metal-source-band
      (concat
        learn/metal-observed-sweep-bridge.fk
        learn/metal-live-pair-anchors.fk
        learn/tests/metal-live-pair-anchors-band.fk)
      (verdict 32767)))

  (authority
    (route "metal-witnessed-audio2audio-acoustic")
    (selector-verdict 67108863)
    (selected-audio2audio "native-audio2audio-acoustic-vocoder")
    (source-authority "decoded-token-source")
    (live-open-mic "pending")
    (neural-metal "pending"))

  (honest-boundary
    "The authority row is scalar on purpose: the direct-source lane cannot
     safely hold the full acoustic sweep receipt and live anchor receipt at
     once. The upstream bands prove those summaries separately. This selects
     the native acoustic audio2audio arm for the decoded-token, closed-prompt,
     metal-witnessed scope; it does not claim open microphone ASR or natural
     neural speech generation."))
