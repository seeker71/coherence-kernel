# speech-native-neural-pair-window-0025.form -- fr<->id neural pair window

(speech-native-neural-pair-window-0025

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "fr")
    (b "id")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "fr->id, id->fr, fr->fr, id->id"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (french
      (voice "Flo (French (France))")
      (truth "je suis")
      (heard "Je suis...")
      (wer 0)
      (wav-bytes 32292)
      (cksum 3056443609))
    (indonesian
      (voice "Damayanti")
      (truth "saya")
      (heard "Saya.")
      (wer 0)
      (wav-bytes 18496)
      (cksum 1333292974)))

  (result
    (cumulative-neural-pairs 25)
    (cumulative-directed-routes 50)
    (epochs 25)
    (native-neural-params 25)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0025-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0025.fk
      learn/tests/speech-native-neural-pair-window-0025-band.fk)
    (verdict 32767)))
