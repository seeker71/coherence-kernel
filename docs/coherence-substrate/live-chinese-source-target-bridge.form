# live-chinese-source-target-bridge.form -- live Chinese source audio to target acoustic frames

(live-chinese-source-target-bridge

  (purpose
    (summary "connect live Chinese source ASR to locale-neutral meaning and target acoustic data")
    (boundary "compact deterministic acoustic frame emitter, not full TCAV and not neural vocoder authority")
    (source "zh")
    (target "en")
    (meaning 303))

  (live-path
    (source-audio "learn/macos-chinese-teacher-acoustic-learning.fk renders and transcribes 我在 on local Metal")
    (source-check "native decoded Chinese text has WER 0 against local oracle")
    (neutral "learn/sanskrit-locale-baseline.fk maps meaning 303 to target tokens")
    (target "Form emits compact target acoustic frames for en tokens")
    (route "native-source-target-acoustic inside this witnessed scoped bridge"))

  (model
    (kind "live source ASR + locale-neutral target acoustic micro-kernel")
    (native-neural-parameters 0)
    (training-kind "one-pass supervised prototype insertion upstream, compact deterministic target-frame emission here")
    (effective-epochs 1)
    (held-out-samples 0)
    (source-locale "zh")
    (target-locale "en")
    (target-token-count 2)
    (target-frame-count 2)
    (live-confidence 96))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/sanskrit-locale-baseline.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/macos-chinese-teacher-acoustic-learning.fk
      learn/live-chinese-source-target-bridge.fk
      learn/tests/live-chinese-source-target-bridge-band.fk)
    (contract-verdict 8191)
    (live-verdict 8191)
    (live-target-frames 2)
    (live-verdict-function lzst-run-verdict))

  (next
    (expand-target "replace compact frames with the full TCAV lane once direct-source composition can carry both stacks")
    (reciprocal "add en->zh live source-target bridge")
    (authority "global audio2audio remains oracle-guided until multi-row live receipts promote")))
