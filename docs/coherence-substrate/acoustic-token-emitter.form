# acoustic-token-emitter.form -- supervised acoustic features to CTC frame tokens

(acoustic-token-emitter

  (lineage
    (wav-sense observe/wav-sense.fk
               "Form reads 16-bit PCM wav bytes and computes acoustic envelope features")
    (emitter observe/acoustic-token-emitter.fk
             "oracle-aligned feature prototypes emit CTC frame tokens by integer L1 distance and earned confidence")
    (segmented-learning learn/segmented-acoustic-token-learning.fk
                        "wav/envelope segments learn token prototypes before CTC decode")
    (token-stream observe/speech-token-stream.fk
                  "decoded frames carry identity, route, control, evidence, memory/scope, and voice-side metadata")
    (ctc observe/open-asr-ctc.fk
         "frame tokens collapse to free transcript text")
    (open-dictation learn/open-dictation-transcript-learning.fk
                    "native transcript rows are scored and promoted by WER/confidence/control receipts"))

  (what-it-proves
    (native-feature-emission "feature vectors can become nonblank or blank CTC frames in Form")
    (supervised-learning "a consentful oracle-aligned token feature can be admitted as a prototype cell")
    (confidence-gate "distance and prototype confidence cut weak rows to blank before transcript promotion")
    (receipt-lowering "the emitted transcript lowers into the open-dictation native success gate")
    (voice-side-meta "confidence, warmth, cadence, hesitation, excitement, and attunement survive through the stream"))

  (runnable
    (concat
      observe/wav-sense.fk
      observe/stt-wer.fk
      learn/speech-loopback-promotion.fk
      form/form-stdlib/observed-auto-learning.fk
      learn/open-dictation-transcript-learning.fk
      observe/speech-token-stream.fk
      observe/open-asr-ctc.fk
      observe/acoustic-token-emitter.fk
      observe/tests/acoustic-token-emitter-band.fk)
    (verdict 32767))

  (honest-boundary
    "This is a native supervised prototype acoustic token emitter, now paired
     with a segmented learning bridge. It is not a finished neural acoustic
     encoder: live mic streaming and stronger acoustic features still have to
     win receipts before open ASR can be live-selected over the current
     closed-prompt prototype route."))
