# sema-voice-vocoder-oracle-bridge.form -- TCAV rows enter the Sema STT bar

(sema-voice-vocoder-oracle-bridge

  (lineage
    (vocoder learn/text-conditioned-acoustic-vocoder.fk
             "native text/neutral Form to acoustic voice frames; bridge consumes its sample row shape")
    (oracle-bar learn/sema-voice-local-oracle-receipt.fk
                "local STT bar for generated Sema voice samples")
    (candidate-search learn/sema-voice-candidate-search.fk
                      "downstream search can consume the resulting local-oracle rows in a split lane"))

  (what-it-adds
    (bridge "TCAV sample row shape -> Sema local-oracle row -> Sema voice receipt")
    (evidence "oracle text, target text, locale, audio hash, consent, fail/timeout/undo, oracle, device")
    (source "text-conditioned-acoustic-vocoder")
    (authority "same local oracle bar decides native or oracle-guide"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      observe/speech-token-stream.fk
      learn/sema-voice-sample-loop.fk
      learn/sema-voice-local-oracle-receipt.fk
      learn/sema-voice-vocoder-oracle-bridge.fk
      learn/tests/sema-voice-vocoder-oracle-bridge-band.fk)
    (verdict 32767))

  (honest-boundary
    "This still does not claim the current live Sema voice passes STT. It proves
     the row handoff contract from the native vocoder sample shape into the
     local oracle bar. The full TCAV + candidate-search composition waits on
     the direct-source ceiling or a split receipt lane."))
