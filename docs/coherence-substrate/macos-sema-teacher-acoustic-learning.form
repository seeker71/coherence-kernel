# macos-sema-teacher-acoustic-learning.form -- real teacher wav trains native ASR

(macos-sema-teacher-acoustic-learning

  (purpose
    (summary "consume the WER-0 macOS teacher wav as native acoustic learning input")
    (boundary "prototype ASR learning, not neural acoustic encoder and not native TTS authority")
    (teacher-text "Open speech flows."))

  (live-path
    (render "learn/macos-sema-teacher-acoustic-learning.fk renders Flo voice with local say")
    (normalize "ffmpeg writes 16 kHz mono PCM wav")
    (oracle "whisper.cpp large-v3-turbo on local Metal transcribes the wav")
    (sense "observe/wav-sense.fk reads the generated wav and extracts the envelope in Form")
    (learn "Form trains acoustic token prototypes from wav-envelope segment rows")
    (decode "Form CTC collapse decodes learned frames back to text"))

  (model
    (kind "supervised Form-native acoustic token prototypes")
    (native-neural-parameters 0)
    (token-features 3)
    (prototype-count 4)
    (live-confidence 96)
    (target "native decoded transcript equals teacher transcript"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/tests/macos-sema-teacher-acoustic-learning-band.fk)
    (contract-verdict 4095)
    (live-verdict 4095)
    (live-wer 0)
    (live-verdict-function mstal-run-verdict)
    (live-wer-function mstal-run-wer))

  (meaning
    (before "teacher carrier produced WER 0, but native model had not consumed the wav")
    (after "Form reads the teacher wav and trains native acoustic token prototypes from it")
    (next "repeat across multiple teacher voices/locales and feed the native acoustic/vocoder candidate search")))
