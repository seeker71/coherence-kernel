# speech-native-neural-pair-window-0040.form -- zh<->it neural pair window

(speech-native-neural-pair-window-0040

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "zh")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "zh->it, it->zh, zh->zh, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (chinese
      (voice "Tingting")
      (truth "我在")
      (heard "我在")
      (wer 0)
      (wav-bytes 15064)
      (cksum 3568659029))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 40)
    (cumulative-directed-routes 80)
    (epochs 40)
    (native-neural-params 40)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0040-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0040.fk
      learn/tests/speech-native-neural-pair-window-0040-band.fk)
    (verdict 32767)))
