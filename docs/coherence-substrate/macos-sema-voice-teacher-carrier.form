# macos-sema-voice-teacher-carrier.form -- local intelligible Sema teacher samples

(macos-sema-voice-teacher-carrier

  (purpose
    (summary "run local macOS TTS voices through local Whisper/Metal to create intelligible teacher rows")
    (boundary "host teacher evidence is not native Sema voice authority")
    (target "Open speech flows."))

  (manual-sweep
    (voices "Samantha, Flo, Grandma, Eddy, Daniel, Karen, Moira, Tessa, Zoe, Serena")
    (result "10/10 local wavs transcribed exactly as Open speech flows.")
    (best-repeatable "Flo (English (US))"))

  (carrier
    (file presence/macos-sema-voice-teacher-carrier.fk)
    (render "say -> aiff")
    (normalize "ffmpeg -> 16000 Hz mono wav")
    (oracle "whisper.cpp-large-v3-turbo on Apple Metal")
    (row "Sema local-oracle row with host-teacher-not-native-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      presence/formant-vocoder.fk
      learn/sema-voice-sample-loop.fk
      learn/sema-voice-local-oracle-receipt.fk
      presence/macos-sema-voice-teacher-carrier.fk
      presence/tests/macos-sema-voice-teacher-carrier-band.fk)
    (contract-verdict 4095)
    (live-verdict-function mstc-run-verdict)
    (live-wer-function mstc-run-wer))

  (meaning
    (current-native-formant "still WER 100")
    (host-teacher "local intelligible samples now repeatably produce WER 0")
    (next "feed host teacher wavs into native acoustic/vocoder learning instead of accepting host TTS as final")))
