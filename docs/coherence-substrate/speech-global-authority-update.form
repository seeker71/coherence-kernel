# speech-global-authority-update.form -- route update from real live receipts

(speech-global-authority-update

  (source
    (intake learn/speech-live-receipt-intake.fk)
    (promotion-readiness learn/speech-global-promotion-readiness.fk)
    (current-status learn/speech-current-status-ledger.fk))

  (current-empty-receipts
    (live-open-dictation "0/3 -> oracle-guide")
    (sema-live-voice "0/3 -> oracle-guide")
    (missing 6))

  (demo-clean-receipts
    (live-open-dictation "3/3 -> native-open-asr-source")
    (sema-live-voice "3/3 -> native-sema-voice")
    (missing 0))

  (thresholds
    (wer-max 25)
    (confidence-min 80)
    (latency-max-ms 2000)
    (controls "choice, cut, fail, undo, timeout clean"))

  (scope
    "This is the route update law. Current receipt input is still empty; demo rows prove the native cutover path.")

  (runnable
    (concat
      learn/speech-model-metrics-report.fk
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/sema-voice-trial-window.fk
      learn/speech-current-status-ledger.fk
      learn/speech-global-promotion-readiness.fk
      learn/speech-live-receipt-intake.fk
      learn/speech-global-authority-update.fk
      learn/tests/speech-global-authority-update-band.fk)
    (verdict 32767)))
