# speech-corpus-training-intake-0001.form -- captured rows enter training

(speech-corpus-training-intake-0001

  (purpose
    (summary "admit the first clean captured self-corpus rows into native prototype training")
    (boundary "training starts; data sufficiency and global ASR/TTS authority remain false"))

  (source
    (capture-batch learn/speech-corpus-capture-batch-0001.fk)
    (captured-rows 6)
    (local-oracle-accepted 6)
    (max-wer 0)
    (observed-wav-bytes 212524)
    (locales "en, de, es, fr, id, pt-br"))

  (training-intake
    (rows-admitted 6)
    (rate "6/6 = 100%")
    (route "native-prototype-training-intake")
    (data-sufficient false)
    (minimum-wav-floor 12000)
    (global-authority false)
    (status "captured-corpus-training-started-not-data-sufficient")
    (next-intake "speech-corpus-training-intake-0002 expands the current aggregate to 30 rows"))

  (runnable
    (concat
      learn/speech-corpus-training-intake-0001.fk
      learn/tests/speech-corpus-training-intake-0001-band.fk)
    (verdict 32767)))
