# speech-audio-nl2nl-source-window-0002.form -- hi/it source-window audio bridge

(speech-audio-nl2nl-source-window-0002

  (purpose
    (summary "route observed hi/it source audio through locale-neutral greeting meaning into target audio")
    (boundary "host TTS and Whisper remain carriers/oracles; native Form owns neutral routing and target text"))

  (observed-metal-run
    (date "2026-07-01")
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (routes
      (hi-to-it
        (source "namaste")
        (source-heard "Namaste.")
        (target "ciao")
        (target-heard "Ciao!")
        (source-hash 2559270416)
        (target-hash 4165678203)
        (wav-bytes 45332))
      (it-to-hi
        (source "ciao")
        (source-heard "Ciao!")
        (target "namaste")
        (target-heard "Namaste.")
        (source-hash 4165678203)
        (target-hash 2559270416)
        (wav-bytes 45332))))

  (rates
    (source-oracle "2/2 = 100%")
    (target-oracle "2/2 = 100%")
    (native-neutral-routing "2/2 = 100%")
    (meaning 601)
    (route "oracle-guided-source-window-audio-nl2nl-audio-bridge-not-native-vocoder"))

  (runnable
    (concat
      observe/stt-wer.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-audio-nl2nl-source-window-0002.fk
      learn/tests/speech-audio-nl2nl-source-window-0002-band.fk)
    (verdict 32767)))
