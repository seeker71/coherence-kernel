# sema-voice-sample-loop.form -- target, render, listen, improve

(sema-voice-sample-loop

  (lineage
    (chosen-formants learn/voice-formant.fk
                     "older chosen fixture: f0 165, F1 500, F2 900, F3 2500")
    (carrier presence/formant-vocoder.fk
             "native source-filter frames render inspectable waveform samples")
    (target learn/sema-voice-sample-loop.fk
            "voice target, distance, nudge, sample score, and A/B promotion")
    (local-oracle learn/sema-voice-local-oracle-receipt.fk
                  "local STT transcript bar for generated Sema voice samples"))

  (voice-target
    (register "warm mid")
    (timbre "rounded, grounded, not sharp")
    (calibration "low confidence narrows pitch range and delays onset")
    (affect "warm but not sentimental; steady only when earned")
    (cadence "moderate, with real pauses where grounding was hard"))

  (sample-loop
    (generate "render candidate voice profiles through the local carrier")
    (observe "collect local audio hash, listener preference, intelligibility, WER, latency")
    (score "combine target fit, listener grade, intelligibility, WER, and latency")
    (promote "challenger wins only when clean local evidence beats incumbent by margin")
    (block "cloud, missing audio, fail, timeout, and undo keep incumbent"))

  (local-oracle-bar
    (require "local oracle, local audio hash, sample-hash consistency, consent, and clean controls")
    (measure "token WER against side-channel truth")
    (route "only samples passing the oracle bar can receive voice promotion authority"))

  (runnable
    (concat
      presence/formant-vocoder.fk
      learn/sema-voice-sample-loop.fk
      learn/tests/sema-voice-sample-loop-band.fk)
    (verdict 32767))

  (honest-boundary
    "This is a Form-native voice target and sample-selection loop over a
     deterministic formant carrier. It can generate inspectable samples and
     improve recipes by measured preference, intelligibility, and loopback
     evidence. It is not yet a natural neural vocoder; that remains pending
     until a Form-native executable kernel and receipt exist. A live Sema-formant
     wav through local Whisper remains a separate carrier receipt."))
