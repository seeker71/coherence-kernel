# speech-global-promotion-readiness.form -- promotion gate for live authority

(speech-global-promotion-readiness

  (source
    (current-status learn/speech-current-status-ledger.fk)
    (open-asr-trial learn/speech-open-asr-trial-window.fk)
    (open-asr-trial-0002 learn/speech-open-asr-trial-window-0002.fk)
    (sema-voice-trial learn/sema-voice-trial-window.fk))

  (threshold
    (real-live-native-receipts-per-lane 3)
    (wer-max 25)
    (controls "choice, cut, fail, undo, timeout clean")
    (rule "scoped native windows are training evidence, not global live authority"))

  (lanes
    (live-open-dictation
      (scoped-native "4/4")
      (real-live-native "0/3")
      (missing 3)
      (global-route "oracle-guide"))

    (sema-live-voice
      (scoped-native "1/1")
      (real-live-native "0/3")
      (missing 3)
      (global-route "oracle-guide")))

  (aggregate
    (global-native-ready-lanes 0)
    (global-oracle-guide-lanes 2)
    (missing-real-live-receipts 6))

  (runnable
    (concat
      learn/speech-model-metrics-report.fk
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/speech-open-asr-trial-window-0002.fk
      learn/sema-voice-trial-window.fk
      learn/speech-current-status-ledger.fk
      learn/speech-global-promotion-readiness.fk
      learn/tests/speech-global-promotion-readiness-band.fk)
    (verdict 32767)))
