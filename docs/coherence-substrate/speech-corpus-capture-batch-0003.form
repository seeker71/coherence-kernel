# speech-corpus-capture-batch-0003.form -- screened phrase audio corpus

(speech-corpus-capture-batch-0003

  (purpose
    (summary "admit local-oracle-clean phrase rows from the translated Coherence Network self-corpus")
    (boundary "screened captured corpus audio, not data-sufficient training and not native ASR/TTS authority"))

  (screening
    (candidate-rows 60)
    (admitted-rows 34)
    (rejected-rows 26)
    (reason "local Whisper/Metal WER floor rejected unstable short phrase and locale/voice combinations"))

  (capture
    (locales "en de es fr id pt-br")
    (voices "Flo en/de/es/pt-br, Amelie fr, Damayanti id")
    (accepted-rows "34/34")
    (max-wer 25)
    (observed-wav-bytes 1272388)
    (native-form true)
    (native-neural-parameters 0)
    (rows-used-for-training 0)
    (status "screened-phrase-corpus-audio-not-training-sufficient"))

  (aggregate-after
    (live-wav-rows 105)
    (observed-wav-bytes 3189170)
    (captured-corpus-audio-rows 64)
    (data-sufficient-training false)
    (data-floor-wavs 12000)
    (status "tiny-corpus-not-data-sufficient-training"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/wav-sense.fk
      learn/macos-sema-teacher-acoustic-learning.fk
      learn/coherence-network-self-corpus.fk
      learn/speech-model-metrics-report.fk
      learn/speech-learning-data-sufficiency.fk
      learn/speech-corpus-acquisition-window.fk
      learn/speech-corpus-capture-batch-0003.fk
      learn/tests/speech-corpus-capture-batch-0003-band.fk)
    (verdict 8191)))
