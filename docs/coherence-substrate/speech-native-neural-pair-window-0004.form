# speech-native-neural-pair-window-0004.form -- fourth trained neural pair

(speech-native-neural-pair-window-0004

  (purpose
    (summary "train the fourth native neural micro-pair window")
    (boundary "this grows trained neural pair coverage, but is not full open ASR/TTS authority"))

  (pair
    (a en)
    (b zh)
    (meaning 303)
    (baseline "aham-asmi")
    (pair-increment 1)
    (directed-increment 2)
    (cumulative-trained-pairs 4)
    (cumulative-directed-routes 8)
    (epochs 4)
    (native-neural-parameters 4))

  (result
    (neural-rate "0 -> 100")
    (form-nl-rate 100)
    (form-audio-rate 100)
    (bootstrap-loss "1 -> 0")
    (route-shifted true)
    (oracle true)
    (native-form true)
    (open-authority false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0004.fk
      learn/tests/speech-native-neural-pair-window-0004-band.fk)
    (verdict 32767)))
