# speech-native-neural-pair-window-0001.form -- first trained neural pair

(speech-native-neural-pair-window-0001

  (purpose
    (summary "make trained neural pair coverage non-zero with an executable Form-native micro-kernel")
    (boundary "this is a trained micro-pair window, not open ASR/TTS authority"))

  (pair
    (a en)
    (b fr)
    (trained-unordered-pairs 1)
    (trained-directed-routes 2)
    (epochs 1)
    (native-neural-parameters 1))

  (result
    (neural-rate "0 -> 100")
    (form-nl-rate 100)
    (form-audio-rate 100)
    (bootstrap-loss "1 -> 0")
    (route-shifted true)
    (oracle true)
    (native-form true)
    (open-authority false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-form-pair-window-0008.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0001.fk
      learn/tests/speech-native-neural-pair-window-0001-band.fk)
    (verdict 32767)))
