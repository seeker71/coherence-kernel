# speech-pair-training-next-action.form -- next pair-training move

(speech-pair-training-next-action

  (purpose
    (summary "choose the next movement after observing zero neural pair training")
    (boundary "the action may expand Form-native evidence, but does not claim neural training"))

  (current
    (neural-pair-windows 0)
    (form-native-pair-windows 6)
    (captured-live-wavs 211)
    (required-live-wavs 12000)
    (native-form true)
    (neural-ready false))

  (chosen-action
    (id "next-form-pair-window-0007")
    (pair "en<->es")
    (route "expand-form-native-pair-window-before-neural")
    (reason "neural-pairs-zero-and-corpus-under-floor")
    (form-window-count "6 -> 7")
    (neural-window-count "0 -> 0")
    (capture-floor "211/12000"))

  (next-after-action
    (capture "render and oracle-check more consentful pair audio")
    (learn "run the Form-native A->B, B->A, A->A, B->B window")
    (hold "do not promote neural until a native neural kernel, epochs, and corpus floor exist"))

  (runnable
    (concat
      learn/speech-neural-pair-coverage.fk
      learn/speech-pair-training-next-action.fk
      learn/tests/speech-pair-training-next-action-band.fk)
    (verdict 32767)))
