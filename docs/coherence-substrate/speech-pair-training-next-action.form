    (boundary "the action may expand Form-native evidence, but does not claim neural training"))

  (current
    (neural-pair-windows 3)
    (form-native-pair-windows 8)
    (captured-live-wavs 211)
    (required-live-wavs 12000)
    (native-form true)
    (neural-ready false))

  (chosen-action
    (id "next-native-neural-pair-window-0004")
    (pair "en<->zh")
    (route "train-native-neural-pair-window")
    (reason "neural-micro-pair-training-enabled")
    (form-window-count "8 -> 8")
    (neural-window-count "3 -> 4")
