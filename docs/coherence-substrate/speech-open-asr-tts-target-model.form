# speech-open-asr-tts-target-model.form -- full open ASR/TTS target

(speech-open-asr-tts-target-model

  (purpose
    (summary "make full open ASR/TTS parity-or-better the native training target")
    (boundary "current authority is measured separately; the target is not capped at micro-pair performance"))

  (target
    (open-asr true)
    (open-tts true)
    (beat-local-oracle true)
    (target-rate 100))

  (current
    (open-asr-native-rate 0)
    (open-asr-oracle-rate 100)
    (sema-voice-native-rate 0)
    (sema-voice-oracle-rate 100)
    (sema-voice-native-eval "0/1")
    (sema-voice-oracle-eval "1/1")
    (sema-voice-training-native "2/3 = 66%")
    (sema-voice-training-oracle "3/3 = 100%")
    (sema-voice-training-status "nonzero floor; live authority held")
    (authority-ready false))

  (enabled-path
    (trained-neural-pairs 29)
    (native-neural-parameters 29)
    (open-asr-gap 100)
    (sema-voice-gap 100)
    (route-enabled true))

  (runnable
    (concat
      learn/speech-open-asr-tts-target-model.fk
      learn/tests/speech-open-asr-tts-target-model-band.fk)
    (verdict 32767)))
