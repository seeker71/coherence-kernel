# speech-native-neural-pair-window-0022.form -- es<->pt-br neural pair window

(speech-native-neural-pair-window-0022

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "es")
    (b "pt-br")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "es->pt-br, pt-br->es, es->es, pt-br->pt-br"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (spanish
      (voice "Flo (Spanish (Spain))")
      (truth "yo soy")
      (heard "Yo soy.")
      (wer 0)
      (wav-bytes 26646))
    (portuguese-brazil
      (voice "Flo (Portuguese (Brazil))")
      (truth "eu sou")
      (heard "Eu sou.")
      (wer 0)
      (wav-bytes 31774)))

  (result
    (cumulative-neural-pairs 22)
    (cumulative-directed-routes 44)
    (epochs 22)
    (native-neural-params 22)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0022-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0022.fk
      learn/tests/speech-native-neural-pair-window-0022-band.fk)
    (verdict 32767)))
