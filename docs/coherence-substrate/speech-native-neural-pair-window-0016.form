# speech-native-neural-pair-window-0016.form -- sixteenth trained neural pair

(speech-native-neural-pair-window-0016

  (purpose
    (summary "train the sixteenth native neural micro-pair window")
    (boundary "this grows trained neural pair coverage, but is not full open ASR/TTS authority"))

  (pair
    (a de)
    (b es)
    (meaning 301)
    (baseline "sarve-bhavantu-sukhinah")
    (pair-increment 1)
    (directed-increment 2)
    (cumulative-trained-pairs 16)
    (cumulative-directed-routes 32)
    (epochs 16)
    (native-neural-parameters 16))

  (result
    (neural-rate "0 -> 100")
    (form-nl-rate 100)
    (form-audio-rate 100)
    (bootstrap-loss "1 -> 0")
    (route-shifted true)
    (oracle true)
    (native-form true)
    (open-authority false))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0016.fk
      learn/tests/speech-native-neural-pair-window-0016-band.fk)
    (verdict 32767)))
