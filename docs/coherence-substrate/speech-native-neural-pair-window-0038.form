# speech-native-neural-pair-window-0038.form -- id<->it neural pair window

(speech-native-neural-pair-window-0038

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "id")
    (b "it")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "id->it, it->id, id->id, it->it"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (indonesian
      (voice "Damayanti")
      (truth "aku ada")
      (heard "Aku ada.")
      (wer 0)
      (wav-bytes 23712)
      (cksum 1805192547))
    (italian
      (voice "Alice")
      (truth "io sono")
      (heard "Io sono")
      (wer 0)
      (wav-bytes 16706)
      (cksum 3343634846)))

  (result
    (cumulative-neural-pairs 38)
    (cumulative-directed-routes 76)
    (epochs 38)
    (native-neural-params 38)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0038-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0038.fk
      learn/tests/speech-native-neural-pair-window-0038-band.fk)
    (verdict 32767)))
