# metal-observed-sweep-bridge.form -- live Metal anchor for multi-locale sweep

(metal-observed-sweep-bridge

  (lineage
    (multiseed-sweep learn/multiseed-speech-learning-sweep.fk
                     "five reversible closed-set locale windows route native in Form")
    (macos-carrier presence/macos-speech-roundtrip-carrier.fk
                   "local say/ffmpeg/whisper.cpp carrier observes real audio on Apple Metal")
    (route-shift learn/audio-locale-route-shift-ledger.fk
                 "live before/after audio route movement")
    (bridge learn/metal-observed-sweep-bridge.fk
            "connects live Metal audio anchors to the multi-locale sweep without overclaiming")
    (live-anchor-set learn/metal-live-pair-anchors.fk
                     "current live anchor count now stands at three reciprocal pairs"))

  (live-anchor
    (pair "en-de")
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo")
    (samples 12)
    (oracle-ok 10)
    (before-native-rate 0)
    (after-native-rate 83)
    (a-to-b-rate 66)
    (b-to-a-rate 100)
    (shifted 1))

  (authority
    (now "metal-anchored-native-guide")
    (observed-live-pairs 3)
    (target-live-pairs 5)
    (next-live-needed 2)
    (not-yet "full-metal-native")
    (reason "three reciprocal pairs have live audio observed on Metal; two remain"))

  (runnable
    (form-band
      (concat
        observe/stt-wer.fk
        observe/asr-prompt-id.fk
        learn/diverse-locale-pairing.fk
        learn/sanskrit-locale-baseline.fk
        learn/multilocale-nl-audio-pipeline.fk
        learn/speech-locale-learning-window.fk
        learn/multiseed-speech-learning-sweep.fk
        learn/metal-observed-sweep-bridge.fk
        learn/tests/metal-observed-sweep-bridge-band.fk)
      (verdict 32767)))

  (honest-boundary
    "The live Metal anchor proves the selected model family has a real local
     audio route shift, while the multi-locale sweep proves broader closed-set
     Form learning. It does not claim every locale pair has live captured audio
     yet; two more live pair anchors are still needed before the bridge can
     route full-metal-native."))
