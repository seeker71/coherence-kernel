# speech-native-neural-pair-window-0034.form -- fr<->sa neural pair window

(speech-native-neural-pair-window-0034

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "fr")
    (b "sa")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "fr->sa, sa->fr, fr->fr, sa->sa"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (french
      (voice "Thomas")
      (truth "je suis")
      (heard "Je suis")
      (wer 0)
      (wav-bytes 17908)
      (cksum 3224208913))
    (sanskrit-baseline-romanized
      (voice "Rishi (English (India))")
      (truth "aham asmi")
      (heard "Aham Asmi.")
      (wer 0)
      (wav-bytes 27510)
      (cksum 2808389783)
      (boundary "romanized baseline carrier; not a native Sanskrit OS voice")))

  (result
    (cumulative-neural-pairs 34)
    (cumulative-directed-routes 68)
    (epochs 34)
    (native-neural-params 34)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0034-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0034.fk
      learn/tests/speech-native-neural-pair-window-0034-band.fk)
    (verdict 32767)))
