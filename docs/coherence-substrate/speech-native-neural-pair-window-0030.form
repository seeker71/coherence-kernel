# speech-native-neural-pair-window-0030.form -- zh<->id neural pair window

(speech-native-neural-pair-window-0030

  (baseline learn/sanskrit-locale-baseline.fk)
  (pipeline learn/multilocale-nl-audio-pipeline.fk)
  (bootstrap learn/speech-native-neural-bootstrap.fk)

  (pair
    (a "zh")
    (b "id")
    (meaning 303)
    (baseline "aham-asmi")
    (directions "zh->id, id->zh, zh->zh, id->id"))

  (observed-local-oracle
    (device "macos-arm64-m4-max")
    (oracle "whisper.cpp-large-v3-turbo-metal")
    (chinese
      (voice "Tingting")
      (truth "我在")
      (heard "我在。")
      (wer 0)
      (wav-bytes 15064)
      (cksum 3568659029))
    (indonesian
      (voice "Damayanti")
      (truth "aku ada")
      (heard "Aku ada.")
      (wer 0)
      (wav-bytes 23712)
      (cksum 1805192547)))

  (result
    (cumulative-neural-pairs 30)
    (cumulative-directed-routes 60)
    (epochs 30)
    (native-neural-params 30)
    (oracle "2/2")
    (form-nl "100%")
    (form-audio "100%")
    (route-shift "0 -> 100"))

  (boundary
    (native-form true)
    (neural-ready true)
    (open-authority false)
    (status "native-neural-micro-pair-0030-trained-not-open-authority"))

  (runnable
    (concat
      observe/stt-wer.fk
      observe/asr-prompt-id.fk
      learn/sanskrit-locale-baseline.fk
      learn/multilocale-nl-audio-pipeline.fk
      learn/speech-native-neural-bootstrap.fk
      learn/speech-native-neural-pair-window-0030.fk
      learn/tests/speech-native-neural-pair-window-0030-band.fk)
    (verdict 32767)))
