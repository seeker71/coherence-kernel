# speech-corpus-adaptive-acquisition.form -- observed misses change the next capture recipe

(speech-corpus-adaptive-acquisition

  (purpose
    (summary "turn batch 0004 shard results into the next corpus acquisition choices")
    (boundary "scheduler/control surface only; it does not promote native ASR, TTS, or neural weights"))

  (observed-batch-0004
    (candidate-wavs 50)
    (admitted 35)
    (observed-wav-bytes 2150026)
    (lanes "en 10/10, de 5/10, es 7/10, fr 4/10, pt-br 9/10"))

  (decisions
    (expand "en pt-br")
    (retry-ab "es")
    (repair "de fr")
    (next "fr")
    (next-recipe "repair-voice-family-and-shorten-phrases")
    (controls "choice-cut-fail-undo-timeout-clean"))

  (model-state
    (native-form true)
    (native-neural-parameters 0)
    (data-sufficient-training false)
    (meaning "observed-batch-0004-changes-next-capture-recipe"))

  (runnable
    (concat
      learn/speech-corpus-adaptive-acquisition.fk
      learn/tests/speech-corpus-adaptive-acquisition-band.fk)
    (verdict 32767)))
