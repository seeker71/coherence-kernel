# speech-live-receipt-intake.form -- real live receipt intake for promotion

(speech-live-receipt-intake

  (source
    (promotion-readiness learn/speech-global-promotion-readiness.fk)
    (current-status learn/speech-current-status-ledger.fk))

  (receipt-row
    (fields "lane, id, device, oracle, audio hash, sample rate, channels, truth, oracle WER, native WER, confidence, latency, local, consent, fail, timeout, undo")
    (validity "local, consented, audio-present, clean controls")
    (success "oracle WER <= 25, native WER <= 25, confidence >= 80, latency <= 2000"))

  (current
    (live-open-dictation "0 real live native receipts")
    (sema-live-voice "0 real live native receipts"))

  (promotion-demo
    (required 3)
    (open-asr "three clean rows satisfy live-open-dictation")
    (sema-voice "three clean rows satisfy sema-live-voice")
    (dirty "missing audio or fail control earns no credit"))

  (scope
    "This is the intake law and demo window, not a claim that the six missing real live receipts exist.")

  (runnable
    (concat
      learn/speech-model-metrics-report.fk
      learn/speech-oracle-native-backlog.fk
      learn/speech-next-trial-scheduler.fk
      learn/speech-open-asr-trial-window.fk
      learn/speech-open-asr-trial-window-0002.fk
      learn/speech-open-asr-trial-window-0003.fk
      learn/sema-voice-trial-window.fk
      learn/sema-voice-trial-window-0002.fk
      learn/speech-current-status-ledger.fk
      learn/speech-global-promotion-readiness.fk
      learn/speech-live-receipt-intake.fk
      learn/tests/speech-live-receipt-intake-band.fk)
    (verdict 32767)))
