{
  "schema": "formbin2-malformed-conformance-v1",
  "cases": [
    {
      "name": "bad-magic",
      "builder": "hex",
      "value": "464f524d42494e58",
      "expected_error": "form binary: bad magic"
    },
    {
      "name": "truncated-string-count",
      "builder": "hex",
      "value": "464f524d42494e32",
      "expected_error": "form binary: truncated u32"
    },
    {
      "name": "string-count-limit",
      "builder": "hex",
      "value": "464f524d42494e3200040001",
      "expected_error": "form binary: maximum string count exceeded"
    },
    {
      "name": "string-bytes-limit",
      "builder": "hex",
      "value": "464f524d42494e320000000102000001",
      "expected_error": "form binary: maximum string bytes exceeded"
    },
    {
      "name": "truncated-string",
      "builder": "hex",
      "value": "464f524d42494e3200000001000000046162",
      "expected_error": "form binary: truncated string"
    },
    {
      "name": "invalid-utf8",
      "builder": "hex",
      "value": "464f524d42494e320000000100000001ff",
      "expected_error": "form binary: invalid utf8"
    },
    {
      "name": "unknown-node-tag",
      "builder": "hex",
      "value": "464f524d42494e320000000000000063",
      "expected_error": "form binary: unknown node tag 99"
    },
    {
      "name": "truncated-leaf",
      "builder": "hex",
      "value": "464f524d42494e32000000000000000000000001",
      "expected_error": "form binary: truncated u32"
    },
    {
      "name": "child-count-limit",
      "builder": "hex",
      "value": "464f524d42494e320000000000000001000000000000000100000002000000220000000100040001",
      "expected_error": "form binary: maximum child count exceeded"
    },
    {
      "name": "node-depth-limit",
      "builder": "nested-composite",
      "depth": 257,
      "expected_error": "form binary: maximum node depth exceeded"
    },
    {
      "name": "trailing-bytes",
      "builder": "hex",
      "value": "464f524d42494e3200000000000000000000000100000001000000010000002a00",
      "expected_error": "form binary: trailing bytes"
    },
    {
      "name": "artifact-size-limit",
      "builder": "oversized-artifact",
      "expected_error": "form binary: maximum artifact size exceeded"
    }
  ]
}
