{
  "schema": "form-kernel-conformance-v1",
  "description": "Canonical Form S-expressions executed by the real Go, Rust, and TypeScript kernel CLIs.",
  "cases": [
    {
      "name": "binary-add",
      "form": "(add 20 22)",
      "expected": "42"
    },
    {
      "name": "binary-math-tree",
      "form": "(sub (mul 9 5) (div 9 3))",
      "expected": "42"
    },
    {
      "name": "modulo",
      "form": "(mod 1071 462)",
      "expected": "147"
    },
    {
      "name": "truth-is-one",
      "form": "(and (lt 1 2) (gt 3 2))",
      "expected": "1"
    },
    {
      "name": "false-is-zero",
      "form": "(or (gt 1 2) (eq 4 5))",
      "expected": "0"
    },
    {
      "name": "conditional",
      "form": "(if (eq 7 7) 42 0)",
      "expected": "42"
    },
    {
      "name": "recursive-factorial",
      "form": "(do (defn factorial (n) (if (le n 1) 1 (mul n (factorial (sub n 1))))) (factorial 6))",
      "expected": "720"
    },
    {
      "name": "recursive-accumulator",
      "form": "(do (defn sum-down (n acc) (if (le n 0) acc (sum-down (sub n 1) (add acc n)))) (sum-down 10 0))",
      "expected": "55"
    },
    {
      "name": "recursive-gcd-uses-mod",
      "form": "(do (defn gcd (a b) (if (eq b 0) a (gcd b (mod a b)))) (gcd 1071 462))",
      "expected": "21"
    },
    {
      "name": "canonical-nodeid-render",
      "form": "(make_nodeid 1 2 12 1)",
      "expected": "@1.2.12.1"
    },
    {
      "name": "canonical-list-render",
      "form": "(list 1 2 3)",
      "expected": "[1, 2, 3]"
    },
    {
      "name": "canonical-string-render",
      "form": "(str_concat \"coherence\" \"-kernel\")",
      "expected": "coherence-kernel"
    }
  ]
}
