; lingbot-map-live-pipeline.fk — production-shaped live entrypoint over the two
; upstream LingBot-Map frames committed as deterministic BMP fixtures.
;
; This is intentionally outside tests: running it calls every new organ and
; returns inspectable image, released-weight, ViT, GCA, geometry, cloud, and
; native-world-model data. Learned end-to-end checkpoint parity remains named 0.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/geometric-camera.fk model/lingbot-pytorch-checkpoint.fk model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk model/lingbot-geometry-heads.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk model/lingbot-map-runtime.fk

(do
  (defn lmpl-slot-sum (rows slot acc)
    (if (eq (len rows) 0) acc
      (lmpl-slot-sum (tail rows) slot (add acc (nth (head rows) slot)))))
  (defn lmpl-slot-min-go (rows slot best)
    (if (eq (len rows) 0) best
      (lmpl-slot-min-go (tail rows) slot (min2 best (nth (head rows) slot)))))
  (defn lmpl-slot-max-go (rows slot best)
    (if (eq (len rows) 0) best
      (lmpl-slot-max-go (tail rows) slot (max2 best (nth (head rows) slot)))))
  (defn lmpl-slot-min (rows slot)
    (lmpl-slot-min-go (tail rows) slot (nth (head rows) slot)))
  (defn lmpl-slot-max (rows slot)
    (lmpl-slot-max-go (tail rows) slot (nth (head rows) slot)))
  (defn lmpl-q6 (x)
    (if (lt x 0.0)
      (sub 0 (float_to_int (add 0.5 (mul -1000000.0 x))))
      (float_to_int (add 0.5 (mul 1000000.0 x)))))
  (defn lmpl-q6-list (xs)
    (if (eq (len xs) 0) (empty)
      (cons (lmpl-q6 (head xs)) (lmpl-q6-list (tail xs)))))

  (defn lingbot-map-live-pipeline ()
    (do
      (let run
        (lmr-run-video-file
          "model/fixtures/lingbot-map/loop-two-frame.mkv"
          "/tmp/lingbot-live-pipeline-%06d.bmp"
          "/tmp/lingbot-live-pipeline-000001.bmp"
          "/tmp/lingbot-live-pipeline-000002.bmp"))
      (let geometry (lmr-geometry run))
      (let pose (nth geometry 0))
      (let depths (nth geometry 1))
      (let cloud (lmr-cloud run))
      (let comparison (lmr-comparison run))
      (let bounds (lgh-cloud-bounds cloud))
      (list
        "lingbot-map-live-pipeline"
        (list "source-commit" "7ff6f3ed0913d4d326f8f13bbb429c4ffc0195c2")
        (list "images" (lmr-images run))
        (list "released-weight" (lmr-weight run))
        (list "vit" (lmr-vision run))
        (list "gca"
          "weighted-first-x1e6" (lmpl-q6-list (nth (lmr-attention run) 0))
          "unweighted-first-x1e6" (lmpl-q6-list (nth (lmr-attention run) 1))
          "weight-ablation-l1-x1e6" (lmpl-q6 (nth (lmr-attention run) 2))
          "retained-kv-rows" (nth (lmr-attention run) 3)
          "mask" (nth (lmr-attention run) 4))
        (list "pose"
          "rotation-x1e6" (lmpl-q6-list (gc-r pose))
          "translation-x1e6" (lmpl-q6-list (gc-t pose)))
        (list "relative-depth"
          "count" (len depths)
          "min-x1e6" (lmpl-q6 (lmpl-slot-min depths 0))
          "mean-x1e6" (lmpl-q6 (div (lmpl-slot-sum depths 0 0.0) (mul (len depths) 1.0)))
          "max-x1e6" (lmpl-q6 (lmpl-slot-max depths 0)))
        (list "point-cloud"
          "count" (len cloud)
          "bounds-x1e6" (list (lmpl-q6-list (nth bounds 0)) (lmpl-q6-list (nth bounds 1))))
        (list "world-model"
          "count" (len (lmr-world run))
          "first" (head (lmr-world run))
          "last" (nth (lmr-world run) (sub (len (lmr-world run)) 1)))
        (list "real-frame-output-comparison"
          "same-index-cost" (nth comparison 0)
          "matched-cost" (nth comparison 1)
          "non-worsened" (nth comparison 4)
          "samples" (nth comparison 5))
        (list "learned-checkpoint-end-to-end-parity" 0
          "released camera tensor loaded; full learned graph parity not claimed"))))

  (lingbot-map-live-pipeline))
