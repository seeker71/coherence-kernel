; whisper-tiny-native-acoustic-live.fk — learned human audio gates world admission.
;
; The non-test door accepts a neutral-path, hash-verified human WAV.  The full
; native Whisper-tiny conv1+erf-form-GELU+conv2+erf-form-GELU stem output must carry learned activity before the
; unprompted host Whisper transcript may enter the complete 10k Form detector.
; Only the detector-returned id is persisted.  A zero learned-output ablation is
; rejected, proving the released native acoustic stem is causally operational.
; witnessed: 2026-07-18 -> M92036254 "book", detected id 571, world admitted
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/whisper-tiny-native-conv1.fk model/whisper-tiny-native-conv2.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk cognition/concept-text-detection-13-runtime.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/concept-audio-asr-13.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk

(do
  (defn wtal-source-sha256 ()
    "1166acadc40e8d60baa82c6321ba3445fda5305a46539c3d1a0cc43e425de523")
  (defn wtal-source-valid? (path)
    (if (str_eq (host-exec (str_concat "shasum -a 256 "
          (str_concat (ca13-shell-quote path) (str_concat " | grep -q '^"
            (str_concat (wtal-source-sha256) "  ' && printf 1")))) "") "1") 1 0))
  (defn wtal-neutral-path? (path)
    (if (or (ge (str_find path "book" 0) 0)
            (ge (str_find path "571" 0) 0)) 0 1))
  (defn wtal-candidate-ids (candidates)
    (if (eq (len candidates) 0) (empty)
      (cons (ctd13-candidate-id (head candidates))
            (wtal-candidate-ids (tail candidates)))))
  (defn wtal-world-admit (candidate acoustic)
    (if (or (eq (len candidate) 0) (eq (nth acoustic 8) 0))
      (list "admitted" 0 "reason" "missing-content-candidate-or-learned-activity")
      (do
        (let detected-id (ctd13-candidate-id candidate))
        (let surface (ctd13-candidate-surface candidate))
        (let known (list (cwm-cell detected-id surface)))
        (let entity (cwm-persist detected-id 0 "native-whisper-released-stem+host-decoder"
                      180718 known))
        (list "admitted" 1 "detected-id" detected-id "surface" surface
          "entity" entity "world" (cwm-world (list entity))
          "world-count" (cwm-concept-count (list entity))))))

  (defn wtal-run-file (path)
    (do
      (let source-valid (wtal-source-valid? path))
      (let neutral (wtal-neutral-path? path))
      (let acoustic (if (and (eq source-valid 1) (eq neutral 1))
                      (wt2-infer-file path) (list path 0 0 0.0 (empty) (empty) 0 0 0 0 (empty))))
      (let transcript (if (and (eq (nth acoustic 8) 1)
                            (eq (casr13-model-valid?) 1))
                         (casr13-transcribe-file path "en") ""))
      (let detected (ctd13-runtime-detect-sentence (ctd13-runtime-open) "en" transcript))
      (let candidate (if (eq (len detected) 0) (empty) (head detected)))
      (let world (wtal-world-admit candidate acoustic))
      ; Same content candidate, learned activity ablated to zero.
      (let zero-acoustic (list path 0 0 0.0 (empty) (empty) 0 1 0))
      (let ablation (wtal-world-admit candidate zero-acoustic))
      (list "whisper-tiny-native-acoustic-live"
        (list "source" path "sha256" (wtal-source-sha256)
          "verified" source-valid "neutral-path" neutral
          "human-recorded" 1 "tts" 0 "media-id" "M92036254")
        (list "native-learned" "openai/whisper-tiny/encoder.conv1+erf-form-gelu+encoder.conv2+erf-form-gelu"
          "revision" "169d4a4341b33bc18d8881c4b69c2e104e1cc0af"
          "parameters" (nth acoustic 6) "weights-valid" (nth acoustic 7)
          "output-width" (len (nth acoustic 4))
          "fingerprint" (nth acoustic 5) "learned-activity" (nth acoustic 8))
        (list "asr" (casr13-oracle-name) "model-valid" (casr13-model-valid?)
          "prompt" "" "transcript" transcript)
        (list "detection" "complete-form-10000-scan"
          "candidate-count" (len detected) "candidate-ids" (wtal-candidate-ids detected)
          "candidate" candidate)
        (list "world" world)
        (list "zero-learned-ablation" ablation)
        (list "strict-native-acoustic-recognizer" 0
          "remaining" "positional-embedding+4-encoder-blocks+decoder+tokenizer+search"))))

  (defn wtal-execute-file (path)
    (do
      (let run (wtal-run-file path))
      (let learned (nth run 2))
      (let detection (nth run 4))
      (let candidate (nth detection 7))
      (let world (nth (nth run 5) 1))
      (let ablation (nth (nth run 6) 1))
      (print_str (ca13-cat (list
        "native-acoustic-live human=1 tts=0 released-parameters="
        (int_to_str (nth learned 5))
        " output-width=" (int_to_str (nth learned 9))
        " learned-activity=" (int_to_str (nth learned 13))
        " candidate-count=" (int_to_str (nth detection 3))
        " detected-id=" (if (eq (len candidate) 0) "-"
                           (int_to_str (ctd13-candidate-id candidate)))
        " detected-surface=" (if (eq (len candidate) 0) "-"
                                (ctd13-candidate-surface candidate))
        " world-admitted=" (int_to_str (nth world 1))
        " zero-ablation-admitted=" (int_to_str (nth ablation 1))
        " native-recognizer=0")))
      run))
)
