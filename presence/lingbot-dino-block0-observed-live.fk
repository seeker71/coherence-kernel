; lingbot-dino-block0-observed-live.fk -- first complete released DINO block.
;
; Two consecutive public-video center patches become full 1024-wide released
; patch tokens, then execute all fourteen learned tensors of DINOv2-L/14 block
; zero.  Framebuffer stages surround decode, patch input, carrier validation,
; 16-head attention, MLP, and the semantic refusal boundary.
;
; This corrects the concrete numerical defect where the learned path stopped
; before every DINO block. It does not conceal the remaining structural gap:
; special/register/position tokens, the full patch sequence, blocks 1..23, and
; a semantic head are still absent. Therefore semantic output is empty and a
; fixture-derived label is actively rejected.
; witnessed: 2026-07-20 -> bounded real two-token block-0 run
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/lingbot-vision-input.fk model/lingbot-learned-patch.fk model/released-row-major-affine.fk model/lingbot-dino-block0.fk observe/framebuffer-runtime-observation.fk

(do
  (defn ldb0ol-video () "model/fixtures/lingbot-map/real-life/loop-24f.mkv")
  (defn ldb0ol-pattern () "/tmp/lingbot-dino-block0-%06d.bmp")
  (defn ldb0ol-path0 () "/tmp/lingbot-dino-block0-000001.bmp")
  (defn ldb0ol-path1 () "/tmp/lingbot-dino-block0-000002.bmp")
  (defn ldb0ol-source-bytes () 1581923)
  (defn ldb0ol-images ()
    (lvi-load-video-file (ldb0ol-video) (ldb0ol-pattern)
      (list (ldb0ol-path0) (ldb0ol-path1))))
  (defn ldb0ol-stage (stage parent before after metric value outcome)
    (fbro-stage-observed "lingbot-dino-block0-real-video" stage parent "Sema"
      "corrects-learned-visual-numerics" "remove-missing-dino-block0"
      "reject-false-semantic-output" before after metric value outcome
      "presence/lingbot-dino-block0-observed-live.fk" 1 1))
  (defn ldb0ol-frames-valid? (images)
    (if (eq (len images) 2)
      (if (and (eq (lvi-width (lvi-image-bytes (nth images 0))) 518)
            (and (eq (lvi-height (lvi-image-bytes (nth images 0))) 294)
              (and (eq (lvi-width (lvi-image-bytes (nth images 1))) 518)
                   (eq (lvi-height (lvi-image-bytes (nth images 1))) 294)))) 1 0)
      0))
  (defn ldb0ol-cat (parts)
    (if (eq (len parts) 0) ""
      (str_concat (head parts) (ldb0ol-cat (tail parts)))))
  (defn ldb0ol-resource-number (resources label i)
    (if (ge i (len resources)) 0
      (if (and (str_eq (nth resources i) label)
               (lt (add i 1) (len resources)))
        (nth resources (add i 1))
        (ldb0ol-resource-number resources label (add i 1)))))
  ; A route/fixture candidate is not perception. Until a learned semantic head
  ; is independently valid, the production result is empty and the candidate
  ; is marked rejected rather than logged as if it were recognized.
  ; Returns (semantic-output admitted false-candidate-rejected candidate).
  (defn ldb0ol-semantic-gate (candidate semantic-head-valid)
    (if (and (eq semantic-head-valid 1) (gt (str_len candidate) 0))
      (list candidate 1 0 candidate)
      (list "" 0 (if (gt (str_len candidate) 0) 1 0) candidate)))

  (defn lingbot-dino-block0-observed-live-run ()
    (do
      (let window (fbro-open "lingbot-dino-block0-real-video" "Sema"
        "corrects-learned-visual-numerics" "remove-missing-dino-block0"
        "reject-false-semantic-output" (ldb0ol-source-bytes)
        "presence/lingbot-dino-block0-observed-live.fk" 1 1))

      (let decode-before (fbro-snapshot))
      (let images (ldb0ol-images))
      (let frames-valid (ldb0ol-frames-valid? images))
      (let decode-after (fbro-snapshot))
      (let decode-event (ldb0ol-stage "frames-decoded" "trace-begin"
        decode-before decode-after "frames" (len images)
        (if (eq frames-valid 1) "two-valid-public-frames" "rejected")))

      (let patch-before (fbro-snapshot))
      (let patch-pack (llp-load-weights))
      (let token0 (if (eq frames-valid 1)
        (llp-center-token (nth images 0) patch-pack) (empty)))
      (let token1 (if (eq frames-valid 1)
        (llp-center-token (nth images 1) patch-pack) (empty)))
      (let input (list token0 token1))
      (let patch-valid (if (and (eq (llp-weights-valid? patch-pack) 1)
            (and (eq (len token0) 1024) (eq (len token1) 1024))) 1 0))
      (let patch-after (fbro-snapshot))
      (let patch-event (ldb0ol-stage "released-patch-input" "frames-decoded"
        patch-before patch-after "released-parameters" 603136
        (if (eq patch-valid 1) "two-1024-wide-pixel-tokens" "held")))

      (let carrier-before (fbro-snapshot))
      (let block-pack (ldb0-load))
      (let block-valid (ldb0-valid? block-pack))
      (let carrier-after (fbro-snapshot))
      (let carrier-event (ldb0ol-stage "block0-carrier-validated"
        "released-patch-input" carrier-before carrier-after
        "released-parameters" (ldb0-parameter-count)
        (if (eq block-valid 1) "fourteen-tensors-crc-valid" "rejected")))

      (let attention-before (fbro-snapshot))
      (let attention (if (and (eq patch-valid 1) (eq block-valid 1))
        (ldb0-attention block-pack input) (list input (empty) (empty))))
      (let attended (nth attention 0))
      (let attention-after (fbro-snapshot))
      (let attention-event (ldb0ol-stage "released-block0-attention"
        "block0-carrier-validated" attention-before attention-after
        "heads" (ldb0-heads) (if (and (eq (len attended) 2)
          (eq (len (head attended)) 1024)) "complete" "held")))

      (let mlp-before (fbro-snapshot))
      (let output (if (and (eq (len attended) 2)
            (eq (len (head attended)) 1024))
        (ldb0-mlp block-pack attended) (empty)))
      (let mlp-after (fbro-snapshot))
      (let output-valid (if (and (eq (len output) 2)
            (eq (len (head output)) 1024)) 1 0))
      (let mlp-event (ldb0ol-stage "released-block0-mlp"
        "released-block0-attention" mlp-before mlp-after
        "released-block-parameters" (ldb0-parameter-count)
        (if (eq output-valid 1) "complete-block0" "held")))

      (let truth-before (fbro-snapshot))
      (let input-to-output (if (eq output-valid 1)
        (list (ldb0-l1 token0 (nth output 0) 0.0)
              (ldb0-l1 token1 (nth output 1) 0.0)) (list 0.0 0.0)))
      (let output-separation (if (eq output-valid 1)
        (ldb0-l1 (nth output 0) (nth output 1) 0.0) 0.0))
      ; `loop` is an upstream route name, not visual perception. The gate
      ; actively rejects that concrete false semantic candidate.
      (let semantic-gate (ldb0ol-semantic-gate "loop" 0))
      (let semantic-output (nth semantic-gate 0))
      (let semantic-admitted (nth semantic-gate 1))
      (let false-candidate-rejected (nth semantic-gate 2))
      (let truth-after (fbro-snapshot))
      (let truth-event (ldb0ol-stage "semantic-output-gate"
        "released-block0-mlp" truth-before truth-after
        "semantic-admitted" semantic-admitted
        "false-fixture-label-rejected"))

      (let report (fbro-close window
        (if (and (eq block-valid 1) (eq output-valid 1))
          "complete-released-block0-semantic-output-held" "held")
        2 "presence/lingbot-dino-block0-observed-live.fk" 1 1))
      (list "lingbot-dino-block0-observed-live"
        (list "source" (ldb0ol-video) "bytes" (ldb0ol-source-bytes)
          "frames-valid" frames-valid "dimensions" (list 518 294 518 294))
        (list "released-patch-input" "valid" patch-valid
          "parameters" 603136 "fingerprints" (ldb0-fingerprints input))
        (list "released-dino-block0" "valid" block-valid
          "parameters" (ldb0-parameter-count) "carrier-bytes" (ldb0-carrier-bytes)
          "attention" (list (nth attention 1) (nth attention 2)))
        (list "block0-output" "valid" output-valid
          "attention-fingerprints" (ldb0-fingerprints attended)
          "output-fingerprints" (ldb0-fingerprints output)
          "input-to-output-l1" input-to-output
          "output-token-separation-l1" output-separation)
        (list "correction-truth"
          "missing-block0-before" 1 "complete-block0-now" output-valid
          "special-register-position-tokens" 0 "full-patch-sequence" 0
          "blocks1-23" 0 "semantic-head" 0
          "semantic-output" semantic-output "semantic-admitted" semantic-admitted
          "false-fixture-label-rejected" false-candidate-rejected)
        report)))

  (defn ldb0ol-stage-duration (report event-index)
    (nth (nth (nth (fbro-events report) event-index) 3) 10))
  (defn lingbot-dino-block0-observed-live-execute ()
    (do
      (let run (lingbot-dino-block0-observed-live-run))
      (let block (nth run 3))
      (let output (nth run 4))
      (let truth (nth run 5))
      (let report (nth run 6))
      (let resources (fbro-resources report))
      (print_str (ldb0ol-cat (list
        "framebuffer-runtime-observation trace=lingbot-dino-block0-real-video"
        " duration-ms=" (int_to_str (nth (fbro-when report) 5))
        " decode-ms=" (int_to_str (ldb0ol-stage-duration report 1))
        " patch-ms=" (int_to_str (ldb0ol-stage-duration report 2))
        " carrier-ms=" (int_to_str (ldb0ol-stage-duration report 3))
        " attention-ms=" (int_to_str (ldb0ol-stage-duration report 4))
        " mlp-ms=" (int_to_str (ldb0ol-stage-duration report 5))
        " released-block-parameters=" (int_to_str (nth block 4))
        " carrier-bytes=" (int_to_str (nth block 6))
        " output-tokens=" (int_to_str (if (eq (nth output 2) 1) 2 0))
        " dispatches=" (int_to_str
          (ldb0ol-resource-number resources "dispatches" 0))
        " semantic-output-empty=" (int_to_str
          (if (str_eq (nth truth 14) "") 1 0))
        " semantic-admitted=" (int_to_str (nth truth 16))
        " false-fixture-label-rejected=" (int_to_str (nth truth 18))
        " outcome=" (nth (fbro-outcome report) 1))))
      run))
)
