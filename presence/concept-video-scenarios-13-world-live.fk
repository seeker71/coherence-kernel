; concept-video-scenarios-13-world-live.fk -- observed scenario concepts persist.
;
; Only content targets present in each original photograph's complete 10k scan
; enter wm-model. Human scenario claims that abstained never manufacture an
; entity. Positions are explicit collection observation slots, not inferred 3-D
; object centers.
;
; witnessed: 2026-07-18 -> 16 content-derived entities, 10 negative claims absent, 255
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk presence/concept-video-scenarios-13-live.fk

(do
  (defn cvsc13w-live-rows (live) (nth (nth live 6) 1))
  (defn cvsc13w-target-present? (row) (nth (nth (nth row 6) 1) 0))
  (defn cvsc13w-targets (rows)
    (if (eq (len rows) 0) (empty)
      (if (eq (cvsc13w-target-present? (head rows)) 1)
        (cons (head rows) (cvsc13w-targets (tail rows)))
        (cvsc13w-targets (tail rows)))))
  (defn cvsc13w-known (rows)
    (if (eq (len rows) 0) (empty)
      (cons (cwm-cell (nth (nth (head rows) 2) 1) (nth (nth (head rows) 2) 2))
            (cvsc13w-known (tail rows)))))
  (defn cvsc13w-persist (rows known index)
    (if (eq (len rows) 0) (empty)
      (cons (cwm-persist (nth (nth (head rows) 2) 1) (list index 0 0)
              "scenario-real-photo" (add 5000 index) known)
            (cvsc13w-persist (tail rows) known (add index 1)))))
  (defn cvsc13w-label-member? (entities label)
    (if (eq (len entities) 0) 0
      (if (str_eq (wm-ent-id (head entities)) label) 1
        (cvsc13w-label-member? (tail entities) label))))
  (defn cvsc13w-hard-negatives-absent (rows entities)
    (if (eq (len rows) 0) 0
      (do (let row (head rows))
          (let claim (nth row 3))
          (add (if (and (eq (nth claim 3) 0)
                     (eq (cvsc13w-label-member? entities (nth claim 2)) 0)) 1 0)
               (cvsc13w-hard-negatives-absent (tail rows) entities)))))
  (defn cvsc13w-labels (entities)
    (if (eq (len entities) 0) (empty)
      (cons (wm-ent-id (head entities)) (cvsc13w-labels (tail entities)))))

  (defn concept-video-scenarios-13-world-live-run ()
    (do (let live (concept-video-scenarios-13-live-run))
        (let rows (cvsc13w-live-rows live))
        (let targets (cvsc13w-targets rows))
        (let known (cvsc13w-known targets))
        (let entities (cvsc13w-persist targets known 1))
        (let negative-absent (cvsc13w-hard-negatives-absent rows entities))
        (let score
          (add (if (eq (nth (nth live 1) 1) 1) 1 0)
            (add (if (eq (len rows) 16) 2 0)
              (add (if (eq (len targets) 16) 4 0)
                (add (if (eq (len known) 16) 8 0)
                  (add (if (eq (len entities) 16) 16 0)
                    (add (if (eq (cwm-concept-count entities) 16) 32 0)
                      (add (if (eq negative-absent 10) 64 0)
                           (if (eq (len (cvsc13w-labels entities)) 16) 128 0))))))))
        (list "concept-video-scenarios-13-world-live"
          (list "source-observations" (len rows) "content-targets" (len targets)
            "hard-negative-claims-absent" negative-absent)
          (list "world-model" (cwm-concept-count entities)
            "positions-are-observation-slots" 1
            "entities" (cvsc13w-labels entities) (cwm-world entities))
          (list "score" score 255))))

  (concept-video-scenarios-13-world-live-run))
