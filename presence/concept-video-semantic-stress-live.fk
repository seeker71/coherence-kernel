; concept-video-semantic-stress-live.fk -- contiguous and cross-video stress probe.
;
; This is an executable development witness, not a claimed parity score. It
; asks whether the raw-pixel descriptor can survive harder temporal splits than
; the interleaved acceptance band and whether the independently captured Oxford
; walk lands near the university/campus concept without any visible address.
;
; preludes: form/form-stdlib/core.fk model/lingbot-vision-input.fk model/concept-video-semantic.fk presence/concept-video-semantic-live.fk

(do
  (defn cvss-exemplars-at (scene indices)
    (if (eq (len indices) 0) (empty)
      (cons (cvsl-exemplar scene (head indices))
            (cvss-exemplars-at scene (tail indices)))))
  (defn cvss-bank (indices)
    (cvs-append (cvss-exemplars-at "loop" indices)
      (cvs-append (cvss-exemplars-at "university" indices)
                  (cvss-exemplars-at "courthouse" indices))))
  (defn cvss-count-one (scene indices prototypes correct rows)
    (if (eq (len indices) 0) (list correct (reverse rows))
      (do (let index (head indices))
          (let result (cvs-detect-file (cvsl-frame scene index) prototypes))
          (cvss-count-one scene (tail indices) prototypes
            (if (eq (nth result 0) (cvsl-concept-id scene)) (add correct 1) correct)
            (cons (list scene index (nth result 0) (nth result 2)) rows)))))
  (defn cvss-count-all (scenes indices prototypes correct rows)
    (if (eq (len scenes) 0) (list correct (reverse rows))
      (do (let one (cvss-count-one (head scenes) indices prototypes 0 (empty)))
          (cvss-count-all (tail scenes) indices prototypes
            (add correct (nth one 0)) (cons (list (head scenes) (nth one 0) (nth one 1)) rows)))))
  (defn cvss-oxford (indices prototypes correct rows)
    (if (eq (len indices) 0) (list correct (reverse rows))
      (do (let index (head indices))
          (let result (cvs-detect-file (cvsl-frame "oxford" index) prototypes))
          (cvss-oxford (tail indices) prototypes
            (if (eq (nth result 0) 1927) (add correct 1) correct)
            (cons (list index (nth result 0) (nth result 2) (nth result 3)) rows)))))
  (defn cvss-frame-distance (scene a b)
    (cvs-l1 (cvs-features-file (cvsl-frame scene a))
            (cvs-features-file (cvsl-frame scene b))))
  (defn cvss-distance-row (scene)
    (list scene
      "first-last" (cvss-frame-distance scene 1 24)
      "first-middle" (cvss-frame-distance scene 1 12)
      "first-quarter" (cvss-frame-distance scene 1 6)
      "middle-last" (cvss-frame-distance scene 12 24)))
  (defn concept-video-semantic-stress-live-run ()
    (do (let decoded (add (cvsl-decode "loop")
                          (add (cvsl-decode "university")
                            (add (cvsl-decode "courthouse") (cvsl-decode "oxford")))))
        (let early (cvss-bank (list 1 2 3 4)))
        (let late (cvss-bank (list 21 22 23 24)))
        (let interleaved (cvsl-prototypes))
        (list "concept-video-semantic-stress-live"
          (list "decoded" decoded)
          (list "early-train-late-test"
            (cvss-count-all (list "loop" "university" "courthouse")
              (list 19 20 21 22 23 24) early 0 (empty)))
          (list "late-train-early-test"
            (cvss-count-all (list "loop" "university" "courthouse")
              (list 1 2 3 4 5 6) late 0 (empty)))
          (list "oxford-as-university"
            (cvss-oxford (list 1 5 9 13 17 21 24) interleaved 0 (empty)))
          (list "trajectory-distances"
            (cvss-distance-row "loop") (cvss-distance-row "university")
            (cvss-distance-row "courthouse") (cvss-distance-row "oxford")))))

  (concept-video-semantic-stress-live-run))
