; concept-video-content-sensing-live.fk -- real semantic pixels enter the world.
;
; Four held-out frames from each committed LingBot trajectory are decoded to
; BMP. Apple's pretrained Vision classifier emits its top raw labels; Form
; composes those labels into scored evidence, applies an abstaining decision,
; maps to the aligned top-10k concept id, and persists the detection through the
; ordinary kernel world model. The classifier receives neither filename meaning
; nor concept metadata: only a BMP path. Form receives only label rows.
;
; Each frame is also rerun after a synthetic 28-pixel identity-like band covers
; its bottom edge. Stable concepts across that intervention prove this path does
; not recover ids from the visible cvg13 address envelope. Oxford is a negative
; control: its generic outdoor/brick/bicycle evidence stays below the admission
; floor instead of being forced into one of the three concepts.
;
; This live carrier is macOS-specific; the pure evidence law is four-way. It is
; closed evidence composition, not general open-vocabulary visual parity.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/lingbot-vision-input.fk model/concept-video-semantic.fk model/concept-video-content-sensing.fk model/concept-world-model.fk presence/concept-video-semantic-live.fk

(do
  (defn cvvsl-carrier-source ()
    "presence/carriers/concept-video-vision-classify.swift")
  (defn cvvsl-carrier-bin () "/tmp/concept-video-vision-classify")
  (defn cvvsl-compile-command ()
    (str_concat "swiftc -O " (str_concat (cvvsl-carrier-source)
      (str_concat " -o " (str_concat (cvvsl-carrier-bin)
        " >/dev/null 2>&1 && printf 1")))))
  (defn cvvsl-test-indices () (list 5 11 17 23))
  (defn cvvsl-band-frame (scene index)
    (str_concat "/tmp/cvcs-band-" (str_concat scene
      (str_concat "-" (str_concat (cvsl-pad6 index) ".bmp")))))
  (defn cvvsl-band-command (scene index)
    (str_concat "ffmpeg -loglevel error -y -i "
      (str_concat (cvsl-frame scene index)
        (str_concat " -vf drawbox=x=0:y=ih-28:w=iw:h=28:color=magenta:t=fill -frames:v 1 -c:v bmp "
          (str_concat (cvvsl-band-frame scene index) " >/dev/null 2>&1 && printf 1")))))
  (defn cvvsl-classify-command (path)
    (str_concat (cvvsl-carrier-bin) (str_concat " " path)))
  (defn cvvsl-classify (path)
    (host-exec (cvvsl-classify-command path) ""))
  (defn cvvsl-raw-labels (scene indices)
    (if (eq (len indices) 0) (empty)
      (cons (cvvsl-classify (cvsl-frame scene (head indices)))
            (cvvsl-raw-labels scene (tail indices)))))
  (defn cvvsl-band-labels (scene indices)
    (if (eq (len indices) 0) (empty)
      (cons (cvvsl-classify (cvvsl-band-frame scene (head indices)))
            (cvvsl-band-labels scene (tail indices)))))
  (defn cvvsl-prepare-bands (scene indices passed)
    (if (eq (len indices) 0) passed
      (cvvsl-prepare-bands scene (tail indices)
        (add passed (if (str_eq (host-exec
          (cvvsl-band-command scene (head indices)) "") "1") 1 0)))))
  (defn cvvsl-detect-raw (scene)
    (cvcs-detect-labels (cvvsl-raw-labels scene (cvvsl-test-indices))))
  (defn cvvsl-detect-band (scene)
    (cvcs-detect-labels (cvvsl-band-labels scene (cvvsl-test-indices))))

  (defn cvvsl-known ()
    (list (cwm-cell 493 "office") (cwm-cell 1927 "university")
          (cwm-cell 9066 "courthouse")))
  ; world row = (scene detected-id entity-id position persistence entity)
  (defn cvvsl-persist (scene detection position known)
    (do (let entity (cwm-persist-detection detection position
                      "semantic-video-content" 2400 known))
        (list scene (nth detection 0) (wm-ent-id entity)
              (wm-ent-position entity) (wm-ent-persistence entity) entity)))
  (defn cvvsl-score-row (detection)
    (list (nth detection 0) (nth detection 1) (nth detection 2)
          (nth detection 3) (nth detection 5) (nth detection 6)
          (nth detection 4)))
  (defn cvvsl-exact? (detection expected)
    (if (eq (nth detection 0) expected) 1 0))

  (defn concept-video-content-sensing-live-run ()
    (do
      (let available (if (str_eq (host-exec
        "command -v swiftc >/dev/null && command -v ffmpeg >/dev/null && printf 1" "") "1") 1 0))
      (let compiled (if (eq available 1)
        (if (str_eq (host-exec (cvvsl-compile-command) "") "1") 1 0) 0))
      (let decoded (if (eq compiled 1)
        (add (cvsl-decode "loop")
          (add (cvsl-decode "university")
            (add (cvsl-decode "courthouse") (cvsl-decode "oxford")))) 0))
      (let bands (if (eq decoded 4)
        (add (cvvsl-prepare-bands "loop" (cvvsl-test-indices) 0)
          (add (cvvsl-prepare-bands "university" (cvvsl-test-indices) 0)
            (add (cvvsl-prepare-bands "courthouse" (cvvsl-test-indices) 0)
                 (cvvsl-prepare-bands "oxford" (cvvsl-test-indices) 0)))) 0))
      (let office (if (eq bands 16) (cvvsl-detect-raw "loop") (empty)))
      (let university (if (eq bands 16) (cvvsl-detect-raw "university") (empty)))
      (let courthouse (if (eq bands 16) (cvvsl-detect-raw "courthouse") (empty)))
      (let oxford (if (eq bands 16) (cvvsl-detect-raw "oxford") (empty)))
      (let office-band (if (eq bands 16) (cvvsl-detect-band "loop") (empty)))
      (let university-band (if (eq bands 16) (cvvsl-detect-band "university") (empty)))
      (let courthouse-band (if (eq bands 16) (cvvsl-detect-band "courthouse") (empty)))
      (let oxford-band (if (eq bands 16) (cvvsl-detect-band "oxford") (empty)))
      (let raw-correct (if (eq bands 16)
        (add (cvvsl-exact? office 493)
          (add (cvvsl-exact? university 1927)
               (cvvsl-exact? courthouse 9066))) 0))
      (let band-stable (if (eq bands 16)
        (add (if (eq (nth office 0) (nth office-band 0)) 1 0)
          (add (if (eq (nth university 0) (nth university-band 0)) 1 0)
               (if (eq (nth courthouse 0) (nth courthouse-band 0)) 1 0))) 0))
      (let known (cvvsl-known))
      (let office-world (if (eq raw-correct 3) (cvvsl-persist "office-route" office 1 known) (empty)))
      (let university-world (if (eq raw-correct 3) (cvvsl-persist "university" university 2 known) (empty)))
      (let courthouse-world (if (eq raw-correct 3) (cvvsl-persist "courthouse" courthouse 3 known) (empty)))
      (let entities (if (eq raw-correct 3)
        (list (nth office-world 5) (nth university-world 5) (nth courthouse-world 5))
        (empty)))
      (let persisted (if (eq (len entities) 3)
        (add (if (str_eq (nth office-world 2) "office") 1 0)
          (add (if (str_eq (nth university-world 2) "university") 1 0)
               (if (str_eq (nth courthouse-world 2) "courthouse") 1 0))) 0))
      (list "concept-video-content-sensing-live"
        (list "carrier" available compiled "Apple-Vision-pretrained-labels")
        (list "decoded" decoded "real-videos" "held-out-frames" 12 "band-variants" bands)
        (list "raw-content" raw-correct 3
          (list "office" (cvvsl-score-row office))
          (list "university" (cvvsl-score-row university))
          (list "courthouse" (cvvsl-score-row courthouse)))
        (list "identity-band-intervention" band-stable 3
          (list "office" (cvvsl-score-row office-band))
          (list "university" (cvvsl-score-row university-band))
          (list "courthouse" (cvvsl-score-row courthouse-band)))
        (list "negative-control-oxford" (cvvsl-score-row oxford)
          "band" (cvvsl-score-row oxford-band)
          "abstained-both" (if (and (eq (nth oxford 0) -1)
                                     (eq (nth oxford-band 0) -1)) 1 0))
        (list "world-model" persisted 3 (cwm-concept-count entities)
          (list office-world university-world courthouse-world) (cwm-world entities))
        (list "boundaries" "closed-evidence-vocabulary"
          "host-pretrained-label-carrier" "not-open-vocabulary-parity"))))

  (concept-video-content-sensing-live-run))
