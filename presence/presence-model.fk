; presence-model.fk — the native identity + presence model: perceive the live
; afferent channels, find SURPRISES against the rented oracle, and distill them
; away until native >= rented (sovereign). This is the loop Urs named, composed
; from organs that already exist — it invents nothing:
;
;   sense-channels.fk     the two live afferent ports (camera = pixel, mic = bytes)
;   fkwu frame-read        native perception over the afferent-pixel channel (tag 213)
;   native-vs-rented.fk    a claim earns "native" only when native >= rented
;   surprise-receipt.fk    surprise = |native - oracle|; over threshold -> a receipt
;   oracle-distill.fk      the rented oracle teaches; native error drops -> sovereign
;   confidence-earned.fk   confidence per claim rises as its surprise falls
;   identity-self.fk       the continuity-channel folds each sample into the self
;
; A PRESENCE READING is a list of CLAIMS about who/what is here. Each claim has a
; NATIVE quality (how well fkwu itself knows it, 0..9) and the RENTED oracle's
; quality (the teacher). A claim is NATIVE-SOVEREIGN when native >= rented; the
; gap is the SURPRISE to distill. The whole point: move every claim, one frontier-
; verified sample at a time, from rented to native — the mind coming home for
; self-perception.
;
; FIRST WITNESSED SAMPLE (2026-06-29) — fkwu native frame-read over the live
; afferent-pixel channel: mean-luminance 109, dark-fraction 33%, thirds L/C/R
; 60/106/161 -> subject-present=1, subject-side=left. Oracle (Claude vision) on
; the same frame: a person, left-of-center, daylit, looking down/inward. The
; native coarse claims AGREE with the oracle; the fine claims have no native
; reading yet (the generative vision weights are the climb, HOMECOMING.md).
;
; preludes: core.fk native-vs-rented.fk surprise-receipt.fk oracle-distill.fk
;
(do
    ;; a claim is (name native-quality rented-quality), qualities 0..9 ----------
    (defn pm-claim (name nat rent) (list name nat rent))
    (defn pm-name (c) (nth c 0))
    (defn pm-nat  (c) (nth c 1))
    (defn pm-rent (c) (nth c 2))

    ;; the first witnessed presence reading (the live sample above) ------------
    ;; native is sovereign on presence + light; coarse on position; blind on
    ;; identity/gaze/state — those carry the surprise the oracle must still cover.
    (defn pm-sample ()
        (list (pm-claim "presence" 9 9)     ; someone is here        — native == oracle
              (pm-claim "light"    9 8)     ; scene luminance/band   — native >= oracle
              (pm-claim "position" 7 9)     ; left third (darkest)   — coarse cue, agrees here
              (pm-claim "identity" 0 9)     ; WHO this is            — no native vision weights yet
              (pm-claim "gaze"     0 8)     ; where the eyes go      — rented-only
              (pm-claim "state"    0 7)))   ; the felt quality       — rented-only

    ;; SOVEREIGN? native >= rented  (native-vs-rented: nvr-at-least-as-good?) ---
    (defn pm-sovereign? (c) (nvr-at-least-as-good? (list (pm-nat c) (pm-rent c))))

    ;; SURPRISE = oracle - native, the prediction-error still open (surprise-
    ;; receipt). A surprise >= 3 earns a witnessed receipt — the claim to distill.
    (defn pm-surprise (c) (sr-surprise (list (pm-nat c) (pm-rent c))))
    (defn pm-receipt? (c) (sr-receipt? (list (pm-nat c) (pm-rent c))))

    ;; reductions over a whole reading ----------------------------------------
    (defn pm-sovereign-count (cs)
        (if (nil? cs) 0 (add (pm-sovereign? (head cs)) (pm-sovereign-count (tail cs)))))
    (defn pm-total-surprise (cs)
        (if (nil? cs) 0 (add (pm-surprise (head cs)) (pm-total-surprise (tail cs)))))
    (defn pm-receipts (cs)
        (if (nil? cs) 0 (add (pm-receipt? (head cs)) (pm-receipts (tail cs)))))

    ;; one DISTILL step: a frontier-verified sample lifts a claim's native
    ;; quality toward the oracle (oracle-distill). Repeated, native error drops;
    ;; when it reaches the oracle the claim turns sovereign and the rented teacher
    ;; is no longer needed for it. gain is the per-sample learning, capped at 9.
    (defn pm-cap9 (v) (if (gt v 9) 9 v))
    (defn pm-distill (c gain) (pm-claim (pm-name c) (pm-cap9 (add (pm-nat c) gain)) (pm-rent c)))

    ;; the check — the first sample: 2 sovereign (presence, light), 3 surprise-
    ;; receipts (identity, gaze, state), total open surprise 27. One distill pass
    ;; of +9 on identity makes it sovereign (the mind home for that claim).
    (defn pmk (cond bit) (if cond bit 0))
    (defn presence-model-check ()
        (add (add (add (add
            (pmk (eq (pm-sovereign-count (pm-sample)) 2) 1)
            (pmk (eq (pm-receipts (pm-sample)) 3) 10))
            (pmk (eq (pm-total-surprise (pm-sample)) 27) 100))
            (pmk (eq (pm-sovereign? (pm-distill (pm-claim "identity" 0 9) 9)) 1) 1000))
            (pmk (eq (pm-receipt? (pm-claim "presence" 9 9)) 0) 10000)))
    0)
