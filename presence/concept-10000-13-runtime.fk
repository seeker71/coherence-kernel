; concept-10000-13-runtime.fk — one operational address across the kernel body.
;
; This is not a test fixture. It is the directly runnable, lazy integration
; door for the 10,000-concept surface: attributed NL text, real spoken audio,
; semantic video planning/backdrop selection, executable PL generation and
; recovery, and persistence through the existing native world model all share
; one concept ID. The specialized audio/video live organs materialize larger
; matrices; this door proves they meet at the same loaded record.
;
; witnessed: 2026-07-18 -> courthouse/Indonesian/Go live, score 255
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/lingbot-vision-input.fk model/concept-video-generation-10000-13.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk
(do
  (defn c1013r-hit (ok bit) (if ok bit 0))
  (defn c1013r-cat (xs)
    (if (eq (len xs) 0) ""
      (str_concat (head xs) (c1013r-cat (tail xs)))))
  (defn c1013r-audio-path (id code)
    (str_concat "/tmp/sema-concept-runtime-" (str_concat (int_to_str id)
      (str_concat "-" (str_concat code ".wav")))))

  (defn c1013r-address-in (ranked semantic-index semantic-payload nl-runtime
                           id nl-code pl-language position)
    (do
      (let record (c10-concept-at-in ranked id))
      (let semantic (cs10-at-in semantic-index semantic-payload id))
      (let text (cnl13-runtime-lookup-sourced nl-runtime id nl-code))
      (let lens (ca13-lens-index nl-code))
      (let audio-path (c1013r-audio-path id nl-code))
      (let audio (ca13-generate nl-runtime id nl-code audio-path))
      (let audio-sensed (if (eq (nth audio 0) 1)
                          (ca13-sense-file audio-path) (list -1 -1 0)))
      (let speech (if (eq (nth audio 0) 1)
                    (ca13-speech-evidence-file audio-path) (list 0 0 0)))
      (let video (cvg13-plan-surface-in ranked semantic-index semantic-payload
                    id lens (nth text 3) (nth text 4) (nth text 5)))
      (let source (cp10-generate-in ranked semantic-index semantic-payload
                    pl-language id))
      (let recovered (cp10-recover-source-in ranked semantic-index
                       semantic-payload source))
      (let known (list (cwm-cell id (c10-concept-label record))))
      (let entity (cwm-persist id position "concept-10000-13-runtime" 1800 known))
      (let world (cwm-world (list entity)))
      (let score
        (add
          (c1013r-hit (and (eq (nth text 0) id)
                            (not (str_eq (nth text 3) ""))) 1)
          (add
            (c1013r-hit (and (eq (nth audio 0) 1)
                              (and (eq (nth audio-sensed 0) id)
                                   (eq (nth audio-sensed 1) lens))) 2)
            (add
              (c1013r-hit (eq (nth speech 2) 1) 4)
              (add
                (c1013r-hit (and (eq (cvg13-plan-id video) id)
                                  (str_eq (cvg13-plan-surface video) (nth text 3))) 8)
                (add
                  (c1013r-hit (not (str_eq (cvg13-plan-backdrop video) "")) 16)
                  (add
                    (c1013r-hit (and (eq (len recovered) 5)
                                      (eq (nth (cp10-source-identity source) 0) id)) 32)
                    (add
                      (c1013r-hit (and (str_eq (wm-ent-id entity)
                                               (c10-concept-label record))
                                        (eq (cwm-concept-count (list entity)) 1)) 64)
                      (c1013r-hit (and (eq (cs10-anchor-id semantic) id)
                                        (eq (cnl13-anchor-count) 10000)) 128)))))))))
      (list "concept-10000-13-address"
        (list "identity" id (c10-concept-label record)
              (cs10-synset-id semantic) (cs10-method-label semantic))
        (list "text" nl-code (nth text 3) (nth text 4) (nth text 5) (nth text 6))
        (list "audio" audio-path (nth audio 0) (nth audio 4) (nth audio 5)
              (nth audio 8) (nth audio 9) speech audio-sensed)
        (list "video-plan" (cvg13-plan-caption video) (cvg13-plan-gloss video)
              (cvg13-plan-backdrop video) (cvg13-plan-surface-state video)
              (cvg13-plan-surface-source video))
        (list "program" pl-language (str_len source)
              (cp10-source-identity source)
              (if (eq (len recovered) 5) (cp13-output (nth recovered 4)) "rejected"))
        (list "world-model" (wm-ent-id entity) (wm-ent-position entity)
              (wm-ent-persistence entity) (cwm-concept-count (list entity)) world)
        (list "address-space" 10000 13 130000 13 130000)
        (list "score" score 255))))

  (defn concept-10000-13-runtime-run ()
    (do
      (let ranked (read_file (c10-ranked-path)))
      (let semantic-index (read_file (cs10-index-path)))
      (let semantic-payload (read_file (cs10-payload-path)))
      (let nl-runtime (cnl13-runtime-open))
      ; Real-life courthouse address: Indonesian speech/text, Go program,
      ; committed courthouse footage selected, and position 3 in the world map.
      ; 9066 is the exact courthouse anchor; 751 is the broader word court and
      ; deliberately has no claim on this footage.
      (c1013r-address-in ranked semantic-index semantic-payload nl-runtime
                         9066 "id" "go" 3)))

  (defn c1013r-print (address)
    (do
      (let identity (nth address 1))
      (let text-row (nth address 2))
      (let audio (nth address 3))
      (let speech (nth audio 7))
      (let sensed (nth audio 8))
      (let video (nth address 4))
      (let program (nth address 5))
      (let program-id (nth program 3))
      (let world (nth address 6))
      (let score (nth address 8))
      (c1013r-cat (list
        "identity id=" (int_to_str (nth identity 1)) " anchor=" (nth identity 2)
          " synset=" (nth identity 3) " mapping=" (nth identity 4) "\n"
        "text locale=" (nth text-row 1) " label=" (nth text-row 2)
          " state=" (nth text-row 3) " source=" (nth text-row 4)
          " code=" (nth text-row 5) "\n"
        "audio generated=" (int_to_str (nth audio 2)) " label=" (nth audio 3)
          " state=" (nth audio 4) " source=" (nth audio 5)
          " code=" (nth audio 6)
          " speech-samples=" (int_to_str (nth speech 0))
          " speech-level=" (int_to_str (nth speech 1))
          " speech-present=" (int_to_str (nth speech 2))
          " sensed=" (int_to_str (nth sensed 0)) ":" (int_to_str (nth sensed 1)) "\n"
        "video caption=" (nth video 1) " gloss=" (nth video 2)
          " backdrop=" (nth video 3) " state=" (nth video 4)
          " source=" (nth video 5) "\n"
        "program language=" (nth program 1) " bytes=" (int_to_str (nth program 2))
          " recovered=" (int_to_str (nth program-id 0)) ":"
          (int_to_str (nth program-id 1)) " fingerprint="
          (int_to_str (nth program-id 2)) " output=" (nth program 4) "\n"
        "world id=" (nth world 1) " position=" (int_to_str (nth world 2))
          " persistence=" (int_to_str (nth world 3))
          " concepts=" (int_to_str (nth world 4)) "\n"
        "surface NL=" (int_to_str (nth (nth address 7) 3))
          " PL=" (int_to_str (nth (nth address 7) 5))
          " score=" (int_to_str (nth score 1)) "/" (int_to_str (nth score 2)) "\n"))))

  (nth (nth (concept-10000-13-runtime-run) 8) 1))
