; concept-10000-13-runtime.fk — one operational address across the kernel body.
;
; This is not a test fixture. It is the directly runnable, lazy integration
; door for the 10,000-concept surface: attributed NL text, real spoken audio,
; semantic video planning/backdrop selection, executable PL generation and
; recovery, and persistence through the existing native world model all share
; one concept ID. The specialized audio/video live organs materialize larger
; matrices; this door proves they meet at the same loaded record.
;
; witnessed: 2026-07-19 -> WordNet+morphology+lexical semantics, attributed
; text, generated PL, 78 public programs, and the complete released four-block
; Whisper encoder and released decoder layer 0 integrated over real human speech, score 511
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/whisper-tiny-native-conv1.fk model/whisper-tiny-native-conv2.fk model/whisper-tiny-native-encoder0.fk model/whisper-tiny-native-encoder.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk model/concept-semantics-10000-wiktionary-lexical.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-roundtrip-10000-13-metadata.fk cognition/concept-text-roundtrip-10000-13.fk cognition/concept-text-roundtrip-10000-13-runtime.fk cognition/concept-human-corpus-13-runtime.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/fixtures/concept-pl-task-families-source/concept-pl-task-families-snapshot.fk presence/concept-pl-task-families-13.fk presence/concept-pl-task-families-13-generation.fk presence/concept-pl-arbitrary-source-13.fk presence/concept-pl-public-algorithms-13.fk presence/concept-pl-real-life-workflows-live.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/lingbot-vision-input.fk model/concept-video-generation-10000-13.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk
; preludes: form/form-stdlib/transformer-decoder.fk model/whisper-tiny-native-decoder0.fk
(do
  (defn c1013r-hit (ok bit) (if ok bit 0))
  (defn c1013r-cat (xs)
    (if (eq (len xs) 0) ""
      (str_concat (head xs) (c1013r-cat (tail xs)))))
  (defn c1013r-audio-path (id code)
    (str_concat "/tmp/sema-concept-runtime-" (str_concat (int_to_str id)
      (str_concat "-" (str_concat code ".wav")))))
  (defn c1013r-public-samples-valid? (rows)
    (if (eq (len rows) 0) 1
      (if (and (eq (nth (head rows) 10) 1)
            (and (eq (nth (head rows) 13) 1)
                 (eq (nth (head rows) 14) 1)))
        (c1013r-public-samples-valid? (tail rows)) 0)))
  (defn c1013r-public-sample-summary (row)
    (list (nth row 0) (nth row 1) "bytes" (nth row 2)
      "tokens" (nth row 4) "ast-nodes" (nth row 5)
      "semantic-roles" (nth row 8) "admitted" (nth row 10)
      "anchor-role-mutation-rejected" (nth row 13)
      "malformed-rejected" (nth row 14)))
  (defn c1013r-public-sample-summaries (rows)
    (if (eq (len rows) 0) (empty)
      (cons (c1013r-public-sample-summary (head rows))
        (c1013r-public-sample-summaries (tail rows)))))
  (defn c1013r-effective-semantic
    (ranked primary-index primary-payload overlay-index overlay-payload
     lexical-index lexical-payload repair-index repair-payload id)
    (do (let repaired (cs10l-repair-at-in ranked repair-index repair-payload id))
        (if (cs10-mapped? repaired) repaired
          (cs10l-at-in ranked primary-index primary-payload overlay-index overlay-payload
            lexical-index lexical-payload id))))

  (defn c1013r-address-in (ranked semantic-index semantic-payload
                           overlay-index overlay-payload lexical-index lexical-payload
                           repair-index repair-payload
                           nl-runtime text-runtime
                           id nl-code pl-language position)
    (do
      (let record (c10-concept-at-in ranked id))
      (let semantic (c1013r-effective-semantic ranked semantic-index semantic-payload
                      overlay-index overlay-payload lexical-index lexical-payload
                      repair-index repair-payload id))
      (let text (cnl13-runtime-lookup-sourced nl-runtime id nl-code))
      (let text-evidence (ctr13-runtime-detect-cell text-runtime id nl-code))
      (let lens (ca13-lens-index nl-code))
      (let audio-path (c1013r-audio-path id nl-code))
      (let audio (ca13-generate nl-runtime id nl-code audio-path))
      (let audio-sensed (if (eq (nth audio 0) 1)
                          (ca13-sense-file audio-path) (list -1 -1 0)))
      (let speech (if (eq (nth audio 0) 1)
                    (ca13-speech-evidence-file audio-path) (list 0 0 0)))
      (let video (cvg13-plan-surface-record-mapping record semantic
                    id lens (nth text 3) (nth text 4) (nth text 5)
                    (cs10l-method-label semantic)))
      (let source (cp10-generate-from pl-language record semantic))
      (let recovered-ok (cp10-recover-known? pl-language record semantic source))
      (let evaluation (cp13-evaluate (cp10-spec-for pl-language record semantic)))
      (let recovered (if (eq recovered-ok 1)
        (list id pl-language record semantic evaluation) (empty)))
      (let task-route (cptf-route-record record semantic))
      ; A method-3 companion is admitted through the same operational path so
      ; the new overlay is consumed by text, PL, and world organs—not merely
      ; reported by its own test. Anchor 2097 is the revision-pinned plural
      ; "patients" -> WordNet lemma "patient".
      (let expanded-id 2097)
      (let expanded-record (c10-concept-at-in ranked expanded-id))
      (let expanded-semantic (c1013r-effective-semantic ranked semantic-index semantic-payload
        overlay-index overlay-payload lexical-index lexical-payload
        repair-index repair-payload expanded-id))
      (let expanded-text (ctr13-runtime-detect-cell text-runtime expanded-id "en"))
      (let expanded-video (cvg13-plan-surface-record-mapping
        expanded-record expanded-semantic expanded-id 0
        (nth (nth expanded-text 2) 1) "indexed-complete-candidate"
        "concept-text-roundtrip-10000-13" (cs10l-method-label expanded-semantic)))
      (let expanded-route (cptf-route-record expanded-record expanded-semantic))
      (let expanded-source (cp10-generate-from "javascript"
        expanded-record expanded-semantic))
      (let expanded-recovered (cp10-recover-known? "javascript"
        expanded-record expanded-semantic expanded-source))
      ; Method-4 companion: id 0 `you` was one of the prior semantic holes.
      ; The production runtime now consumes its revision-pinned Wiktionary
      ; definition in PL generation and the shared world, not only an audit.
      (let lexical-id 0)
      (let lexical-record (c10-concept-at-in ranked lexical-id))
      (let lexical-semantic (c1013r-effective-semantic ranked semantic-index semantic-payload
        overlay-index overlay-payload lexical-index lexical-payload
        repair-index repair-payload lexical-id))
      (let lexical-route (cptf-route-record lexical-record lexical-semantic))
      (let lexical-source (cp10-generate-from "javascript"
        lexical-record lexical-semantic))
      (let lexical-recovered (cp10-recover-known? "javascript"
        lexical-record lexical-semantic lexical-source))
      ; Method-5 companion: repaired stable ID 104 enters through the primary
      ; NL table, effective semantic priority, PL recovery, and shared world.
      (let repair-id 104)
      (let repair-record (c10-concept-at-in ranked repair-id))
      (let repair-semantic (c1013r-effective-semantic ranked semantic-index semantic-payload
        overlay-index overlay-payload lexical-index lexical-payload
        repair-index repair-payload repair-id))
      (let repair-text (cnl13-runtime-lookup-sourced nl-runtime repair-id "id"))
      (let repair-roundtrip (ctr13-runtime-detect-cell text-runtime repair-id "id"))
      (let repair-source (cp10-generate-from "javascript" repair-record repair-semantic))
      (let repair-recovered (cp10-recover-known? "javascript"
        repair-record repair-semantic repair-source))
      (let public-task-source (cptfg-generate "javascript" 0))
      (let public-task-recovered (cptfg-recover public-task-source))
      (let public-task-valid (if (and (eq (len public-task-recovered) 5)
        (value_eq (nth public-task-recovered 3)
          (cptf-evaluations (cptf-tasks)))) 1 0))
      ; Real public source, not a generated marker: the pinned Exercism
      ; JavaScript Luhn implementation passes tokenizer/AST/ten-role semantics,
      ; while modulo-11 and unclosed-group mutations are both rejected.
      (let arbitrary-pl (cpa13-observe-one (head (cpa13-fixtures))))
      ; Six exact public programs expose six independent algorithm families.
      (let public-algorithm-samples (cppa13-live-samples))
      (let real-life-workflows (concept-pl-real-life-workflows-run))
      (let real-life-totals (nth real-life-workflows 2))
      (let real-life-world (nth real-life-workflows 3))
      ; A real attributed Indonesian sentence now enters this production door.
      ; Its expected concept never enters detection: the world bridge selects
      ; id 259 only if it is present in the complete detector result.
      (let human-runtime (hcnl13-runtime-open))
      (let human-row (hcnl13-runtime-row human-runtime 101))
      (let human-world (hcnl13-runtime-world-admit-index human-runtime 101))
      ; Real CC0 human speech executes the released conv stem, two positional
      ; rows, all four six-head attention/FFN blocks, and final encoder norm.
      (let native-acoustic (wte-infer-file
        "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
      (let native-decoder (wtd0-infer-encoder
        "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"
        (nth native-acoustic 27)))
      (let known (list (cwm-cell id (c10-concept-label record))
        (cwm-cell expanded-id (c10-concept-label expanded-record))
        (cwm-cell lexical-id (c10-concept-label lexical-record))
        (cwm-cell repair-id (c10-concept-label repair-record))))
      (let entity (cwm-persist id position (nth task-route 2) 1800 known))
      (let expanded-entity (cwm-persist expanded-id (add position 1)
        (nth expanded-route 2) 1800 known))
      (let lexical-entity (cwm-persist lexical-id (add position 2)
        (nth lexical-route 2) 1800 known))
      (let repair-entity (cwm-persist repair-id (add position 3)
        "substantive-id-repair-wiktionary" 1800 known))
      (let world (cwm-world (list entity expanded-entity lexical-entity repair-entity)))
      (let base-score
        (add
          (c1013r-hit (and (eq (nth text 0) id)
                            (not (str_eq (nth text 3) ""))) 1)
          (add
            (c1013r-hit (and (eq (nth audio 0) 1)
                              (and (eq (nth audio-sensed 0) id)
                                   (eq (nth audio-sensed 1) lens))) 2)
            (add
              (c1013r-hit (eq (nth speech 2) 1) 4)
              (add
                (c1013r-hit (and (eq (cvg13-plan-id video) id)
                                  (str_eq (cvg13-plan-surface video) (nth text 3))) 8)
                (add
                  (c1013r-hit (not (str_eq (cvg13-plan-backdrop video) "")) 16)
                  (add
                    (c1013r-hit (and (eq (len recovered) 5)
                      (and (eq (nth (cp10-source-identity source) 0) id)
                        (and (eq public-task-valid 1)
                          (and (eq (nth arbitrary-pl 8) 10)
                            (and (eq (nth arbitrary-pl 9) 1)
                              (and (eq (nth arbitrary-pl 12) 1)
                                (and (eq (nth arbitrary-pl 13) 1)
                                  (and (eq (c1013r-public-samples-valid?
                                        public-algorithm-samples) 1)
                                    (and (eq (nth real-life-totals 2) 78)
                                         (eq (nth real-life-world 2) 6)))))))))) 32)
                    (add
                      (c1013r-hit (and (str_eq (wm-ent-id entity)
                                               (c10-concept-label record))
                        (and (str_eq (wm-ent-id expanded-entity)
                               (c10-concept-label expanded-record))
                          (and (eq (cwm-concept-count
                                      (list entity expanded-entity lexical-entity repair-entity)) 4)
                            (and (eq (cs10-method expanded-semantic) 3)
                              (and (eq expanded-recovered 1)
                                (and (eq (cs10-method lexical-semantic) 4)
                                  (and (eq lexical-recovered 1)
                                    (and (eq (nth (nth expanded-text 6) 1) 1)
                                      (and (str_eq (cvg13-plan-mapping expanded-video)
                                             "wiktionary-form+wordnet")
                                           (and (gt (str_len
                                             (cs10-gloss lexical-semantic)) 0)
                                             (and (eq (cs10-method repair-semantic) 5)
                                               (and (str_eq (c10-concept-label repair-record) "welcoming")
                                                 (and (str_eq (nth repair-text 3) "menyambut")
                                                   (and (eq (nth (nth repair-roundtrip 4) 2) 1)
                                                     (and (eq repair-recovered 1)
                                                       (str_eq (wm-ent-id repair-entity) "welcoming")))))))))))))) 64)
                      (c1013r-hit (and (eq (cs10-anchor-id semantic) id)
                        (and (eq (cnl13-anchor-count) 10000)
                          (and (eq (nth human-world 1) 1)
                               (eq (nth human-world 3) 259)))) 128)))))))))
      (let score (add base-score
        (c1013r-hit (and (eq (nth native-acoustic 17) 1)
          (and (eq (nth native-acoustic 13) 2)
            (and (eq (nth native-acoustic 14) 384)
              (and (eq (nth native-acoustic 15) 7633152)
                (and (eq (nth native-acoustic 22) 1)
                  (and (gt (nth (nth native-acoustic 20) 0) 1.0)
                    (and (gt (nth (nth native-acoustic 20) 5) 1.0)
                      (and (eq (nth native-decoder 8) 2408832)
                        (and (eq (nth native-decoder 20) 1)
                             (gt (nth native-decoder 18) 1.0)))))))))) 256)))
      (list "concept-10000-13-address"
        (list "identity" id (c10-concept-label record)
              (cs10-synset-id semantic) (cs10l-method-label semantic))
        (list "text" nl-code (nth text 3) (nth text 4) (nth text 5) (nth text 6)
              text-evidence)
        (list "audio" audio-path (nth audio 0) (nth audio 4) (nth audio 5)
              (nth audio 8) (nth audio 9) speech audio-sensed)
        (list "video-plan" (cvg13-plan-caption video) (cvg13-plan-gloss video)
              (cvg13-plan-backdrop video) (cvg13-plan-surface-state video)
              (cvg13-plan-surface-source video))
        (list "program" pl-language (str_len source)
              (cp10-source-identity source)
              (if (eq (len recovered) 5) (cp13-output (nth recovered 4)) "rejected")
              (nth task-route 2) (nth task-route 3) (nth task-route 4)
              (list "method3-companion" expanded-id "javascript"
                (str_len expanded-source) expanded-recovered
                (nth expanded-route 2) (nth expanded-route 3)
                (cvg13-plan-caption expanded-video)
                (cvg13-plan-gloss expanded-video)
                (cvg13-plan-mapping expanded-video))
              (list "method4-companion" lexical-id "javascript"
                (str_len lexical-source) lexical-recovered
                (cs10l-method-label lexical-semantic)
                (cs10-gloss lexical-semantic))
              (list "method5-substantive-repair" repair-id "javascript"
                (str_len repair-source) repair-recovered
                (c10-concept-label repair-record) (nth repair-text 3)
                (cs10l-method-label repair-semantic))
              (list "public-data-six-family" "javascript"
                (str_len public-task-source) public-task-valid
                (if (eq (len public-task-recovered) 5)
                  (nth public-task-recovered 3) (empty)))
              (list "arbitrary-public-source" (nth arbitrary-pl 0)
                (nth arbitrary-pl 1) "bytes" (nth arbitrary-pl 2)
                "tokens" (nth arbitrary-pl 4) "ast-nodes" (nth arbitrary-pl 5)
                "semantic-roles" (nth arbitrary-pl 8)
                "admitted" (nth arbitrary-pl 9)
                "modulo-11-rejected" (nth arbitrary-pl 12)
                "broken-group-rejected" (nth arbitrary-pl 13))
              (list "public-six-algorithm-samples"
                (c1013r-public-sample-summaries public-algorithm-samples))
              (list "real-life-six-workflows" "programs" (nth real-life-totals 2)
                "bytes" (nth real-life-totals 4) "world-concepts" (nth real-life-world 2)))
        (list "world-model" (wm-ent-id entity) (wm-ent-position entity)
              (wm-ent-persistence entity)
              (cwm-concept-count (list entity expanded-entity lexical-entity repair-entity)) world
              (cs10l-method-label semantic) (nth task-route 2)
              (list "method3-companion" (wm-ent-id expanded-entity)
                (cs10l-method-label expanded-semantic) (cs10-lemma expanded-semantic)
                (nth expanded-route 2))
              (list "method4-companion" (wm-ent-id lexical-entity)
                (cs10l-method-label lexical-semantic)
                (cs10-gloss lexical-semantic))
              (list "method5-substantive-repair" (wm-ent-id repair-entity)
                (cs10l-method-label repair-semantic) (nth repair-text 3)))
        (list "address-space" 10000 13 130000 13 130000)
        (list "score" score 511)
        (list "public-human-text"
          (hcnl13-row-locale human-row)
          (hcnl13-row-sentence-id human-row)
          (hcnl13-row-author human-row)
          (hcnl13-row-license human-row)
          (hcnl13-row-url human-row)
          (hcnl13-row-review-state human-row)
          (hcnl13-row-sentence human-row)
          (list "detector" "unprompted-complete-10000"
            "world-admission" human-world))
        (list "native-acoustic-encoder"
          "source" "Lingua-Libre-M92036254-human-book"
          "causal-parameters" (nth native-acoustic 15)
          "carried-parameters" (nth native-acoustic 16)
          "tokens" (nth native-acoustic 13) "width" (nth native-acoustic 14)
          "attention" (nth native-acoustic 18)
          "fingerprints" (nth native-acoustic 19)
          "native-recognizer" (nth native-acoustic 24))
        (list "native-acoustic-decoder0"
          "prompt" (nth native-decoder 2)
          "causal-parameters" (nth native-decoder 8)
          "carried-parameters" (nth native-decoder 9)
          "self-attention" (nth native-decoder 11)
          "cross-attention" (nth native-decoder 12)
          "special-window-winner-id" (nth native-decoder 15)
          "encoder-collapse-distance" (nth native-decoder 18)
          "complete" (nth native-decoder 20)
          "native-recognizer" (nth native-decoder 22))))))

  (defn concept-10000-13-runtime-run ()
    (do
      (let ranked (read_file (c10-ranked-path)))
      (let semantic-index (read_file (cs10-index-path)))
      (let semantic-payload (read_file (cs10-payload-path)))
      (let overlay-index (read_file (cs10w-index-path)))
      (let overlay-payload (read_file (cs10w-payload-path)))
      (let lexical-index (read_file (cs10l-index-path)))
      (let lexical-payload (read_file (cs10l-payload-path)))
      (let repair-index (read_file (csr111-semantic-index-path)))
      (let repair-payload (read_file (csr111-semantic-payload-path)))
      (let nl-runtime (cnl13-runtime-open))
      (let text-runtime (ctr13-runtime-open))
      ; Real-life courthouse address: Indonesian speech/text, Go program,
      ; committed courthouse footage selected, and position 3 in the world map.
      ; 9066 is the exact courthouse anchor; 751 is the broader word court and
      ; deliberately has no claim on this footage.
      (c1013r-address-in ranked semantic-index semantic-payload
        overlay-index overlay-payload lexical-index lexical-payload repair-index repair-payload
        nl-runtime text-runtime
        9066 "id" "go" 3)))

  (defn c1013r-print (address)
    (do
      (let identity (nth address 1))
      (let text-row (nth address 2))
      (let audio (nth address 3))
      (let speech (nth audio 7))
      (let sensed (nth audio 8))
      (let video (nth address 4))
      (let program (nth address 5))
      (let program-id (nth program 3))
      (let world (nth address 6))
      (let score (nth address 8))
      (let human (nth address 9))
      (let native-acoustic (nth address 10))
      (let native-decoder (nth address 11))
      (c1013r-cat (list
        "identity id=" (int_to_str (nth identity 1)) " anchor=" (nth identity 2)
          " synset=" (nth identity 3) " mapping=" (nth identity 4) "\n"
        "text locale=" (nth text-row 1) " label=" (nth text-row 2)
          " state=" (nth text-row 3) " source=" (nth text-row 4)
          " code=" (nth text-row 5) "\n"
        "audio generated=" (int_to_str (nth audio 2)) " label=" (nth audio 3)
          " state=" (nth audio 4) " source=" (nth audio 5)
          " code=" (nth audio 6)
          " speech-samples=" (int_to_str (nth speech 0))
          " speech-level=" (int_to_str (nth speech 1))
          " speech-present=" (int_to_str (nth speech 2))
          " sensed=" (int_to_str (nth sensed 0)) ":" (int_to_str (nth sensed 1)) "\n"
        "video caption=" (nth video 1) " gloss=" (nth video 2)
          " backdrop=" (nth video 3) " state=" (nth video 4)
          " source=" (nth video 5) "\n"
        "program language=" (nth program 1) " bytes=" (int_to_str (nth program 2))
          " recovered=" (int_to_str (nth program-id 0)) ":"
          (int_to_str (nth program-id 1)) " fingerprint="
          (int_to_str (nth program-id 2)) " output=" (nth program 4) "\n"
        "world id=" (nth world 1) " position=" (int_to_str (nth world 2))
          " persistence=" (int_to_str (nth world 3))
          " concepts=" (int_to_str (nth world 4)) "\n"
        "public-human-text locale=" (nth human 1)
          " sentence-id=" (int_to_str (nth human 2))
          " by=" (nth human 3) " review=" (nth human 6)
          " quote=" (nth human 7) "\n"
        "native-acoustic source=" (nth native-acoustic 2)
          " causal-parameters=" (int_to_str (nth native-acoustic 4))
          " tokens=" (int_to_str (nth native-acoustic 8))
          " width=" (int_to_str (nth native-acoustic 10))
          " native-recognizer=" (int_to_str (nth native-acoustic 16)) "\n"
        "native-decoder0 causal-parameters="
          (int_to_str (nth native-decoder 4))
          " collapse-distance=" (float_to_str (nth native-decoder 14))
          " complete=" (int_to_str (nth native-decoder 16)) "\n"
        "surface NL=" (int_to_str (nth (nth address 7) 3))
          " PL=" (int_to_str (nth (nth address 7) 5))
          " score=" (int_to_str (nth score 1)) "/" (int_to_str (nth score 2)) "\n"))))

  (nth (nth (concept-10000-13-runtime-run) 8) 1)
