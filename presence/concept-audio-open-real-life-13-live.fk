; concept-audio-open-real-life-13-live.fk -- situated open speech witnesses.
;
; These are not the universal metalinguistic frames.  Each locale carries one
; concrete public-life situation: road ice, an emergency exit, delayed transit,
; medical dosage, kitchen safety, a workplace meeting, storm damage, a weather
; warning, disrupted school, flood safety, emergency water, child medication,
; and an ambulance arrival.  The same speech-only -> Whisper -> full Form 10k
; path is used and misses remain visible.
; witnessed: 2026-07-18 -> 12/13 situated hits; Hindi बच्चा -> बचा miss retained
; preludes: form/form-stdlib/core.fk presence/concept-audio-open-10000-13-live.fk

(do
  ; fixture = id, code, voice, situation, sentence.
  (defn cao10rl-fixtures ()
    (list
      (list 629 "en" "Eddy (English (UK))" "black-ice-road-closure"
        "Because black ice covered the street, the road crew closed one lane before the morning commute.")
      (list 296 "id" "Damayanti" "emergency-exit-inspection"
        "Petugas memeriksa pintu darurat sebelum gedung dibuka untuk umum.")
      (list 1102 "es" "Eddy (Spanish (Mexico))" "delayed-public-transit"
        "El autobús llegó veinte minutos tarde por una avería durante la hora punta.")
      (list 370 "fr" "Eddy (French (Canada))" "pharmacy-dosage-review"
        "Le médecin a vérifié la dose avec le pharmacien avant de renouveler le traitement.")
      (list 6600 "pt-br" "Eddy (Portuguese (Brazil))" "kitchen-fire-prevention"
        "Desliguei o fogão e conferi o detector de fumaça antes de sair de casa.")
      (list 150 "sw" "Samantha" "workplace-safety-meeting"
        "Katika mkutano wa kazi, timu ilikagua mpango wa usalama wa ghala.")
      (list 1071 "de" "Eddy (German (Germany))" "storm-road-obstruction"
        "Nach dem Sturm blockierte ein Baum die Landstraße, bis die Feuerwehr eintraf.")
      (list 332 "ru" "Milena" "severe-weather-warning"
        "Я получил предупреждение о сильной грозе на телефон и отменил поездку.")
      (list 571 "zh" "Eddy (Chinese (China mainland))" "school-closure-reading"
        "暴雨停课后，老师通过网络把书和作业发给了学生。")
      (list 916 "ja" "Eddy (Japanese (Japan))" "river-flood-evacuation"
        "大雨で川の岸が浸水したため、住民は高台へ避難しました。")
      (list 377 "ar" "Majed" "emergency-water-distribution"
        "وزعت فرق الطوارئ ماء نظيفًا على الأسر بعد انقطاع الأنابيب.")
      (list 468 "hi" "Lekha" "child-medicine-instructions"
        "नर्स ने बताया कि बच्चा दवा की अगली खुराक भोजन के बाद लेगा।")
      (list 628 "tr" "Yelda" "ambulance-hospital-arrival"
        "Ambulans yaralı bisikletçiyi öğleden önce hastane acil servisine getirdi.")))

  (defn cao10rl-run (index)
    (do (let fixture (nth (cao10rl-fixtures) index))
        (cao10l-situation-run (nth fixture 0) (nth fixture 1)
          (nth fixture 4) (nth fixture 2)
          (str_concat "-open-real-life-" (int_to_str index)))))
  (defn cao10rl-execute (index)
    (do
      (let fixture (nth (cao10rl-fixtures) index))
      (let row (cao10rl-run index))
      (let request (nth row 1))
      (let waveform (nth row 3))
      (let asr (nth row 4))
      (let detection (nth row 5))
      (let result (nth row 7))
      (let pcm (nth waveform 5))
      (print_str (ca13-cat (list
        "fixture=" (int_to_str index)
        " address=" (int_to_str (nth request 1)) ":" (nth request 2)
        " status=" (nth result 1)
        " reason=" (nth result 5)
        " situation=" (nth fixture 3)
        " surface=" (nth request 4)
        " candidates=" (int_to_str (nth detection 5))
        " source=" (nth request 6)
        " pcm-samples=" (int_to_str (nth pcm 0))
        " wav-sha256=" (nth waveform 3)
        " transcript=" (nth asr 5))))
      row))

  ; The shell carrier invokes one row per isolated fkwu process so waveform and
  ; detector evidence stays bounded.  This file itself only defines the organ.
)
