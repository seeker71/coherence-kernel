; concept-video-public-snapshot-live.fk -- 24 public real-photo observations.
;
; A provenance-pinned Wikimedia Commons snapshot supplies 24 real photographs
; from 24 ordinary-world domains. The unchanged Apple Vision carrier receives
; only decoded pixels through numeric local paths. Form scans every raw top-20
; label stream against all 10,000 English anchors, before fixture targets or
; source metadata are consulted. Bottom occlusion and center crop are fresh
; pixel interventions, not replayed labels.
;
; This is content evidence from host-rented weights, not a Form-native learned
; visual encoder and not 10,000-class visual parity.
;
; witnessed: 2026-07-18 -> 24/23/23 distinct targets, one complete 10k
;                            candidate sweep and 72 exact raw-stream filters
; preludes: form/form-stdlib/core.fk cognition/concept-text-detection-13-runtime.fk model/concept-video-open-label.fk

(do
  (defn cvps-dir () "model/fixtures/concept-vision-public-snapshot/")
  (defn cvps-bin () "/tmp/concept-video-public-snapshot-classify")
  (defn cvps-floor () 100000)
  (defn cvps-domains ()
    (list "built-heritage" "museum-object" "road-transport"
      "environmental-action" "mountain-landscape" "cultural-performance"
      "signage" "urban-art" "maritime-wreck" "public-sculpture"
      "ocean-transit" "harbor-infrastructure" "archaeology"
      "insect-wildlife" "urban-high-rise" "recreation" "sound-sculpture"
      "bamboo-forest" "residential-architecture" "civic-access"
      "rural-agriculture" "seascape" "material-decay" "public-landscape"))

  ; fixture = numeric stem, domain, observed target id/label, pinned image hash.
  ; Targets are 24 distinct top-10k cells selected only after raw observations.
  (defn cvps-fixtures ()
    (list
      (list "0001" "built-heritage" 752 "building" "cbaf564e2262d0504d74e79d6e3f70171babfa4107608ebae7217e01791b1f08")
      (list "0002" "museum-object" 8497 "vase" "7b631954e5416207ffa04ec11cbfda75a9c1ce4207a2d4de918c849387ae9d93")
      (list "0003" "road-transport" 248 "car" "3ef7805ba635edc5538f11c6ebee338b2c169e6e76a0e08544d084e9cab0d19d")
      (list "0004" "environmental-action" 2365 "material" "c0fbceccd0d8ccc7ce4aa38ef19ebc0cb955cdedc92dab254dbe1b7de8599260")
      (list "0005" "mountain-landscape" 1595 "mountain" "f97c831bd42c0c6922bdad0e0c3a9370981cb7c01c03e766cd4651990d6e1be2")
      (list "0006" "cultural-performance" 4515 "jewelry" "28f9e0c9ad5492c4ee7ed4afe2300575afdb13409d06187e9f56126ba7dbbf7c")
      (list "0007" "signage" 4598 "document" "fca8af796685f00294263ffeb7d9fa35c4837c9ff8075615277802ace746159e")
      (list "0008" "urban-art" 998 "art" "c89cd335139ae73d3e4c40d5bd3aa52b65e9af6bfdecd835700926b7f071198a")
      (list "0009" "maritime-wreck" 883 "boat" "200f1e71a3a5e24effda276d0aac5e3992139b206ee5d6c41bbc10e55d0aa476")
      (list "0010" "public-sculpture" 4032 "statue" "f204677fdb1b0051ab7fa7b74c10f2d61425883665049d8bc795e514bb5220a0")
      (list "0011" "ocean-transit" 1941 "ocean" "a921f61d993c50ecbeb482c28a8846962fda88bfccc10463039cef8328edfff9")
      (list "0012" "harbor-infrastructure" 5585 "dock" "02e1f82b37cf081c3394317255812313b4f4f4aa9ba92cafa6af662740e73bc6")
      (list "0013" "archaeology" 1520 "bridge" "d5441ec5672c20e811108a832d5a27227a978ea3567c70ed364a76b8898b1509")
      (list "0014" "insect-wildlife" 5547 "butterfly" "03ee45a7e90d61d1ae87f57ee562d0db01f1cda6be3fcb731ba475ace905175f")
      (list "0015" "urban-high-rise" 1020 "apartment" "a16dfc8df067fa6381fe740b9fa19e788ab87d9325e102953f5c96ec21cece5c")
      (list "0016" "recreation" 8249 "playground" "71a65e02bcb948723116019407f6201b60d3e6608cf380dccc848651a3816d69")
      (list "0017" "sound-sculpture" 1215 "bell" "b400f61123181b37c7703008736853a6f60d63954b9050d679401acb34d6ca5e")
      (list "0018" "bamboo-forest" 1874 "forest" "610eaaa6c77a90739eef998fd1ce5b28fd00764466459ad4084bd8a1f7323bb7")
      (list "0019" "residential-architecture" 1795 "roof" "b260eb16cd8795a2a837da729f7adb0e883cf64f0f8cc062501569683c74ccb3")
      (list "0020" "civic-access" 296 "door" "6da564f657a6238645f0f2e0e39730faeb0808755c2f7d977cf66910a02f43c1")
      (list "0021" "rural-agriculture" 4091 "barn" "6d42777e52d44d8c0f36d7c8cd9cfca14a24491f4e3d08fb2083886801b20601")
      (list "0022" "seascape" 377 "water" "a517867b3eaf058f8dbe930c3be5964c881466e3cadcc3924f318071fb18130e")
      (list "0023" "material-decay" 4000 "structure" "0d7cbb1cfd5e466ce29c28ef1167c5933743c30d192bca03fd7499a2afd4b202")
      (list "0024" "public-landscape" 1776 "path" "49c686c08bfa3142a4bf4b55d613417f0ff6f2269e6e6943f293a41f839f4ff9")))

  ; Human-visible source claims are audit probes only. They are consulted after
  ; inference and never count as accepted targets. Six are three-way misses.
  ; claim = numeric stem, concept id, exact English label.
  (defn cvps-claims ()
    (list (list "0001" 5332 "mill") (list "0002" 1329 "bottle")
      (list "0004" 1874 "forest") (list "0006" 3231 "costume")
      (list "0007" 650 "sign") (list "0009" 4534 "wreck")
      (list "0011" 756 "ship") (list "0018" 9860 "bamboo")
      (list "0020" 1763 "access") (list "0023" 2177 "wood")
      (list "0024" 9439 "sculpture")))

  (defn cvps-path (stem) (str_concat (cvps-dir) (str_concat stem ".jpg")))
  (defn cvps-band-path (stem) (str_concat "/tmp/cvps-" (str_concat stem "-band.jpg")))
  (defn cvps-crop-path (stem) (str_concat "/tmp/cvps-" (str_concat stem "-crop.jpg")))
  (defn cvps-compile ()
    (host-exec (str_concat "swiftc -O presence/carriers/concept-video-vision-classify.swift -o "
      (str_concat (cvps-bin) " >/dev/null 2>&1 && printf 1")) ""))
  (defn cvps-classify (path) (host-exec (str_concat (cvps-bin) (str_concat " " path)) ""))
  (defn cvps-hash-valid? (fixture)
    (if (str_eq (host-exec (str_concat "/usr/bin/shasum -a 256 "
          (str_concat (cvps-path (nth fixture 0))
            (str_concat " | grep -q '^" (str_concat (nth fixture 4) "  ' && printf 1")))) "") "1") 1 0))
  (defn cvps-hash-count (fixtures)
    (if (eq (len fixtures) 0) 0
      (add (cvps-hash-valid? (head fixtures)) (cvps-hash-count (tail fixtures)))))
  (defn cvps-transform (fixture)
    (do (let stem (nth fixture 0))
        (let source (cvps-path stem))
        (let band (host-exec (str_concat "ffmpeg -loglevel error -y -i "
          (str_concat source (str_concat " -vf 'drawbox=x=0:y=ih-80:w=iw:h=80:color=magenta:t=fill' -frames:v 1 "
            (str_concat (cvps-band-path stem) " >/dev/null 2>&1 && printf 1")))) ""))
        (let crop (host-exec (str_concat "ffmpeg -loglevel error -y -i "
          (str_concat source (str_concat " -vf 'crop=iw*0.8:ih*0.8:iw*0.1:ih*0.1' -frames:v 1 "
            (str_concat (cvps-crop-path stem) " >/dev/null 2>&1 && printf 1")))) ""))
        (if (and (str_eq band "1") (str_eq crop "1")) 1 0)))
  (defn cvps-transform-count (fixtures)
    (if (eq (len fixtures) 0) 0
      (add (cvps-transform (head fixtures)) (cvps-transform-count (tail fixtures)))))
  (defn cvps-scan (runtime raw)
    (cvol-observations raw (ctd13-runtime-detect-sentence runtime "en" raw) (cvps-floor)))

  ; Raw collection happens before any fixture target is consulted.
  (defn cvps-raw-one (fixture)
    (do (let stem (nth fixture 0))
        (let raw (cvps-classify (cvps-path stem)))
        (let band-raw (cvps-classify (cvps-band-path stem)))
        (let crop-raw (cvps-classify (cvps-crop-path stem)))
        (let id (nth fixture 2))
        (let label (nth fixture 3))
        (list stem (nth fixture 1) id label
          (cvol-confidence raw label) (cvol-confidence band-raw label)
          (cvol-confidence crop-raw label)
          (list raw band-raw crop-raw))))
  (defn cvps-raw-all (fixtures)
    (if (eq (len fixtures) 0) (empty)
      (cons (cvps-raw-one (head fixtures)) (cvps-raw-all (tail fixtures)))))
  (defn cvps-floor-labels-go (raw cursor out)
    (do (let next (str_find raw "\n" cursor))
        (if (lt next 0) out
          (do (let tab (str_find raw "\t" cursor))
              (let confidence (str_to_int (substring raw cursor tab)))
              (let label (substring raw (add tab 1) next))
              (cvps-floor-labels-go raw (add next 1)
                (if (ge confidence (cvps-floor))
                  (do (let needle (str_concat "\n" (str_concat label "\n")))
                      (if (lt (str_find (str_concat "\n" out) needle 0) 0)
                        (str_concat out (str_concat label "\n")) out)) out))))))
  (defn cvps-floor-labels-in (raw out)
    ; Raw top-20 stays retained on each row. Only observations eligible for the
    ; explicit visual floor enter candidate discovery. This parser consumes
    ; carrier bytes in Form and never sees fixture metadata.
    (cvps-floor-labels-go raw 0 out))
  (defn cvps-raw-corpus-go (raw-rows out)
    (if (eq (len raw-rows) 0) out
      (do (let raw (nth (head raw-rows) 7))
          (let with-original (cvps-floor-labels-in (nth raw 0) out))
          (let with-band (cvps-floor-labels-in (nth raw 1) with-original))
          (let with-crop (cvps-floor-labels-in (nth raw 2) with-band))
          (cvps-raw-corpus-go (tail raw-rows) with-crop))))
  (defn cvps-raw-corpus (raw-rows) (cvps-raw-corpus-go raw-rows ""))

  ; Candidate discovery is one complete 10k sweep across the union of exact
  ; raw label streams. cvol-observations then rechecks exact label/confidence
  ; against each of the 72 streams, so a label from another image cannot leak.
  ; row = stem, domain, target id/label, three confidences, three accepted
  ; candidate sets, three target states, and exact three raw top-20 streams.
  (defn cvps-observe-one (raw-row candidates)
    (do (let raw (nth raw-row 7))
        (let original (cvol-observations (nth raw 0) candidates (cvps-floor)))
        (let band (cvol-observations (nth raw 1) candidates (cvps-floor)))
        (let crop (cvol-observations (nth raw 2) candidates (cvps-floor)))
        (let id (nth raw-row 2))
        (list (nth raw-row 0) (nth raw-row 1) id (nth raw-row 3)
          (nth raw-row 4) (nth raw-row 5) (nth raw-row 6)
          original band crop
          (list (cvol-target-present? original id) (cvol-target-present? band id)
            (cvol-target-present? crop id)) raw)))
  (defn cvps-observe-all (raw-rows candidates)
    (if (eq (len raw-rows) 0) (empty)
      (cons (cvps-observe-one (head raw-rows) candidates)
        (cvps-observe-all (tail raw-rows) candidates))))
  (defn cvps-state-count (rows variant)
    (if (eq (len rows) 0) 0
      (add (nth (nth (head rows) 10) variant) (cvps-state-count (tail rows) variant))))
  (defn cvps-row-by-stem (rows stem)
    (if (eq (len rows) 0) (empty)
      (if (str_eq (nth (head rows) 0) stem) (head rows)
        (cvps-row-by-stem (tail rows) stem))))
  (defn cvps-claim-states (rows claim)
    (do (let row (cvps-row-by-stem rows (nth claim 0)))
        (let raw (nth row 11))
        (list (if (ge (cvol-confidence (nth raw 0) (nth claim 2)) (cvps-floor)) 1 0)
          (if (ge (cvol-confidence (nth raw 1) (nth claim 2)) (cvps-floor)) 1 0)
          (if (ge (cvol-confidence (nth raw 2) (nth claim 2)) (cvps-floor)) 1 0))))
  (defn cvps-hard-negative-count (rows claims)
    (if (eq (len claims) 0) 0
      (do (let states (cvps-claim-states rows (head claims)))
          (add (if (and (eq (nth states 0) 0)
                     (and (eq (nth states 1) 0) (eq (nth states 2) 0))) 1 0)
            (cvps-hard-negative-count rows (tail claims))))))
  (defn cvps-public-row (row)
    (list (nth row 0) (nth row 1) (list "target" (nth row 2) (nth row 3))
      (list "confidence-ppm" (nth row 4) (nth row 5) (nth row 6))
      (list "states" (nth row 10))
      (list "complete-10k-candidates" (nth row 7) (nth row 8) (nth row 9))
      (list "raw-top20" (nth row 11))))
  (defn cvps-public-rows (rows)
    (if (eq (len rows) 0) (empty)
      (cons (cvps-public-row (head rows)) (cvps-public-rows (tail rows)))))

  ; Lightweight requirement-ledger view. Pass an already observed live result
  ; to avoid reclassifying. This admits content counts only; fixture addresses,
  ; source captions, and the 50-row acquisition pool never increase them.
  (defn cvps-audit-summary-from-live (live)
    (do (let snapshot (nth live 2))
        (let targets (nth live 3))
        (let claims (nth live 4))
        (list "concept-video-public-snapshot-audit"
          (list "real-public-photos" (nth snapshot 1)
            "verified-hashes" (nth snapshot 3) "domains" (nth snapshot 7))
          (list "semantic-content-targets" (nth targets 1)
            "original" (nth targets 3) "occlusion" (nth targets 5)
            "crop" (nth targets 7) "complete-10k-sweeps" (nth targets 9)
            "raw-stream-filters" (nth targets 11) "candidate-bank" (nth targets 13))
          (list "claims" (nth claims 1) "three-way-hard-negatives" (nth claims 3))
          (list "held-out-accuracy" 0 "post-sweep-content-admission" 1
            "native-visual-weights" 0))))
  (defn concept-video-public-snapshot-audit ()
    (cvps-audit-summary-from-live (concept-video-public-snapshot-live-run)))

  (defn concept-video-public-snapshot-live-run ()
    (do (let ready (if (str_eq (host-exec
          "command -v swiftc >/dev/null && command -v ffmpeg >/dev/null && test -x /usr/bin/shasum && printf 1" "") "1") 1 0))
        (let compiled (if (eq ready 1) (if (str_eq (cvps-compile) "1") 1 0) 0))
        (let fixtures (cvps-fixtures))
        (let hashes (if (eq compiled 1) (cvps-hash-count fixtures) 0))
        (let transformed (if (eq hashes 24) (cvps-transform-count fixtures) 0))
        (let runtime (ctd13-runtime-open))
        (let raw-rows (if (eq transformed 24) (cvps-raw-all fixtures) (empty)))
        (let candidates (if (eq (len raw-rows) 24)
          (ctd13-runtime-detect-sentence runtime "en" (cvps-raw-corpus raw-rows)) (empty)))
        (let rows (cvps-observe-all raw-rows candidates))
        (list "concept-video-public-snapshot-live"
          (list "carrier" ready compiled "Apple-Vision-top20-content-only"
            "weights" "host-rented-unavailable-for-hash")
          (list "public-snapshot" (len rows) "verified-hashes" hashes
            "fresh-interventions" transformed "domains" (len (cvps-domains)))
          (list "distinct-targets" (len rows)
            "original" (cvps-state-count rows 0)
            "bottom-occlusion" (cvps-state-count rows 1)
            "center-crop" (cvps-state-count rows 2)
            "complete-10k-candidate-sweeps" (if (eq (len raw-rows) 24) 1 0)
            "exact-raw-stream-filters" (mul (len rows) 3)
            "candidate-bank" (len candidates))
          (list "audit-claims" (len (cvps-claims))
            "three-way-hard-negatives" (cvps-hard-negative-count rows (cvps-claims)))
          (list "observations" (cvps-public-rows rows))
          (list "boundaries" "metadata-never-entered-inference"
            "numeric-local-paths-only" "no-caption-or-address-band"
            "no-boxes-masks-tracks-or-native-visual-weights"))))

  (concept-video-public-snapshot-live-run))
