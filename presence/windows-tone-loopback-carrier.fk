; windows-tone-loopback-carrier.fk — the Windows cell's live speech-loopback carrier: the body
; renders a 440Hz burst through its own speakers and hears itself through its own mic
; ((sense_audio_loopback ms), op 236 — integers only, nothing retained), then lowers the
; measured envelope through the carrier-receipt law.
;
; The honest boundary, carried in the shape: no STT oracle exists on this cell yet, so the
; capability row says oracle=0 — by law slr-ready? fails, the receipt carries effective-fail,
; the window routes "oracle", and the row becomes control debt, never native credit
; (receipts/2026-06-30-speech-loopback-carrier-run.md named exactly this). What the tone CAN
; honestly witness: render+capture on real metal, acoustic discrimination (burst vs silence
; envelope through asr-prompt-id's closed set, GATED on audio evidence so a muted capture is
; never "confidently silence"), and the lowering law running end to end on live integers.
;
; preludes (cat in this order): form/form-stdlib/hati-os-targets.fk,
;   form/form-stdlib/host-os-membrane.fk, observe/stt-wer.fk, observe/asr-prompt-id.fk,
;   learn/speech-loopback-promotion.fk, presence/speech-loopback-carrier-receipt.fk,
;   presence/speech-loopback-carrier-run.fk, this file.
;
; Verdict bits (255 with audible speakers; 199 with muted speakers — both HONEST):
;   1   the membrane says this platform is ready for the loopback door
;   2   the door returned the full 20-integer measurement row
;   4   real samples were captured
;   8   the burst is acoustically present (score >= 3)
;   16  the closed-set read heard "burst" (gated on audio evidence)
;   32  audio-evidence and the receipt's audio-hash agree (present iff heard)
;   64  the window routes "oracle" — the no-oracle law holds, no native credit stolen
;   128 the unready row carries its debt (effective-fail marks it; nothing claims clean)
(do
    (defn wtl-bit (cond bit) (if cond bit 0))
    (defn wtl-rev (xs acc)
        (if (eq (len xs) 0) acc (wtl-rev (tail xs) (cons (head xs) acc))))
    ; collapse the door's 16 window energies to 8 (pid feature vectors are fixed-length)
    (defn wtl-pair8 (ws)
        (if (lt (len ws) 2) (empty)
            (cons (div (add (head ws) (head (tail ws))) 2) (wtl-pair8 (tail (tail ws))))))
    (defn wtl-max (xs m)
        (if (eq (len xs) 0) m (wtl-max (tail xs) (if (gt (head xs) m) (head xs) m))))
    (defn wtl-norm (xs half acc)
        (if (eq (len xs) 0) (wtl-rev acc (empty))
            (wtl-norm (tail xs) half (cons (if (gt (head xs) half) 100 0) acc))))
    (defn wtl-candidates ()
        (cons (pid-candidate 1 (list "burst") (list 0 0 100 100 100 100 0 0))
            (cons (pid-candidate 2 (list "silence") (list 0 0 0 0 0 0 0 0)) (empty))))

    (defn windows-tone-loopback (ms)
        (do
            (let r (sense_audio_loopback ms))
            (if (lt (len r) 20) 0
                (do
                    (let got (nth r 0))
                    (let silen (nth r 1))
                    (let burst (nth r 2))
                    (let score (nth r 3))
                    (let w8 (wtl-pair8 (tail (tail (tail (tail r))))))
                    (let evidence (gt burst 0))
                    (let q (wtl-norm w8 (div (wtl-max w8 0) 2) (empty)))
                    (let picked (if evidence (pid-native-transcript q (wtl-candidates)) (empty)))
                    (let conf (if evidence (if (pid-confident? q (wtl-candidates) 100 50) 95 0) 0))
                    (let cap (slr-capability "windows-amd64" 1 1 0 1 16000 1 1))
                    (let ahash (if evidence (add burst (add silen got)) 0))
                    (let rc (slc-receipt 1 1 0 ahash 16000 1 1 0 (list "burst") (empty)
                                picked conf 0 (slr-effective-fail cap 0) 0 0))
                    (let route (slr-window-route cap (list rc rc rc rc) 10 80 100 4 0 0 3))
                    (add (wtl-bit (eq (slr-platform-ready? cap) 1) 1)
                    (add (wtl-bit (eq (len r) 20) 2)
                    (add (wtl-bit (gt got 0) 4)
                    (add (wtl-bit (ge score 3) 8)
                    (add (wtl-bit (if evidence (str_eq (head picked) "burst") 0) 16)
                    (add (wtl-bit (eq (slc-audio-present? rc) (if evidence 1 0)) 32)
                    (add (wtl-bit (str_eq route "oracle") 64)
                         (wtl-bit (eq (slc-control-clean? rc) 0) 128))))))))))))
    0)
