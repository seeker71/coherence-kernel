; macos-en-it-speech-roundtrip-variant.fk -- fifth live macOS Metal pair.
;
; Load after presence/macos-speech-roundtrip-carrier.fk. This keeps the carrier
; mechanics in one file and overrides only the locale pair, prompt rows, and
; voices. The run still uses local say -> ffmpeg -> whisper.cpp -> Form wav
; feature learning; no script and no C-seed growth.
;
; This anchor was witnessed with ASCII Italian prompt text; the shared WER token
; lane now also preserves accented Latin and non-Latin transcript evidence.

(do
    (defn masr-b () "it")

    (defn masr-board ()
        (masr-prompt "hatiSuci-board-empty" 201 101
                     "The sun shines."
                     "Il sole brilla."))
    (defn masr-enter ()
        (masr-prompt "hatiSuci-reg-enter" 202 102
                     "The river runs."
                     "Il fiume scorre."))
    (defn masr-gather ()
        (masr-prompt "hatiSuci-gather-ask" 203 103
                     "Thank you friend."
                     "Grazie amico."))

    (defn masr-train-voice (locale)
        (if (str_eq locale "en") "Samantha" "Alice"))
    (defn masr-eval-voice (locale)
        (if (str_eq locale "en") "Eddy (English (US))" "Eddy (Italian (Italy))"))

    0)
