; concept-real-life-workflows-13-live.fk -- Form generates one thirteen-row
; workflow batch per PL, writes it to /tmp, recovers it exactly, executes each
; of the twelve permitted non-Python carriers, and compares all 156 outputs.
; Python remains generated/recovered only by explicit user policy.
; witnessed: 2026-07-18 -> live band 511; 156/156 target outputs exact
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-real-life-workflows-13.fk presence/concept-real-life-workflows-13-generation.fk
(do
  (defn crl13x-root () "/tmp/coherence-crl13")
  (defn crl13x-toolchain-root () "/tmp/coherence-cp10-toolchains")
  (defn crl13x-java-home ()
    (str_concat (crl13x-toolchain-root) "/jdk/Contents/Home"))
  (defn crl13x-java-command (name)
    (cp13-cat (list (crl13x-java-home) "/bin/" name)))
  (defn crl13x-kotlinc-command ()
    (str_concat (crl13x-toolchain-root) "/kotlin/kotlinc/bin/kotlinc"))
  (defn crl13x-languages ()
    (list "javascript" "typescript" "java" "c" "cpp" "csharp" "go"
          "rust" "ruby" "php" "swift" "kotlin"))
  (defn crl13x-extension (language)
    (if (str_eq language "javascript") "js"
    (if (str_eq language "typescript") "ts"
    (if (str_eq language "java") "java"
    (if (str_eq language "c") "c"
    (if (str_eq language "cpp") "cpp"
    (if (str_eq language "csharp") "cs"
    (if (str_eq language "go") "go"
    (if (str_eq language "rust") "rs"
    (if (str_eq language "ruby") "rb"
    (if (str_eq language "php") "php"
    (if (str_eq language "swift") "swift"
    (if (str_eq language "kotlin") "kt" "txt"))))))))))))
  (defn crl13x-source-path (language)
    (if (str_eq language "java")
      (str_concat (crl13x-root) "/java/ConceptWorkflows.java")
      (if (str_eq language "csharp")
        (str_concat (crl13x-root) "/csharp/Program.cs")
        (cp13-cat (list (crl13x-root) "/workflows." (crl13x-extension language))))))
  (defn crl13x-binary-path (language)
    (cp13-cat (list (crl13x-root) "/workflows-" language)))
  (defn crl13x-required-command (language)
    (if (str_eq language "javascript") "node"
    (if (str_eq language "typescript") "npx"
    (if (str_eq language "java") (crl13x-java-command "javac")
    (if (str_eq language "c") "clang"
    (if (str_eq language "cpp") "clang++"
    (if (str_eq language "csharp") "dotnet"
    (if (str_eq language "go") "go"
    (if (str_eq language "rust") "rustc"
    (if (str_eq language "ruby") "ruby"
    (if (str_eq language "php") "php"
    (if (str_eq language "swift") "swiftc"
    (if (str_eq language "kotlin") (crl13x-kotlinc-command) "missing"))))))))))))
  (defn crl13x-available? (language)
    (str_eq (host-exec (cp13-cat (list "command -v "
      (crl13x-required-command language) " >/dev/null 2>&1 && printf 1 || printf 0")) "") "1"))
  (defn crl13x-command (language source)
    (do (let binary (crl13x-binary-path language))
      (if (str_eq language "javascript") (str_concat "node " source)
      (if (str_eq language "typescript") (str_concat "npx --yes tsx " source)
      (if (str_eq language "java")
        (cp13-cat (list (crl13x-java-command "javac") " -d " (crl13x-root)
          "/java " source " && " (crl13x-java-command "java") " -cp "
          (crl13x-root) "/java ConceptWorkflows"))
      (if (str_eq language "c")
        (cp13-cat (list "clang -std=c11 " source " -o " binary " && " binary))
      (if (str_eq language "cpp")
        (cp13-cat (list "clang++ -std=c++17 " source " -o " binary " && " binary))
      (if (str_eq language "csharp")
        "dotnet run --project /tmp/coherence-crl13/csharp/Workflows.csproj --configuration Release --nologo --verbosity quiet"
      (if (str_eq language "go") (str_concat "go run " source)
      (if (str_eq language "rust")
        (cp13-cat (list "rustc -O " source " -o " binary " && " binary))
      (if (str_eq language "ruby") (str_concat "ruby " source)
      (if (str_eq language "php") (str_concat "php " source)
      (if (str_eq language "swift")
        (cp13-cat (list "swiftc " source " -o " binary " && " binary))
      (if (str_eq language "kotlin")
        (cp13-cat (list "JAVA_HOME=" (crl13x-java-home) " PATH="
          (crl13x-java-home) "/bin:/usr/bin:/bin " (crl13x-kotlinc-command) " "
          source " -include-runtime -d " binary ".jar && "
          (crl13x-java-command "java") " -jar " binary ".jar")) ""))))))))))))))
  (defn crl13x-trim-lf (text)
    (if (eq (str_len text) 0) text
      (if (or (eq (str_byte_at text (sub (str_len text) 1)) 10)
              (eq (str_byte_at text (sub (str_len text) 1)) 13))
        (crl13x-trim-lf (substring text 0 (sub (str_len text) 1))) text)))
  (defn crl13x-count-byte-go (text byte i count)
    (if (eq i (str_len text)) count
      (crl13x-count-byte-go text byte (add i 1)
        (add count (if (eq (str_byte_at text i) byte) 1 0)))))
  (defn crl13x-line-count (text)
    (if (eq (str_len text) 0) 0
      (add 1 (crl13x-count-byte-go text 10 0 0))))
  (defn crl13x-prepare ()
    (do (host-exec "mkdir -p /tmp/coherence-crl13/csharp /tmp/coherence-crl13/java" "")
        (write_file "/tmp/coherence-crl13/csharp/Workflows.csproj"
          "<Project Sdk=\"Microsoft.NET.Sdk\"><PropertyGroup><OutputType>Exe</OutputType><TargetFramework>net9.0</TargetFramework><ImplicitUsings>enable</ImplicitUsings></PropertyGroup></Project>")))
  ; row=(language available wrote recovered output-lines exact actual hash)
  (defn crl13x-run-one (language)
    (do (let available (if (crl13x-available? language) 1 0))
        (if (eq available 0) (list language 0 0 0 0 0 "" 0)
          (do (let source (crl13-generate language))
              (let path (crl13x-source-path language))
              (let wrote (write_file path source))
              (let recovered (crl13-recover source))
              (let expected (crl13x-trim-lf (crl13-expected-lines)))
              (let actual (crl13x-trim-lf
                (host-exec (crl13x-command language path) "")))
              (let lines (crl13x-line-count actual))
              (let exact (if (and (gt wrote 0)
                (and (eq (len recovered) 3) (str_eq actual expected))) 1 0))
              (list language 1 wrote (if (eq (len recovered) 3) 1 0)
                lines exact actual (cp10-hash-text actual))))))
  ; totals=(languages available written recovered outputs exact hash rows)
  (defn crl13x-run-go (languages totals)
    (if (eq (len languages) 0) totals
      (do (let row (crl13x-run-one (head languages)))
          (crl13x-run-go (tail languages)
            (list (add (nth totals 0) 1)
              (add (nth totals 1) (nth row 1))
              (add (nth totals 2) (if (gt (nth row 2) 0) 1 0))
              (add (nth totals 3) (nth row 3))
              (add (nth totals 4) (nth row 4))
              (add (nth totals 5) (nth row 5))
              (mod (add (mul (nth totals 6) 131) (nth row 7)) 1000000007)
              (cons row (nth totals 7)))))))
  (defn crl13x-run ()
    (do (crl13x-prepare)
        (crl13x-run-go (crl13x-languages) (list 0 0 0 0 0 0 0 (empty)))))
)
