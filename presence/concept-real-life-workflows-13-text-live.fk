; concept-real-life-workflows-13-text-live.fk -- each operational workflow is
; grounded by a real sentence, complete same-surface candidates, provenance,
; and its full pinned WordNet 3.1 sense set before any program is generated.
; witnessed: 2026-07-18 -> live band 1023; 13/13 targets, 74 senses
; preludes: form/form-stdlib/core.fk cognition/concept-text-detection-13-runtime.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-real-life-workflows-13.fk
(do
  (defn crl13t-find-id (candidates id)
    (if (eq (len candidates) 0) (empty)
      (if (eq (ctd13-candidate-id (head candidates)) id) (head candidates)
        (crl13t-find-id (tail candidates) id))))
  ; evidence=(id label sentence occurrence all-candidates target full-senses
  ;           context-analysis source-code)
  (defn crl13t-observe-one (runtime w)
    (do (let result (ctd13-runtime-detect-surface-in-sentence runtime "en"
          (crl13-label w) (crl13-sentence w)))
        (let candidates (nth result 4))
        (let target (crl13t-find-id candidates (crl13-id w)))
        (let senses (ctd13-runtime-senses runtime (crl13-id w)))
        (let analysis (ctd13-runtime-analyze-senses runtime
          (crl13-id w) (crl13-sentence w)))
        (list (crl13-id w) (crl13-label w) (crl13-sentence w) (nth result 3)
          candidates target senses analysis
          (if (eq (len target) 0) "0" (ctd13-candidate-source-code target)))))
  (defn crl13t-observe-go (runtime ws out)
    (if (eq (len ws) 0) (reverse out)
      (crl13t-observe-go runtime (tail ws)
        (cons (crl13t-observe-one runtime (head ws)) out))))
  (defn crl13t-observe (runtime)
    (crl13t-observe-go runtime (crl13-workflows) (empty)))
  (defn crl13t-evidence-row? (row)
    (and (eq (nth row 3) 1)
      (and (gt (len (nth row 4)) 0)
        (and (not (eq (len (nth row 5)) 0))
          (and (gt (len (nth row 6)) 0)
            (and (eq (len (nth row 6)) (nth (nth row 7) 1))
              (and (not (str_eq (nth row 8) "0"))
                   (not (str_eq (nth (nth row 7) 0) "no-senses"))))))))
  ; audit=(workflows occurred targets-with-senses candidates total-senses
  ;        sourced context-ranked full-sentence-candidates evidence)
  (defn crl13t-audit-go (rows totals)
    (if (eq (len rows) 0) totals
      (do (let row (head rows))
          (let analysis (nth row 7))
          (crl13t-audit-go (tail rows)
            (list (add (nth totals 0) 1)
              (add (nth totals 1) (nth row 3))
              (add (nth totals 2) (if (and (not (eq (len (nth row 5)) 0))
                                         (gt (len (nth row 6)) 0)) 1 0))
              (add (nth totals 3) (len (nth row 4)))
              (add (nth totals 4) (len (nth row 6)))
              (add (nth totals 5) (if (str_eq (nth row 8) "0") 0 1))
              (add (nth totals 6) (if (str_eq (nth analysis 0)
                "context-ranked-not-resolved") 1 0))
              (nth totals 7)
              (add (nth totals 8) (if (crl13t-evidence-row? row) 1 0)))))))
  (defn crl13t-audit (runtime)
    (do (let rows (crl13t-observe runtime))
        (let full (ctd13-runtime-detect-sentence runtime "en"
          (crl13-sentence (head (crl13-workflows)))))
        (let totals (crl13t-audit-go rows (list 0 0 0 0 0 0 0 0 0)))
        (list (nth totals 0) (nth totals 1) (nth totals 2) (nth totals 3)
          (nth totals 4) (nth totals 5) (nth totals 6) (len full)
          (nth totals 8) rows full)))
)
