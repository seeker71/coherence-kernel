; concept-lenses-26-live.fk -- one real corpus concept through 13 NL + 13 PL.
;
; This is the first joined door over the ranked 10,000-anchor substrate. It
; detects "water" in the pinned corpus, generates and re-detects thirteen
; bounded natural-language frames, generates and re-detects thirteen bounded
; programming-language functions, and carries the same concept/lens address
; into the audio/video signal codec.
;
; It is not yet the 10,000 x 13 x 13 completion: arbitrary identifier escaping,
; general translation, speech, semantic image synthesis, and learned held-out
; detection remain open and are named in the receipts.
;
; witnessed: 2026-07-18 -> water id 377 crosses all 26 bounded text lenses
; preludes: form/form-stdlib/core.fk model/concept-10000-data.fk model/concept-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/pl-lenses-13.fk model/concept-multimodal-codec.fk

(do
  (defn cl26-nl-go (rows concept index out)
    (if (eq (len rows) 0) (reverse out)
      (do (let row (head rows))
          (let surface (nl13-generate (nl13-code row) 4
                         (c10-concept-label concept)))
          (cl26-nl-go (tail rows) concept (add index 1)
            (cons
              (list index (nl13-code row) surface (nl13-detect-generated-runtime surface)
                    (cmm-code (c10-concept-id concept) index)
                    (cmm-audio-frequencies (c10-concept-id concept) index))
              out)))))
  (defn cl26-nl (concept) (cl26-nl-go (nl13-data) concept 0 (empty)))

  (defn cl26-pl-go (rows concept index out)
    (if (eq (len rows) 0) (reverse out)
      (do (let row (head rows))
          (let id (pl13-id row))
          (let spec (pl13-binary-spec
                       (str_concat (c10-concept-label concept) "_balance")
                       "input" "reserve" "sub"))
          (let surface (pl13-generate-detectable id spec))
          (cl26-pl-go (tail rows) concept (add index 1)
            (cons
              (list index id surface (pl13-detect surface)
                    (cmm-code (c10-concept-id concept) index)
                    (str_len (cmm-video-filter (c10-concept-id concept) index)))
              out)))))
  (defn cl26-pl (concept) (cl26-pl-go (pl13-registry) concept 0 (empty)))

  (defn cl26-detected-all? (rows code-slot detected-slot)
    (if (eq (len rows) 0) 1
      (if (str_eq (nth (head rows) code-slot) (nth (head rows) detected-slot))
        (cl26-detected-all? (tail rows) code-slot detected-slot) 0)))
  (defn cl26-addressed-all? (rows)
    (if (eq (len rows) 0) 1
      (if (and (eq (cmm-code-concept (nth (head rows) 4)) 377)
               (eq (cmm-code-lens (nth (head rows) 4)) (nth (head rows) 0)))
        (cl26-addressed-all? (tail rows)) 0)))
  (defn cl26-score-bit (ok bit) (if ok bit 0))

  (defn concept-lenses-26-live-run ()
    (do (let concept (c10-detect-text "water"))
        (let nl (cl26-nl concept))
        (let pl (cl26-pl concept))
        (let score
          (add
            (cl26-score-bit (and (eq (c10-concept-id concept) 377)
                                 (str_eq (c10-concept-label concept) "water")) 1)
            (add
              (cl26-score-bit (eq (len nl) 13) 2)
              (add
                (cl26-score-bit (eq (cl26-detected-all? nl 1 3) 1) 4)
                (add
                  (cl26-score-bit (eq (cl26-addressed-all? nl) 1) 8)
                  (add
                    (cl26-score-bit (eq (len pl) 13) 16)
                    (add
                      (cl26-score-bit (eq (cl26-detected-all? pl 1 3) 1) 32)
                      (cl26-score-bit (eq (cl26-addressed-all? pl) 1) 64))))))))
        (list "concept-lenses-26-live"
              (list "concept" (c10-concept-id concept)
                    (c10-concept-label concept) (c10-concept-rank concept)
                    (c10-concept-frequency concept))
              (list "natural-language" nl)
              (list "programming-language" pl)
              (list "coverage-now" 10000 13 13
                    "represented-addresses" 130000
                    "joined-live-concept-lenses" 26
                    "full-matrix-parity" 0)
              score)))

  (concept-lenses-26-live-run))
