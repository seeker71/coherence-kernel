; Operational observation entrypoint for the substantive repair organ.
; This is deliberately outside tests: it exercises canonical English input,
; legacy alias compatibility, Indonesian generation, and Japanese detection.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000-substantive-repair-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk model/concept-semantics-10000-wiktionary-lexical.fk cognition/concept-10000-substantive-repair-111-nl-data.fk cognition/concept-10000-substantive-repair-111-nl.fk presence/concept-substantive-repair-111-live.fk
(do
  (let runtime (csr111-live-open))
  (let canonical (csr111-live-resolve runtime "welcoming" "id"))
  (let legacy (csr111-live-resolve runtime "didn" "id"))
  (let japanese (csr111-live-resolve runtime "plum" "ja"))
  (let detected (csr111-live-detect-nl runtime "id" (nth canonical 8)))
  (list canonical legacy japanese detected))
