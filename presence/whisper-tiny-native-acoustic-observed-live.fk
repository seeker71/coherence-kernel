; whisper-tiny-native-acoustic-observed-live.fk -- trace before claim.
;
; This is the first observation door for the expensive Whisper-tiny acoustic
; path.  It runs the exact committed human recording through the existing
; released encoder, complete decoder, 51,865-row tied-vocabulary scan, and
; world-admission gate.  Form places source-attributed stage nodes around each
; boundary, reads them back from fkwu's framebuffer, and carries whole-window
; clock/allocation/I/O counters into the kernel world model.
;
; There is no automatic per-function source trace on fkwu yet.  These are
; explicit boundary events plus exact kernel counter deltas, not a claim that
; every numeric list operation emitted a framebuffer node.  The source WAV is
; real CC0 human speech; the current native recognizer still has no generated
; text, so the world gate honestly refuses content admission.
;
; witnessed: 2026-07-20 -> live data emitted by
; presence/tests/whisper-tiny-native-acoustic-observed-live-band.fk
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk form/form-stdlib/transformer-decoder.fk model/whisper-tiny-native-conv1.fk model/whisper-tiny-native-conv2.fk model/whisper-tiny-native-encoder0.fk model/whisper-tiny-native-encoder.fk model/whisper-tiny-native-decoder0.fk model/whisper-tiny-native-decoder.fk model/whisper-tiny-native-vocabulary.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk cognition/concept-text-detection-13-runtime.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/concept-audio-asr-13.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk presence/whisper-tiny-native-acoustic-live.fk observe/framebuffer-runtime-observation.fk observe/framebuffer-runtime-world.fk

(do
  (defn wtaol-path ()
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav")
  (defn wtaol-stage (stage parent started ended metric value outcome line)
    (fbro-stage "whisper-tiny-human-acoustic" stage parent "Sema"
      "senses-human-speech" "understand-what-where-why"
      "user-requested-native-acoustic-evidence" started ended metric value
      outcome "presence/whisper-tiny-native-acoustic-observed-live.fk" line 7))

  (defn whisper-tiny-native-acoustic-observed-live-run ()
    (do
      (let path (wtaol-path))
      (let window (fbro-open "whisper-tiny-human-acoustic" "Sema"
        "senses-human-speech" "understand-what-where-why"
        "user-requested-native-acoustic-evidence" (wtal-source-byte-count)
        "presence/whisper-tiny-native-acoustic-observed-live.fk" 32 7))

      (let source-start (now_unix_ms))
      (let source-valid (wtal-source-valid? path))
      (let source-end (now_unix_ms))
      (let source-event (wtaol-stage "source-verified" "trace-begin"
        source-start source-end "wav-bytes" (wtal-source-byte-count)
        (if (eq source-valid 1) "verified-human-cc0" "rejected") 40))

      (let encoder-start (now_unix_ms))
      (let acoustic (if (eq source-valid 1) (wte-infer-file path) (empty)))
      (let encoder-end (now_unix_ms))
      (let encoder-event (wtaol-stage "encoder-complete" "source-verified"
        encoder-start encoder-end "causal-parameters"
        (if (eq (len acoustic) 28) (nth acoustic 15) 0)
        (if (and (eq (len acoustic) 28) (eq (nth acoustic 22) 1))
          "complete" "held") 47))

      (let decoder-start (now_unix_ms))
      (let decoder (if (eq (len acoustic) 28)
        (wtd-infer-encoder path (nth acoustic 27)) (empty)))
      (let decoder-end (now_unix_ms))
      (let decoder-event (wtaol-stage "decoder-complete" "encoder-complete"
        decoder-start decoder-end "causal-parameters"
        (if (eq (len decoder) 28) (nth decoder 11) 0)
        (if (and (eq (len decoder) 28) (eq (nth decoder 22) 1))
          "complete" "held") 57))

      (let final-state (if (and (eq (len decoder) 28)
            (eq (len (nth decoder 27)) 4))
        (nth (nth decoder 27) 3) (empty)))
      (let vocabulary-start (now_unix_ms))
      (let vocabulary (if (eq (len final-state) 384)
        (wtv-scan final-state) (list -1 0.0 -1 0.0 0)))
      (let vocabulary-end (now_unix_ms))
      (let vocabulary-event (wtaol-stage "vocabulary-scanned" "decoder-complete"
        vocabulary-start vocabulary-end "rows" (nth vocabulary 4)
        (if (eq (nth vocabulary 4) 51865) "complete" "held") 70))

      ; No filename-derived or host-decoded text is admitted.  Until native
      ; generation yields decoded content, the same production gate refuses.
      (let world-start (now_unix_ms))
      (let world-gate (wtal-world-admit (empty) acoustic))
      (let world-end (now_unix_ms))
      (let world-event (wtaol-stage "world-gate" "vocabulary-scanned"
        world-start world-end "admitted" (nth world-gate 1)
        (if (eq (nth world-gate 1) 1) "admitted" "held-no-native-text") 79))

      (let report (fbro-close window
        (if (and (eq source-valid 1)
              (and (eq (len acoustic) 28)
                (and (eq (len decoder) 28) (eq (nth vocabulary 4) 51865))))
          "native-stages-complete-world-held-no-generated-text" "held")
        5 "presence/whisper-tiny-native-acoustic-observed-live.fk" 83 7))
      (list "whisper-tiny-native-acoustic-observed-live"
        (list "source" path "valid" source-valid "bytes" (wtal-source-byte-count))
        (list "encoder" "causal-parameters"
          (if (eq (len acoustic) 28) (nth acoustic 15) 0)
          "complete" (if (eq (len acoustic) 28) (nth acoustic 22) 0))
        (list "decoder" "causal-parameters"
          (if (eq (len decoder) 28) (nth decoder 11) 0)
          "complete" (if (eq (len decoder) 28) (nth decoder 22) 0))
        (list "vocabulary" "rows" (nth vocabulary 4)
          "best-token" (nth vocabulary 0) "margin" (wtv-margin vocabulary))
        (list "content-world-gate" world-gate)
        report
        (fbrw-world-update report))))

  (defn wtaol-stage-duration (report event-index)
    (nth (nth (nth (fbro-events report) event-index) 3) 10))
  (defn wtaol-execute ()
    (do
      (let run (whisper-tiny-native-acoustic-observed-live-run))
      (let report (nth run 6))
      (let resources (fbro-resources report))
      (let where (fbro-where report))
      (print_str (ca13-cat (list
        "framebuffer-runtime-observation trace=whisper-tiny-human-acoustic"
        " start=" (int_to_str (nth (fbro-when report) 1))
        " duration-ms=" (int_to_str (nth (fbro-when report) 5))
        " source-ms=" (int_to_str (wtaol-stage-duration report 1))
        " encoder-ms=" (int_to_str (wtaol-stage-duration report 2))
        " decoder-ms=" (int_to_str (wtaol-stage-duration report 3))
        " vocabulary-ms=" (int_to_str (wtaol-stage-duration report 4))
        " world-ms=" (int_to_str (wtaol-stage-duration report 5))
        " dispatches=" (int_to_str (fbrw-resource-number resources "dispatches" 0))
        " nodes=" (int_to_str (fbrw-resource-number resources "interned-nodes" 0))
        " strings=" (int_to_str (fbrw-resource-number resources "string-pool" 0))
        " arena-cons=" (int_to_str (fbrw-resource-number resources "arena-cons" 0))
        " boxed-floats=" (int_to_str (fbrw-resource-number resources "boxed-floats" 0))
        " io-sense-dispatches=" (int_to_str (fbrw-resource-number resources "io-sense-dispatches" 0))
        " input-bytes=" (int_to_str (fbrw-resource-number resources "input-bytes" 0))
        " events=" (int_to_str (len (fbro-events report)))
        " source-start=" (nth (nth where 1) 0) ":"
          (int_to_str (nth (nth where 1) 1)) ":"
          (int_to_str (nth (nth where 1) 2))
        " source-end=" (nth (nth where 2) 0) ":"
          (int_to_str (nth (nth where 2) 1)) ":"
          (int_to_str (nth (nth where 2) 2))
        " encoder-parameters=" (int_to_str (nth (nth run 2) 2))
        " decoder-parameters=" (int_to_str (nth (nth run 3) 2))
        " vocabulary-rows=" (int_to_str (nth (nth run 4) 2))
        " best-token=" (int_to_str (nth (nth run 4) 4))
        " world-admitted=" (int_to_str (nth (nth (nth run 5) 1) 1))
        " outcome=" (nth (fbro-outcome report) 1))))
      run))
)
