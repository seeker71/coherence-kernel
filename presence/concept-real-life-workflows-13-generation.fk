; concept-real-life-workflows-13-generation.fk -- exact source generation and
; recovery for the thirteen operational workflows in all thirteen PL lenses.
; witnessed: 2026-07-18 -> 169/169 workflow/language surfaces recovered
; preludes: form/form-stdlib/core.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-real-life-workflows-13.fk
(do
  (defn crl13g-ids () (cp13-int-list (crl13-int-list-field 0)))
  (defn crl13g-ops () (cp13-int-list (crl13-int-list-field 1)))
  (defn crl13g-thresholds () (cp13-int-list (crl13-int-list-field 2)))
  (defn crl13g-values () (cp13-int-list (crl13-flat-values)))
  (defn crl13g-offsets () (cp13-int-list (crl13-offsets)))
  (defn crl13g-alerts () (crl13-quoted-list (crl13-string-list-field 0)))
  (defn crl13g-clears () (crl13-quoted-list (crl13-string-list-field 1)))

  ; Every target implements the same audited six-operation engine.  Target
  ; stdout is computed from the values; no expected output is embedded.
  (defn crl13g-python (m)
    (cp13-cat (list "# " m "\nids=[" (crl13g-ids) "]\nops=[" (crl13g-ops)
      "]\nthresholds=[" (crl13g-thresholds) "]\nvalues=[" (crl13g-values)
      "]\noffsets=[" (crl13g-offsets) "]\nalerts=[" (crl13g-alerts)
      "]\nclears=[" (crl13g-clears) "]\n"
      "for i in range(13):\n s=values[offsets[i]:offsets[i+1]]; op=ops[i]; t=thresholds[i]; metric=0\n"
      " if op==0: metric=sum(1 for x in s if x<t)\n"
      " elif op==1: metric=sum(1 for x in s if x>t)\n"
      " elif op==2:\n  seen=set(); metric=sum(1 if x in seen else (seen.add(x) or 0) for x in s)\n"
      " elif op==3: metric=sum(1 for x in s if x==0)\n"
      " elif op==4: metric=max(0,sum(s)-t)\n"
      " else: metric=sum(1 for j in range(2,len(s),2) if s[j]<s[j-1])\n"
      " print(f'{ids[i]}:{alerts[i] if metric>0 else clears[i]}:{metric}')\n")))
  (defn crl13g-js (m typed)
    (cp13-cat (list "// " m "\nconst ids" typed "=[" (crl13g-ids)
      "],ops" typed "=[" (crl13g-ops) "],thresholds" typed "=[" (crl13g-thresholds)
      "],values" typed "=[" (crl13g-values) "],offsets" typed "=[" (crl13g-offsets)
      "],alerts" (if (str_eq typed "") "" ":string[]") "=[" (crl13g-alerts)
      "],clears" (if (str_eq typed "") "" ":string[]") "=[" (crl13g-clears) "];\n"
      "for(let i=0;i<13;i++){const s=values.slice(offsets[i],offsets[i+1]);let metric=0;"
      "if(ops[i]===0)metric=s.filter(x=>x<thresholds[i]).length;"
      "else if(ops[i]===1)metric=s.filter(x=>x>thresholds[i]).length;"
      "else if(ops[i]===2){const seen=new Set" (if (str_eq typed "") "()" "<number>()") ";for(const x of s){if(seen.has(x))metric++;else seen.add(x);}}"
      "else if(ops[i]===3)metric=s.filter(x=>x===0).length;"
      "else if(ops[i]===4)metric=Math.max(0,s.reduce((a,b)=>a+b,0)-thresholds[i]);"
      "else for(let j=2;j<s.length;j+=2)if(s[j]<s[j-1])metric++;"
      "console.log(`${ids[i]}:${metric>0?alerts[i]:clears[i]}:${metric}`);}\n")))
  (defn crl13g-java (m)
    (cp13-cat (list "// " m "\nimport java.util.*; public class ConceptWorkflows{public static void main(String[]a){"
      "int[] ids={" (crl13g-ids) "},ops={" (crl13g-ops) "},thresholds={" (crl13g-thresholds)
      "},values={" (crl13g-values) "},offsets={" (crl13g-offsets) "};String[] alerts={"
      (crl13g-alerts) "},clears={" (crl13g-clears) "};for(int i=0;i<13;i++){int metric=0;"
      "if(ops[i]==0||ops[i]==1||ops[i]==3){for(int j=offsets[i];j<offsets[i+1];j++)if((ops[i]==0&&values[j]<thresholds[i])||(ops[i]==1&&values[j]>thresholds[i])||(ops[i]==3&&values[j]==0))metric++;}"
      "else if(ops[i]==2){Set<Integer>s=new HashSet<>();for(int j=offsets[i];j<offsets[i+1];j++)if(!s.add(values[j]))metric++;}"
      "else if(ops[i]==4){for(int j=offsets[i];j<offsets[i+1];j++)metric+=values[j];metric=Math.max(0,metric-thresholds[i]);}"
      "else for(int j=offsets[i]+2;j<offsets[i+1];j+=2)if(values[j]<values[j-1])metric++;"
      "System.out.println(ids[i]+\":\"+(metric>0?alerts[i]:clears[i])+\":\"+metric);}}}\n")))
  (defn crl13g-c (m cpp)
    (cp13-cat (list "// " m "\n#include <stdio.h>\n" (if cpp "#include <set>\n" "")
      "int main(){int ids[]={" (crl13g-ids) "},ops[]={" (crl13g-ops)
      "},thresholds[]={" (crl13g-thresholds) "},values[]={" (crl13g-values)
      "},offsets[]={" (crl13g-offsets) "};const char* alerts[]={" (crl13g-alerts)
      "},*clears[]={" (crl13g-clears) "};for(int i=0;i<13;i++){int metric=0;"
      "if(ops[i]==0||ops[i]==1||ops[i]==3){for(int j=offsets[i];j<offsets[i+1];j++)if((ops[i]==0&&values[j]<thresholds[i])||(ops[i]==1&&values[j]>thresholds[i])||(ops[i]==3&&values[j]==0))metric++;}"
      (if cpp
        "else if(ops[i]==2){std::set<int>s;for(int j=offsets[i];j<offsets[i+1];j++)if(!s.insert(values[j]).second)metric++;}"
        "else if(ops[i]==2){for(int j=offsets[i];j<offsets[i+1];j++)for(int k=offsets[i];k<j;k++)if(values[j]==values[k]){metric++;break;}}")
      "else if(ops[i]==4){for(int j=offsets[i];j<offsets[i+1];j++)metric+=values[j];metric=metric>thresholds[i]?metric-thresholds[i]:0;}"
      "else for(int j=offsets[i]+2;j<offsets[i+1];j+=2)if(values[j]<values[j-1])metric++;"
      "printf(\"%d:%s:%d\\n\",ids[i],metric>0?alerts[i]:clears[i],metric);}return 0;}\n")))
  (defn crl13g-csharp (m)
    (cp13-cat (list "// " m "\nusing System;using System.Collections.Generic;class Program{static void Main(){"
      "int[] ids={" (crl13g-ids) "},ops={" (crl13g-ops) "},thresholds={" (crl13g-thresholds)
      "},values={" (crl13g-values) "},offsets={" (crl13g-offsets) "};string[] alerts={"
      (crl13g-alerts) "},clears={" (crl13g-clears) "};for(int i=0;i<13;i++){int metric=0;"
      "if(ops[i]==0||ops[i]==1||ops[i]==3)for(int j=offsets[i];j<offsets[i+1];j++){if((ops[i]==0&&values[j]<thresholds[i])||(ops[i]==1&&values[j]>thresholds[i])||(ops[i]==3&&values[j]==0))metric++;}"
      "else if(ops[i]==2){var s=new HashSet<int>();for(int j=offsets[i];j<offsets[i+1];j++)if(!s.Add(values[j]))metric++;}"
      "else if(ops[i]==4){for(int j=offsets[i];j<offsets[i+1];j++)metric+=values[j];metric=Math.Max(0,metric-thresholds[i]);}"
      "else for(int j=offsets[i]+2;j<offsets[i+1];j+=2)if(values[j]<values[j-1])metric++;"
      "Console.WriteLine($\"{ids[i]}:{(metric>0?alerts[i]:clears[i])}:{metric}\");}}}\n")))
  (defn crl13g-go (m)
    (cp13-cat (list "// " m "\npackage main\nimport \"fmt\"\nfunc main(){ids:=[]int{" (crl13g-ids)
      "};ops:=[]int{" (crl13g-ops) "};thresholds:=[]int{" (crl13g-thresholds)
      "};values:=[]int{" (crl13g-values) "};offsets:=[]int{" (crl13g-offsets)
      "};alerts:=[]string{" (crl13g-alerts) "};clears:=[]string{" (crl13g-clears)
      "};for i:=0;i<13;i++{metric:=0;if ops[i]==0||ops[i]==1||ops[i]==3{for j:=offsets[i];j<offsets[i+1];j++{if (ops[i]==0&&values[j]<thresholds[i])||(ops[i]==1&&values[j]>thresholds[i])||(ops[i]==3&&values[j]==0){metric++}}}else if ops[i]==2{s:=map[int]bool{};for j:=offsets[i];j<offsets[i+1];j++{if s[values[j]]{metric++};s[values[j]]=true}}else if ops[i]==4{for j:=offsets[i];j<offsets[i+1];j++{metric+=values[j]};metric-=thresholds[i];if metric<0{metric=0}}else{for j:=offsets[i]+2;j<offsets[i+1];j+=2{if values[j]<values[j-1]{metric++}}};state:=clears[i];if metric>0{state=alerts[i]};fmt.Printf(\"%d:%s:%d\\n\",ids[i],state,metric)}}\n")))
  (defn crl13g-rust (m)
    (cp13-cat (list "// " m "\nuse std::collections::HashSet;fn main(){let ids=[" (crl13g-ids)
      "];let ops=[" (crl13g-ops) "];let thresholds=[" (crl13g-thresholds)
      "];let values=[" (crl13g-values) "];let offsets=[" (crl13g-offsets)
      "];let alerts=[" (crl13g-alerts) "];let clears=[" (crl13g-clears)
      "];for i in 0..13{let mut metric=0;if ops[i]==0||ops[i]==1||ops[i]==3{for j in offsets[i]..offsets[i+1]{if (ops[i]==0&&values[j]<thresholds[i])||(ops[i]==1&&values[j]>thresholds[i])||(ops[i]==3&&values[j]==0){metric+=1;}}}else if ops[i]==2{let mut s=HashSet::new();for j in offsets[i]..offsets[i+1]{if !s.insert(values[j]){metric+=1;}}}else if ops[i]==4{for j in offsets[i]..offsets[i+1]{metric+=values[j];}metric=std::cmp::max(0,metric-thresholds[i]);}else{let mut j=offsets[i]+2;while j<offsets[i+1]{if values[j]<values[j-1]{metric+=1;}j+=2;}}println!(\"{}:{}:{}\",ids[i],if metric>0{alerts[i]}else{clears[i]},metric);}}\n")))
  (defn crl13g-ruby (m)
    (cp13-cat (list "# " m "\nids=[" (crl13g-ids) "];ops=[" (crl13g-ops)
      "];thresholds=[" (crl13g-thresholds) "];values=[" (crl13g-values)
      "];offsets=[" (crl13g-offsets) "];alerts=[" (crl13g-alerts) "];clears=["
      (crl13g-clears) "]\n13.times do|i|;s=values[offsets[i]...offsets[i+1]];metric=case ops[i];when 0 then s.count{|x|x<thresholds[i]};when 1 then s.count{|x|x>thresholds[i]};when 2 then s.length-s.uniq.length;when 3 then s.count(0);when 4 then [0,s.sum-thresholds[i]].max;else (1...(s.length/2)).count{|j|s[j*2]<s[j*2-1]};end;puts \"#{ids[i]}:#{metric>0 ? alerts[i]:clears[i]}:#{metric}\";end\n")))
  (defn crl13g-php (m)
    (cp13-cat (list "<?php // " m "\n$ids=[" (crl13g-ids) "];$ops=[" (crl13g-ops)
      "];$thresholds=[" (crl13g-thresholds) "];$values=[" (crl13g-values)
      "];$offsets=[" (crl13g-offsets) "];$alerts=[" (crl13g-alerts) "];$clears=["
      (crl13g-clears) "];for($i=0;$i<13;$i++){$s=array_slice($values,$offsets[$i],$offsets[$i+1]-$offsets[$i]);$metric=0;if($ops[$i]==0||$ops[$i]==1||$ops[$i]==3){foreach($s as $x)if(($ops[$i]==0&&$x<$thresholds[$i])||($ops[$i]==1&&$x>$thresholds[$i])||($ops[$i]==3&&$x==0))$metric++;}elseif($ops[$i]==2)$metric=count($s)-count(array_unique($s));elseif($ops[$i]==4)$metric=max(0,array_sum($s)-$thresholds[$i]);else for($j=2;$j<count($s);$j+=2)if($s[$j]<$s[$j-1])$metric++;$state=$metric>0?$alerts[$i]:$clears[$i];echo \"{$ids[$i]}:$state:$metric\\n\";}\n")))
  (defn crl13g-swift (m)
    (cp13-cat (list "// " m "\nimport Foundation\nlet ids=[" (crl13g-ids) "],ops=["
      (crl13g-ops) "],thresholds=[" (crl13g-thresholds) "],values=[" (crl13g-values)
      "],offsets=[" (crl13g-offsets) "];let alerts=[" (crl13g-alerts) "],clears=["
      (crl13g-clears) "];for i in 0..<13{let s=Array(values[offsets[i]..<offsets[i+1]]);var metric=0;if ops[i]==0{metric=s.filter{$0<thresholds[i]}.count}else if ops[i]==1{metric=s.filter{$0>thresholds[i]}.count}else if ops[i]==2{metric=s.count-Set(s).count}else if ops[i]==3{metric=s.filter{$0==0}.count}else if ops[i]==4{metric=max(0,s.reduce(0,+)-thresholds[i])}else{var j=2;while j<s.count{if s[j]<s[j-1]{metric+=1};j+=2}};print(\"\\(ids[i]):\\(metric>0 ? alerts[i]:clears[i]):\\(metric)\")}\n")))
  (defn crl13g-kotlin (m)
    (cp13-cat (list "// " m "\nfun main(){val ids=intArrayOf(" (crl13g-ids)
      ");val ops=intArrayOf(" (crl13g-ops) ");val thresholds=intArrayOf(" (crl13g-thresholds)
      ");val values=intArrayOf(" (crl13g-values) ");val offsets=intArrayOf(" (crl13g-offsets)
      ");val alerts=arrayOf(" (crl13g-alerts) ");val clears=arrayOf(" (crl13g-clears)
      ");for(i in 0 until 13){val s=values.slice(offsets[i] until offsets[i+1]);var metric=0;if(ops[i]==0)metric=s.count{it<thresholds[i]}else if(ops[i]==1)metric=s.count{it>thresholds[i]}else if(ops[i]==2)metric=s.size-s.toSet().size else if(ops[i]==3)metric=s.count{it==0}else if(ops[i]==4)metric=maxOf(0,s.sum()-thresholds[i])else{var j=2;while(j<s.size){if(s[j]<s[j-1])metric++;j+=2}};println(\"${ids[i]}:${if(metric>0)alerts[i]else clears[i]}:$metric\")}}\n")))

  (defn crl13-generate (language)
    (do (let m (crl13-marker language))
      (if (str_eq language "python") (crl13g-python m)
      (if (str_eq language "javascript") (crl13g-js m "")
      (if (str_eq language "typescript") (crl13g-js m ":number[]")
      (if (str_eq language "java") (crl13g-java m)
      (if (str_eq language "c") (crl13g-c m 0)
      (if (str_eq language "cpp") (crl13g-c m 1)
      (if (str_eq language "csharp") (crl13g-csharp m)
      (if (str_eq language "go") (crl13g-go m)
      (if (str_eq language "rust") (crl13g-rust m)
      (if (str_eq language "ruby") (crl13g-ruby m)
      (if (str_eq language "php") (crl13g-php m)
      (if (str_eq language "swift") (crl13g-swift m)
      (if (str_eq language "kotlin") (crl13g-kotlin m) "")))))))))))))))
  (defn crl13-source-identity (source)
    (do (let start (str_find source "FKR13:" 0))
        (if (lt start 0) (empty)
          (do (let a (add start 6))
              (let b (str_find source ":" a))
              (let c (if (lt b 0) -1 (str_find source ":" (add b 1))))
              (if (or (lt b 0) (lt c 0)) (empty)
                (list (str_to_int (substring source a b))
                  (str_to_int (substring source (add b 1) c))))))))
  (defn crl13-recover (source)
    (do (let identity (crl13-source-identity source))
        (if (not (eq (len identity) 2)) (empty)
          (do (let language (cp10-language-at (head identity)))
              (if (and (not (str_eq language ""))
                       (and (eq (nth identity 1) (crl13-data-fingerprint))
                            (str_eq source (crl13-generate language))))
                (list language (crl13-workflows) (crl13-expected-lines)) (empty))))))
  ; audit=(languages workflow-surfaces nonempty exact-recovered source-hash)
  (defn crl13-generation-audit-go (languages code audit)
    (if (eq (len languages) 0) audit
      (do (let source (crl13-generate (head languages)))
          (let recovered (crl13-recover source))
          (crl13-generation-audit-go (tail languages) (add code 1)
            (list (add (nth audit 0) 1) (add (nth audit 1) 13)
              (add (nth audit 2) (if (gt (str_len source) 0) 13 0))
              (add (nth audit 3) (if (eq (len recovered) 3) 13 0))
              (mod (add (mul (nth audit 4) 131)
                     (add code (cp10-hash-text source))) 1000000007))))))
  (defn crl13-generation-audit ()
    (crl13-generation-audit-go (cp10-languages) 0 (list 0 0 0 0 0)))
)
