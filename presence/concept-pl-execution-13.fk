; concept-pl-execution-13.fk — one semantic concept crosses thirteen language
; surfaces, with host carriers named present or absent from observed evidence.
;
; The concept is selective retention under bounded attention:
; signals=[2,7,1,8,2,8], threshold=5, score floor=100, retained floor=3.
; A target must LOOP, accumulate score += value*(index+1), count retained
; values, BRANCH on both floors, and print verdict:score:retained. The answer
; coherent:109:3 is never embedded in generated source.
;
; This is a bounded semantic generator, not a parser/transpiler. Carrier rows
; are a 2026-07-18 observation of this host. Python is absent by task policy;
; Java and Kotlin use pinned external /tmp carriers from the bootstrap script.
; witnessed: 2026-07-18 -> pure control 32767 four-way; fixture equality 8191;
; twelve live carriers -> coherent:109:3, one explicit carrier absence
; preludes: form/form-stdlib/core.fk

(do
  (defn cp13-cat (xs)
    (if (eq (len xs) 0) "" (str_concat (head xs) (cp13-cat (tail xs)))))
  (defn cp13-int-list (xs)
    (if (eq (len xs) 0) ""
      (if (eq (len (tail xs)) 0) (int_to_str (head xs))
        (str_concat (int_to_str (head xs))
          (str_concat ", " (cp13-int-list (tail xs)))))))

  ; spec=(concept signals threshold score-floor retained-floor alive dead)
  (defn cp13-spec (concept signals threshold score-floor retained-floor alive dead)
    (list concept signals threshold score-floor retained-floor alive dead))
  (defn cp13-concept (s) (nth s 0))
  (defn cp13-signals (s) (nth s 1))
  (defn cp13-threshold (s) (nth s 2))
  (defn cp13-score-floor (s) (nth s 3))
  (defn cp13-retained-floor (s) (nth s 4))
  (defn cp13-alive (s) (nth s 5))
  (defn cp13-dead (s) (nth s 6))
  (defn cp13-live-spec ()
    (cp13-spec "selective-retention" (list 2 7 1 8 2 8) 5 100 3
      "coherent" "fragmented"))

  (defn cp13-eval-go (signals threshold i score retained)
    (if (eq (len signals) 0) (list score retained)
      (do
        (let value (head signals))
        (cp13-eval-go (tail signals) threshold (add i 1)
          (add score (mul value (add i 1)))
          (add retained (if (ge value threshold) 1 0))))))
  (defn cp13-evaluate (spec)
    (do
      (let totals (cp13-eval-go (cp13-signals spec) (cp13-threshold spec) 0 0 0))
      (let alive (if (and (ge (nth totals 0) (cp13-score-floor spec))
                           (ge (nth totals 1) (cp13-retained-floor spec))) 1 0))
      (list (if alive (cp13-alive spec) (cp13-dead spec))
            (nth totals 0) (nth totals 1))))
  (defn cp13-output (evaluation)
    (cp13-cat (list (nth evaluation 0) ":" (int_to_str (nth evaluation 1))
                   ":" (int_to_str (nth evaluation 2)))))

  (defn cp13-gen-python (s)
    (cp13-cat (list
      "# concept: " (cp13-concept s) "\n"
      "signals = [" (cp13-int-list (cp13-signals s)) "]\n"
      "threshold = " (int_to_str (cp13-threshold s)) "\n"
      "score_floor = " (int_to_str (cp13-score-floor s)) "\n"
      "retained_floor = " (int_to_str (cp13-retained-floor s)) "\n"
      "score = 0\nretained = 0\n"
      "for index, value in enumerate(signals):\n"
      "    score += value * (index + 1)\n"
      "    if value >= threshold:\n        retained += 1\n"
      "verdict = \"" (cp13-alive s) "\" if score >= score_floor and retained >= retained_floor else \"" (cp13-dead s) "\"\n"
      "print(f\"{verdict}:{score}:{retained}\")\n")))
  (defn cp13-gen-javascript (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\n"
      "const signals = [" (cp13-int-list (cp13-signals s)) "];\n"
      "const threshold = " (int_to_str (cp13-threshold s)) ";\n"
      "const scoreFloor = " (int_to_str (cp13-score-floor s)) ";\n"
      "const retainedFloor = " (int_to_str (cp13-retained-floor s)) ";\n"
      "let score = 0;\nlet retained = 0;\n"
      "for (let index = 0; index < signals.length; index += 1) {\n"
      "  const value = signals[index];\n  score += value * (index + 1);\n"
      "  if (value >= threshold) retained += 1;\n}\n"
      "const verdict = score >= scoreFloor && retained >= retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "console.log(verdict + \":\" + score + \":\" + retained);\n")))
  (defn cp13-gen-typescript (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\n"
      "const signals: number[] = [" (cp13-int-list (cp13-signals s)) "];\n"
      "const threshold: number = " (int_to_str (cp13-threshold s)) ";\n"
      "const scoreFloor: number = " (int_to_str (cp13-score-floor s)) ";\n"
      "const retainedFloor: number = " (int_to_str (cp13-retained-floor s)) ";\n"
      "let score = 0;\nlet retained = 0;\n"
      "for (let index = 0; index < signals.length; index += 1) {\n"
      "  const value: number = signals[index];\n  score += value * (index + 1);\n"
      "  if (value >= threshold) retained += 1;\n}\n"
      "const verdict: string = score >= scoreFloor && retained >= retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "console.log(verdict + \":\" + score + \":\" + retained);\n")))
  (defn cp13-gen-java (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\npublic final class ConceptPulse {\n"
      "  public static void main(String[] args) {\n"
      "    int[] signals = {" (cp13-int-list (cp13-signals s)) "};\n"
      "    int threshold = " (int_to_str (cp13-threshold s)) ";\n"
      "    int scoreFloor = " (int_to_str (cp13-score-floor s)) ";\n"
      "    int retainedFloor = " (int_to_str (cp13-retained-floor s)) ";\n"
      "    int score = 0; int retained = 0;\n"
      "    for (int index = 0; index < signals.length; index++) {\n"
      "      int value = signals[index]; score += value * (index + 1);\n"
      "      if (value >= threshold) retained++;\n    }\n"
      "    String verdict = score >= scoreFloor && retained >= retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "    System.out.println(verdict + \":\" + score + \":\" + retained);\n  }\n}\n")))
  (defn cp13-gen-c (s)
    (cp13-cat (list
      "/* concept: " (cp13-concept s) " */\n#include <stdio.h>\n"
      "int main(void) {\n  int signals[] = {" (cp13-int-list (cp13-signals s)) "};\n"
      "  int threshold = " (int_to_str (cp13-threshold s)) ";\n"
      "  int score_floor = " (int_to_str (cp13-score-floor s)) ";\n"
      "  int retained_floor = " (int_to_str (cp13-retained-floor s)) ";\n"
      "  int score = 0, retained = 0;\n"
      "  for (int index = 0; index < 6; index++) {\n"
      "    int value = signals[index]; score += value * (index + 1);\n"
      "    if (value >= threshold) retained++;\n  }\n"
      "  const char *verdict = score >= score_floor && retained >= retained_floor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "  printf(\"%s:%d:%d\\n\", verdict, score, retained);\n  return 0;\n}\n")))
  (defn cp13-gen-cpp (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\n#include <iostream>\n#include <string>\n#include <vector>\n"
      "int main() {\n  std::vector<int> signals = {" (cp13-int-list (cp13-signals s)) "};\n"
      "  int threshold = " (int_to_str (cp13-threshold s)) ";\n"
      "  int scoreFloor = " (int_to_str (cp13-score-floor s)) ";\n"
      "  int retainedFloor = " (int_to_str (cp13-retained-floor s)) ";\n"
      "  int score = 0, retained = 0;\n"
      "  for (std::size_t index = 0; index < signals.size(); ++index) {\n"
      "    int value = signals[index]; score += value * static_cast<int>(index + 1);\n"
      "    if (value >= threshold) ++retained;\n  }\n"
      "  std::string verdict = score >= scoreFloor && retained >= retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "  std::cout << verdict << ':' << score << ':' << retained << '\\n';\n}\n")))
  (defn cp13-gen-csharp (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\nusing System;\n"
      "int[] signals = {" (cp13-int-list (cp13-signals s)) "};\n"
      "int threshold = " (int_to_str (cp13-threshold s)) ";\n"
      "int scoreFloor = " (int_to_str (cp13-score-floor s)) ";\n"
      "int retainedFloor = " (int_to_str (cp13-retained-floor s)) ";\n"
      "int score = 0; int retained = 0;\n"
      "for (int index = 0; index < signals.Length; index++) {\n"
      "  int value = signals[index]; score += value * (index + 1);\n"
      "  if (value >= threshold) retained++;\n}\n"
      "string verdict = score >= scoreFloor && retained >= retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "Console.WriteLine($\"{verdict}:{score}:{retained}\");\n")))
  (defn cp13-gen-go (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\npackage main\nimport \"fmt\"\nfunc main() {\n"
      "  signals := []int{" (cp13-int-list (cp13-signals s)) "}\n"
      "  threshold := " (int_to_str (cp13-threshold s)) "\n"
      "  scoreFloor := " (int_to_str (cp13-score-floor s)) "\n"
      "  retainedFloor := " (int_to_str (cp13-retained-floor s)) "\n"
      "  score, retained := 0, 0\n"
      "  for index, value := range signals {\n    score += value * (index + 1)\n"
      "    if value >= threshold { retained++ }\n  }\n"
      "  verdict := \"" (cp13-dead s) "\"\n"
      "  if score >= scoreFloor && retained >= retainedFloor { verdict = \"" (cp13-alive s) "\" }\n"
      "  fmt.Printf(\"%s:%d:%d\\n\", verdict, score, retained)\n}\n")))
  (defn cp13-gen-rust (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\nfn main() {\n"
      "    let signals: [i64; 6] = [" (cp13-int-list (cp13-signals s)) "];\n"
      "    let threshold: i64 = " (int_to_str (cp13-threshold s)) ";\n"
      "    let score_floor: i64 = " (int_to_str (cp13-score-floor s)) ";\n"
      "    let retained_floor: i64 = " (int_to_str (cp13-retained-floor s)) ";\n"
      "    let mut score: i64 = 0; let mut retained: i64 = 0;\n"
      "    for (index, value) in signals.iter().enumerate() {\n"
      "        score += *value * (index as i64 + 1);\n"
      "        if *value >= threshold { retained += 1; }\n    }\n"
      "    let verdict = if score >= score_floor && retained >= retained_floor { \"" (cp13-alive s) "\" } else { \"" (cp13-dead s) "\" };\n"
      "    println!(\"{}:{}:{}\", verdict, score, retained);\n}\n")))
  (defn cp13-gen-ruby (s)
    (cp13-cat (list
      "# concept: " (cp13-concept s) "\nsignals = [" (cp13-int-list (cp13-signals s)) "]\n"
      "threshold = " (int_to_str (cp13-threshold s)) "\n"
      "score_floor = " (int_to_str (cp13-score-floor s)) "\n"
      "retained_floor = " (int_to_str (cp13-retained-floor s)) "\n"
      "score = 0\nretained = 0\n"
      "signals.each_with_index do |value, index|\n  score += value * (index + 1)\n"
      "  retained += 1 if value >= threshold\nend\n"
      "verdict = score >= score_floor && retained >= retained_floor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\"\n"
      "puts \"#{verdict}:#{score}:#{retained}\"\n")))
  (defn cp13-gen-php (s)
    (cp13-cat (list
      "<?php\n// concept: " (cp13-concept s) "\n$signals = [" (cp13-int-list (cp13-signals s)) "];\n"
      "$threshold = " (int_to_str (cp13-threshold s)) ";\n"
      "$scoreFloor = " (int_to_str (cp13-score-floor s)) ";\n"
      "$retainedFloor = " (int_to_str (cp13-retained-floor s)) ";\n"
      "$score = 0; $retained = 0;\n"
      "foreach ($signals as $index => $value) {\n  $score += $value * ($index + 1);\n"
      "  if ($value >= $threshold) $retained++;\n}\n"
      "$verdict = $score >= $scoreFloor && $retained >= $retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\";\n"
      "echo \"$verdict:$score:$retained\\n\";\n")))
  (defn cp13-gen-swift (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\nlet signals = [" (cp13-int-list (cp13-signals s)) "]\n"
      "let threshold = " (int_to_str (cp13-threshold s)) "\n"
      "let scoreFloor = " (int_to_str (cp13-score-floor s)) "\n"
      "let retainedFloor = " (int_to_str (cp13-retained-floor s)) "\n"
      "var score = 0\nvar retained = 0\n"
      "for (index, value) in signals.enumerated() {\n  score += value * (index + 1)\n"
      "  if value >= threshold { retained += 1 }\n}\n"
      "let verdict = score >= scoreFloor && retained >= retainedFloor ? \"" (cp13-alive s) "\" : \"" (cp13-dead s) "\"\n"
      "print(\"\\(verdict):\\(score):\\(retained)\")\n")))
  (defn cp13-gen-kotlin (s)
    (cp13-cat (list
      "// concept: " (cp13-concept s) "\nfun main() {\n"
      "  val signals = listOf(" (cp13-int-list (cp13-signals s)) ")\n"
      "  val threshold = " (int_to_str (cp13-threshold s)) "\n"
      "  val scoreFloor = " (int_to_str (cp13-score-floor s)) "\n"
      "  val retainedFloor = " (int_to_str (cp13-retained-floor s)) "\n"
      "  var score = 0\n  var retained = 0\n"
      "  signals.forEachIndexed { index, value ->\n    score += value * (index + 1)\n"
      "    if (value >= threshold) retained++\n  }\n"
      "  val verdict = if (score >= scoreFloor && retained >= retainedFloor) \"" (cp13-alive s) "\" else \"" (cp13-dead s) "\"\n"
      "  println(\"$verdict:$score:$retained\")\n}\n")))

  (defn cp13-generate (language spec)
    (if (str_eq language "python") (cp13-gen-python spec)
    (if (str_eq language "javascript") (cp13-gen-javascript spec)
    (if (str_eq language "typescript") (cp13-gen-typescript spec)
    (if (str_eq language "java") (cp13-gen-java spec)
    (if (str_eq language "c") (cp13-gen-c spec)
    (if (str_eq language "cpp") (cp13-gen-cpp spec)
    (if (str_eq language "csharp") (cp13-gen-csharp spec)
    (if (str_eq language "go") (cp13-gen-go spec)
    (if (str_eq language "rust") (cp13-gen-rust spec)
    (if (str_eq language "ruby") (cp13-gen-ruby spec)
    (if (str_eq language "php") (cp13-gen-php spec)
    (if (str_eq language "swift") (cp13-gen-swift spec)
    (if (str_eq language "kotlin") (cp13-gen-kotlin spec) ""))))))))))))))

  ; carrier=(language state mode evidence-or-reason)
  (defn cp13-carrier (language state mode evidence)
    (list language state mode evidence))
  (defn cp13-carrier-language (c) (nth c 0))
  (defn cp13-carrier-state (c) (nth c 1))
  (defn cp13-carriers ()
    (list
      (cp13-carrier "python" "absent" "policy" "task explicitly forbids Python")
      (cp13-carrier "javascript" "present" "interpreted" "node v26.0.0")
      (cp13-carrier "typescript" "present" "transpile-run" "npx 11.12.1 + tsx")
      (cp13-carrier "java" "present" "pinned-external" "Temurin 25.0.3+9 from concept-pl-toolchains.sh")
      (cp13-carrier "c" "present" "compiled" "Apple Clang 17.0.0")
      (cp13-carrier "cpp" "present" "compile-run" "Apple clang 17.0.0")
      (cp13-carrier "csharp" "present" "compile-run" "dotnet 9.0.115")
      (cp13-carrier "go" "present" "compile-run" "go1.26.3 darwin/arm64")
      (cp13-carrier "rust" "present" "compile-run" "rustc 1.95.0")
      (cp13-carrier "ruby" "present" "interpreted" "ruby 2.6.10")
      (cp13-carrier "php" "present" "interpreted" "PHP 8.5.6")
      (cp13-carrier "swift" "present" "compile-run" "Swift 6.2.3")
      (cp13-carrier "kotlin" "present" "pinned-external" "Kotlin 2.3.21 compiler from concept-pl-toolchains.sh")))
)
