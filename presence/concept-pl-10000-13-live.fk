; concept-pl-10000-13-live.fk — Form writes, recovers, and executes generated
; programs for materially different concepts on the nine observed carriers.
;
; Python and C remain generation-only by explicit task policy. Java and Kotlin
; remain generation-only because their runtimes are absent. All effects stay in
; /tmp/coherence-cp10-pl; no generated compiler state enters the repository.
; witnessed: 2026-07-18 -> nine carriers x four concepts = 36/36 exact runs
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk

(do
  (defn cp10x-root () "/tmp/coherence-cp10-pl")
  (defn cp10x-languages ()
    (list "javascript" "typescript" "cpp" "csharp" "go" "rust"
          "ruby" "php" "swift"))
  ; unmatched pronoun, mapped verb, mapped concrete noun, and mapped control
  ; structure. Their semantics and generated outputs are materially different.
  (defn cp10x-concepts () (list 0 46 377 6196))
  (defn cp10x-trim-lf (text)
    (if (eq (str_len text) 0) text
      (if (or (eq (str_byte_at text (sub (str_len text) 1)) 10)
              (eq (str_byte_at text (sub (str_len text) 1)) 13))
        (cp10x-trim-lf (substring text 0 (sub (str_len text) 1))) text)))
  (defn cp10x-extension (language)
    (if (str_eq language "javascript") "js"
    (if (str_eq language "typescript") "ts"
    (if (str_eq language "cpp") "cpp"
    (if (str_eq language "csharp") "cs"
    (if (str_eq language "go") "go"
    (if (str_eq language "rust") "rs"
    (if (str_eq language "ruby") "rb"
    (if (str_eq language "php") "php"
    (if (str_eq language "swift") "swift" "txt"))))))))))
  (defn cp10x-source-path (language id)
    (if (str_eq language "csharp")
      (str_concat (cp10x-root) "/csharp/Program.cs")
      (cp13-cat (list (cp10x-root) "/concept-" (int_to_str id) "."
        (cp10x-extension language)))))
  (defn cp10x-binary-path (language id)
    (cp13-cat (list (cp10x-root) "/" language "-" (int_to_str id))))
  (defn cp10x-required-command (language)
    (if (str_eq language "javascript") "node"
    (if (str_eq language "typescript") "npx"
    (if (str_eq language "cpp") "clang++"
    (if (str_eq language "csharp") "dotnet"
    (if (str_eq language "go") "go"
    (if (str_eq language "rust") "rustc"
    (if (str_eq language "ruby") "ruby"
    (if (str_eq language "php") "php"
    (if (str_eq language "swift") "swiftc" "missing"))))))))))
  (defn cp10x-available? (language)
    (str_eq (host-exec
      (cp13-cat (list "command -v " (cp10x-required-command language)
        " >/dev/null 2>&1 && printf 1 || printf 0")) "") "1"))
  (defn cp10x-command (language id source)
    (do
      (let binary (cp10x-binary-path language id))
      (if (str_eq language "javascript") (str_concat "node " source)
      (if (str_eq language "typescript") (str_concat "npx --yes tsx " source)
      (if (str_eq language "cpp")
        (cp13-cat (list "clang++ -std=c++17 " source " -o " binary " && " binary))
      (if (str_eq language "csharp")
        "dotnet run --project /tmp/coherence-cp10-pl/csharp/Concept.csproj --configuration Release --nologo --verbosity quiet"
      (if (str_eq language "go") (str_concat "go run " source)
      (if (str_eq language "rust")
        (cp13-cat (list "rustc -O " source " -o " binary " && " binary))
      (if (str_eq language "ruby") (str_concat "ruby " source)
      (if (str_eq language "php") (str_concat "php " source)
      (if (str_eq language "swift")
        (cp13-cat (list "swiftc " source " -o " binary " && " binary)) "")))))))))))

  ; row=(language id available wrote recovered expected actual pass output-hash)
  (defn cp10x-run-one (corpus semantic-index payload language id)
    (do
      (let available (if (cp10x-available? language) 1 0))
      (if (eq available 0) (list language id 0 0 0 "" "" 0 0)
        (do
          (let record (c10-concept-at-in corpus id))
          (let semantic (cs10-at-in semantic-index payload id))
          (let spec (cp10-spec-for language record semantic))
          (let source (cp13-generate language spec))
          (let path (cp10x-source-path language id))
          (let wrote (write_file path source))
          (let recovered (cp10-recover-source-in corpus semantic-index payload source))
          (let expected (cp13-output (cp13-evaluate spec)))
          (let actual (cp10x-trim-lf
            (host-exec (cp10x-command language id path) "")))
          (let pass (if (and (gt wrote 0)
            (and (eq (len recovered) 5) (str_eq expected actual))) 1 0))
          (list language id 1 wrote (if (eq (len recovered) 5) 1 0)
            expected actual pass (cp10-hash-text actual))))))

  ; totals=(languages concepts available attempted passed recovered wrote
  ;         changed-adjacent outputs-hash rows)
  (defn cp10x-totals-empty () (list 0 0 0 0 0 0 0 0 0 (empty)))
  (defn cp10x-concepts-go (corpus semantic-index payload language concepts
                           previous-output totals)
    (if (eq (len concepts) 0) totals
      (do
        (let row (cp10x-run-one corpus semantic-index payload language (head concepts)))
        (let available (nth row 2))
        (let actual (nth row 6))
        (let changed (if (and (gt (str_len previous-output) 0)
                             (not (str_eq previous-output actual))) 1 0))
        (cp10x-concepts-go corpus semantic-index payload language (tail concepts)
          actual
          (list (nth totals 0) (add (nth totals 1) 1)
            (add (nth totals 2) available)
            (add (nth totals 3) available)
            (add (nth totals 4) (nth row 7))
            (add (nth totals 5) (nth row 4))
            (add (nth totals 6) (if (gt (nth row 3) 0) 1 0))
            (add (nth totals 7) changed)
            (mod (add (mul (nth totals 8) 131) (nth row 8)) 1000000007)
            (cons row (nth totals 9)))))))
  (defn cp10x-languages-go (corpus semantic-index payload languages totals)
    (if (eq (len languages) 0) totals
      (do
        (let after (cp10x-concepts-go corpus semantic-index payload
          (head languages) (cp10x-concepts) "" totals))
        (cp10x-languages-go corpus semantic-index payload (tail languages)
          (list (add (nth after 0) 1) (nth after 1) (nth after 2)
            (nth after 3) (nth after 4) (nth after 5) (nth after 6)
            (nth after 7) (nth after 8) (nth after 9))))))
  (defn cp10x-prepare ()
    (do
      (host-exec "mkdir -p /tmp/coherence-cp10-pl/csharp" "")
      (write_file "/tmp/coherence-cp10-pl/csharp/Concept.csproj"
        "<Project Sdk=\"Microsoft.NET.Sdk\"><PropertyGroup><OutputType>Exe</OutputType><TargetFramework>net9.0</TargetFramework><ImplicitUsings>enable</ImplicitUsings><Nullable>enable</Nullable></PropertyGroup></Project>")))
  (defn cp10x-run ()
    (do
      (cp10x-prepare)
      (cp10x-languages-go
        (read_file (c10-ranked-path))
        (read_file (cs10-index-path))
        (read_file (cs10-payload-path))
        (cp10x-languages) (cp10x-totals-empty))))
)
