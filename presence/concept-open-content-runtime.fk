; concept-open-content-runtime.fk -- content-derived arbitrary concept runtime.
;
; This is the honest successor to the address-based courthouse door.  For any
; valid concept id, NL lens, and PL lens it independently round-trips visible
; text, speech-only PCM, decoded video pixels, and generated program source.
; Text candidates come from a complete 10k scan, audio candidates come only
; from a Whisper transcript, and video candidates come only from OCR or host
; pretrained labels.  Tone codes, pixel bands, filenames, and requested ids
; are never accepted as semantic observations.  Successful text/audio/video
; observations enter the ordinary persistent world model as separate views.
;
; This door is lazy and callable; it does not imply 130,000 observed acoustic
; or visual rows.  Speech is synthesized, video meaning is visible text plus
; pretrained labels, and learned carriers remain host-rented.
; witnessed: 2026-07-18 -> dog/en/JavaScript content-unified, three world views
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk cognition/concept-text-detection-13-runtime.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/concept-audio-asr-13.fk model/concept-audio-open-10000-13.fk presence/concept-audio-open-10000-13-live.fk model/lingbot-vision-input.fk model/concept-video-generation-10000-13.fk model/concept-video-open-runtime.fk presence/concept-video-open-runtime-live.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-pl-10000-13-live.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk

(do
  ; runtime = ranked, semantic index/payload, text runtime, video runtime.
  (defn cocr-open ()
    (list (read_file (c10-ranked-path))
      (read_file (cs10-index-path)) (read_file (cs10-payload-path))
      (ctd13-runtime-open) (cvorl-open)))
  (defn cocr-ranked (runtime) (nth runtime 0))
  (defn cocr-semantic-index (runtime) (nth runtime 1))
  (defn cocr-semantic-payload (runtime) (nth runtime 2))
  (defn cocr-text-runtime (runtime) (nth runtime 3))
  (defn cocr-video-runtime (runtime) (nth runtime 4))

  (defn cocr-audio-hit? (row)
    (if (lt (len row) 8) 0 (nth (nth row 7) 3)))
  (defn cocr-audio-status (row)
    (if (lt (len row) 8) "unavailable" (nth (nth row 7) 1)))
  (defn cocr-audio-reason (row)
    (if (lt (len row) 8) "no-row" (nth (nth row 7) 5)))
  (defn cocr-video-hit? (row)
    (if (eq (len row) 0) 0 (cvorl-result-semantic? row)))
  (defn cocr-video-localized? (row)
    (if (eq (len row) 0) 0 (cvorl-result-localized? row)))
  (defn cocr-video-generated? (row)
    (if (eq (len row) 0) 0 (cvorl-result-generated? row)))

  (defn cocr-collect-entities (rows)
    (if (eq (len rows) 0) (empty)
      (if (eq (len (head rows)) 0) (cocr-collect-entities (tail rows))
        (cons (head rows) (cocr-collect-entities (tail rows))))))
  (defn cocr-entity-if (hit id position viewpoint time known)
    (if (eq hit 1) (cwm-persist id position viewpoint time known) (empty)))

  (defn cocr-pl-execution-state (requested language row)
    (if (eq requested 0) "not-requested"
      (if (str_eq language "python") "policy-absent"
          (if (eq (len row) 0) "carrier-unavailable"
          (if (eq (nth row 2) 0) "carrier-unavailable"
            (if (eq (nth row 7) 1) "passed" "failed"))))))

  (defn cocr-run-in (runtime id code pl-language position suffix execute-pl)
    (if (or (eq (cao10-valid-address? id code) 0)
            (lt (cp10-language-code pl-language) 0))
      (list "concept-open-content-runtime"
        (list "request" id code pl-language)
        (list "status" "invalid-address"))
      (do
        (let ranked (cocr-ranked runtime))
        (let semantic-index (cocr-semantic-index runtime))
        (let semantic-payload (cocr-semantic-payload runtime))
        (let text-runtime (cocr-text-runtime runtime))
        (let record (c10-concept-at-in ranked id))
        (let semantic (cs10-at-in semantic-index semantic-payload id))
        (let sourced (cnl13-runtime-lookup-sourced
          (ctd13-runtime-nl text-runtime) id code))
        (let surface (nth sourced 3))

        ; The generated text surface is rescanned without an id candidate list.
        (let text-candidates
          (ctd13-runtime-detect-sentence text-runtime code surface))
        (let text-hit (cvor-candidate-id-present? text-candidates id))

        ; Both live organs retain their complete evidence, including misses.
        (let audio (cao10l-address-run id code suffix))
        (let audio-hit (cocr-audio-hit? audio))
        (let video (cvorl-generate-sense (cocr-video-runtime runtime)
          id (ca13-lens-index code)))
        (let video-hit (cocr-video-hit? video))

        (let source (cp10-generate-in ranked semantic-index semantic-payload
          pl-language id))
        (let recovered (cp10-recover-source-in ranked semantic-index
          semantic-payload source))
        (let pl-recovered (if (eq (len recovered) 5) 1 0))
        (let _prepared (if (and (eq execute-pl 1)
                                (not (str_eq pl-language "python")))
          (cp10x-prepare) 0))
        (let execution (if (and (eq execute-pl 1)
                                (not (str_eq pl-language "python")))
          (cp10x-run-one ranked semantic-index semantic-payload pl-language id)
          (empty)))
        (let execution-state
          (cocr-pl-execution-state execute-pl pl-language execution))

        ; A modality enters the world only after its content path recovered the
        ; requested concept.  Three views may therefore persist zero to three
        ; entities; the request itself never creates one.
        (let known (list (cwm-cell id (c10-concept-label record))))
        (let text-entity (cocr-entity-if text-hit id position
          "generated-text-content" 3100 known))
        (let audio-entity (cocr-entity-if audio-hit id position
          "speech-only-content" 3200 known))
        (let video-entity (cocr-entity-if video-hit id position
          "decoded-video-content" 3300 known))
        (let entities (cocr-collect-entities
          (list text-entity audio-entity video-entity)))
        (let unified (if (and (eq text-hit 1)
          (and (eq audio-hit 1) (eq video-hit 1))) 1 0))

        (list "concept-open-content-runtime"
          (list "request" id code pl-language position
            (c10-concept-label record) (cs10-synset-id semantic)
            (cs10-method-label semantic))
          (list "text" surface (nth sourced 4) (nth sourced 5)
            "candidate-count" (len text-candidates)
            "candidate-ids" (cvor-candidate-ids text-candidates)
            "expected-found" text-hit)
          (list "audio" "status" (cocr-audio-status audio)
            "reason" (cocr-audio-reason audio)
            "expected-found" audio-hit "full-evidence" audio)
          (list "video" "generated" (cocr-video-generated? video)
            "semantic-content" video-hit
            "localized-content" (cocr-video-localized? video)
            "full-evidence" video)
          (list "program" "language" pl-language
            "source-bytes" (str_len source) "source-hash" (cp10-hash-text source)
            "recovered" pl-recovered
            "identity" (cp10-source-identity source)
            "execution-state" execution-state "execution" execution)
          (list "world-model" "accepted-views" (len entities)
            "concept-entities" (cwm-concept-count entities)
            "entities" entities "world" (cwm-world entities))
          (list "verdict" "text-content" text-hit "audio-content" audio-hit
            "video-content" video-hit "pl-recovered" pl-recovered
            "content-unified" unified)
          (list "boundaries"
            "complete-text-scan"
            "speech-only-asr-no-tone-envelope"
            "decoded-video-ocr-or-pretrained-label-no-pixel-envelope"
            "generated-source-recovery-is-not-arbitrary-code-understanding"
            "host-rented-acoustic-and-visual-weights"
            "lazy-addressability-is-not-130000-observed-content")))))

  (defn concept-open-content-runtime-run (id code pl-language position suffix)
    (cocr-run-in (cocr-open) id code pl-language position suffix 1))

  (defn concept-open-content-runtime-execute
        (id code pl-language position suffix)
    (do
      (let row (concept-open-content-runtime-run
        id code pl-language position suffix))
      (if (eq (len row) 3)
        (print_str (ca13-cat (list "address=" (int_to_str id) ":" code
          " PL=" pl-language " status=invalid-address")))
        (do
          (let request (nth row 1))
          (let text-row (nth row 2))
          (let audio-row (nth row 3))
          (let video-row (nth row 4))
          (let program-row (nth row 5))
          (let world-row (nth row 6))
          (let verdict (nth row 7))
          (print_str (ca13-cat (list
            "address=" (int_to_str (nth request 1)) ":" (nth request 2)
            " PL=" (nth request 3) " label=" (nth request 5)
            " text=" (int_to_str (nth text-row 9))
            " audio=" (int_to_str (nth audio-row 6))
            " video=" (int_to_str (nth video-row 4))
            " pl=" (int_to_str (nth program-row 8))
            " pl-exec=" (nth program-row 12)
            " world-views=" (int_to_str (nth world-row 2))
            " unified=" (int_to_str (nth verdict 10)))))))
      0))
)
