; concept-video-open-label-world-live.fk -- real-photo concepts enter wm-model.
;
; The open-label visual lane decides which top-10k concepts are actually named
; by pretrained labels above its explicit confidence floor. This join persists
; only positive targets that survived that complete scan. Fixture expectations
; never manufacture an entity, and the held guitar negative stays absent.
;
; Positions are observation slots in this photo collection, not inferred 3-D
; coordinates. The separate LingBot real-life doors carry metric-free geometry;
; this organ proves expanded content-derived identity uses the same native world
; model instead of a second visual-only store.
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk presence/concept-video-open-label-live.fk

(do
  (defn cvowl-target-present? (row)
    (and (eq (nth row 3) 1) (eq (nth (nth row 5) 1) 1)))
  (defn cvowl-targets-go (rows out)
    (if (eq (len rows) 0) (reverse out)
      (cvowl-targets-go (tail rows)
        (if (cvowl-target-present? (head rows)) (cons (head rows) out) out))))
  (defn cvowl-targets (live)
    (cvowl-targets-go (nth (nth live 5) 1) (empty)))
  (defn cvowl-known (rows)
    (if (eq (len rows) 0) (empty)
      (cons (cwm-cell (nth (head rows) 1) (nth (head rows) 2))
            (cvowl-known (tail rows)))))
  (defn cvowl-persist-go (rows known index)
    (if (eq (len rows) 0) (empty)
      (cons (cwm-persist (nth (head rows) 1) (list index 0 0)
              "open-label-real-photo" (add 4000 index) known)
            (cvowl-persist-go (tail rows) known (add index 1)))))
  (defn cvowl-entity-labels (entities)
    (if (eq (len entities) 0) (empty)
      (cons (wm-ent-id (head entities)) (cvowl-entity-labels (tail entities)))))

  (defn concept-video-open-label-world-live-run ()
    (do
      (let live (concept-video-open-label-live-run))
      (let targets (cvowl-targets live))
      (let known (cvowl-known targets))
      (let entities (cvowl-persist-go targets known 1))
      (let carrier (nth live 1))
      (let fixtures (nth live 2))
      (let positives (nth live 3))
      (let negative (nth live 4))
      (let score
        (add
          (if (and (eq (nth carrier 1) 1) (eq (nth carrier 2) 1)) 1 0)
          (add
            (if (eq (nth fixtures 1) 10) 2 0)
            (add
              (if (eq (nth positives 1) 9) 4 0)
              (add
                (if (eq (nth negative 1) 1) 8 0)
                (add
                  (if (eq (len targets) 9) 16 0)
                  (add
                    (if (eq (len known) 9) 32 0)
                    (add
                      (if (eq (len entities) 9) 64 0)
                      (if (eq (cwm-concept-count entities) 9) 128 0)))))))))
      (list "concept-video-open-label-world-live"
        (list "visual-observations" (len (nth (nth live 5) 1))
          "accepted-positive-targets" (len targets)
          "negative-held" (nth negative 1))
        (list "world-model" (cwm-concept-count entities)
          "positions-are-observation-slots" 1
          "entities" (cvowl-entity-labels entities)
          (cwm-world entities))
        (list "score" score 255))))

  (concept-video-open-label-world-live-run))
