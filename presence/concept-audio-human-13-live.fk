; concept-audio-human-13-live.fk -- human speech enters the 10k detector and world.
;
; The carrier supplies a hash-verified Commons recording at a neutral numeric
; path.  Whisper receives only those human-recorded samples, with an explicit
; language and no prompt.  The complete Form detector then receives only the
; resulting transcript and locale.  Expected identity is consulted after that
; scan solely to report presence/absence; only an actually returned candidate
; may be admitted through the kernel's ordinary concept world bridge.
; witnessed: 2026-07-18 -> live human corpus, misses retained
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk cognition/concept-text-detection-13-runtime.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/concept-audio-asr-13.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk model/concept-audio-human-13.fk model/concept-audio-human-13-observed.fk

(do
  (defn cah13-find-id (candidates id)
    (if (eq (len candidates) 0) (empty)
      (if (eq (ctd13-candidate-id (head candidates)) id) (head candidates)
        (cah13-find-id (tail candidates) id))))
  (defn cah13-candidate-ids (candidates)
    (if (eq (len candidates) 0) (empty)
      (cons (ctd13-candidate-id (head candidates))
        (cah13-candidate-ids (tail candidates)))))
  (defn cah13-ids-text (ids)
    (if (eq (len ids) 0) "-"
      (if (eq (len (tail ids)) 0) (int_to_str (head ids))
        (ca13-cat (list (int_to_str (head ids)) ","
          (cah13-ids-text (tail ids)))))))
  (defn cah13-sha256-file (path)
    (host-exec (ca13-cat (list "shasum -a 256 " (ca13-shell-quote path)
      " | awk '{printf \"%s\",$1}'")) ""))
  (defn cah13-source-integrity? (fixture sha256 bytes status)
    (if (and (str_eq status "verified")
          (and (str_eq sha256 (cah13-sha256 fixture))
               (eq bytes (cah13-bytes fixture)))) 1 0))
  (defn cah13-neutral-path? (fixture wav)
    (if (ge (str_find wav (cah13-transcription fixture) 0) 0) 0 1))

  ; This is the non-test world admission door.  Its id comes from a returned
  ; detector candidate, never from the fixture.  The fixture supplies only the
  ; attributed label for the known persistent cell and observation metadata.
  (defn cah13-world-admit (candidate fixture index)
    (if (eq (len candidate) 0)
      (list "admitted" 0 "reason" "expected-id-absent-from-content-scan")
      (do
        (let detected-id (ctd13-candidate-id candidate))
        (let known (list (cwm-cell detected-id (cah13-transcription fixture))))
        (let entity (cwm-persist detected-id index "commons-human-audio"
                      (add 180718 index) known))
        (list "admitted" 1 "detected-id" detected-id
          "entity" entity "world" (cwm-world (list entity))
          "world-count" (cwm-concept-count (list entity))))))

  (defn cah13-run-file (index source-file wav sha256 bytes retrieved rms-db peak-db noise-floor-db)
    (do
      (let fixture (nth (cah13-fixtures) index))
      (let source-sha256 (cah13-sha256-file source-file))
      (let source-ok (if (and (str_eq sha256 source-sha256)
        (eq (cah13-source-integrity? fixture source-sha256 bytes "verified") 1)) 1 0))
      (let pcm (if (eq source-ok 1)
                 (casr13-pcm-evidence-file wav) (list 0 0 0)))
      (let wav-sha256 (if (eq (nth pcm 2) 1) (cah13-sha256-file wav) ""))
      (let transcript (if (and (eq source-ok 1) (eq (nth pcm 2) 1))
                         (casr13-transcribe-file wav (cah13-code fixture)) ""))
      ; Content-only boundary: code + actual ASR output are the only inputs.
      (let runtime (ctd13-runtime-open))
      (let detected (ctd13-runtime-detect-sentence runtime
                       (cah13-code fixture) transcript))
      ; Only after live detection do we consult the frozen replay row.
      (let detected-ids (cah13-candidate-ids detected))
      (let observed (nth (cah13-observed-rows) index))
      (let offline-exact (if (and
        (str_eq transcript (cah13-observed-transcript observed))
        (and (str_eq wav-sha256 (cah13-observed-wav-sha256 observed))
          (value_eq detected-ids (cah13-observed-candidate-ids observed)))) 1 0))
      (let expected (cah13-find-id detected (cah13-id fixture)))
      (let found (if (eq (len expected) 0) 0 1))
      (let world (cah13-world-admit expected fixture index))
      (list "concept-audio-human-observation"
        (list "source" "Wikimedia-Commons/Lingua-Libre"
          "media-id" (cah13-media-id fixture)
          "speaker" (cah13-speaker fixture)
          "recorded" (cah13-recorded fixture)
          "license" (cah13-license fixture)
          "page" (cah13-page fixture) "raw-url" (cah13-url fixture)
          "raw-sha1" (cah13-sha1 fixture) "raw-sha256" source-sha256
          "raw-bytes" bytes "retrieved" retrieved)
        (list "source-label" (cah13-id fixture) (cah13-code fixture)
          (cah13-transcription fixture) "metadata-only-not-detector-input")
        (list "acoustic" wav "human-recorded" 1 "tts" 0
          "pcm" pcm "wav-sha256" wav-sha256
          "rms-db" rms-db "peak-db" peak-db
          "noise-floor-db" noise-floor-db)
        (list "asr" (casr13-oracle-name) "model-sha256"
          (casr13-model-sha256) "prompt" "" "transcript" transcript)
        (list "detection" "complete-form-scan" "limit" 10000
          "candidate-count" (len detected)
          "candidate-ids" detected-ids
          "candidates" detected)
        (list "result" (if (eq found 1) "success" "miss")
          "expected-found" found
          "reason" (if (eq found 1) "none"
            "human-asr-transcript-missing-expected-concept")
          "expected-candidate" expected)
        (list "world-model" world)
        (list "integrity" "source-hash-verified" source-ok
          "neutral-numeric-path" (cah13-neutral-path? fixture wav)
          "detector-input" "transcript-only" "transcription-prompt" 0
          "expected-id-injected" 0 "closed-candidate-list" 0
          "address-envelope" 0 "offline-output-exact" offline-exact))))

  (defn cah13-unavailable (index status retrieved)
    (do
      (let fixture (nth (cah13-fixtures) index))
      (list "concept-audio-human-observation"
        (list "source" "Wikimedia-Commons/Lingua-Libre"
          "media-id" (cah13-media-id fixture)
          "speaker" (cah13-speaker fixture)
          "recorded" (cah13-recorded fixture)
          "license" (cah13-license fixture)
          "page" (cah13-page fixture) "raw-url" (cah13-url fixture)
          "raw-sha1" (cah13-sha1 fixture) "retrieved" retrieved)
        (list "source-label" (cah13-id fixture) (cah13-code fixture)
          (cah13-transcription fixture) "metadata-only-not-detector-input")
        (list "acoustic" "unavailable" "human-recorded" 1 "tts" 0)
        (list "asr" (casr13-oracle-name) "transcript" "")
        (list "detection" "not-run" "limit" 10000 "candidate-count" 0
          "candidate-ids" (empty) "candidates" (empty))
        (list "result" "unavailable" "expected-found" 0 "reason" status)
        (list "world-model" (list "admitted" 0 "reason" status))
        (list "integrity" "detector-input" "none" "expected-id-injected" 0
          "address-envelope" 0))))

  (defn cah13-execute-file (index source-file wav sha256 bytes retrieved rms-db peak-db noise-floor-db)
    (do
      (let row (cah13-run-file index source-file wav sha256 bytes retrieved
                  rms-db peak-db noise-floor-db))
      (let source (nth row 1))
      (let detection (nth row 5))
      (let result (nth row 6))
      (let world (nth (nth row 7) 1))
      (let integrity (nth row 8))
      (print_str (ca13-cat (list
        "human-sample=" (int_to_str index)
        " code=" (cah13-code (nth (cah13-fixtures) index))
        " speaker=" (cah13-speaker (nth (cah13-fixtures) index))
        " status=" (nth result 1)
        " candidates=" (int_to_str (nth detection 5))
        " candidate-ids=" (cah13-ids-text (nth detection 7))
        " world-admitted=" (int_to_str (nth world 1))
        " offline-exact=" (int_to_str (nth integrity 16))
        " bytes=" (int_to_str (nth source 19))
        " transcript=" (nth (nth row 4) 7))))
      row))

  (defn cah13-execute-unavailable (index status retrieved)
    (do
      (let row (cah13-unavailable index status retrieved))
      (print_str (ca13-cat (list
        "human-sample=" (int_to_str index)
        " code=" (cah13-code (nth (cah13-fixtures) index))
        " speaker=" (cah13-speaker (nth (cah13-fixtures) index))
        " status=unavailable candidates=0 world-admitted=0 reason=" status)))
      row))
)
