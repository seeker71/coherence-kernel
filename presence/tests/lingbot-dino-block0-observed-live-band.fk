; Complete released DINOv2-L/14 block-0 acceptance over two real pixel tokens.
; expected: 32767
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/lingbot-vision-input.fk model/lingbot-learned-patch.fk model/released-row-major-affine.fk model/lingbot-dino-block0.fk observe/framebuffer-runtime-observation.fk presence/lingbot-dino-block0-observed-live.fk

(do
  (defn ldb0ob-bit (ok bit) (if ok bit 0))
  (defn ldb0ob-close? (actual expected)
    (lt (abs (sub actual expected)) 0.000000000001))
  (defn ldb0ob-values (report i) (nth (nth (fbro-events report) i) 3))
  (defn ldb0ob-stage? (report i name metric value)
    (do (let values (ldb0ob-values report i))
        (and (str_eq (nth values 2) name)
          (and (str_eq (nth values 11) metric) (eq (nth values 12) value)))))

  (defn lingbot-dino-block0-observed-live-band ()
    (do
      (let run (lingbot-dino-block0-observed-live-run))
      (let source (nth run 1))
      (let patch (nth run 2))
      (let patch-fp (nth patch 6))
      (let block (nth run 3))
      (let attention (nth block 8))
      (let output (nth run 4))
      (let attended-fp (nth output 4))
      (let output-fp (nth output 6))
      (let movements (nth output 8))
      (let separation (nth output 10))
      (let truth (nth run 5))
      (let report (nth run 6))
      (let resources (fbro-resources report))
      (let float-bottleneck (fbro-bottleneck report "boxed-floats"))
      (sum (list
        (ldb0ob-bit (and (eq (nth source 3) 1581923)
          (and (eq (nth source 5) 1)
               (value_eq (nth source 7) (list 518 294 518 294)))) 1)
        (ldb0ob-bit (and (eq (nth patch 2) 1)
          (and (eq (nth patch 4) 603136)
            (and (ldb0ob-close? (nth (nth patch-fp 0) 8)
                   0.36816813101718826)
                 (ldb0ob-close? (nth (nth patch-fp 1) 8)
                   -5.2784386886527592)))) 2)
        (ldb0ob-bit (and (eq (nth block 2) 1)
          (and (eq (nth block 4) 12598272)
               (eq (nth block 6) 50394880))) 4)
        (ldb0ob-bit (and (ldb0ob-close? (nth (nth attention 0) 0)
              0.53690760630367362)
          (and (ldb0ob-close? (nth (nth attention 0) 1)
                 0.46309239369632638)
            (and (ldb0ob-close? (nth (nth attention 1) 0)
                   0.5120957920332494)
                 (ldb0ob-close? (nth (nth attention 1) 1)
                   0.48790420796675055)))) 8)
        (ldb0ob-bit (and (ldb0ob-close? (nth (nth attended-fp 0) 0)
              0.12255551927412393)
          (and (ldb0ob-close? (nth (nth attended-fp 0) 8)
                 -3.4311777388151397)
               (ldb0ob-close? (nth (nth attended-fp 1) 8)
                 -9.0795536942292667))) 16)
        (ldb0ob-bit (and (eq (nth output 2) 1)
          (and (ldb0ob-close? (nth (nth output-fp 0) 0)
                 0.14120925650035721)
            (and (ldb0ob-close? (nth (nth output-fp 0) 9)
                   180.74734975841341)
              (and (ldb0ob-close? (nth (nth output-fp 1) 0)
                     0.067715456170171578)
                   (ldb0ob-close? (nth (nth output-fp 1) 9)
                     183.81337185811444))))) 32)
        (ldb0ob-bit (and (ldb0ob-close? (nth movements 0)
              134.70614667005006)
          (and (ldb0ob-close? (nth movements 1) 144.0745122077175)
               (ldb0ob-close? separation 60.13735514085694))) 64)
        (ldb0ob-bit (and (value_eq (ldb0ol-semantic-gate "loop" 0)
              (list "" 0 1 "loop"))
          (and (eq (nth truth 4) 1)
          (and (eq (nth truth 6) 0)
            (and (eq (nth truth 8) 0)
              (and (eq (nth truth 10) 0)
                (and (eq (nth truth 12) 0)
                  (and (str_eq (nth truth 14) "")
                    (and (eq (nth truth 16) 0) (eq (nth truth 18) 1))))))))) 128)
        (ldb0ob-bit (and (eq (len (fbro-events report)) 8)
          (str_eq (nth (fbro-outcome report) 1)
            "complete-released-block0-semantic-output-held")) 256)
        (ldb0ob-bit (and (ldb0ob-stage? report 1 "frames-decoded" "frames" 2)
          (and (ldb0ob-stage? report 2 "released-patch-input"
                 "released-parameters" 603136)
            (ldb0ob-stage? report 3 "block0-carrier-validated"
              "released-parameters" 12598272))) 512)
        (ldb0ob-bit (and (ldb0ob-stage? report 4 "released-block0-attention"
              "heads" 16)
          (and (ldb0ob-stage? report 5 "released-block0-mlp"
                 "released-block-parameters" 12598272)
            (ldb0ob-stage? report 6 "semantic-output-gate"
              "semantic-admitted" 0))) 1024)
        (ldb0ob-bit (and (eq (ldb0ol-resource-number resources "input-bytes" 0)
              1581923)
          (gt (ldb0ol-resource-number resources "dispatches" 0) 1000000000)) 2048)
        (ldb0ob-bit (gt (fbro-event-number (nth (fbro-events report) 3)
              "io-sense-dispatches") 0) 4096)
        (ldb0ob-bit (and (gt (fbro-event-number (nth (fbro-events report) 4)
              "boxed-floats") 1000000)
          (gt (fbro-event-number (nth (fbro-events report) 5)
              "boxed-floats") 1000000)) 8192)
        (ldb0ob-bit (and (gt (nth float-bottleneck 1) 1000000)
          (str_eq (nth float-bottleneck 2) "released-block0-mlp")) 16384)))))

  (lingbot-dino-block0-observed-live-band)
)
