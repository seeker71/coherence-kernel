; preludes:
;   observe/stt-agree.fk
;   observe/stt-wer.fk
;   presence/text-normalize.fk
;   presence/g2p.fk
;   presence/phoneme-timing.fk
;   presence/prosody-contour.fk
;   presence/voice-phrasing.fk
;   presence/voice-prosody.fk
;   presence/speaker-embed.fk
;   presence/native-speech-stack.fk
;
; native-speech-stack-band -- STT + TTS pre-acoustic stack in one witness.
;
; Verdict 2047:
;   1    STT agreement accepts a matching transcript
;   2    STT WER catches order errors that overlap can miss
;   4    hallucinated transcript is rejected
;   8    text normalization is present before g2p
;   16   g2p lookup is native
;   32   phoneme timing is native
;   64   prosody contour is native
;   128  grounded phrasing is native
;   256  honest prosody is native
;   512  speaker decision is native
;   1024 composed stack receipt is ready

(do
    (defn nss-band-score (cond bit) (if cond bit 0))
    (defn nss-band-truth () (list "we" "are" "the" "iris"))
    (defn nss-band-same () (list "we" "are" "the" "iris"))
    (defn nss-band-halluc () (list "gunshot" "gunshot" "gunshot" "gunshot"))
    (defn nss-band-roster ()
        (list (list "a" (list 10 0 0 0))
              (list "b" (list 0 10 0 0))
              (list "c" (list 7 7 0 0))))
    (defn nss-band-qA () (list 9 1 0 0))

    (defn nss-band-stt ()
        (sa-agree? (nss-band-same) (nss-band-truth) 80))
    (defn nss-band-wer ()
        (if (and (eq (sa-accuracy (list "are" "we" "the" "iris") (nss-band-truth)) 100)
                 (gt (sw-wer (list "are" "we" "the" "iris") (nss-band-truth)) 0)) 1 0))
    (defn nss-band-normalize ()
        (if (str_eq (tn-en 42) "forty-two") 1 0))
    (defn nss-band-g2p ()
        (if (and (eq (g2p-lookup 1 (list 10 20 30)) 10)
                 (eq (g2p-lookup 3 (list 10 20 30)) 30)) 1 0))
    (defn nss-band-timing ()
        (if (eq (pt-duration (list 1 4)) 8) 1 0))
    (defn nss-band-contour ()
        (pc-rises? 5 2))
    (defn nss-band-phrasing ()
        (if (gt (vph-break (list 1)) (vph-break (list 5))) 1 0))
    (defn nss-band-prosody ()
        (vp-honest-uncertainty? (list 1 5 3 0)))
    (defn nss-band-speaker ()
        (se-confident? (nss-band-qA) (nss-band-roster) 50 10))
    (defn nss-band-receipt ()
        (nss-receipt (nss-band-stt)
                     (nss-band-wer)
                     (nss-band-normalize)
                     (nss-band-g2p)
                     (nss-band-timing)
                     (nss-band-contour)
                     (nss-band-phrasing)
                     (nss-band-prosody)
                     (nss-band-speaker)))

    (defn native-speech-stack-band ()
        (add
            (add
                (add
                    (add (nss-band-score (eq (nss-band-stt) 1) 1)
                         (nss-band-score (eq (nss-band-wer) 1) 2))
                    (add (nss-band-score (eq (sa-accuracy (nss-band-halluc) (nss-band-truth)) 0) 4)
                         (nss-band-score (eq (nss-band-normalize) 1) 8)))
                (add
                    (add (nss-band-score (eq (nss-band-g2p) 1) 16)
                         (nss-band-score (eq (nss-band-timing) 1) 32))
                    (add (nss-band-score (eq (nss-band-contour) 1) 64)
                         (nss-band-score (eq (nss-band-phrasing) 1) 128))))
            (add (add (nss-band-score (eq (nss-band-prosody) 1) 256)
                      (nss-band-score (eq (nss-band-speaker) 1) 512))
                 (nss-band-score (eq (nss-ready? (nss-band-receipt)) 1) 1024))))

    (native-speech-stack-band))
