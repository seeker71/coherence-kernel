(do
  (defn cprlwb-every-live? (workflows)
    (if (eq (len workflows) 0) 1
      (do (let workflow (head workflows))
          (let source (nth workflow 2))
          (let syntax (nth workflow 3))
          (let semantics (nth workflow 4))
          (let admission (nth workflow 5))
          (let negative (nth workflow 6))
          (let coverage (nth workflow 7))
          (let world (nth workflow 8))
          (if (and (gt (nth source 8) 0)
                (and (gt (nth source 10) 0)
                (and (gt (nth syntax 2) 0)
                (and (gt (nth syntax 4) 0)
                (and (gt (nth syntax 6) 0)
                (and (gt (nth semantics 2) 0)
                (and (eq (nth semantics 2) (nth semantics 4))
                (and (eq (nth admission 2) 1)
                (and (eq (nth negative 6) 1)
                (and (eq (nth negative 10) 1)
                (and (eq (nth negative 12) 1)
                (and (eq (nth coverage 2) 13)
                (and (eq (nth coverage 18) 13)
                (and (eq (nth coverage 24) 13)
                (and (eq (nth coverage 26) 13)
                     (eq (nth world 2) 1))))))))))))))))
            (cprlwb-every-live? (tail workflows)) 0))))

  (defn cprlwb-concepts (workflows)
    (if (eq (len workflows) 0) (empty)
      (cons (nth (nth (head workflows) 8) 6)
        (cprlwb-concepts (tail workflows)))))

  (defn concept-pl-real-life-workflows-band ()
    (do (let report (concept-pl-real-life-workflows-run))
        (let live (nth report 1))
        (let workflows (nth live 3))
        (let totals (nth report 2))
        (let world (nth report 3))
        (let concepts (cprlwb-concepts workflows))
        (add (if (eq (nth live 1) 6) 1 0)
          (add (if (eq (cprlwb-every-live? workflows) 1) 2 0)
          (add (if (eq (nth totals 2) 78) 4 0)
          (add (if (gt (nth totals 4) 70000) 8 0)
          (add (if (gt (nth totals 6) 15000) 16 0)
          (add (if (gt (nth totals 8) 13000) 32 0)
          (add (if (gt (nth totals 10) 1900) 64 0)
          (add (if (eq (nth totals 12) 650) 128 0)
          (add (if (eq (nth totals 14) 650) 256 0)
          (add (if (eq (nth totals 16) 78) 512 0)
          (add (if (eq (nth totals 18) 78) 1024 0)
          (add (if (eq (nth totals 20) 78) 2048 0)
          (add (if (eq (nth world 2) 6) 4096 0)
          (add (if (value_eq concepts (list 1466 1105 1142 5812 5119 6130)) 8192 0)
               (if (value_eq (cprlw-contracts) (list
                 (list "checkout-payment-card-validation" "luhn" "python" "account"
                   "4539 1488 0343 6467" "valid account number; authorize checkout")
                 (list "warehouse-inventory-lookup" "binary-search" "rust" "search"
                   "sorted SKUs [1004,1012,1049,1103,1180], target 1049"
                   "index 2; retrieve bin record")
                 (list "service-config-delimiter-validation" "matching-brackets" "c" "match"
                   "{worker:{queue:[1,2,3]}}" "balanced; accept configuration")
                 (list "rsa-modulus-key-audit" "prime-factors" "kotlin" "factor"
                   "3233" "factors [53,61]; flag deliberately small training key")
                 (list "sensor-telemetry-compression" "run-length-encoding" "javascript" "stream"
                   "SSSSSNNN" "5S3N; preserve eight sensor-state samples")
                 (list "warehouse-robot-navigation" "robot-simulator" "c" "grid"
                   "start=(7,3,north), commands=RAALAL" "finish=(9,4,west)"))) 16384 0)))))))))))))))))

  (concept-pl-real-life-workflows-band))
