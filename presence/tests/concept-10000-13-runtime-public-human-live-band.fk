; Production runtime consumes an attributed real Indonesian sentence and only
; admits the concept returned by its complete unprompted 10k content scan.
; expected: 127
; preludes: form/form-stdlib/core.fk presence/concept-10000-13-runtime.fk

(do
  (let address (concept-10000-13-runtime-run))
  (let human (nth address 9))
  (let detector (nth human 8))
  (let world (nth detector 3))
  (add
    (if (str_eq (nth human 1) "id") 1 0)
    (add (if (eq (nth human 2) 365975) 2 0)
      (add (if (str_eq (nth human 3) "hayabusa_future") 4 0)
        (add (if (str_eq (nth human 6) "human-contributed-unreviewed") 8 0)
          (add (if (str_eq (nth human 7) "Kameraku tahan air.") 16 0)
            (add (if (and (eq (nth world 1) 1)
                       (eq (nth world 3) 377)) 32 0)
              (if (eq (nth (nth address 8) 1) 255) 64 0)))))))
)
