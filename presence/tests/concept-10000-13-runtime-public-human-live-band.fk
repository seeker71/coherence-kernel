; Production runtime consumes an attributed real Indonesian sentence and only
; admits the concept returned by its complete unprompted 10k content scan.
; expected: 255
; preludes: form/form-stdlib/core.fk presence/concept-10000-13-runtime.fk

(do
  (let address (concept-10000-13-runtime-run))
  (let human (nth address 9))
  (let detector (nth human 8))
  (let world (nth detector 3))
  (let native-acoustic (nth address 10))
  (let native-decoder (nth address 11))
  (add
    (if (str_eq (nth human 1) "id") 1 0)
    (add (if (eq (nth human 2) 331311) 2 0)
      (add (if (str_eq (nth human 3) "umarsaid") 4 0)
        (add (if (str_eq (nth human 6) "human-contributed-unreviewed") 8 0)
          (add (if (str_eq (nth human 7)
            "Mary tidak punya teman bicara, tapi dia tidak merasa kesepian.") 16 0)
            (add (if (and (eq (nth world 1) 1)
                       (eq (nth world 3) 259)) 32 0)
              (add (if (eq (nth (nth address 8) 1) 511) 64 0)
                (if (and (eq (nth native-acoustic 4) 7633152)
                      (and (eq (nth native-acoustic 8) 2)
                        (and (eq (nth native-acoustic 10) 384)
                          (and (eq (nth native-decoder 4) 9506304)
                            (and (eq (nth native-decoder 16) 1)
                              (and (gt (nth native-decoder 14) 1.0)
                                (and (eq (nth native-decoder 20) 51865)
                                  (and (eq (nth native-decoder 22) 14194)
                                    (and (str_eq (nth native-decoder 24) " banana")
                                         (eq (nth native-decoder 28) 0))))))))) 128 0))))))))
)
