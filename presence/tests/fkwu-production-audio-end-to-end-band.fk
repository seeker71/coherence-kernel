; fkwu-production-audio-end-to-end-band -- real local personal lane contract.
;
; This band proves the local progress lane has no stand-in runtime and can use
; the current public-demo voice package as borrowed real data.
; import "presence/fkwu-production-audio-end-to-end.fk"

(do
    (defn fpae-band-score (ok bit) (if ok bit 0))
    (defn fkwu-production-audio-end-to-end-band ()
        (add
            (add
                (add
                    (fpae-band-score (str_eq (fpae-kind) "fkwu-production-audio-end-to-end") 1)
                    (fpae-band-score (str_eq (fpae-target-text) "Sema audio path is alive.") 2))
                (add
                    (fpae-band-score (str_eq (fpae-voice-wav) "audio-training-runs/current/voice-reference-package/voice.wav") 4)
                    (fpae-band-score (str_eq (fpae-output-wav) "audio-training-runs/current/fkwu-production-audio-end-to-end/production-audio.wav") 8)))
            (add
                (add
                    (fpae-band-score (eq (fpae-cli-ready?) 1) 16)
                    (fpae-band-score (eq (fpae-models-ready?) 1) 32))
                (add
                    (add
                        (fpae-band-score (eq (fpae-package-files-present?) 1) 64)
                        (fpae-band-score (eq (fpae-package-progress-authorized?) 1) 128))
                    (add
                        (add
                            (fpae-band-score (eq (fpae-ready-to-run?) 1) 256)
                            (fpae-band-score (str_eq (fpae-blocker) "none") 512))
                        (add
                            (add
                                (fpae-band-score (str_eq (fpae-status) "ready_to_execute_real_audio_cpp_borrowed_public_demo") 1024)
                                (fpae-band-score (str_eq (fpae-run-all-command-path) "audio-training-runs/current/fkwu-production-audio-end-to-end/run.command") 2048))
                            0))))))

    (fkwu-production-audio-end-to-end-band))
