; Real-video released-patch -> GCA -> geometry -> world framebuffer gate.
; Exact numeric visual output is provenance/effect evidence, never a semantic
; fixture label or complete native-visual-weights claim.
; expected: 32767
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/geometric-camera.fk model/lingbot-pytorch-checkpoint.fk model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk model/lingbot-geometry-heads.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk model/lingbot-map-runtime.fk model/lingbot-learned-patch.fk model/lingbot-learned-map-runtime.fk observe/framebuffer-runtime-observation.fk observe/framebuffer-runtime-world.fk presence/lingbot-learned-map-observed-live.fk

(do
  (defn llmolb-bit (ok bit) (if ok bit 0))
  (defn llmolb-close? (actual expected)
    (lt (abs (sub actual expected)) 0.000000000001))
  (defn llmolb-event-values (report i) (nth (nth (fbro-events report) i) 3))
  (defn llmolb-stage? (report i name metric value)
    (do (let values (llmolb-event-values report i))
        (and (str_eq (nth values 2) name)
          (and (str_eq (nth values 11) metric) (eq (nth values 12) value)))))

  (defn lingbot-learned-map-observed-live-band ()
    (do
      (let run (lingbot-learned-map-observed-live-run))
      (let source (nth run 1))
      (let weights (nth run 2))
      (let learned (nth run 3))
      (let fingerprints (nth learned 4))
      (let gca (nth run 4))
      (let geometry (nth run 5))
      (let world-row (nth run 6))
      (let truth (nth run 7))
      (let report (nth run 8))
      (let runtime-world (nth run 9))
      (let resources (fbro-resources report))
      (let bottleneck (fbro-bottleneck report "boxed-floats"))
      (sum (list
        (llmolb-bit (and (str_eq (head run) "lingbot-learned-map-observed-live")
          (and (eq (nth source 3) 1581923)
            (and (eq (nth source 5) 1)
                 (value_eq (nth source 7) (list 518 294 518 294))))) 1)
        (llmolb-bit (and (eq (nth weights 2) 1)
          (and (eq (nth weights 4) 603136)
            (and (eq (nth weights 6) 3386682685)
                 (eq (nth weights 8) 2077575075)))) 2)
        (llmolb-bit (and (value_eq (nth learned 2) (list 1024 1024))
          (and (llmolb-close? (nth (nth fingerprints 0) 0)
                 0.12222902429764307)
               (llmolb-close? (nth (nth fingerprints 1) 8)
                 -5.2784386886527592))) 4)
        (llmolb-bit (and (eq (len (nth gca 2)) 4)
          (and (llmolb-close? (nth gca 6) 0.21510655547983293)
            (and (eq (nth gca 8) 36) (eq (len (nth gca 10)) 2)))) 8)
        (llmolb-bit (and (eq (nth geometry 2) 64)
          (and (eq (nth geometry 4) 64)
            (and (eq (nth geometry 6) 2385740)
                 (eq (nth geometry 8) 284311)))) 16)
        (llmolb-bit (and (eq (nth world-row 2) 64)
          (eq (nth world-row 4) 0)) 32)
        (llmolb-bit (value_eq truth
          (list "strict-truth" "released-patch-projection" 1
            "DINO-24-blocks" 0 "learned-GCA" 0 "learned-pose-depth" 0
            "native-visual-weights" 0)) 64)
        (llmolb-bit (and (str_eq (head report) "framebuffer-runtime-observation")
          (and (eq (len (fbro-events report)) 8)
            (and (str_eq (nth (fbro-outcome report) 1)
              "released-patch-to-world-observed-full-visual-parity-held")
              (eq (fbro-trace-first? report) 1)))) 128)
        (llmolb-bit (and (eq (fbrw-resource-number resources "input-bytes" 0)
              1581923)
          (and (gt (fbrw-resource-number resources "dispatches" 0) 1000000)
               (gt (fbrw-resource-number resources "boxed-floats" 0) 1000000))) 256)
        (llmolb-bit (and (llmolb-stage? report 1 "frames-decoded" "frames" 2)
          (and (llmolb-stage? report 2 "released-patch-weights"
                 "released-parameters" 603136)
            (llmolb-stage? report 3 "released-patch-projection"
              "released-parameters" 603136))) 512)
        (llmolb-bit (and (llmolb-stage? report 4 "operational-gca"
              "retained-kv-rows" 36)
          (and (llmolb-stage? report 5 "classical-geometry-cloud"
                 "cloud-points" 64)
            (llmolb-stage? report 6 "native-world-projection"
              "generic-objects" 64))) 1024)
        (llmolb-bit (and (gt (fbro-event-number (nth (fbro-events report) 1)
              "io-sense-dispatches") 0)
          (gt (fbro-event-number (nth (fbro-events report) 3)
              "boxed-floats") 1000000)) 2048)
        (llmolb-bit (and (gt (nth bottleneck 1) 1000000)
          (str_eq (nth bottleneck 2) "released-patch-projection")) 4096)
        (llmolb-bit (and (str_eq (head runtime-world) "framebuffer-world-update")
          (and (eq (len (nth runtime-world 2)) 7)
            (and (str_eq (nth (head (nth runtime-world 2)) 0) "runtime-event")
              (and (str_eq (nth (nth (nth runtime-world 2) 1) 0) "runtime-stage")
                (str_eq (head (nth runtime-world 3))
                  "framebuffer-focus"))))) 8192)
        (llmolb-bit (and (value_eq (nth (fbro-where report) 1)
              (list "presence/lingbot-learned-map-observed-live.fk" 1 1))
          (and (gt (nth (fbro-when report) 1) 1700000000000)
            (and (eq (nth world-row 4) 0)
                 (eq (nth truth 10) 0)))) 16384)))))

  (lingbot-learned-map-observed-live-band)
)
