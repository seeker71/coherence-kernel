; preludes: observe/stt-wer.fk presence/formant-vocoder.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk presence/macos-sema-voice-local-oracle-carrier.fk
;
; macos-sema-voice-local-oracle-carrier-band -- Sema target live carrier contract.
;
; Verdict 2047:
;   1     render command names ffmpeg + aevalsrc
;   2     render command carries Sema target f0/formants
;   4     generated sample row is local and audio-consistent
;   8     exact local oracle transcript can pass the Sema STT bar
;   16    punctuation-only transcript remains measurable but fails success
;   32    failing transcript routes oracle-guide
;   64    verdict records honest oracle-guide when the bar is missed
;   128   field code records WER 100 and oracle-guide
;   256   receipt preserves local oracle, device, and audio hash
;   512   receipt keeps native Form true and neural vocoder pending
;   1024  local Mac/Whisper identity is explicit

(do
    (defn msvlc-band-score (cond bit) (if cond bit 0))
    (defn msvlc-band-good-row () (msvlc-row-from 981777 (msvlc-text) 0 0 0))
    (defn msvlc-band-punct-row () (msvlc-row-from 981778 "." 0 0 0))
    (defn msvlc-band-punct-rec () (msvlc-receipt (msvlc-band-punct-row)))
    (defn msvlc-band-good-rec () (msvlc-receipt (msvlc-band-good-row)))
    (defn msvlc-band-command () (msvlc-render-command (svsl-target) "/tmp/sema-formant-target.wav"))

    (defn msvlc-band-command-score ()
        (add
            (msvlc-band-score (and (ge (str_find (msvlc-band-command) "ffmpeg" 0) 0)
                                   (ge (str_find (msvlc-band-command) "aevalsrc" 0) 0)) 1)
            (msvlc-band-score
                (and (ge (str_find (msvlc-band-command) "165" 0) 0)
                     (and (ge (str_find (msvlc-band-command) "500" 0) 0)
                          (and (ge (str_find (msvlc-band-command) "900" 0) 0)
                               (ge (str_find (msvlc-band-command) "2500" 0) 0)))) 2)))

    (defn msvlc-band-row-score ()
        (add
            (add
                (msvlc-band-score (and (eq (svlor-control-clean? (msvlc-band-good-row)) 1)
                                       (eq (svlor-audio-consistent? (msvlc-band-good-row)) 1)) 4)
                (msvlc-band-score (eq (svlor-oracle-success? (msvlc-band-good-row) (msvlc-max-wer)) 1) 8))
            (add
                (msvlc-band-score (and (eq (svlor-valid? (msvlc-band-punct-row)) 1)
                                       (eq (svlor-oracle-success? (msvlc-band-punct-row) (msvlc-max-wer)) 0)) 16)
                (msvlc-band-score (str_eq (svlor-rec-route (msvlc-band-punct-rec)) "oracle-guide") 32))))

    (defn msvlc-band-receipt-score ()
        (add
            (add
                (msvlc-band-score (eq (msvlc-verdict (msvlc-band-punct-row) (msvlc-band-punct-rec)) 479) 64)
                (msvlc-band-score (eq (msvlc-field-code (msvlc-band-punct-row) (msvlc-band-punct-rec)) 110100002) 128))
            (add
                (msvlc-band-score
                    (and (str_eq (svlor-rec-oracle (msvlc-band-good-rec)) (msvlc-oracle))
                         (and (str_eq (svlor-rec-device (msvlc-band-good-rec)) (msvlc-device))
                              (eq (svlor-rec-audio-hash (msvlc-band-good-rec)) 981777))) 256)
                (add
                    (msvlc-band-score
                        (and (eq (svlor-rec-native-form (msvlc-band-good-rec)) 1)
                             (eq (svlor-rec-neural-vocoder (msvlc-band-good-rec)) 0)) 512)
                    (msvlc-band-score
                        (and (str_eq (msvlc-oracle) "whisper.cpp-large-v3-turbo")
                             (str_eq (msvlc-device) "macos-arm64-m4-max")) 1024)))))

    (defn macos-sema-voice-local-oracle-carrier-band ()
        (add
            (add (msvlc-band-command-score) (msvlc-band-row-score))
            (msvlc-band-receipt-score)))

    (macos-sema-voice-local-oracle-carrier-band))
