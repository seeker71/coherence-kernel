; preludes: observe/stt-wer.fk presence/formant-vocoder.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk presence/macos-sema-voice-teacher-carrier.fk
;
; macos-sema-voice-teacher-carrier-band -- local say/Whisper teacher contract.
;
; Verdict 4095:
;   1     row names the teacher carrier
;   2     audio hash is carried
;   4     exact transcript passes the local STT bar
;   8     row refuses native authority
;   16    lowered Sema local-oracle row is valid
;   32    lowered row passes oracle success
;   64    local oracle identity is preserved
;   128   local device identity is preserved
;   256   render command uses local say
;   512   whisper command uses local whisper-cli
;   1024  missing transcript fails the bar
;   2048  missing audio hash fails validity

(do
    (defn mstc-band-score (cond bit) (if cond bit 0))
    (defn mstc-band-good () (mstc-row-from 983777 "Flo (English (US))" 983777 (mstc-text)))
    (defn mstc-band-empty () (mstc-row-from 983778 "Flo (English (US))" 983778 ""))
    (defn mstc-band-no-audio () (mstc-row-from 983779 "Flo (English (US))" 0 (mstc-text)))

    (defn macos-sema-voice-teacher-carrier-band ()
        (do
            (let good (mstc-band-good))
            (let empty (mstc-band-empty))
            (let no-audio (mstc-band-no-audio))
            (let c0 (mstc-band-score (str_eq (mstc-row-kind good) "macos-sema-voice-teacher-row") 1))
            (let c1 (mstc-band-score (eq (mstc-row-hash good) 983777) 2))
            (let c2 (mstc-band-score (and (eq (mstc-row-wer good) 0)
                                          (eq (mstc-row-pass good) 1)) 4))
            (let c3 (mstc-band-score (str_eq (mstc-row-authority good) "host-teacher-not-native-authority") 8))
            (let c4 (mstc-band-score (eq (svlor-valid? (mstc-row-svlor good)) 1) 16))
            (let c5 (mstc-band-score (eq (svlor-oracle-success? (mstc-row-svlor good) (mstc-max-wer)) 1) 32))
            (let c6 (mstc-band-score (str_eq (svlor-oracle-name (mstc-row-svlor good)) (mstc-oracle)) 64))
            (let c7 (mstc-band-score (str_eq (svlor-device (mstc-row-svlor good)) (mstc-device)) 128))
            (let c8 (mstc-band-score (ge (str_find (mstc-say-command "Flo (English (US))" "/tmp/a.aiff" (mstc-text)) "say" 0) 0) 256))
            (let c9 (mstc-band-score (ge (str_find (mstc-whisper-command "/tmp/a.wav") "whisper-cli" 0) 0) 512))
            (let c10 (mstc-band-score (and (eq (mstc-row-pass empty) 0)
                                           (eq (svlor-valid? (mstc-row-svlor empty)) 0)) 1024))
            (let c11 (mstc-band-score (eq (svlor-valid? (mstc-row-svlor no-audio)) 0) 2048))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) (add c10 c11)))))

    (macos-sema-voice-teacher-carrier-band))
