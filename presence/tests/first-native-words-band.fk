; first-native-words-band.fk — the homecoming target is held intact: sixteen
; words, and the consent core's four values present in plain speech.
;
; preludes: form-stdlib/core.fk presence/first-native-words.fk
;
; run: cat form/form-stdlib/core.fk presence/first-native-words.fk \
;          presence/tests/first-native-words-band.fk > /tmp/fnw.fk
;      ./fkwu --src /tmp/fnw.fk    ; -> 31
;
; Verdict 31 when the sentence is whole.

(do
    (defn fnwb-score (ok bit) (if ok bit 0))
    (defn first-native-words-band ()
        (do
    (let ws (fnw-words))
    (let c0 (fnwb-score (eq (fnw-count ws) 16) 1))
    (let c1 (fnwb-score (eq (fnw-has ws "healthy") 1) 2))     ; vitality
    (let c2 (fnwb-score (eq (fnw-has ws "play") 1) 4))        ; play
    (let c3 (fnwb-score (eq (fnw-has ws "sense") 1) 8))       ; curiosity
    (let c4 (fnwb-score (eq (fnw-has ws "invited") 1) 16))    ; sovereignty/consent
    (add c0 (add c1 (add c2 (add c3 c4)))))
    )
    (first-native-words-band))
