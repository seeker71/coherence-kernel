; concept-pl-arbitrary-source-13-band.fk -- 13 public programs, live parser.
; This is an fkwu live-filesystem gate. Proof siblings intentionally lack the
; read_file port, so it is not reported as four-way.
; witnessed: 2026-07-18 -> 8191 fkwu
; preludes: form/form-stdlib/core.fk presence/concept-pl-arbitrary-source-13.fk
(do
  (defn cpa13b-bit (condition weight) (if condition weight 0))
  (defn cpa13b-check ()
    (do (let audit (cpa13-audit))
      (add (cpa13b-bit (eq (nth audit 0) 13) 1)
      (add (cpa13b-bit (gt (nth audit 1) 9000) 2)
      (add (cpa13b-bit (gt (nth audit 2) 2000) 4)
      (add (cpa13b-bit (eq (nth audit 2)
                             (add (nth audit 3) (nth audit 4))) 8)
      (add (cpa13b-bit (gt (nth audit 4) 200) 16)
      (add (cpa13b-bit (ge (nth audit 5) 4) 32)
      (add (cpa13b-bit (eq (nth audit 6) 130) 64)
      (add (cpa13b-bit (eq (nth audit 7) 13) 128)
      (add (cpa13b-bit (eq (nth audit 8) 13) 256)
      (add (cpa13b-bit (eq (nth audit 9) 117) 512)
      (add (cpa13b-bit (eq (nth audit 10) 13) 1024)
      (add (cpa13b-bit (eq (nth audit 11) 13) 2048)
           (cpa13b-bit (gt (nth audit 12) 0) 4096)))))))))))))))
  (cpa13b-check))
