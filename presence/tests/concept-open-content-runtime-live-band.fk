; concept-open-content-runtime-live-band.fk -- one independently sensed address.
;
; The companion scenario gates provide broad real-life coverage.  This direct
; gate proves that one arbitrary address joins content-derived text, audio, and
; generated video with real JavaScript execution and persistent world views.
; expected: 1023
; witnessed: 2026-07-18 -> 1023 live; three independent content world views
; preludes: form/form-stdlib/core.fk presence/concept-open-content-runtime.fk

(do
  (let row (concept-open-content-runtime-run
    537 "en" "javascript" 7 "-content-door"))
  (let text-row (nth row 2))
  (let audio-row (nth row 3))
  (let video-row (nth row 4))
  (let program-row (nth row 5))
  (let world-row (nth row 6))
  (let verdict (nth row 7))
  (let audio-evidence (nth audio-row 8))
  (let video-evidence (nth video-row 8))
  (add
    (if (eq (nth text-row 9) 1) 1 0)
    (add (if (eq (nth audio-row 6) 1) 2 0)
      (add (if (eq (nth video-row 4) 1) 4 0)
        (add (if (eq (nth program-row 8) 1) 8 0)
          (add (if (str_eq (nth program-row 12) "passed") 16 0)
            (add (if (eq (nth world-row 2) 3) 32 0)
              (add (if (eq (nth world-row 4) 3) 64 0)
                (add (if (eq (nth verdict 10) 1) 128 0)
                  (add (if (eq (nth (nth audio-evidence 8) 8) 0) 256 0)
                       (if (eq (cvor-decoded-address-evidence
                                 (cvorl-result-evidence video-evidence)) 0)
                         512 0))))))))))
)
