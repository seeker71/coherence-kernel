; concept-video-content-sensing-live-band.fk -- macOS real-pixel acceptance.
; expected on the witnessed macOS carrier: 511
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/lingbot-vision-input.fk model/concept-video-semantic.fk model/concept-video-content-sensing.fk model/concept-world-model.fk presence/concept-video-semantic-live.fk presence/concept-video-content-sensing-live.fk

(do
  (defn cvvslb-bit (ok bit) (if ok bit 0))
  (defn concept-video-content-sensing-live-check ()
    (do (let live (concept-video-content-sensing-live-run))
        (let carrier (nth live 1))
        (let decoded (nth live 2))
        (let raw (nth live 3))
        (let band (nth live 4))
        (let negative (nth live 5))
        (let world (nth live 6))
        (let office (nth (nth raw 3) 1))
        (let university (nth (nth raw 4) 1))
        (let courthouse (nth (nth raw 5) 1))
        (add
          (cvvslb-bit (and (eq (nth carrier 1) 1) (eq (nth carrier 2) 1)) 1)
          (add (cvvslb-bit (eq (nth decoded 1) 4) 2)
            (add (cvvslb-bit (and (eq (nth decoded 4) 12) (eq (nth decoded 6) 16)) 4)
              (add (cvvslb-bit (eq (nth raw 1) 3) 8)
                (add (cvvslb-bit (eq (nth band 1) 3) 16)
                  (add (cvvslb-bit (eq (nth negative 5) 1) 32)
                    (add (cvvslb-bit (and (eq (nth world 1) 3) (eq (nth world 3) 3)) 64)
                      (add (cvvslb-bit (and (eq (nth office 0) 493)
                                            (and (eq (nth university 0) 1927)
                                                 (eq (nth courthouse 0) 9066))) 128)
                           (cvvslb-bit (and (eq (nth office 5) 0)
                                            (and (eq (nth university 5) 0)
                                                 (eq (nth courthouse 5) 0))) 256)))))))))))
  (concept-video-content-sensing-live-check))
