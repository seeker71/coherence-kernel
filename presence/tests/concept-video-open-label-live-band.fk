; preludes: form/form-stdlib/core.fk presence/concept-video-open-label-live.fk

(do
  (let result (concept-video-open-label-live-run))
  (let carrier (nth result 1))
  (let fixtures (nth result 2))
  (let positives (nth result 3))
  (let negative (nth result 4))
  (let observations (nth result 5))
  (add
    (if (eq (nth carrier 1) 1) 1 0)
    (add (if (eq (nth carrier 2) 1) 2 0)
      (add (if (eq (nth fixtures 1) 10) 4 0)
        (add (if (eq (nth fixtures 4) 10) 8 0)
          (add (if (eq (nth positives 1) 9) 16 0)
            (add (if (eq (nth positives 4) 9) 32 0)
              (add (if (eq (nth positives 7) 9) 64 0)
                (add (if (eq (nth negative 1) 1) 128 0)
                  (add (if (eq (len (nth observations 1)) 10) 256 0)
                       (if (and (eq (nth positives 10) 9)
                             (str_eq (nth (nth result 6) 2) "complete-10k-text-scan")) 512 0))))))))))
)
