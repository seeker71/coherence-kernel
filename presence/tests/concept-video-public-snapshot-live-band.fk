; concept-video-public-snapshot-live-band.fk -- public-photo content gate.
; expected: 4095
; preludes: form/form-stdlib/core.fk presence/concept-video-public-snapshot-live.fk

(do
  (let live (concept-video-public-snapshot-live-run))
  (let carrier (nth live 1))
  (let snapshot (nth live 2))
  (let targets (nth live 3))
  (let claims (nth live 4))
  (let audit (cvps-audit-summary-from-live live))
  (add (if (eq (nth carrier 1) 1) 1 0)
    (add (if (eq (nth carrier 2) 1) 2 0)
      (add (if (eq (nth snapshot 1) 24) 4 0)
        (add (if (eq (nth snapshot 3) 24) 8 0)
          (add (if (eq (nth snapshot 5) 24) 16 0)
            (add (if (eq (nth snapshot 7) 24) 32 0)
              (add (if (eq (nth targets 1) 24) 64 0)
                (add (if (eq (nth targets 3) 24) 128 0)
                  (add (if (eq (nth targets 5) 23) 256 0)
                    (add (if (eq (nth targets 7) 23) 512 0)
                      (add (if (and (eq (nth targets 9) 1)
                                 (eq (nth targets 11) 72)) 1024 0)
                        (if (and (eq (nth claims 3) 7)
                             (eq (nth (nth audit 4) 1) 0)) 2048 0))))))))))))
)
