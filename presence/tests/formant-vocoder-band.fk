; preludes: presence/formant-vocoder.fk
;
; formant-vocoder-band -- first native source-filter waveform witness.
;
; Verdict 511:
;   1    frame accessors hold duration
;   2    voiced frame renders expected length
;   4    voiced source alternates by pitch period
;   8    unvoiced source is deterministic but different
;   16   rendering concatenates frame durations
;   32   rendered energy equals frame energy
;   64   formant color raises energy
;   128  voiced count is measured
;   256  fingerprint carries duration/energy/voicing/first phoneme

(do
    (defn fv-band-score (cond bit) (if cond bit 0))
    (defn fv-band-voiced () (fv-frame 1 4 2 10 100 200 0))
    (defn fv-band-noise () (fv-frame 2 3 2 10 101 200 1))
    (defn fv-band-plain () (fv-frame 1 4 2 10 0 0 0))
    (defn fv-band-colored () (fv-frame 1 4 2 10 100 200 0))
    (defn fv-band-frames () (list (fv-band-voiced) (fv-band-noise)))

    (defn formant-vocoder-band ()
        (do
            (let voiced (fv-render-frame (fv-band-voiced)))
            (let noise (fv-render-frame (fv-band-noise)))
            (let rendered (fv-render (fv-band-frames)))
            (let fp (fv-fingerprint (fv-band-frames)))
            (let c0 (fv-band-score (eq (fv-duration (fv-band-voiced)) 4) 1))
            (let c1 (fv-band-score (eq (len voiced) 4) 2))
            (let c2 (fv-band-score (and (gt (nth voiced 0) 0) (lt (nth voiced 1) 0)) 4))
            (let c3 (fv-band-score (and (eq (len noise) 3) (not (eq (nth noise 0) (nth voiced 0)))) 8))
            (let c4 (fv-band-score (eq (len rendered) (fv-total-duration (fv-band-frames))) 16))
            (let c5 (fv-band-score (eq (fv-energy rendered) (fv-total-energy (fv-band-frames))) 32))
            (let c6 (fv-band-score (gt (fv-frame-energy (fv-band-colored)) (fv-frame-energy (fv-band-plain))) 64))
            (let c7 (fv-band-score (eq (fv-voiced-count (fv-band-frames)) 1) 128))
            (let c8 (fv-band-score
                (and (eq (nth fp 0) 7)
                     (and (eq (nth fp 1) (fv-total-energy (fv-band-frames)))
                          (and (eq (nth fp 2) 1) (eq (nth fp 3) 1))))
                256))
            (add (add (add (add c0 c1) (add c2 c3))
                      (add (add c4 c5) (add c6 c7)))
                 c8)))
    (formant-vocoder-band))
