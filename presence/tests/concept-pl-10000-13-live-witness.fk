; concept-pl-10000-13-live-witness.fk — emit the real full audit and samples.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk

(do
  (defn cp10lw-row (corpus semantic-index payload language id)
    (do
      (let source (cp10-generate-in corpus semantic-index payload language id))
      (let recovered (cp10-recover-source-in corpus semantic-index payload source))
      (list id language
        (c10-concept-label (c10-concept-at-in corpus id))
        (cs10-method-label (cs10-at-in semantic-index payload id))
        (cp13-output (nth recovered 4))
        (cp10-hash-text source)
        (len recovered))))
  (defn concept-pl-10000-13-live-witness ()
    (do
      (let corpus (read_file (c10-ranked-path)))
      (let semantic-index (read_file (cs10-index-path)))
      (let payload (read_file (cs10-payload-path)))
      (list (cp10-audit-in corpus semantic-index payload)
        (cp10lw-row corpus semantic-index payload "javascript" 227)
        (cp10lw-row corpus semantic-index payload "go" 377)
        (cp10lw-row corpus semantic-index payload "rust" 751)
        (cp10lw-row corpus semantic-index payload "ruby" 1927)
        (cp10lw-row corpus semantic-index payload "php" 6196)
        (cp10lw-row corpus semantic-index payload "swift" 9999))))
  (concept-pl-10000-13-live-witness))
