; fkwu-local-audio-loop-band -- fast contract for the practical local loop.
;
; This band does not invoke host audio tools. It proves the Form-owned wiring:
; bounded translation command, file-fed TTS command, clean ASR command, JSON
; request shape, WER scoring, and the all-clear score surface.
; import "presence/fkwu-local-audio-loop.fk"

(do
    (defn flal-band-bit (ok bit) (if ok bit 0))
    (defn fkwu-local-audio-loop-band ()
        (do
            (let request (flal-translation-request-json "Open speech flows."))
            (let say-cmd (flal-say-file-command "Samantha" "/tmp/source.txt" "/tmp/source.aiff"))
            (let ff-cmd (flal-ffmpeg-command "/tmp/source.aiff" "/tmp/source.wav"))
            (let wh-cmd (flal-whisper-command "/tmp/model.bin" "/tmp/source.wav" "en"))
            (let tx-cmd (flal-translation-command "/tmp/request.json"))
            (let score (flal-score-from
                            1 1 1 1
                            "Open speech flows."
                            0
                            "Offene Rede fliesst."
                            1
                            "Offene Rede fliesst."
                            0
                            1))
            (add
                (add
                    (add
                        (flal-band-bit (gt (str_len request) 200) 1)
                        (flal-band-bit (str_eq (flal-json-string "ab") "\"ab\"") 2))
                    (add
                        (flal-band-bit (str_eq say-cmd "say -v 'Samantha' -o '/tmp/source.aiff' -f '/tmp/source.txt'") 4)
                        (flal-band-bit (str_eq ff-cmd "ffmpeg -hide_banner -loglevel error -y -i '/tmp/source.aiff' -ar 16000 -ac 1 -c:a pcm_s16le '/tmp/source.wav'") 8)))
                (add
                    (add
                        (flal-band-bit (str_eq wh-cmd "whisper-cli -m '/tmp/model.bin' -f '/tmp/source.wav' -l en -nt -np 2>/dev/null | tr '\\n' ' ' | head -c 500") 16)
                        (flal-band-bit (gt (str_len tx-cmd) 100) 32))
                    (add
                        (add
                            (flal-band-bit (str_eq (flal-status 1 0 "Offene Rede fliesst." 0)
                                                   "functional_local_talk_listen_translate_loop") 64)
                            (flal-band-bit (str_eq (flal-failing-gate 1 0 "Offene Rede fliesst." 0)
                                                   "none") 128))
                        (add
                            (add
                                (flal-band-bit (eq score 16383) 256)
                                (flal-band-bit (eq (flal-wer "Open speech flows." (flal-source-text)) 0) 512))
                            (add
                                (flal-band-bit (str_eq (flal-source-wav-path)
                                                       "audio-training-runs/current/fkwu-local-audio-loop/source.wav") 1024)
                                (add
                                    (flal-band-bit (str_eq (flal-translation-oracle) "ollama:llama3.2:1b") 2048)
                                    (add
                                        (flal-band-bit (str_eq (flal-trim " \nOpen speech flows. \n")
                                                               "Open speech flows.") 4096)
                                        (flal-band-bit (str_eq (flal-kind) "fkwu-local-audio-loop") 8192)))))))))

    (fkwu-local-audio-loop-band))
