; Native paired-surface grammar induction acceptance band.
; expected: 32767
; preludes: form/form-stdlib/core.fk form/form-stdlib/bmf-core.fk form/form-stdlib/bmf-grammar.fk model/pl-grammar-induction.fk observe/framebuffer-runtime-observation.fk presence/pl-grammar-induction-observed-live.fk

(do
  (defn plgiob-bit (ok bit) (if ok bit 0))
  (defn plgiob-stage? (report i name metric value)
    (do
      (let values (nth (nth (fbro-events report) i) 3))
      (if (and (str_eq (nth values 2) name)
            (and (str_eq (nth values 11) metric)
                 (eq (nth values 12) value))) 1 0)))
  (defn pl-grammar-induction-observed-live-band ()
    (do
      (let python-scan (plgi-scan "warehouse_reorder_point = 314159"))
      (let go-scan (plgi-scan "remainingInventory := 271828"))
      (let python-induction (plgi-python-induction))
      (let go-induction (plgi-go-induction))
      (let python-candidates (plgi-induction-candidates python-induction))
      (let go-candidates (plgi-induction-candidates go-induction))
      (let python-exact (nth python-candidates 0))
      (let python-typed (nth python-candidates 1))
      (let python-any (nth python-candidates 2))
      (let go-exact (nth go-candidates 0))
      (let python-rule (plgi-induced-rule python-induction))
      (let go-rule (plgi-induced-rule go-induction))
      (let python-grammar (plgi-rule-grammar python-rule))
      (let run (pl-grammar-induction-observed-live-run))
      (let heldout (nth run 3))
      (let python-ir (nth heldout 2))
      (let go-ir (nth heldout 4))
      (let emission (nth run 4))
      (let truth (nth run 5))
      (let report (nth run 6))
      (sum (list
        (plgiob-bit (and (plgi-scan-ok? python-scan)
          (and (eq (len (plgi-scan-tokens python-scan)) 3)
            (and (str_eq (plgi-token-kind
                    (nth (plgi-scan-tokens python-scan) 0)) "identifier")
                 (str_eq (plgi-token-text
                    (nth (plgi-scan-tokens python-scan) 2)) "314159")))) 1)
        (plgiob-bit (and (plgi-scan-ok? go-scan)
          (and (eq (len (plgi-scan-tokens go-scan)) 3)
               (str_eq (plgi-token-text
                 (nth (plgi-scan-tokens go-scan) 1)) ":="))) 2)
        (plgiob-bit (and (str_eq (plgi-candidate-name python-exact)
              "exact-training-row")
          (and (eq (plgi-candidate-coverage python-exact) 1)
               (eq (plgi-candidate-coverage go-exact) 1))) 4)
        (plgiob-bit (and (str_eq (plgi-candidate-name python-typed)
              "minimal-typed-skeleton")
          (and (eq (plgi-candidate-coverage python-typed) 2)
            (and (eq (plgi-candidate-cost python-typed) 6)
              (and (eq (plgi-rule-coverage python-rule) 2)
                   (eq (plgi-rule-cost go-rule) 7))))) 8)
        (plgiob-bit (and (str_eq (plgi-candidate-name python-any)
              "untyped-any-token")
          (and (eq (plgi-candidate-coverage python-any) 2)
               (eq (plgi-candidate-faithful python-any) 0))) 16)
        (plgiob-bit (and (eq (nth truth 6) 1)
          (and (eq (plgi-rule-contains? python-rule "retry_budget") 0)
            (and (eq (plgi-rule-contains? python-rule "batch_limit") 0)
              (and (eq (plgi-rule-contains? go-rule "retryBudget") 0)
                   (eq (plgi-rule-contains? go-rule "batchLimit") 0))))) 32)
        (plgiob-bit (and (str_eq (g-start python-grammar)
              "induced-assignment")
          (and (not (nil? (g-rule python-grammar "induced-assignment")))
               (str_eq (head (r3-pat
                 (g-rule python-grammar "induced-assignment"))) "seq"))) 64)
        (plgiob-bit (value_eq python-ir
          (plgi-ir-assign "warehouse_reorder_point" 314159)) 128)
        (plgiob-bit (value_eq go-ir
          (plgi-ir-assign "remainingInventory" 271828)) 256)
        (plgiob-bit (str_eq (nth emission 1)
          "warehouse_reorder_point := 314159") 512)
        (plgiob-bit (str_eq (nth emission 2)
          "remainingInventory = 271828") 1024)
        (plgiob-bit (and (eq (plgi-ir-value python-ir) 314159)
          (and (eq (plgi-ir-value go-ir) 271828)
            (and (eq (plgi-rule-contains? python-rule "314159") 0)
                 (eq (plgi-rule-contains? go-rule "271828") 0)))) 2048)
        (plgiob-bit (value_eq (plgi-parse python-rule "314159 = 2")
          (list "parse-rejected" "invalid-identifier")) 4096)
        (plgiob-bit (and
          (value_eq (plgi-parse python-rule "valid_name := 2")
            (list "parse-rejected" "grammar-mismatch"))
          (value_eq (plgi-parse go-rule "validName = 2")
            (list "parse-rejected" "grammar-mismatch"))) 8192)
        (plgiob-bit (and
          (value_eq (plgi-emit python-rule
            (list "neutral-typed-ir" "assign"
              (list "identifier" "x") (list "string" "two")))
            (list "emit-rejected" "typed-ir-required"))
          (and (eq (fbro-trace-first? report) 1)
            (and (eq (len (fbro-events report)) 8)
              (and (plgiob-stage? report 1 "paired-surfaces-observed"
                    "paired-programs" 4)
                (and (plgiob-stage? report 2 "minimal-rules-selected"
                      "candidate-rules-evaluated" 6)
                  (and (plgiob-stage? report 3 "bmf-grammars-materialized"
                        "executable-grammar-values" 2)
                    (and (plgiob-stage? report 4 "held-out-programs-parsed"
                          "held-out-programs" 2)
                      (and (plgiob-stage? report 5 "target-programs-emitted"
                            "cross-language-programs" 2)
                           (plgiob-stage? report 6
                             "row-memorization-rejected"
                             "retained-training-values" 0))))))))) 16384)))))

  (pl-grammar-induction-observed-live-band)
)
