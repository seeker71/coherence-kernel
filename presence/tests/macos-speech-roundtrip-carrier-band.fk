; macos-speech-roundtrip-carrier-band -- Form carrier contract, no host tools.
;
; Verdict 511 when the Form carrier owns prompt data, tokenization, command
; lowering, path construction, and local-tool readiness remains a Form query.

(do
    (defn masr-band-score (ok bit) (if ok bit 0))
    (defn masr-band-tokens () (masr-tokens "The board is clear. Nothing is waiting."))
    (defn masr-band-punct () (masr-tokens "Alle, FRAGEN!"))
    (defn macos-speech-roundtrip-carrier-band ()
        (do
            (let toks (masr-band-tokens))
            (let punct (masr-band-punct))
            (let p (masr-board))
            (let out "/tmp/sema-band")
            (let say-cmd (masr-say-command "Samantha" "/tmp/a.aiff" "hello"))
            (let ff-cmd (masr-ffmpeg-command "/tmp/a.aiff" "/tmp/a.wav"))
            (let wh-cmd (masr-whisper-command "/tmp/model.bin" "/tmp/a.wav" "en"))
            (add
                (add
                    (add
                        (masr-band-score (eq (len toks) 7) 1)
                        (masr-band-score (str_eq (head toks) "the") 2))
                    (add
                        (masr-band-score (str_eq (nth toks 6) "waiting") 4)
                        (masr-band-score (and (str_eq (head punct) "alle")
                                              (str_eq (nth punct 1) "fragen")) 8)))
                (add
                    (add
                        (masr-band-score (eq (str_find say-cmd "say -v" 0) 0) 16)
                        (masr-band-score (ge (str_find ff-cmd "ffmpeg" 0) 0) 32))
                    (add
                        (masr-band-score (and (ge (str_find wh-cmd "whisper-cli" 0) 0)
                                              (lt (str_find ff-cmd "audio-locale-native-sample" 0) 0)) 64)
                        (add
                            (masr-band-score (str_eq (masr-wav-path p "en" "eval" out)
                                                     "/tmp/sema-band/hatiSuci-board-empty-en-eval.wav") 128)
                            (masr-band-score (str_eq (masr-oracle) "whisper.cpp-large-v3-turbo") 256)))))))

    (macos-speech-roundtrip-carrier-band))
