; fkwu-audio-task-surface-band -- pure task-surface contract.
;
; This band does not invoke host tools or require live artifacts. It proves that
; the local audio loop stages lower into typed speech-task/result cells, and
; that the next live adapter gap is explicitly named.
; import "presence/fkwu-audio-task-surface.fk"

(do
    (defn fats-band-score (ok bit) (if ok bit 0))
    (defn fkwu-audio-task-surface-band ()
        (do
            (let source-tts (fats-local-source-tts-task))
            (let source-asr (fats-local-source-asr-task))
            (let translation (fats-local-translation-task))
            (let reply-tts (fats-local-reply-tts-task))
            (let reply-asr (fats-local-reply-asr-task))
            (let source-asr-result (fats-local-source-asr-result "Open speech flows."))
            (let stream (stc-result-stream source-asr-result))
            (add
                (add
                    (add
                        (fats-band-score (eq (fats-local-task-contract-score) 31) 1)
                        (fats-band-score (eq (stc-op-allowed? "conversion") 1) 2))
                    (add
                        (fats-band-score (eq (stc-task-valid? source-tts) 1) 4)
                        (fats-band-score (eq (stc-task-valid? source-asr) 1) 8)))
                (add
                    (add
                        (fats-band-score (eq (stc-task-valid? translation) 1) 16)
                        (fats-band-score (eq (stc-task-valid? reply-tts) 1) 32))
                    (add
                        (add
                            (fats-band-score (eq (stc-task-valid? reply-asr) 1) 64)
                            (fats-band-score (str_eq (sts-transcript stream) "open speech flows") 128))
                        (add
                            (add
                                (fats-band-score (str_eq (fats-status (fats-score-max))
                                                         "local_loop_functional_audio_cpp_adapters_observed_not_swapped") 256)
                                (fats-band-score (str_eq (fats-next-gap (fats-score-max))
                                                         "swap audio.cpp ASR/TTS behind the same speech-task slots in the real local personal lane") 512))
                            (add
                                (fats-band-score (str_eq (fats-kind) "fkwu-audio-task-surface") 1024)
                                (fats-band-score (str_eq (fats-summary-path)
                                                         "audio-training-runs/current/fkwu-audio-task-surface/summary") 2048))))))))

    (fkwu-audio-task-surface-band))
