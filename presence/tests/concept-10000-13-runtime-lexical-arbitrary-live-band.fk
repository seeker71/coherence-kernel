; Production runtime consumes method-4 lexical meaning and arbitrary public PL.
; expected: 255
; preludes: form/form-stdlib/core.fk presence/concept-10000-13-runtime.fk

(do
  (defn c1013la-bit (ok bit) (if ok bit 0))
  (let address (concept-10000-13-runtime-run))
  (let program (nth address 5))
  (let method4 (nth program 9))
  (let arbitrary (nth program 11))
  (let world (nth address 6))
  (let world-method4 (nth world 9))
  (add
    (c1013la-bit (eq (nth (nth address 8) 1) 255) 1)
    (add (c1013la-bit (eq (nth world 4) 3) 2)
      (add (c1013la-bit
        (str_eq (nth method4 5) "wiktionary-first-definition") 4)
        (add (c1013la-bit (gt (str_len (nth method4 6)) 0) 8)
          (add (c1013la-bit (str_eq (nth world-method4 1) "you") 16)
            (add (c1013la-bit (eq (nth arbitrary 10) 10) 32)
              (add (c1013la-bit (eq (nth arbitrary 12) 1) 64)
                (c1013la-bit
                  (and (eq (nth arbitrary 14) 1)
                       (eq (nth arbitrary 16) 1)) 128))))))))
)
