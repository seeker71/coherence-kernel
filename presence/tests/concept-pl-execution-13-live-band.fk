; concept-pl-execution-13-live-band.fk — live ledger is complete and honest.
; preludes: form/form-stdlib/core.fk presence/concept-pl-execution-13-live.fk

(do
  (defn cp13xb (ok bit) (if ok bit 0))
  (defn concept-pl-execution-13-live-band ()
    (do
      (let rows (cp13x-observations))
      (add
        (cp13xb (eq (len rows) 13) 1)
        (add
          (cp13xb (eq (cp13x-count rows "pass" 0) 9) 2)
          (add
            (cp13xb (eq (cp13x-count rows "absent" 0) 4) 4)
            (add
              (cp13xb (eq (cp13x-pass-outputs rows) 1) 8)
              (cp13xb (eq (cp13x-absent-honest rows) 1) 16)))))))
  (concept-pl-execution-13-live-band))
