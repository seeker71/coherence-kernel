; concept-pl-10000-13-band.fk — pure mechanics for concept-conditioned source.
; preludes: form/form-stdlib/core.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk

(do
  (defn cp10t-bit (ok bit) (if ok bit 0))
  (defn cp10t-all-sources (languages record semantic count valid)
    (if (eq (len languages) 0) (list count valid)
      (do
        (let language (head languages))
        (let source (cp10-generate-from language record semantic))
        (let identity (cp10-source-identity source))
        (cp10t-all-sources (tail languages) record semantic
          (add count 1)
          (and valid
            (and (gt (str_len source) 200)
              (and (eq (nth identity 0) (c10-concept-id record))
                (eq (nth identity 1) (cp10-language-code language)))))))))
  (defn cp10t-semantic (gloss relation-bytes relation-count senses tags)
    (cs10-semantic 42 1 "n01234567" "n" "current" gloss
      senses 2 tags relation-count relation-bytes))
  (defn cp10t-behavior (record semantic)
    (do
      (let spec (cp10-spec-for "javascript" record semantic))
      (list (cp13-signals spec) (cp13-threshold spec)
        (cp13-score-floor spec) (cp13-retained-floor spec)
        (cp13-alive spec) (cp13-dead spec))))
  (defn cp10t-number-list-eq (a b)
    (if (not (eq (len a) (len b))) 0
      (if (eq (len a) 0) 1
        (if (eq (head a) (head b))
          (cp10t-number-list-eq (tail a) (tail b)) 0))))
  (defn cp10t-behavior-eq (a b)
    (and (eq (cp10t-number-list-eq (nth a 0) (nth b 0)) 1)
      (and (eq (nth a 1) (nth b 1))
        (and (eq (nth a 2) (nth b 2))
          (and (eq (nth a 3) (nth b 3))
            (and (str_eq (nth a 4) (nth b 4))
                 (str_eq (nth a 5) (nth b 5))))))))
  (defn cp10t-all-behavior-changed (record base variants)
    (if (eq (len variants) 0) 1
      (if (not (cp10t-behavior-eq (cp10t-behavior record base)
                                  (cp10t-behavior record (head variants))))
        (cp10t-all-behavior-changed record base (tail variants)) 0)))
  (defn concept-pl-10000-13-band ()
    (do
      (let record (c10-record 42 "current" 43 987654
        (c10-features 42 "current" 987654)))
      (let semantic-a (cp10t-semantic "a steady movement of water"
        "@ n00001740~ n09426788" 2 4 19))
      (let semantic-b (cp10t-semantic "a steady movement of water"
        "! n00001740~ n09426788" 2 4 19))
      (let semantic-c (cp10t-semantic "an electrical movement"
        "@ n00001740~ n09426788" 2 4 19))
      (let spec-a (cp10-spec-for "javascript" record semantic-a))
      (let spec-b (cp10-spec-for "javascript" record semantic-b))
      (let source-a (cp10-generate-from "javascript" record semantic-a))
      (let source-b (cp10-generate-from "javascript" record semantic-b))
      (let source-c (cp10-generate-from "javascript" record semantic-c))
      (let identity (cp10-source-identity source-a))
      (let all (cp10t-all-sources (cp10-languages) record semantic-a 0 1))
      (let c0 (cp10t-bit (eq (len (cp10-languages)) 13) 1))
      (let c1 (cp10t-bit
        (and (eq (cp10-language-code "python") 0)
             (eq (cp10-language-code "kotlin") 12)) 2))
      (let c2 (cp10t-bit (str_eq (cp10-language-at 7) "go") 4))
      (let c3 (cp10t-bit (eq (len (cp13-signals spec-a)) 6) 8))
      (let c4 (cp10t-bit
        (not (eq (cp10-semantic-fingerprint semantic-a)
                 (cp10-semantic-fingerprint semantic-b))) 16))
      (let c5 (cp10t-bit (not (str_eq source-a source-b)) 32))
      (let c6 (cp10t-bit (not (str_eq source-a source-c)) 64))
      (let c7 (cp10t-bit
        (and (eq (nth identity 0) 42)
          (and (eq (nth identity 1) 1)
               (eq (nth identity 2)
                   (cp10-record-fingerprint record semantic-a)))) 128))
      (let c8 (cp10t-bit (eq (len (cp10-source-identity "no marker")) 0) 256))
      (let c9 (cp10t-bit
        (eq (len (cp10-source-identity
          (str_concat "FKC10:42:1:" "broken"))) 0) 512))
      (let c10 (cp10t-bit
        (and (eq (nth all 0) 13) (eq (nth all 1) 1)) 1024))
      (let c11 (cp10t-bit
        (and (ge (str_find source-a "for (let index" 0) 0)
             (ge (str_find source-a "score +=" 0) 0)) 2048))
      (let c12 (cp10t-bit
        (lt (str_find source-a (cp13-output (cp13-evaluate spec-a)) 0) 0) 4096))
      (let c13 (cp10t-bit
        (not (str_eq (cp13-output (cp13-evaluate spec-a))
                     (cp13-output (cp13-evaluate
                       (cp10-spec-for "javascript" record semantic-c))))) 8192))
      (let c14 (cp10t-bit
        (and (ge (str_find source-a "FKC10:42:1:" 0) 0)
             (not (str_eq (cp10-marker "javascript" record semantic-a)
                          (cp10-marker "go" record semantic-a)))) 16384))
      (let variants (list
        (cs10-semantic 42 2 "n01234567" "n" "current"
          "a steady movement of water" 4 2 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "v07654321" "n" "current"
          "a steady movement of water" 4 2 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "v" "current"
          "a steady movement of water" 4 2 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "stream"
          "a steady movement of water" 4 2 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "current"
          "an electrical movement" 4 2 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "current"
          "a steady movement of water" 7 2 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "current"
          "a steady movement of water" 4 3 19 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "current"
          "a steady movement of water" 4 2 31 2 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "current"
          "a steady movement of water" 4 2 19 3 "@ n00001740~ n09426788")
        (cs10-semantic 42 1 "n01234567" "n" "current"
          "a steady movement of water" 4 2 19 2 "! n00001740~ n09426788")))
      (let c15 (cp10t-bit
        (eq (cp10t-all-behavior-changed record semantic-a variants) 1) 32768))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6
        (add c7 (add c8 (add c9 (add c10 (add c11 (add c12
          (add c13 (add c14 c15)))))))))))))))))
  (concept-pl-10000-13-band))
