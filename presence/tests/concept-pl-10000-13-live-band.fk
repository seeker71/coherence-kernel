; concept-pl-10000-13-live-band.fk — asserted 10,000 x 13 real-data audit.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk

(do
  (defn cp10lb-bit (ok bit) (if ok bit 0))
  (defn concept-pl-10000-13-live-band ()
    (do
      (let corpus (read_file (c10-ranked-path)))
      (let semantic-index (read_file (cs10-index-path)))
      (let payload (read_file (cs10-payload-path)))
      (let audit (cp10-audit-in corpus semantic-index payload))
      (let source-a (cp10-generate-in corpus semantic-index payload "javascript" 0))
      (let source-b (cp10-generate-in corpus semantic-index payload "go" 49))
      (let source-c (cp10-generate-in corpus semantic-index payload "rust" 377))
      (let source-d (cp10-generate-in corpus semantic-index payload "swift" 6196))
      (let recovered-a (cp10-recover-source-in corpus semantic-index payload source-a))
      (let recovered-b (cp10-recover-source-in corpus semantic-index payload source-b))
      (let recovered-c (cp10-recover-source-in corpus semantic-index payload source-c))
      (let recovered-d (cp10-recover-source-in corpus semantic-index payload source-d))
      (let c0 (cp10lb-bit (eq (nth audit 0) 10000) 1))
      (let c1 (cp10lb-bit (eq (nth audit 1) 130000) 2))
      (let c2 (cp10lb-bit (eq (nth audit 2) 130000) 4))
      (let c3 (cp10lb-bit (eq (nth audit 3) 130000) 8))
      (let c4 (cp10lb-bit
        (and (eq (nth audit 4) 7371) (eq (nth audit 5) 2629)) 16))
      (let c5 (cp10lb-bit (eq (nth audit 6) 7266) 32))
      (let c6 (cp10lb-bit (eq (nth audit 7) 282606005) 64))
      (let c7 (cp10lb-bit (eq (nth audit 8) 499894812) 128))
      (let c8 (cp10lb-bit
        (and (eq (len recovered-a) 5) (eq (len recovered-b) 5)) 256))
      (let c9 (cp10lb-bit
        (and (eq (len recovered-c) 5) (eq (len recovered-d) 5)) 512))
      (let c10 (cp10lb-bit
        (and (eq (nth recovered-a 0) 0)
             (str_eq (nth recovered-b 1) "go")) 1024))
      (let c11 (cp10lb-bit
        (eq (len (cp10-recover-source-in corpus semantic-index payload
          (str_concat source-c "\n"))) 0) 2048))
      (let c12 (cp10lb-bit
        (eq (len (cp10-recover-source-in corpus semantic-index payload
          (str_concat "// FKC10:377:8:1:\n" source-c))) 0) 4096))
      (let c13 (cp10lb-bit
        (and (not (str_eq (cp13-output (nth recovered-a 4))
                          (cp13-output (nth recovered-c 4))))
             (not (str_eq (cp13-output (nth recovered-b 4))
                          (cp13-output (nth recovered-d 4))))) 8192))
      (let c14 (cp10lb-bit
        (and (eq (len (cp10-generate-in corpus semantic-index payload
          "javascript" -1)) 0)
             (eq (len (cp10-generate-in corpus semantic-index payload
          "brainfuck" 1)) 0)) 16384))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6
        (add c7 (add c8 (add c9 (add c10 (add c11 (add c12
          (add c13 c14))))))))))))))))
  (concept-pl-10000-13-live-band))
