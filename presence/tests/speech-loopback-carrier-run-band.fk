; preludes:
;   form/form-stdlib/hati-os-targets.fk
;   form/form-stdlib/host-os-membrane.fk
;   observe/stt-wer.fk
;   presence/formant-vocoder.fk
;   observe/asr-prompt-id.fk
;   presence/native-speech-loopback.fk
;   learn/speech-loopback-promotion.fk
;   presence/speech-loopback-carrier-receipt.fk
;   presence/speech-loopback-carrier-run.fk
;
; speech-loopback-carrier-run-band -- platform carrier facts into loopback receipt.
;
; Verdict 511:
;   1    Android target is membrane-ready for direct-source speech loopback law
;   2    local render/capture/oracle facts make the carrier run-ready
;   4    missing capture prevents readiness
;   8    native loopback lowers into a valid local carrier receipt
;   16   native transcript WER is measured from the loopback
;   32   unready carrier rows become control debt
;   64   ready clean windows route native
;   128  short windows route oracle
;   256  unready carrier window routes oracle

(do
    (defn slr-band-score (cond bit) (if cond bit 0))
    (defn slr-band-truth () (list "we" "are"))
    (defn slr-band-a-frames () (list (fv-frame 1 4 2 10 100 200 0)))
    (defn slr-band-candidates ()
        (list
            (pid-candidate 1 (slr-band-truth) (fv-fingerprint (slr-band-a-frames)))
            (pid-candidate 2 (list "go" "home") (list 6 148 1 2))))
    (defn slr-band-cap ()
        (slr-capability "android-arm64" 1 1 1 1 16000 1 1))
    (defn slr-band-nocap ()
        (slr-capability "android-arm64" 1 0 1 1 16000 1 1))
    (defn slr-band-loopback ()
        (nsl-receipt 1 (slr-band-truth) (slr-band-a-frames) (slr-band-candidates) 0 80 10))
    (defn slr-band-receipt (sid cap)
        (slr-receipt-from-loopback sid cap 111 222 (slr-band-truth) (slr-band-truth)
                                   (slr-band-loopback) 40 0 0 0))
    (defn slr-band-clean-window ()
        (list (slr-band-receipt 1 (slr-band-cap))
              (slr-band-receipt 2 (slr-band-cap))
              (slr-band-receipt 3 (slr-band-cap))
              (slr-band-receipt 4 (slr-band-cap))))
    (defn slr-band-short-window ()
        (list (slr-band-receipt 5 (slr-band-cap))
              (slr-band-receipt 6 (slr-band-cap))))
    (defn slr-band-unready-window ()
        (list (slr-band-receipt 7 (slr-band-nocap))
              (slr-band-receipt 8 (slr-band-nocap))
              (slr-band-receipt 9 (slr-band-nocap))
              (slr-band-receipt 10 (slr-band-nocap))))

    (defn speech-loopback-carrier-run-band ()
        (do
            (let cap (slr-band-cap))
            (let nocap (slr-band-nocap))
            (let good (slr-band-receipt 11 cap))
            (let unready (slr-band-receipt 12 nocap))
            (let c0 (slr-band-score (eq (slr-platform-ready? cap) 1) 1))
            (let c1 (slr-band-score (eq (slr-ready? cap) 1) 2))
            (let c2 (slr-band-score (eq (slr-ready? nocap) 0) 4))
            (let c3 (slr-band-score (eq (slc-valid? good) 1) 8))
            (let c4 (slr-band-score (eq (slc-native-wer good) 0) 16))
            (let c5 (slr-band-score (eq (slp-control-debt (slc-to-promotion-sample unready 10 80 100)) 1) 32))
            (let c6 (slr-band-score
                (str_eq (slr-window-route cap (slr-band-clean-window) 10 80 100 4 0 0 3) "native")
                64))
            (let c7 (slr-band-score
                (str_eq (slr-window-route cap (slr-band-short-window) 10 80 100 4 0 0 3) "oracle")
                128))
            (let c8 (slr-band-score
                (str_eq (slr-window-route nocap (slr-band-unready-window) 10 80 100 4 0 0 3) "oracle")
                256))
            (add (add (add c0 c1) (add c2 c3))
                 (add (add c4 c5) (add c6 (add c7 c8))))))

    (speech-loopback-carrier-run-band))
