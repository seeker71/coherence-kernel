; concept-real-life-workflows-13-live-band.fk -- twelve real non-Python PL
; carriers execute all thirteen operational workflow outputs exactly.
; Verdict 511 means 156/156 computed target outputs matched Form.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-real-life-workflows-13.fk presence/concept-real-life-workflows-13-generation.fk presence/concept-real-life-workflows-13-live.fk
(do
  (defn crl13xlb-bit (ok bit) (if ok bit 0))
  (let totals (crl13x-run))
  (add (crl13xlb-bit (eq (nth totals 0) 12) 1)
   (add (crl13xlb-bit (eq (nth totals 1) 12) 2)
    (add (crl13xlb-bit (eq (nth totals 2) 12) 4)
     (add (crl13xlb-bit (eq (nth totals 3) 12) 8)
      (add (crl13xlb-bit (eq (nth totals 4) 156) 16)
       (add (crl13xlb-bit (eq (nth totals 5) 12) 32)
        (add (crl13xlb-bit (gt (nth totals 6) 0) 64)
         (add (crl13xlb-bit (eq (len (nth totals 7)) 12) 128)
              (crl13xlb-bit (eq (crl13x-line-count
                (nth (head (nth totals 7)) 6)) 13) 256)))))))))
)
