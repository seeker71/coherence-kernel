; Released native conv1 is causal in a real human-audio world admission.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk model/whisper-tiny-native-conv1.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk cognition/concept-text-detection-13-runtime.fk model/concept-multimodal-codec.fk model/concept-audio-scale-13.fk model/concept-audio-asr-13.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk presence/whisper-tiny-native-acoustic-live.fk

(do
  (defn wtalb-bit (ok bit) (if ok bit 0))
  (defn whisper-tiny-native-acoustic-live-band (path)
    (do
      (let run (wtal-run-file path))
      (let source (nth run 1))
      (let learned (nth run 2))
      (let asr (nth run 3))
      (let detection (nth run 4))
      (let world (nth (nth run 5) 1))
      (let ablation (nth (nth run 6) 1))
      (sum (list
        (wtalb-bit (and (eq (nth source 5) 1) (eq (nth source 7) 1)) 1)
        (wtalb-bit (and (eq (nth learned 5) 92544)
                        (eq (nth learned 7) 1)) 2)
        (wtalb-bit (and (eq (nth learned 9) 384)
                        (eq (nth learned 13) 1)) 4)
        (wtalb-bit (str_eq (nth asr 5) "\n book.") 8)
        (wtalb-bit (and (eq (nth detection 3) 1)
                        (value_eq (nth detection 5) (list 571))) 16)
        (wtalb-bit (and (eq (nth world 1) 1)
                        (eq (nth world 3) 571)) 32)
        (wtalb-bit (eq (nth world 11) 1) 64)
        (wtalb-bit (eq (nth ablation 1) 0) 128)
        (wtalb-bit (eq (nth (nth run 7) 1) 0) 256)))))
)
