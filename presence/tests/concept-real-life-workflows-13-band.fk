; concept-real-life-workflows-13-band.fk -- pure workflow and generation proof.
; Verdict 4095 checks thirteen computed interventions and 169 exact sources.
; preludes: form/form-stdlib/core.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-real-life-workflows-13.fk presence/concept-real-life-workflows-13-generation.fk
(do
  (defn crl13b-bit (ok bit) (if ok bit 0))
  (defn crl13b-bits (checks bit)
    (if (eq (len checks) 0) 0
      (add (crl13b-bit (head checks) bit)
           (crl13b-bits (tail checks) (mul bit 2)))))
  (defn crl13b-metrics-go (ws out)
    (if (eq (len ws) 0) (reverse out)
      (crl13b-metrics-go (tail ws) (cons (crl13-metric (head ws)) out))))
  (defn crl13b-metrics () (crl13b-metrics-go (crl13-workflows) (empty)))
  (let ws (crl13-workflows))
  (let audit (crl13-generation-audit))
  (let js (crl13-generate "javascript"))
  (let recovered (crl13-recover js))
  (let metrics (crl13b-metrics))
  (crl13b-bits
    (list
      (eq (len ws) 13)
      (c10-number-list-eq? metrics (list 1 1 1 1 1 1 1 2 1 700 1 1 2))
      (and (str_eq (crl13-output (head ws)) "8180:reorder:1")
           (str_eq (crl13-output (nth ws 9)) "3999:over-budget-cents:700"))
      (eq (nth audit 0) 13)
      (eq (nth audit 1) 169)
      (eq (nth audit 2) 169)
      (eq (nth audit 3) 169)
      (gt (nth audit 4) 0)
      (and (eq (len recovered) 3)
           (str_eq (nth recovered 2) (crl13-expected-lines)))
      (eq (len (crl13-recover (str_concat js " "))) 0)
      (and (gt (str_find (crl13-generate "python") "FKR13:0:" 0) -1)
           (gt (str_find (crl13-generate "kotlin") "FKR13:12:" 0) -1))
      (and (eq (len (crl13-flat-values)) 44)
           (eq (len (crl13-offsets)) 14))) 1)
)
