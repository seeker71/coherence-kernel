; concept-video-open-runtime-live-band.fk -- broad content-only generated-video sample.
;
; Thirteen predeclared held-out addresses use thirteen distinct concepts and
; cover every NL lens exactly once. The carrier is generic; these ids are not
; embedded in the renderer, OCR, label carrier, or acceptance functions.
; Verdict 2047.
; witnessed: 2026-07-18 -> 2047 live fkwu; 13/13 semantic, 12/13 localized
; preludes: form/form-stdlib/core.fk presence/concept-video-open-runtime-live.fk

(do
  (defn cvorl-samples ()
    (list
      (list 377 0)    ; water / English
      (list 959 1)    ; camera / Indonesian
      (list 270 2)    ; family / Spanish
      (list 365 3)    ; music / French
      (list 786 4)    ; train / Portuguese
      (list 537 5)    ; dog / Swahili
      (list 1520 6)   ; bridge / German
      (list 5037 7)   ; democracy / Russian
      (list 628 8)    ; hospital / Chinese
      (list 327 9)    ; school / Japanese
      (list 1494 10)  ; freedom / Arabic
      (list 1098 11)  ; computer / Hindi
      (list 1595 12))) ; mountain / Turkish

  ; matrix = rows, generated, animated, semantic, localized, label-hit,
  ;          decoded-address-sum.
  (defn cvorl-sample-all (runtime samples rows generated animated semantic
                           localized label-hits decoded-address)
    (if (eq (len samples) 0)
      (list (reverse rows) generated animated semantic localized label-hits
            decoded-address)
      (do (let address (head samples))
          (let row (cvorl-generate-sense runtime (nth address 0) (nth address 1)))
          (let evidence (cvorl-result-evidence row))
          (cvorl-sample-all runtime (tail samples) (cons row rows)
            (add generated (cvorl-result-generated? row))
            (add animated (cvorl-result-animated? row))
            (add semantic (cvorl-result-semantic? row))
            (add localized (cvorl-result-localized? row))
            (add label-hits (cvorl-result-label-hit? row))
            (add decoded-address (cvor-decoded-address-evidence evidence))))))

  (let runtime (cvorl-open))
  (let matrix (if (eq (cvorl-ready? runtime) 1)
    (cvorl-sample-all runtime (cvorl-samples) (empty) 0 0 0 0 0 0)
    (list (empty) 0 0 0 0 0 -1)))
  ; The Hindi computer card is the observed pretrained-label positive. Its
  ; twenty raw labels enter a complete English 10k scan. The 260-label union
  ; was also observed (33 candidates, one sample target) but is not repeated in
  ; this gate because it multiplies scan cost without changing target evidence.
  (let hindi-row (nth (nth matrix 0) 11))
  (let label-raw (nth (cvorl-result-labels hindi-row) 0))
  (let label-candidates (ctd13-runtime-detect-sentence (nth runtime 4) "en" label-raw))
  (let hindi-evidence (cvorl-result-evidence hindi-row))
  (add
    (if (eq (cvorl-ready? runtime) 1) 1 0)
    (add (if (eq (len (nth matrix 0)) 13) 2 0)
      (add (if (eq (nth matrix 1) 13) 4 0)
        (add (if (eq (nth matrix 2) 13) 8 0)
          (add (if (eq (nth matrix 3) 13) 16 0)
            (add (if (eq (nth matrix 4) 12) 32 0)
              (add (if (eq (nth matrix 5) 1) 64 0)
                (add (if (eq (cvor-candidate-id-present? label-candidates 1098) 1) 128 0)
                  (add (if (gt (len label-candidates) 0) 256 0)
                    (add (if (eq (nth matrix 6) 0) 512 0)
                      (if (and (eq (cvor-localized-both? hindi-evidence) 0)
                               (eq (cvor-anchor-both? hindi-evidence) 1)) 1024 0)))))))))))
