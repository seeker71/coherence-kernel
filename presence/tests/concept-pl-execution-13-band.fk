; concept-pl-execution-13-band.fk — pure control for the semantic carrier lane.
; The band proves one neutral concept evaluates, conditions all thirteen source
; programs, contains loop/accumulate/branch/output structure, and keeps four
; unavailable carriers explicitly absent.
; preludes: form/form-stdlib/core.fk presence/concept-pl-execution-13.fk

(do
  (defn cp13t-bit (ok bit) (if ok bit 0))
  (defn cp13t-languages ()
    (list "python" "javascript" "typescript" "java" "c" "cpp" "csharp"
          "go" "rust" "ruby" "php" "swift" "kotlin"))
  (defn cp13t-list-eq (a b)
    (if (not (eq (len a) (len b))) 0
      (if (eq (len a) 0) 1
        (if (eq (head a) (head b)) (cp13t-list-eq (tail a) (tail b)) 0))))
  (defn cp13t-count-state (carriers state count)
    (if (eq (len carriers) 0) count
      (cp13t-count-state (tail carriers) state
        (add count (if (str_eq (cp13-carrier-state (head carriers)) state) 1 0)))))
  (defn cp13t-all-generated (languages spec)
    (if (eq (len languages) 0) 1
      (if (gt (str_len (cp13-generate (head languages) spec)) 0)
        (cp13t-all-generated (tail languages) spec) 0)))
  (defn cp13t-all-not-canned (languages spec)
    (if (eq (len languages) 0) 1
      (if (lt (str_find (cp13-generate (head languages) spec) "coherent:109:3" 0) 0)
        (cp13t-all-not-canned (tail languages) spec) 0)))
  (defn cp13t-has (source marker) (if (ge (str_find source marker 0) 0) 1 0))
  (defn cp13t-four (source a b c d)
    (if (and (cp13t-has source a) (and (cp13t-has source b)
      (and (cp13t-has source c) (cp13t-has source d)))) 1 0))
  (defn cp13t-semantic-source (language source)
    (if (str_eq language "python") (cp13t-four source "for index" "score +=" "if value" "print(")
    (if (str_eq language "javascript") (cp13t-four source "for (let index" "score +=" "const verdict" "console.log")
    (if (str_eq language "typescript") (cp13t-four source "for (let index" "score +=" "const verdict" "console.log")
    (if (str_eq language "java") (cp13t-four source "for (int index" "score +=" "String verdict" "System.out.println")
    (if (str_eq language "c") (cp13t-four source "for (int index" "score +=" "const char *verdict" "printf(")
    (if (str_eq language "cpp") (cp13t-four source "for (std::size_t" "score +=" "std::string verdict" "std::cout")
    (if (str_eq language "csharp") (cp13t-four source "for (int index" "score +=" "string verdict" "Console.WriteLine")
    (if (str_eq language "go") (cp13t-four source "for index" "score +=" "if score" "fmt.Printf")
    (if (str_eq language "rust") (cp13t-four source "for (index" "score +=" "let verdict" "println!(")
    (if (str_eq language "ruby") (cp13t-four source "each_with_index" "score +=" "verdict =" "puts ")
    (if (str_eq language "php") (cp13t-four source "foreach (" "$score +=" "$verdict =" "echo ")
    (if (str_eq language "swift") (cp13t-four source "enumerated()" "score +=" "let verdict" "print(")
    (if (str_eq language "kotlin") (cp13t-four source "forEachIndexed" "score +=" "val verdict" "println(") 0))))))))))))))
  (defn cp13t-all-semantic (languages spec)
    (if (eq (len languages) 0) 1
      (if (eq (cp13t-semantic-source (head languages)
                (cp13-generate (head languages) spec)) 1)
        (cp13t-all-semantic (tail languages) spec) 0)))
  (defn cp13t-absent-reasons (carriers)
    (if (eq (len carriers) 0) 1
      (if (str_eq (cp13-carrier-state (head carriers)) "absent")
        (if (gt (str_len (nth (head carriers) 3)) 0)
          (cp13t-absent-reasons (tail carriers)) 0)
        (cp13t-absent-reasons (tail carriers)))))
  (defn concept-pl-execution-13-band ()
    (do
      (let spec (cp13-live-spec))
      (let negative (cp13-spec "selective-retention" (list 2 7 1 8 2 8)
                       9 200 3 "coherent" "fragmented"))
      (let evaluation (cp13-evaluate spec))
      (let carriers (cp13-carriers))
      (let languages (cp13t-languages))
      (let c0 (cp13t-bit
        (and (str_eq (nth evaluation 0) "coherent")
             (and (eq (nth evaluation 1) 109) (eq (nth evaluation 2) 3))) 1))
      (let c1 (cp13t-bit (str_eq (cp13-output evaluation) "coherent:109:3") 2))
      (let c2 (cp13t-bit (eq (len languages) 13) 4))
      (let c3 (cp13t-bit (eq (cp13t-all-generated languages spec) 1) 8))
      (let c4 (cp13t-bit (eq (len carriers) 13) 16))
      (let c5 (cp13t-bit (eq (cp13t-count-state carriers "present" 0) 12) 32))
      (let c6 (cp13t-bit (eq (cp13t-count-state carriers "absent" 0) 1) 64))
      (let c7 (cp13t-bit (eq (cp13t-absent-reasons carriers) 1) 128))
      (let c8 (cp13t-bit (eq (cp13t-all-semantic languages spec) 1) 256))
      (let c9 (cp13t-bit
        (do
          (let neg-eval (cp13-evaluate negative))
          (and (str_eq (nth neg-eval 0) "fragmented")
               (and (eq (nth neg-eval 1) 109) (eq (nth neg-eval 2) 0)))) 512))
      (let c10 (cp13t-bit
        (and (ge (str_find (cp13-generate "javascript" negative) "threshold = 9" 0) 0)
             (ge (str_find (cp13-generate "rust" negative) "score_floor: i64 = 200" 0) 0)) 1024))
      (let c11 (cp13t-bit (eq (cp13t-all-not-canned languages spec) 1) 2048))
      (let c12 (cp13t-bit
        (and (str_eq (cp13-carrier-state (nth carriers 0)) "absent")
             (str_eq (cp13-carrier-state (nth carriers 4)) "present")) 4096))
      (let c13 (cp13t-bit
        (and (str_eq (cp13-carrier-language (nth carriers 1)) "javascript")
             (str_eq (cp13-carrier-language (nth carriers 12)) "kotlin")) 8192))
      (let c14 (cp13t-bit
        (and (ge (str_find (cp13-generate "swift" spec) "2, 7, 1, 8, 2, 8" 0) 0)
             (ge (str_find (cp13-generate "php" spec) "$retainedFloor = 3" 0) 0)) 16384))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6
        (add c7 (add c8 (add c9 (add c10 (add c11 (add c12 (add c13 c14))))))))))))))))
  (concept-pl-execution-13-band))
