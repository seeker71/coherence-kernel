; preludes: observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk presence/native-speech-loopback.fk
;
; native-speech-loopback-band -- native vocoder -> native prompt ASR -> route shift.
;
; Verdict 1023:
;   1    receipt names native-speech-loopback
;   2    loopback features are the vocoder fingerprint
;   4    native ASR returns the expected transcript
;   8    loopback WER is 0 for the expected prompt
;   16   native ASR is confident
;   32   success gate passes
;   64   successful loopback routes native
;   128  ambiguous loopback is not confident
;   256  ambiguous loopback routes oracle
;   512  generated waveform has nonzero energy

(do
    (defn nsl-band-score (cond bit) (if cond bit 0))
    (defn nsl-band-a-frames () (list (fv-frame 1 4 2 10 100 200 0)))
    (defn nsl-band-b-frames () (list (fv-frame 2 6 3 20 200 300 0)))
    (defn nsl-band-weak-frames () (list (fv-frame 1 5 2 17 100 200 0)))
    (defn nsl-band-a-words () (list "we" "are"))
    (defn nsl-band-b-words () (list "go" "home"))
    (defn nsl-band-candidates ()
        (list
            (pid-candidate 1 (nsl-band-a-words) (fv-fingerprint (nsl-band-a-frames)))
            (pid-candidate 2 (nsl-band-b-words) (fv-fingerprint (nsl-band-b-frames)))))
    (defn nsl-band-a-receipt ()
        (nsl-receipt 1 (nsl-band-a-words) (nsl-band-a-frames) (nsl-band-candidates) 0 80 10))
    (defn nsl-band-weak-features () (fv-fingerprint (nsl-band-weak-frames)))

    (defn native-speech-loopback-band ()
        (do
            (let r (nsl-band-a-receipt))
            (let weak (nsl-band-weak-features))
            (let c0 (nsl-band-score (str_eq (nsl-kind r) "native-speech-loopback") 1))
            (let c1 (nsl-band-score (eq (nth (nsl-features r) 1) (fv-total-energy (nsl-band-a-frames))) 2))
            (let c2 (nsl-band-score (eq (sw-wer (nsl-transcript r) (nsl-band-a-words)) 0) 4))
            (let c3 (nsl-band-score (eq (nsl-wer r) 0) 8))
            (let c4 (nsl-band-score (eq (nsl-confident r) 1) 16))
            (let c5 (nsl-band-score (eq (nsl-success r) 1) 32))
            (let c6 (nsl-band-score (str_eq (nsl-route-of r) "native") 64))
            (let c7 (nsl-band-score (eq (pid-confident? weak (nsl-band-candidates) 0 80) 0) 128))
            (let c8 (nsl-band-score
                (str_eq (nsl-route weak (nsl-band-candidates) (nsl-band-a-words) 0 80 10) "oracle")
                256))
            (let c9 (nsl-band-score (gt (fv-energy (fv-render (nsl-band-a-frames))) 0) 512))
            (add (add (add (add c0 c1) (add c2 c3))
                      (add (add c4 c5) (add c6 c7)))
                 (add c8 c9))))
    (native-speech-loopback-band))
