; concept-video-semantic-stress-live-band.fk -- preserve the hard misses.
; expected: 127
; preludes: form/form-stdlib/core.fk model/lingbot-vision-input.fk model/concept-video-semantic.fk presence/concept-video-semantic-live.fk presence/concept-video-semantic-stress-live.fk

(do
  (defn cvssb-bit (ok bit) (if ok bit 0))
  (defn cvssb-all-detected (rows id)
    (if (eq (len rows) 0) 1
      (if (eq (nth (head rows) 1) id)
        (cvssb-all-detected (tail rows) id) 0)))
  (defn concept-video-semantic-stress-live-check ()
    (do (let live (concept-video-semantic-stress-live-run))
        (let early (nth (nth live 2) 1))
        (let late (nth (nth live 3) 1))
        (let oxford (nth (nth live 4) 1))
        (let early-rows (nth early 1))
        (let late-rows (nth late 1))
        (add
          (cvssb-bit (eq (nth (nth live 1) 1) 4) 1)
          (add (cvssb-bit (eq (nth early 0) 10) 2)
            (add (cvssb-bit (eq (nth late 0) 10) 4)
              (add (cvssb-bit (eq (nth oxford 0) 0) 8)
                (add (cvssb-bit (and (eq (nth (nth early-rows 0) 1) 6)
                                      (and (eq (nth (nth early-rows 1) 1) 2)
                                           (eq (nth (nth early-rows 2) 1) 2))) 16)
                  (add (cvssb-bit (and (eq (nth (nth late-rows 0) 1) 6)
                                        (and (eq (nth (nth late-rows 1) 1) 3)
                                             (eq (nth (nth late-rows 2) 1) 1))) 32)
                       (cvssb-bit (eq (cvssb-all-detected (nth oxford 1) 9066) 1) 64)))))))))
  (concept-video-semantic-stress-live-check))
