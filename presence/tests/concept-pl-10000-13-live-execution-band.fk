; concept-pl-10000-13-live-execution-band.fk — nine real carriers execute four
; materially distinct concept-conditioned programs each. No Python or C runs.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk presence/concept-pl-execution-13.fk presence/concept-pl-10000-13.fk presence/concept-pl-10000-13-live.fk

(do
  (defn cp10xb-bit (ok bit) (if ok bit 0))
  (defn concept-pl-10000-13-live-execution-band ()
    (do
      (let totals (cp10x-run))
      (let c0 (cp10xb-bit (eq (nth totals 0) 9) 1))
      (let c1 (cp10xb-bit (eq (nth totals 1) 36) 2))
      (let c2 (cp10xb-bit (eq (nth totals 2) 36) 4))
      (let c3 (cp10xb-bit (eq (nth totals 3) 36) 8))
      (let c4 (cp10xb-bit (eq (nth totals 4) 36) 16))
      (let c5 (cp10xb-bit (eq (nth totals 5) 36) 32))
      (let c6 (cp10xb-bit (eq (nth totals 6) 36) 64))
      (let c7 (cp10xb-bit (eq (nth totals 7) 27) 128))
      (let c8 (cp10xb-bit (gt (nth totals 8) 0) 256))
      (let c9 (cp10xb-bit (eq (len (nth totals 9)) 36) 512))
      (add c0 (add c1 (add c2 (add c3 (add c4
        (add c5 (add c6 (add c7 (add c8 c9)))))))))))
  (concept-pl-10000-13-live-execution-band))
