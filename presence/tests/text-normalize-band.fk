; preludes: presence/text-normalize.fk
;
; text-normalize-band -- the first native TTS pre-g2p layer.
;
; Verdict 255:
;   1    zero is its own word
;   2    one digit reads through ones data
;   4    teen reads through teens data
;   8    compound tens use the locale join
;   16   exact tens do not append a join
;   32   hundreds compose with a space
;   64   thousands compose with a space
;   128  the en convenience route delegates to int->words

(do
    (defn text-normalize-band ()
        (do
            (let loc (tn-locale-en))
            (let c0 (if (str_eq (int->words loc 0) "zero") 1 0))
            (let c1 (if (str_eq (int->words loc 7) "seven") 2 0))
            (let c2 (if (str_eq (int->words loc 13) "thirteen") 4 0))
            (let c3 (if (str_eq (int->words loc 42) "forty-two") 8 0))
            (let c4 (if (str_eq (int->words loc 80) "eighty") 16 0))
            (let c5 (if (str_eq (int->words loc 105) "one hundred five") 32 0))
            (let c6 (if (str_eq (int->words loc 1000) "one thousand") 64 0))
            (let c7 (if (str_eq (tn-en 2042) "two thousand forty-two") 128 0))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))
    (text-normalize-band))
