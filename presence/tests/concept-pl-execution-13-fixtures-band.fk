; concept-pl-execution-13-fixtures-band.fk — host-I/O equality between the
; Form-generated concept program and every materialized target source.
; fkwu-only because proof siblings deliberately omit host filesystem effects.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk presence/concept-pl-execution-13.fk

(do
  (defn cp13f-bit (ok bit) (if ok bit 0))
  (defn cp13f-eq (language path bit)
    (cp13f-bit (str_eq (cp13-generate language (cp13-live-spec))
                       (read_file path)) bit))
  (defn concept-pl-execution-13-fixtures-band ()
    (add
      (cp13f-eq "python" "presence/concept-pl-execution-13-fixtures/concept_pulse.py" 1)
      (add
        (cp13f-eq "javascript" "presence/concept-pl-execution-13-fixtures/concept_pulse.js" 2)
        (add
          (cp13f-eq "typescript" "presence/concept-pl-execution-13-fixtures/concept_pulse.ts" 4)
          (add
            (cp13f-eq "java" "presence/concept-pl-execution-13-fixtures/ConceptPulse.java" 8)
            (add
              (cp13f-eq "c" "presence/concept-pl-execution-13-fixtures/concept_pulse.c" 16)
              (add
                (cp13f-eq "cpp" "presence/concept-pl-execution-13-fixtures/concept_pulse.cpp" 32)
                (add
                  (cp13f-eq "csharp" "presence/concept-pl-execution-13-fixtures/csharp/Program.cs" 64)
                  (add
                    (cp13f-eq "go" "presence/concept-pl-execution-13-fixtures/concept_pulse.go" 128)
                    (add
                      (cp13f-eq "rust" "presence/concept-pl-execution-13-fixtures/concept_pulse.rs" 256)
                      (add
                        (cp13f-eq "ruby" "presence/concept-pl-execution-13-fixtures/concept_pulse.rb" 512)
                        (add
                          (cp13f-eq "php" "presence/concept-pl-execution-13-fixtures/concept_pulse.php" 1024)
                          (add
                            (cp13f-eq "swift" "presence/concept-pl-execution-13-fixtures/concept_pulse.swift" 2048)
                            (cp13f-eq "kotlin" "presence/concept-pl-execution-13-fixtures/ConceptPulse.kt" 4096))))))))))))))
  (concept-pl-execution-13-fixtures-band))
