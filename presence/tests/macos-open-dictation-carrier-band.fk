; preludes: observe/stt-wer.fk learn/speech-loopback-promotion.fk form/form-stdlib/observed-auto-learning.fk learn/open-dictation-transcript-learning.fk presence/macos-open-dictation-carrier.fk
;
; macos-open-dictation-carrier-band -- live carrier contract without host effects.
;
; Verdict 511:
;   1    row kind is free open dictation transcript
;   2    audio metadata is present
;   4    local oracle transcript succeeds
;   8    WER reaches zero for the side-channel text
;   16   route stays oracle because no native open-ASR candidate is supplied
;   32   observed A/B mode is present
;   64   clean controls continue
;   128  native-local is explicitly false
;   256  four-row receipt window is present

(do
    (defn macos-open-dictation-carrier-band ()
        (do
            (let row
                (odtl-row 9001
                          (modc-locale)
                          (modc-text)
                          (modc-text)
                          ""
                          (odtl-audio 818181 16000 1)
                          1
                          (odtl-native 0 0 0)
                          1
                          (odtl-control-row 1 0 0 0 0)))
            (let summary (modc-summary row))
            (modc-verdict row summary)))

    (macos-open-dictation-carrier-band))
