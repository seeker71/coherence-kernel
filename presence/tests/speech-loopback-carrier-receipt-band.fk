; preludes:
;   observe/stt-wer.fk
;   learn/speech-loopback-promotion.fk
;   presence/speech-loopback-carrier-receipt.fk
;
; speech-loopback-carrier-receipt-band -- real local loopback measurement contract.
;
; Verdict 4095:
;   1    local carrier flags are required
;   2    audio metadata is required
;   4    native WER is measured
;   8    oracle success is measured
;   16   native success is measured
;   32   clean receipt lowers to a clean promotion sample
;   64   four clean real-loopback receipts route native
;   128  short window routes oracle
;   256  nonlocal/cloud receipt creates control debt
;   512  timeout receipt creates control debt and routes oracle
;   1024 regression routes oracle
;   2048 summary records native authority

(do
    (defn slc-band-score (cond bit) (if cond bit 0))
    (defn slc-band-truth () (list "we" "are"))
    (defn slc-band-good ()
        (slc-receipt 1 10 111 222 16000 1
                     1 1
                     (slc-band-truth)
                     (slc-band-truth)
                     (slc-band-truth)
                     95 40
                     0 0 0))
    (defn slc-band-cloud ()
        (slc-receipt 2 10 111 222 16000 1
                     0 1
                     (slc-band-truth)
                     (slc-band-truth)
                     (slc-band-truth)
                     95 40
                     0 0 0))
    (defn slc-band-timeout ()
        (slc-receipt 3 10 111 222 16000 1
                     1 1
                     (slc-band-truth)
                     (slc-band-truth)
                     (slc-band-truth)
                     95 40
                     0 1 0))
    (defn slc-band-bad-native ()
        (slc-receipt 4 10 111 222 16000 1
                     1 1
                     (slc-band-truth)
                     (slc-band-truth)
                     (list "go" "home")
                     95 40
                     0 0 0))
    (defn slc-band-clean-window ()
        (list (slc-band-good) (slc-band-good) (slc-band-good) (slc-band-good)))
    (defn slc-band-short-window ()
        (list (slc-band-good) (slc-band-good)))
    (defn slc-band-timeout-window ()
        (list (slc-band-good) (slc-band-good) (slc-band-timeout) (slc-band-good)))
    (defn slc-band-regress-window ()
        (list (slc-band-good) (slc-band-bad-native) (slc-band-bad-native) (slc-band-bad-native)))

    (defn speech-loopback-carrier-receipt-band ()
        (do
            (let good (slc-band-good))
            (let clean (slc-band-clean-window))
            (let short (slc-band-short-window))
            (let timeoutw (slc-band-timeout-window))
            (let regress (slc-band-regress-window))
            (let cloud-sample (slc-to-promotion-sample (slc-band-cloud) 10 80 100))
            (let timeout-sample (slc-to-promotion-sample (slc-band-timeout) 10 80 100))
            (let summary (slc-summary clean 10 80 100 4 0 0 3))
            (let c0 (slc-band-score (eq (slc-local? good) 1) 1))
            (let c1 (slc-band-score (eq (slc-audio-present? good) 1) 2))
            (let c2 (slc-band-score (eq (slc-native-wer good) 0) 4))
            (let c3 (slc-band-score (eq (slc-oracle-success? good 10) 1) 8))
            (let c4 (slc-band-score (eq (slc-native-success? good 10 80 100) 1) 16))
            (let c5 (slc-band-score (eq (slp-control-debt (slc-to-promotion-sample good 10 80 100)) 0) 32))
            (let c6 (slc-band-score (str_eq (slc-route-window clean 10 80 100 4 0 0 3) "native") 64))
            (let c7 (slc-band-score (str_eq (slc-route-window short 10 80 100 4 0 0 3) "oracle") 128))
            (let c8 (slc-band-score (eq (slp-control-debt cloud-sample) 1) 256))
            (let c9 (slc-band-score
                (and (eq (slp-control-debt timeout-sample) 1)
                     (str_eq (slc-route-window timeoutw 10 80 100 4 0 0 3) "oracle"))
                512))
            (let c10 (slc-band-score (str_eq (slc-route-window regress 10 80 100 4 0 0 3) "oracle") 1024))
            (let c11 (slc-band-score (str_eq (slc-summary-route summary) "native") 2048))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) (add c10 c11)))))
    (speech-loopback-carrier-receipt-band))
