; whisper-full-decoder-vocabulary-observed-live.fk -- same encoder, real truth.
;
; Loads the exact 35x384 f64 carrier produced by the traced full-valid-STFT
; encoder, runs every released decoder block, scores all 51,865 tied vocabulary
; rows once, and compares the generation-policy winner with the spoken truth
; "book".  Raw and policy rankings share each computed logit.  Every expensive
; stage streams before the final result so a fault cannot erase its location.
;
; This lane is not official Whisper preprocessing: centered STFT and 30-second
; padding remain required.  It never promotes a mismatched first token and does
; not claim a transcript without autoregressive EOS completion.
; witnessed: 2026-07-20 -> complete 51865-row scan; ` w` mismatch rejected
; preludes: form/form-stdlib/core.fk form/form-stdlib/format-arith.fk form/form-stdlib/f64-bytes.fk form/form-stdlib/wire-corba-cdr.fk model/lingbot-pytorch-checkpoint.fk model/whisper-tiny-native-vocabulary.fk model/whisper-tiny-native-affine-row-major.fk audio/whisper-full-encoder-f64-carrier.fk audio/whisper-tiny-full-decoder-row-major.fk observe/framebuffer-runtime-observation.fk

(do
  (defn wafd-begin (stage parent)
    (do
      (print_str (fbro-cat (list
        "FRAMEBUFFER STAGE-BEGIN trace=whisper-full-decoder-vocabulary"
        " stage=" stage " parent=" parent " actor=Sema"
        " relation=decodes-same-human-speech-state"
        " why=correct-false-semantic-output")))
      (fbro-snapshot)))
  (defn wafd-stage (stage parent before after metric value outcome line)
    (fbro-stage-observed-stream "whisper-full-decoder-vocabulary"
      stage parent "Sema" "decodes-same-human-speech-state"
      "correct-false-semantic-output" "human-truth-book"
      before after metric value outcome
      "presence/whisper-full-decoder-vocabulary-observed-live.fk" line 7))

  (defn whisper-full-decoder-vocabulary-observed-live ()
    (do
      (let window (fbro-open-stream "whisper-full-decoder-vocabulary" "Sema"
        "decodes-same-human-speech-state" "correct-false-semantic-output"
        "human-truth-book" (waec-byte-count)
        "presence/whisper-full-decoder-vocabulary-observed-live.fk" 33 7))

      (let encoder-before (wafd-begin "encoder-carrier" "trace-begin"))
      (let encoder-pack (waec-load))
      (let encoder (waec-output encoder-pack))
      (let encoder-after (fbro-snapshot))
      (let encoder-event (wafd-stage "encoder-carrier" "trace-begin"
        encoder-before encoder-after "tokens" (len encoder)
        (if (and (eq (waec-valid? encoder-pack) 1)
              (and (eq (len encoder) 35) (eq (len (head encoder)) 384)))
          "exact-carrier-loaded" "held") 41))

      (let weights-before (wafd-begin "decoder-weights+prompt" "encoder-carrier"))
      (let pack0 (wtd0-load))
      (let pack13 (wtd-load))
      (let input (if (and (eq (wtd0-valid? pack0) 1)
            (eq (wtd-valid? pack13) 1)) (wtd0-embed-prompt pack0) (empty)))
      (let weights-after (fbro-snapshot))
      (let weights-event (wafd-stage "decoder-weights+prompt" "encoder-carrier"
        weights-before weights-after "prompt-tokens" (len input)
        (if (eq (len input) 4) "complete" "held") 51))

      (let layer0-before (wafd-begin "decoder-layer0" "decoder-weights+prompt"))
      (let out0 (if (and (eq (len encoder) 35) (eq (len input) 4))
        (waud-layer0 (wtd0-layer-carrier pack0) input encoder) (empty)))
      (let layer0-after (fbro-snapshot))
      (let layer0-event (wafd-stage "decoder-layer0" "decoder-weights+prompt"
        layer0-before layer0-after "tokens" (len out0)
        (if (eq (len out0) 4) "complete" "held") 59))

      (let layer1-before (wafd-begin "decoder-layer1" "decoder-layer0"))
      (let out1 (if (eq (len out0) 4)
        (waud-layer (wtd-carrier pack13) 0 out0 encoder) (empty)))
      (let layer1-after (fbro-snapshot))
      (let layer1-event (wafd-stage "decoder-layer1" "decoder-layer0"
        layer1-before layer1-after "tokens" (len out1)
        (if (eq (len out1) 4) "complete" "held") 67))

      (let layer2-before (wafd-begin "decoder-layer2" "decoder-layer1"))
      (let out2 (if (eq (len out1) 4)
        (waud-layer (wtd-carrier pack13) (wtd-layer-byte-count) out1 encoder)
        (empty)))
      (let layer2-after (fbro-snapshot))
      (let layer2-event (wafd-stage "decoder-layer2" "decoder-layer1"
        layer2-before layer2-after "tokens" (len out2)
        (if (eq (len out2) 4) "complete" "held") 76))

      (let layer3-before (wafd-begin "decoder-layer3" "decoder-layer2"))
      (let out3 (if (eq (len out2) 4)
        (waud-layer (wtd-carrier pack13) (mul 2 (wtd-layer-byte-count))
          out2 encoder) (empty)))
      (let layer3-after (fbro-snapshot))
      (let layer3-event (wafd-stage "decoder-layer3" "decoder-layer2"
        layer3-before layer3-after "tokens" (len out3)
        (if (eq (len out3) 4) "complete" "held") 85))

      (let final-before (wafd-begin "decoder-final-layernorm" "decoder-layer3"))
      (let final (if (eq (len out3) 4)
        (wte0-layernorm-seq (wtd0-layer-carrier pack0)
          (wtd0-final-ln-weight-off) (wtd0-final-ln-bias-off) out3) (empty)))
      (let state (if (eq (len final) 4) (nth final 3) (empty)))
      (let final-after (fbro-snapshot))
      (let final-event (wafd-stage "decoder-final-layernorm" "decoder-layer3"
        final-before final-after "state-width" (len state)
        (if (eq (len state) 384) "complete" "held") 95))

      (let scan-before (wafd-begin "vocabulary-raw+policy" "decoder-final-layernorm"))
      (let both (if (eq (len state) 384) (waud-scan-both state 0)
        (list (list -1 0.0 -1 0.0 0) (list -1 0.0 -1 0.0 0)
          -1000000000.0 -1000000000.0)))
      (let raw (nth both 0))
      (let policy (nth both 1))
      (let scan-after (fbro-snapshot))
      (let scan-event (wafd-stage "vocabulary-raw+policy"
        "decoder-final-layernorm" scan-before scan-after "rows" (nth raw 4)
        (if (and (eq (nth raw 4) 51865) (eq (nth policy 4) 51865))
          "complete-single-logit-pass" "held") 106))

      (let truth-before (wafd-begin "human-truth-comparison" "vocabulary-raw+policy"))
      (let raw-text (if (ge (nth raw 0) 0) (wtv-token-text (nth raw 0)) ""))
      (let policy-text (if (ge (nth policy 0) 0)
        (wtv-token-text (nth policy 0)) ""))
      (let truth-match (if (or (str_eq policy-text " book")
            (str_eq policy-text "book")) 1 0))
      (let truth-after (fbro-snapshot))
      (let truth-event (wafd-stage "human-truth-comparison"
        "vocabulary-raw+policy" truth-before truth-after "first-token-match"
        truth-match (if (eq truth-match 1) "matched-book" "rejected-mismatch") 118))

      (let complete (if (and (eq (len state) 384)
        (and (eq (nth raw 4) 51865) (eq (nth policy 4) 51865))) 1 0))
      (let report (fbro-close-stream window
        (if (eq complete 0) "held-incomplete-decoder-or-vocabulary"
          (if (eq truth-match 1)
            "decoder-complete-first-token-book-full-transcript-still-held"
            "decoder-complete-semantic-mismatch-rejected"))
        (nth raw 4)
        "presence/whisper-full-decoder-vocabulary-observed-live.fk" 126 7))
      (list "whisper-full-decoder-vocabulary-observed-live"
        "encoder" (list "tokens" (len encoder) "width"
          (if (gt (len encoder) 0) (len (head encoder)) 0)
          "carrier-bytes" (str_len (waec-carrier encoder-pack))
          "crc32" (waec-crc32 encoder-pack))
        "decoder" (list "prompt-tokens" (len input) "final-width" (len state)
          "complete" complete "fingerprint"
          (if (eq (len state) 384) (wt2-fingerprint state) (empty)))
        "raw" (list "rows" (nth raw 4) "token" (nth raw 0)
          "text" raw-text "logit" (nth raw 1) "runner" (nth raw 2)
          "runner-logit" (nth raw 3) "margin" (wtv-margin raw))
        "policy" (list "rows" (nth policy 4) "token" (nth policy 0)
          "text" policy-text "logit" (nth policy 1) "runner" (nth policy 2)
          "runner-logit" (nth policy 3) "margin" (wtv-margin policy))
        "book" (list "space-book-token" 1446 "logit" (nth both 2)
          "book-token" 2939 "logit" (nth both 3))
        "human-truth" "book" "truth-first-token-match" truth-match
        "native-recognizer" 0
        "semantic-preprocessing-defect"
          "valid-only-STFT-35-tokens; centered-STFT+30s-padding-1500-tokens-required"
        "framebuffer" report)))
  0)
