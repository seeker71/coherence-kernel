; windows-air-loopback-carrier.fk — the three legs COMPOSED, one Form cell, this metal:
;   render: the body writes its own TTS payload; PowerShell speaks the truth to a wav (local),
;   air:    (sense_wav_loopback in out) plays it through the SPEAKERS while the MIC captures —
;           the phrase crosses the room as sound, not as bytes,
;   oracle: whisper.cpp (local) transcribes what the mic actually heard,
;   law:    the row lowers through the carrier-receipt law (capability render=1 capture=1
;           oracle=1 local-only=1), the capture file is CONSUMED (fs_remove) after measuring —
;           transient teacher material, the macOS carrier's own pattern.
;
; This is the composition the membrane's speech-carrier flag waits on. It does not flip today:
; one clean air row is evidence, and the flip needs the promotion law's windows plus the body's
; band-law change — named, not rushed. A silent/muted room scores WER 100 and the verdict says
; so; both outcomes are honest.
;
; preludes (cat in this order): form/form-stdlib/hati-os-targets.fk,
;   form/form-stdlib/host-os-membrane.fk, observe/stt-wer.fk,
;   learn/speech-loopback-promotion.fk, presence/speech-loopback-carrier-receipt.fk,
;   presence/speech-loopback-carrier-run.fk, presence/windows-speech-oracle-carrier.fk (the
;   tokenizer/hash/ps1 helpers live there), this file.
;
; Verdict bits (255 = the composed carrier heard its own voice through the air):
;   1   capability row fully ready (render+capture+oracle, local)
;   2   the air door played and captured real samples
;   4   the mic heard real energy (peak above the silence floor)
;   8   the capture crossed to the oracle and came back as words
;   16  air WER == 0 — the room carried the phrase intact
;   32  oracle-success under the band threshold (WER <= 10)
;   64  the receipt row is valid with clean controls
;   128 the capture file was consumed after measuring (nothing silently retained)
(do
    (defn wal-bit (cond bit) (if cond bit 0))

    (defn windows-air-loopback ()
        (do
            (let wrote (write_file_text "C:/tmp/sema-oracle-tts.ps1" (wso-ps1)))
            (let tts-out (host-exec
                "powershell -NoProfile -ExecutionPolicy Bypass -File C:/tmp/sema-oracle-tts.ps1"
                ""))
            (let air (sense_wav_loopback "C:/tmp/sema-truth.wav" "C:/tmp/sema-air.wav"))
            (if (lt (len air) 4) 0
                (do
                    (let played (nth air 0))
                    (let got (nth air 1))
                    (let peak (nth air 2))
                    (let transcript (host-exec
                        (str_concat "C:\\models\\whisper\\Release\\whisper-cli.exe "
                        (str_concat "-m C:\\models\\whisper\\ggml-base.en.bin "
                                    "-f C:/tmp/sema-air.wav -nt 2>nul"))
                        ""))
                    (let truth (list "open" "speech" "flows"))
                    (let awords (wso-words transcript))
                    (let awav (read_file "C:/tmp/sema-air.wav"))
                    (let cap (slr-capability "windows-amd64" 1 1 1 1 16000 1 1))
                    (let rc (slc-receipt 2 1 (wso-hash "open speech flows") (str_len awav)
                                16000 1 1 1 truth awords (empty) 0 0
                                (slr-effective-fail cap 0) 0 0))
                    (let gone (fs_remove "C:/tmp/sema-air.wav"))
                    (do
                        (print_str (str_concat "air-heard:[" (str_concat (wso-join awords "")
                            (str_concat "] wer=" (str_concat (wso-i2s (slc-oracle-wer rc))
                            (str_concat " peak=" (wso-i2s peak)))))))
                        (add (wal-bit (eq (slr-ready? cap) 1) 1)
                        (add (wal-bit (and (gt played 0) (gt got 0)) 2)
                        (add (wal-bit (gt peak 500) 4)
                        (add (wal-bit (gt (len awords) 0) 8)
                        (add (wal-bit (eq (slc-oracle-wer rc) 0) 16)
                        (add (wal-bit (eq (slc-oracle-success? rc 10) 1) 32)
                        (add (wal-bit (and (eq (slc-valid? rc) 1) (eq (slc-control-clean? rc) 1)) 64)
                             (wal-bit (eq (fs_exists "C:/tmp/sema-air.wav") 0) 128)))))))))))))
    0)
