; concept-video-public-snapshot-world-live.fk -- content-only world admission.
;
; Only targets present in each original public photograph's exact candidate
; set enter the ordinary cwm/wm-model path. Source captions and seven retained
; three-way claim misses cannot create entities. Positions are collection slots
; and are explicitly not object centers, camera poses, or inferred geometry.
;
; witnessed: 2026-07-18 -> 24 content-derived entities, seven misses absent
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk presence/concept-video-public-snapshot-live.fk

(do
  (defn cvpsw-rows (live) (nth (nth live 5) 1))
  (defn cvpsw-original-observations (row) (nth (nth row 5) 1))
  ; The fixture target is consulted only after content inference, to select a
  ; matching returned observation. Every value admitted below is read back
  ; from that observation rather than copied from the fixture tuple.
  (defn cvpsw-detected-target (row)
    (cvol-find-id (cvpsw-original-observations row) (nth (nth row 2) 1)))
  (defn cvpsw-original-present? (row)
    (if (eq (len (cvpsw-detected-target row)) 0) 0 1))
  (defn cvpsw-targets (rows)
    (if (eq (len rows) 0) (empty)
      (if (eq (cvpsw-original-present? (head rows)) 1)
        (cons (head rows) (cvpsw-targets (tail rows)))
        (cvpsw-targets (tail rows)))))
  (defn cvpsw-known (rows)
    (if (eq (len rows) 0) (empty)
      (do (let detected (cvpsw-detected-target (head rows)))
          (cons (cwm-cell (nth detected 0) (nth detected 1))
            (cvpsw-known (tail rows))))))
  (defn cvpsw-persist (rows known index)
    (if (eq (len rows) 0) (empty)
      (do (let detected (cvpsw-detected-target (head rows)))
          (cons (cwm-persist (nth detected 0) (list index 0 0)
                  "public-real-photo" (add 7000 index) known)
            (cvpsw-persist (tail rows) known (add index 1))))))
  (defn cvpsw-label-member? (entities label)
    (if (eq (len entities) 0) 0
      (if (str_eq (wm-ent-id (head entities)) label) 1
        (cvpsw-label-member? (tail entities) label))))
  (defn cvpsw-negative-labels ()
    (list "mill" "wreck" "ship" "bamboo" "access" "wood" "sculpture"))
  (defn cvpsw-negatives-absent (entities labels)
    (if (eq (len labels) 0) 0
      (add (if (eq (cvpsw-label-member? entities (head labels)) 0) 1 0)
        (cvpsw-negatives-absent entities (tail labels)))))
  (defn cvpsw-labels (entities)
    (if (eq (len entities) 0) (empty)
      (cons (wm-ent-id (head entities)) (cvpsw-labels (tail entities)))))
  (defn cvpsw-entities-match-observations? (rows entities)
    (if (eq (len rows) 0) (eq (len entities) 0)
      (if (eq (len entities) 0) 0
        (if (str_eq (wm-ent-id (head entities))
              (nth (cvpsw-detected-target (head rows)) 1))
          (cvpsw-entities-match-observations? (tail rows) (tail entities)) 0))))
  (defn cvpsw-positions-are-slots (entities index)
    (if (eq (len entities) 0) 0
      (add (if (eq (nth (wm-ent-position (head entities)) 0) index) 1 0)
        (cvpsw-positions-are-slots (tail entities) (add index 1)))))

  (defn concept-video-public-snapshot-world-live-run ()
    (do (let live (concept-video-public-snapshot-live-run))
        (let rows (cvpsw-rows live))
        (let targets (cvpsw-targets rows))
        (let known (cvpsw-known targets))
        (let entities (cvpsw-persist targets known 1))
        (let negative-absent (cvpsw-negatives-absent entities (cvpsw-negative-labels)))
        (let slots (cvpsw-positions-are-slots entities 1))
        (let score
          (add (if (eq (nth (nth live 1) 1) 1) 1 0)
            (add (if (eq (len rows) 24) 2 0)
              (add (if (eq (len targets) 24) 4 0)
                (add (if (eq (len known) 24) 8 0)
                  (add (if (eq (len entities) 24) 16 0)
                    (add (if (eq (cwm-concept-count entities) 24) 32 0)
                      (add (if (eq negative-absent 7) 64 0)
                        (add (if (and (eq (len (cvpsw-labels entities)) 24)
                                   (eq (cvpsw-entities-match-observations?
                                     targets entities) 1)) 128 0)
                          (add (if (eq slots 24) 256 0)
                            (if (eq (nth (nth live 4) 3) 7) 512 0)))))))))))
        (list "concept-video-public-snapshot-world-live"
          (cvps-audit-summary-from-live live)
          (list "world-model" (cwm-concept-count entities)
            "admitted-from-original-content" (len targets)
            "three-way-claim-misses-absent" negative-absent
            "positions-are-observation-slots" slots
            "entities" (cvpsw-labels entities) (cwm-world entities))
          (list "score" score 1023))))

  (concept-video-public-snapshot-world-live-run))
