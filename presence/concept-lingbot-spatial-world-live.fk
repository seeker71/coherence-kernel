; concept-lingbot-spatial-world-live.fk -- pixels name a reconstructed place.
;
; One real 24-frame LingBot trajectory is independently observed twice: the
; pretrained content carrier sees four held-out frames and Form decides the
; concept; the native LingBot body visits every source pixel, streams ViT/GCA,
; composes poses, predicts relative depths, and reconstructs its cloud/world.
; Only then is the accepted content identity persisted at the observed final
; camera viewpoint. Neither the scene/config name nor expected id enters
; detection; object-center localization is not claimed.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/geometric-camera.fk model/lingbot-pytorch-checkpoint.fk model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk model/lingbot-geometry-heads.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk model/lingbot-map-runtime.fk model/lingbot-real-life.fk observe/lingbot-map-real-life-acceptance.fk model/concept-video-semantic.fk model/concept-video-content-sensing.fk model/concept-world-model.fk model/concept-spatial-world.fk presence/concept-video-semantic-live.fk presence/concept-video-content-sensing-live.fk

(do
  (defn cslw-config-index (scene)
    (if (str_eq scene "loop") 0 (if (str_eq scene "university") 2 3)))
  (defn cslw-known ()
    (list (cwm-cell 493 "office") (cwm-cell 1927 "university")
          (cwm-cell 9066 "courthouse")))
  (defn cslw-entity (spatial)
    (nth (nth spatial 3) 1))
  (defn cslw-combined-count (spatial)
    (nth (nth spatial 4) 6))

  (defn concept-lingbot-spatial-world-live-run (scene expected-id)
    (do
      (let ready (if (str_eq (host-exec
        "command -v swiftc >/dev/null && command -v ffmpeg >/dev/null && printf 1" "") "1") 1 0))
      (let compiled (if (eq ready 1)
        (if (str_eq (host-exec (cvvsl-compile-command) "") "1") 1 0) 0))
      (let decoded (if (eq compiled 1) (cvsl-decode scene) 0))
      ; These four raw classifier calls receive only BMP paths.
      (let detection (if (eq decoded 1) (cvvsl-detect-raw scene) (empty)))
      ; Config/expected id enter only after the independent content decision.
      (let geometry (lre-run-scene
        (nth (lre-default-configs) (cslw-config-index scene))))
      (let spatial (if (and (eq decoded 1) (eq (nth detection 5) 1))
        (csw-run geometry detection (cslw-known)) (empty)))
      (let entity (if (eq (len spatial) 0) (empty) (cslw-entity spatial)))
      (let position (if (eq (len entity) 0) (list 0.0 0.0 0.0)
                      (wm-ent-position entity)))
      (let score
        (add
          (if (and (eq ready 1) (eq compiled 1)) 1 0)
          (add (if (eq decoded 1) 2 0)
            (add (if (and (eq (nth detection 0) expected-id)
                           (eq (nth detection 5) 1)) 4 0)
              (add (if (eq (lrea-scene-score geometry) 1023) 8 0)
                (add (if (and (not (eq (len entity) 0))
                               (str_eq (wm-ent-id entity) (nth detection 1))) 16 0)
                  (add (if (gt (lgh-vnorm3 position) 0.01) 32 0)
                    (add (if (and (eq (csw-depth-count geometry) 1472)
                                   (eq (csw-cloud-count geometry) 1472)) 64 0)
                         (if (and (not (eq (len spatial) 0))
                                  (eq (cslw-combined-count spatial) 1473)) 128 0)))))))))
      (list "concept-lingbot-spatial-world-live"
        (list "content" scene detection "expected-after-observation" expected-id)
        (list "geometry-acceptance" (lrea-scene-score geometry) 1023)
        spatial
        (list "score" score 255))))

  0)
