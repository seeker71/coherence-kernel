; cell-type-band.fk — stone S13: the eval-level type / contract system, proven.
;
; A TYPE is the interface a cell offers (axiom-4); the BLUEPRINT is the structural
; type (axiom-3); type-checking is the boundary's trust decision and a mismatch
; ACKS NOTHING (axiom-1 / axiom-5). The structural decision (ty-of / ty-satisfies?
; / width-subtyping / key-read) is pure list+string ops, so it crosses FOUR-WAY.
; The decline ARM — a mismatch acks the canonical first-class (nothing) — is the
; fkwu-native reduction-step ack (stone 2a), proven on --src exactly as nothing is
; (the three walkers do not carry nothing?, as their stone-2a counterpart noted).
;
; Cells are bound as NULLARY DEFNS (the fourth-arm-band-scope idiom): a composed
; cell stored through `let` degenerates on the --src seed, so each cell is a
; nullary recipe rebuilt at use — walker-portable, four-way clean.
;
; FOUR-WAY VERDICT 1013 when every structural claim lands:
;   3      ty-of(person) offers THREE keys — the structural type IS the offered
;          interface (axiom-4), read through the existing cell-card facets.
;   +10    ty-satisfies?(person, Identifiable) = 1 — the cell offers every key the
;          interface requires (axiom-3 structural match; WIDTH-SUBTYPING: person
;          offers name/where/age, the interface demands name/where → admit).
;   +100*0 ty-satisfies?(bad, Identifiable) = 0 — bad offers only name, missing
;          where → the boundary's structural verdict is NO (the decline the
;          nothing-arm dresses; here as the four-way-portable 0).
;   +1000  ty-of(person) head = "name" — the offered shape is readable and ordered
;          (the Blueprint is the present structural type, axiom-3).
;
; THE NOTHING-ARM (fkwu-native --src, the axiom-1 turn — NOT folded into the
; four-way number since the walkers lack nothing?):
;   (ty-check person Identifiable)            -> 1            (admit ack)
;   (nothing? (ty-check bad Identifiable))    -> 1            (decline acks NOTHING)
;   (eq (ty-check bad Identifiable) 0)        -> 0            (decline is NOT 0)
; The decline is the canonical first-class (nothing) (stone 2a), returned LIVE as
; the tail value so the boundary's ack is observable — the mismatch acks nothing.
;
; preludes: substrate/channel-interface.fk substrate/cross-cell-interface.fk substrate/cell-card.fk substrate/cell-type.fk

(do
    ; a real cell offering three keys (its structural type / interface).
    (defn person ()
        (cell-make "p1" "Ana"
            (list (facet-make "name"  "what"  "Ana")
                  (facet-make "where" "where" "Bali")
                  (facet-make "age"   "what"  30))
            (list)))

    ; the Identifiable interface-cell: a contract IS a cell offering the required
    ; keys (axiom-4) — checking-against-a-contract and checking-against-a-cell's
    ; offer are the SAME engine, the contract carried as data.
    (defn iface-id () (iface-make "Identifiable" (list "name" "where")))

    ; a cell that does NOT satisfy: it offers only name, the interface needs where.
    (defn bad () (cell-make "q1" "Bo" (list (facet-make "name" "what" "Bo")) (list)))

    ; ── the four-way structural witness ────────────────────────────────────────
    ;   3  + 10*1  + 100*0  + 1000*1  = 1013
    (add (len (ty-of (person)))
        (add (mul 10  (ty-satisfies? (person) (iface-id)))
            (add (mul 100 (ty-satisfies? (bad)    (iface-id)))
                 (mul 1000 (if (str_eq (head (ty-of (person))) "name") 1 0))))))
