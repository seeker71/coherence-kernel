; channel-interface-band.fk — proof of the interface-consent law.
;
; preludes: form-stdlib/core.fk form-stdlib/channel-interface.fk
;
; A cell offers the interface {witness, see, invite} — it allows being witnessed,
; seen into, and invited; it does NOT offer reflect or project. Then:
;   see      -> honored   (in the offer)
;   invite   -> honored   (in the offer)
;   project  -> INVASION  (not offered — reaching beyond)
;   silence  -> honored   (always, even though not listed in the offer)
; And the flow of my intents {see, project, invite} toward that offer keeps exactly
; {see, invite} — the un-offered project never crosses.
;
; Verdict 127 when every assertion holds across sibling kernels and fkwu.

(do
    (defn ci-band-score (ok bit) (if ok bit 0))

    (let offer (list (m-witness) (m-see) (m-invite)))
    (let f     (ci-flow (list (m-see) (m-project) (m-invite)) offer))

    (sum
        (list
            (ci-band-score (ci-honors? (m-see) offer) 1)
            (ci-band-score (ci-honors? (m-invite) offer) 2)
            (ci-band-score (ci-invasion? (m-project) offer) 4)
            (ci-band-score (ci-honors? (m-silence) offer) 8)
            (ci-band-score (eq (len f) 2) 16)
            (ci-band-score (eq (head f) (m-see)) 32)
            (ci-band-score (eq (head (tail f)) (m-invite)) 64))))
