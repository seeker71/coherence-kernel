; native-structures-band.fk — STONE S8 HARD GATE, four-way where value-pure.
;
; Proves, in ONE arithmetic witness, the array roundtrip + the content-addressed
; map roundtrip + the miss->nothing observable:
;
;   ARRAY  a-set then a-get returns the set value; untouched cells keep their value;
;          a-len is the count.
;   MAP    m-put then m-get returns the put value; a second distinct key is held
;          independently (no collision); a re-put of the SAME content-key shadows
;          (axiom-3 dedup, latest wins); m-get of a MISSING key acks `nothing`.
;
; Witness packs every fact into one integer so the gate reads as a single value:
;   arr  = a-set(a-make 6 0, 4, 99)
;     a-get(arr,4) = 99            -> ones+ : 99
;     a-get(arr,0) = 0  (untouched, contributes 0)
;     a-len(arr)   = 6             -> *10^5 : 600000
;   map  = m-put(m-put(m-put(m-make,7,1),3,55),7,2)   ; 7 put twice: latest=2
;     m-get(map,7) = 2  (shadowed) -> *10^3 :  2000
;     m-get(map,3) = 55 (distinct) -> *10^7 : 550000000
;     nothing?(m-get(map,5)) = 1   -> *10^9 : 1000000000   (the miss acks nothing)
;
;   99 + 600000 + 2000 + 550000000 + 1000000000 = 1550602099
;
; FOUR-WAY SCOPE (honest floor):
;   ARRAY side is value-pure over cons/nth/head/tail/len/empty/if/eq/le/arith —
;   crosses FOUR-WAY: fkwu = go = rust = ts = 600099 (witness /tmp/arr-only).
;   MAP side uses the content-address op `make_nodeid` (axiom-3 key) — fkwu-native
;   only: go/rust/ts walkers have no `make_nodeid` (go: unbound; rust/ts: error).
;   This is an UNSUPPORTED OP (the content-address op family is absent on the
;   siblings), NOT a divergence — the axiom-3 keying is exact on fkwu. The full
;   1550602099 gate is the fkwu `--src` receipt; the array sub-witness is the
;   four-way receipt. (Exposing make_nodeid to the siblings closes the gap.)
;
; preludes: form-stdlib/core.fk substrate/native-structures.fk

(do
    ; ARRAY: index 4 set to 99 over a 6-cell array of zeros.
    (defn ns-arr () (a-set (a-make 6 0) 4 99))
    ; MAP: 7->1 then 3->55 then 7->2 (7 re-put: content-key shadows, latest wins).
    (defn ns-map () (m-put (m-put (m-put (m-make) 7 1) 3 55) 7 2))

    (defn ns-gate ()
        (add (a-get (ns-arr) 4)                              ; 99   (set roundtrip)
        (add (mul (a-len (ns-arr)) 100000)                   ; 600000 (len)
        (add (mul (m-get (ns-map) 7) 1000)                   ; 2000 (shadowed put)
        (add (mul (m-get (ns-map) 3) 10000000)               ; 550000000 (distinct key)
             (mul (if (nothing? (m-get (ns-map) 5)) 1 0)     ; miss -> nothing observable
                  1000000000))))))

    (ns-gate))
