; cell-type.fk — stone S13: the eval-level type / contract system, as a Form
; recipe layer over the EXISTING substrate (cell-card facets / Blueprint shape /
; the resolution check). NO runtime/fkwu-uni.c change — this is pure recipe over
; the kernel's already-native list, string, and first-class-nothing primitives.
;
; ── AXIOM DERIVATION (a theorem, not bolted on) ───────────────────────────────
;   axiom-4 (boundary's offer)  : a TYPE *is* the interface a cell offers. The
;                                 keys a cell presents at its boundary ARE its
;                                 type — there is no type apart from the offer.
;   axiom-3 (present shape)      : the BLUEPRINT is the structural type — the
;                                 ordered shape of keys the cell presently is.
;                                 Two cells offering the same keys share a type
;                                 by content, not by name (content-addressing).
;   axiom-1 (first-class nothing): a type MISMATCH acks NOTHING. The boundary,
;                                 asked to admit a cell that does not satisfy the
;                                 interface, declines — and a decline is the
;                                 canonical first-class (nothing), not 0, not an
;                                 error mode (stone 2a). satisfy -> 1; mismatch ->
;                                 (nothing). This is the boundary's trust decision
;                                 expressed as an offer/ack (axiom-5): the check
;                                 OFFERS the cell to the interface; the interface
;                                 ACKS 1 (admit) or nothing (decline).
;
; ── OBSERVABLE ────────────────────────────────────────────────────────────────
;   ty-check is an offer/ack: a satisfying cell ACKS 1; a mismatching cell ACKS
;   (nothing) — observable live via nothing?. The match decision rides only the
;   structural shape (Blueprint), so the satisfy/decline verdict crosses FOUR-WAY
;   as a pure predicate (ty-satisfies?); the nothing-ARM is the fkwu-native
;   reduction-step ack (axiom-1), proven on --src exactly as stone 2a's nothing.
;
; Self-contained over the kernel's native builtins (list, nth, len, head, tail,
; str_eq, eq, if, and) + the cell-card cell/facet shape. A contract is itself an
; interface-cell: a list of required keys is a cell offering exactly that shape,
; so "checking a cell against a contract" and "checking a cell against the type
; another cell offers" are the SAME engine — one recipe, contract as data.
;
; preludes: substrate/channel-interface.fk substrate/cross-cell-interface.fk substrate/cell-card.fk

(do
    ; ── ty-of(cell) -> the STRUCTURAL TYPE (the interface the cell offers) ──────
    ; axiom-4: the type IS the offered interface. A cell offers its facet KEYS;
    ; the structural type is the ordered list of those keys — the Blueprint shape.
    ; This reads through the EXISTING substrate readers (cell-facets / facet-key),
    ; never a parallel structure: the type is derived from the cell as it is.
    (defn ty-keys-of-facets (facets)
        (if (eq (len facets) 0)
            (list)
            (cons (facet-key (head facets))
                  (ty-keys-of-facets (tail facets)))))
    (defn ty-of (cell) (ty-keys-of-facets (cell-facets cell)))

    ; ── an INTERFACE / CONTRACT is itself a cell ───────────────────────────────
    ; A contract is an interface-cell whose facets name the REQUIRED keys. So a
    ; contract's own structural type (ty-of) is exactly the list of keys it
    ; demands — checking-against-a-contract and checking-against-a-cell's-offer
    ; are one engine. iface-make builds the smallest such cell (a name + the
    ; required-key facets); ty-of reads its required shape back out.
    (defn iface-key->facet (k) (facet-make k "require" k))
    (defn iface-keys->facets (ks)
        (if (eq (len ks) 0)
            (list)
            (cons (iface-key->facet (head ks))
                  (iface-keys->facets (tail ks)))))
    (defn iface-make (name required-keys)
        (cell-make name name (iface-keys->facets required-keys) (list)))
    (defn iface-required (iface) (ty-of iface))   ; the keys the interface demands

    ; ── structural membership: does the offered shape CONTAIN key k? ───────────
    (defn ty-offers? (offered k)
        (if (eq (len offered) 0)
            0
            (if (str_eq (head offered) k)
                1
                (ty-offers? (tail offered) k))))

    ; ── ty-satisfies?(cell, iface) -> 1 / 0 (the FOUR-WAY structural verdict) ───
    ; axiom-3: the boundary's trust decision is a pure read of the present shape —
    ; the cell satisfies the interface iff its offered type contains EVERY key the
    ; interface requires (structural width-subtyping: offer at least the demanded
    ; shape). Pure list/string ops -> crosses all four walkers identically. This
    ; is the decision; ty-check wraps it in the offer/ack ARM (1 | nothing).
    (defn ty-covers? (offered required)
        (if (eq (len required) 0)
            1
            (if (eq (ty-offers? offered (head required)) 1)
                (ty-covers? offered (tail required))
                0)))
    (defn ty-satisfies? (cell iface)
        (ty-covers? (ty-of cell) (iface-required iface)))

    ; ── ty-check(cell, iface) -> 1 (admit) | (nothing) (decline) ───────────────
    ; axiom-1 + axiom-5: the boundary OFFERS the cell to the interface and ACKS.
    ; satisfy -> 1 (admit). mismatch -> (nothing): the canonical first-class
    ; decline (stone 2a), NOT 0 and NOT an error mode. The (nothing) is RETURNED
    ; LIVE as the tail value so the caller observes it with nothing? — a stored
    ; nothing loses the reduction-step identity, an offered-and-acked one keeps it.
    (defn ty-check (cell iface)
        (if (eq (ty-satisfies? cell iface) 1)
            1
            (nothing)))

    0)
