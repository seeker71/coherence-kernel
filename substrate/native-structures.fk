; native-structures.fk — STONE S8: native indexed ARRAY + content-addressed MAP.
;
; The two oldest data primitives, derived from the axioms, built as a Form recipe
; layer over the EXISTING kernel core — no change to runtime/fkwu-uni.c's reducer.
;
; AXIOM-GROUNDED
;   ARRAY = axiom-2 (a cell composes indexed children). An array IS a cell whose
;           children are read/written by position; `a-get i` is the i-th child,
;           `a-set i v` is the same composition with one child re-pointed. The
;           indexed-children carrier here is the kernel's cons-list (cons/nth):
;           position is the natural index of axiom-2 composition.
;   MAP   = axiom-3 (content-addressing IS identity). A key's content-hash node-id
;           is its address: same content -> same `make_nodeid` -> same node, so the
;           key IS its address and lookup is match-by-content (node_eq). The
;           content-hash is the hash; the map is keyed by what a key IS, not where
;           it sits. `make_nodeid` is the kernel's existing content-address op.
;
; OBSERVABLE (axiom-5 offer/ack)
;   `a-get` / `m-get` are OFFERS that produce an observable ack: a present value
;   on a hit, and `nothing` (axiom-1) on a miss — `(nothing? (m-get m absent))`
;   is true. The miss is not an error; it is the declined ack the observer reads.
;
; HONEST FLOOR — O(1) and the TCB-follow stone.
;   ARRAY get/set are O(i) here, not O(1): the cons-list reachable from `--src`
;   has no random-access slot. O(1) indexed storage needs a mutable indexed buffer
;   op (`ll-buffer` / `fk_buf` get/set) exposed to the source layer — NOT yet
;   `--src`-reachable (the kernel HAS `fk_buf` internally; no op-name in
;   fkwu-optable.h binds it for source). That is the named TCB-follow stone:
;   "expose the indexed buffer slot to --src", after which a-get/a-set become O(1)
;   with this same recipe shape unchanged (cons-list -> buffer is a carrier swap).
;   MAP lookup is O(n) scan here for the same reason — the kernel's native record
;   (tag 64/65/66/67) is a content-addressed store, but its CONSTRUCTOR (tag 64)
;   has no op-name in fkwu-optable.h, so it is not `--src`-reachable to bootstrap
;   an empty map. Exposing the record constructor (or a content-hash bucket op) to
;   `--src` is the same TCB-follow stone for the map: O(1)-by-content lands when the
;   constructor is reachable; the axiom-3 KEYING (content-hash IS the key) is
;   already exact and proven here over the reachable carrier.
;
; preludes: form-stdlib/core.fk

(do
    ; nil? locally, so the `--src` proof stands without the BML core.fk lowering.
    (defn ns-nil? (xs) (eq (len xs) 0))

    ; ── ARRAY (axiom-2: indexed children) ──────────────────────────────────────
    ; a-make n v  — an array of n cells, each the initial value v.
    (defn a-make (n v) (if (le n 0) (empty) (cons v (a-make (sub n 1) v))))
    ; a-len a     — the count of indexed children.
    (defn a-len (a) (len a))
    ; a-get a i   — the i-th child (axiom-2 position). Out of range -> nothing.
    (defn a-get (a i)
        (if (ns-nil? a) (nothing)
            (if (eq i 0) (head a) (a-get (tail a) (sub i 1)))))
    ; a-set a i v — the same composition with child i re-pointed to v (axiom-3:
    ;               nothing referenced is overwritten; a new shape is composed).
    (defn a-set (a i v)
        (if (ns-nil? a) (empty)
            (if (eq i 0) (cons v (tail a))
                (cons (head a) (a-set (tail a) (sub i 1) v)))))

    ; ── MAP (axiom-3: content-address IS the hash) ─────────────────────────────
    ; m-key k — the content-hash node-id of key k: same content -> same id. The
    ;           key IS its address. (Carries an int key as the instance field of a
    ;           content-addressed node; any content the encoder hashes works.)
    (defn m-key (k) (make_nodeid (list 0 0 0 k)))
    ; m-make    — the empty map.
    (defn m-make () (empty))
    ; m-put m k v — bind k's content-address to v. Latest binding wins (a re-put of
    ;               the same content-id shadows; axiom-3 dedup: same content, same id).
    (defn m-put (m k v) (cons (m-key k) (cons v m)))
    ; m-find m id — match by content-hash id (node_eq). Hit -> value; miss -> nothing.
    (defn m-find (m id)
        (if (ns-nil? m) (nothing)
            (if (node_eq (head m) id) (head (tail m))
                (m-find (tail (tail m)) id))))
    ; m-get m k   — offer the content-address; the ack is the value or nothing.
    (defn m-get (m k) (m-find m (m-key k)))
    ; m-has? m k  — observable membership: did the offer ack a present value?
    (defn m-has? (m k) (if (nothing? (m-get m k)) false true))

    0)
