(do (defn max2 (a b) (if (gt a b) a b)) (defn idea_score (potential_value confidence estimated_cost resistance_risk) (do (let denom (max2 (_plus estimated_cost resistance_risk) 0.5)) (div (mul potential_value confidence) denom))) (let potential_value 8.0) (let confidence 0.75) (let estimated_cost 2.0) (let resistance_risk 1.0) (idea_score potential_value confidence estimated_cost resistance_risk))
