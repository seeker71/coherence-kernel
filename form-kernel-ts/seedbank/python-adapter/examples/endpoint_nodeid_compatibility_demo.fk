(do (defn match1 (x y) (if (eq x y) 1 0)) (defn compatibility (a_pkg a_lvl a_type a_inst b_pkg b_lvl b_type b_inst) (do (let c (_plus (match1 a_pkg b_pkg) (match1 a_lvl b_lvl))) (do (let c (_plus (_plus c (match1 a_type b_type)) (match1 a_inst b_inst))) c))) (let a_pkg 1) (let a_lvl 5) (let a_type 4) (let a_inst 1) (let b_pkg 1) (let b_lvl 4) (let b_type 4) (let b_inst 7) (compatibility a_pkg a_lvl a_type a_inst b_pkg b_lvl b_type b_inst))
