(do (defn cost_vector (estimated_cost) (do (let compute_cc (round_ndigits (mul estimated_cost 0.6) 4)) (do (let infrastructure_cc (round_ndigits (mul estimated_cost 0.15) 4)) (do (let human_attention_cc (round_ndigits (mul estimated_cost 0.25) 4)) (do (let opportunity_cc 0.0) (do (let external_cc 0.0) (do (let total_cc (round_ndigits estimated_cost 4)) (list compute_cc infrastructure_cc human_attention_cc opportunity_cc external_cc total_cc)))))))) (let estimated_cost 33.333) (cost_vector estimated_cost))
