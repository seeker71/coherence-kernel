(do (defn max2 (a b) (if (gt a b) a b)) (defn grounded_roi (estimated_cost actual_cost potential_value actual_value) (do (let value_gap (max2 (sub potential_value actual_value) 0.0)) (do (let remaining_cost_cc (round_ndigits (max2 (sub estimated_cost actual_cost) 0.0) 4)) (do (let value_gap_cc (round_ndigits value_gap 4)) (do (let roi_cc (if (gt remaining_cost_cc 0) (round_ndigits (div value_gap_cc remaining_cost_cc) 4) 0.0)) (list remaining_cost_cc value_gap_cc roi_cc)))))) (let estimated_cost 60.0) (let actual_cost 12.0) (let potential_value 33.333) (let actual_value 8.0) (grounded_roi estimated_cost actual_cost potential_value actual_value))
