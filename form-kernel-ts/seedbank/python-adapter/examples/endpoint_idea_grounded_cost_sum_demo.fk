(do (defn total_actual_cost (specs) (do (let total 0.0) (do (do (defn _for_0 (_remaining total) (if (eq (len _remaining) 0) total (do (let s (head _remaining)) (let total (_plus total (_get s "actual_cost"))) (_for_0 (tail _remaining) total)))) (let total (_for_0 (_iter specs) total))) total))) (defn total_actual_value (specs) (do (let total 0.0) (do (do (defn _for_1 (_remaining total) (if (eq (len _remaining) 0) total (do (let s (head _remaining)) (let total (_plus total (_get s "actual_value"))) (_for_1 (tail _remaining) total)))) (let total (_for_1 (_iter specs) total))) total))) (defn grounded_cost_sum (specs) (list (total_actual_cost specs) (total_actual_value specs))) (let specs (list (_dict_new "actual_cost" 3.5 "actual_value" 1.5) (_dict_new "actual_cost" 1.25 "actual_value" 0.0) (_dict_new "actual_cost" 0.5 "actual_value" 2.25))) (grounded_cost_sum specs))
