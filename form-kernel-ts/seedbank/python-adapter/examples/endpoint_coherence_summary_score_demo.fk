(do (defn min2 (a b) (if (gt a b) b a)) (defn max2 (a b) (if (gt a b) a b)) (defn clamp01 (x) (max2 0.0 (min2 x 1.0))) (defn safe_ratio (num denom) (if (gt denom 0) (div (_plus num 0.0) (_plus denom 0.0)) 0.0)) (defn coherence_summary_score (task_count target_state_count evidence_count task_card_count task_card_scores_sum task_card_scores_len) (do (let target_state_coverage (safe_ratio target_state_count task_count)) (do (let evidence_coverage (safe_ratio evidence_count task_count)) (do (let task_card_coverage (safe_ratio task_card_count task_count)) (do (let task_card_quality (safe_ratio task_card_scores_sum task_card_scores_len)) (do (let combination (_plus (_plus (_plus (mul 0.35 target_state_coverage) (mul 0.3 task_card_quality)) (mul 0.2 task_card_coverage)) (mul 0.15 evidence_coverage))) (do (let score (if (gt task_count 0) (clamp01 combination) 0.5)) (list (round_ndigits score 4) (round_ndigits target_state_coverage 4) (round_ndigits task_card_coverage 4) (round_ndigits task_card_quality 4) (round_ndigits evidence_coverage 4))))))))) (let task_count 10) (let target_state_count 7) (let evidence_count 5) (let task_card_count 6) (let task_card_scores_sum 4.5) (let task_card_scores_len 6) (coherence_summary_score task_count target_state_count evidence_count task_card_count task_card_scores_sum task_card_scores_len))
