(do (defn dot (values weights) (do (let total 0.0) (do (let i 0) (do (let n (len values)) (do (do (defn _while_0 (total i) (if (lt i n) (do (do (let total (_plus total (mul (_get values i) (_get weights i)))) (let i (_plus i 1))) (_while_0 total i)) (list total i))) (let _while_1_result (_while_0 total i)) (let total (nth _while_1_result 0)) (let i (nth _while_1_result 1))) total))))) (defn sum_floats (weights) (do (let total 0.0) (do (let i 0) (do (let n (len weights)) (do (do (defn _while_1 (total i) (if (lt i n) (do (do (let total (_plus total (_get weights i))) (let i (_plus i 1))) (_while_1 total i)) (list total i))) (let _while_2_result (_while_1 total i)) (let total (nth _while_2_result 0)) (let i (nth _while_2_result 1))) total))))) (defn weighted_average (values weights) (do (let numerator (dot values weights)) (do (let denominator (sum_floats weights)) (div numerator denominator)))) (let values (list 0.5 0.75 1.0)) (let weights (list 0.25 0.25 0.5)) (weighted_average values weights))
