(do (defn value_vector (potential_value) (do (let adoption_cc (round_ndigits (mul potential_value 0.5) 4)) (do (let lineage_cc (round_ndigits (mul potential_value 0.3) 4)) (do (let friction_avoided_cc (round_ndigits (mul potential_value 0.2) 4)) (do (let revenue_cc 0.0) (do (let total_cc (round_ndigits potential_value 4)) (list adoption_cc lineage_cc friction_avoided_cc revenue_cc total_cc))))))) (let potential_value 9.205) (value_vector potential_value))
