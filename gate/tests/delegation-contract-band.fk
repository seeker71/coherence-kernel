; delegation-contract-band.fk — the fiduciary law holds every arm: done is
; a postcondition observed, authority refuses out-of-scope, the fallen-short
; attempt escalates to its NAMED target (the human is first-class), and an
; ungrounded contract is unfit before the worker is ever judged.
;
; preludes: form-stdlib/core.fk gate/delegation-contract.fk
;
; run: cat form/form-stdlib/core.fk gate/delegation-contract.fk \
;          gate/tests/delegation-contract-band.fk > /tmp/dc.fk
;      ./fkwu --src /tmp/dc.fk    ; -> 127
;
; Verdict 127 when the contract is honest.

(do
    (defn dcb-score (ok bit) (if ok bit 0))
    (defn delegation-contract-band ()
        (do
    (let human-k  (dc-contract 127 1 (list 10 11) 1))
    (let oracle-k (dc-contract 15 1 (list 20) 2))
    ; the observed postcondition completes the contract
    (let c0 (dcb-score (eq (dc-verdict human-k 127) 2) 1))
    ; a helpful-but-wrong result does NOT complete — it escalates
    (let c1 (dcb-score (eq (dc-verdict human-k 42) 1) 2))
    ; the escalation target is named before the work: the HUMAN
    (let c2 (dcb-score (eq (dc-escalates-to-human? human-k) 1) 4))
    ; ...and the oracle-armed contract names the oracle, not the human
    (let c3 (dcb-score (and (eq (dc-escalate-to oracle-k) 2)
                            (eq (dc-escalates-to-human? oracle-k) 0)) 8))
    ; authority: in-scope acts, out-of-scope is refused
    (let c4 (dcb-score (and (eq (dc-act human-k 11) 1)
                            (eq (dc-act human-k 12) 0)) 16))
    ; an ungrounded contract is unfit even when the number matches
    (let c5 (dcb-score (eq (dc-verdict (dc-contract 127 0 (list 10) 1) 127) 0) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (dcb-score (eq (delegation-contract-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (delegation-contract-band))
