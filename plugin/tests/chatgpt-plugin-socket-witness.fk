; tests/chatgpt-plugin-socket-witness.fk — the live lane: one real HTTP request over 127.0.0.1 TCP
; through plugin/chatgpt-plugin.fk's own serve path (accept -> stream-recv -> handle -> stream-send
; -> close), single-process loopback in the same shape tests/fkwu-src-socket-loopback-band.fk
; proved for the raw sockets.
;
; preludes: form-stdlib/core.fk form-stdlib/relationship-store.fk form-stdlib/circle-recognition.fk cognition/text-frequency.fk plugin/chatgpt-plugin.fk
;
; Run (from the repo root):
;   ( cat form/form-stdlib/core.fk form/form-stdlib/relationship-store.fk \
;     form/form-stdlib/circle-recognition.fk cognition/text-frequency.fk plugin/chatgpt-plugin.fk \
;     plugin/tests/chatgpt-plugin-socket-witness.fk ) > /tmp/cpsw.fk && ./fkwu --src /tmp/cpsw.fk
;
; Verdict: 11111 when the listener opens, the wire carries the request, the served response is a
; 200 that grounds the question in judged-trust, and the client reads the same bytes the server sent.

(do
    (defn cpsw-score (cond bit) (if cond bit 0))
    (defn cpsw-recv-all (h acc)
        (do
            (let chunk (socket_recv h 65536))
            (if (eq (str_len chunk) 0) acc (cpsw-recv-all h (str_concat acc chunk)))))

    (defn chatgpt-plugin-socket-witness ()
        (do
            (let srv (socket_listen 0))
            (let port (socket_port srv))
            (let cli (socket_connect "127.0.0.1" port))
            (let sent (socket_send cli "GET /ask?q=trust%20over%20fear HTTP/1.1\r\nHost: witness\r\n\r\n"))
            (let served (cp-serve-conn (socket_accept srv)))
            (let got (cpsw-recv-all cli ""))
            (let cli-closed (socket_close cli))
            (let srv-closed (socket_close srv))
            (add (add (add (add
                (cpsw-score (gt port 0) 1)
                (cpsw-score (ge (str_find served "HTTP/1.1 200" 0) 0) 10))
                (cpsw-score (ge (str_find served "judged-trust" 0) 0) 100))
                (cpsw-score (str_eq got served) 1000))
                (cpsw-score (eq srv-closed 0) 10000))))

    (chatgpt-plugin-socket-witness))
