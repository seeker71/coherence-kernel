; tests/chatgpt-plugin-band.fk — witness band for plugin/chatgpt-plugin.fk (the rented-mind door).
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk cognition/text-frequency.fk plugin/chatgpt-plugin.fk
;
; PURE, no socket: plugin-handle is called on hardcoded request STRINGS and the produced wire
; responses are checked for the load-bearing content — the parse -> route -> ground -> attune ->
; trace arc, plus the honesty edges (miss named as miss, unknown path a 404, absent frequency
; "unread"). The manifest/openapi checks read the committed plugin/*.json via read_file, so run
; this band FROM THE REPO ROOT (the same convention rag-ask.fk's default index path carries).
;
; fkwu-witnessed on `fkwu --src` (socket/read_file are the fkwu surface; four-way is not claimed).
; Run:
;   ( cat form/form-stdlib/core.fk form/form-stdlib/sha256.fk cognition/text-frequency.fk \
;     plugin/chatgpt-plugin.fk plugin/tests/chatgpt-plugin-band.fk ) > /tmp/cpb.fk \
;   && ./fkwu --src /tmp/cpb.fk
;
; Verdict: 111111111111 (twelve decimal bits) when every check passes; any other value names the
; failing bit by position. Bits 10 and 11 witness the enquiry lane: the in-band workings
; (index named, oracles honestly none) and a REAL boot-table NodeID (sha256: prefix) carried
; in the ask response. Bit 12 witnesses /privacy serving the committed policy from the door
; itself.

(do
    (defn cpb-contains? (s needle) (ge (str_find s needle 0) 0))
    (defn cpb-score (cond bit) (if cond bit 0))

    (defn cpb-req (target)
        (str_concat "GET " (str_concat target " HTTP/1.1\r\nHost: witness\r\n\r\n")))

    (defn chatgpt-plugin-check ()
        (do
            ;; a REAL one-cell boot table: the trust question grounds on judged-trust, so its
            ;; enquiry row must carry a true sha256 content address, not the pending marker.
            (let nidtable (list (list "judged-trust" (cp-nodeid-of "ingest/judged-trust.fk"))))
            (let welcome (plugin-handle (cpb-req "/") (empty)))
            (let ask (plugin-handle (cpb-req "/ask?q=can%20I%20trust%20this%20body") nidtable))
            (let fear-band (cp-band-of (cp-charged (cp-tokens "i am afraid this will collapse"))))
            (let love-band (cp-band-of (cp-charged (cp-tokens "i trust the open heart"))))
            (let missing (plugin-handle (cpb-req "/no-such-door") (empty)))
            (let decoded (cp-url-decode "hello%20world+x"))
            (let trace (plugin-handle (cpb-req "/trace?path=ingest%2Fjudged-trust.fk") (empty)))
            (let miss (plugin-handle (cpb-req "/ask?q=zxqv%20wubble") (empty)))
            (let manifest (plugin-handle (cpb-req "/.well-known/ai-plugin.json") (empty)))
            (let privacy (plugin-handle (cpb-req "/privacy") (empty)))
            (add (add (add (add (add
                (cpb-score (cpb-contains? welcome "HTTP/1.1 200") 1)
                (cpb-score (cpb-contains? ask "judged-trust") 10))
                (add (cpb-score (if (str_eq fear-band "fear") (str_eq love-band "love") false) 100)
                     (cpb-score (cpb-contains? ask "commits/main") 1000)))
                (add (add (cpb-score (cpb-contains? missing "HTTP/1.1 404") 10000)
                          (cpb-score (str_eq decoded "hello world x") 100000))
                     (add (cpb-score (cpb-contains? trace "blame/main/ingest/judged-trust.fk") 1000000)
                          (cpb-score (cpb-contains? miss "grounded:miss") 10000000))))
                (cpb-score (cpb-contains? manifest "name_for_model") 100000000))
                (add (add (cpb-score (if (cpb-contains? ask "lexical-seed-v1")
                                    (if (cpb-contains? ask "oracle_remote") (cpb-contains? ask "matched_tokens") false)
                                    false) 1000000000)
                     (cpb-score (cpb-contains? ask "sha256:") 10000000000))
                     (cpb-score (if (cpb-contains? privacy "HTTP/1.1 200") (cpb-contains? privacy "Privacy Policy") false) 100000000000)))))

    (chatgpt-plugin-check))
