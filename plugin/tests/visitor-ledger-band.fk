; tests/visitor-ledger-band.fk — witness band for the arrival ledger and the remember-me offer at
; the rented-mind door (plugin/chatgpt-plugin.fk).
;
; preludes: form-stdlib/core.fk form-stdlib/relationship-store.fk form-stdlib/circle-recognition.fk cognition/text-frequency.fk plugin/chatgpt-plugin.fk
;
; PURE over request strings (no socket): plugin-handle-arrive is called with a ledger threaded
; exactly as plugin-serve-loop threads it, so what this band proves is what the live loop does.
; The memory doors write REAL rows under plugin/circle/ (gitignored) through relationship-store.fk,
; so run this band FROM THE REPO ROOT; the band cleans its own witness handle before and after.
;
; Run:
;   ( cat form/form-stdlib/core.fk form/form-stdlib/relationship-store.fk \
;     form/form-stdlib/circle-recognition.fk cognition/text-frequency.fk plugin/chatgpt-plugin.fk \
;     plugin/tests/visitor-ledger-band.fk ) > /tmp/vlb.fk && ./fkwu --src /tmp/vlb.fk
;
; Verdict: 1111111111 (ten decimal bits) when every check passes; any other value names the
; failing bit by position.
;   1 — /ask carries the remember-me offer in-band
;   2 — the /ask arrival row: ordinal 1, door /ask, offer extended
;   3 — the row's connected cells name the grounded organ; the frequency band is read
;   4 — a machine door (/openapi.json) is arrival 2 and carries no offer
;   5 — /visitors shows both arrivals with connected cells, and holds NO question text
;   6 — an unknown handle at /come-in gets the empty-room greeting (stranger, nothing presumed)
;   7 — /remember with the visitor's own yes writes, verifies, and the row says member
;   8 — /come-in now recognizes the member: welcome back, memory in hand
;   9 — /forget is total revocation: the handle returns to stranger
;  10 — a handle that could walk the filesystem is refused with 400

(do
    (defn vlb-contains? (s needle) (ge (str_find s needle 0) 0))
    (defn vlb-score (cond bit) (if cond bit 0))
    (defn vlb-req (target)
        (str_concat "GET " (str_concat target " HTTP/1.1\r\nHost: witness\r\n\r\n")))
    (defn vlb-resp (rr) (head rr))
    (defn vlb-row (rr) (head (tail rr)))

    (defn visitor-ledger-check ()
        (do
            ; clean state for the witness handle (idempotent remove)
            (let _c (cr-forget-member (cp-circle-dir) "witness-w1"))

            ; arrival 1: /ask — the offer in-band, the row grounded
            (let r1 (plugin-handle-arrive (vlb-req "/ask?q=can%20I%20trust%20this%20body") (empty)))
            (let row1 (vlb-row r1))
            (let led1 (cons row1 (empty)))
            (let b1 (vlb-score (vlb-contains? (vlb-resp r1) "/remember?handle=") 1))
            (let b2 (vlb-score (and (eq (nth row1 0) 1)
                                    (and (str_eq (nth row1 1) "/ask") (eq (nth row1 2) 1))) 10))
            (let b3 (vlb-score (and (eq (cp-in? "ingest/judged-trust.fk" (nth row1 3)) 1)
                                    (str_eq (nth row1 4) "love")) 100))

            ; arrival 2: a machine door — recorded, no offer
            (let r2 (plugin-handle-arrive (vlb-req "/openapi.json") led1))
            (let led2 (cons (vlb-row r2) led1))
            (let b4 (vlb-score (and (eq (nth (vlb-row r2) 0) 2) (eq (nth (vlb-row r2) 2) 0)) 1000))

            ; arrival 3: /visitors — both arrivals visible, the visitor's words NOT held
            (let r3 (plugin-handle-arrive (vlb-req "/visitors") led2))
            (let b5 (vlb-score (and (vlb-contains? (vlb-resp r3) "\"count\":2")
                                    (and (vlb-contains? (vlb-resp r3) "ingest/judged-trust.fk")
                                         (if (vlb-contains? (vlb-resp r3) "trust this body") false true))) 10000))

            ; the memory doors: stranger -> own yes -> member -> revocation -> stranger
            (let r4 (plugin-handle-arrive (vlb-req "/come-in?handle=witness-w1") led2))
            (let b6 (vlb-score (vlb-contains? (vlb-resp r4) "the room is empty and yours") 100000))
            (let r5 (plugin-handle-arrive (vlb-req "/remember?handle=witness-w1&note=here%20to%20witness") led2))
            (let b7 (vlb-score (and (vlb-contains? (vlb-resp r5) "\"remembered\":\"witness-w1\"")
                                    (str_eq (nth (vlb-row r5) 5) "member")) 1000000))
            (let r6 (plugin-handle-arrive (vlb-req "/come-in?handle=witness-w1") led2))
            (let b8 (vlb-score (vlb-contains? (vlb-resp r6) "welcome back, witness-w1") 10000000))
            (let r7 (plugin-handle-arrive (vlb-req "/forget?handle=witness-w1") led2))
            (let b9 (vlb-score (and (vlb-contains? (vlb-resp r7) "\"forgotten\"")
                                    (str_eq (cr-recognize (cp-circle-dir) "witness-w1") "stranger")) 100000000))

            ; the filesystem cannot be walked with a handle
            (let r8 (plugin-handle-arrive (vlb-req "/remember?handle=..%2F..%2Fevil&note=x") led2))
            (let b10 (vlb-score (vlb-contains? (vlb-resp r8) "HTTP/1.1 400") 1000000000))

            (add b1 (add b2 (add b3 (add b4 (add b5 (add b6 (add b7 (add b8 (add b9 b10)))))))))))

    (visitor-ledger-check))
