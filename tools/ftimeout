#!/usr/bin/env perl
# ftimeout SECONDS command [args...] — portable timeout for macOS (no GNU coreutils).
# Kills the command after SECONDS; exits 124 on timeout (like GNU timeout), else the
# command's own exit code. Provided because macOS lacks `timeout` and we hit it constantly.
# (Perl is the portable carrier here; a form-native seed primitive — fk_host_exec with a
# fork+alarm — is the hardening, tracked separately.)
use strict; use warnings;
my $secs = shift @ARGV or die "usage: ftimeout SECONDS command [args...]\n";
die "ftimeout: first arg must be seconds\n" unless $secs =~ /^\d+$/;
my $pid = fork();
die "ftimeout: fork failed: $!\n" unless defined $pid;
if ($pid == 0) { exec @ARGV or die "ftimeout: exec failed: $!\n"; }
local $SIG{ALRM} = sub { kill 'KILL', $pid; waitpid($pid, 0); exit 124; };
alarm $secs;
waitpid($pid, 0);
alarm 0;
exit($? >> 8);
