#!/bin/sh
# fgrep [-c] PATTERN FILE — the body's grep, AS A TOOL.
#
# Contract (what the caller sees): `fgrep PATTERN FILE` prints matching lines; `-c` prints the count.
# Nothing else — no preludes, no --src, no T_flat, no tag tables. All of that is internal.
#
# It LOADS a compiled artifact and BUILDS it from source if missing/stale. The artifact backend is a
# drop-in that upgrades WITHOUT changing this interface:
#   today : self-contained source, re-run on fkwu   (the compile path below is still source-level,
#           because producing a .tbl from source is blocked at the serializer, and form-asm arm64
#           dylibs are not byte-conviction-ready yet — see receipts 2026-07-01-four-way-run-tbl-*)
#   next  : a flattened .tbl  (fkwu artifact.tbl)    — once the serializer is unblocked
#   then  : an arm64 .dylib   (loader executes it)   — once model/form-asm.fk passes conviction
set -e
here="$(cd "$(dirname "$0")/.." && pwd)"
forge="$here/.forge"; src="$here/form/form-stdlib/native-edit.fk"; art="$forge/netool.art"

build() { mkdir -p "$forge"; cat "$here/form/form-stdlib/core.fk" "$src" > "$art"; }   # source -> artifact
[ -f "$art" ] && [ ! "$src" -nt "$art" ] || build                                       # load-or-build

mode=lines; [ "$1" = "-c" ] && { mode=count; shift; }
q="$1"; f="$2"
if [ "$mode" = count ]; then
  { cat "$art"; printf '\n(ne-grep-count "%s" (read_file "%s"))\n' "$q" "$f"; } | "$here/fkwu" --src /dev/stdin 2>/dev/null | tail -1
else
  o="$forge/out.$$"
  { cat "$art"; printf '\n(write_file "%s" (ne-grep-file "%s" "%s"))\n' "$o" "$q" "$f"; } | "$here/fkwu" --src /dev/stdin >/dev/null 2>&1
  cat "$o" 2>/dev/null; rm -f "$o"
fi
