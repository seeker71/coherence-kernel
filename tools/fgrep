#!/bin/sh
# fgrep PATTERN FILE — the body's OWN grep (native-edit ne-grep), one call, no rented grep.
# Prints the lines of FILE containing PATTERN (fixed substring). PATTERN/FILE are simple
# strings (no embedded double-quotes). Core.fk + native-edit.fk only — no fsh grammar stack.
#   -c : print the match COUNT instead of the lines.
here="$(cd "$(dirname "$0")/.." && pwd)"
if [ "$1" = "-c" ]; then
  printf '(ne-grep-count "%s" (read_file "%s"))\n' "$2" "$3" \
    | cat "$here/form/form-stdlib/core.fk" "$here/form/form-stdlib/native-edit.fk" - \
    | "$here/fkwu" --src /dev/stdin 2>/dev/null | tail -1
else
  out="${TMPDIR:-/tmp}/fgrep.$$"
  printf '(write_file "%s" (ne-grep-file "%s" "%s"))\n' "$out" "$1" "$2" \
    | cat "$here/form/form-stdlib/core.fk" "$here/form/form-stdlib/native-edit.fk" - \
    | "$here/fkwu" --src /dev/stdin >/dev/null 2>&1
  cat "$out" 2>/dev/null; rm -f "$out"
fi
