; ground-recursive.fk -- recursion witness for the direct-source runner.
;
; This returns fib(10) = 55. The checkout command may pass a trailing 10 for
; readability; direct-source Form does not yet read argv without a table entry.

(defn ground-fib (n)
    (if (lt n 2) n
        (add (ground-fib (sub n 1))
             (ground-fib (sub n 2)))))

(ground-fib 10)
