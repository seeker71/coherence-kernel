; sha256-as-recipe.fk — SHA-256 lives in Form, computed from bitwise primitives.
;
; preludes: form-stdlib/sha256.fk
;
; Walks the discipline Urs named:
;   "we want just primitives in the kernel. and form native code to
;    host native assembly using JIT to have generic cross kernel
;    functions with host native performance"
;
; The recipe in form-stdlib/sha256.fk IS the canonical definition of
; SHA-256 in this body, composed from the kernel's bitwise primitives
; (band, bor, bxor, bnot_u32, shl_u32, shr_u32, rotr_u32, add_u32 —
; the true machine-word primitives that CAN'T be expressed in pure Form).
; A kernel with those primitives can compute the hash from this recipe
; alone. No host crypto library. No SHA-256 native. The recipe is
; sovereign across all three sibling kernels.
;
; This sample validates the recipe against FIPS 180-4 test vectors.
; Real host-speed dispatch is the NEXT breath: a Form→host-asm JIT
; compiler (cranelift in Rust, generated Go source + plugin in Go, the
; existing compiler.ts in TS) that takes this exact recipe and emits
; machine code. Same Form symbol; same canonical authoring; host-fast
; execution per kernel. No new native; the JIT IS the bootstrap.

(do
    (defn nil? (xs) (eq (len xs) 0))
    (defn sum-bytes (bs acc)
        (if (nil? bs) acc (sum-bytes (tail bs) (add acc (head bs)))))

    ;; ---------- FIPS 180-4 TEST VECTORS -----------------------------
    ;; sha256("")    → e3b0c442 98fc1c14 9afbf4c8 996fb924
    ;;                 27ae41e4 649b934c a495991b 7852b855   (sum=4399)
    ;; sha256("abc") → ba7816bf 8f01cfea 414140de 5dae2223
    ;;                 b00361a3 96177a9c b410ff61 f20015ad   (sum=3730)

    (let h-empty (sha256 (list)))
    (let h-abc (sha256 (list 97 98 99)))
    (print "sha256-empty-len:" (len h-empty))
    (print "sha256-empty-sum:" (sum-bytes h-empty 0))
    (print "sha256-abc-len:" (len h-abc))
    (print "sha256-abc-sum:" (sum-bytes h-abc 0))

    ;; Final verdict: 2 when both FIPS vectors match. Three-way sibling
    ;; parity attests every kernel computes sha256 from the recipe alone.
    (add (if (eq (sum-bytes h-empty 0) 4399) 1 0)
         (if (eq (sum-bytes h-abc 0) 3730) 1 0)))
