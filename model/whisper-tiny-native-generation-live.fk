; One policy-constrained generated token from complete encoder+decoder weights.
; This remains a one-step witness, not a transcript or recognition claim.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-vocabulary.fk
(do
  (let encoder-result (wte-infer-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (let encoder (nth encoder-result 27))
  (wtv-generated-step encoder (wtv-prompt-ids) 0))
