; jit-container-profile-register-gate.fk - profile-derived register schedule gate.
;
; preludes: observe/jit-profile-receipt.fk model/jit-container-lowering.fk model/jit-container-backend.fk model/jit-container-backend-register-gate.fk
;
; Prelude:
;   observe/jit-profile-receipt.fk
;   model/jit-container-lowering.fk
;   model/jit-container-backend.fk
;   model/jit-container-backend-register-gate.fk
;
; This compact bridge proves that profile-derived list, array, dict, hashmap, and
; red-black-tree container plans enter the same register-aware backend schedule
; gate as direct backend schedules. It stays separate from the larger
; replacement/live stack so the current source-runner envelope remains stable.

(do
    (defn jcprg-dict-profile ()
        (jpr-receipt 13 8 610 9 1 (jpr-call-mono) (jpr-int) (jpr-dict) 2301 (jpr-string) 0 (jpr-index-none) (jpr-stack-tail) (jpr-cpu-scalar) (jpr-gpu-none) (jpr-deopt-none) 28))
    (defn jcprg-hash-profile () (jpr-hash-sample))
    (defn jcprg-tree-profile ()
        (jpr-receipt 14 9 620 9 1 (jpr-call-poly) (jpr-int) (jpr-rbtree) 0 (jpr-orderable) 0 (jpr-index-none) (jpr-stack-normal) (jpr-cpu-none) (jpr-gpu-warp) (jpr-deopt-none) 33))
    (defn jcprg-array-profile () (jpr-array-sample 700 12))
    (defn jcprg-list-profile () (jpr-list-sample 710 11))
    (defn jcprg-warm-profile ()
        (jpr-receipt 30 1 701 3 1 (jpr-call-poly) (jpr-int) (jpr-hashmap) 0 (jpr-string) 0 (jpr-index-none) (jpr-stack-normal) (jpr-cpu-scalar) (jpr-gpu-none) (jpr-deopt-none) 12))

    (defn jcprg-op-for (r)
        (if (eq (jpr-container r) (jpr-list))
            (jcb-list)
            (if (eq (jpr-container r) (jpr-array))
                (jcb-array)
                (if (eq (jpr-container r) (jpr-dict))
                    (jcb-dict)
                    (if (eq (jpr-container r) (jpr-hashmap))
                        (jcb-hash)
                        (if (eq (jpr-container r) (jpr-rbtree)) (jcb-tree) 0))))))
    (defn jcprg-target-for (r)
        (if (eq (jpr-gpu-reg? r) 1) (jcb-gpu) (jcb-cpu)))
    (defn jcprg-container-direct? (r)
        (if (eq (jpr-index-direct? r) 1)
            1
            (if (eq (jpr-hash-direct? r) 1) 1 (jpr-tree-direct? r))))
    (defn jcprg-tier? (r)
        (if (eq (jpr-deopt r) (jpr-deopt-none))
            (if (eq (jpr-hot-pure? r) 1)
                (if (gt (jpr-opt-mask r) 1) 1 0)
                0)
            0))
    (defn jcprg-regs? (r)
        (if (eq (jpr-cpu-reg? r) 1) 1 (jpr-gpu-reg? r)))
    (defn jcprg-profile-ok? (r)
        (if (eq (jcb-op-ok? (jcprg-op-for r)) 1)
            (if (eq (jcprg-container-direct? r) 1)
                (if (eq (jcprg-tier? r) 1)
                    (jcprg-regs? r)
                    0)
                0)
            0))
    (defn jcprg-schedule (r)
        (if (eq (jcprg-profile-ok? r) 1)
            (jcb-emit (jcprg-target-for r) (jcprg-op-for r))
            (empty)))
    (defn jcprg-ready? (r) (jcbr-schedule-ok? (jcprg-schedule r)))

    (defn jcprg-bit (cond bit) (if cond bit 0))
    (defn jit-container-profile-register-gate-check ()
        (add
            (jcprg-bit (eq (jcprg-ready? (jcprg-dict-profile)) 1) 1)
            (add
                (jcprg-bit (eq (jcprg-ready? (jcprg-hash-profile)) 1) 2)
                (add
                    (jcprg-bit (eq (jcprg-ready? (jcprg-tree-profile)) 1) 4)
                    (add
                        (jcprg-bit (eq (jcbr-cpu-shape? (jcprg-schedule (jcprg-dict-profile))) 1) 8)
                        (add
                            (jcprg-bit (eq (jcbr-cpu-shape? (jcprg-schedule (jcprg-hash-profile))) 1) 16)
                                (add
                                    (jcprg-bit (eq (jcbr-gpu-shape? (jcprg-schedule (jcprg-tree-profile))) 1) 32)
                                    (add
                                    (jcprg-bit (if (eq (jcprg-ready? (jcprg-array-profile)) 1) (eq (jcprg-ready? (jcprg-list-profile)) 1) 0) 64)
                                    (add
                                        (jcprg-bit (if (eq (jcbr-cpu-shape? (jcprg-schedule (jcprg-array-profile))) 1) (eq (jcbr-cpu-shape? (jcprg-schedule (jcprg-list-profile))) 1) 0) 128)
                                        (add
                                            (jcprg-bit (eq (jcprg-ready? (jcprg-warm-profile)) 0) 256)
                                            (add
                                                (jcprg-bit (eq (jcbr-cpu-shape? (jcb-schedule (jcb-cpu) (jcb-hash) (jcb-stream-for (jcb-hash)) 5 2 1 1 1 1 1 1)) 0) 512)
                                                (add
                                                    (jcprg-bit (eq (jcbr-gpu-shape? (jcb-schedule (jcb-gpu) (jcb-hash) (jcb-stream-for (jcb-hash)) 16 1 1 1 1 1 1 1)) 0) 1024)
                                                    (add
                                                        (jcprg-bit (eq (jcbr-receipt-ok? (jcbr-stale-register)) 0) 2048)
                                                        (jcprg-bit (eq (jcbr-receipt-ok? (jcbr-no-maps)) 0) 4096))))))))))))

    0)
