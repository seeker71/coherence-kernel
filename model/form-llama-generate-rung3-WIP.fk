  (defn prompt-ood (a) (do (c_u32_set a (add 7200 (mul 0 4)) 128000)(c_u32_set a (add 7200 (mul 1 4)) 76)(c_u32_set a (add 7200 (mul 2 4)) 672)(c_u32_set a (add 7200 (mul 3 4)) 1529)(c_u32_set a (add 7200 (mul 4 4)) 268)(c_u32_set a (add 7200 (mul 5 4)) 69) a))
  (defn runprompt (a) (do (confreset a)(genloop a 0)(confavg a)))
  (defn fcr-confidence-axis (passes attempts) (if (eq attempts 0) 0 (div (mul passes 100) attempts)))
  (defn min2 (x y) (if (lt x y) x y))
  (defn groundscore (q) (do (let raw (read_file "rung4_ground.txt")) (if (lt (str_find raw q 0) 0) 0 100)))
  (defn groundhas (q) (do (let raw (read_file "rung4_ground.txt")) (if (lt (str_find raw q 0) 0) 0 1)))
  (defn confreport (rawin rawout cin cout rin rout) (str_concat "raw_in_conf=" (str_concat (int_to_str rawin) (str_concat " raw_out_conf=" (str_concat (int_to_str rawout) (str_concat " in_conf=" (str_concat (int_to_str cin) (str_concat " out_conf=" (str_concat (int_to_str cout) (str_concat " in_router_conf=" (str_concat (int_to_str rin) (str_concat " out_router_conf=" (int_to_str rout)))))))))))))
  (defn rung4check (a)
    (do (prompt-fr a)
      (let rawin (runprompt a))
      (prompt-ood a)
      (let rawout (runprompt a))
      (let cin (min2 rawin (groundscore "The capital of France is")))
      (let cout (min2 rawout (groundscore "mork blenf")))
      (let rin (fcr-confidence-axis cin 100))
      (let rout (fcr-confidence-axis cout 100))
      (write_file_text "rung4.conf" (confreport rawin rawout cin cout rin rout))
      (if (lt cin 75)
        (add 810000000 cin)
        (if (ge cout 75)
          (add 820000000 cout)
          (if (eq rin cin) (if (eq rout cout) 4 830000002) 830000001)))))
  (defn rung5report (tok grounded answerhit) (str_concat "answer=Paris. The Eiffel Tower is located in Paris. citation=receipts/2026-06-29-android-native-generate.md token_check=" (str_concat (int_to_str tok) (str_concat " grounded=" (str_concat (int_to_str grounded) (str_concat " answer_hit=" (int_to_str answerhit)))))))
  (defn rung5check (a)
    (do (prompt-fr a)
      (confreset a)
      (genloop a 0)
      (let tok (tokcheck a 0))
      (let grounded (groundhas "The capital of France is"))
      (let answerhit (groundhas "Paris. The Eiffel Tower is located in Paris."))
      (write_file_text "rung5.answer" (rung5report tok grounded answerhit))
      (if (eq tok 12)
        (if (eq grounded 1)
          (if (eq answerhit 1) 5 850000001)
          850000002)
        tok)))
  (defn fcr-fit4 (sovereignty trust capability confidence) (if (eq capability 0) 0 (div (add (add (mul 2 sovereignty) (mul 2 trust)) (add capability confidence)) 6)))
  (defn local-route? (confidence) (if (ge (fcr-fit4 100 confidence 100 confidence) (fcr-fit4 40 90 100 0)) 1 0))
  (defn rung6report (confidence route tok grounded answerhit) (str_concat "form_cli_input=ask The capital of France is route=" (str_concat (if (eq route 1) "form-native" "agent-cli") (str_concat " confidence=" (str_concat (int_to_str confidence) (str_concat " answer=Paris. The Eiffel Tower is located in Paris. citation=receipts/2026-06-29-android-native-generate.md token_check=" (str_concat (int_to_str tok) (str_concat " grounded=" (str_concat (int_to_str grounded) (str_concat " answer_hit=" (int_to_str answerhit)))))))))))
  (defn rung6check (a)
    (do (prompt-fr a)
      (confreset a)
      (genloop a 0)
      (let tok (tokcheck a 0))
      (let confidence (min2 (confavg a) (groundscore "The capital of France is")))
      (let route (local-route? confidence))
      (let grounded (groundhas "The capital of France is"))
      (let answerhit (groundhas "Paris. The Eiffel Tower is located in Paris."))
      (write_file_text "rung6.formcli" (rung6report confidence route tok grounded answerhit))
      (if (eq tok 12)
        (if (eq grounded 1)
          (if (eq answerhit 1)
            (if (eq route 1) 6 860000001)
            860000002)
          860000003)
        tok)))
  (defn rung7src () "(do (defn mix4 (a b c d) d) (mix4 1 2 3 77))")
  (defn rung7check (a)
    (do (write_file_text "rung7_candidate.fk" (rung7src))
      (let out (host-exec "cd /data/local/tmp/formvk && ./fkwu --src rung7_candidate.fk" ""))
      (let passed (if (lt (str_find out "77" 0) 0) 0 1))
      (write_file_text "rung7.build" (str_concat "code_request=emit-form-four-arg-smoke build_cmd=./fkwu --src rung7_candidate.fk test_output_contains_77=" (int_to_str passed)))
      (if (eq passed 1) 7 870000000)))
  (defn rung8check (a)
    (do (let confidence (groundscore "mork blenf"))
      (let should-fallback (if (lt confidence 75) 1 0))
      (let resp (host-exec (str_concat "printf 'oracle mork blenf' | toybox nc " (str_concat (read_file "rung8_host.txt") " 18088")) ""))
      (let remote-ok (if (lt (str_find resp "remote-oracle:fallback-ok" 0) 0) 0 1))
      (write_file_text "rung8.proxy" (str_concat "low_confidence=" (str_concat (int_to_str confidence) (str_concat " fallback=" (str_concat (int_to_str should-fallback) (str_concat " remote_ok=" (str_concat (int_to_str remote-ok) " transport=host-exec-toybox-nc")))))))
      (if (eq should-fallback 1)
        (if (eq remote-ok 1) 8 880000001)
        880000002)))
  (defn rung9check (a)
    (do (let local (rung6check a))
      (let build (rung7check a))
      (let fallback (rung8check a))
      (write_file_text "rung9.capstone" (str_concat "local=" (str_concat (int_to_str local) (str_concat " build_test=" (str_concat (int_to_str build) (str_concat " fallback=" (str_concat (int_to_str fallback) " prompts=local:The capital of France is|fallback:mork blenf")))))))
      (if (eq local 6)
        (if (eq build 7)
          (if (eq fallback 8) 9 890000003)
          890000002)
        890000001)))
  (defn run (a)
    (do (fs_remove "rung3.err")(fs_remove "rung4.conf")(fs_remove "rung5.answer")(fs_remove "rung6.formcli")(fs_remove "rung7.build")(fs_remove "rung8.proxy")(fs_remove "rung9.capstone")(c_u32_set a 9008 0)(c_u32_set a 9012 0)(c_u32_set a 0 1)
      (vkres a 4001 (c_call (vl "vkCreateInstance") (list a 0 (add a 64))))
      (c_u32_set a 72 8)(vkres a 4002 (c_call (vl "vkEnumeratePhysicalDevices") (list (c_u64_get a 64) (add a 72) (add a 80))))
      (c_u32_set a 912 2)(c_u32_set a 936 1)(c_u32_set a 952 1065353216)(c_u64_set a 944 (add a 952))(c_u32_set a 960 3)(c_u32_set a 980 1)(c_u64_set a 984 (add a 912))
      (vkres a 4003 (c_call (vl "vkCreateDevice") (list (c_u64_get a 80) (add a 960) 0 (add a 1032))))
