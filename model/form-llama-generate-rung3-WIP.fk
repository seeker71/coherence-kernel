      (c_u32_set a 3208 7)(c_u32_set a 3212 16)(c_u32_set a 3216 33)(c_u32_set a 3236 1)(c_u32_set a 3240 1)(c_u64_set a 3248 (add a 3208))(vkres a 4004 (c_call (vl "vkCreateDescriptorPool") (list (c_u64_get a 1032) (add a 3216) 0 (add a 3256))))
      (c_u32_set a 4168 39)(c_u32_set a 4172 2)(vkres a 4005 (c_call (vl "vkCreateCommandPool") (list (c_u64_get a 1032) (add a 4168) 0 (add a 4192))))
      (c_u32_set a 4200 40)(c_u64_set a 4216 (c_u64_get a 4192))(c_u32_set a 4224 0)(c_u32_set a 4228 1)(vkres a 4006 (c_call (vl "vkAllocateCommandBuffers") (list (c_u64_get a 1032) (add a 4200) (add a 4232))))
      (c_u32_set a 4344 8)(vkres a 4007 (c_call (vl "vkCreateFence") (list (c_u64_get a 1032) (add a 4344) 0 (add a 4360))))
      (c_u32_set a 6000 3)(c_u32_set a 6032 12)(mkpipe a 0)(c_u32_set a 6000 3)(c_u32_set a 6032 8)(mkpipe a 1)(c_u32_set a 6000 3)(c_u32_set a 6032 4)(mkpipe a 2)(c_u32_set a 6000 3)(c_u32_set a 6032 4)(mkpipe a 3)(c_u32_set a 6000 2)(c_u32_set a 6032 16)(mkpipe a 4)(c_u32_set a 6000 3)(c_u32_set a 6032 12)(mkpipe a 5)
      (mkall a 0)
