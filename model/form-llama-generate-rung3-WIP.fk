  (defn expid (i) (if (eq i 0) 12366 (if (eq i 1) 13 (if (eq i 2) 578 (if (eq i 3) 469 (if (eq i 4) 3168 (if (eq i 5) 301 (if (eq i 6) 22703 (if (eq i 7) 374 (if (eq i 8) 7559 (if (eq i 9) 304 (if (eq i 10) 12366 (if (eq i 11) 13 0)))))))))))))
