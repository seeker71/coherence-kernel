      (rd a 5500 "r2/embd_t0.bin" (bmap a 26) 131334144)(rd a 5501 "r2/embd_t1.bin" (bmap a 27) 131334144)(rd a 5502 "r2/embd_t2.bin" (bmap a 28) 131334144)(rd a 5503 "r2/embd_t3.bin" (bmap a 29) 131334144)(rd a 5504 "r2/embd_t4.bin" (bmap a 30) 131334144)(rd a 5505 "r2/embd_t5.bin" (bmap a 31) 131334144)(rd a 5506 "r2/embd_t6.bin" (bmap a 32) 131334144)(rd a 5507 "r2/embd_t7.bin" (bmap a 33) 131334144)
      (prompt-fr a)
