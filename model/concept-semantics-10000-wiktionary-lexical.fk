; concept-semantics-10000-wiktionary-lexical.fk — three-source lookup.
;
; Selection law: a stable-ID substantive repair definition first for its 111
; migrated anchors, then Princeton WordNet exact/exception, then explicit
; Wiktionary morphology into WordNet, then a revision-pinned first substantive
; Wiktionary definition. Methods 4 and 5 are lexical-source meanings, never
; synsets. Repair priority prevents an old anchor's sense from leaking into the
; new canonical label that deliberately retained its stable ID.
;
; Source record:
;   (id page revision timestamp english-sha lookup title status section
;    definition definition-count morphology-status)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000-substantive-repair-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk
(do
  (defn cs10l-source
    (id page revision timestamp english-sha lookup title status section
     definition definition-count morphology-status)
    (list id page revision timestamp english-sha lookup title status section
      definition definition-count morphology-status))
  (defn cs10l-source-id (s) (nth s 0))
  (defn cs10l-page-id (s) (nth s 1))
  (defn cs10l-revision-id (s) (nth s 2))
  (defn cs10l-timestamp (s) (nth s 3))
  (defn cs10l-english-sha (s) (nth s 4))
  (defn cs10l-lookup (s) (nth s 5))
  (defn cs10l-title (s) (nth s 6))
  (defn cs10l-status (s) (nth s 7))
  (defn cs10l-section (s) (nth s 8))
  (defn cs10l-definition (s) (nth s 9))
  (defn cs10l-definition-count (s) (nth s 10))
  (defn cs10l-morphology-status (s) (nth s 11))
  (defn cs10l-empty-source (id status)
    (cs10l-source id 0 0 "" "" "" "" status "" "" 0 ""))

  (defn cs10l-take-field (payload at width)
    (do (let size (str_to_int (substring payload at (add at width))))
        (let start (add at width))
        (list (substring payload start (add start size)) (add start size))))
  (defn cs10l-source-at-in (index payload id)
    (if (and (ge id 0) (lt id (cs10-count)))
      (do (let base (mul id (cs10l-index-width)))
          (let off (str_to_int (substring index (add base 2) (add base 10))))
          (let plen (str_to_int (substring index (add base 10) (add base 15))))
          (if (eq plen 0) (cs10l-empty-source id "not-in-lexical-pass")
            (do (let p (substring payload off (add off plen)))
                (let lookup-field (cs10l-take-field p 104 2))
                (let title-field (cs10l-take-field p (nth lookup-field 1) 2))
                (let status-field (cs10l-take-field p (nth title-field 1) 2))
                (let section-field (cs10l-take-field p (nth status-field 1) 2))
                (let definition-field (cs10l-take-field p (nth section-field 1) 5))
                (let count-at (nth definition-field 1))
                (let morphology-field (cs10l-take-field p (add count-at 3) 2))
                (cs10l-source id
                  (str_to_int (substring p 0 10))
                  (str_to_int (substring p 10 20))
                  (c10-rtrim-space (substring p 20 40))
                  (substring p 40 104)
                  (nth lookup-field 0) (nth title-field 0) (nth status-field 0)
                  (nth section-field 0) (nth definition-field 0)
                  (str_to_int (substring p count-at (add count-at 3)))
                  (nth morphology-field 0)))))
      (cs10l-empty-source id "out-of-range")))
  (defn cs10l-source-at (id)
    (cs10l-source-at-in
      (read_file (cs10l-index-path)) (read_file (cs10l-payload-path)) id))

  (defn cs10l-source-accepted? (source)
    (if (str_eq (cs10l-status source) "accepted-lexical") 1 0))
  (defn cs10l-repair-source-accepted? (source)
    (if (str_eq (cs10l-status source) "accepted-substantive-repair") 1 0))
  (defn cs10l-semantic-from-source (ranked source)
    (do (let id (cs10l-source-id source))
        (let anchor (c10-concept-at-in ranked id))
        (cs10-semantic id 4 "" (cs10l-section source)
          (c10-concept-label anchor) (cs10l-definition source)
          (cs10l-definition-count source) 1 0 0 "")))
  (defn cs10l-repair-semantic-from-source (ranked source)
    (do (let id (cs10l-source-id source))
        (let anchor (c10-concept-at-in ranked id))
        (cs10-semantic id 5 "" (cs10l-section source)
          (c10-concept-label anchor) (cs10l-definition source)
          (cs10l-definition-count source) 1 0 0 "")))
  (defn cs10l-repair-at-in (ranked repair-index repair-payload id)
    (do (let source (cs10l-source-at-in repair-index repair-payload id))
        (if (cs10l-repair-source-accepted? source)
          (cs10l-repair-semantic-from-source ranked source)
          (cs10-miss id))))
  (defn cs10l-at-in
    (ranked primary-index primary-payload morphology-index morphology-payload
     lexical-index lexical-payload id)
    (if (and (ge id 0) (lt id (cs10-count)))
      (do (let method (cs10w-effective-method-at primary-index morphology-index id))
          (if (gt method 0)
            (cs10w-at-in primary-index primary-payload
              morphology-index morphology-payload id)
            (do (let source (cs10l-source-at-in lexical-index lexical-payload id))
                (if (cs10l-source-accepted? source)
                  (cs10l-semantic-from-source ranked source)
                  (cs10-miss id)))))
      (cs10-miss id)))
  (defn cs10l-at (id)
    (do (let ranked (read_file (c10-ranked-path)))
        (let repair (cs10l-repair-at-in ranked
          (read_file (csr111-semantic-index-path))
          (read_file (csr111-semantic-payload-path)) id))
        (if (cs10-mapped? repair) repair
          (cs10l-at-in ranked
            (read_file (cs10-index-path)) (read_file (cs10-payload-path))
            (read_file (cs10w-index-path)) (read_file (cs10w-payload-path))
            (read_file (cs10l-index-path)) (read_file (cs10l-payload-path)) id))))
  ; Open once for production scans and tests. Re-reading the multi-megabyte
  ; carriers at every lookup is semantically correct but operationally false.
  (defn cs10l-open ()
    (list (read_file (c10-ranked-path))
      (read_file (cs10-index-path)) (read_file (cs10-payload-path))
      (read_file (cs10w-index-path)) (read_file (cs10w-payload-path))
      (read_file (cs10l-index-path)) (read_file (cs10l-payload-path))
      (read_file (csr111-semantic-index-path))
      (read_file (csr111-semantic-payload-path))))
  (defn cs10l-open-at (opened id)
    (do (let repair (cs10l-repair-at-in
          (nth opened 0) (nth opened 7) (nth opened 8) id))
        (if (cs10-mapped? repair) repair
          (cs10l-at-in (nth opened 0) (nth opened 1) (nth opened 2)
            (nth opened 3) (nth opened 4) (nth opened 5) (nth opened 6) id))))
  (defn cs10l-open-source-at (opened id)
    (do (let repair (cs10l-source-at-in (nth opened 7) (nth opened 8) id))
        (if (cs10l-repair-source-accepted? repair) repair
          (cs10l-source-at-in (nth opened 5) (nth opened 6) id))))
  (defn cs10l-method-label (semantic)
    (if (eq (cs10-method semantic) 5) "substantive-id-repair-wiktionary"
      (if (eq (cs10-method semantic) 4) "wiktionary-first-definition"
        (cs10w-method-label semantic))))

)
