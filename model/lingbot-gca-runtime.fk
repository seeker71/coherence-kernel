; lingbot-gca-runtime.fk — executable Geometric Context Attention state.
;
; This is the pure-Form runtime anatomy described in LingBot-Map section 3.2:
;   * every frame contributes M image tokens plus six context tokens;
;   * anchor and pose-reference-window frames retain dense projected K/V;
;   * an evicted window frame retains exactly its six context-token K/V rows;
;   * Video RoPE rotates queries and cached keys by observation time;
;   * GCA consumes the selected cached tensors under an explicit A/T/W mask.
;
; The projection matrices below are small native witness weights, not the
; released LingBot checkpoint.  The state transition and attention are real:
; K and V are distinct matrices, persist across calls, are evicted by tier,
; and directly determine the returned cross-frame attention values.
;
; No trig.fk dependency: lgr-wrap-angle + the fixed polynomials are the local
; four-way-safe replacement for trig.fk's walker-incompatible `round` path.
; preludes: form/form-stdlib/core.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk
(do
  (defn lgr-tier-anchor () 1)
  (defn lgr-tier-trajectory () 2)
  (defn lgr-tier-window () 3)

  ; ---- local Video RoPE -----------------------------------------------------
  (defn lgr-wrap-angle (x)
    (if (gt x 3.141592653589793)
      (lgr-wrap-angle (sub x 6.283185307179586))
      (if (lt x -3.141592653589793)
        (lgr-wrap-angle (add x 6.283185307179586)) x)))
  (defn lgr-sin (angle)
    (do (let x (lgr-wrap-angle angle))
        (let x2 (mul x x))
        (let x3 (mul x x2))
        (let x5 (mul x3 x2))
        (let x7 (mul x5 x2))
        (let x9 (mul x7 x2))
        (add (sub (add (sub x (div x3 6.0)) (div x5 120.0)) (div x7 5040.0))
             (div x9 362880.0))))
  (defn lgr-cos (angle)
    (do (let x (lgr-wrap-angle angle))
        (let x2 (mul x x))
        (let x4 (mul x2 x2))
        (let x6 (mul x4 x2))
        (let x8 (mul x6 x2))
        (add (sub (add (sub 1.0 (div x2 2.0)) (div x4 24.0)) (div x6 720.0))
             (div x8 40320.0))))
  (defn lgr-rotate-pair (a b angle)
    (do (let c (lgr-cos angle))
        (let s (lgr-sin angle))
        (list (sub (mul a c) (mul b s))
              (add (mul a s) (mul b c)))))
  (defn lgr-video-rope (v time)
    (do (let p0 (lgr-rotate-pair (nth v 0) (nth v 1) (mul (mul time 1.0) 0.1)))
        (let p1 (lgr-rotate-pair (nth v 2) (nth v 3) (mul (mul time 1.0) 0.01)))
        (list (nth p0 0) (nth p0 1) (nth p1 0) (nth p1 1))))
  (defn lgr-video-rope-seq (xs time)
    (if (eq (len xs) 0) (empty)
      (cons (lgr-video-rope (head xs) time)
            (lgr-video-rope-seq (tail xs) time))))

  ; ---- six context tokens + explicit Q/K/V projections --------------------
  (defn lgr-last (xs) (if (eq (len (tail xs)) 0) (head xs) (lgr-last (tail xs))))
  (defn lgr-vsum (xs acc)
    (if (eq (len xs) 0) acc (lgr-vsum (tail xs) (tb-vec-add acc (head xs)))))
  (defn lgr-mean-token (tokens)
    (tn-scale (lgr-vsum tokens (tb-zeros (len (head tokens))))
              (div 1.0 (mul (len tokens) 1.0))))
  ; camera, anchor, four register carriers: six frame-derived context rows.
  (defn lgr-context-six (image-tokens)
    (list (lgr-mean-token image-tokens)
          (head image-tokens)
          (nth image-tokens 1)
          (nth image-tokens 2)
          (nth image-tokens 3)
          (lgr-last image-tokens)))
  (defn lgr-full-frame-tokens (image-tokens)
    (append (lgr-context-six image-tokens) image-tokens))

  (defn lgr-wq ()
    (list (list 1.0 0.0 0.0 0.0) (list 0.0 1.0 0.0 0.0)
          (list 0.0 0.0 1.0 0.0) (list 0.0 0.0 0.0 1.0)))
  (defn lgr-wk ()
    (list (list 1.0 0.125 0.0 0.0) (list 0.0 1.0 0.125 0.0)
          (list 0.0 0.0 1.0 0.125) (list 0.125 0.0 0.0 1.0)))
  (defn lgr-wv ()
    (list (list 0.75 0.25 0.0 0.0) (list 0.0 0.75 0.25 0.0)
          (list 0.0 0.0 0.75 0.25) (list 0.25 0.0 0.0 0.75)))
  (defn lgr-project-seq (w xs)
    (if (eq (len xs) 0) (empty)
      (cons (tb-matvec w (head xs)) (lgr-project-seq w (tail xs)))))
  (defn lgr-query-tensor (image-tokens time)
    (lgr-video-rope-seq (lgr-project-seq (lgr-wq) (lgr-full-frame-tokens image-tokens)) time))
  (defn lgr-key-tensor (image-tokens time)
    (lgr-video-rope-seq (lgr-project-seq (lgr-wk) (lgr-full-frame-tokens image-tokens)) time))
  (defn lgr-value-tensor (image-tokens)
    (lgr-project-seq (lgr-wv) (lgr-full-frame-tokens image-tokens)))

  ; ---- persistent tensor cache ---------------------------------------------
  ; entry = (time tier key-matrix value-matrix)
  (defn lgr-entry (time tier keys values) (list time tier keys values))
  (defn lgr-entry-time (e) (nth e 0))
  (defn lgr-entry-tier (e) (nth e 1))
  (defn lgr-entry-keys (e) (nth e 2))
  (defn lgr-entry-values (e) (nth e 3))
  (defn lgr-frame-entry (time tier image-tokens)
    (lgr-entry time tier (lgr-key-tensor image-tokens time) (lgr-value-tensor image-tokens)))
  (defn lgr-take (xs n)
    (if (or (eq n 0) (eq (len xs) 0)) (empty)
      (cons (head xs) (lgr-take (tail xs) (sub n 1)))))
  (defn lgr-compress-entry (e)
    (lgr-entry (lgr-entry-time e) (lgr-tier-trajectory)
               (lgr-take (lgr-entry-keys e) 6)
               (lgr-take (lgr-entry-values e) 6)))

  ; cache = (dense-anchors compact-trajectory dense-local-window)
  (defn lgr-cache (anchors trajectory window) (list anchors trajectory window))
  (defn lgr-cache-empty () (lgr-cache (empty) (empty) (empty)))
  (defn lgr-anchors (s) (nth s 0))
  (defn lgr-trajectory (s) (nth s 1))
  (defn lgr-window (s) (nth s 2))
  (defn lgr-cache-entries (s)
    (append (lgr-anchors s) (append (lgr-trajectory s) (lgr-window s))))
  (defn lgr-cache-frame (state time image-tokens anchor-count window-size)
    (if (lt (len (lgr-anchors state)) anchor-count)
      (lgr-cache
        (append (lgr-anchors state)
                (list (lgr-frame-entry time (lgr-tier-anchor) image-tokens)))
        (lgr-trajectory state) (lgr-window state))
      (do (let dense (append (lgr-window state)
                             (list (lgr-frame-entry time (lgr-tier-window) image-tokens))))
          (if (le (len dense) window-size)
            (lgr-cache (lgr-anchors state) (lgr-trajectory state) dense)
            (lgr-cache (lgr-anchors state)
                       (append (lgr-trajectory state)
                               (list (lgr-compress-entry (head dense))))
                       (tail dense))))))
  (defn lgr-entry-token-count (e) (len (lgr-entry-keys e)))
  (defn lgr-cache-token-count-go (entries)
    (if (eq (len entries) 0) 0
      (add (lgr-entry-token-count (head entries))
           (lgr-cache-token-count-go (tail entries)))))
  (defn lgr-cache-token-count (s) (lgr-cache-token-count-go (lgr-cache-entries s)))

  ; ---- explicit anchor / trajectory / window mask -------------------------
  (defn lgr-visible? (query-time query-tier entry)
    (and (le (lgr-entry-time entry) query-time)
         (if (eq query-tier (lgr-tier-anchor))
           (eq (lgr-entry-tier entry) (lgr-tier-anchor))
           (or (eq (lgr-entry-tier entry) (lgr-tier-anchor))
               (or (eq (lgr-entry-tier entry) (lgr-tier-trajectory))
                   (eq (lgr-entry-tier entry) (lgr-tier-window)))))))
  ; Each row is (frame-time tier visible-bit retained-token-count).
  (defn lgr-mask-row-go (entries query-time query-tier)
    (if (eq (len entries) 0) (empty)
      (do (let e (head entries))
          (cons (list (lgr-entry-time e) (lgr-entry-tier e)
                      (if (lgr-visible? query-time query-tier e) 1 0)
                      (lgr-entry-token-count e))
                (lgr-mask-row-go (tail entries) query-time query-tier)))))
  (defn lgr-mask-row (state query-time query-tier)
    (lgr-mask-row-go (lgr-cache-entries state) query-time query-tier))
  (defn lgr-visible-tensor-go (entries query-time query-tier tensor-index)
    (if (eq (len entries) 0) (empty)
      (if (lgr-visible? query-time query-tier (head entries))
        (append (nth (head entries) tensor-index)
                (lgr-visible-tensor-go (tail entries) query-time query-tier tensor-index))
        (lgr-visible-tensor-go (tail entries) query-time query-tier tensor-index))))
  (defn lgr-visible-keys (state query-time query-tier)
    (lgr-visible-tensor-go (lgr-cache-entries state) query-time query-tier 2))
  (defn lgr-visible-values (state query-time query-tier)
    (lgr-visible-tensor-go (lgr-cache-entries state) query-time query-tier 3))

  ; ---- Geometric Context Attention + atomic streaming step ----------------
  (defn lgr-gca (image-tokens time query-tier state)
    (do (let qs (lgr-query-tensor image-tokens time))
        (let ks (lgr-visible-keys state time query-tier))
        (let vs (lgr-visible-values state time query-tier))
        (if (eq (len ks) 0) (lgr-project-seq (lgr-wv) (lgr-full-frame-tokens image-tokens))
          (tb-attn-seq qs ks vs 0.5))))
  ; returns (attended-frame next-cache exact-mask-used)
  (defn lgr-step (state time image-tokens anchor-count window-size)
    (do (let next (lgr-cache-frame state time image-tokens anchor-count window-size))
        (let tier (if (lt time anchor-count) (lgr-tier-anchor) (lgr-tier-window)))
        (list (lgr-gca image-tokens time tier next)
              next
              (lgr-mask-row next time tier))))
)
