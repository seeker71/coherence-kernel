; concept-semantics-10000-wiktionary-lexical-data.fk — lexical source overlay.
;
; Source: English Wiktionary page revisions, CC BY-SA 4.0.
; This lane carries source definitions verbatim. It does not claim WordNet
; synsets, context disambiguation, or semantics for unresolved corpus fragments.
;
; witnessed: 2026-07-18 -> 1,445 new definitions; 9,889 / 10,000 represented.
; preludes: form/form-stdlib/core.fk
(do
  (defn cs10l-index-path () "model/concept-semantics-10000-wiktionary-lexical-index.dat")
  (defn cs10l-payload-path () "model/concept-semantics-10000-wiktionary-lexical-payload.dat")
  (defn cs10l-blocks-path () "model/concept-semantics-10000-wiktionary-lexical-blocks.dat")
  (defn cs10l-evidence-path () "model/concept-semantics-10000-wiktionary-lexical-evidence.jsonl")
  (defn cs10l-manifest-path () "model/concept-semantics-10000-wiktionary-lexical-source-manifest.txt")
  (defn cs10l-remaining-path () "model/concept-semantics-10000-wiktionary-lexical-remaining.tsv")
  ; index = state[1] valid[1] payload-offset[8] payload-length[5].
  ; state: 0 not in lexical pass, 1 accepted exact title,
  ;        2 accepted capitalized title, 3 explicit miss.
  (defn cs10l-index-width () 15)
  (defn cs10l-accepted-count () 1445)
  (defn cs10l-combined-represented-count () 9889)
  (defn cs10l-combined-hole-count () 111)
  0)
