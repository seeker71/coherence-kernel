; lingbot-learned-map-runtime.fk — released learned pixels enter GCA and world.
;
; Two real consecutive frames produce complete 1024-channel center tokens plus
; twelve spatial 4-channel learned tokens each. The spatial tokens drive the
; operational GCA cache; its attended learned vector becomes the embedding of
; 64 reconstructed native world objects. A zero-input ablation proves the
; released image coefficients affect the admitted world state.
; witnessed: 2026-07-18 -> live loop frames, learned attention/world admission
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/geometric-camera.fk model/lingbot-pytorch-checkpoint.fk model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk model/lingbot-geometry-heads.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk model/lingbot-map-runtime.fk model/lingbot-learned-patch.fk

(do
  (defn llmr-video () "model/fixtures/lingbot-map/real-life/loop-24f.mkv")
  (defn llmr-pattern () "/tmp/lingbot-learned-map-%06d.bmp")
  (defn llmr-path0 () "/tmp/lingbot-learned-map-000001.bmp")
  (defn llmr-path1 () "/tmp/lingbot-learned-map-000002.bmp")
  (defn llmr-images ()
    (lvi-load-video-file (llmr-video) (llmr-pattern) (list (llmr-path0) (llmr-path1))))

  (defn llmr-zero-tokens (count)
    (if (eq count 0) (empty)
      (cons (list 0.0 0.0 0.0 0.0) (llmr-zero-tokens (sub count 1)))))

  ; run = (tag source weight learned attention geometry cloud world comparison).
  (defn llmr-run ()
    (do
      (let pack (llp-load-weights))
      (let images (llmr-images))
      (let image0 (nth images 0))
      (let image1 (nth images 1))
      (let center0 (llp-center-token image0 pack))
      (let center1 (llp-center-token image1 pack))
      (let tokens0 (llp-grid-tokens image0 pack 4 3 4))
      (let tokens1 (llp-grid-tokens image1 pack 4 3 4))

      (let learned-step0 (lgr-step (lgr-cache-empty) 0 tokens0 1 2))
      (let learned-step1 (lgr-step (nth learned-step0 1) 1 tokens1 1 2))
      (let zero-tokens (llmr-zero-tokens 12))
      (let zero-step0 (lgr-step (lgr-cache-empty) 0 zero-tokens 1 2))
      (let zero-step1 (lgr-step (nth zero-step0 1) 1 zero-tokens 1 2))
      (let visual (head (nth learned-step1 0)))
      (let zero-visual (head (nth zero-step1 0)))

      (let n 8)
      (let focal 8.0)
      (let frame0 (lmr-luma-grid (lvi-image-bytes image0) n))
      (let frame1 (lmr-luma-grid (lvi-image-bytes image1) n))
      (let geometry (lgh-predict frame0 frame1 n 2 focal))
      (let pose (nth geometry 0))
      (let depths (nth geometry 1))
      (let cloud (lgh-point-cloud depths n (list focal focal 3.5 3.5) pose))
      (let world (wmlm-world-from-cloud cloud visual))
      (let comparison (lgh-output-comparison frame0 frame1 n (nth geometry 2)))

      (list
        "lingbot-learned-map-runtime"
        (list (llmr-video) (nth image0 2) (nth image1 2))
        (list (llp-weights-valid? pack)
          (lbpt-entry-size (llp-weight-entry pack))
          (lbpt-entry-crc (llp-weight-entry pack))
          (lbpt-entry-size (llp-bias-entry pack))
          (lbpt-entry-crc (llp-bias-entry pack)))
        (list (len center0) (llp-token-fingerprint center0)
          (len center1) (llp-token-fingerprint center1)
          (len tokens0) (len (head tokens0)) (len tokens1) (len (head tokens1)))
        (list visual zero-visual (llp-vector-l1 visual zero-visual)
          (lgr-cache-token-count (nth learned-step1 1)) (nth learned-step1 2))
        geometry cloud world comparison)))

  (defn llmr-source (run) (nth run 1))
  (defn llmr-weight (run) (nth run 2))
  (defn llmr-learned (run) (nth run 3))
  (defn llmr-attention (run) (nth run 4))
  (defn llmr-geometry (run) (nth run 5))
  (defn llmr-cloud (run) (nth run 6))
  (defn llmr-world (run) (nth run 7))
  (defn llmr-comparison (run) (nth run 8))
)
