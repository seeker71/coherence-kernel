; geometric-context-cache.fk — LingBot-Map GCA's exact token-accounting and
; state-transition law, distilled from paper Sec. 3.2 and the pinned cache code.
;
; A dense frame carries M image tokens + 6 special tokens (camera, anchor/scale,
; four registers). Anchors and the k-frame local window stay dense; every older
; frame sheds M image tokens but retains its six temporally ordered trajectory
; tokens. This cell computes the live state, causal baseline, marginal growth,
; paged allocation, and relative-pose supervision pair count.
;
; Honest floor: token/cache mechanics, not attention values or CUDA allocation.
; witnessed: 2026-07-18 -> band 127 four-way (fkwu/Go/Rust/TS)
; preludes: form/form-stdlib/core.fk
(do
  (defn gcc-special () 6)
  (defn gcc-dense-frame (m) (add m (gcc-special)))
  (defn gcc-old-frames (t anchors window) (max2 0 (sub t (add anchors window))))
  (defn gcc-dense-frames (t anchors window) (min2 t (add anchors window)))
  (defn gcc-context-tokens (t anchors window m)
    (add (mul (gcc-dense-frames t anchors window) (gcc-dense-frame m))
         (mul (gcc-old-frames t anchors window) (gcc-special))))
  (defn gcc-causal-tokens (t m) (mul t (gcc-dense-frame m)))
  (defn gcc-saved-tokens (t anchors window m)
    (sub (gcc-causal-tokens t m) (gcc-context-tokens t anchors window m)))
  (defn gcc-growth (t anchors window m)
    (sub (gcc-context-tokens (add t 1) anchors window m)
         (gcc-context-tokens t anchors window m)))
  (defn gcc-pages (tokens page-size)
    (div (add tokens (sub page-size 1)) page-size))
  (defn gcc-relative-pairs (window) (mul window (sub window 1)))
  ; state = (frames dense-frames trajectory-frames visible-tokens)
  (defn gcc-state (t anchors window m)
    (list t (gcc-dense-frames t anchors window) (gcc-old-frames t anchors window)
          (gcc-context-tokens t anchors window m)))
  (defn gcc-append (state anchors window m)
    (gcc-state (add (nth state 0) 1) anchors window m))
)
