; concept-semantics-10000-wiktionary-lexical-audit.fk — bounded full-pass audit.
;
; The builder emits one 12-byte count row per canonical 100-anchor block:
; exact-title[3], capitalized-title[3], rejected[3], valid-source[3]. Form
; composes all 100 blocks without loading the 357 KB definition payload.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-semantics-10000-wiktionary-lexical-data.fk
(do
  (defn cs10l-audit-empty () (list 0 0 0 0))
  (defn cs10l-audit-block-row (blocks block a)
    (do (let start (mul block 12))
        (list
          (add (nth a 0) (str_to_int (substring blocks start (add start 3))))
          (add (nth a 1) (str_to_int (substring blocks (add start 3) (add start 6))))
          (add (nth a 2) (str_to_int (substring blocks (add start 6) (add start 9))))
          (add (nth a 3) (str_to_int (substring blocks (add start 9) (add start 12)))))))
  (defn cs10l-audit-blocks (blocks block a)
    (if (eq block 100) a
      (cs10l-audit-blocks blocks (add block 1)
        (cs10l-audit-block-row blocks block a))))
  (defn cs10l-audit-in (blocks)
    (if (eq (str_len blocks) 1200)
      (cs10l-audit-blocks blocks 0 (cs10l-audit-empty))
      (list -1 -1 -1 -1)))
  (defn cs10l-audit ()
    (cs10l-audit-in (read_file (cs10l-blocks-path))))
  ; (represented holes exact-title capitalized-title rejected valid failures)
  (defn cs10l-completion-audit ()
    (do (let lexical (cs10l-audit))
        (let exact (nth lexical 0))
        (let capitalized-count (nth lexical 1))
        (let rejected (nth lexical 2))
        (let valid (nth lexical 3))
        (let represented (add 8444 (add exact capitalized-count)))
        (list represented (sub 10000 represented) exact capitalized-count
          rejected valid
          (if (and (eq represented (cs10l-combined-represented-count))
                (and (eq rejected (cs10l-combined-hole-count))
                     (eq valid 1556))) 0 1))))
)
