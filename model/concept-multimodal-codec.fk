; concept-multimodal-codec.fk -- one concept identity across text, audio, video.
;
; This is a symbolic multimodal carrier, not a learned audio/video generator.
; It gives every id in the 10,000-concept address space and every one of the
; 13 lens slots an exact signal that Form can generate and sense again:
;
;   text  -- explicit concept/lens signature
;   audio -- three half-second PCM tone bands (id-high, id-low, lens)
;   video -- six PPM frames carrying an 18-bit moving colour code
;
; ffmpeg is only the codec carrier. Form chooses the signal, constructs the
; carrier command, reads the resulting bytes, and recovers the identity.
; Natural-language wording, programming-language syntax, speech, and visual
; semantics live in their lens/model cells; this cell is their common address.
;
; witnessed: 2026-07-18 -> native codec arithmetic and live carrier observed
; preludes: form/form-stdlib/core.fk

(do
  (defn cmm-concept-count () 10000)
  (defn cmm-lens-count () 13)
  (defn cmm-valid-concept? (id)
    (if (and (ge id 0) (lt id (cmm-concept-count))) 1 0))
  (defn cmm-valid-lens? (lens)
    (if (and (ge lens 0) (lt lens (cmm-lens-count))) 1 0))

  (defn cmm-append (a b)
    (if (eq (len a) 0) b (cons (head a) (cmm-append (tail a) b))))
  (defn cmm-take (xs n)
    (if (or (eq n 0) (eq (len xs) 0)) (empty)
      (cons (head xs) (cmm-take (tail xs) (sub n 1)))))
  (defn cmm-drop (xs n)
    (if (or (eq n 0) (eq (len xs) 0)) xs
      (cmm-drop (tail xs) (sub n 1))))

  ; Least-significant bit first: 14 bits cover 0..16383, four cover 0..15.
  (defn cmm-bits (n width)
    (if (eq width 0) (empty)
      (cons (mod n 2) (cmm-bits (div n 2) (sub width 1)))))
  (defn cmm-bits-value-go (bits place total)
    (if (eq (len bits) 0) total
      (cmm-bits-value-go (tail bits) (mul place 2)
        (add total (mul (head bits) place)))))
  (defn cmm-bits-value (bits) (cmm-bits-value-go bits 1 0))
  (defn cmm-code (concept-id lens)
    (cmm-append (cmm-bits concept-id 14) (cmm-bits lens 4)))
  (defn cmm-code-concept (bits) (cmm-bits-value (cmm-take bits 14)))
  (defn cmm-code-lens (bits) (cmm-bits-value (cmm-take (cmm-drop bits 14) 4)))
  (defn cmm-code-valid? (bits)
    (if (and (eq (len bits) 18)
             (and (eq (cmm-valid-concept? (cmm-code-concept bits)) 1)
                  (eq (cmm-valid-lens? (cmm-code-lens bits)) 1))) 1 0))

  (defn cmm-text (concept-id lens label surface)
    (str_concat "concept=" (str_concat (int_to_str concept-id)
      (str_concat "|lens=" (str_concat (int_to_str lens)
        (str_concat "|label=" (str_concat label
          (str_concat "|surface=" surface))))))))

  ; ---- audio --------------------------------------------------------------
  ; The high/low base-100 digits and lens become frequencies separated by
  ; four or twenty hertz. Half-second windows give a two-hertz crossing-count
  ; resolution, enough to recover every code exactly from PCM samples.
  (defn cmm-audio-frequencies (concept-id lens)
    (list (add 300 (mul 4 (div concept-id 100)))
          (add 800 (mul 4 (mod concept-id 100)))
          (add 1300 (mul 20 lens))))
  (defn cmm-frequency-concept (f0 f1)
    (add (mul 100 (div (add (sub f0 300) 2) 4))
         (div (add (sub f1 800) 2) 4)))
  (defn cmm-frequency-lens (f2)
    (div (add (sub f2 1300) 10) 20))
  (defn cmm-q (s) (str_concat "'" (str_concat s "'")))
  (defn cmm-safe-path-byte? (c)
    (if (or (and (ge c 48) (le c 57)) (and (ge c 65) (le c 90))) 1
      (if (or (and (ge c 97) (le c 122)) (eq c 47)) 1
        (if (or (eq c 46) (eq c 45)) 1 (if (eq c 95) 1 0)))))
  (defn cmm-safe-path-go? (s i)
    (if (eq i (str_len s)) 1
      (if (eq (cmm-safe-path-byte? (str_byte_at s i)) 1)
        (cmm-safe-path-go? s (add i 1)) 0)))
  (defn cmm-safe-path? (s)
    (if (eq (str_len s) 0) 0 (cmm-safe-path-go? s 0)))
  (defn cmm-audio-command (concept-id lens path)
    (do (let fs (cmm-audio-frequencies concept-id lens))
        (let f0 (int_to_str (nth fs 0)))
        (let f1 (int_to_str (nth fs 1)))
        (let f2 (int_to_str (nth fs 2)))
        (str_concat "ffmpeg -loglevel error -y -f lavfi -i \"aevalsrc=0.45*if(lt(t\\,0.5)\\,sin(2*PI*"
          (str_concat f0 (str_concat "*t)\\,if(lt(t\\,1.0)\\,sin(2*PI*"
            (str_concat f1 (str_concat "*t)\\,sin(2*PI*"
              (str_concat f2 (str_concat "*t))):s=8000:d=1.5\" -ac 1 -c:a pcm_s16le "
                (str_concat (cmm-q path) " >/dev/null 2>&1 && printf 1"))))))))))
  (defn cmm-generate-audio (concept-id lens path)
    (if (and (eq (cmm-valid-concept? concept-id) 1)
             (and (eq (cmm-valid-lens? lens) 1) (eq (cmm-safe-path? path) 1)))
      (if (str_eq (host-exec (cmm-audio-command concept-id lens path) "") "1") 1 0)
      0))

  (defn cmm-data-offset-go (bs i n)
    (if (gt (add i 4) n) 0
      (if (and (eq (str_byte_at bs i) 100)
               (and (eq (str_byte_at bs (add i 1)) 97)
                    (and (eq (str_byte_at bs (add i 2)) 116)
                         (eq (str_byte_at bs (add i 3)) 97))))
        (add i 8)
        (cmm-data-offset-go bs (add i 1) n))))
  (defn cmm-data-offset (bs) (cmm-data-offset-go bs 12 (str_len bs)))
  (defn cmm-s16 (bs i)
    (do (let u (add (str_byte_at bs i) (mul 256 (str_byte_at bs (add i 1)))))
        (if (ge u 32768) (sub u 65536) u)))
  (defn cmm-positive-crossings (bs start samples i prev total)
    (if (eq i samples) total
      (do (let value (cmm-s16 bs (add start (mul i 2))))
          (cmm-positive-crossings bs start samples (add i 1) value
            (if (and (le prev 0) (gt value 0)) (add total 1) total)))))
  (defn cmm-window-frequency (bs data-offset window)
    (mul 2 (cmm-positive-crossings bs
      (add data-offset (mul window 8000)) 4000 0 0 0)))
  (defn cmm-sense-audio (path)
    (do (let bs (read_file path))
        (let off (cmm-data-offset bs))
        (if (eq off 0) (list -1 -1 0 0 0)
          (do (let f0 (cmm-window-frequency bs off 0))
              (let f1 (cmm-window-frequency bs off 1))
              (let f2 (cmm-window-frequency bs off 2))
              (list (cmm-frequency-concept f0 f1)
                    (cmm-frequency-lens f2) f0 f1 f2)))))

  ; ---- video --------------------------------------------------------------
  ; P3 is intentionally textual: fkwu supplies the recipe to ffmpeg over
  ; stdin without needing a byte-writing primitive in the temporary C seed.
  (defn cmm-ppm-pixel (bit frame)
    (if (eq bit 1)
      (str_concat "255 " (str_concat (int_to_str (add 30 (mul frame 25))) " 20 "))
      (str_concat "10 10 " (str_concat (int_to_str (add 80 (mul frame 20))) " "))))
  (defn cmm-ppm-row-go (bits frame out)
    (if (eq (len bits) 0) (str_concat out "\n")
      (cmm-ppm-row-go (tail bits) frame
        (str_concat out (cmm-ppm-pixel (head bits) frame)))))
  (defn cmm-ppm-rows (bits frame row out)
    (if (eq row 8) out
      (cmm-ppm-rows bits frame (add row 1)
        (str_concat out (cmm-ppm-row-go bits frame "")))))
  (defn cmm-ppm-frame (concept-id lens frame)
    (str_concat "P3\n18 8\n255\n"
      (cmm-ppm-rows (cmm-code concept-id lens) frame 0 "")))
  (defn cmm-ppm-video-go (concept-id lens frame count out)
    (if (eq frame count) out
      (cmm-ppm-video-go concept-id lens (add frame 1) count
        (str_concat out (cmm-ppm-frame concept-id lens frame)))))
  (defn cmm-ppm-video (concept-id lens)
    (cmm-ppm-video-go concept-id lens 0 6 ""))
  (defn cmm-video-filter-go (bits x out)
    (if (eq (len bits) 0) out
      (cmm-video-filter-go (tail bits) (add x 1)
        (if (eq (head bits) 1)
          (str_concat out
            (str_concat ",drawbox=x="
              (str_concat (int_to_str (mul x 10))
                ":y=0:w=10:h=80:color=0xFF5014:t=fill")))
          out))))
  (defn cmm-video-filter (concept-id lens)
    (cmm-video-filter-go (cmm-code concept-id lens) 0 "null"))
  (defn cmm-video-command (concept-id lens path)
    (str_concat "ffmpeg -loglevel error -y -f lavfi -i color=c=0x0A0A50:s=180x80:r=6:d=1 -vf \""
      (str_concat (cmm-video-filter concept-id lens)
        (str_concat "\" -frames:v 6 -c:v ffv1 "
          (str_concat (cmm-q path) " >/dev/null 2>&1 && printf 1")))))
  (defn cmm-generate-video (concept-id lens path)
    (if (and (eq (cmm-valid-concept? concept-id) 1)
             (and (eq (cmm-valid-lens? lens) 1) (eq (cmm-safe-path? path) 1)))
      (if (str_eq (host-exec (cmm-video-command concept-id lens path) "") "1") 1 0)
      0))
  (defn cmm-sense-rgb-go (rgb-at x bits)
    (if (eq x 18) (reverse bits)
      (do (let rgb (rgb-at x 3))
          (cmm-sense-rgb-go rgb-at (add x 1)
            (cons (if (gt (nth rgb 0) (nth rgb 2)) 1 0) bits)))))
  (defn cmm-sense-rgb (rgb-at)
    (do (let bits (cmm-sense-rgb-go rgb-at 0 (empty)))
        (list (cmm-code-concept bits) (cmm-code-lens bits) bits)))

  (defn cmm-arithmetic-roundtrip? (concept-id lens)
    (do (let bits (cmm-code concept-id lens))
        (if (and (eq (cmm-code-concept bits) concept-id)
                 (eq (cmm-code-lens bits) lens)) 1 0)))
)
