; whisper-tiny-native-decoder0.fk — released decoder layer zero in Form.
;
; The real Whisper prompt <|startoftranscript|><|en|><|transcribe|>
; <|notimestamps|> enters four released token embeddings plus four learned
; position rows. Decoder layer 0 then executes six-head causal self-attention,
; six-head cross-attention over two adjacent real-human-speech encoder tokens,
; and the complete 1536-wide erf-GELU FFN. The released final decoder layer
; norm and a 106-row tied-logit probe make the output observable.
;
; This proves one complete decoder block, not recognition: decoder layers 1-3,
; a full 51,865-row output scan, tokenizer carrier, and search remain pending.
; witnessed: 2026-07-19 -> released decoder layer 0 crosses real speech
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk form/form-stdlib/transformer-decoder.fk model/whisper-tiny-native-conv1.fk model/whisper-tiny-native-conv2.fk model/whisper-tiny-native-encoder0.fk model/whisper-tiny-native-encoder.fk

(do
  (defn wtd0-position-path ()
    (str_concat (wtc-root) "decoder-position0-3.f32"))
  (defn wtd0-token-path ()
    (str_concat (wtc-root) "decoder-token50258-50363.f32"))
  (defn wtd0-layer-path ()
    (str_concat (wtc-root) "decoder-ln-layer0.f32"))
  (defn wtd0-position-bytes () 6144)
  (defn wtd0-token-bytes () 162816)
  (defn wtd0-layer-bytes () 9466368)
  (defn wtd0-token-first () 50258)
  (defn wtd0-token-last () 50363)
  (defn wtd0-prompt-ids () (list 50258 50259 50359 50363))
  (defn wtd0-layer-parameter-count () 2365824)
  (defn wtd0-causal-parameter-count () 2408832)
  (defn wtd0-carried-parameter-count () 2408832)

  ; The compact layer carrier begins with decoder.layer_norm bias+weight,
  ; followed by the exact contiguous decoder.layers.0 region.
  (defn wtd0-final-ln-bias-off () 0)
  (defn wtd0-final-ln-weight-off () 1536)
  (defn wtd0-base () 3072)
  (defn wtd0-at (relative) (add (wtd0-base) relative))
  (defn wtd0-cross-k-weight-off () (wtd0-at 0))
  (defn wtd0-cross-out-bias-off () (wtd0-at 589824))
  (defn wtd0-cross-out-weight-off () (wtd0-at 591360))
  (defn wtd0-cross-q-bias-off () (wtd0-at 1181184))
  (defn wtd0-cross-q-weight-off () (wtd0-at 1182720))
  (defn wtd0-cross-v-bias-off () (wtd0-at 1772544))
  (defn wtd0-cross-v-weight-off () (wtd0-at 1774080))
  (defn wtd0-cross-ln-bias-off () (wtd0-at 2363904))
  (defn wtd0-cross-ln-weight-off () (wtd0-at 2365440))
  (defn wtd0-fc1-bias-off () (wtd0-at 2366976))
  (defn wtd0-fc1-weight-off () (wtd0-at 2373120))
  (defn wtd0-fc2-bias-off () (wtd0-at 4732416))
  (defn wtd0-fc2-weight-off () (wtd0-at 4733952))
  (defn wtd0-ffn-ln-bias-off () (wtd0-at 7093248))
  (defn wtd0-ffn-ln-weight-off () (wtd0-at 7094784))
  (defn wtd0-self-k-weight-off () (wtd0-at 7096320))
  (defn wtd0-self-out-bias-off () (wtd0-at 7686144))
  (defn wtd0-self-out-weight-off () (wtd0-at 7687680))
  (defn wtd0-self-q-bias-off () (wtd0-at 8277504))
  (defn wtd0-self-q-weight-off () (wtd0-at 8279040))
  (defn wtd0-self-v-bias-off () (wtd0-at 8868864))
  (defn wtd0-self-v-weight-off () (wtd0-at 8870400))
  (defn wtd0-self-ln-bias-off () (wtd0-at 9460224))
  (defn wtd0-self-ln-weight-off () (wtd0-at 9461760))

  ; pack = (position rows, special-token rows, final-ln+layer0, valid).
  (defn wtd0-load ()
    (do
      (let positions (fs-read-slice (wtd0-position-path) 0
        (wtd0-position-bytes)))
      (let tokens (fs-read-slice (wtd0-token-path) 0 (wtd0-token-bytes)))
      (let layer (fs-read-slice (wtd0-layer-path) 0 (wtd0-layer-bytes)))
      (list positions tokens layer
        (if (and (eq (str_len positions) (wtd0-position-bytes))
              (and (eq (str_len tokens) (wtd0-token-bytes))
                   (eq (str_len layer) (wtd0-layer-bytes)))) 1 0))))
  (defn wtd0-positions (pack) (nth pack 0))
  (defn wtd0-tokens (pack) (nth pack 1))
  (defn wtd0-layer-carrier (pack) (nth pack 2))
  (defn wtd0-valid? (pack) (nth pack 3))
  (defn wtd0-position-crc32-expected () 1869936199)
  (defn wtd0-token-crc32-expected () 3633849010)
  (defn wtd0-layer-crc32-expected () 3469154316)
  (defn wtd0-carrier-provenance-valid? ()
    (and (eq (lbpt-crc-string (fs-read-slice (wtd0-position-path) 0
              (wtd0-position-bytes))) (wtd0-position-crc32-expected))
      (and (eq (lbpt-crc-string (fs-read-slice (wtd0-token-path) 0
                (wtd0-token-bytes))) (wtd0-token-crc32-expected))
           (eq (lbpt-crc-string (fs-read-slice (wtd0-layer-path) 0
                (wtd0-layer-bytes))) (wtd0-layer-crc32-expected)))))

  (defn wtd0-position-row (carrier position)
    (lbpt-f32-list carrier (mul position 1536) 384))
  (defn wtd0-token-row (carrier token-id)
    (lbpt-f32-list carrier (mul (sub token-id (wtd0-token-first)) 1536) 384))
  (defn wtd0-embed-prompt-go (tokens positions ids position out)
    (if (eq (len ids) 0) (reverse out)
      (wtd0-embed-prompt-go tokens positions (tail ids) (add position 1)
        (cons (tb-vec-add (wtd0-token-row tokens (head ids))
                (wtd0-position-row positions position)) out))))
  (defn wtd0-embed-prompt (pack)
    (wtd0-embed-prompt-go (wtd0-tokens pack) (wtd0-positions pack)
      (wtd0-prompt-ids) 0 (empty)))

  (defn wtd0-causal-weights (q k query-index head-index)
    (tn-softmax (tb-scores
      (nth (tb-seq-headslice q head-index 64) query-index)
      (tb-take (tb-seq-headslice k head-index 64) (add query-index 1))
      0.125)))
  (defn wtd0-cross-weights (q k query-index head-index)
    (tn-softmax (tb-scores
      (nth (tb-seq-headslice q head-index 64) query-index)
      (tb-seq-headslice k head-index 64) 0.125)))

  ; Returns output, self q/k/context/residual, cross q/k/context/residual, hidden.
  (defn wtd0-layer0 (carrier input encoder)
    (do
      (let self-ln (wte0-layernorm-seq carrier
        (wtd0-self-ln-weight-off) (wtd0-self-ln-bias-off) input))
      (let self-q (wte0-affine-seq carrier (wtd0-self-q-weight-off)
        (wtd0-self-q-bias-off) 384 384 self-ln))
      (let self-k (wte0-affine-seq carrier (wtd0-self-k-weight-off) -1
        384 384 self-ln))
      (let self-v (wte0-affine-seq carrier (wtd0-self-v-weight-off)
        (wtd0-self-v-bias-off) 384 384 self-ln))
      (let self-context (tb-mh-causal self-q self-k self-v 6 64 0.125))
      (let self-projected (wte0-affine-seq carrier
        (wtd0-self-out-weight-off) (wtd0-self-out-bias-off)
        384 384 self-context))
      (let self-out (tb-add-seq input self-projected))
      (let cross-ln (wte0-layernorm-seq carrier
        (wtd0-cross-ln-weight-off) (wtd0-cross-ln-bias-off) self-out))
      (let cross-q (wte0-affine-seq carrier (wtd0-cross-q-weight-off)
        (wtd0-cross-q-bias-off) 384 384 cross-ln))
      (let cross-k (wte0-affine-seq carrier (wtd0-cross-k-weight-off) -1
        384 384 encoder))
      (let cross-v (wte0-affine-seq carrier (wtd0-cross-v-weight-off)
        (wtd0-cross-v-bias-off) 384 384 encoder))
      (let cross-context (tb-mh-attn cross-q cross-k cross-v 6 64 0.125))
      (let cross-projected (wte0-affine-seq carrier
        (wtd0-cross-out-weight-off) (wtd0-cross-out-bias-off)
        384 384 cross-context))
      (let cross-out (tb-add-seq self-out cross-projected))
      (let ffn-ln (wte0-layernorm-seq carrier
        (wtd0-ffn-ln-weight-off) (wtd0-ffn-ln-bias-off) cross-out))
      (let hidden (wte0-gelu-seq (wte0-affine-seq carrier
        (wtd0-fc1-weight-off) (wtd0-fc1-bias-off) 384 1536 ffn-ln)))
      (let ffn-out (wte0-affine-seq carrier
        (wtd0-fc2-weight-off) (wtd0-fc2-bias-off) 1536 384 hidden))
      (list (tb-add-seq cross-out ffn-out)
        self-q self-k self-context self-out
        cross-q cross-k cross-context cross-out hidden)))

  (defn wtd0-special-logits-go (tokens state token-id out)
    (if (gt token-id (wtd0-token-last)) (reverse out)
      (wtd0-special-logits-go tokens state (add token-id 1)
        (cons (wte0-dot-bytes tokens
          (mul (sub token-id (wtd0-token-first)) 1536) state 0.0) out))))
  (defn wtd0-special-logits (tokens state)
    (wtd0-special-logits-go tokens state (wtd0-token-first) (empty)))
  (defn wtd0-fingerprints (tokens)
    (if (eq (len tokens) 0) (empty)
      (cons (wt2-fingerprint (head tokens))
        (wtd0-fingerprints (tail tokens)))))
  (defn wtd0-argmax-go (xs index best best-index)
    (if (eq (len xs) 0) best-index
      (if (gt (head xs) best)
        (wtd0-argmax-go (tail xs) (add index 1) (head xs) index)
        (wtd0-argmax-go (tail xs) (add index 1) best best-index))))
  (defn wtd0-argmax (xs)
    (wtd0-argmax-go (tail xs) 1 (head xs) 0))

  (defn wtd0-infer-encoder (path encoder)
    (do
      (let pack (wtd0-load))
      (let input (if (eq (wtd0-valid? pack) 1)
        (wtd0-embed-prompt pack) (empty)))
      (let layer (if (and (eq (len encoder) 2) (eq (len input) 4))
        (wtd0-layer0 (wtd0-layer-carrier pack) input encoder) (empty)))
      (let output (if (eq (len layer) 10) (nth layer 0) (empty)))
      (let final (if (eq (len output) 4)
        (wte0-layernorm-seq (wtd0-layer-carrier pack)
          (wtd0-final-ln-weight-off) (wtd0-final-ln-bias-off) output)
        (empty)))
      (let logits (if (eq (len final) 4)
        (wtd0-special-logits (wtd0-tokens pack) (nth final 3)) (empty)))
      ; Collapse the second real encoder token onto the first. Unlike swapping,
      ; this changes the cross-attention content and must move the final state.
      (let collapsed-encoder (if (eq (len encoder) 2)
        (list (nth encoder 0) (nth encoder 0)) (empty)))
      (let collapsed-layer (if (and (eq (len input) 4)
            (eq (len collapsed-encoder) 2))
        (wtd0-layer0 (wtd0-layer-carrier pack) input collapsed-encoder)
        (empty)))
      (let collapsed-final (if (eq (len collapsed-layer) 10)
        (wte0-layernorm-seq (wtd0-layer-carrier pack)
          (wtd0-final-ln-weight-off) (wtd0-final-ln-bias-off)
          (nth collapsed-layer 0)) (empty)))
      (let collapse-distance (if (and (eq (len final) 4)
            (eq (len collapsed-final) 4))
        (wte0-vector-distance (nth final 3) (nth collapsed-final 3)) 0.0))
      (let self-attention (if (eq (len layer) 10)
        (list (wtd0-causal-weights (nth layer 1) (nth layer 2) 1 0)
          (wtd0-causal-weights (nth layer 1) (nth layer 2) 3 5)) (empty)))
      (let cross-attention (if (eq (len layer) 10)
        (list (wtd0-cross-weights (nth layer 5) (nth layer 6) 0 0)
          (wtd0-cross-weights (nth layer 5) (nth layer 6) 3 5)) (empty)))
      (list "whisper-tiny-native-decoder0" path (wtd0-prompt-ids)
        (len encoder) (if (eq (len encoder) 2) (len (head encoder)) 0)
        (len input) (len output) (len final)
        (wtd0-causal-parameter-count) (wtd0-carried-parameter-count)
        (wtd0-valid? pack) self-attention cross-attention
        (if (eq (len final) 4) (wtd0-fingerprints final) (empty))
        (if (eq (len logits) 106) (wtd0-argmax logits) -1)
        (if (eq (len logits) 106)
          (add (wtd0-token-first) (wtd0-argmax logits)) -1)
        (if (eq (len logits) 106) (nth logits 0) 0.0)
        (if (eq (len logits) 106) (nth logits 105) 0.0)
        collapse-distance
        "native-decoder-layer0-complete" (if (eq (len final) 4) 1 0)
        "native-recognizer" 0
        "pending" "decoder-layers1-3+full-vocabulary-scan+tokenizer+search")))
  (defn wtd0-infer-file (path)
    (do
      (let encoder-result (wte-infer-file path))
      (wtd0-infer-encoder path (nth encoder-result 27))))
  0)
