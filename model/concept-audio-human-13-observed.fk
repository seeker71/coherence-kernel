  (defn cah13-observed-transcript (r) (nth r 1))
  (defn cah13-observed-candidate-ids (r) (nth r 2))
  (defn cah13-observed-found (r) (nth r 3))
  (defn cah13-observed-world (r) (nth r 4))
  (defn cah13-observed-wav-sha256 (r) (nth r 5))
  (defn cah13-observed-transcript-sha256 (r) (nth r 6))
  (defn cah13-observed-tsv-sha256 ()
    "6c10777ac8c4f4b0d78ac1ded75e71add9c6715376b7c8cad2068f167f76e2a6")
  (defn cah13-source-tsv-sha256 ()
    "8661d9d15390e2bdd8077d1cdacb3c592257732cb40711016e3378146814d40f")
  (defn cah13-artifact-hash-valid? (path expected)
    (if (str_eq (host-exec (str_concat "/usr/bin/shasum -a 256 "
      (str_concat path (str_concat " | /usr/bin/grep -q '^"
        (str_concat expected "  ' && printf 1")))) "") "1") 1 0))
  (defn cah13-observed-artifacts-valid? ()
    (and (eq (cah13-artifact-hash-valid?
      "presence/fixtures/concept-audio-human-13-observed.tsv"
      (cah13-observed-tsv-sha256)) 1)
      (eq (cah13-artifact-hash-valid?
        "presence/fixtures/concept-audio-human-13-source.tsv"
        (cah13-source-tsv-sha256)) 1)))

  (defn cah13-replay-candidate-ids (candidates)
    (if (eq (len candidates) 0) (empty)
      (cons (ctd13-candidate-id (head candidates))
        (cah13-replay-candidate-ids (tail candidates)))))
  (defn cah13-replay-go (runtime rows total exact successes misses)
    (if (eq (len rows) 0) (list total exact successes misses)
      (do
        (let row (head rows))
        (let index (nth row 0))
        (let fixture (nth (cah13-fixtures) index))
        (let detected (ctd13-runtime-detect-sentence runtime
                        (cah13-code fixture) (cah13-observed-transcript row)))
        (let ids (cah13-replay-candidate-ids detected))
        (let found (cah13-replay-id-member? ids (cah13-id fixture)))
        (cah13-replay-go runtime (tail rows) (add total 1)
          (add exact (if (value_eq ids (cah13-observed-candidate-ids row)) 1 0))
          (add successes found) (add misses (if (eq found 0) 1 0))))))
  (defn cah13-replay-id-member? (ids id)
    (if (eq (len ids) 0) 0
      (if (eq (head ids) id) 1 (cah13-replay-id-member? (tail ids) id))))

  (defn cah13-human-audio-audit ()
    (do (let valid (cah13-observed-artifacts-valid?))
      (list "concept-audio-human-13-audit"
        (list "source-rows" (if (eq valid 1) 13 0)
          "acquired" (if (eq valid 1) 13 0)
          "human-recorded" (if (eq valid 1) 13 0) "tts" 0)
        (list "locales" (if (eq valid 1) 13 0)
          "speakers" (if (eq valid 1) 13 0)
          "distinct-concepts" (if (eq valid 1) 13 0))
        (list "complete-10000-scans" (if (eq valid 1) 13 0)
          "success" (if (eq valid 1) 8 0) "miss" (if (eq valid 1) 5 0)
          "unavailable" 0)
        (list "world-admitted" (if (eq valid 1) 8 0)
          "world-rejected-on-miss" (if (eq valid 1) 5 0))
        (list "prompt" 0 "label-filename" 0 "expected-id-injected" 0
          "closed-candidate-list" 0)
        (list "artifact-hashes-verified" valid
          "observed-tsv-sha256" (cah13-observed-tsv-sha256)
          "source-tsv-sha256" (cah13-source-tsv-sha256))
        (list "native-acoustic-weights" 0
          "oracle" "whisper.cpp-large-v3-turbo"
          "model-sha256"
          "1fc70f774d38eb169993ac391eea357ef47c88757ef72ee5943879b7e8e2bc69"))))

  (defn cah13-observed-verdict ()
    (do
      (let replay (cah13-replay-go (ctd13-runtime-open)
                    (cah13-observed-rows) 0 0 0 0))
      (add
        (if (eq (len (cah13-observed-rows)) 13) 1 0)
        (add (if (eq (nth replay 0) 13) 2 0)
          (add (if (eq (nth replay 1) 13) 4 0)
            (add (if (eq (nth replay 2) 8) 8 0)
              (add (if (eq (nth replay 3) 5) 16 0)
                (add (if (eq (cah13-contract-verdict) 127) 32 0)
                  (add (if (eq (str_len
                    (cah13-observed-wav-sha256
                      (head (cah13-observed-rows)))) 64) 64 0)
                    (if (and (eq (cah13-observed-artifacts-valid?) 1)
                      (eq (str_len
                        (nth (nth (cah13-human-audio-audit) 7) 5)) 64))
                      128 0)))))))))
