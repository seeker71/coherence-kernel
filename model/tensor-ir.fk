; tensor-ir.fk — ONE precision-explicit tensor IR; the target ISA is DATA, not a hand-written emitter.
;
; THE SMELL THIS CLOSES (Grok's #2): form-glsl.fk / form-ptx.fk / jit-tensor-emit.fk (MSL) / the CUDA
; spines each RE-WRITE the same numeric discipline — a downward right-fold dot, an explicit NON-fused
; mul+add (two roundings, split through a named temporary so no conformant compiler contracts it into
; an fma), recipe-Taylor exp/tanh/gelu, barrier/workgroup load/store — in that ISA's syntax. The
; arithmetic body of jte-matvec-msl-spine and jte-matvec-cuda-spine is BYTE-FOR-BYTE identical; only
; the memory-model scaffolding (`kernel void` vs `__global__ void`, `device const T*` vs `const T*`,
; `[[thread_position_in_grid]]` vs `blockIdx.x*blockDim.x+threadIdx.x`) differs. That difference is the
; only thing that is per-ISA, so that difference is the only thing that should be DATA.
;
; THE ONE IR (the small, precision-explicit op set every backend shares):
;   right-fold-dot  — the serial DOWNWARD dot, j = cols-1..0 (tb-dot's a0·b0 + (a1·b1 + (… + 0.0))).
;   acc-step        — the two-rounding accumulate ladder: p = T(a)*T(b); acc = p + acc. The mul and the
;                     add are SEPARATE roundings, split through the named temporary `p`, never fused.
;   exp / tanh / gelu — the transcendentals as NAMED ops, realized by the recipe's OWN 14-term Taylor
;                     (halving-reduce + square-back), never the hardware ex2.approx / tanh intrinsic.
;   load / store    — typed memory access (load widens elem->acc exactly; store rounds acc->elem once, RNE).
;   barrier / workgroup — the memory-model primitives (one threadgroup per problem row / per token).
; A KERNEL (matvec / ffn / surprise) is a composition of these ops — authored ONCE, here, ISA-free.
;
; BACKENDS ARE DATA. Each target (MSL, PTX/CUDA, SPIR-V/GLSL) is a TABLE of (slot -> fragment) rows: the
; memory-model header (kernel keyword, buffer qualifier, index expression, scratch qualifier) plus the
; precision row (elem/acc type names). ONE generic emitter — tir-emit-* — walks (kernel-spec + backend
; table) -> target source. Adding a backend is adding a TABLE, never a new emitter .fk. The generic
; emitter has NO per-ISA `if` chain: it only ever does tb-slot lookups by name (grep-proven).
;
; CONFORMANCE BY CONSTRUCTION: the IR-emitted Mac MSL is the SAME string the proven jte-matvec-msl /
; sk-msl produce — the body spine is shared, the memory model is the MSL table — so the M4 Max bit-exact
; reference still holds, now flowing through this engine. Proven: model/tests/tensor-ir-band.fk.
;
; preludes: form-stdlib/core.fk

; ─────────────────────────────────────────────────────────────────────────────────────────────
; BACKEND TABLE — a list of (slot-name fragment) rows. tb-slot looks a fragment up by name. This is
; the ENTIRE per-ISA surface: the generic emitter reads ONLY these named fragments, never an ISA `if`.
; ─────────────────────────────────────────────────────────────────────────────────────────────
(defn tb-slot (tbl key)
    (if (eq (len tbl) 0) ""
        (if (str_eq (head (head tbl)) key)
            (head (tail (head tbl)))
            (tb-slot (tail tbl) key))))

; ── precision rows: the lane's storage (elem) and accumulator (acc) type NAMES, as data. fp32 is the
;    bit-exact ground; a half/bfloat lane is a NEW ROW (different elem), never a copy of the emitter.
(defn tir-elem (tbl) (tb-slot tbl "elem"))
(defn tir-acc  (tbl) (tb-slot tbl "acc"))

; ─────────────────────────────────────────────────────────────────────────────────────────────
; THE IR ARITHMETIC SPINE — authored ONCE, ISA-free. The precision-explicit op bodies. Each takes the
; backend table (for elem/acc type names only) and emits the SAME numeric discipline as a string.
; ─────────────────────────────────────────────────────────────────────────────────────────────

; acc-step / right-fold-dot: the two-rounding downward dot over a `row` and `x`, length `cols`, into
; an `acc` of the accumulator type. p = acc(row[j]) * acc(x[j]); acc = p + acc — SEPARATE roundings,
; split through `p`, j counting DOWN from cols. The literal heart of tb-dot / the matvec spines.
; The load is a NAMED op realized by two data slots: the per-element CAST ("ld"/"ldc" — a precision-
; explicit "cast( … )" for the pointer-model ISAs, MSL/CUDA: ld = "float(" / ldc = ")"; empty for GLSL
; whose buffer is already float) wrapping a per-backend element REFERENCE ("wref" for the weight, the
; logical `x[j]` shared). The pointer ISAs read row[j]; GLSL reads w[i*cols+uint(j)] — the addressing is
; data, not a per-ISA `if`. ONE spine; cast + addressing arrive as table rows.
(defn tir-ld (tbl ref)
    (str_concat (tb-slot tbl "ld")
    (str_concat ref (tb-slot tbl "ldc"))))

(defn tir-dot-down (tbl)
    (str_concat (tir-acc tbl)
    (str_concat " acc = 0.0f; "
    (str_concat (tb-slot tbl "idx")
    (str_concat " j = cols; while (j > 0) { j -= 1; "
    (str_concat (tir-acc tbl)
    (str_concat " p = "
    (str_concat (tir-ld tbl (tb-slot tbl "wref"))
    (str_concat " * "
    (str_concat (tir-ld tbl (tb-slot tbl "xref"))
    (str_concat "; acc = p + acc; } "
    "")))))))))))

; store: one rounding acc->elem at the lane boundary (RNE), the named-tie store.
(defn tir-store-y (tbl)
    (str_concat "y[i] = "
    (str_concat (tb-slot tbl "st")
    (str_concat "acc" (str_concat (tb-slot tbl "stc") ";")))))

; tir-store-into: the named-tie store of an arbitrary acc-typed EXPRESSION into an lvalue —
; `lval = st( expr )stc;`. The same one-rounding acc->elem boundary as tir-store-y, generalized
; so the affine-train weight/bias updates flow through the SAME store op, not a hand-rolled cast.
(defn tir-store-into (tbl lval expr)
    (str_concat lval
    (str_concat " = "
    (str_concat (tb-slot tbl "st")
    (str_concat expr (str_concat (tb-slot tbl "stc") ";"))))))

; ── affine-layer (y = W·x + b) TRAINING-STEP body, authored ONCE, ISA-free. Forward dot (the SHARED
;    tir-dot-down) -> bias add -> SSE residual + per-row loss -> upstream grad g = 2(y-t) -> SGD update
;    of this row's dW = outer(g,x) and db = g, IN PLACE. The fold is tb-dot's downward right-fold; the
;    update loop counts DOWN over cols exactly like the forward dot; every load widens elem->acc and
;    every store rounds acc->elem ONCE through the named cast slots. Memory model (kw / sig / row decl /
;    idx type) arrives from the backend table — the arithmetic is the SAME bytes for MSL and CUDA.
(defn tir-train-tail (tbl)
    (str_concat (tir-acc tbl)
    (str_concat " y = acc + "
    (str_concat (tir-ld tbl "b[i]")
    (str_concat "; "
    (str_concat (tir-acc tbl)
    (str_concat " d = y - "
    (str_concat (tir-ld tbl "t[i]")
    (str_concat "; loss[i] = d * d; "
    (str_concat (tir-acc tbl)
    " g = 2.0f * d; "))))))))))

(defn tir-train-update (tbl)
    (str_concat (tb-slot tbl "idx")
    (str_concat " k = cols; while (k > 0) { k -= 1; "
    (str_concat (tir-store-into tbl "row[k]"
                  (str_concat (tir-ld tbl "row[k]")
                  (str_concat " - lr * g * " (tir-ld tbl "x[k]"))))
    (str_concat " } "
    (tir-store-into tbl "b[i]"
        (str_concat (tir-ld tbl "b[i]") " - lr * g")))))))

; ─────────────────────────────────────────────────────────────────────────────────────────────
; THE TRANSCENDENTAL FRAGMENT — exp / tanh / gelu / gelu' realized ONCE, ISA-free, as the recipe's OWN
; Taylor (never the hardware ex2.approx / tanh intrinsic). The tensor-IR's vocabulary NAMED exp/tanh/gelu;
; this REALIZES them as a shared spine fragment. The ONLY per-target datum is the working type — read
; from the backend table's "acc" slot (the wide accumulator), exactly as tir-dot-down reads it. So MSL
; (acc="float") and any other target share these bytes; a wider-acc lane is the SAME fragment over a
; different "acc" row, never a copy. This is the heart of every block kernel's nonlinearity (FFN gelu,
; attention/softmax exp): the block kernels stop hand-rolling fexp/fgelu and compose THIS.
;
;   fexp_small — the 14-term Taylor of e^x (term-ratio recurrence, |x| already halved into [-0.5,0.5])
;   fexp       — range-reduce by halving until |x|<=0.5, Taylor, then square back (e^x = (e^(x/2^k))^(2^k))
;   ftanh      — (e^2x - 1)/(e^2x + 1) over the recipe's own fexp
;   fgelu      — the tanh-approx gelu: 0.5x(1 + tanh(√(2/π)(x + 0.044715 x³)))
;   fgelud     — gelu' (for the training backprop kernels; forward kernels carry it too, byte-stable)
; The downstream block emitter prepends this fragment exactly where jte-mlp-helpers used to sit.
(defn tir-fexp-small (ty)
  (str_concat ty (str_concat " fexp_small(" (str_concat ty (str_concat " x){ " (str_concat ty (str_concat " n = 1.0f; " (str_concat ty (str_concat " term = 1.0f; " (str_concat ty " acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } "))))))))))
(defn tir-fexp (ty)
  (str_concat ty (str_concat " fexp(" (str_concat ty (str_concat " x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } " (str_concat ty " v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } "))))))
(defn tir-ftanh (ty)
  (str_concat ty (str_concat " ftanh(" (str_concat ty (str_concat " x){ " (str_concat ty " e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } "))))))
(defn tir-fgelu (ty)
  (str_concat ty (str_concat " fgelu(" (str_concat ty (str_concat " x){ " (str_concat ty " z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } "))))))
(defn tir-fgelud (ty)
  (str_concat ty (str_concat " fgelud(" (str_concat ty (str_concat " x){ " (str_concat ty (str_concat " z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); " (str_concat ty " th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } "))))))))

; the whole transcendental helper block, type read from the backend table's acc slot (zero per-ISA `if`).
; tir-transcendentals-ty takes the type directly; tir-transcendentals reads it from the table's acc slot.
(defn tir-transcendentals-ty (ty)
    (str_concat (tir-fexp-small ty)
    (str_concat (tir-fexp ty)
    (str_concat (tir-ftanh ty)
    (str_concat (tir-fgelu ty) (tir-fgelud ty))))))
(defn tir-transcendentals (tbl) (tir-transcendentals-ty (tir-acc tbl)))

; ─────────────────────────────────────────────────────────────────────────────────────────────
; THE FFN-FORWARD FRAGMENTS — y = W2·gelu(W1·x + b1) + b2, one threadgroup, threads strided over rows.
; The FFN reduction is the SAME two-rounding discipline as tir-dot-down (load widens elem->acc, the
; mul+add is a per-element step), here over a strided 2-D weight w[row*stride + j] rather than a per-
; thread row pointer — the addressing (wref/xref/stride) is a backend datum, the arithmetic is shared.
; The transcendental (gelu) is the realized tir-transcendentals fragment, not a hand-rolled fexp. So the
; FFN-forward block kernel is COMPOSED from realized IR fragments — the named next-stone, closed for FFN.
;
; tir-ffn-dot: the inner accumulating dot of layer L over `stride` inputs into `acc`. The loop counter is
; `loopv` (j for layer 1, k for layer 2 — matching the hand-spine), counting DOWN from `stride`; the weight
; row is indexed (rowvar*stride + loopv), the vector term is `xexpr`. The mul+add lands in ONE acc-typed
; statement `acc = W * X + acc` (the FFN-forward hand-spine's fused-source accumulate, two roundings under
; the compiler's `--fmad=false`). The element load widens through the table's ld/ldc cast.
(defn tir-ffn-dot (tbl wbuf rowvar stride loopv xexpr)
  (str_concat (tir-acc tbl)
  (str_concat " acc = 0.0f; uint "
  (str_concat loopv
  (str_concat " = "
  (str_concat stride
  (str_concat "; while ("
  (str_concat loopv
  (str_concat " > 0) { "
  (str_concat loopv
  (str_concat " -= 1; acc = "
  (str_concat (tir-ld tbl (str_concat wbuf (str_concat "[" (str_concat rowvar (str_concat " * " (str_concat stride (str_concat " + " (str_concat loopv "]"))))))))
  (str_concat " * "
  (str_concat xexpr
  " + acc; } "))))))))))))))

; tir-ffn-fwd1: hidden = gelu(W1·x + b1), thread-strided over `hid` units; writes scratch h1[k] (pre-act)
; and a[k] (post-gelu), then a device barrier. The dot loops `j` over `indim`; its vector term is the
; input float(x[j]) (widened through the load cast).
(defn tir-ffn-fwd1 (tbl)
  (str_concat "for (uint k = tid; k < hid; k += tgs) { "
  (str_concat (tir-ffn-dot tbl "w1" "k" "indim" "j" (tir-ld tbl "x[j]"))
  (str_concat (tir-acc tbl)
  (str_concat " hk = acc + "
  (str_concat (tir-ld tbl "b1[k]")
  "; h1[k] = hk; a[k] = fgelu(hk); } threadgroup_barrier(mem_flags::mem_device); "))))))

; tir-ffn-fwd-out: y = W2·a + b2, thread-strided over `outd`; the dot loops `k` over `hid`, its vector term
; the scratch a[k] (already acc-typed, no cast), and the store rounds acc->elem ONCE through the table's st/stc.
(defn tir-ffn-fwd-out (tbl)
  (str_concat "for (uint i = tid; i < outd; i += tgs) { "
  (str_concat (tir-ffn-dot tbl "w2" "i" "hid" "k" "a[k]")
  (str_concat (tir-store-into tbl "y[i]"
                (str_concat "acc + " (tir-ld tbl "b2[i]")))
  " } }"))))

; ─────────────────────────────────────────────────────────────────────────────────────────────
; THE GENERIC EMITTER — walks (kernel-name + backend table) -> target source. The memory-model
; tokens come from the table; the arithmetic spine is the shared IR body. NO per-ISA `if`.
; ─────────────────────────────────────────────────────────────────────────────────────────────
;
; tir-emit-matvec: y = W·x. One thread per output row (rows independent — parallelism without touching
; the fold). It reads ONLY named slots — "kw" / "sig" (signature), "rowdecl" (the per-thread row
; pointer, empty on GLSL) — then the shared IR spine (dot-down + store). NO per-ISA `if`.
(defn tir-emit-matvec (fname tbl)
    (str_concat (tb-slot tbl "kw")
    (str_concat fname
    (str_concat (tb-slot tbl "sig")
    (str_concat " if (i >= rows) return; "
    (str_concat (tb-slot tbl "rowdecl")
    (str_concat (tir-dot-down tbl)
    (str_concat (tir-store-y tbl)
    " }"))))))))

; tir-emit-affine-train: ONE SGD step of y = W·x + b. One thread per output row i (each thread owns
; row i, reads its whole row before writing — no cross-thread aliasing). It reads ONLY named slots —
; "kw" / "tsig" (the training signature, mutable w/b) / "trowdecl" (the MUTABLE per-thread row pointer,
; no `const`) — then the shared IR train body (dot-down + bias/loss/grad tail + in-place update).
; NO per-ISA `if`; the MSL and CUDA bodies are byte-identical save the table's memory model.
(defn tir-emit-affine-train (fname tbl)
    (str_concat (tb-slot tbl "kw")
    (str_concat fname
    (str_concat (tb-slot tbl "tsig")
    (str_concat " if (i >= rows) return; "
    (str_concat (tb-slot tbl "trowdecl")
    (str_concat (tir-dot-down tbl)
    (str_concat (tir-train-tail tbl)
    (str_concat (tir-train-update tbl)
    " }")))))))))

; tir-emit-ffn-fwd: the FFN-FORWARD BLOCK KERNEL — y = W2·gelu(W1·x + b1) + b2 — emitted THROUGH the IR.
; The first block kernel realized end-to-end from shared fragments: the realized transcendental block
; (tir-transcendentals), the FFN signature (the table's "ffnsig" memory-model row), and the two strided
; FFN dots + gelu (tir-ffn-fwd1, tir-ffn-fwd-out). It reads ONLY named slots and the shared fragments —
; NO per-ISA `if`. Byte-identical to jit-tensor-emit's hand-authored jte-mlp-fwd-msl (the named next-stone
; the S7 follow-on left hand-authored, now closed for FFN-forward): model/tests/tensor-ir-ffn-fwd-band.fk.
(defn tir-emit-ffn-fwd (fname tbl)
    (str_concat (tir-transcendentals tbl)
    (str_concat (tb-slot tbl "kw")
    (str_concat fname
    (str_concat (tb-slot tbl "ffnsig")
    (str_concat (tir-ffn-fwd1 tbl)
    (tir-ffn-fwd-out tbl)))))))

; ─────────────────────────────────────────────────────────────────────────────────────────────
; BACKEND TABLES — pure DATA. Adding a target = one of these lists; NO emitter body per target.
; The slots carry the whole per-ISA surface:
;   kw       kernel keyword                   sig      the parameter signature up to the open brace
;   idx      loop-counter type                rowdecl  the per-thread row-pointer declaration
;   acc      accumulator decl type            ld/ldc   the load CAST wrapper ("float(" / ")" | "" / "")
;   wref     weight element reference         xref     vector element reference
;   st/stc   the store CAST wrapper           elem     store type (for the cast)
; f32 lane shown; an f16/bf16 lane is the same table with elem -> "half"/"bfloat", acc unchanged.
; ─────────────────────────────────────────────────────────────────────────────────────────────

; ── Vulkan / Android (SPIR-V via GLSL) — structural twin; same shared body, GLSL memory model. GLSL has
;    no device-pointer scratch, so rowdecl is empty and the weight reference inlines the row offset
;    w[i*cols+uint(j)]; the buffer is already float so the load/store CAST slots are empty. `precise`
;    on acc/p keeps mul+add unfused — the SAME two-rounding acc-step, the GLSL way. Buffers/layout are
;    in the sig (std430). elem stays "float" so the (empty-cast) store is plain `y[i] = acc;`.
(defn tir-glsl-table ()
    (list
        (list "kw"      "void ")
        (list "idx"     "uint")
        (list "acc"     "precise float")
        (list "elem"    "float")
        (list "rowdecl" "")
        (list "ld"      "")
        (list "ldc"     "")
        (list "wref"    "w[i * cols + uint(j)]")
        (list "xref"    "x[uint(j)]")
        (list "st"      "")
        (list "stc"     "")
        (list "sig"  " { uint i = gl_GlobalInvocationID.x;")))

; ─────────────────────────────────────────────────────────────────────────────────────────────
; PRECISION-PARAMETERIZED TABLES — the lane's storage type (elem) is the ONLY parameter. The whole
; per-format surface (sig, rowdecl, store cast) is COMPOSED from `el`; acc stays the wide fp32
; accumulator and the load always widens elem->fp32 ("float("). So an f16/bf16/f32 lane is the SAME
; emitter over a DIFFERENT el — never a copy of the spine (the jte-msl-elem/jte-cuda-elem rows the
; hand-emitter carried, now generated). fp32 (el="float") reproduces tir-msl-table/tir-cuda-table
; byte-for-byte; el="half"/"bfloat" (MSL) / el="__half"/"__nv_bfloat16" (CUDA) are the wide-store lanes.
(defn tir-msl-table-el (el)
    (list
        (list "kw"      "kernel void ")
        (list "idx"     "uint")
        (list "acc"     "float")
        (list "elem"    el)
        (list "rowdecl" (str_concat "device const " (str_concat el "* row = w + i * cols; ")))
        (list "ld"      "float(")
        (list "ldc"     ")")
        (list "wref"    "row[j]")
        (list "xref"    "x[j]")
        (list "st"      (str_concat el "("))
        (list "stc"     ")")
        (list "trowdecl" (str_concat "device " (str_concat el "* row = w + i * cols; ")))
        (list "tsig"
            (str_concat "(device "
            (str_concat el
            (str_concat "* w [[buffer(0)]], device "
            (str_concat el
            (str_concat "* b [[buffer(1)]], device const "
            (str_concat el
            (str_concat "* x [[buffer(2)]], device const "
            (str_concat el
                        "* t [[buffer(3)]], device float* loss [[buffer(4)]], constant uint& rows [[buffer(5)]], constant uint& cols [[buffer(6)]], constant float& lr [[buffer(7)]], uint i [[thread_position_in_grid]]) {")))))))))
        (list "sig"
            (str_concat "(device const "
            (str_concat el
            (str_concat "* w [[buffer(0)]], device const "
            (str_concat el
            (str_concat "* x [[buffer(1)]], device "
            (str_concat el
                        "* y [[buffer(2)]], constant uint& rows [[buffer(3)]], constant uint& cols [[buffer(4)]], uint i [[thread_position_in_grid]]) {")))))))
        ; ffnsig — the FFN-FORWARD memory model: w1/b1/w2/b2/x/y are storage-typed (el); the scratch h1/a
        ; are accumulator-typed ("float"); dims indim/hid/outd are constants; one threadgroup (tid/tgs).
        (list "ffnsig"
            (str_concat "(device "
            (str_concat el
            (str_concat "* w1 [[buffer(0)]], device "
            (str_concat el
            (str_concat "* b1 [[buffer(1)]], device "
            (str_concat el
            (str_concat "* w2 [[buffer(2)]], device "
            (str_concat el
            (str_concat "* b2 [[buffer(3)]], device const "
            (str_concat el
            (str_concat "* x [[buffer(4)]], device "
            (str_concat el
                        "* y [[buffer(5)]], device float* h1 [[buffer(6)]], device float* a [[buffer(7)]], constant uint& indim [[buffer(8)]], constant uint& hid [[buffer(9)]], constant uint& outd [[buffer(10)]], uint tid [[thread_position_in_threadgroup]], uint tgs [[threads_per_threadgroup]]) { ")))))))))))))))

(defn tir-cuda-table-el (el)
    (list
        (list "kw"      "__global__ void ")
        (list "idx"     "unsigned")
        (list "acc"     "float")
        (list "elem"    el)
        (list "rowdecl" (str_concat "const " (str_concat el "* row = w + i * cols; ")))
        (list "ld"      "float(")
        (list "ldc"     ")")
        (list "wref"    "row[j]")
        (list "xref"    "x[j]")
        (list "st"      (str_concat el "("))
        (list "stc"     ")")
        (list "trowdecl" (str_concat el "* row = w + i * cols; "))
        (list "tsig"
            (str_concat "("
            (str_concat el
            (str_concat "* w, "
            (str_concat el
            (str_concat "* b, const "
            (str_concat el
            (str_concat "* x, const "
            (str_concat el
                        "* t, float* loss, unsigned rows, unsigned cols, float lr) { unsigned i = blockIdx.x * blockDim.x + threadIdx.x;")))))))))
        (list "sig"
            (str_concat "(const "
            (str_concat el
            (str_concat "* w, const "
            (str_concat el
            (str_concat "* x, "
            (str_concat el
                        "* y, unsigned rows, unsigned cols) { unsigned i = blockIdx.x * blockDim.x + threadIdx.x;")))))))))

; format-name -> lane elem type (the jte-msl-elem / jte-cuda-elem rows, now data on the format axis)
(defn tir-msl-elem  (fmt) (if (str_eq fmt "f16") "half"   (if (str_eq fmt "bf16") "bfloat"        "float")))
(defn tir-cuda-elem (fmt) (if (str_eq fmt "f16") "__half" (if (str_eq fmt "bf16") "__nv_bfloat16" "float")))

; the canonical f32 lane is the precision builder at el="float" — ONE table-builder, no duplicated rows.
; (kept as named handles; the M4-Max-bit-exact MSL reference is tir-msl-table -> tir-msl-table-el "float".)
(defn tir-msl-table  () (tir-msl-table-el  "float"))
(defn tir-cuda-table () (tir-cuda-table-el "float"))

; ── per-target one-call entries (the public surface; same shape as jte-matvec-msl) ──
(defn tir-matvec-msl-fmt  (fname fmt) (tir-emit-matvec fname (tir-msl-table-el  (tir-msl-elem  fmt))))
(defn tir-matvec-cuda-fmt (fname fmt) (tir-emit-matvec fname (tir-cuda-table-el (tir-cuda-elem fmt))))
(defn tir-matvec-msl  (fname) (tir-matvec-msl-fmt  fname "f32"))
(defn tir-matvec-cuda (fname) (tir-matvec-cuda-fmt fname "f32"))
(defn tir-matvec-glsl (fname) (tir-emit-matvec fname (tir-glsl-table)))

; ── affine-train one-call entries — the SAME IR train body, MSL and CUDA memory models from the tables.
;    (GLSL has no training reference in the hand-emitter; it is a NEW table row when an Android train
;    audit is authored, not a new emitter — honest absence, not a faked lane.)
(defn tir-affine-train-msl-fmt  (fname fmt) (tir-emit-affine-train fname (tir-msl-table-el  (tir-msl-elem  fmt))))
(defn tir-affine-train-cuda-fmt (fname fmt) (tir-emit-affine-train fname (tir-cuda-table-el (tir-cuda-elem fmt))))
(defn tir-affine-train-msl  (fname) (tir-affine-train-msl-fmt  fname "f32"))
(defn tir-affine-train-cuda (fname) (tir-affine-train-cuda-fmt fname "f32"))

; ── FFN-forward one-call entries — the first BLOCK KERNEL realized through the IR. f32 lane first; the
;    f16/bf16 lanes parameterize the SAME emitter over a different el (the storage type), exactly as the
;    matvec lane does — the scratch/acc stays the wide "float". (CUDA FFN-forward is a NEW table row when
;    a CUDA FFN audit is authored — honest absence, not a faked lane: jte-mlp-fwd has no CUDA twin.)
(defn tir-ffn-fwd-msl-fmt (fname fmt) (tir-emit-ffn-fwd fname (tir-msl-table-el (tir-msl-elem fmt))))
(defn tir-ffn-fwd-msl     (fname)     (tir-ffn-fwd-msl-fmt fname "f32"))

