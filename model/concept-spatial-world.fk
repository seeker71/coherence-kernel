; concept-spatial-world.fk -- content identity binds to reconstructed place.
;
; A semantic detector and LingBot geometry arrive as independent observations.
; This organ locates the accepted top-10k concept at the trajectory's observed
; final camera viewpoint and persists it through the ordinary concept/world
; bridge. It does not pretend that the camera pose is the object's 3-D center.
; It never substitutes a fixture name for a rejected content detection.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk model/lingbot-real-life.fk

(do
  (defn csw-final-position (scene)
    (nth (lre-summary-trajectory scene) 4))
  (defn csw-path-length (scene)
    (nth (lre-summary-trajectory scene) 2))
  (defn csw-depth-count (scene)
    (nth (lre-summary-depth scene) 1))
  (defn csw-cloud-count (scene)
    (nth (lre-summary-cloud-world scene) 1))
  (defn csw-object-count (scene)
    (nth (lre-summary-cloud-world scene) 3))
  (defn csw-detection-accepted? (detection)
    (and (ge (nth detection 0) 0) (eq (nth detection 5) 1)))
  (defn csw-bind (scene detection known)
    (if (csw-detection-accepted? detection)
      (cwm-persist-detection detection (csw-final-position scene)
        "lingbot-spatial-content" 5000 known)
      (empty)))
  (defn csw-run (scene detection known)
    (do
      (let entity (csw-bind scene detection known))
      (list "concept-spatial-world"
        (list "scene" (lre-summary-name scene)
          "content-id" (nth detection 0) "content-label" (nth detection 1)
          "content-score" (nth detection 2) "content-margin" (nth detection 3))
        (list "geometry" "path-length" (csw-path-length scene)
          "final-viewpoint-position" (csw-final-position scene)
          "depths" (csw-depth-count scene) "cloud-points" (csw-cloud-count scene)
          "native-object-rows" (csw-object-count scene))
        (list "concept-entity" entity)
        (list "world-counts"
          "concept" (if (eq (len entity) 0) 0 1)
          "objects" (csw-object-count scene)
          "combined" (if (eq (len entity) 0) (csw-object-count scene)
                       (add 1 (csw-object-count scene)))))))
)
