; concept-video-generation-10000-13.fk -- semantic video plans at full address scale.
;
; This cell joins the ranked 10,000-concept substrate, WordNet semantics, and
; thirteen natural-language framing lenses. Generation is lazy: no 130,000
; videos are stored, but every valid (concept-id,lens) pair produces a complete
; plan on demand. A live carrier rasterizes the plan; this cell owns the text,
; semantic visual hash, visible identity envelope, backdrop choice, and pixel
; sensing used to verify the decoded video.
;
; The pure plan accepts an attributed localized surface explicitly; the live
; cell supplies it from the complete concept-ID-aligned 13-NL runtime. An absent
; surface still falls back visibly to the English anchor as a defensive law
; rather than inventing a translation; the current 130,000 cells are present.
; WordNet gloss is present for mapped concepts and explicitly empty for misses.
; witnessed: 2026-07-18 -> 8191 four-way; 78/78 decoded matrix identities live
; preludes: form/form-stdlib/core.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk model/concept-multimodal-codec.fk model/lingbot-vision-input.fk
(do
  (defn cvg13-concept-count () 10000)
  (defn cvg13-lens-count () 13)
  (defn cvg13-address-count () 130000)
  (defn cvg13-lens-codes ()
    (list "en" "id" "es" "fr" "pt-br" "sw" "de" "ru" "zh" "ja" "ar" "hi" "tr"))
  (defn cvg13-valid? (concept-id lens)
    (if (and (and (ge concept-id 0) (lt concept-id (cvg13-concept-count)))
             (and (ge lens 0) (lt lens (cvg13-lens-count)))) 1 0))
  (defn cvg13-lens-code (lens)
    (if (and (ge lens 0) (lt lens (cvg13-lens-count)))
      (nth (cvg13-lens-codes) lens) ""))

  (defn cvg13-text-hash-go (text i hash)
    (if (eq i (str_len text)) hash
      (cvg13-text-hash-go text (add i 1)
        (mod (add (mul hash 131) (str_byte_at text i)) 1000003))))
  (defn cvg13-text-hash (text) (cvg13-text-hash-go text 0 17))
  (defn cvg13-semantic-hash (caption gloss)
    (cvg13-text-hash (str_concat caption (str_concat "\n" gloss))))

  (defn cvg13-hex-digit (n)
    (if (lt n 10) (substring "0123456789" n (add n 1))
      (substring "abcdef" (sub n 10) (sub n 9))))
  (defn cvg13-byte-hex (n)
    (str_concat (cvg13-hex-digit (div n 16)) (cvg13-hex-digit (mod n 16))))
  (defn cvg13-text-hex-go (text i out)
    (if (eq i (str_len text)) out
      (cvg13-text-hex-go text (add i 1)
        (str_concat out (cvg13-byte-hex (str_byte_at text i))))))
  ; A single dash is the shell-safe empty sentinel; nonempty UTF-8 hex can
  ; contain only 0..9/a..f and therefore cannot collide with it.
  (defn cvg13-text-hex (text)
    (if (str_eq text "") "-" (cvg13-text-hex-go text 0 "")))

  ; A real committed scene is selected only where its visible content supports
  ; the lexical concept. The upstream route called `loop` is an office interior,
  ; so it belongs to office=493, not the lexical loop=6196. Likewise courthouse
  ; is its own ranked concept 9066, not the polysemous court=751.
  ; Other concepts receive semantic-hash animation rather than false footage.
  (defn cvg13-backdrop (concept-id)
    (if (eq concept-id 493) "model/fixtures/lingbot-map/real-life/loop-24f.mkv"
      (if (eq concept-id 1927) "model/fixtures/lingbot-map/real-life/university-24f.mkv"
        (if (eq concept-id 9066) "model/fixtures/lingbot-map/real-life/courthouse-24f.mkv" ""))))

  ; plan = (tag id lens code anchor caption gloss mapping semantic-hash backdrop
  ;         rendered-surface surface-state surface-source)
  (defn cvg13-plan-surface-in (ranked semantic-index semantic-payload
                               concept-id lens localized state source)
    (if (eq (cvg13-valid? concept-id lens) 0) (empty)
      (do (let concept (c10-concept-at-in ranked concept-id))
          (let semantic (cs10-at-in semantic-index semantic-payload concept-id))
          (let code (cvg13-lens-code lens))
          (let anchor (c10-concept-label concept))
          (let surface (if (str_eq localized "") anchor localized))
          (let caption (nl13-generate code 4 surface))
          (let gloss (cs10-gloss semantic))
          (list "concept-video-plan" concept-id lens code anchor caption gloss
                (cs10-method-label semantic) (cvg13-semantic-hash caption gloss)
                (cvg13-backdrop concept-id) surface state source))))
  (defn cvg13-plan-in (ranked semantic-index semantic-payload concept-id lens)
    (cvg13-plan-surface-in ranked semantic-index semantic-payload concept-id lens
      "" "absent-anchor-fallback" "frequency-anchor"))
  (defn cvg13-plan (concept-id lens)
    (cvg13-plan-in (read_file (c10-ranked-path))
      (read_file (cs10-index-path)) (read_file (cs10-payload-path)) concept-id lens))
  (defn cvg13-plan-id (p) (nth p 1))
  (defn cvg13-plan-lens (p) (nth p 2))
  (defn cvg13-plan-code (p) (nth p 3))
  (defn cvg13-plan-anchor (p) (nth p 4))
  (defn cvg13-plan-caption (p) (nth p 5))
  (defn cvg13-plan-gloss (p) (nth p 6))
  (defn cvg13-plan-mapping (p) (nth p 7))
  (defn cvg13-plan-semantic-hash (p) (nth p 8))
  (defn cvg13-plan-backdrop (p) (nth p 9))
  (defn cvg13-plan-surface (p) (nth p 10))
  (defn cvg13-plan-surface-state (p) (nth p 11))
  (defn cvg13-plan-surface-source (p) (nth p 12))

  (defn cvg13-identity-bits (concept-id lens) (cmm-code concept-id lens))
  ; Exhaustive 130,000-address audit with bounded recursion depth. Every valid
  ; identity must survive Form's bit construction and recovery, not just the
  ; low/high examples in the band.
  (defn cvg13-audit-lenses (concept-id lens total)
    (if (eq lens 13) total
      (do (let bits (cvg13-identity-bits concept-id lens))
          (cvg13-audit-lenses concept-id (add lens 1)
            (if (and (eq (cmm-code-concept bits) concept-id)
                     (eq (cmm-code-lens bits) lens)) (add total 1) total)))))
  (defn cvg13-audit-block (concept-id end total)
    (if (eq concept-id end) total
      (cvg13-audit-block (add concept-id 1) end
        (cvg13-audit-lenses concept-id 0 total))))
  (defn cvg13-audit-blocks (start total)
    (if (eq start 10000) total
      (cvg13-audit-blocks (add start 100)
        (cvg13-audit-block start (add start 100) total))))
  (defn cvg13-audit-addresses () (cvg13-audit-blocks 0 0))
  (defn cvg13-envelope-x (bit-index) (add 54 (mul bit-index 31)))
  ; AppKit writes the envelope at y=8..27 in bottom-origin coordinates.
  ; The decoded BMP reader exposes top-origin coordinates.
  (defn cvg13-envelope-y (height) (sub height 18))
  (defn cvg13-sense-bits-go (bytes bit-index y bits)
    (if (eq bit-index 18) (reverse bits)
      (do (let rgb (lvi-rgb-at bytes (cvg13-envelope-x bit-index) y))
          (cvg13-sense-bits-go bytes (add bit-index 1) y
            (cons (if (gt (nth rgb 0) (nth rgb 2)) 1 0) bits)))))
  ; result = (concept-id lens valid? bits width height)
  (defn cvg13-sense-frame-bytes (bytes)
    (if (eq (lvi-bmp24? bytes) 0) (list -1 -1 0 (empty) 0 0)
      (do (let bits (cvg13-sense-bits-go bytes 0
                        (cvg13-envelope-y (lvi-height bytes)) (empty)))
          (list (cmm-code-concept bits) (cmm-code-lens bits)
                (cmm-code-valid? bits) bits (lvi-width bytes) (lvi-height bytes)))))
  (defn cvg13-sense-frame-file (path) (cvg13-sense-frame-bytes (read_file path)))

  ; Deterministic caption-panel witness over actual decoded pixels. Sampling
  ; the 20..619 x 24..255 top-origin panel excludes the identity envelope.
  (defn cvg13-panel-hash-row (bytes x y hash)
    (if (ge x 620) hash
      (do (let rgb (lvi-rgb-at bytes x y))
          (cvg13-panel-hash-row bytes (add x 8) y
            (mod (add (mul hash 131)
                   (add (nth rgb 0) (add (mul 3 (nth rgb 1)) (mul 7 (nth rgb 2)))))
                 1000003)))))
  (defn cvg13-panel-hash-go (bytes y hash)
    (if (ge y 256) hash
      (cvg13-panel-hash-go bytes (add y 8)
        (cvg13-panel-hash-row bytes 20 y hash))))
  (defn cvg13-panel-hash-bytes (bytes)
    (if (eq (lvi-bmp24? bytes) 0) -1 (cvg13-panel-hash-go bytes 24 17)))
  (defn cvg13-panel-hash-file (path)
    (cvg13-panel-hash-bytes (read_file path)))
)
