; rag-ask.fk — sovereign grounded retrieval over the healed jsonl index (zero Python).
;
; preludes: form-stdlib/core.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
;           form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk
;
; Keeps the live one-shot path native: fkwu reads the staged query and healed
; JSONL index, finds a grounded cell, and returns grounded:<id>. The vector cells
; (re-vec, ric-*, rag-topk) remain four-way over literal/index values; the live
; host-read JSONL path avoids passing host strings through helpers until that
; carrier boundary is lifted.

(do
    (defn ra-default-index () ".coherence-network/rag-index/index.jsonl")
    (defn ra-staged-query () ".coherence-network/rag-query.txt")
    (defn ra-id-key () "\"id\":\"")
    (defn ra-id-key-spaced () "\"id\": \"")

    (defn ra-lines (s)
        (if (eq (str_len s) 0)
            (empty)
            (do
                (let nl (str_find s (byte_to_str 10) 0))
                (if (lt nl 0)
                    (cons s (empty))
                    (do
                        (let line (substring s 0 nl))
                        (let next (add nl 1))
                        (let rest (if (ge next (str_len s)) "" (substring s next (str_len s))))
                        (cons line (ra-lines rest)))))))

    (defn ra-entry-of-line (line)
        (rag-entry (ric-id line) (ric-vec line)))

    (defn ra-entries-of (lines)
        (if (eq (len lines) 0) (empty)
            (if (eq (str_len (head lines)) 0) (ra-entries-of (tail lines))
                (cons (ra-entry-of-line (head lines))
                      (ra-entries-of (tail lines))))))

    (defn ra-read-index (index-path)
        (do (let raw (read_file index-path))
            (if (nil? raw) (empty)
                (do (let text (node_value (intern_trivial_string raw)))
                    (ra-entries-of (ra-lines text))))))

    (defn ra-nearest-id-for (query entries)
        (rag-nearest-id (re-vec query) entries))

    (defn ra-last-id-before-loop (index-path from hit last-pos)
        (do (let raw (read_file index-path))
            (let tight (str_find raw (ra-id-key) from))
            (let spaced (str_find raw (ra-id-key-spaced) from))
            (let next (if (lt tight 0) spaced
                (if (lt spaced 0) tight
                    (if (lt tight spaced) tight spaced))))
            (if (or (lt next 0) (gt next hit))
                last-pos
                (ra-last-id-before-loop index-path (add next 1) hit next))))

    ; top-1 grounded hit — the R6 retrieval lane before any rented oracle.
    ; Native fkwu host-read strings currently must be parsed inside the read frame:
    ; passing them through helpers loses content. The pure vector helpers above remain
    ; four-way for literal/index cells; this path keeps live index lookup no-HTTP.
    (defn ra-grounded-at (index-path query)
        (do (let raw (read_file index-path))
            (if (or (nil? raw) (eq (str_len raw) 0))
                "grounded:miss"
                (do
                    (let staged (if (eq (str_len query) 0) (read_file (ra-staged-query)) query))
                    (let q (if (nil? staged) "" staged))
                    (let needle q)
                    (let hit (str_find raw needle 0))
                    (if (or (eq (str_len needle) 0) (lt hit 0))
                        "grounded:miss"
                        (do
	                            (let id-pos (ra-last-id-before-loop index-path 0 hit -1))
	                            (if (lt id-pos 0)
	                                "grounded:miss"
	                                (do
	                                    (let spaced-key (ra-id-key-spaced))
	                                    (let tight-key (ra-id-key))
	                                    (let key (if (eq (str_find raw spaced-key id-pos) id-pos) spaced-key tight-key))
	                                    (let id-start (add id-pos (str_len key)))
	                                    (let id-end (str_find raw "\"" id-start))
                                    (if (lt id-end 0)
                                        "grounded:miss"
                                        (str_concat "grounded:" (substring raw id-start id-end)))))))))))

    (defn ra-grounded (query)
        (ra-grounded-at (ra-default-index) query))

    0)
