; concept-audio-open-10000-13.fk -- arbitrary-address speech contract.
;
; Every pair in [0,10000) x the thirteen NL lens codes is a valid requested
; address.  The live organ must derive the pinned surface from that address,
; place it in a locale-specific utterance, synthesize speech-only PCM, run ASR,
; and give the transcript (not the requested id) to the complete 10k detector.
; A miss is evidence and may never be replaced with the requested id.
; witnessed: 2026-07-18 -> 127 four-way contract
; preludes: form/form-stdlib/core.fk

(do
  (defn cao10-codes ()
    (list "en" "id" "es" "fr" "pt-br" "sw" "de" "ru" "zh" "ja" "ar" "hi" "tr"))
  (defn cao10-member? (xs value)
    (if (eq (len xs) 0) 0
      (if (str_eq (head xs) value) 1 (cao10-member? (tail xs) value))))
  (defn cao10-valid-address? (id code)
    (if (and (ge id 0) (lt id 10000))
      (cao10-member? (cao10-codes) code) 0))
  (defn cao10-sample-id (index)
    (mod (add 503 (mul index 7919)) 10000))
  (defn cao10-sample-code (index)
    (nth (cao10-codes) (mod index 13)))
  (defn cao10-sample-addresses-go (index limit out)
    (if (ge index limit) (reverse out)
      (cao10-sample-addresses-go (add index 1) limit
        (cons (list (cao10-sample-id index) (cao10-sample-code index)) out))))
  (defn cao10-sample-addresses (count)
    (cao10-sample-addresses-go 0 count (empty)))
  (defn cao10-distinct-go (rows seen)
    (if (eq (len rows) 0) 1
      (do (let id (nth (head rows) 0))
          (if (eq (cao10-member? seen (int_to_str id)) 1) 0
            (cao10-distinct-go (tail rows) (cons (int_to_str id) seen))))))
  (defn cao10-contract ()
    (list "concept-audio-open-10000-13-contract"
      (list "address-domain" 0 9999 "nl-lenses" (cao10-codes))
      (list "generation" "pinned-surface+locale-context+speech-only-pcm")
      (list "sensing" "whisper-transcript->complete-form-10000-scan")
      (list "evidence" "all-candidates+senses+provenance+success-or-miss")
      (list "forbidden" "closed-candidates" "tone" "identity-envelope"
        "expected-id-injection" "python" "runtime-c-growth")
      (list "sampling" "id=(503+7919*i)%10000" "code=i%13")))
  (defn cao10-contract-verdict ()
    (do (let samples (cao10-sample-addresses 52))
        (add
          (if (eq (len (cao10-codes)) 13) 1 0)
          (add (if (and (eq (cao10-valid-address? 0 "en") 1)
                         (eq (cao10-valid-address? 9999 "tr") 1)) 2 0)
            (add (if (and (eq (cao10-valid-address? -1 "en") 0)
                           (eq (cao10-valid-address? 10000 "en") 0)) 4 0)
              (add (if (eq (cao10-valid-address? 5 "xx") 0) 8 0)
                (add (if (eq (len samples) 52) 16 0)
                  (add (if (eq (cao10-distinct-go samples (empty)) 1) 32 0)
                    (if (and (ge (nth (nth samples 0) 0) 0)
                             (lt (nth (nth samples 51) 0) 10000)) 64 0)))))))))
)
