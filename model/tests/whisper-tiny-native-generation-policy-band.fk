; Exact pinned Whisper generation policy and arbitrary-position embedding.
; Expected: 255.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-vocabulary.fk
(sum (list
  (if (value_eq (wtv-begin-suppress-tokens) (list 220 50257)) 1 0)
  (if (eq (len (wtv-suppress-tokens)) 88) 2 0)
  (if (eq (wtv-token-allowed? 50257 0) 0) 4 0)
  (if (eq (wtv-token-allowed? 50257 1) 1) 8 0)
  (if (eq (wtv-token-allowed? 50359 1) 0) 16 0)
  (if (eq (wtv-token-allowed? 50364 1) 0) 32 0)
  (if (eq (wtv-token-allowed? 1446 0) 1) 64 0)
  (if (and (eq (fs-stat-size (wtv-generation-config-path)) 3747)
        (eq (str_len (wtv-position-row 447)) 1536)) 128 0)))
