; concept-audio-scale-13-band.fk -- pure 10k x 13 audio address law.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-multimodal-codec.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk model/concept-audio-scale-13.fk
(do
  (defn ca13b-bit (ok bit) (if ok bit 0))
  (defn ca13b-weighted (checks bit total)
    (if (eq (len checks) 0) total
      (ca13b-weighted (tail checks) (mul bit 2)
        (add total (ca13b-bit (head checks) bit)))))
  (defn concept-audio-scale-13-band ()
    (do (let edge (ca13-envelope-frequencies 9999 12))
        (let mid (ca13-envelope-frequencies 70 5))
        (let sw (ca13-voice-row "sw"))
        (let synthetic-fallback (ca13-resolve-values "" "absent" "absent" "0"
                                  "camera" "frequency-anchor" "F"))
        (ca13b-weighted (list
          (eq (len (cnl13-locale-codes)) 13)
          (eq (ca13-lens-index "tr") 12)
          (eq (ca13-frequencies-concept (nth edge 1) (nth edge 2)) 9999)
          (eq (ca13-frequency-lens (nth edge 3)) 12)
          (eq (ca13-frequencies-concept (nth mid 1) (nth mid 2)) 70)
          (eq (ca13-frequency-lens (nth mid 3)) 5)
          (str_eq (nth sw 1) "Samantha")
          (eq (nth sw 3) 0)
          (eq (nth (ca13-voice-row "hi") 3) 1)
          (eq (len (ca13-voice-row "not-a-locale")) 0)
          (str_eq (ca13-shell-quote "body's") "'body'\\''s'")
          (eq (ca13-window-samples) 4000)
          (eq (ca13-envelope-bytes) 32000)
          (eq (ca13-marker-frequency) 2200)
          (and (str_eq (nth synthetic-fallback 0) "camera")
            (and (str_eq (nth synthetic-fallback 1) "missing-label-fallback-en-anchor")
              (and (str_eq (nth synthetic-fallback 4) "frequency-anchor")
                   (str_eq (nth synthetic-fallback 5) "F"))))) 1 0)))
  (concept-audio-scale-13-band))
