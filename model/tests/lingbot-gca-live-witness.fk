; lingbot-gca-live-witness.fk — real upstream BMP bytes enter persistent GCA.
; Run from repo root with core, form-fs, transformer numerics/block, and runtime.
; No Python and no trig.fk: BMP sampling and Video RoPE both execute in Form.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-gca-runtime.fk
(do
  (defn lgrw-u16 (s i) (add (str_byte_at s i) (mul 256 (str_byte_at s (add i 1)))))
  (defn lgrw-u32 (s i) (add (lgrw-u16 s i) (mul 65536 (lgrw-u16 s (add i 2)))))
  (defn lgrw-i32 (s i)
    (do (let u (lgrw-u32 s i)) (if (ge u 2147483648) (sub u 4294967296) u)))
  (defn lgrw-width (s) (lgrw-u32 s 18))
  (defn lgrw-height-signed (s) (lgrw-i32 s 22))
  (defn lgrw-height (s) (abs (lgrw-height-signed s)))
  (defn lgrw-offset (s) (lgrw-u32 s 10))
  (defn lgrw-stride (s) (mul 4 (div (add (mul 3 (lgrw-width s)) 3) 4)))
  (defn lgrw-storage-y (s y)
    (if (lt (lgrw-height-signed s) 0) y (sub (sub (lgrw-height s) 1) y)))
  (defn lgrw-pixel-index (s x y)
    (add (lgrw-offset s)
         (add (mul (lgrw-storage-y s y) (lgrw-stride s)) (mul x 3))))
  (defn lgrw-luma (s x y)
    (do (let i (lgrw-pixel-index s x y))
        (let b (str_byte_at s i))
        (let g (str_byte_at s (add i 1)))
        (let r (str_byte_at s (add i 2)))
        (div (add (mul 77 r) (add (mul 150 g) (mul 29 b))) 256)))
  (defn lgrw-sample-x (s n x)
    (div (mul (add (mul 2 x) 1) (lgrw-width s)) (mul 2 n)))
  (defn lgrw-sample-y (s n y)
    (div (mul (add (mul 2 y) 1) (lgrw-height s)) (mul 2 n)))
  (defn lgrw-grid-go (s n i)
    (if (eq i (mul n n)) (empty)
      (cons (lgrw-luma s (lgrw-sample-x s n (mod i n))
                         (lgrw-sample-y s n (div i n)))
            (lgrw-grid-go s n (add i 1)))))
  (defn lgrw-cell (g n x y) (nth g (add (mul y n) x)))
  (defn lgrw-edge (g n x y)
    (add (if (lt (add x 1) n) (abs (sub (lgrw-cell g n x y) (lgrw-cell g n (add x 1) y))) 0)
         (if (lt (add y 1) n) (abs (sub (lgrw-cell g n x y) (lgrw-cell g n x (add y 1)))) 0)))
  (defn lgrw-token (g n x y)
    (list (div (mul (lgrw-cell g n x y) 1.0) 255.0)
          (div (mul (lgrw-edge g n x y) 1.0) 510.0)
          (div (mul x 1.0) (mul (sub n 1) 1.0))
          (div (mul y 1.0) (mul (sub n 1) 1.0))))
  (defn lgrw-tokens-go (g n i)
    (if (eq i (mul n n)) (empty)
      (cons (lgrw-token g n (mod i n) (div i n)) (lgrw-tokens-go g n (add i 1)))))
  (defn lgrw-tokens (s n)
    (do (let g (lgrw-grid-go s n 0)) (list g (lgrw-tokens-go g n 0))))

  (let bytes0 (read_file "model/fixtures/lingbot-map/loop-000000.bmp"))
  (let bytes1 (read_file "model/fixtures/lingbot-map/loop-000001.bmp"))
  (let observed0 (lgrw-tokens bytes0 4))
  (let observed1 (lgrw-tokens bytes1 4))
  (let grid0 (nth observed0 0))
  (let grid1 (nth observed1 0))
  (let f0 (nth observed0 1))
  (let f1 (nth observed1 1))
  (let s0 (lgr-cache-frame (lgr-cache-empty) 0 f0 1 2))
  (let s1 (lgr-cache-frame s0 1 f1 1 2))
  (let s2 (lgr-cache-frame s1 2 f0 1 2))
  (let s3 (lgr-cache-frame s2 3 f1 1 2))
  (let step4 (lgr-step s3 4 f0 1 2))
  (let out4 (nth step4 0))
  (let state4 (nth step4 1))
  (let anchor (head (lgr-anchors state4)))
  (list 7101
        ; Live image ingestion evidence.
        (list (lgrw-width bytes0) (lgrw-height bytes0) (str_len bytes0)
              (sum grid0) (sum grid1) (head f0) (head f1))
        ; Video RoPE evidence: same real token at t=0 and t=4.
        (list (lgr-video-rope (head f0) 0) (lgr-video-rope (head f0) 4))
        ; Exact A/T/W routing mask and retained row counts.
        (nth step4 2)
        ; Operational K/V evidence: distinct persisted matrices and total rows.
        (list (len (lgr-entry-keys anchor)) (len (lgr-entry-values anchor))
              (head (lgr-entry-keys anchor)) (head (lgr-entry-values anchor))
              (lgr-cache-token-count state4))
        ; GCA evidence: 22 real-frame outputs, with first attended vector exposed.
        (list (len out4) (len (head out4)) (head out4)))
)
