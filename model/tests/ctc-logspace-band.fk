; ctc-logspace-band.fk — log-space CTC equals probability-space where both work,
; and stays finite where probability-space underflows to 0. Four-way.
;
; preludes: form-stdlib/core.fk model/transformer-numerics.fk model/trig.fk
;           model/ctc-loss.fk model/ctc-logspace.fk
;
; run: cat form/form-stdlib/core.fk model/transformer-numerics.fk model/trig.fk \
;          model/ctc-loss.fk model/ctc-logspace.fk model/tests/ctc-logspace-band.fk > /tmp/cl.fk
;      ./fkwu --src /tmp/cl.fk    ; -> 127
;
; Verdict 127 when log-space is correct AND underflow-proof.

(do
    (defn clb2-abs (x) (if (lt x 0.0) (sub 0.0 x) x))
    (defn clb2-close? (a b) (if (lt (clb2-abs (sub a b)) 0.000001) 1 0))
    ; n copies of a frame
    (defn clb2-rep (n f acc) (if (eq n 0) acc (clb2-rep (sub n 1) f (cons f acc))))

    (defn clb2-score (ok bit) (if ok bit 0))
    (defn ctc-logspace-band ()
        (do
    ; correctness: exp(log-p) == probability-space p on the toys
    (let a-log (clog-forward (list (list 0.5 0.5) (list 0.5 0.5)) (list 1)))
    (let a-prob (ctc-forward (list (list 0.5 0.5) (list 0.5 0.5)) (list 1)))
    (let ab-log (clog-forward (list (list 0.5 0.5 0.0) (list 0.5 0.0 0.5) (list 0.5 0.0 0.0)) (list 1 2)))
    (let c0 (clb2-score (clb2-close? (tn-exp a-log) a-prob) 1))
    (let c1 (clb2-score (clb2-close? (tn-exp a-log) 0.75) 2))
    (let c2 (clb2-score (clb2-close? (tn-exp ab-log) (ctc-forward (list (list 0.5 0.5 0.0) (list 0.5 0.0 0.5) (list 0.5 0.0 0.0)) (list 1 2))) 4))
    ; the point: 10 frames of prob 1e-40 -> prob-space underflows to 0, log-space finite
    (let uf (clb2-rep 10 (list 0.0 1.0e-40) (empty)))
    (let c3 (clb2-score (eq (ctc-forward uf (list 1)) 0.0) 8))
    (let c4 (clb2-score (lt (clog-forward uf (list 1)) -900.0) 16))
    (let c5 (clb2-score (gt (clog-forward uf (list 1)) -950.0) 32))
    ; and the log-space loss is the positive NLL, finite where prob-space loss is -log(0)=inf
    (let c6 (clb2-score (gt (clog-loss uf (list 1)) 900.0) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (ctc-logspace-band))
