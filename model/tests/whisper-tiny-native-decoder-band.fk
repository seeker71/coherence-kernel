; Complete released decoder layers 0-3 cross real human speech in Form.
; Expected with exact live pins; carrier CRC adds the remaining provenance bit.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-decoder.fk
(do
  (defn wtdb-bit (ok bit) (if ok bit 0))
  (defn wtdb-probability-row? (row count)
    (and (eq (len row) count)
      (and (lt (abs (sub (sum row) 1.0)) 0.000001)
           (gt (abs (sub (head row) (nth row (sub count 1)))) 0.000001))))
  (defn wtdb-layer-attention? (layer)
    (and (eq (len layer) 2)
      (and (wtdb-probability-row? (nth (nth layer 0) 0) 2)
        (and (wtdb-probability-row? (nth (nth layer 0) 1) 4)
          (and (wtdb-probability-row? (nth (nth layer 1) 0) 2)
               (wtdb-probability-row? (nth (nth layer 1) 1) 2))))))
  (defn wtdb-attention? (layers)
    (if (eq (len layers) 0) 1
      (if (wtdb-layer-attention? (head layers))
        (wtdb-attention? (tail layers)) 0)))
  (defn wtdb-positive? (xs)
    (if (eq (len xs) 0) 1
      (if (gt (head xs) 1.0) (wtdb-positive? (tail xs)) 0)))
  (defn wtdb-close (a b) (lt (abs (sub a b)) 0.000000001))
  (defn wtdb-vector-close (actual expected)
    (if (eq (len actual) 0) (eq (len expected) 0)
      (if (and (gt (len expected) 0)
            (wtdb-close (head actual) (head expected)))
        (wtdb-vector-close (tail actual) (tail expected)) 0)))
  (let result (wtd-infer-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (let attention (nth result 14))
  (let fingerprints (nth result 15))
  (let distances (nth result 16))
  (sum (list
    (wtdb-bit (value_eq (nth result 2)
      (list 50258 50259 50359 50363)) 1)
    (wtdb-bit (and (eq (nth result 3) 2) (eq (nth result 4) 384)) 2)
    (wtdb-bit (and (eq (nth result 5) 4) (eq (nth result 6) 4)) 4)
    (wtdb-bit (and (eq (nth result 7) 4) (eq (nth result 8) 4)) 8)
    (wtdb-bit (and (eq (nth result 9) 4) (eq (nth result 10) 4)) 16)
    (wtdb-bit (eq (nth result 11) 9506304) 32)
    (wtdb-bit (eq (nth result 12) 9506304) 64)
    (wtdb-bit (eq (nth result 13) 1) 128)
    (wtdb-bit (and (eq (len attention) 4) (wtdb-attention? attention)) 256)
    (wtdb-bit (and (eq (len fingerprints) 5)
      (and (eq (len (nth fingerprints 4)) 4)
           (eq (len (nth (nth fingerprints 4) 3)) 10))) 512)
    (wtdb-bit (and (eq (len distances) 6) (wtdb-positive? distances)) 1024)
    (wtdb-bit (and (eq (nth result 22) 1)
      (and (eq (nth result 24) 0)
        (str_eq (nth result 26)
          "full-vocabulary-scan+tokenizer+search"))) 2048)
    (wtdb-bit (and
      (wtdb-vector-close (nth (nth (nth attention 3) 1) 1)
        (list 0.93873387737624447 0.061266122623755623))
      (and (wtdb-vector-close (nth (nth fingerprints 4) 3)
        (list -10.343394082846144 -6.4753990010625078
          -12.96050073624685 1.909340020689307 0.64867116942531211
          -3.966638002867958 6.7649247019163123 -3.2791518410598157
          -93.544467316526706 3231.6984732886572))
        (and (wtdb-vector-close distances
          (list 50.206664900087389 59.60778193332893
            61.595341973125556 132.75962951869943
            3096.9146090683194 2367.5030335630931))
          (and (eq (nth result 18) 50293)
            (and (wtdb-close (nth result 19) 3.9582448267074533)
                 (wtdb-close (nth result 20) 6.0119573665002299)))))) 4096)
    (wtdb-bit (wtd-carrier-provenance-valid?) 8192)
    (wtdb-bit (and (not (eq (nth result 18) 50363))
      (gt (nth distances 4) 3000.0)) 16384))))
