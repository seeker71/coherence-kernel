; layer-contribution-band.fk — selective-freeze training works and the
; counterfactual contribution metric reads it correctly: each single layer
; learns, neither matches full training exactly (the gap is real), both
; recover > 99.9% of the full gain on this fixture, the frozen layer comes
; back bit-identical, and layer 0 out-contributes layer 1.
;
; preludes: form-stdlib/core.fk model/transformer-numerics.fk
;           model/transformer-block.fk model/transformer-backprop.fk
;           model/layer-contribution.fk
;
; run: cat form/form-stdlib/core.fk model/transformer-numerics.fk \
;          model/transformer-block.fk model/transformer-backprop.fk \
;          model/layer-contribution.fk \
;          model/tests/layer-contribution-band.fk > /tmp/lc.fk
;      ./fkwu --src /tmp/lc.fk    ; -> 127
;
; Verdict 127 when the contribution sense is honest.

(do
    (defn lcb-score (ok bit) (if ok bit 0))
    (defn layer-contribution-band ()
        (do
    (let base (lc-loss-base))
    (let full (lc-loss-full))
    (let k0 (lc-loss-of-k 0))
    (let k1 (lc-loss-of-k 1))
    ; training a single layer genuinely learns (loss falls well below base)
    (let c0 (lcb-score (and (lt k0 base) (lt k1 base)) 1))
    ; full training remains the ceiling here — the single-layer gap is real
    (let c1 (lcb-score (and (lt full k0) (lt full k1)) 2))
    ; each single layer recovers > 99.9% of the full gain: C(k) > 0.999
    (let c2 (lcb-score (gt (lc-c-of-k 0) 0.999) 4))
    (let c3 (lcb-score (gt (lc-c-of-k 1) 0.999) 8))
    ; ...and C(k) never exceeds 1 on this fixture (full is the ceiling)
    (let c4 (lcb-score (and (lt (lc-c-of-k 0) 1.0) (lt (lc-c-of-k 1) 1.0)) 16))
    ; the frozen layer is REALLY frozen: a stack rebuilt from the ORIGINAL
    ; layer 0 plus the returned layer 1 reproduces the base loss EXACTLY
    ; (float eq, bit-exact through the whole forward). Witnessed numerically,
    ; not by value_eq: node-identity is not stable across arena melts —
    ; floats re-box under heavy work, a lesson this band's first run taught.
    (let c5 (lcb-score (eq (tbp-stk-loss
                (list (lc-l0)
                      (nth (lc-train-k (lc-layers) (lc-x) (lc-t) (lc-lr) (lc-eps) (lc-n) 0) 1))
                (lc-x) (lc-t) (lc-eps)) base) 32))
    ; the ranking the metric exists to reveal: layer 0 out-contributes layer 1
    (let c6 (lcb-score (lt k0 k1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (layer-contribution-band))
