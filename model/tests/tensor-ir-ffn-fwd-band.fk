; tensor-ir-ffn-fwd-band — the FIRST BLOCK KERNEL emitted THROUGH the data-driven tensor IR, byte-identical
; to jit-tensor-emit's hand-authored spine. The FFN-forward y = W2·gelu(W1·x + b1) + b2 now composes
; REALIZED IR fragments: the transcendental block (exp/tanh/gelu — the named-but-unrealized IR vocab, now
; realized as a shared spine fragment) + the strided FFN dots. Self-contained (no external prelude): it
; inlines the IR engine (tensor-ir.fk's tb-slot + tir-transcendentals + tir-ffn-* + the precision MSL table)
; and the PROVEN reference emitter from jit-tensor-emit.fk (jte-mlp-helpers + jte-mlp-fwd spine), then checks
; the IR output against it. All recipe ops are defn / str_concat / str_eq (no `let`, no `let`-bound lists),
; so it crosses FOUR-WAY.
;
; Verdict 7 when every claim lands:
;   1   IR-emitted MSL FFN-forward (f32)  ≡ the proven jte-mlp-fwd-msl output, BYTE-FOR-BYTE (diff=0)
;   2   IR-emitted MSL FFN-forward (f16)  ≡ the proven jte-mlp-fwd-msl f16 lane, BYTE-FOR-BYTE (precision=data)
;   4   the realized transcendental fragment ≡ the proven jte-mlp-helpers block (exp/tanh/gelu realized once)
;
; The transcendental block is realized ONCE in the IR (tir-transcendentals); every block kernel's helper
; prefix now flows through it. The FFN reduction is the same two-rounding load-widen / acc-step discipline as
; the matvec dot, over a strided 2-D weight. Proven on metal: the FFN forward is the held-out EVAL path of
; metal_ffn_audit (the M4 Max bit-exact reference), now flowing through this engine. f16 is the wide-store
; lane (one RNE at the lane boundary). The whole spine is emitted with ZERO per-ISA `if`.

; ── the IR engine (verbatim shape of model/tensor-ir.fk: tb-slot + transcendentals + FFN-fwd fragments) ──
(defn tb-slot (tbl key)
    (if (eq (len tbl) 0) ""
        (if (str_eq (head (head tbl)) key) (head (tail (head tbl)))
            (tb-slot (tail tbl) key))))
(defn tir-acc (tbl) (tb-slot tbl "acc"))
(defn tir-ld (tbl ref)
    (str_concat (tb-slot tbl "ld") (str_concat ref (tb-slot tbl "ldc"))))
(defn tir-store-into (tbl lval expr)
    (str_concat lval
    (str_concat " = "
    (str_concat (tb-slot tbl "st")
    (str_concat expr (str_concat (tb-slot tbl "stc") ";"))))))

; the realized transcendental fragment — exp/tanh/gelu/gelu' Taylor, type read from the table's acc slot.
(defn tir-fexp-small (ty)
  (str_concat ty (str_concat " fexp_small(" (str_concat ty (str_concat " x){ " (str_concat ty (str_concat " n = 1.0f; " (str_concat ty (str_concat " term = 1.0f; " (str_concat ty " acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } "))))))))))
(defn tir-fexp (ty)
  (str_concat ty (str_concat " fexp(" (str_concat ty (str_concat " x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } " (str_concat ty " v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } "))))))
(defn tir-ftanh (ty)
  (str_concat ty (str_concat " ftanh(" (str_concat ty (str_concat " x){ " (str_concat ty " e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } "))))))
(defn tir-fgelu (ty)
  (str_concat ty (str_concat " fgelu(" (str_concat ty (str_concat " x){ " (str_concat ty " z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } "))))))
(defn tir-fgelud (ty)
  (str_concat ty (str_concat " fgelud(" (str_concat ty (str_concat " x){ " (str_concat ty (str_concat " z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); " (str_concat ty " th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } "))))))))
(defn tir-transcendentals-ty (ty)
    (str_concat (tir-fexp-small ty)
    (str_concat (tir-fexp ty)
    (str_concat (tir-ftanh ty)
    (str_concat (tir-fgelu ty) (tir-fgelud ty))))))
(defn tir-transcendentals (tbl) (tir-transcendentals-ty (tir-acc tbl)))

; the strided FFN dot + the two forward layers (gelu hidden, bias output).
(defn tir-ffn-dot (tbl wbuf rowvar stride loopv xexpr)
  (str_concat (tir-acc tbl)
  (str_concat " acc = 0.0f; uint "
  (str_concat loopv
  (str_concat " = "
  (str_concat stride
  (str_concat "; while ("
  (str_concat loopv
  (str_concat " > 0) { "
  (str_concat loopv
  (str_concat " -= 1; acc = "
  (str_concat (tir-ld tbl (str_concat wbuf (str_concat "[" (str_concat rowvar (str_concat " * " (str_concat stride (str_concat " + " (str_concat loopv "]"))))))))
  (str_concat " * "
  (str_concat xexpr
  " + acc; } "))))))))))))))
(defn tir-ffn-fwd1 (tbl)
  (str_concat "for (uint k = tid; k < hid; k += tgs) { "
  (str_concat (tir-ffn-dot tbl "w1" "k" "indim" "j" (tir-ld tbl "x[j]"))
  (str_concat (tir-acc tbl)
  (str_concat " hk = acc + "
  (str_concat (tir-ld tbl "b1[k]")
  "; h1[k] = hk; a[k] = fgelu(hk); } threadgroup_barrier(mem_flags::mem_device); "))))))
(defn tir-ffn-fwd-out (tbl)
  (str_concat "for (uint i = tid; i < outd; i += tgs) { "
  (str_concat (tir-ffn-dot tbl "w2" "i" "hid" "k" "a[k]")
  (str_concat (tir-store-into tbl "y[i]"
                (str_concat "acc + " (tir-ld tbl "b2[i]")))
  " } }"))))
(defn tir-emit-ffn-fwd (fname tbl)
    (str_concat (tir-transcendentals tbl)
    (str_concat (tb-slot tbl "kw")
    (str_concat fname
    (str_concat (tb-slot tbl "ffnsig")
    (str_concat (tir-ffn-fwd1 tbl)
    (tir-ffn-fwd-out tbl)))))))

; the precision-parameterized MSL table (the lane storage type `el` is the only parameter).
(defn tir-msl-table-el (el)
    (list
        (list "kw"      "kernel void ")
        (list "acc"     "float")
        (list "ld"      "float(")
        (list "ldc"     ")")
        (list "st"      (str_concat el "("))
        (list "stc"     ")")
        (list "ffnsig"
            (str_concat "(device "
            (str_concat el
            (str_concat "* w1 [[buffer(0)]], device "
            (str_concat el
            (str_concat "* b1 [[buffer(1)]], device "
            (str_concat el
            (str_concat "* w2 [[buffer(2)]], device "
            (str_concat el
            (str_concat "* b2 [[buffer(3)]], device const "
            (str_concat el
            (str_concat "* x [[buffer(4)]], device "
            (str_concat el
                        "* y [[buffer(5)]], device float* h1 [[buffer(6)]], device float* a [[buffer(7)]], constant uint& indim [[buffer(8)]], constant uint& hid [[buffer(9)]], constant uint& outd [[buffer(10)]], uint tid [[thread_position_in_threadgroup]], uint tgs [[threads_per_threadgroup]]) { ")))))))))))))))
(defn tir-msl-elem (fmt) (if (str_eq fmt "f16") "half" (if (str_eq fmt "bf16") "bfloat" "float")))
(defn tir-ffn-fwd-msl-fmt (fname fmt) (tir-emit-ffn-fwd fname (tir-msl-table-el (tir-msl-elem fmt))))
(defn tir-ffn-fwd-msl (fname) (tir-ffn-fwd-msl-fmt fname "f32"))

; ── the PROVEN reference emitter (jit-tensor-emit.fk: jte-mlp-helpers + jte-mlp-fwd spine, verbatim shape) ──
(defn jte-mlp-helpers (ac)
  (str_concat ac (str_concat " fexp_small(" (str_concat ac (str_concat " x){ " (str_concat ac (str_concat " n = 1.0f; " (str_concat ac (str_concat " term = 1.0f; " (str_concat ac (str_concat " acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } " (str_concat ac (str_concat " fexp(" (str_concat ac (str_concat " x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } " (str_concat ac (str_concat " v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } " (str_concat ac (str_concat " ftanh(" (str_concat ac (str_concat " x){ " (str_concat ac (str_concat " e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } " (str_concat ac (str_concat " fgelu(" (str_concat ac (str_concat " x){ " (str_concat ac (str_concat " z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } " (str_concat ac (str_concat " fgelud(" (str_concat ac (str_concat " x){ " (str_concat ac (str_concat " z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); " (str_concat ac " th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } "))))))))))))))))))))))))))))))))))))
(defn jte-msl-elem (fmt) (if (str_eq fmt "f16") "half" (if (str_eq fmt "bf16") "bfloat" "float")))
(defn jte-mlp-fwd-sig (fname el ac)
  (str_concat "kernel void " (str_concat fname (str_concat "(device " (str_concat el (str_concat "* w1 [[buffer(0)]], device " (str_concat el (str_concat "* b1 [[buffer(1)]], device " (str_concat el (str_concat "* w2 [[buffer(2)]], device " (str_concat el (str_concat "* b2 [[buffer(3)]], device const " (str_concat el (str_concat "* x [[buffer(4)]], device " (str_concat el (str_concat "* y [[buffer(5)]], device " (str_concat ac (str_concat "* h1 [[buffer(6)]], device " (str_concat ac "* a [[buffer(7)]], constant uint& indim [[buffer(8)]], constant uint& hid [[buffer(9)]], constant uint& outd [[buffer(10)]], uint tid [[thread_position_in_threadgroup]], uint tgs [[threads_per_threadgroup]]) { ")))))))))))))))))))
(defn jte-mlp-fwd1 (el ac)
  (str_concat "for (uint k = tid; k < hid; k += tgs) { " (str_concat ac (str_concat " acc = 0.0f; uint j = indim; while (j > 0) { j -= 1; acc = " (str_concat ac (str_concat "(w1[k * indim + j]) * " (str_concat ac (str_concat "(x[j]) + acc; } " (str_concat ac (str_concat " hk = acc + " (str_concat ac "(b1[k]); h1[k] = hk; a[k] = fgelu(hk); } threadgroup_barrier(mem_flags::mem_device); ")))))))))))
(defn jte-mlp-fwd-out (el ac)
  (str_concat "for (uint i = tid; i < outd; i += tgs) { " (str_concat ac (str_concat " acc = 0.0f; uint k = hid; while (k > 0) { k -= 1; acc = " (str_concat ac (str_concat "(w2[i * hid + k]) * a[k] + acc; } y[i] = " (str_concat el (str_concat "(acc + " (str_concat ac "(b2[i])); } }")))))))))
(defn jte-mlp-fwd-msl-spine (fname el ac)
  (str_concat (jte-mlp-helpers ac)
  (str_concat (jte-mlp-fwd-sig fname el ac)
  (str_concat (jte-mlp-fwd1 el ac) (jte-mlp-fwd-out el ac)))))
(defn jte-mlp-fwd-msl-fmt (fname fmt) (jte-mlp-fwd-msl-spine fname (jte-msl-elem fmt) "float"))
(defn jte-mlp-fwd-msl (fname) (jte-mlp-fwd-msl-fmt fname "f32"))

; ── the verdict: IR output ≡ proven reference, per precision lane; the realized transcendental fragment ──
(defn ffn-band-c0 ()
    (if (str_eq (tir-ffn-fwd-msl "ffn_fwd") (jte-mlp-fwd-msl "ffn_fwd")) 1 0))
(defn ffn-band-c1 ()
    (if (str_eq (tir-ffn-fwd-msl-fmt "ffn_fwd" "f16") (jte-mlp-fwd-msl-fmt "ffn_fwd" "f16")) 2 0))
(defn ffn-band-c2 ()
    (if (str_eq (tir-transcendentals-ty "float") (jte-mlp-helpers "float")) 4 0))
(defn ffn-band-verdict ()
    (add (ffn-band-c0) (add (ffn-band-c1) (ffn-band-c2))))
(ffn-band-verdict)
