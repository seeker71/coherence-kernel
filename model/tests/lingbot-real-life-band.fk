; lingbot-real-life-band.fk — pure four-way laws behind native-resolution runs.
; Expected: 2047.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/transformer-numerics.fk
; cognition/transformer-block.fk model/geometric-camera.fk
; model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk
; model/lingbot-geometry-heads.fk model/lingbot-real-life.fk

(do
  (defn lreb-bit (ok bit) (if ok bit 0))
  (defn lreb-close (a b) (lt (abs (sub a b)) 0.000001))
  (defn lingbot-real-life-band ()
    (do
      (let projected (lre-project-tile
        (list 4080 2040 1020 65536.0 -32768.0 16) 4 4 3 2 8 6))
      (let paths (lre-decoded-paths "/tmp/frame-" 24))
      (let token (list 0.5 0.1 0.25 0.75))
      (let frame (lvi-vit-encode (list token token token token)))
      (let frames (list frame frame frame frame frame frame frame frame frame frame
                         frame frame frame frame frame frame frame frame frame frame
                         frame frame frame frame))
      (let stream (lre-stream frames 3 8))
      (let cache (nth stream 0))
      (let p0 (gc-pose (gc-m3-id) (list 0.0 0.0 0.0)))
      (let p1 (gc-pose (gc-m3-id) (list 1.0 0.0 0.0)))
      (let p2 (gc-pose (gc-m3-id) (list 1.0 2.0 0.0)))
      (sum (list
        (lreb-bit (eq (len paths) 24) 1)
        (lreb-bit (str_eq (head paths) "/tmp/frame-000001.bmp") 2)
        (lreb-bit (str_eq (nth paths 23) "/tmp/frame-000024.bmp") 4)
        (lreb-bit (and (eq (len projected) 4) (gt (nth projected 0) 0.0)) 8)
        (lreb-bit (and (gt (nth projected 2) 0.3) (gt (nth projected 3) 0.3)) 16)
        (lreb-bit (eq (lgr-cache-token-count cache) 199) 32)
        (lreb-bit (and (eq (len (lgr-anchors cache)) 3)
                    (and (eq (len (lgr-trajectory cache)) 13)
                         (eq (len (lgr-window cache)) 8))) 64)
        (lreb-bit (eq (len (nth stream 1)) 24) 128)
        (lreb-bit (lreb-close (lre-path-length (list p0 p1 p2)) 3.0) 256)
        (lreb-bit (eq (len (lre-default-configs)) 4) 512)
        (lreb-bit (and (eq (lre-config-source-frames (nth (lre-default-configs) 1)) 320)
                       (eq (lre-config-stride (nth (lre-default-configs) 2)) 14)) 1024)))))
  (lingbot-real-life-band))
