; Exact row emitted by the non-test learned live door is compared to human
; truth. The learned witness is model/whisper-tiny-native-generation-live.fk;
; this bounded gate characterizes the refusal without executing the 79.7 MB
; projection a second time in the same evidence movement.
; The generated ` banana` does not match the human `book`; recognition stays 0.
; Expected: 255.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-vocabulary.fk
(do
  (defn wtgs-close (a b) (lt (abs (sub a b)) 0.000000001))
  (let step (list 14194 " banana" 9.1332537930199518
    2031 8.3994698758087711 0.73378391721118064))
  (sum (list
    (if (eq (nth step 0) 14194) 1 0)
    (if (str_eq (nth step 1) " banana") 2 0)
    (if (wtgs-close (nth step 2) 9.1332537930199518) 4 0)
    (if (eq (nth step 3) 2031) 8 0)
    (if (wtgs-close (nth step 4) 8.3994698758087711) 16 0)
    (if (wtgs-close (nth step 5) 0.73378391721118064) 32 0)
    (if (eq (wtv-human-book-token-match? step) 0) 64 0)
    ; A generated nonmatching token is evidence against recognition, not a
    ; result to massage into the expected label.
    (if (and (eq (wtv-token-allowed? (nth step 0) 0) 1)
          (not (str_eq (nth step 1) " book"))) 128 0))))
