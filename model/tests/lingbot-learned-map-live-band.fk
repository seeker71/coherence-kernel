; lingbot-learned-map-live-band.fk — learned visual-to-world acceptance.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/geometric-camera.fk model/lingbot-pytorch-checkpoint.fk model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk model/lingbot-geometry-heads.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk model/lingbot-map-runtime.fk model/lingbot-learned-patch.fk model/lingbot-learned-map-runtime.fk

(do
  (defn llmrb-bit (ok bit) (if ok bit 0))
  (defn lingbot-learned-map-live-band ()
    (do
      (let run (llmr-run))
      (let source (llmr-source run))
      (let weight (llmr-weight run))
      (let learned (llmr-learned run))
      (let attention (llmr-attention run))
      (let geometry (llmr-geometry run))
      (let comparison (llmr-comparison run))
      (sum (list
        (llmrb-bit (and (eq (len source) 3)
          (and (eq (nth (nth source 1) 0) 518) (eq (nth (nth source 2) 0) 518))) 1)
        (llmrb-bit (and (eq (nth weight 0) 1)
          (and (eq (nth weight 1) 2408448) (eq (nth weight 3) 4096))) 2)
        (llmrb-bit (and (eq (nth learned 0) 1024) (eq (nth learned 2) 1024)) 4)
        (llmrb-bit (not (eq (nth (nth learned 1) 8) (nth (nth learned 3) 8))) 8)
        (llmrb-bit (and (eq (nth learned 4) 12)
          (and (eq (nth learned 5) 4)
            (and (eq (nth learned 6) 12) (eq (nth learned 7) 4)))) 16)
        (llmrb-bit (and (eq (len (nth attention 0)) 4)
          (gt (nth attention 2) 0.01)) 32)
        (llmrb-bit (and (eq (nth attention 3) 36) (eq (len (nth attention 4)) 2)) 64)
        (llmrb-bit (and (gt (abs (nth (gc-r (nth geometry 0)) 1)) 0.0)
          (eq (len (nth geometry 1)) 64)) 128)
        (llmrb-bit (and (eq (len (llmr-cloud run)) 64) (eq (len (llmr-world run)) 64)) 256)
        (llmrb-bit (lt (nth comparison 1) (nth comparison 0)) 512)))))

  (lingbot-learned-map-live-band))
