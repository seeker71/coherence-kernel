; Complete released Whisper-tiny encoder over two adjacent real-speech tokens.
; Expected: 16383.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-encoder.fk
(do
  (defn wteb-bit (ok bit) (if ok bit 0))
  (defn wteb-close (a b) (lt (abs (sub a b)) 0.000000001))
  (defn wteb-vector-close (actual expected)
    (if (eq (len actual) 0) (eq (len expected) 0)
      (if (and (gt (len expected) 0) (wteb-close (head actual) (head expected)))
        (wteb-vector-close (tail actual) (tail expected)) 0)))
  (defn wteb-attention-valid? (layers)
    (if (eq (len layers) 0) 1
      (do (let rows (head layers))
        (if (and (eq (len rows) 2)
              (and (eq (len (nth rows 0)) 2)
                (and (eq (len (nth rows 1)) 2)
                  (and (lt (abs (sub (sum (nth rows 0)) 1.0)) 0.000001)
                    (and (lt (abs (sub (sum (nth rows 1)) 1.0)) 0.000001)
                      (and (gt (abs (sub (nth (nth rows 0) 0)
                                          (nth (nth rows 0) 1))) 0.000001)
                           (gt (abs (sub (nth (nth rows 1) 0)
                                          (nth (nth rows 1) 1))) 0.000001)))))))
          (wteb-attention-valid? (tail layers)) 0))))
  (defn wteb-positive? (xs)
    (if (eq (len xs) 0) 1
      (if (gt (head xs) 1.0) (wteb-positive? (tail xs)) 0)))
  (let result (wte-infer-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (let attention (nth result 18))
  (let fingerprints (nth result 19))
  (let distances (nth result 20))
  (sum (list
    (wteb-bit (eq (nth result 17) 1) 1)
    (wteb-bit (and (eq (nth result 5) 8) (eq (nth result 6) 6)) 2)
    (wteb-bit (and (eq (nth result 7) 2) (eq (nth result 8) 2)) 4)
    (wteb-bit (and (eq (nth result 9) 2) (eq (nth result 10) 2)) 8)
    (wteb-bit (and (eq (nth result 11) 2) (eq (nth result 12) 2)) 16)
    (wteb-bit (and (eq (nth result 13) 2) (eq (nth result 14) 384)) 32)
    (wteb-bit (eq (nth result 15) 7633152) 64)
    (wteb-bit (eq (nth result 16) 8208384) 128)
    (wteb-bit (and (eq (len attention) 4)
                    (wteb-attention-valid? attention)) 256)
    (wteb-bit (and (eq (len fingerprints) 5)
      (and (eq (len (nth fingerprints 0)) 2)
           (eq (len (nth (nth fingerprints 4) 1)) 10))) 512)
    (wteb-bit (and (eq (len distances) 6) (wteb-positive? distances)) 1024)
    (wteb-bit (and (eq (nth result 22) 1)
      (and (eq (nth result 24) 0)
        (str_eq (nth result 26)
          "decoder-embedding+4-decoder-blocks+tokenizer+search"))) 2048)
    (wteb-bit (and
      (and
        (wteb-vector-close (nth (nth attention 1) 0)
          (list 0.67009651837457029 0.32990348162542971))
        (wteb-vector-close (nth (nth attention 1) 1)
          (list 0.5325845082975813 0.46741549170241875)))
      (and
        (wteb-vector-close (nth (nth attention 2) 0)
          (list 0.53430065497443546 0.46569934502556459))
        (and (wteb-vector-close (nth (nth attention 2) 1)
          (list 0.5187878925419076 0.4812121074580924))
        (and
          (wteb-vector-close (nth (nth attention 3) 0)
            (list 0.73101109643913054 0.26898890356086946))
          (and (wteb-vector-close (nth (nth attention 3) 1)
            (list 0.71104852830366483 0.288951471696335))
          (and
            (wteb-vector-close (nth (nth fingerprints 4) 0)
              (list -0.27823668402969848 0.76146145348530281
                0.38295455335264716 -0.68463446286215124
                -0.98506456801413655 0.45946242256938641
                0.016733619471973493 0.68388372690586197
                -5.3176184169910012 181.55806872596258))
            (and (wteb-vector-close (nth (nth fingerprints 4) 1)
              (list 0.10194038659944865 1.9949372382706654
                0.44534062540740715 -1.2254770750201298
                -2.3903454163388789 2.0456629107598827
                0.83799823566493026 1.5437077912913373
                -5.3545822984713318 340.10229018309474))
              (wteb-vector-close distances
                (list 203.33590172647547 118.40792949927003
                  152.15803940109254 445.70542192406919
                  517.49312348196668 237.57915489958066))))))))) 4096)
    (wteb-bit (and (wte0-carrier-provenance-valid?)
                   (wte-carrier-provenance-valid?)) 8192))))
