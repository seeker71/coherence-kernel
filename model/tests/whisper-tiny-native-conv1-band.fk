; Complete released Whisper-tiny conv1 over real human speech.
; Independent expected values come from verify-native-conv1-reference.mjs.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk model/whisper-tiny-native-conv1.fk

(do
  (defn wtcb-bit (ok bit) (if ok bit 0))
  (defn wtcb-close? (actual expected)
    (lt (abs (sub actual expected)) 0.00000001))
  (defn wtcb-fingerprint-close? (actual expected)
    (if (eq (len actual) 0) (eq (len expected) 0)
      (if (wtcb-close? (head actual) (head expected))
        (wtcb-fingerprint-close? (tail actual) (tail expected)) 0)))
  (defn whisper-tiny-native-conv1-band ()
    (do
      (let result (wtc-infer-file (wtc-human-path)))
      (let fingerprint (nth result 5))
      (let expected (list
        1.479262509249532 -1.676065684405518 0.07197640114503567
        -1.9385381190770288 0.6139602734565989 -0.10746001130249724
        -0.2412528915643827 0.6832136439554694 -88.59371480237915
        263.3570208697341))
      (sum (list
        (wtcb-bit (eq (nth result 1) 22828) 1)
        (wtcb-bit (eq (nth result 2) 44) 2)
        (wtcb-bit (wtcb-close? (nth result 3) 0.8258705179541589) 4)
        (wtcb-bit (eq (len (nth result 4)) 384) 8)
        (wtcb-bit (eq (nth result 6) 92544) 16)
        (wtcb-bit (eq (nth result 7) 1) 32)
        (wtcb-bit (eq (nth result 8) 1) 64)
        (wtcb-bit (wtcb-fingerprint-close? fingerprint expected) 128)
        (wtcb-bit (and (eq (wtc-weight-count) 92160)
                        (eq (wtc-bias-count) 384)) 256)
        (wtcb-bit (and (eq (mb-count) 80)
                        (eq (wtc-kernel-width) 3)) 512)))))
  (whisper-tiny-native-conv1-band))
