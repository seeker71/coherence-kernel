; lingbot-vision-live-witness.fk — real upstream-frame ingress and ViT evidence.
; Run from repository root. The witness returns exact fp64 values.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-vision-input.fk
(do
  (defn lvil-attention-evidence (frame)
    (do (let scores (tb-scores (head frame) frame 0.5))
        (let probs (tn-softmax scores))
        (list (head scores) (nth scores 1) (head probs) (tn-sum probs))))
  (defn lvil-frame-evidence (encoded)
    (list (len encoded) (len (head encoded)) (len (head (head encoded)))
          (head (head encoded)) (head (nth encoded 1))))
  (defn lvil-source-evidence (video container)
    (do (let b0 (lvi-image-bytes (nth video 0)))
        (let b1 (lvi-image-bytes (nth video 1)))
        (list (str_len container) (len video) (lvi-bmp24? b0)
              (lvi-image-info b0) (lvi-image-info b1)
              (lvi-rgb-at b0 0 0) (lvi-rgb-at b0 15 15)
              (lvi-rgb-at b1 0 0) (lvi-rgb-at b1 15 15))))
  (defn lvil-run (video container)
    (do (let b0 (lvi-image-bytes (nth video 0)))
        (let b1 (lvi-image-bytes (nth video 1)))
        ; A bounded live carrier witness: one real 4x4 (16-pixel) patch per
        ; frame. lvi-patch-embed is the full non-overlapping frame walk; the
        ; pure band proves the projection/ViT seam with multiple patch tokens.
        (let p0 (list (lvi-patch-token b0 4 0 0 4 4)))
        (let p1 (list (lvi-patch-token b1 4 0 0 4 4)))
        (let encoded (lvi-encode-token-video (list p0 p1)))
        (list (lvil-source-evidence video container)
              (list (len p0) (len p1) (head p0) (head p1))
              (lvil-frame-evidence encoded)
              (lvil-attention-evidence (head encoded)))))
  (lvil-run
    (lvi-load-video-file
      "model/fixtures/lingbot-map/loop-two-frame.mkv"
      "/tmp/lingbot-vision-decoded-%06d.bmp"
      (list "/tmp/lingbot-vision-decoded-000001.bmp"
            "/tmp/lingbot-vision-decoded-000002.bmp"))
    (read_file "model/fixtures/lingbot-map/loop-two-frame.mkv"))
)
