; Full-valid-STFT columns and exact released padded convolution shapes.
; Expected: 4095.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-frontend-full.fk
(do
  (defn wtfsb-bit (ok bit) (if ok bit 0))
  (defn wtfsb-close (a b) (lt (abs (sub a b)) 0.000000001))
  (defn wtfsb-vector-close (actual expected)
    (if (eq (len actual) 0) (eq (len expected) 0)
      (if (and (gt (len expected) 0)
            (wtfsb-close (head actual) (head expected)))
        (wtfsb-vector-close (tail actual) (tail expected)) 0)))
  (let result (wtf-frontend-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (sum (list
    (wtfsb-bit (and (eq (nth result 2) 22828) (eq (nth result 3) 44)) 1)
    (wtfsb-bit (eq (nth result 4) 11392) 2)
    (wtfsb-bit (and (eq (nth result 5) 69) (eq (nth result 7) 69)) 4)
    (wtfsb-bit (eq (nth result 8) 69) 8)
    (wtfsb-bit (eq (nth result 9) 35) 16)
    (wtfsb-bit (eq (nth result 10) 1) 32)
    (wtfsb-bit (and (eq (len (nth result 11)) 3)
      (eq (len (nth (nth result 11) 2)) 10)) 64)
    (wtfsb-bit (and (eq (len (nth result 12)) 3)
      (eq (len (nth (nth result 12) 2)) 10)) 128)
    (wtfsb-bit (eq (nth result 13) 535296) 256)
    (wtfsb-bit (and (eq (nth result 17) 0)
      (str_eq (nth result 19)
        "centered-stft+30-second-feature-padding+complete-encoder-rewitness")) 512)
    (wtfsb-bit (wtfsb-close (nth result 6) 0.82587051795304589) 1024)
    (wtfsb-bit (and
      (wtfsb-vector-close (nth (nth result 12) 0)
        (list -0.16793260423529008 -0.0001405580719289119
          -0.084558542491558933 -0.14196724746718306
          -0.010098705453983819 -0.16848162338808201
          0.60374237074352266 -0.11389888772335305
          30.493403267378671 76.187539657411619))
      (wtfsb-vector-close (nth (nth result 12) 2)
        (list -0.15473996266309545 -0.0024654124714174517
          -0.15760335143583321 -0.098273057840111255
          -0.017231115507283758 -0.16955785530953235
          0.57856703058007453 -0.168392626478855
          24.910070577064879 75.217670849265232))) 2048))))
