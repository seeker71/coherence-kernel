; lingbot-learned-patch-live-band.fk — authentic learned visual acceptance.
;
; The model computation is not mocked: this gate decodes four upstream videos,
; validates both checkpoint tensor CRCs, and runs 4 x 1024 x 3 x 14 x 14 learned
; multiply-adds in Form before judging the returned values.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-vision-input.fk model/lingbot-learned-patch.fk model/lingbot-learned-real-life.fk

(do
  (defn llplb-bit (ok bit) (if ok bit 0))
  (defn llplb-close? (actual expected)
    (lt (abs (sub actual expected)) 0.000000000001))
  (defn llplb-row-shape? (row expected-height)
    (and (eq (nth row 1) 518)
      (and (eq (nth row 2) expected-height)
        (and (eq (nth row 5) 196)
             (eq (len (nth row 6)) 1024)))))
  (defn lingbot-learned-patch-live-band ()
    (do
      (let run (llrl-run))
      (let weight (llrl-weight-receipt run))
      (let rows (llrl-rows run))
      (let distances (llrl-distances run))
      (sum (list
        (llplb-bit (eq (nth weight 0) 1) 1)
        (llplb-bit
          (and (str_eq (nth weight 1) "checkpoint/data/7")
               (and (eq (nth weight 2) 2408448)
                    (eq (nth weight 3) 3386682685))) 2)
        (llplb-bit
          (and (str_eq (nth weight 4) "checkpoint/data/8")
               (and (eq (nth weight 5) 4096)
                    (eq (nth weight 6) 2077575075))) 4)
        (llplb-bit (and (eq (nth weight 7) 602112) (eq (nth weight 8) 1024)) 8)
        (llplb-bit
          (and (llplb-row-shape? (nth rows 0) 294)
               (llplb-row-shape? (nth rows 1) 392)) 16)
        (llplb-bit
          (and (llplb-row-shape? (nth rows 2) 294)
               (llplb-row-shape? (nth rows 3) 294)) 32)
        (llplb-bit
          (and (gt (nth distances 0) 1.0)
            (and (gt (nth distances 1) 1.0) (gt (nth distances 2) 1.0))) 64)
        (llplb-bit
          ; Independent JavaScript IEEE-f32/BMP/Conv2d reference values. These
          ; compare numeric model output, not a semantic fixture identifier.
          (and (llplb-close? (nth (nth (nth rows 0) 7) 0) 0.12222902429764307)
            (and (llplb-close? (nth (nth (nth rows 1) 7) 8) 9.5278445757771024)
              (and (llplb-close? (nth (nth (nth rows 2) 7) 8) 30.137872961305479)
                (and (llplb-close? (nth (nth (nth rows 3) 7) 8) 26.571668267340147)
                     (llplb-close? (nth distances 0) 220.21151896216611))))) 128)))))

  (lingbot-learned-patch-live-band))
