; Bounded carrier + semantics + NL + compatibility gate for the 111-slot repair.
; The exact 111-row rebuild verifier is the Node builder; this Form gate samples
; the first/middle/last repair and audits aggregate cardinality/provenance.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000-substantive-repair-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk model/concept-semantics-10000-wiktionary-lexical.fk model/concept-semantics-10000-wiktionary-lexical-audit.fk cognition/concept-10000-substantive-repair-111-nl-data.fk cognition/concept-10000-substantive-repair-111-nl.fk
(do
  (let ranked (read_file (c10-ranked-path)))
  (let canonical-index (read_file (c10-lexical-index-path)))
  (let aliases (read_file (csr111-alias-index-path)))
  (let repair-index (read_file (csr111-semantic-index-path)))
  (let repair-payload (read_file (csr111-semantic-payload-path)))
  (let nl (csr111-nl-open))
  (let welcoming (c10-detect-text-with-alias-in ranked canonical-index aliases "welcoming"))
  (let legacy-first (c10-detect-text-with-alias-in ranked canonical-index aliases "didn"))
  (let legacy-middle (c10-detect-text-with-alias-in ranked canonical-index aliases "yöu"))
  (let plum (c10-detect-text-with-alias-in ranked canonical-index aliases "plum"))
  (let legacy-last (c10-detect-text-with-alias-in ranked canonical-index aliases "waitin"))
  (let first-semantic (cs10l-repair-at-in ranked repair-index repair-payload 104))
  (let middle-semantic (cs10l-repair-at-in ranked repair-index repair-payload 5019))
  (let last-semantic (cs10l-repair-at-in ranked repair-index repair-payload 9965))
  (let id-label (csr111-nl-open-generate nl 104 "id"))
  (let ja-label (csr111-nl-open-generate nl 9965 "ja"))
  (let detected-id (csr111-nl-open-detect nl "id" id-label))
  (let completion (cs10l-substantive-completion-audit))
  (add (if (and (eq (str_len ranked) 300000) (eq (c10-source-count-in ranked) 10000)) 1 0)
  (add (mul 2 (if (and (eq (str_len canonical-index) 260000) (eq (c10-index-count-in canonical-index) 10000)) 1 0))
  (add (mul 4 (if (and (eq (str_len aliases) 2886) (eq (c10-alias-count-in aliases) 111)) 1 0))
  (add (mul 8 (if (and (eq (c10-concept-id legacy-first) 104)
                  (and (eq (c10-concept-id legacy-middle) 5019)
                       (eq (c10-concept-id legacy-last) 9965))) 1 0))
  (add (mul 16 (if (and (eq (cs10-method first-semantic) 5)
                   (and (eq (cs10-method middle-semantic) 5)
                        (eq (cs10-method last-semantic) 5))) 1 0))
  (add (mul 32 (if (and (eq (nth completion 0) 10000)
                   (and (eq (nth completion 1) 0) (eq (nth completion 7) 0))) 1 0))
  (add (mul 64 (if (and (eq (file_size (csr111-nl-sources-path)) 1443)
                   (and (eq (len (csr111-nl-offsets)) 112)
                        (and (gt (str_len id-label) 0) (gt (str_len ja-label) 0)))) 1 0))
  (add (mul 128 (if (and (eq (c10-concept-id welcoming) 104)
                    (and (str_eq (c10-concept-label welcoming) "welcoming")
                         (eq (c10-concept-id legacy-first) 104))) 1 0))
  (add (mul 256 (if (and (eq (c10-concept-rank welcoming) 10001)
                    (and (eq (c10-concept-rank plum) 10182)
                         (eq (c10-concept-id legacy-last) (c10-concept-id plum)))) 1 0))
  (add (mul 512 (if (and (str_eq (cs10-lemma first-semantic) "welcoming")
                    (and (gt (str_len (cs10-gloss first-semantic)) 0)
                         (str_eq (cs10-lemma last-semantic) "plum"))) 1 0))
  (add (mul 1024 (if (and (eq (nth detected-id 0) 104)
                     (str_eq (nth detected-id 2) id-label)) 1 0))
    (mul 2048 (if (c10-missing?
      (c10-detect-text-with-alias-in ranked canonical-index aliases "coherence-kernel")) 1 0)))))))))))))
)
