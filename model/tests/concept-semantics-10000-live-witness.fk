; concept-semantics-10000-live-witness.fk — live WordNet rows and accounting.
; Nested strings emit as byte lists so direct-source output stays literal.
; witnessed: 2026-07-18 -> full 350,000-byte index audited in Form.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk
(do
  (defn cs10-live-bytes-go (s i end)
    (if (eq i end) (empty)
      (cons (str_byte_at s i) (cs10-live-bytes-go s (add i 1) end))))
  (defn cs10-live-bytes (s) (cs10-live-bytes-go s 0 (str_len s)))
  (defn cs10-live-prefix (s n)
    (cs10-live-bytes-go s 0 (if (lt (str_len s) n) (str_len s) n)))
  (defn cs10-live-row (id)
    (do (let s (cs10-at id))
        (let r (cs10-relation-at s 0))
        (list id (cs10-method s)
          (cs10-live-bytes (cs10-synset-id s))
          (cs10-live-bytes (cs10-pos s))
          (cs10-live-bytes (cs10-lemma s))
          (cs10-sense-count s) (cs10-pos-count s) (cs10-tag-count s)
          (cs10-relation-count-of s) (str_len (cs10-gloss s))
          (cs10-live-prefix (cs10-gloss s) 72)
          (cs10-live-bytes (cs10-relation-symbol r))
          (cs10-live-bytes (cs10-relation-target r)))))
  (defn cs10-live-detection (text)
    (do (let s (cs10-detect-text text))
        (list (cs10-anchor-id s) (cs10-method s)
              (cs10-live-bytes (cs10-synset-id s)))))
  (list
    (list (file_size (cs10-index-path)) (file_size (cs10-payload-path)))
    (cs10-audit)
    (cs10-live-row 0)
    (cs10-live-row 11)
    (cs10-live-row 122)
    (cs10-live-row 227)
    (cs10-live-row 959)
    (cs10-live-row 9999)
    (cs10-live-detection "love")
    (cs10-live-detection "camera")
    (cs10-live-detection "coherence-kernel")))
