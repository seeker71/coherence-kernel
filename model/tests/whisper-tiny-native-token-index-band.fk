; Released Whisper token ids resolve through pinned tokenizer data in Form.
; Expected: 127.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-vocabulary.fk
(sum (list
  (if (str_eq (wtv-token-piece 50258) "<|startoftranscript|>") 1 0)
  (if (str_eq (wtv-token-piece 50259) "<|en|>") 2 0)
  (if (str_eq (wtv-token-piece 50359) "<|transcribe|>") 4 0)
  (if (str_eq (wtv-token-piece 50363) "<|notimestamps|>") 8 0)
  (if (str_eq (wtv-token-piece 1446) "Ġbook") 16 0)
  (if (and (str_eq (wtv-token-piece 2939) "book")
        (eq (str_len (wtv-position-row 447)) 1536)) 32 0)
  (if (and (str_eq (wtv-token-text 1446) " book")
        (str_eq (wtv-token-text 2939) "book")) 64 0)))
