; ctc-train-band.fk — the CTC loss TRAINS: a decoder learns its target from
; wrong to zero error, natively, four-way (fkwu/Go/Rust/TS).
;
; preludes: form-stdlib/core.fk form-stdlib/transformer-numerics.fk form-stdlib/trig.fk model/ctc-loss.fk model/ctc-train.fk
;
; run: cat form/form-stdlib/core.fk model/transformer-numerics.fk model/trig.fk \
;          model/ctc-loss.fk model/ctc-train.fk model/tests/ctc-train-band.fk > /tmp/ctt.fk
;      ./fkwu --src /tmp/ctt.fk    ; -> 127
;
; Verdict 127 when the decoder learns.

(do
    (defn cttb-score (ok bit) (if ok bit 0))
    (defn ctc-train-band ()
        (do
    ; --- single-label "a", symmetric init, 300 steps ---
    (let a-trained (ctt-train (ctt-u0-a) (ctt-tgt-a) 2 0.5 0.0001 300))
    ; before: greedy decode is "" (0) — WER 100
    (let c0 (cttb-score (eq (ctt-decode (ctt-u0-a)) 0) 1))
    ; after: greedy decode is "a" (1) — WER 0, the number earned
    (let c1 (cttb-score (eq (ctt-decode a-trained) 1) 2))
    ; loss strictly decreased
    (let c2 (cttb-score (lt (ctt-loss a-trained (ctt-tgt-a)) (ctt-loss (ctt-u0-a) (ctt-tgt-a))) 4))

    ; --- ordered "ab", ADVERSARIAL init (wrong order), 400 steps ---
    (let ab-trained (ctt-train (ctt-u0-ab) (ctt-tgt-ab) 3 1.0 0.0001 400))
    ; before: decode "" (0) — WER 100
    (let c3 (cttb-score (eq (ctt-decode (ctt-u0-ab)) 0) 8))
    ; after: decode "ab" (12) — WER 0, ordering + skip learned from the WRONG nudge
    (let c4 (cttb-score (eq (ctt-decode ab-trained) 12) 16))
    ; loss strictly decreased
    (let c5 (cttb-score (lt (ctt-loss ab-trained (ctt-tgt-ab)) (ctt-loss (ctt-u0-ab) (ctt-tgt-ab))) 32))
    ; the trained loss is small (the target is now the dominant alignment): < 0.7
    (let c6 (cttb-score (lt (ctt-loss ab-trained (ctt-tgt-ab)) 0.7) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (ctc-train-band))
