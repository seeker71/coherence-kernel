; jit-container-replacement-runtime-band.fk
;
; preludes: observe/jit-profile-receipt.fk model/jit-container-lowering.fk model/jit-container-backend.fk model/jit-container-byteplan.fk observe/jit-loader-contract.fk model/jit-container-loader.fk model/jit-container-profile-runtime.fk model/jit-container-replacement-runtime.fk
;
;   ( cat observe/jit-profile-receipt.fk model/jit-container-lowering.fk model/jit-container-backend.fk model/jit-container-byteplan.fk observe/jit-loader-contract.fk model/jit-container-loader.fk model/jit-container-profile-runtime.fk model/jit-container-replacement-runtime.fk model/tests/jit-container-replacement-runtime-band.fk ) > /tmp/jcrr.fk
;   ./fkwu --src /tmp/jcrr.fk

(do
    (add
        (if (eq (jcrr-ready? (jcpr-plan (jcpr-hash-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-hash-profile)) 1 1 0 0 1)) 1) 1 0)
        (add
            (if (eq (jcrr-ready? (jcpr-plan (jcpr-tree-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-tree-profile)) 1 1 0 0 1)) 1) 2 0)
            (add
                (if (eq (len (jcrr-bytes (jcpr-plan (jcpr-dict-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-dict-profile)) 1 1 0 0 1))) 4) 4 0)
                (add
                    (if (eq (len (jcrr-bytes (jcpr-plan (jcpr-tree-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-tree-profile)) 1 1 0 0 1))) 8) 8 0)
                    (add
                        (if (eq (jcrr-ready? (jcpr-plan (jcpr-hash-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-hash-profile)) 1 0 0 0 1)) 0) 16 0)
                        (add
                            (if (eq (jcpr-safe? (jcpr-plan (jcpr-hash-profile) (jcpr-bad-static-ticket) (jcpr-inline-for (jcpr-hash-profile)) 1 1 0 0 1)) 0) 32 0)
                            (add
                                (if (eq (jcpr-safe? (jcpr-plan (jcpr-hash-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-hash-profile)) 0 1 0 0 1)) 0) 64 0)
                                (if (if (eq (jcrr-ready? (jcpr-plan (jcpr-array-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-array-profile)) 1 1 0 0 1)) 1) (eq (jcrr-ready? (jcpr-plan (jcpr-list-profile) (jcpr-good-static) (jcpr-inline-for (jcpr-list-profile)) 1 1 0 0 1)) 1) 0) 128 0)))))))))
