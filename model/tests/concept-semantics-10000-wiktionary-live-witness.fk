; concept-semantics-10000-wiktionary-live-witness.fk — literal source + sense rows.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk
(do
  (defn cs10ww-bytes-go (s i end)
    (if (eq i end) (empty)
      (cons (str_byte_at s i) (cs10ww-bytes-go s (add i 1) end))))
  (defn cs10ww-bytes (s) (cs10ww-bytes-go s 0 (str_len s)))
  (defn cs10ww-prefix (s n)
    (cs10ww-bytes-go s 0 (if (lt (str_len s) n) (str_len s) n)))
  (defn cs10ww-row (domain id)
    (do (let semantic (cs10w-at id))
        (let source (cs10w-source-at id))
        (let candidate (head (cs10w-source-candidates source)))
        (list (cs10ww-bytes domain) id
          (cs10ww-bytes (c10-concept-label (c10-concept-at id)))
          (cs10-method semantic) (cs10ww-bytes (cs10-lemma semantic))
          (cs10ww-bytes (cs10-synset-id semantic))
          (cs10ww-prefix (cs10-gloss semantic) 96) (cs10-sense-count semantic)
          (cs10-relation-count-of semantic)
          (cs10w-source-page-id source) (cs10w-source-revision-id source)
          (cs10ww-bytes (cs10w-source-timestamp source))
          (cs10ww-bytes (cs10w-source-status source))
          (cs10ww-bytes (cs10w-candidate-template candidate))
          (cs10ww-bytes (cs10w-candidate-base candidate)))))
  (list (cs10w-audit) (cs10w-provenance-audit)
    (cs10ww-row "health" 2097)
    (cs10ww-row "finance" 1204)
    (cs10ww-row "education" 1667)
    (cs10ww-row "transport" 1422)
    (cs10ww-row "ecology" 1905)
    (cs10ww-row "civil-rights" 1948)
    (cs10ww-row "software" 7481)
    (cs10ww-row "agriculture" 5228)
    (cs10ww-row "science" 5590)
    (cs10ww-row "emergency" 4134)
    (cs10ww-row "family" 581)
    (cs10ww-row "security" 1474)))
