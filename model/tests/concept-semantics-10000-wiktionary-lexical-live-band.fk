(do
  (defn cs10ll-bit (ok bit) (if ok bit 0))
  (defn cs10ll-list-eq (a b)
    (if (eq (len a) 0) (eq (len b) 0)
      (if (eq (len b) 0) 0
        (if (eq (head a) (head b))
          (cs10ll-list-eq (tail a) (tail b)) 0))))
  (let audit (cs10l-audit))
  (let completion (cs10l-completion-audit))
  (add
    (cs10ll-bit (eq (fs-stat-size (cs10l-index-path)) 150000) 1)
    (add (cs10ll-bit (eq (fs-stat-size (cs10l-payload-path)) 357719) 2)
    (add (cs10ll-bit (eq (fs-stat-size (cs10l-blocks-path)) 1200) 4)
    (add (cs10ll-bit
      (cs10ll-list-eq audit (list 997 448 111 1556)) 8)
    (add (cs10ll-bit
      (cs10ll-list-eq completion (list 9889 111 997 448 111 1556 0)) 16)
    (add (cs10ll-bit (eq (add (nth audit 0) (nth audit 1)) 1445) 32)
    (add (cs10ll-bit (eq (add (nth completion 0) (nth completion 1)) 10000) 64)
    (add (cs10ll-bit (eq (nth audit 3) 1556) 128)
    (add (cs10ll-bit (eq (nth audit 2) 111) 256)
    (add (cs10ll-bit (eq (fs-exists? (cs10l-evidence-path)) 1) 512)
    (add (cs10ll-bit
      (and (eq (fs-exists? (cs10l-manifest-path)) 1)
           (eq (fs-exists? (cs10l-remaining-path)) 1)) 1024)
         (cs10ll-bit (eq (div (fs-stat-size (cs10l-blocks-path)) 12) 100) 2048))))))))))))
)
