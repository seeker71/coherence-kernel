; concept-spatial-world-band.fk -- semantic/geometry/world binding laws.
; Verdict 255, four-way.
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk model/lingbot-real-life.fk model/concept-spatial-world.fk

(do
  (defn cswb-bit (ok bit) (if ok bit 0))
  (defn cswb-scene ()
    (list "lingbot-real-life-scene" "courthouse"
      (list "source") (list "resolution") (list "vision") (list "gca")
      (list "trajectory" 24 7.0 (list 1 0 0 0 1 0 0 0 1)
        (list -0.135 -0.101 -0.806))
      (list "depth" 1472 0.7 2.0 17.2)
      (list "cloud-world" 1472 (empty) 1472)
      (list "comparison") (list "released-weight-valid" 1)))
  (let detection (list 9066 "courthouse" 12 12 (empty) 1 0))
  (let rejected (list -1 "unknown" 6 4 (empty) 0 0))
  (let known (list (cwm-cell 9066 "courthouse")))
  (let result (csw-run (cswb-scene) detection known))
  (let entity (nth (nth result 3) 1))
  (add
    (cswb-bit (eq (nth (nth result 1) 3) 9066) 1)
    (add (cswb-bit (eq (len (csw-bind (cswb-scene) rejected known)) 0) 2)
      (add (cswb-bit (str_eq (wm-ent-id entity) "courthouse") 4)
        (add (cswb-bit (eq (wm-ent-persistence entity) 2) 8)
          (add (cswb-bit (and
                (eq (nth (wm-ent-position entity) 0) -0.135)
                (and (eq (nth (wm-ent-position entity) 1) -0.101)
                     (eq (nth (wm-ent-position entity) 2) -0.806))) 16)
            (add (cswb-bit (eq (csw-depth-count (cswb-scene)) 1472) 32)
              (add (cswb-bit (eq (csw-object-count (cswb-scene)) 1472) 64)
                   (cswb-bit (eq (nth (nth result 4) 6) 1473) 128))))))))
)
