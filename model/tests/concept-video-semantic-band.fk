; concept-video-semantic-band.fk -- pure scene prototype/decision law.
; preludes: form/form-stdlib/core.fk model/lingbot-vision-input.fk model/concept-video-semantic.fk

(do
  (defn cvsb-bit (ok bit) (if ok bit 0))
  (defn concept-video-semantic-check ()
    (do (let loop (cvs-prototype 493 "office" (list 1 2 3 4) (list "a" "b" "c" "d")))
        (let university (cvs-prototype 1927 "university" (list 9 8 7 6) (list "e" "f" "g" "h")))
        (let court (cvs-prototype 9066 "courthouse" (list 4 9 2 8) (list "i" "j" "k" "l")))
        (let ps (list loop university court))
        (let q (list 2 2 3 5))
        (let win (cvs-nearest q ps))
        (add
          (cvsb-bit (eq (cvs-prototype-id win) 493) 1)
          (add (cvsb-bit (eq (cvs-l1 q (cvs-prototype-features loop)) 2) 2)
            (add (cvsb-bit (eq (len (cvs-distances q ps)) 3) 4)
              (add (cvsb-bit (eq (len (cvs-average4
                                      (list 4.0 8.0) (list 8.0 12.0)
                                      (list 0.0 4.0) (list 4.0 0.0))) 2) 8)
                (add (cvsb-bit (eq (nth (cvs-average4
                                      (list 4.0 8.0) (list 8.0 12.0)
                                      (list 0.0 4.0) (list 4.0 0.0)) 0) 4.0) 16)
                  (add (cvsb-bit (str_eq (cvs-prototype-label win) "office") 32)
                       (cvsb-bit (eq (len (cvs-prototype-sources loop)) 4) 64)))))))))
  (concept-video-semantic-check))
