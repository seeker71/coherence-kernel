; concept-semantics-10000-band.fk — pure four-way semantic-index mechanics.
; Full attributed WordNet data is witnessed by the live companion.
; preludes: form/form-stdlib/core.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk
(do
  (defn cs10b-bit (ok bit) (if ok bit 0))
  (defn cs10b-semantic-index ()
    (str_concat "10000000000030n07558676006200042001"
                "00000000000000n00000000000000000000"))
  (defn cs10b-payload () "04love0009affection@ n07495208")
  (defn cs10b-ranked ()
    "love                |00830324;you                 |28787591;")
  (defn cs10b-lexical-index ()
    "love                |0000;you                 |0001;")
  (defn cs10b-row ()
    (cs10-at-in (cs10b-semantic-index) (cs10b-payload) 0))
  (defn cs10b-primary-check ()
    (do (let s (cs10b-row))
        (cs10b-bit
          (and (eq (cs10-method s) 1)
            (and (str_eq (cs10-synset-id s) "n07558676")
                 (str_eq (cs10-pos s) "n"))) 1)))
  (defn cs10b-text-check ()
    (do (let s (cs10b-row))
        (cs10b-bit
          (and (str_eq (cs10-lemma s) "love")
               (str_eq (cs10-gloss s) "affection")) 2)))
  (defn cs10b-count-check ()
    (do (let s (cs10b-row))
        (cs10b-bit
          (and (eq (cs10-sense-count s) 6)
            (and (eq (cs10-pos-count s) 2)
              (and (eq (cs10-tag-count s) 42)
                   (eq (cs10-relation-count-of s) 1)))) 4)))
  (defn cs10b-relation-check ()
    (do (let r (cs10-relation-at (cs10b-row) 0))
        (cs10b-bit
          (and (str_eq (cs10-relation-symbol r) "@")
               (str_eq (cs10-relation-target r) "n07495208")) 8)))
  (defn cs10b-miss-check ()
    (do (let s (cs10-at-in (cs10b-semantic-index) (cs10b-payload) 1))
        (cs10b-bit
          (and (eq (cs10-mapped? s) 0)
            (and (eq (cs10-method s) 0)
                 (str_eq (cs10-method-label s) "unmatched"))) 16)))
  (defn cs10b-bound-check ()
    (cs10b-bit
      (and (eq (cs10-anchor-id
                  (cs10-at-in (cs10b-semantic-index) (cs10b-payload) -1)) -1)
           (eq (cs10-mapped?
                 (cs10-at-in (cs10b-semantic-index) (cs10b-payload) 10000)) 0)) 32))
  (defn cs10b-integration-check ()
    (do (let love (cs10-detect-text-in
                    (cs10b-ranked) (cs10b-lexical-index)
                    (cs10b-semantic-index) (cs10b-payload) "love"))
        (let absent (cs10-detect-text-in
                      (cs10b-ranked) (cs10b-lexical-index)
                      (cs10b-semantic-index) (cs10b-payload) "absent"))
        (cs10b-bit
          (and (str_eq (cs10-synset-id love) "n07558676")
            (and (eq (cs10-polysemous? love) 1)
              (and (eq (cs10-anchor-id absent) -1)
                   (eq (cs10-mapped? absent) 0)))) 64)))
  (defn concept-semantics-10000-band ()
    (add (cs10b-primary-check)
      (add (cs10b-text-check)
        (add (cs10b-count-check)
          (add (cs10b-relation-check)
            (add (cs10b-miss-check)
              (add (cs10b-bound-check) (cs10b-integration-check))))))))
  (concept-semantics-10000-band))
