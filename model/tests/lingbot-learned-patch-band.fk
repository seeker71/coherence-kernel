; lingbot-learned-patch-band.fk — four-way learned patch tensor contract.
;
; Host-free proof of the exact released tensor layout and normalization seam.
; Authentic file/CRC/inference evidence lives in the sibling live band.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-vision-input.fk model/lingbot-learned-patch.fk

(do
  (defn llpb-bit (ok bit) (if ok bit 0))
  (defn llpb-close? (actual expected)
    (lt (abs (sub actual expected)) 0.000000001))
  (defn lingbot-learned-patch-band ()
    (sum (list
      (llpb-bit
        (and (eq (llp-patch-size) 14)
          (and (eq (llp-input-channels) 3) (eq (llp-output-channels) 1024))) 1)
      (llpb-bit
        (and (eq (llp-channel-area) 196)
          (and (eq (llp-filter-size) 588) (eq (llp-weight-count) 602112))) 2)
      (llpb-bit (eq (llp-weight-index 0 0 0 0) 0) 4)
      (llpb-bit (eq (llp-weight-index 0 2 13 13) 587) 8)
      (llpb-bit (eq (llp-weight-index 1 0 0 0) 588) 16)
      (llpb-bit (eq (llp-weight-index 1023 2 13 13) 602111) 32)
      (llpb-bit
        (and (llpb-close? (llp-normalize-byte 0 0) -2.1179039301310043)
          (and (llpb-close? (llp-normalize-byte 255 2) 2.64)
               (llpb-close? (llp-normalize-byte 128 1) 0.20518207282913102))) 64))))

  (lingbot-learned-patch-band))
