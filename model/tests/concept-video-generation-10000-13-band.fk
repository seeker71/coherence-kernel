; concept-video-generation-10000-13-band.fk -- pure full-address video laws.
; expected: 8191
; preludes: form/form-stdlib/core.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk model/concept-multimodal-codec.fk model/lingbot-vision-input.fk model/concept-video-generation-10000-13.fk
(do
  (defn cvg13-test-code-roundtrips (concept-id lens)
    (do (let bits (cvg13-identity-bits concept-id lens))
        (if (and (eq (cmm-code-concept bits) concept-id)
                 (eq (cmm-code-lens bits) lens)) 1 0)))
  (defn concept-video-generation-10000-13-band ()
    (add
      (if (eq (cvg13-concept-count) 10000) 1 0)
      (add (if (eq (cvg13-lens-count) 13) 2 0)
      (add (if (eq (cvg13-address-count) 130000) 4 0)
      (add (if (and (eq (cvg13-valid? 0 0) 1)
                    (eq (cvg13-valid? 9999 12) 1)) 8 0)
      (add (if (and (eq (cvg13-valid? -1 0) 0)
                    (eq (cvg13-valid? 10000 12) 0)) 16 0)
      (add (if (and (eq (cvg13-test-code-roundtrips 0 0) 1)
                    (eq (cvg13-test-code-roundtrips 9999 12) 1)) 32 0)
      (add (if (and (str_eq (cvg13-lens-code 0) "en")
                    (str_eq (cvg13-lens-code 12) "tr")) 64 0)
      (add (if (not (eq (cvg13-semantic-hash "water" "liquid")
                        (cvg13-semantic-hash "water" "a river"))) 128 0)
      (add (if (not (eq (cvg13-semantic-hash "water" "liquid")
                        (cvg13-semantic-hash "world" "liquid"))) 256 0)
      (add (if (str_eq (cvg13-text-hex "Form") "466f726d") 512 0)
      (add (if (and (str_eq (cvg13-backdrop 6196)
                            "model/fixtures/lingbot-map/real-life/loop-24f.mkv")
                    (str_eq (cvg13-backdrop 42) "")) 1024 0)
      (add (if (and (eq (cvg13-envelope-x 0) 54)
                    (eq (cvg13-envelope-x 17) 581)) 2048 0)
           (if (eq (cvg13-audit-addresses) 130000) 4096 0))))))))))))))
  (concept-video-generation-10000-13-band))
