; concept-semantics-10000-wiktionary-live-band.fk — 12-domain attributed gate.
; witnessed: 2026-07-18 -> 65535, including all-10,000 provenance alignment.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk
(do
  (defn cs10wl-bit (ok bit) (if ok bit 0))
  (defn cs10wl-list-eq (a b)
    (if (eq (len a) 0) (eq (len b) 0)
      (if (eq (len b) 0) 0
        (if (eq (head a) (head b))
          (cs10wl-list-eq (tail a) (tail b)) 0))))
  (defn cs10wl-example (id lemma synset page revision)
    (do (let semantic (cs10w-at id))
        (let source (cs10w-source-at id))
        (let candidate (head (cs10w-source-candidates source)))
        (and (eq (cs10-method semantic) 3)
          (and (str_eq (cs10-lemma semantic) lemma)
            (and (str_eq (cs10-synset-id semantic) synset)
              (and (gt (str_len (cs10-gloss semantic)) 0)
                (and (gt (cs10-sense-count semantic) 0)
                  (and (eq (cs10w-source-page-id source) page)
                    (and (eq (cs10w-source-revision-id source) revision)
                      (and (str_eq (cs10w-source-status source) "accepted")
                        (and (str_eq (cs10w-candidate-base candidate) lemma)
                             (gt (str_len (cs10w-candidate-template candidate)) 0))))))))))))
  (add
    (cs10wl-bit
      (and (eq (str_len (read_file (cs10w-index-path))) 350000)
        (and (eq (str_len (read_file (cs10w-payload-path))) 318229)
          (and (eq (str_len (read_file (cs10w-provenance-index-path))) 130000)
               (gt (str_len (read_file (cs10w-provenance-payload-path))) 0)))) 1)
    (add
      (cs10wl-bit
        (cs10wl-list-eq (cs10w-audit)
          (list 8444 1556 7234 137 1073 6602 8339 90098)) 2)
      (add (cs10wl-bit (cs10wl-example 2097 "patient" "n10425439" 280945 86544811) 4)
      (add (cs10wl-bit (cs10wl-example 1204 "dollar" "n13683378" 217554 87245798) 8)
      (add (cs10wl-bit (cs10wl-example 1667 "student" "n10685137" 237625 80997758) 16)
      (add (cs10wl-bit (cs10wl-example 1422 "car" "n02961779" 85600 87782004) 32)
      (add (cs10wl-bit (cs10wl-example 1905 "tree" "n13124818" 216160 89989971) 64)
      (add (cs10wl-bit (cs10wl-example 1948 "right" "n05182180" 77494 91127980) 128)
      (add (cs10wl-bit (cs10wl-example 7481 "program" "n05907175" 281184 79788340) 256)
      (add (cs10wl-bit (cs10wl-example 5228 "farmer" "n10098586" 206292 85449949) 512)
      (add (cs10wl-bit (cs10wl-example 5590 "experiment" "n00640799" 243748 79673354) 1024)
      (add (cs10wl-bit (cs10wl-example 4134 "fire" "n07317454" 200254 83014160) 2048)
      (add (cs10wl-bit (cs10wl-example 581 "parent" "n10419190" 4511 88221381) 4096)
      (add (cs10wl-bit (cs10wl-example 1474 "weapon" "n04572661" 228610 91371853) 8192)
        (do (let semantic (cs10w-at 0))
            (let source (cs10w-source-at 0))
            (add
              (cs10wl-bit
                (and (eq (cs10-method semantic) 0)
                     (str_eq (cs10w-source-status source) "non-wordnet-pos-first")) 16384)
              (cs10wl-bit
                (cs10wl-list-eq (cs10w-provenance-audit)
                  (list 1073 1556 7371 10000 0)) 32768)))))))))))))))))
)
