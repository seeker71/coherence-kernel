; lingbot-pytorch-live-witness.fk — inspectable live output over authentic byte
; ranges from the released 4.63 GB LingBot-Map checkpoint.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk
; form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk
; form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk

(do
  (defn lingbot-pytorch-live-witness ()
    (do
      (let root "model/fixtures/lingbot-map/")
      (let directory
        (fs-read-slice (str_concat root "checkpoint-central-directory.bin") 0 1024))
      (let entry (lbpt-find-entry directory "checkpoint/data/0"))
      (let tensor
        (lbpt-load-record-tensor
          (str_concat root "checkpoint-data0-record.bin") entry))
      (let tail-path (str_concat root "checkpoint-central-directory.bin"))
      (let summary
        (lbpt-zip64-summary
          (fs-read-slice tail-path 0 (fs-stat-size tail-path)) 4632303465))
      (list
        "lingbot-map-released-checkpoint"
        "archive-bytes" (nth summary 3)
        "zip-entries" (nth summary 0)
        "central-directory-bytes" (nth summary 1)
        "tensor" "aggregator.camera_token"
        "shape" (list 1 2 1 1024)
        "dtype" "float32"
        "tensor-bytes" (str_len tensor)
        "crc32" (lbpt-crc-string tensor)
        "crc-matches-release" (lbpt-tensor-valid? tensor entry)
        "first-weight" (lbpt-f32 tensor 0)
        "last-weight" (lbpt-f32 tensor 8188))))

  (lingbot-pytorch-live-witness))
