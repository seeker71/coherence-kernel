; Released decoder layer 0 crosses four real prompt tokens with real speech.
; Expected: 32767.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-decoder0.fk
(do
  (defn wtd0b-bit (ok bit) (if ok bit 0))
  (defn wtd0b-close (a b) (lt (abs (sub a b)) 0.000000001))
  (defn wtd0b-vector-close (actual expected)
    (if (eq (len actual) 0) (eq (len expected) 0)
      (if (and (gt (len expected) 0)
            (wtd0b-close (head actual) (head expected)))
        (wtd0b-vector-close (tail actual) (tail expected)) 0)))
  (defn wtd0b-probability-row? (row count)
    (and (eq (len row) count)
      (and (lt (abs (sub (sum row) 1.0)) 0.000001)
           (gt (abs (sub (head row) (nth row (sub count 1)))) 0.000001))))
  (let result (wtd0-infer-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (let self-attention (nth result 11))
  (let cross-attention (nth result 12))
  (let fingerprints (nth result 13))
  (sum (list
    (wtd0b-bit (value_eq (nth result 2) (list 50258 50259 50359 50363)) 1)
    (wtd0b-bit (and (eq (nth result 3) 2) (eq (nth result 4) 384)) 2)
    (wtd0b-bit (and (eq (nth result 5) 4) (eq (nth result 6) 4)) 4)
    (wtd0b-bit (and (eq (nth result 7) 4) (eq (nth result 10) 1)) 8)
    (wtd0b-bit (eq (nth result 8) 2408832) 16)
    (wtd0b-bit (eq (nth result 9) 2408832) 32)
    (wtd0b-bit (and (eq (len self-attention) 2)
      (and (wtd0b-probability-row? (nth self-attention 0) 2)
           (wtd0b-probability-row? (nth self-attention 1) 4))) 64)
    (wtd0b-bit (and (eq (len cross-attention) 2)
      (and (wtd0b-probability-row? (nth cross-attention 0) 2)
           (wtd0b-probability-row? (nth cross-attention 1) 2))) 128)
    (wtd0b-bit (and (eq (len fingerprints) 4)
      (eq (len (nth fingerprints 3)) 10)) 256)
    (wtd0b-bit (and (ge (nth result 14) 0) (lt (nth result 14) 106)) 512)
    (wtd0b-bit (and (eq (nth result 20) 1) (eq (nth result 22) 0)) 1024)
    (wtd0b-bit (str_eq (nth result 24)
      "decoder-layers1-3+full-vocabulary-scan+tokenizer+search") 2048)
    (wtd0b-bit (and
      (wtd0b-vector-close (nth self-attention 0)
        (list 0.30527835390870783 0.69472164609129228))
      (and (wtd0b-vector-close (nth self-attention 1)
        (list 0.19131334958382634 0.025003565227017022
          0.035622238984068313 0.74806084620508839))
      (and (wtd0b-vector-close (nth cross-attention 0)
        (list 0.9947382999985358 0.005261700001464204))
      (and (wtd0b-vector-close (nth cross-attention 1)
        (list 0.970145260682308 0.029854739317691933))
      (and (wtd0b-vector-close (nth fingerprints 3)
        (list -12.63155224981397 0.965014334693161
          4.0833414900587153 4.0318342689639826
          -0.77717374858953003 -4.583315910370823
          -0.060845586764540494 -0.34938954695441699
          87.90965119336272 2344.6550147233283))
        (and (eq (nth result 14) 105)
          (and (eq (nth result 15) 50363)
            (and (wtd0b-close (nth result 16) -3.1392594288843929)
                 (wtd0b-close (nth result 17) 6.6807035509482731))))))))) 4096)
    (wtd0b-bit (wtd0-carrier-provenance-valid?) 8192)
    (wtd0b-bit (gt (nth result 18) 1.0) 16384))))
