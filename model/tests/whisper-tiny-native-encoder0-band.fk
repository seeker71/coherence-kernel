; whisper-tiny-native-encoder0-band.fk — released two-token encoder-0 witness.
; Expected: 8191.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-encoder0.fk

(do
  (defn wte0b-bit (ok bit) (if ok bit 0))
  (defn wte0b-close (a b tolerance) (lt (abs (sub a b)) tolerance))
  (defn wte0b-vector-close (actual expected tolerance)
    (if (eq (len actual) 0) (eq (len expected) 0)
      (if (and (gt (len expected) 0)
               (wte0b-close (head actual) (head expected) tolerance))
        (wte0b-vector-close (tail actual) (tail expected) tolerance) 0)))
  (let result (wte0-infer-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (let attention0 (nth result 14))
  (let attention1 (nth result 15))
  (let fingerprint0 (nth result 16))
  (let fingerprint1 (nth result 17))
  (sum (list
    (wte0b-bit (eq (nth result 13) 1) 1)
    (wte0b-bit (and (eq (nth result 5) 8) (eq (nth result 6) 6)) 2)
    (wte0b-bit (and (eq (nth result 7) 2) (eq (nth result 8) 2)) 4)
    (wte0b-bit (and (eq (nth result 9) 2) (eq (nth result 10) 384)) 8)
    (wte0b-bit (eq (nth result 11) 2310144) 16)
    (wte0b-bit (eq (nth result 12) 2886144) 32)
    (wte0b-bit (and (eq (len attention0) 2) (eq (len attention1) 2)) 64)
    (wte0b-bit (and (wte0b-close (sum attention0) 1.0 0.000001)
                    (wte0b-close (sum attention1) 1.0 0.000001)) 128)
    (wte0b-bit (and
      (wte0b-vector-close attention0
        (list 0.74177101667904166 0.25822898332095834) 0.000000001)
      (wte0b-vector-close attention1
        (list 0.99113152617659039 0.0088684738234096182) 0.000000001)) 256)
    (wte0b-bit (and
      (wte0b-vector-close fingerprint0
        (list 0.28293116261900808 1.021182505660037
          0.31154958382802622 0.35257270820981157
          0.34697272218430097 0.42518556741143587
          0.50736601388153635 0.71437550641998127
          263.20700170505131 267.56912866594985) 0.000000001)
      (wte0b-vector-close fingerprint1
        (list 1.0946487798677724 1.6066674587889098
          0.84306109135258123 0.7556052428729666
          0.41477385161879382 0.5300788296668677
          0.58213336144719985 0.71869324712133764
          274.34046496938782 279.35663047097358) 0.000000001)) 512)
    (wte0b-bit (and (gt (nth result 18) 1.0) (gt (nth result 19) 1.0)) 1024)
    (wte0b-bit (and (eq (nth result 21) 0)
      (str_eq (nth result 23)
        "encoder-layers-1-3+final-ln+decoder+tokenizer+search")) 2048)
    (wte0b-bit (wte0-carrier-provenance-valid?) 4096))))
