; concept-multimodal-codec-band.fk -- pure four-way multimodal identity law.
; preludes: form/form-stdlib/core.fk model/concept-multimodal-codec.fk

(do
  (defn cmmb-bit (condition value) (if condition value 0))
  (defn cmmb-audit-concepts (id)
    ; Independent walkers recurse on the host stack, so the four-way band
    ; probes the first 512 plus the upper edge. The fkwu live receipt runs the
    ; full 10,000-row audit; the codec law itself is width-independent.
    (if (eq id 512) 1
      (if (eq (cmm-arithmetic-roundtrip? id (mod id 13)) 1)
        (cmmb-audit-concepts (add id 1)) 0)))
  (defn cmmb-audit-lenses (lens)
    (if (eq lens 13) 1
      (if (eq (cmm-arithmetic-roundtrip? 9999 lens) 1)
        (cmmb-audit-lenses (add lens 1)) 0)))
  (defn concept-multimodal-codec-check ()
    (do (let edge (cmm-code 9999 12))
        (let af (cmm-audio-frequencies 9999 12))
        (let text (cmm-text 9999 12 "water" "water protects life"))
        (add
          (cmmb-bit (and (eq (cmm-concept-count) 10000)
                         (eq (cmm-lens-count) 13)) 1)
          (add
            (cmmb-bit (and (eq (len edge) 18)
                           (and (eq (cmm-code-concept edge) 9999)
                                (eq (cmm-code-lens edge) 12))) 2)
            (add
              (cmmb-bit (and (eq (cmm-frequency-concept (nth af 0) (nth af 1)) 9999)
                             (eq (cmm-frequency-lens (nth af 2)) 12)) 4)
              (add
                (cmmb-bit (and (eq (cmmb-audit-concepts 0) 1)
                               (eq (cmmb-audit-lenses 0) 1)) 8)
                (add
                  (cmmb-bit (and (ge (str_find text "concept=9999" 0) 0)
                                 (ge (str_find text "water protects life" 0) 0)) 16)
                  (add
                    (cmmb-bit (gt (str_len (cmm-ppm-video 42 7)) 5000) 32)
                    (cmmb-bit (and (eq (cmm-valid-concept? 10000) 0)
                                   (eq (cmm-valid-lens? 13) 0)) 64)))))))))

  (concept-multimodal-codec-check))
