; All 51,865 released tied embedding rows are searched in bounded windows.
; Expected structural full-decoder verdict: 255.
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-vocabulary.fk
(do
  (defn wtvb-bit (ok bit) (if ok bit 0))
  (defn wtvb-close (a b) (lt (abs (sub a b)) 0.000000001))
  (let result (wtv-scan-decoder-file
    "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"))
  (sum (list
    (wtvb-bit (wtv-artifacts-present?) 1)
    (wtvb-bit (value_eq (wtv-prompt-ids)
      (list 50258 50259 50359 50363)) 2)
    (wtvb-bit (value_eq (wtv-book-token-candidates) (list 1446 2939)) 4)
    (wtvb-bit (and (eq (nth result 2) 51865) (eq (nth result 4) 384)) 8)
    (wtvb-bit (and (ge (nth result 6) 0) (lt (nth result 6) 51865)) 16)
    (wtvb-bit (and (ge (nth result 10) 0) (lt (nth result 10) 51865)) 32)
    (wtvb-bit (and (gt (nth result 14) 0.0) (eq (nth result 20) 0)) 64)
    (wtvb-bit (and (gt (str_len (nth result 16)) 0)
      (and (eq (fs-stat-size (wtv-position-path)) 688128)
           (eq (str_len (wtv-position-row 447)) 1536))) 128))))
