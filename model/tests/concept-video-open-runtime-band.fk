; concept-video-open-runtime-band.fk -- parser and evidence separation.
; Verdict 2047.
; witnessed: 2026-07-18 -> 2047 four-way
; preludes: form/form-stdlib/core.fk cognition/concept-text-detection-13.fk model/concept-video-open-runtime.fk

(do
  (let raw "900000\twater\n700000\ta clear liquid\n")
  (let wanted (ctd13-candidate 377 "14845743-n" "en" "water" "omw" "OMW" "W"
                378 90 "wordnet" "n14845743" "n" "water" 4 1 (empty) 700 "raw"))
  (let other (ctd13-candidate 136 "00015388-n" "en" "animal" "omw" "OMW" "W"
                137 20 "wordnet" "n00015388" "n" "animal" 3 1 (empty) 600 "raw"))
  (let candidates (list other wanted))
  (let content (cvor-evidence 1 1 1 1 0))
  (let fallback (cvor-evidence 0 0 1 1 1))
  (add
    (if (eq (cvor-exact-confidence raw "water") 900000) 1 0)
    (add (if (eq (cvor-exact-confidence raw "a clear liquid") 700000) 2 0)
      (add (if (eq (cvor-exact-confidence raw "clear") 0) 4 0)
        (add (if (eq (cvor-candidate-id-present? candidates 377) 1) 8 0)
          (add (if (eq (cvor-candidate-id-present? candidates 9999) 0) 16 0)
            (add (if (eq (len (cvor-candidate-ids candidates)) 2) 32 0)
              (add (if (eq (cvor-localized-both? content) 1) 64 0)
                (add (if (eq (cvor-semantic-both? content) 1) 128 0)
                  (add (if (eq (cvor-semantic-both? fallback) 1) 256 0)
                    (add (if (eq (cvor-label-hit? fallback) 1) 512 0)
                         (if (eq (cvor-decoded-address-evidence content) 0) 1024 0)))))))))))
)
