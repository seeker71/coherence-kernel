; concept-world-model-band.fk -- pure top-10k persistence bridge.
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk model/concept-world-model.fk

(do
  (defn cwmb-bit (ok bit) (if ok bit 0))
  (defn concept-world-model-check ()
    (do (let known (list (cwm-cell 6196 "loop")
                         (cwm-cell 1927 "university")
                         (cwm-cell 751 "courthouse")))
        (let seen (cwm-persist-detection
                    (list 751 "courthouse" 17 (empty)) 23 "camera-a" 100 known))
        (let novel (cwm-persist 959 7 "camera-a" 101 known))
        (let world (list seen novel))
        (add
          (cwmb-bit (str_eq (wm-ent-kind seen) "concept") 1)
          (add (cwmb-bit (str_eq (wm-ent-id seen) "courthouse") 2)
            (add (cwmb-bit (eq (wm-ent-position seen) 23) 4)
              (add (cwmb-bit (eq (wm-ent-persistence seen) 2) 8)
                (add (cwmb-bit (eq (wm-held-open? novel) 1) 16)
                  (add (cwmb-bit (eq (cwm-concept-count world) 2) 32)
                       (cwmb-bit (eq (len (cwm-world world)) 2) 64)))))))))
  (concept-world-model-check))
