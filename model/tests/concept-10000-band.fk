; concept-10000-band.fk — pure four-way lookup/detection mechanics.
; Full attributed 10,000-row evidence is concept-10000-live-witness.fk.
; preludes: form/form-stdlib/core.fk model/concept-10000.fk
(do
  (defn c10b (ok bit) (if ok bit 0))
  (defn c10b-ranked ()
    "you                 |28787591;love                |00830324;camera              |00056757;")
  (defn c10b-index ()
    "camera              |0002;love                |0001;you                 |0000;")
  (defn c10b-row-check (id label frequency bit)
    (do (let c (c10-concept-at-in (c10b-ranked) id))
        (c10b (and (str_eq (c10-concept-label c) label)
                   (eq (c10-concept-frequency c) frequency)) bit)))
  (defn c10b-text-check ()
    (c10b (eq (c10-concept-id
      (c10-detect-text-n-in (c10b-ranked) (c10b-index) "love" 3)) 1) 16))
  (defn c10b-feature-check ()
    (do (let camera (c10-concept-at-in (c10b-ranked) 2))
        (c10b (eq (c10-concept-id
          (c10-detect-features-in (c10b-ranked)
            (c10-concept-features camera))) 2) 32)))
  (defn c10b-rejection-check ()
    (do (let corrupt (list 2 0 6 99 97 2))
        (c10b
          (and (eq (c10-source-count-in (c10b-ranked)) 3)
            (and (eq (c10-index-count-in (c10b-index)) 3)
              (and (c10-missing?
                     (c10-detect-text-n-in
                       (c10b-ranked) (c10b-index) "absent" 3))
                   (c10-missing?
                     (c10-detect-features-in (c10b-ranked) corrupt))))) 64)))
  (defn concept-10000-band ()
    (add (c10b (eq (c10-count) 10000) 1)
      (add (c10b-row-check 0 "you" 28787591 2)
        (add (c10b-row-check 1 "love" 830324 4)
          (add (c10b-row-check 2 "camera" 56757 8)
            (add (c10b-text-check)
              (add (c10b-feature-check) (c10b-rejection-check))))))))
  (concept-10000-band))
