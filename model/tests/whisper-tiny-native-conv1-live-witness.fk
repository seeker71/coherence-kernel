; Inspectable complete learned acoustic layer output on CC0 human speech.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk model/whisper-tiny-native-conv1.fk

(do
  (let result (wtc-infer-file (wtc-human-path)))
  (list "whisper-tiny-native-conv1-live"
    (list "source" "Lingua-Libre" "media-id" "M92036254"
      "human-recorded" 1 "tts" 0 "wav-sha256"
      "1166acadc40e8d60baa82c6321ba3445fda5305a46539c3d1a0cc43e425de523")
    (list "released-model" "openai/whisper-tiny"
      "revision" "169d4a4341b33bc18d8881c4b69c2e104e1cc0af"
      "weight-shape" (list 384 80 3) "bias-shape" (list 384)
      "learned-parameters" (nth result 6) "all-applied" (nth result 7))
    (list "native-front-end" "pcm-s16le->hann->direct-dft->80-slaney-log-mel"
      "mel-shape" (list 3 80) "peak" (nth result 3))
    (list "full-output-width" (len (nth result 4))
      "fingerprint" (nth result 5) "learned-activity" (nth result 8))
    (list "completion-floor" "one-complete-learned-acoustic-layer"
      "native-recognizer" 0)))
