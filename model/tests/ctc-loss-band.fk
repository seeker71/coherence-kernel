; ctc-loss-band.fk — the CTC forward objective is bit-exact, and the loss falls
; as the alignment sum rises. Four-way (fkwu/Go/Rust/TS).
;
; preludes: form-stdlib/core.fk form-stdlib/trig.fk model/ctc-loss.fk
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/trig.fk model/ctc-loss.fk \
;          model/tests/ctc-loss-band.fk > /tmp/ctc.fk
;      ./fkwu --src /tmp/ctc.fk    ; -> 95
;
; Verdict 95 (bits 1+2+4+8+16+64; no bit 32) when the objective holds.

(do
    (defn clb-t1 () (ctc-forward (list (list 0.5 0.5 0.0) (list 0.5 0.5 0.0)) (list 1)))
    (defn clb-t2 () (ctc-forward (list (list 0.5 0.5 0.0) (list 0.5 0.0 0.5)) (list 1 2)))
    (defn clb-score (ok bit) (if ok bit 0))
    (defn ctc-loss-band ()
        (add
            ; target "a", T=2: 3 of 4 alignments collapse to "a" -> 0.75, bit-exact
            (clb-score (eq (clb-t1) 0.75) 1)
        (add
            ; target "ab", T=2: only (a,b) is valid -> 0.25, proves the skip transition
            (clb-score (eq (clb-t2) 0.25) 2)
        (add
            ; the more-constrained target is less probable (a discriminating control)
            (clb-score (gt (clb-t1) (clb-t2)) 4)
        (add
            ; p_total is a probability in (0,1]
            (clb-score (if (gt (clb-t1) 0.0) (if (le (clb-t1) 1.0) 1 0) 0) 8)
        (add
            ; loss = -ln(p) is positive for p<1
            (clb-score (gt (ctc-loss (list (list 0.5 0.5 0.0) (list 0.5 0.5 0.0)) (list 1)) 0.0) 16)
            ; and lower for the higher-probability target: loss(0.75) < loss(0.25)
            (clb-score (lt (ctc-loss (list (list 0.5 0.5 0.0) (list 0.5 0.5 0.0)) (list 1))
                           (ctc-loss (list (list 0.5 0.5 0.0) (list 0.5 0.0 0.5)) (list 1 2))) 64)))))))
    (ctc-loss-band))
