; concept-semantics-10000-live-band.fk — asserted full-data WordNet witness.
; witnessed: 2026-07-18 -> 1023, live pinned data.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk
(do
  (defn cs10lb-bit (ok bit) (if ok bit 0))
  (defn cs10lb-list-eq (a b)
    (if (eq (len a) 0) (eq (len b) 0)
      (if (eq (len b) 0) 0
        (if (eq (head a) (head b))
          (cs10lb-list-eq (tail a) (tail b)) 0))))
  (defn cs10lb-primary (index payload id method synset lemma senses poses tags rels)
    (do (let s (cs10-at-in index payload id))
        (and (eq (cs10-method s) method)
          (and (str_eq (cs10-synset-id s) synset)
            (and (str_eq (cs10-lemma s) lemma)
              (and (eq (cs10-sense-count s) senses)
                (and (eq (cs10-pos-count s) poses)
                  (and (eq (cs10-tag-count s) tags)
                       (eq (cs10-relation-count-of s) rels)))))))))
  (defn cs10lb-run (index payload ranked lexical-index)
    (add
      (cs10lb-bit
        (and (eq (str_len index) 350000)
             (eq (str_len payload) 1621448)) 1)
      (add
        (cs10lb-bit
          (cs10lb-list-eq (cs10-audit-in index)
            (list 7371 2629 7234 137 5618 7266 72046)) 2)
        (add
          (cs10lb-bit
            (and (eq (cs10-method (cs10-at-in index payload 0)) 0)
                 (eq (cs10-anchor-id (cs10-at-in index payload 0)) 0)) 4)
          (add
            (cs10lb-bit
              (cs10lb-primary index payload 11 2 "v02610777" "be" 14 2 10742 138) 8)
            (add
              (cs10lb-bit
                (cs10lb-primary index payload 122 1 "v01779085" "love" 10 2 43 12) 16)
              (add
                (cs10lb-bit
                  (cs10lb-primary index payload 227 1 "n09489410" "world" 9 2 49 11) 32)
                (add
                  (cs10lb-bit
                    (cs10lb-primary index payload 959 1 "n02946154" "camera" 2 1 18 19) 64)
                  (add
                    (cs10lb-bit
                      (cs10lb-primary index payload 9999 1 "n07815555" "caviar" 1 1 0 2) 128)
                    (add
                      (do (let love (cs10-at-in index payload 122))
                          (let camera (cs10-at-in index payload 959))
                          (cs10lb-bit
                            (and (str_eq (cs10-relation-target
                                           (cs10-relation-at love 0)) "a01462344")
                                 (str_eq (cs10-relation-target
                                           (cs10-relation-at camera 0)) "n03932386")) 256))
                      (do (let love (cs10-detect-text-in
                                      ranked lexical-index index payload "love"))
                          (let absent (cs10-detect-text-in
                                        ranked lexical-index index payload "coherence-kernel"))
                          (cs10lb-bit
                            (and (str_eq (cs10-synset-id love) "v01779085")
                              (and (eq (cs10-anchor-id absent) -1)
                                   (eq (cs10-mapped? absent) 0))) 512))))))))))))
  (cs10lb-run
    (read_file (cs10-index-path))
    (read_file (cs10-payload-path))
    (read_file (c10-ranked-path))
    (read_file (c10-lexical-index-path))))
