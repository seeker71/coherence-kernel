; concept-audio-asr-13-band.fk -- pure laws for content/address separation.
; preludes: form/form-stdlib/core.fk model/concept-multimodal-codec.fk cognition/concept-nl-semantic-13-runtime.fk model/concept-audio-scale-13.fk model/concept-audio-asr-13.fk

(do
  (defn casr13b-bit (held bit) (if held bit 0))
  (defn concept-audio-asr-13-check ()
    (do (let candidates (list
          (casr13-candidate 377 "water")
          (casr13-candidate 959 "camera")
          (casr13-candidate 365 "music")))
        (let long-candidates (list
          (casr13-candidate 1 "photo")
          (casr13-candidate 959 "appareil photo")))
        (add
          (casr13b-bit (eq (casr13-contains? "I need WATER." "water") 1) 1)
          (add
            (casr13b-bit (eq (casr13-contains? "我需要水来做晚饭。" "水") 1) 2)
            (add
              (casr13b-bit (eq (nth (casr13-detect-candidates
                                "The camera recorded music." candidates) 0) 959) 4)
              (add
                (casr13b-bit (eq (nth (casr13-detect-candidates
                                  "L'appareil photo fonctionne." long-candidates) 0) 959) 8)
                (add
                  (casr13b-bit (str_eq (casr13-oracle-name)
                                    "whisper.cpp-large-v3-turbo") 16)
                  (add
                    (casr13b-bit (eq (str_find
                                      (casr13-speech-only-command "Samantha" "water"
                                        "/tmp/a.aiff" "/tmp/a.wav")
                                      "aevalsrc" 0) -1) 32)
                    (casr13b-bit (eq (str_find
                                      (casr13-speech-only-command "Samantha" "water"
                                        "/tmp/a.aiff" "/tmp/a.wav")
                                      "concat=n=" 0) -1) 64)))))))))
  (concept-audio-asr-13-check))
