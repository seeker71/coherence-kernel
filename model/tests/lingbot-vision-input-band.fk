; lingbot-vision-input-band.fk — pure four-way vision/ViT contract.
; The host-I/O and real-byte witness is lingbot-vision-live-witness.fk.
; preludes: form/form-stdlib/core.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-vision-input.fk
(do
  (defn lvib-bit (ok bit) (if ok bit 0))
  (defn lvib-close (a b) (lt (tn-abs (sub a b)) 0.000001))
  (defn lingbot-vision-input-band ()
    (do
      ; Each accumulator represents every pixel in one 4x4 RGB patch.
      (let p0 (lvi-project-acc (list 1600 1280 960 -8192 4096) 4 0 0 2 1))
      (let p1 (lvi-project-acc (list 960 1440 1760 6144 -2048) 4 1 0 2 1))
      (let q0 (lvi-project-acc (list 1760 1120 800 -4096 7168) 4 0 0 2 1))
      (let q1 (lvi-project-acc (list 800 1600 1920 8192 -1024) 4 1 0 2 1))
      (let frames (list (list p0 p1) (list q0 q1)))
      (let encoded (lvi-encode-token-video frames))
      (let e0 (nth encoded 0))
      (let e1 (nth encoded 1))
      (let c0 (lvib-bit (and (eq (len p0) 4) (lvib-close (nth p0 0) 0.3137254901960784)) 1))
      (let c1 (lvib-bit (and (lt (nth p0 1) 0.2) (gt (nth p1 2) 0.5)) 2))
      (let c2 (lvib-bit (and (eq (len e0) 3) (eq (len (head e0)) 4)) 4))
      (let c3 (lvib-bit (not (lvib-close (nth (head e0) 0) (nth (lvi-frame-token) 0))) 8))
      (let c4 (lvib-bit (and (eq (len encoded) 2) (eq (len e1) 3)) 16))
      (let c5 (lvib-bit (not (lvib-close (nth (head e0) 0) (nth (head e1) 0))) 32))
      (let probs (tn-softmax (tb-scores (head e0) e0 0.5)))
      (let c6 (lvib-bit (lvib-close (tn-sum probs) 1.0) 64))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6))))))))
  (lingbot-vision-input-band))
