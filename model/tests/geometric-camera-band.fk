; geometric-camera-band.fk — pinhole reconstruction and SE(3) relations agree.
; preludes: form/form-stdlib/core.fk model/geometric-camera.fk
(do
  (defn gcb (ok bit) (if ok bit 0))
  (defn geometric-camera-band ()
    (do
      (let id (gc-m3-id))
      (let rz (list 0 -1 0 1 0 0 0 0 1))
      (let p (gc-pose rz (list 10 0 0)))
      (let q (gc-pose id (list 0 2 0)))
      (let c0 (gcb (gc-list-eq (gc-unproject 2 2 2 (list 2 2 1 1)) (list 1 1 2)) 1))
      (let c1 (gcb (gc-list-eq (gc-depth-to-world 1 1 2 (list 2 2 1 1) p) (list 10 0 2)) 2))
      (let c2 (gcb (gc-list-eq (gc-transform (gc-inverse p) (gc-transform p (list 3 4 5))) (list 3 4 5)) 4))
      (let c3 (gcb (gc-list-eq (gc-transform (gc-compose p q) (list 1 0 0))
                            (gc-transform p (gc-transform q (list 1 0 0)))) 8))
      (let c4 (gcb (gc-list-eq (gc-t (gc-relative p (gc-compose p q))) (list 0 2 0)) 16))
      (let c5 (gcb (gc-list-close (gc-normalize-point (list 20 10 5) 5) (list 4.0 2.0 1.0)) 32))
      (let c6 (gcb (gc-list-close (gc-t (gc-normalize-pose (gc-pose id (list 30 15 0)) 15)) (list 2.0 1.0 0.0)) 64))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6))))))))
  (geometric-camera-band))
