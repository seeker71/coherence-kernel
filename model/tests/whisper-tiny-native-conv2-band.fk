; Complete released Whisper-tiny conv1 -> erf-form GELU -> conv2 -> erf-form GELU.
; Expected values use Ruby/libm Math.erf, independent from Form's A&S erf.
; Verdict 2047 proves the real fixture, tensors, full learned path, and output.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/whisper-tiny-native-conv1.fk model/whisper-tiny-native-conv2.fk

(do
  (defn wt2b-bit (ok bit) (if ok bit 0))
  (defn wt2b-close? (actual expected) (lt (abs (sub actual expected)) 0.00002))
  (defn wt2b-vector-close? (actual expected)
    (if (eq (len expected) 0) (eq (len actual) 0)
      (if (wt2b-close? (head actual) (head expected))
        (wt2b-vector-close? (tail actual) (tail expected)) 0)))
  (defn whisper-tiny-native-conv2-band ()
    (do
      (let result (wt2-infer-file (wtc-human-path)))
      (let expected (list
        -0.13670750223762715 -0.000021198802438007303 -0.13907305567910191
        -0.15989431764229514 -0.013989911796331774 -0.1633629627614285
        0.30051730922599623 0.24343038018044535 24.186262468005253
        70.81786842384183))
      (sum (list
        (wt2b-bit (eq (nth result 1) 22828) 1)
        (wt2b-bit (eq (nth result 2) 44) 2)
        (wt2b-bit (wt2b-close? (nth result 3) 0.8258705179541589) 4)
        (wt2b-bit (eq (len (nth result 4)) 384) 8)
        (wt2b-bit (wt2b-vector-close? (nth result 5) expected) 16)
        (wt2b-bit (eq (nth result 6) 535296) 32)
        (wt2b-bit (eq (nth result 7) 1) 64)
        (wt2b-bit (eq (nth result 8) 1) 128)
        (wt2b-bit (eq (nth result 9) 6) 256)
        (wt2b-bit (and (eq (len (nth result 10)) 4)
                       (eq (len (nth (nth result 10) 0)) 384)) 512)
        (wt2b-bit (and (eq (wt2-weight-count) 442368)
                       (eq (wt2-bias-count) 384)) 1024)))))
  (whisper-tiny-native-conv2-band))
