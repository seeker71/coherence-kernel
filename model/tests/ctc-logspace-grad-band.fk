; ctc-logspace-grad-band.fk — the log-space gradient equals the probability-space
; gradient where both work, and stays a valid posterior residual at length. Four-way.
;
; preludes: form-stdlib/core.fk form-stdlib/transformer-numerics.fk form-stdlib/trig.fk model/ctc-loss.fk model/ctc-grad.fk model/ctc-logspace.fk model/ctc-logspace-grad.fk
;
; run: cat form/form-stdlib/core.fk model/transformer-numerics.fk model/trig.fk \
;          model/ctc-loss.fk model/ctc-grad.fk model/ctc-logspace.fk \
;          model/ctc-logspace-grad.fk model/tests/ctc-logspace-grad-band.fk > /tmp/clg.fk
;      ./fkwu --src /tmp/clg.fk    ; -> 127
;
; Verdict 127 when the log-space gradient is correct AND stable.

(do
    (defn clgb-abs (x) (if (lt x 0.0) (sub 0.0 x) x))
    (defn clgb-eq? (a b) (if (lt (clgb-abs (sub a b)) 0.00001) 1 0))
    (defn clgb-in11? (x) (if (lt x 1.001) (if (gt x -1.001) 1 0) 0))
    (defn clgb-rep (n f acc) (if (eq n 0) acc (clgb-rep (sub n 1) f (cons f acc))))

    (defn clgb-uA () (list (list 0.3 0.7) (list 0.1 0.4)))
    (defn clgb-uB () (list (list 0.2 0.5 0.1) (list 0.3 0.1 0.6) (list 0.4 0.2 0.3)))

    (defn clgb-score (ok bit) (if ok bit 0))
    (defn ctc-logspace-grad-band ()
        (do
    ; correctness: log-space gradient == probability-space gradient (ctc-grad) on toy A
    (let c0 (clgb-score (eq (add (clgb-eq? (clg-grad (clgb-uA) (list 1) 0 0) (cg-grad (clgb-uA) (list 1) 0 0))
                            (add (clgb-eq? (clg-grad (clgb-uA) (list 1) 0 1) (cg-grad (clgb-uA) (list 1) 0 1))
                            (add (clgb-eq? (clg-grad (clgb-uA) (list 1) 1 0) (cg-grad (clgb-uA) (list 1) 1 0))
                                 (clgb-eq? (clg-grad (clgb-uA) (list 1) 1 1) (cg-grad (clgb-uA) (list 1) 1 1))))) 4) 1))
    ; toy B: equals prob-space gradient on the skip-exercising params
    (let c1 (clgb-score (eq (clgb-eq? (clg-grad (clgb-uB) (list 1 2) 0 1) (cg-grad (clgb-uB) (list 1 2) 0 1)) 1) 2))
    (let c2 (clgb-score (eq (clgb-eq? (clg-grad (clgb-uB) (list 1 2) 2 2) (cg-grad (clgb-uB) (list 1 2) 2 2)) 1) 4))
    (let c3 (clgb-score (eq (clgb-eq? (clg-grad (clgb-uB) (list 1 2) 1 1) (cg-grad (clgb-uB) (list 1 2) 1 1)) 1) 8))
    ; the gradient is a valid posterior residual: in [-1,1]
    (let c4 (clgb-score (eq (clgb-in11? (clg-grad (clgb-uA) (list 1) 0 1)) 1) 16))
    ; per-frame gradients sum to ~0 (softmax sums to 1, posterior mass sums to 1)
    (let c5 (clgb-score (lt (clgb-abs (add (clg-grad (clgb-uA) (list 1) 0 0) (clg-grad (clgb-uA) (list 1) 0 1))) 0.00001) 32))
    ; robustness at length: on a 12-frame sequence the gradient is still a valid
    ; residual in [-1,1] (where probability-space alpha/beta would underflow)
    (let long (clgb-rep 12 (list 0.0 0.0) (empty)))
    (let c6 (clgb-score (eq (clgb-in11? (clg-grad long (list 1) 5 1)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (ctc-logspace-grad-band))
