; concept-semantics-10000-wiktionary-lexical-live-witness.fk — readable live rows.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk model/concept-semantics-10000-wiktionary-lexical.fk model/concept-semantics-10000-wiktionary-lexical-audit.fk
(do
  (defn cs10llw-row (ranked lexical-index lexical-payload id)
    (do (let anchor (c10-concept-at-in ranked id))
        (let source (cs10l-source-at-in lexical-index lexical-payload id))
        (let semantic (if (cs10l-source-accepted? source)
          (cs10l-semantic-from-source ranked source) (cs10-miss id)))
        (list id (c10-concept-label anchor) (c10-concept-frequency anchor)
          (cs10-method semantic)
          (if (eq (cs10-method semantic) 4) "wiktionary-first-definition" "unmatched")
          (cs10l-lookup source) (cs10l-title source) (cs10l-section source)
          (cs10l-definition source) (cs10l-page-id source)
          (cs10l-revision-id source) (cs10l-timestamp source)
          (cs10l-english-sha source))))
  (let ranked (read_file (c10-ranked-path)))
  (let lexical-index (read_file (cs10l-index-path)))
  (let lexical-payload (read_file (cs10l-payload-path)))
  (list (cs10l-completion-audit)
    (cs10llw-row ranked lexical-index lexical-payload 0)
    (cs10llw-row ranked lexical-index lexical-payload 5)
    (cs10llw-row ranked lexical-index lexical-payload 95)
    (cs10llw-row ranked lexical-index lexical-payload 1592)
    (cs10llw-row ranked lexical-index lexical-payload 1316)
    (cs10llw-row ranked lexical-index lexical-payload 1575)
    (cs10llw-row ranked lexical-index lexical-payload 1603)
    (cs10llw-row ranked lexical-index lexical-payload 5397)
    (cs10llw-row ranked lexical-index lexical-payload 104)))
