; concept-video-content-sensing-band.fk -- pure semantic-evidence law.
; expected: 1023
; preludes: form/form-stdlib/core.fk model/concept-video-content-sensing.fk

(do
  (defn cvcst-bit (ok bit) (if ok bit 0))
  (defn concept-video-content-sensing-check ()
    (do
      (let office (cvcs-detect-labels
        (list "400000\tdocument\n300000\tcomputer\n200000\tdesk\n"
              "300000\twhiteboard\n200000\tinterior_room\n")))
      (let university (cvcs-detect-labels
        (list "500000\tarena\n400000\trink\n" "300000\tbridge\n200000\tbench\n")))
      (let courthouse (cvcs-detect-labels
        (list "600000\tdome\n500000\tstatue\n" "400000\tfountain\n300000\tarch\n")))
      (let unknown (cvcs-detect-labels
        (list "900000\tsky\n800000\tstreet\n" "700000\twindow\n")))
      (add
        (cvcst-bit (eq (nth office 0) 493) 1)
        (add (cvcst-bit (str_eq (nth university 1) "university") 2)
          (add (cvcst-bit (eq (nth courthouse 0) 9066) 4)
            (add (cvcst-bit (eq (nth unknown 0) -1) 8)
              (add (cvcst-bit (eq (nth unknown 5) 0) 16)
                (add (cvcst-bit (eq (nth office 6) 0) 32)
                  (add (cvcst-bit (eq (len (nth office 4)) 3) 64)
                    (add (cvcst-bit (gt (nth office 2) (nth university 2)) 128)
                      (add (cvcst-bit (eq (cvcs-has-label? "1\tcomputer_monitor\n" "computer") 1) 256)
                           (cvcst-bit (eq (cvcs-has-exact-label? "1\tcomputer_monitor\n" "computer") 0) 512))))))))))))
  (concept-video-content-sensing-check))
