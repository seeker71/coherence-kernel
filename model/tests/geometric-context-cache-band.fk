; geometric-context-cache-band.fk — exact GCA accounting at short and 10k scale.
; preludes: form/form-stdlib/core.fk model/geometric-context-cache.fk
(do
  (defn gccb (ok bit) (if ok bit 0))
  (defn geometric-context-cache-band ()
    (do
      (let s19 (gcc-state 19 3 16 500))
      (let s20 (gcc-append s19 3 16 500))
      (let c0 (gccb (eq (gcc-context-tokens 10 3 16 500) 5060) 1))
      (let c1 (gccb (and (eq (nth s19 1) 19) (eq (nth s19 2) 0)) 2))
      (let c2 (gccb (and (eq (nth s20 1) 19) (eq (nth s20 2) 1)) 4))
      (let c3 (gccb (eq (gcc-growth 20 3 16 500) 6) 8))
      (let c4 (gccb (and (eq (gcc-causal-tokens 10000 500) 5060000)
                          (eq (gcc-context-tokens 10000 3 16 500) 69500)) 16))
      (let c5 (gccb (eq (gcc-saved-tokens 10000 3 16 500) 4990500) 32))
      (let c6 (gccb (and (eq (gcc-relative-pairs 64) 4032)
                          (eq (gcc-pages 69500 128) 543)) 64))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6))))))))
  (geometric-context-cache-band))
