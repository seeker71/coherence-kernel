; preludes: form-stdlib/core.fk form-stdlib/numeric-tower.fk
;
; numeric-tower-band — STONE S9: bignum / rational / complex as pure Form recipes
; composed over cells (axiom-1 integers + axiom-2 composition). Proven FOUR-WAY
; (Go=Rust=TS=fkwu) on the PURE-OP surface AND on-metal via `fkwu --src`.
;
; The verdict is a single nullary defn over nested expressions (NO do/let
; sequencing): fkwu's --src source-runner binds defn params and walks nested
; calls/recursion, so the witness crosses on the real native too — every claim is
; a structural digit-list / pair comparison built only from list+int ops every
; walker shares. (The decimal STRING of a bignum needs int_to_str, which the
; minimal Rust/TS walkers don't carry — that lane is three-way: fkwu --src + Go,
; shown in the receipt. The ARITHMETIC under test here is four-way.)
;
; HARD-GATE claims from re-architecture-stones.form — verdict 127 when all land:
;   1   bn-add  99999999999999999999 + 1  →  the digit-list of 10^20  (past 64-bit)
;   2   bn-mul  99999999999999999999^2     →  the exact 40-digit digit-list
;   4   bn-cmp  (10^20) > (10^20 − 1)
;   8   rat-reduce  4/8  →  1/2
;   16  rat-add  1/2 + 1/3  →  5/6
;   32  cx-mul  (1+2i)(3+4i)  →  (−5, 10)
;   64  cx-add  (1+2i)+(3+4i)  →  (4, 6)

; ── the named witnesses (each a nullary defn — one form, fkwu-scope-safe) ──

; 99999999999999999999 = 9999999999 * 10^10 + 9999999999  (20 nines, past 2^63)
(defn ntb-big99 ()
  (bn-add (bn-mul (bn-from-int 9999999999) (bn-from-int 10000000000))
          (bn-from-int 9999999999)))
; 10^20 = (10^10)^2 — built independently from the arithmetic under test
(defn ntb-ten20 () (bn-mul (bn-from-int 10000000000) (bn-from-int 10000000000)))
; the exact base-10000 little-endian digit-list of 99999999999999999999^2
(defn ntb-sq-expect () (list 1 0 0 0 0 9998 9999 9999 9999 9999))

(defn ntbk (cond bit) (if cond bit 0))

; c0: bn-add 99999999999999999999 + 1 == 10^20  (structural digit-list match)
(defn ntb-c0 () (ntbk (bn-eq (bn-add (ntb-big99) (bn-from-int 1)) (ntb-ten20)) 1))
; c1: bn-mul big99^2 == the exact 40-decimal-digit number
(defn ntb-c1 () (ntbk (bn-eq (bn-mul (ntb-big99) (ntb-big99)) (ntb-sq-expect)) 2))
; c2: bn-cmp 10^20 > (10^20 − 1)
(defn ntb-c2 () (ntbk (eq (bn-cmp (ntb-ten20) (ntb-big99)) 1) 4))
; c3: rat-reduce 4/8 == 1/2
(defn ntb-c3 ()
  (ntbk (and (eq (rat-num (rat-reduce (rat 4 8))) 1)
             (eq (rat-den (rat-reduce (rat 4 8))) 2)) 8))
; c4: rat-add 1/2 + 1/3 == 5/6
(defn ntb-c4 ()
  (ntbk (and (eq (rat-num (rat-add (rat 1 2) (rat 1 3))) 5)
             (eq (rat-den (rat-add (rat 1 2) (rat 1 3))) 6)) 16))
; c5: cx-mul (1+2i)(3+4i) == (−5, 10)
(defn ntb-c5 ()
  (ntbk (and (eq (cx-re (cx-mul (cx 1 2) (cx 3 4))) -5)
             (eq (cx-im (cx-mul (cx 1 2) (cx 3 4))) 10)) 32))
; c6: cx-add (1+2i)+(3+4i) == (4, 6)
(defn ntb-c6 ()
  (ntbk (and (eq (cx-re (cx-add (cx 1 2) (cx 3 4))) 4)
             (eq (cx-im (cx-add (cx 1 2) (cx 3 4))) 6)) 64))

(defn numeric-tower-check ()
  (add (ntb-c0)
  (add (ntb-c1)
  (add (ntb-c2)
  (add (ntb-c3)
  (add (ntb-c4)
  (add (ntb-c5) (ntb-c6))))))))

(numeric-tower-check)
