; jit-container-lowering-metadata-band.fk
;
;   ( cat model/jit-container-lowering.fk model/tests/jit-container-lowering-metadata-band.fk ) > /tmp/jclm.fk
;   ./fkwu --src /tmp/jclm.fk

(do
    (defn jclm-plan (repr-total fault fallback collision order)
        (jcl-plan 1 1 7
            1 1 1 repr-total (jcl-repr-complete-total) fault fallback
            1 collision order))
    (defn jclm-tree-plan (order)
        (jcl-plan 1 1 8
            1 1 1 (jcl-repr-complete-total) (jcl-repr-complete-total) 1 1
            2 0 order))
    (add
        (if (eq (len (jcl-compile (jclm-plan 511 1 1 0 0) 6 1)) 0) 1 0)
        (add
            (if (eq (len (jcl-compile (jclm-plan (jcl-repr-complete-total) 0 1 0 0) 6 1)) 0) 2 0)
            (add
                (if (eq (len (jcl-compile (jclm-plan (jcl-repr-complete-total) 1 0 0 0) 6 1)) 0) 4 0)
                (add
                    (if (eq (len (jcl-compile (jclm-plan (jcl-repr-complete-total) 1 1 1 0) 6 1)) 0) 8 0)
                    (if (eq (len (jcl-compile (jclm-tree-plan 0) 6 1)) 0) 16 0))))))
