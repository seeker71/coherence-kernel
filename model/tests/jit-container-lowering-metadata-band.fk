; jit-container-lowering-metadata-band.fk
;
;   ( cat model/jit-container-lowering.fk model/tests/jit-container-lowering-metadata-band.fk ) > /tmp/jclm.fk
;   ./fkwu --src /tmp/jclm.fk

(do
    (add
        (if (eq (len (jcl-compile (jcl-plan 1 1 7 1 1 1 511 1023 1 1 1 0 0) 6 1)) 0) 1 0)
        (add
            (if (eq (len (jcl-compile (jcl-plan 1 1 7 1 1 1 1023 1023 0 1 1 0 0) 6 1)) 0) 2 0)
            (add
                (if (eq (len (jcl-compile (jcl-plan 1 1 7 1 1 1 1023 1023 1 0 1 0 0) 6 1)) 0) 4 0)
                (add
                    (if (eq (len (jcl-compile (jcl-plan 1 1 7 1 1 1 1023 1023 1 1 1 1 0) 6 1)) 0) 8 0)
                    (if (eq (len (jcl-compile (jcl-plan 1 1 8 1 1 1 1023 1023 1 1 2 0 0) 6 1)) 0) 16 0))))))
