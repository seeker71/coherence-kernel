; concept-audio-semantic-band.fk -- pure prototype/decision law.
; preludes: form/form-stdlib/core.fk form/form-stdlib/trig.fk observe/wav-sense.fk observe/spectrum.fk model/concept-multimodal-codec.fk model/concept-audio-semantic.fk

(do
  (defn casb-bit (ok bit) (if ok bit 0))
  (defn concept-audio-semantic-check ()
    (do (let water (cas-prototype 377 "water" (list 1 2 3 4) (list "a" "b" "c")))
        (let world (cas-prototype 227 "world" (list 8 7 6 5) (list "d" "e" "f")))
        (let camera (cas-prototype 959 "camera" (list 3 8 2 9) (list "g" "h" "i")))
        (let ps (list water world camera))
        (let q (list 2 2 3 5))
        (let win (cas-nearest q ps))
        (add
          (casb-bit (eq (cas-prototype-id win) 377) 1)
          (add
            (casb-bit (eq (cas-l1 q (cas-prototype-features water)) 2) 2)
            (add
              (casb-bit (eq (len (cas-distances q ps)) 3) 4)
              (add
                (casb-bit (eq (len (cas-average3
                              (list 3.0 6.0) (list 6.0 9.0) (list 0.0 3.0))) 2) 8)
                (add
                  (casb-bit (eq (nth (cas-average3
                                    (list 3.0 6.0) (list 6.0 9.0) (list 0.0 3.0)) 0) 3.0) 16)
                  (add
                    (casb-bit (eq (cmm-data-offset
                                  "RIFFxxxxxxxxdataxxxx") 20) 32)
                    (casb-bit (str_eq (cas-prototype-label win) "water") 64)))))))))
  (concept-audio-semantic-check))
