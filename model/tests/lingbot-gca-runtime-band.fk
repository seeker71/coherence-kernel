; lingbot-gca-runtime-band.fk — real-frame tokens cross executable GCA state.
; The two luma grids are sampled from the committed upstream LingBot loop BMPs.
; preludes: form/form-stdlib/core.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-gca-runtime.fk
(do
  (defn lgrb-hit (ok bit) (if ok bit 0))
  (defn lgrb-close (a b eps) (le (abs (sub a b)) eps))
  (defn lgrb-vclose (a b eps)
    (if (eq (len a) 0) 1
      (and (lgrb-close (head a) (head b) eps)
           (lgrb-vclose (tail a) (tail b) eps))))
  (defn lgrb-norm2 (v) (tb-dot v v))
  (defn lgrb-grid-cell (g n x y) (nth g (add (mul y n) x)))
  (defn lgrb-grid-edge (g n x y)
    (add (if (lt (add x 1) n)
           (abs (sub (lgrb-grid-cell g n x y) (lgrb-grid-cell g n (add x 1) y))) 0)
         (if (lt (add y 1) n)
           (abs (sub (lgrb-grid-cell g n x y) (lgrb-grid-cell g n x (add y 1)))) 0)))
  (defn lgrb-token-at (g n x y)
    (list (div (mul (lgrb-grid-cell g n x y) 1.0) 255.0)
          (div (mul (lgrb-grid-edge g n x y) 1.0) 510.0)
          (div (mul x 1.0) (mul (sub n 1) 1.0))
          (div (mul y 1.0) (mul (sub n 1) 1.0))))
  (defn lgrb-tokens-go (g n i)
    (if (eq i (mul n n)) (empty)
      (cons (lgrb-token-at g n (mod i n) (div i n))
            (lgrb-tokens-go g n (add i 1)))))
  (defn lgrb-tokens (g n) (lgrb-tokens-go g n 0))
  (defn lgrb-all-visible (rows)
    (if (eq (len rows) 0) 1
      (and (eq (nth (head rows) 2) 1) (lgrb-all-visible (tail rows)))))
  (defn lgrb-any-different (a b eps)
    (if (eq (len a) 0) 0
      (if (not (lgrb-vclose (head a) (head b) eps)) 1
        (lgrb-any-different (tail a) (tail b) eps))))

  (defn lingbot-gca-runtime-band ()
    (do
      ; Exact 4x4 luma observations from loop-000000.bmp / loop-000001.bmp.
      (let f0 (lgrb-tokens
        (list 191 137 149 185 198 110 90 190 203 110 111 113 150 96 13 103) 4))
      (let f1 (lgrb-tokens
        (list 192 140 155 179 198 110 94 198 200 110 107 115 149 97 21 104) 4))
      (let r0 (lgr-video-rope (head f0) 0))
      (let r7 (lgr-video-rope (head f0) 7))
      (let s0 (lgr-cache-frame (lgr-cache-empty) 0 f0 1 2))
      (let s1 (lgr-cache-frame s0 1 f1 1 2))
      (let s2 (lgr-cache-frame s1 2 f0 1 2))
      (let s3 (lgr-cache-frame s2 3 f1 1 2))
      (let step4 (lgr-step s3 4 f0 1 2))
      (let out4 (nth step4 0))
      (let s4 (nth step4 1))
      (let m4 (nth step4 2))
      (let past-mask (lgr-mask-row s4 1 (lgr-tier-window)))
      (let without-traj (lgr-cache (lgr-anchors s4) (empty) (lgr-window s4)))
      (let out-no-traj (lgr-gca f0 4 (lgr-tier-window) without-traj))
      (let anchor0 (head (lgr-anchors s0)))
      (let anchor4 (head (lgr-anchors s4)))
      (let c0 (lgrb-hit (and (eq (len f0) 16)
                              (lgrb-close (nth (head f0) 0) (div 191.0 255.0) 0.000000000001)) 1))
      (let c1 (lgrb-hit (not (lgrb-vclose r0 r7 0.000001)) 2))
      (let c2 (lgrb-hit (lgrb-close (lgrb-norm2 r0) (lgrb-norm2 r7) 0.0001) 4))
      (let c3 (lgrb-hit (and (eq (len (lgr-anchors s4)) 1)
                              (and (eq (len (lgr-trajectory s4)) 2)
                                   (eq (len (lgr-window s4)) 2))) 8))
      (let c4 (lgrb-hit (and (eq (lgr-entry-tier (head (lgr-trajectory s4))) 2)
                              (eq (lgr-entry-tier (head (lgr-window s4))) 3)) 16))
      (let c5 (lgrb-hit (and (eq (len (lgr-entry-keys anchor4)) 22)
                              (and (eq (len (head (lgr-entry-keys anchor4))) 4)
                                   (not (lgrb-vclose (head (lgr-entry-keys anchor4))
                                                     (head (lgr-entry-values anchor4)) 0.000001)))) 32))
      (let c6 (lgrb-hit (eq (lgr-cache-token-count s4) 78) 64))
      (let c7 (lgrb-hit (and (eq (len m4) 5) (lgrb-all-visible m4)) 128))
      (let c8 (lgrb-hit (and (eq (nth (nth past-mask 0) 2) 1)
                              (and (eq (nth (nth past-mask 1) 2) 1)
                                   (and (eq (nth (nth past-mask 2) 2) 0)
                                        (eq (nth (nth past-mask 4) 2) 0)))) 256))
      (let c9 (lgrb-hit (and (eq (len out4) 22) (eq (len (head out4)) 4)) 512))
      (let c10 (lgrb-hit (lgrb-any-different out4 out-no-traj 0.000001) 1024))
      (let c11 (lgrb-hit (lgrb-vclose (head (lgr-entry-keys anchor0))
                                      (head (lgr-entry-keys anchor4)) 0.000000000001) 2048))
      (let c12 (lgrb-hit (and (eq (len (lgr-entry-keys (head (lgr-trajectory s4)))) 6)
                                (eq (len (lgr-entry-keys (head (lgr-window s4)))) 22)) 4096))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6
        (add c7 (add c8 (add c9 (add c10 (add c11 c12))))))))))))))
  (lingbot-gca-runtime-band))
