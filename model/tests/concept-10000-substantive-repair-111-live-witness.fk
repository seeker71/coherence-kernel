; Literal bounded live samples: canonical/NL labels plus rejected false aliases.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000-substantive-repair-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk model/concept-semantics-10000-wiktionary-lexical.fk model/concept-semantics-10000-wiktionary-lexical-audit.fk cognition/concept-10000-substantive-repair-111-nl-data.fk cognition/concept-10000-substantive-repair-111-nl.fk
(do
  (defn csr111-witness-bytes-go (s i)
    (if (eq i (str_len s)) (empty)
      (cons (str_byte_at s i) (csr111-witness-bytes-go s (add i 1)))))
  (defn csr111-witness-bytes (s) (csr111-witness-bytes-go s 0))
  (defn csr111-witness-row (ranked canonical repair-index repair-payload nl text code)
    (do (let concept (c10-detect-text-in ranked canonical text))
        (let id (c10-concept-id concept))
        (let semantic (cs10l-repair-at-in ranked repair-index repair-payload id))
        (let label (csr111-nl-open-generate nl id code))
        (list id (csr111-witness-bytes (c10-concept-label concept))
          (c10-concept-rank concept) (c10-concept-frequency concept)
          (csr111-witness-bytes (cs10l-method-label semantic))
          (csr111-witness-bytes (cs10-pos semantic))
          (csr111-witness-bytes (cs10-gloss semantic)) code
          (csr111-witness-bytes label))))
  (let ranked (read_file (c10-ranked-path)))
  (let canonical (read_file (c10-lexical-index-path)))
  (let aliases (read_file (csr111-alias-index-path)))
  (let repair-index (read_file (csr111-semantic-index-path)))
  (let repair-payload (read_file (csr111-semantic-payload-path)))
  (let nl (csr111-nl-open))
  (list
    (csr111-witness-row ranked canonical repair-index repair-payload nl "welcoming" "id")
    (csr111-witness-row ranked canonical repair-index repair-payload nl "plum" "ja")
    (list "rejected-false-semantic-aliases"
      (c10-missing? (c10-detect-text-in ranked canonical "didn"))
      (c10-missing? (c10-detect-text-in ranked canonical "yöu"))
      (c10-missing? (c10-detect-text-in ranked canonical "waitin")))
    (cs10l-substantive-completion-audit)
    (list 111 1443 (file_size (csr111-nl-data-path))
      (file_size (csr111-nl-sources-path))))
)
