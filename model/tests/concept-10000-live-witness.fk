; concept-10000-live-witness.fk — full-corpus cardinality and detection evidence.
; Labels emit as UTF-8 byte lists because direct-source result printing exposes
; intern ids for nested strings; the bytes keep the evidence literal.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk
(do
  (defn c10-live-bytes-go (s i)
    (if (eq i (str_len s)) (empty)
      (cons (str_byte_at s i) (c10-live-bytes-go s (add i 1)))))
  (defn c10-live-bytes (s) (c10-live-bytes-go s 0))
  (defn c10-live-row (id)
    (do (let c (c10-concept-at id))
        (list (c10-concept-id c) (c10-live-bytes (c10-concept-label c))
              (c10-concept-rank c) (c10-concept-frequency c)
              (c10-concept-features c))))
  (defn c10-live-token-evidence ()
    (do (let found
          (c10-detect-tokens (list "love" "world" "camera" "coherence-kernel")))
        (list (c10-concept-id (nth found 0))
              (c10-concept-id (nth found 1))
              (c10-concept-id (nth found 2))
              (c10-missing? (nth found 3)))))
  (defn c10-live-feature-evidence ()
    (do (let camera (c10-concept-at 959))
        (c10-concept-id
          (c10-detect-features (c10-concept-features camera)))))
  (list
    (list (file_size (c10-ranked-path)) (c10-source-count))
    (list (file_size (c10-lexical-index-path)) (c10-index-count))
    (c10-live-row 0)
    (c10-live-row 122)
    (c10-live-row 227)
    (c10-live-row 959)
    (c10-live-row 9999)
    (c10-live-token-evidence)
    (c10-live-feature-evidence))
)
