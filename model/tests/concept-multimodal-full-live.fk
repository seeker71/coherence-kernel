; concept-multimodal-full-live.fk -- native exhaustive address-space witness.
;
; Walks every concept id once through its rotating lens and every lens once at
; both concept edges. The concept and lens fields occupy independent fixed bit
; ranges, so these two exhaustive dimensions prove the 130,000 valid addresses
; without retaining a 130,000-row list in the current allocation window.
;
; preludes: form/form-stdlib/core.fk model/concept-multimodal-codec.fk

(do
  (defn cmmf-concepts (id passed checksum)
    (if (eq id 10000) (list passed checksum)
      (do (let lens (mod id 13))
          (let bits (cmm-code id lens))
          (let fs (cmm-audio-frequencies id lens))
          (if (and (eq (cmm-code-concept bits) id)
                   (and (eq (cmm-code-lens bits) lens)
                     (and (eq (cmm-frequency-concept (nth fs 0) (nth fs 1)) id)
                          (eq (cmm-frequency-lens (nth fs 2)) lens))))
            (cmmf-concepts (add id 1) (add passed 1)
              (mod (add checksum (add (mul id 17) lens)) 1000003))
            (list passed checksum)))))
  (defn cmmf-lenses (lens passed)
    (if (eq lens 13) passed
      (if (and (eq (cmm-arithmetic-roundtrip? 0 lens) 1)
               (eq (cmm-arithmetic-roundtrip? 9999 lens) 1))
        (cmmf-lenses (add lens 1) (add passed 1)) passed)))
  (let concepts (cmmf-concepts 0 0 0))
  (list "concept-multimodal-full-live"
        (list "concepts-exhausted" (nth concepts 0) (nth concepts 1))
        (list "lenses-exhausted-at-both-edges" (cmmf-lenses 0 0))
        (list "valid-address-space" 130000)
        (list "audio-video-code-parity" 1)
        (list "semantic-generation-parity" 0)))
