; concept-video-open-label.fk -- generic pretrained-label to top-10k bridge.
;
; Apple's carrier emits confidence<TAB>label rows. The complete English 10k
; text detector finds every aligned concept whose surface occurs in those raw
; rows. This organ recovers each candidate's exact carrier confidence, rejects
; substring-only accidents, and preserves every candidate above an explicit
; visual floor. It does not contain a closed visual vocabulary or choose a
; fixture's expected answer.
;
; witnessed: 2026-07-18 -> pure parser/filter band
; preludes: form/form-stdlib/core.fk cognition/concept-text-detection-13.fk

(do
  (defn cvol-line-start-go (raw target cursor start)
    (do (let next (str_find raw "\n" cursor))
        (if (or (lt next 0) (ge next target)) start
          (cvol-line-start-go raw target (add next 1) (add next 1)))))
  (defn cvol-confidence (raw label)
    (do (let tab (str_find raw (str_concat "\t" (str_concat label "\n")) 0))
        (if (lt tab 0) 0
          (str_to_int (substring raw (cvol-line-start-go raw tab 0 0) tab)))))

  ; observation row = concept id, English surface, carrier confidence ppm,
  ; text score, source code, anchor, primary synset, primary gloss.
  (defn cvol-row (raw candidate)
    (list (ctd13-candidate-id candidate)
      (ctd13-candidate-surface candidate)
      (cvol-confidence raw (ctd13-candidate-surface candidate))
      (ctd13-candidate-score candidate)
      (ctd13-candidate-source-code candidate)
      (ctd13-candidate-anchor candidate)
      (ctd13-candidate-primary-synset candidate)
      (ctd13-candidate-primary-gloss candidate)))
  (defn cvol-observations-go (raw candidates floor out)
    (if (eq (len candidates) 0) (reverse out)
      (do (let row (cvol-row raw (head candidates)))
          (cvol-observations-go raw (tail candidates) floor
            (if (ge (nth row 2) floor) (cons row out) out)))))
  (defn cvol-observations (raw candidates floor)
    (cvol-observations-go raw candidates floor (empty)))
  (defn cvol-find-id (rows id)
    (if (eq (len rows) 0) (empty)
      (if (eq (nth (head rows) 0) id) (head rows)
        (cvol-find-id (tail rows) id))))
  (defn cvol-target-present? (rows id)
    (if (eq (len (cvol-find-id rows id)) 0) 0 1))
)
