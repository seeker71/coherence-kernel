; whisper-tiny-native-frontend-full-row-major.fk -- full 35-token encoder lane.
;
; Composes the complete valid-STFT frontend with the exact row-major affine
; reuse cell.  Every released encoder block still executes in Form over the
; pinned released f32 carriers; only the affine loop nest changes.  The final
; tensor remains available to the native decoder/generation cells.  This cell
; does not call generation and cannot claim recognition by itself.
; witnessed: 2026-07-20 -> complete 35x384 released encoder over real speech
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-affine-row-major.fk

(do
  (defn wafrf-encoder-file (path)
    (do
      (let frontend (wtf-frontend-file path))
      (let pack0 (wte0-load))
      (let pack13 (wte-load))
      (let conv2 (nth frontend 20))
      (let positioned (if (gt (len conv2) 0)
        (wtf-position (wte0-carrier pack0) conv2) (empty)))
      (let out0 (if (gt (len positioned) 0)
        (wafr-layer0 (wte0-carrier pack0) positioned) (empty)))
      (let out1 (if (gt (len out0) 0)
        (wafr-layer (wte-carrier pack13) 0 out0) (empty)))
      (let out2 (if (gt (len out1) 0)
        (wafr-layer (wte-carrier pack13) (wte-layer-byte-count) out1) (empty)))
      (let out3 (if (gt (len out2) 0)
        (wafr-layer (wte-carrier pack13) (mul 2 (wte-layer-byte-count)) out2)
        (empty)))
      (let final (if (gt (len out3) 0)
        (wte0-layernorm-seq (wte0-carrier pack0)
          (wte0-encoder-ln-weight-off) (wte0-encoder-ln-bias-off) out3)
        (empty)))
      (list "whisper-tiny-native-full-row-major-encoder" path
        "samples" (nth frontend 4)
        "valid-mel-columns" (nth frontend 5)
        "conv2-tokens" (len conv2)
        "positioned" (len positioned)
        "layer0" (len out0) "layer1" (len out1)
        "layer2" (len out2) "layer3" (len out3)
        "final-tokens" (len final)
        "width" (if (gt (len final) 0) (len (head final)) 0)
        "weights-valid" (if (and (eq (nth frontend 10) 1)
          (and (eq (wte0-valid? pack0) 1) (eq (wte-valid? pack13) 1))) 1 0)
        "native-encoder-complete" (if (and (eq (len final) 35)
          (eq (len (head final)) 384)) 1 0)
        "fingerprints" (if (gt (len final) 0)
          (list (wtf-three-fingerprints out0) (wtf-three-fingerprints out1)
            (wtf-three-fingerprints out2) (wtf-three-fingerprints out3)
            (wtf-three-fingerprints final)) (empty))
        "native-recognizer" 0
        "remaining" "decoder+generation+truth-match-over-this-complete-encoder"
        "encoder" final)))

  (defn wafrf-encoder-output (result) (nth result 33))
  0)
