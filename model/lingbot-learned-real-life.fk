; lingbot-learned-real-life.fk — four-place learned visual execution.
;
; One original-resolution frame from each released LingBot-Map example video
; passes through the complete authentic 1024-channel DINOv2-L/14 patch
; projection. ffmpeg is only the video codec carrier; BMP/RGB normalization and
; every learned multiply-add are owned by Form.
; witnessed: 2026-07-18 -> four full learned tokens, scene-distinct
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/lingbot-vision-input.fk model/lingbot-learned-patch.fk

(do
  (defn llrl-frame (video output-pattern output-path)
    (do
      (let frames (lvi-load-video-file video output-pattern (list output-path)))
      (if (eq (len frames) 1) (head frames) (empty))))

  (defn llrl-loop-frame ()
    (llrl-frame
      "model/fixtures/lingbot-map/real-life/loop-24f.mkv"
      "/tmp/lingbot-learned-loop-%06d.bmp"
      "/tmp/lingbot-learned-loop-000001.bmp"))
  (defn llrl-oxford-frame ()
    (llrl-frame
      "model/fixtures/lingbot-map/real-life/oxford-24f.mkv"
      "/tmp/lingbot-learned-oxford-%06d.bmp"
      "/tmp/lingbot-learned-oxford-000001.bmp"))
  (defn llrl-university-frame ()
    (llrl-frame
      "model/fixtures/lingbot-map/real-life/university-24f.mkv"
      "/tmp/lingbot-learned-university-%06d.bmp"
      "/tmp/lingbot-learned-university-000001.bmp"))
  (defn llrl-courthouse-frame ()
    (llrl-frame
      "model/fixtures/lingbot-map/real-life/courthouse-24f.mkv"
      "/tmp/lingbot-learned-courthouse-%06d.bmp"
      "/tmp/lingbot-learned-courthouse-000001.bmp"))

  ; run = (tag learned-weight-receipt scene-rows cross-scene-L1).
  (defn llrl-run ()
    (do
      (let pack (llp-load-weights))
      (let loop-row (llp-infer-center "loop" (llrl-loop-frame) pack))
      (let oxford-row (llp-infer-center "oxford" (llrl-oxford-frame) pack))
      (let university-row
        (llp-infer-center "university" (llrl-university-frame) pack))
      (let courthouse-row
        (llp-infer-center "courthouse" (llrl-courthouse-frame) pack))
      (let rows (list loop-row oxford-row university-row courthouse-row))
      (let tokens (list (nth loop-row 6) (nth oxford-row 6)
                         (nth university-row 6) (nth courthouse-row 6)))
      (list
        "lingbot-learned-real-life"
        (list
          (llp-weights-valid? pack)
          (lbpt-entry-name (llp-weight-entry pack))
          (lbpt-entry-size (llp-weight-entry pack))
          (lbpt-entry-crc (llp-weight-entry pack))
          (lbpt-entry-name (llp-bias-entry pack))
          (lbpt-entry-size (llp-bias-entry pack))
          (lbpt-entry-crc (llp-bias-entry pack))
          (llp-weight-count) (llp-output-channels))
        rows
        (list
          (llp-vector-l1 (nth tokens 0) (nth tokens 1))
          (llp-vector-l1 (nth tokens 0) (nth tokens 2))
          (llp-vector-l1 (nth tokens 0) (nth tokens 3))))))

  (defn llrl-weight-receipt (run) (nth run 1))
  (defn llrl-rows (run) (nth run 2))
  (defn llrl-distances (run) (nth run 3))

  (defn llrl-row-summary (row)
    (list (nth row 0) (nth row 1) (nth row 2) (nth row 3) (nth row 4)
          (nth row 5) (len (nth row 6)) (nth row 7)))
  (defn llrl-row-summaries (rows)
    (if (eq (len rows) 0) (empty)
      (cons (llrl-row-summary (head rows)) (llrl-row-summaries (tail rows)))))
  (defn llrl-summary (run)
    (list (head run) (llrl-weight-receipt run)
          (llrl-row-summaries (llrl-rows run)) (llrl-distances run)))
)
