  (defn cah13-id (f) (nth f 0))
  (defn cah13-code (f) (nth f 1))
  (defn cah13-transcription (f) (nth f 2))
  (defn cah13-speaker (f) (nth f 3))
  (defn cah13-recorded (f) (nth f 4))
  (defn cah13-license (f) (nth f 5))
  (defn cah13-media-id (f) (nth f 6))
  (defn cah13-url (f) (nth f 7))
  (defn cah13-page (f) (nth f 8))
  (defn cah13-sha1 (f) (nth f 9))
  (defn cah13-sha256 (f) (nth f 10))
  (defn cah13-bytes (f) (nth f 11))
  (defn cah13-duration-ms (f) (nth f 12))

  (defn cah13-member? (xs value)
    (if (eq (len xs) 0) 0
      (if (str_eq (head xs) value) 1
        (cah13-member? (tail xs) value))))
  (defn cah13-distinct-field-go (fs field seen)
    (if (eq (len fs) 0) 1
      (do
        (let f (head fs))
        (let value (if (eq field 0) (int_to_str (cah13-id f)) (nth f field)))
        (if (eq (cah13-member? seen value) 1) 0
          (cah13-distinct-field-go (tail fs) field (cons value seen))))))
  (defn cah13-complete-meta-go (fs)
    (if (eq (len fs) 0) 1
      (do
        (let f (head fs))
        (if (and (gt (str_len (cah13-transcription f)) 0)
              (and (gt (str_len (cah13-speaker f)) 0)
                (and (gt (str_len (cah13-recorded f)) 0)
                  (and (gt (str_len (cah13-media-id f)) 1)
                    (and (gt (str_len (cah13-page f)) 30)
                      (and (eq (str_len (cah13-sha1 f)) 40)
                        (and (eq (str_len (cah13-sha256 f)) 64)
                          (and (gt (cah13-bytes f) 60000)
                            (gt (cah13-duration-ms f) 500)))))))))
          (cah13-complete-meta-go (tail fs)) 0))))
  (defn cah13-licenses-open-go (fs)
    (if (eq (len fs) 0) 1
      (if (or (str_eq (cah13-license (head fs)) "CC0")
              (str_eq (cah13-license (head fs)) "CC BY-SA 4.0"))
        (cah13-licenses-open-go (tail fs)) 0)))

  (defn cah13-contract ()
    (list "concept-audio-human-13-contract"
      (list "source" "Wikimedia-Commons/Lingua-Libre" "human-recorded" 1)
      (list "domain" "locales" 13 "concepts" 13 "speakers" 13)
      (list "detection" "neutral-numeric-file->unprompted-whisper->complete-form-10000")
      (list "world" "admit-detected-id-only-through-cwm-persist")
      (list "forbidden" "tts" "transcription-prompt" "label-filename"
        "closed-candidates" "expected-id-injection")))
  (defn cah13-contract-verdict ()
    (do
      (let fs (cah13-fixtures))
      (add
        (if (eq (len fs) 13) 1 0)
        (add (if (eq (cah13-distinct-field-go fs 0 (empty)) 1) 2 0)
          (add (if (eq (cah13-distinct-field-go fs 1 (empty)) 1) 4 0)
            (add (if (eq (cah13-distinct-field-go fs 3 (empty)) 1) 8 0)
              (add (if (eq (cah13-licenses-open-go fs) 1) 16 0)
                (add (if (eq (cah13-complete-meta-go fs) 1) 32 0)
                  (if (and (str_eq (cah13-code (head fs)) "en")
                           (str_eq (cah13-code (nth fs 12)) "tr")) 64 0))))))))
)
