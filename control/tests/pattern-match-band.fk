; preludes: control/pattern-match.fk
;
; pattern-match-band — STONE S10 WITNESSED. Pattern matching / destructuring over
; composed cells, each claim an instance of the ONE recipe (pm-match over DATA
; clauses), none a hardcoded branch.
;
; The strange-minimal edge that pins the whole shape: the SAME clause list, offered
; two different cells, must (a) pick the RIGHT branch with the RIGHT bindings for a
; cell that fits, and (b) acknowledge NOTHING for a cell that fits none — match and
; no-match are the two acks of one offer (axiom-5), and the no-match silence is the
; first-class nothing (axiom-1), not a 0.
;
; THE CELLS (axiom-2 composition; ctor in slot 0, children after):
;   (pair 3 4)  = (list 7 3 4)   ctor 7, children 3 4
;   (lit  9)    = (list 5 9)     ctor 5, child 9
;   (triple ..) = (list 8 1 2 3) ctor 8, arity 3  — fits NEITHER clause below
;
; THE CLAUSES (data): match a pair → a+b (destructure both holes, add); match a
;   lit → its single child. A triple matches neither → nothing.
;     clause-pair = (list 7 2 (list 2 (list 0 0) (list 0 1)))  ; ctor 7, arity 2, hole0 + hole1
;     clause-lit  = (list 5 1 (list 0 0))                      ; ctor 5, arity 1, hole0
;
; Verdict 511 when every claim lands (each a distinct power of two). EVERY claim
; here crosses FOUR-WAY — the band uses only the pure-list cell surface all four
; kernels carry (the no-match arm is read as a four-way SCALAR via pm-found? /
; pm-match-or, not the canonical-nothing op). The canonical-nothing contract of
; pm-match itself (axiom-1) is fkwu-native and witnessed separately — see the
; receipt's "native nothing arm" — because the pure-list walkers carry the cell
; surface but not the canonical-nothing op (a known op-family edge, never a
; divergence: no kernel computes a DIFFERENT match).
;   1    pm-fits? is structural: the pair-pattern fits (pair 3 4), arity-checked
;   2    destructure (pair 3 4) → bind a=3,b=4 → a+b = 7 (THE spec example)
;   4    the SAME clauses pick the OTHER branch for a lit: (lit 9) → 9
;   8    a non-matching cell (triple) → pm-found? = 0 (which-ack: no clause)
;   16   the miss is the FIRST-class ground: pm-found? distinguishes it from a
;        matched 0 — (lit 0) matches (found=1) while triple misses (found=0)
;   32   pm-match-or carries the miss as a four-way scalar: triple → default -1
;   64   clause ORDER decides: a cell fitting two clauses takes the FIRST
;   128  an empty clause list never matches: pm-found? = 0 (the ground)
;   256  a single hole reads the right child: destructure (lit 9) → 9 (axiom-2)
(do
    ;; --- the cells (axiom-2): ctor-tag in slot 0, children after ------------
    (defn pair   (a b)   (list 7 a b))
    (defn lit    (v)     (list 5 v))
    (defn triple (a b c) (list 8 a b c))

    ;; --- the clauses as DATA -----------------------------------------------
    ;; built through defn params (the --src seed runs these; a bare (let x (list..))
    ;; would not — the honest seed floor, faithful to the recipe shape).
    (defn clause-pair () (list 7 2 (list 2 (list 0 0) (list 0 1))))
    (defn clause-lit  () (list 5 1 (list 0 0)))
    (defn clauses     () (list (clause-pair) (clause-lit)))

    ;; (1) pm-fits? is STRUCTURAL — the pair pattern (ctor 7, arity 2) fits a pair.
    (defn k1 () (if (eq (pm-fits? (pair 3 4) 7 2) 1) 1 0))

    ;; (2) DESTRUCTURE the spec example: (pair 3 4) → a=3,b=4 → a+b = 7.
    (defn k2 () (if (eq (pm-match (pair 3 4) (clauses)) 7) 2 0))

    ;; (3) the SAME clauses pick the OTHER branch for a lit: (lit 9) → 9.
    (defn k3 () (if (eq (pm-match (lit 9) (clauses)) 9) 4 0))

    ;; (4) a non-matching cell (triple, arity 3) → no clause: pm-found? = 0.
    (defn k4 () (if (eq (pm-found? (triple 1 2 3) (clauses)) 0) 8 0))

    ;; (5) the MISS is the first-class ground, distinct from a matched 0: pm-found?
    ;; reads 1 for (lit 0) (a real match whose value is 0) and 0 for triple (no
    ;; clause). Absence is never a 0 masquerading as a value (axiom-1) — and this
    ;; reads as a four-way scalar (no canonical-nothing op needed).
    (defn k5 () (if (and (eq (pm-found? (lit 0) (clauses)) 1)
                         (eq (pm-found? (triple 1 2 3) (clauses)) 0)) 16 0))

    ;; (6) pm-match-or carries the miss as a four-way SCALAR: triple → default -1.
    (defn k6 () (if (eq (pm-match-or (triple 1 2 3) (clauses) -1) -1) 32 0))

    ;; (7) clause ORDER: a cell fitting two clauses takes the FIRST. A pair offered
    ;; (clause-pair, clause-pair') where the first adds and the second would give a
    ;; literal 99 — the FIRST (add → 7) wins, proving first-match, not last.
    (defn clause-pair2 () (list 7 2 (list 1 99)))
    (defn k7 () (if (eq (pm-match (pair 3 4) (list (clause-pair) (clause-pair2))) 7) 64 0))

    ;; (8) an empty clause list never matches: pm-found? = 0 (the ground).
    (defn k8 () (if (eq (pm-found? (pair 3 4) (list)) 0) 128 0))

    ;; (9) a single hole reads the RIGHT child: destructure (lit 9) → hole0 → 9.
    (defn k9 () (if (eq (pm-tmpl-eval (lit 9) (list 0 0)) 9) 256 0))

    (add (k1) (add (k2) (add (k3) (add (k4) (add (k5) (add (k6) (add (k7) (add (k8) (k9))))))))))
