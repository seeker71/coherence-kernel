; reason-coverage.fk -- explicit reason-manifest coverage for bands.
;
; This layer compares an explicit expected reason list with observed reason
; values produced by a band. It is not reflection, test generation, execution,
; file IO, or dynamic evaluation.
;
; preludes: form-stdlib/core.fk

(do
    (defn rcov-feature (name status) (list "reason-coverage-feature" name status))
    (defn rcov-feature-name (f) (nth f 1))
    (defn rcov-feature-status (f) (nth f 2))
    (defn reason-coverage-manifest ()
        (list
            (rcov-feature "pure-list-coverage" 1)
            (rcov-feature "explicit-reason-manifest-not-reflection" 1)
            (rcov-feature "missing-reason-detection" 1)
            (rcov-feature "unexpected-reason-detection" 1)
            (rcov-feature "duplicate-observed-diagnostic" 1)
            (rcov-feature "duplicate-expected-failure" 1)
            (rcov-feature "deterministic-status-precedence" 1)
            (rcov-feature "covered-predicate-no-missing-unexpected" 1)
            (rcov-feature "duplicate-observed-does-not-fail-covered" 1)
            (rcov-feature "self-status-coverage" 1)
            (rcov-feature "applies-to-layer-branches" 1)
            (rcov-feature "observed-from-real-invocations" 1)
            (rcov-feature "no-file-io" 1)
            (rcov-feature "no-dynamic-eval" 1)
            (rcov-feature "no-runtime-execution" 1)
            (rcov-feature "no-c-seed-growth" 1)))
    (defn reason-coverage-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rcov-feature-name (head fs)) name)
                     (eq (rcov-feature-status (head fs)) 1))
                1
                (reason-coverage-manifest-has? name (tail fs)))))

    (defn rcov-status-covered () "covered")
    (defn rcov-status-missing () "missing")
    (defn rcov-status-unexpected () "unexpected")
    (defn rcov-status-duplicate-expected () "duplicate-expected")
    (defn rcov-status-duplicate-observed () "duplicate-observed")

    (defn rcov-member? (x xs)
        (if (nil? xs)
            0
            (if (str_eq x (head xs)) 1 (rcov-member? x (tail xs)))))
    (defn rcov-count (x xs)
        (if (nil? xs)
            0
            (add (if (str_eq x (head xs)) 1 0)
                 (rcov-count x (tail xs)))))
    (defn rcov-missing (expected observed)
        (if (nil? expected)
            (empty)
            (if (rcov-member? (head expected) observed)
                (rcov-missing (tail expected) observed)
                (cons (head expected) (rcov-missing (tail expected) observed)))))
    (defn rcov-unexpected (expected observed)
        (if (nil? observed)
            (empty)
            (if (rcov-member? (head observed) expected)
                (rcov-unexpected expected (tail observed))
                (cons (head observed) (rcov-unexpected expected (tail observed))))))
    (defn rcov-duplicates-loop (xs seen dupes)
        (if (nil? xs)
            dupes
            (if (rcov-member? (head xs) seen)
                (if (rcov-member? (head xs) dupes)
                    (rcov-duplicates-loop (tail xs) seen dupes)
                    (rcov-duplicates-loop (tail xs) seen (cons (head xs) dupes)))
                (rcov-duplicates-loop (tail xs) (cons (head xs) seen) dupes))))
    (defn rcov-duplicates (xs)
        (rcov-duplicates-loop xs (empty) (empty)))
    (defn rcov-empty? (xs) (nil? xs))

    (defn rcov-status-from (missing unexpected duplicate-expected duplicate-observed)
        (if (not (rcov-empty? missing))
            (rcov-status-missing)
            (if (not (rcov-empty? unexpected))
                (rcov-status-unexpected)
                (if (not (rcov-empty? duplicate-expected))
                    (rcov-status-duplicate-expected)
                    (if (not (rcov-empty? duplicate-observed))
                        (rcov-status-duplicate-observed)
                        (rcov-status-covered))))))

    ; coverage = ("reason-coverage" expected observed missing unexpected
    ;             duplicate-expected duplicate-observed status)
    (defn rcov-coverage (expected observed)
        (do
            (let missing (rcov-missing expected observed))
            (let unexpected (rcov-unexpected expected observed))
            (let duplicate-expected (rcov-duplicates expected))
            (let duplicate-observed (rcov-duplicates observed))
            (list "reason-coverage"
                  expected
                  observed
                  missing
                  unexpected
                  duplicate-expected
                  duplicate-observed
                  (rcov-status-from missing unexpected duplicate-expected duplicate-observed))))
    (defn rcov-coverage? (c)
        (if (eq (len c) 8)
            (str_eq (nth c 0) "reason-coverage")
            0))
    (defn rcov-expected (c) (nth c 1))
    (defn rcov-observed (c) (nth c 2))
    (defn rcov-missing-list (c) (nth c 3))
    (defn rcov-unexpected-list (c) (nth c 4))
    (defn rcov-duplicate-expected-list (c) (nth c 5))
    (defn rcov-duplicate-observed-list (c) (nth c 6))
    (defn rcov-status (c) (nth c 7))
    ; Consumers should gate on this predicate, not status equality: duplicate
    ; observed reasons are diagnostic-only and may leave the row still covered.
    (defn rcov-covered? (c)
        (if (rcov-coverage? c)
            (if (rcov-empty? (rcov-missing-list c))
                (if (rcov-empty? (rcov-unexpected-list c))
                    (rcov-empty? (rcov-duplicate-expected-list c))
                    0)
                0)
            0))
)
