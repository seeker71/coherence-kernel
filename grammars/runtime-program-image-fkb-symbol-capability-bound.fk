; runtime-program-image-fkb-symbol-capability-bound.fk -- Layer 9h7 capability-bound computed symbol walk.
;
; Layer 9h7 binds genuine 9g program-image-walker readiness to the computed
; Layer 9h6 symbol walk. It does not accept a supplied 9h6 receipt or an
; independent trace as authority. The single runtime entry point recomputes
; `rpsw-walk-symbol` from envelope, admission, symbol request, budget, and input
; after proving the 9g readiness row. Only that recomputed walk can expose a
; capability-bound trace.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/runtime-artifact-executor-capability.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-fkb-byte-container.fk
;           form-stdlib/program-image-fkb-byte-file-witness.fk
;           form-stdlib/program-image-fkb-byte-decode.fk
;           form-stdlib/program-image-symbol-entry.fk
;           form-stdlib/runtime-program-image-fkb-walker-trace.fk
;           form-stdlib/runtime-program-image-fkb-micro-walker.fk
;           form-stdlib/runtime-program-image-fkb-symbol-walk.fk

(do
    (defn rpswc-version () "runtime-program-image-fkb-symbol-capability-bound-v1")

    (defn rpswc-feature (name status) (list "runtime-program-image-fkb-symbol-capability-bound-feature" name status))
    (defn rpswc-feature-name (f) (nth f 1))
    (defn rpswc-feature-status (f) (nth f 2))
    (defn runtime-program-image-fkb-symbol-capability-bound-manifest ()
        (list
            (rpswc-feature "layer-9h7-capability-bound-computed-symbol-walk" 1)
            (rpswc-feature "binds-9g-readiness-to-computed-9h6-symbol-walk" 1)
            (rpswc-feature "single-public-bind-entry-recomputes-9h6" 1)
            (rpswc-feature "no-supplied-rpsw-receipt-authority" 1)
            (rpswc-feature "no-independent-trace-input" 1)
            (rpswc-feature "envelope-must-be-program-image-fkb" 1)
            (rpswc-feature "readiness-row-shape-required" 1)
            (rpswc-feature "ready-status-alone-not-trusted" 1)
            (rpswc-feature "capability-ready-reason-required" 1)
            (rpswc-feature "supplied-current-evidence-required" 1)
            (rpswc-feature "attempt-supplier-authority-required" 1)
            (rpswc-feature "current-freshness-required" 1)
            (rpswc-feature "program-image-walker-required" 1)
            (rpswc-feature "nested-capability-revalidated" 1)
            (rpswc-feature "readiness-recomputed-from-capability" 1)
            (rpswc-feature "symbol-walk-agreement-required" 1)
            (rpswc-feature "trace-exposed-only-after-capability-and-computed-walk" 1)
            (rpswc-feature "non-ready-readiness-produces-no-bound-trace" 1)
            (rpswc-feature "non-produced-symbol-walk-preserved" 1)
            (rpswc-feature "forged-readiness-produces-no-bound-trace" 1)
            (rpswc-feature "no-9h1-9h2-9h3-9h4-consumption" 1)
            (rpswc-feature "no-attempt-or-observation-production" 1)
            (rpswc-feature "no-raw-entry-runtime-api" 1)
            (rpswc-feature "no-supplied-run-or-trace-input" 1)
            (rpswc-feature "no-table-payload-authority" 1)
            (rpswc-feature "no-presentation-lens-authority" 1)
            (rpswc-feature "no-artifact-io" 1)
            (rpswc-feature "no-generated-table-authority" 1)
            (rpswc-feature "no-selector-storage-or-champion-mutation" 1)
            (rpswc-feature "no-c-seed-growth" 1)))
    (defn runtime-program-image-fkb-symbol-capability-bound-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rpswc-feature-name (head fs)) name)
                     (eq (rpswc-feature-status (head fs)) 1))
                1
                (runtime-program-image-fkb-symbol-capability-bound-manifest-has? name (tail fs)))))

    (defn rpswc-status-bound () "capability-bound-trace")
    (defn rpswc-status-unavailable () "unavailable")
    (defn rpswc-status-investigate () "investigate")
    (defn rpswc-status-refused () "refused")

    (defn rpswc-reason-malformed-envelope () "malformed-envelope")
    (defn rpswc-reason-non-program-image-envelope () "non-program-image-envelope")
    (defn rpswc-reason-malformed-readiness () "malformed-readiness")
    (defn rpswc-reason-readiness-envelope-identity-mismatch () "readiness-envelope-identity-mismatch")
    (defn rpswc-reason-readiness-field-mismatch () "readiness-field-mismatch")
    (defn rpswc-reason-readiness-ready-fields-forged () "readiness-ready-fields-forged")
    (defn rpswc-reason-malformed-capability () "malformed-capability")
    (defn rpswc-reason-nested-capability-mismatch () "nested-capability-mismatch")
    (defn rpswc-reason-nested-capability-evidence-mismatch () "nested-capability-evidence-mismatch")
    (defn rpswc-reason-recomputed-readiness-mismatch () "recomputed-readiness-mismatch")
    (defn rpswc-reason-malformed-symbol-walk () "malformed-symbol-walk")
    (defn rpswc-reason-symbol-walk-envelope-mismatch () "symbol-walk-envelope-mismatch")
    (defn rpswc-reason-symbol-walk-agreement-mismatch () "symbol-walk-agreement-mismatch")
    (defn rpswc-reason-malformed-bound-trace () "malformed-bound-trace")
    (defn rpswc-reason-manifest ()
        (list
            (rpswc-reason-malformed-envelope)
            (rpswc-reason-non-program-image-envelope)
            (rpswc-reason-malformed-readiness)
            (rpswc-reason-readiness-envelope-identity-mismatch)
            (rpswc-reason-readiness-field-mismatch)
            (rpswc-reason-readiness-ready-fields-forged)
            (rpswc-reason-malformed-capability)
            (rpswc-reason-nested-capability-mismatch)
            (rpswc-reason-nested-capability-evidence-mismatch)
            (rpswc-reason-recomputed-readiness-mismatch)
            (rpswc-reason-malformed-symbol-walk)
            (rpswc-reason-symbol-walk-envelope-mismatch)
            (rpswc-reason-symbol-walk-agreement-mismatch)
            (rpswc-reason-malformed-bound-trace)
            (raec-reason-no-capability-supplied)
            (raec-reason-capability-unavailable)
            (raec-reason-capability-stale)
            (raec-reason-evidence-inadequate)
            (raec-reason-forbidden-authority)
            (rpsw-reason-diagnostic-node-not-runtime-request)
            (pise-reason-canonical-key-not-found)
            (rpmw-reason-walk-completed)
            (rpmw-reason-step-budget-exhausted)
            (rpmw-reason-unsupported-tag)
            (rpmw-reason-negative-step-budget)))

    (defn rpswc-no-symbol-walk () (list "runtime-program-image-fkb-symbol-capability-bound-no-symbol-walk"))
    (defn rpswc-no-symbol-walk? (r)
        (if (eq (len r) 1)
            (str_eq (nth r 0) "runtime-program-image-fkb-symbol-capability-bound-no-symbol-walk")
            0))
    (defn rpswc-no-bound-trace () (list "runtime-program-image-fkb-symbol-capability-bound-no-bound-trace"))
    (defn rpswc-no-bound-trace? (t)
        (if (eq (len t) 1)
            (str_eq (nth t 0) "runtime-program-image-fkb-symbol-capability-bound-no-bound-trace")
            0))

    ; join = ("runtime-program-image-fkb-symbol-capability-bound" envelope
    ;         readiness admission symbol-request step-budget input-value
    ;         symbol-walk bound-trace status reason)
    (defn rpswc-join? (j)
        (if (eq (len j) 11)
            (str_eq (nth j 0) "runtime-program-image-fkb-symbol-capability-bound")
            0))
    (defn rpswc-join-envelope (j) (nth j 1))
    (defn rpswc-join-readiness (j) (nth j 2))
    (defn rpswc-join-admission (j) (nth j 3))
    (defn rpswc-join-symbol-request (j) (nth j 4))
    (defn rpswc-join-step-budget (j) (nth j 5))
    (defn rpswc-join-input-value (j) (nth j 6))
    (defn rpswc-join-symbol-walk (j) (nth j 7))
    (defn rpswc-join-bound-trace (j) (nth j 8))
    (defn rpswc-join-status (j) (nth j 9))
    (defn rpswc-join-reason (j) (nth j 10))

    (defn rpswc-program-image-envelope? (envelope)
        (rpmw-program-image-envelope? envelope))
    (defn rpswc-envelope-identity-matches? (expected actual)
        (rpsw-envelope-identity-matches? expected actual))
    (defn rpswc-readiness-envelope-matches? (envelope readiness)
        (rpswc-envelope-identity-matches? envelope (raec-readiness-envelope readiness)))
    (defn rpswc-readiness-fields-match-envelope? (envelope readiness)
        (and (str_eq (raec-readiness-action readiness) (rale-envelope-action envelope))
        (and (eq (raec-readiness-route readiness) (rale-envelope-route envelope))
        (and (str_eq (raec-readiness-artifact-kind readiness) (rale-envelope-artifact-kind envelope))
             (str_eq (raec-readiness-required-capability readiness) (raec-cap-program-image-walker))))))
    (defn rpswc-readiness-ready-fields? (readiness)
        (and (str_eq (raec-readiness-status readiness) (raec-status-ready))
        (and (str_eq (raec-readiness-reason readiness) (raec-reason-ready))
        (and (str_eq (raec-readiness-evidence-kind readiness) (raec-evidence-supplied-current))
        (and (str_eq (raec-readiness-authority readiness) (raec-authority-attempt-supplier))
             (str_eq (raec-readiness-freshness readiness) (raec-freshness-current)))))))
    (defn rpswc-capability-tuple-matches-envelope? (envelope capability)
        (and (str_eq (raec-capability-name capability) (raec-cap-program-image-walker))
        (and (str_eq (raec-capability-action capability) (rale-envelope-action envelope))
        (and (eq (raec-capability-route capability) (rale-envelope-route envelope))
             (str_eq (raec-capability-artifact-kind capability) (rale-envelope-artifact-kind envelope))))))
    (defn rpswc-capability-evidence-current? (capability)
        (and (str_eq (raec-capability-availability capability) (raec-availability-available))
        (and (str_eq (raec-capability-evidence-kind capability) (raec-evidence-supplied-current))
        (and (str_eq (raec-capability-authority capability) (raec-authority-attempt-supplier))
             (str_eq (raec-capability-freshness capability) (raec-freshness-current))))))
    (defn rpswc-recomputed-readiness-matches? (envelope readiness)
        (do
            (let recomputed (raec-readiness-from-envelope-capability envelope (raec-readiness-capability readiness)))
            (and (raec-readiness? recomputed)
            (and (str_eq (raec-readiness-status recomputed) (raec-readiness-status readiness))
            (and (str_eq (raec-readiness-reason recomputed) (raec-readiness-reason readiness))
            (and (str_eq (raec-readiness-required-capability recomputed) (raec-readiness-required-capability readiness))
            (and (str_eq (raec-readiness-evidence-kind recomputed) (raec-readiness-evidence-kind readiness))
            (and (str_eq (raec-readiness-authority recomputed) (raec-readiness-authority readiness))
            (and (str_eq (raec-readiness-freshness recomputed) (raec-readiness-freshness readiness))
            (and (str_eq (raec-readiness-action recomputed) (raec-readiness-action readiness))
            (and (eq (raec-readiness-route recomputed) (raec-readiness-route readiness))
            (and (str_eq (raec-readiness-artifact-kind recomputed) (raec-readiness-artifact-kind readiness))
                 (str_eq (raec-readiness-detail recomputed) (raec-readiness-detail readiness))))))))))))))
    (defn rpswc-symbol-walk-envelope-matches? (envelope symbol-walk)
        (rpswc-envelope-identity-matches? envelope (rpsw-receipt-envelope symbol-walk)))

    (defn rpswc-bind (envelope readiness admission symbol-request step-budget input-value)
        (if (not (rale-envelope? envelope))
            (list "runtime-program-image-fkb-symbol-capability-bound"
                  envelope readiness admission symbol-request step-budget input-value
                  (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                  (rpswc-status-refused) (rpswc-reason-malformed-envelope))
            (if (not (rpswc-program-image-envelope? envelope))
                (list "runtime-program-image-fkb-symbol-capability-bound"
                      envelope readiness admission symbol-request step-budget input-value
                      (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                      (rpswc-status-investigate) (rpswc-reason-non-program-image-envelope))
                (if (not (raec-readiness? readiness))
                    (list "runtime-program-image-fkb-symbol-capability-bound"
                          envelope readiness admission symbol-request step-budget input-value
                          (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                          (rpswc-status-refused) (rpswc-reason-malformed-readiness))
                    (if (not (rpswc-readiness-envelope-matches? envelope readiness))
                        (list "runtime-program-image-fkb-symbol-capability-bound"
                              envelope readiness admission symbol-request step-budget input-value
                              (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                              (rpswc-status-investigate) (rpswc-reason-readiness-envelope-identity-mismatch))
                        (if (not (rpswc-readiness-fields-match-envelope? envelope readiness))
                            (list "runtime-program-image-fkb-symbol-capability-bound"
                                  envelope readiness admission symbol-request step-budget input-value
                                  (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                  (rpswc-status-investigate) (rpswc-reason-readiness-field-mismatch))
                            (if (not (str_eq (raec-readiness-status readiness) (raec-status-ready)))
                                (if (str_eq (raec-readiness-status readiness) (raec-status-unavailable))
                                    (list "runtime-program-image-fkb-symbol-capability-bound"
                                          envelope readiness admission symbol-request step-budget input-value
                                          (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                          (rpswc-status-unavailable) (raec-readiness-reason readiness))
                                    (if (str_eq (raec-readiness-status readiness) (raec-status-refused))
                                        (list "runtime-program-image-fkb-symbol-capability-bound"
                                              envelope readiness admission symbol-request step-budget input-value
                                              (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                              (rpswc-status-refused) (raec-readiness-reason readiness))
                                        (list "runtime-program-image-fkb-symbol-capability-bound"
                                              envelope readiness admission symbol-request step-budget input-value
                                              (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                              (rpswc-status-investigate) (raec-readiness-reason readiness))))
                                (if (not (rpswc-readiness-ready-fields? readiness))
                                    (list "runtime-program-image-fkb-symbol-capability-bound"
                                          envelope readiness admission symbol-request step-budget input-value
                                          (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                          (rpswc-status-investigate) (rpswc-reason-readiness-ready-fields-forged))
                                    (do
                                        (let capability (raec-readiness-capability readiness))
                                        (if (not (raec-capability? capability))
                                            (list "runtime-program-image-fkb-symbol-capability-bound"
                                                  envelope readiness admission symbol-request step-budget input-value
                                                  (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                                  (rpswc-status-refused) (rpswc-reason-malformed-capability))
                                            (if (not (rpswc-capability-tuple-matches-envelope? envelope capability))
                                                (list "runtime-program-image-fkb-symbol-capability-bound"
                                                      envelope readiness admission symbol-request step-budget input-value
                                                      (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                                      (rpswc-status-investigate) (rpswc-reason-nested-capability-mismatch))
                                                (if (not (rpswc-capability-evidence-current? capability))
                                                    (list "runtime-program-image-fkb-symbol-capability-bound"
                                                          envelope readiness admission symbol-request step-budget input-value
                                                          (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                                          (rpswc-status-investigate) (rpswc-reason-nested-capability-evidence-mismatch))
                                                    (if (not (rpswc-recomputed-readiness-matches? envelope readiness))
                                                        (list "runtime-program-image-fkb-symbol-capability-bound"
                                                              envelope readiness admission symbol-request step-budget input-value
                                                              (rpswc-no-symbol-walk) (rpswc-no-bound-trace)
                                                              (rpswc-status-investigate) (rpswc-reason-recomputed-readiness-mismatch))
                                                        (do
                                                            (let symbol-walk (rpsw-walk-symbol envelope admission symbol-request step-budget input-value))
                                                            (if (not (rpsw-receipt? symbol-walk))
                                                                (list "runtime-program-image-fkb-symbol-capability-bound"
                                                                      envelope readiness admission symbol-request step-budget input-value
                                                                      symbol-walk (rpswc-no-bound-trace)
                                                                      (rpswc-status-investigate) (rpswc-reason-malformed-symbol-walk))
                                                                (if (not (rpswc-symbol-walk-envelope-matches? envelope symbol-walk))
                                                                    (list "runtime-program-image-fkb-symbol-capability-bound"
                                                                          envelope readiness admission symbol-request step-budget input-value
                                                                          symbol-walk (rpswc-no-bound-trace)
                                                                          (rpswc-status-investigate) (rpswc-reason-symbol-walk-envelope-mismatch))
                                                                    (if (not (str_eq (rpsw-receipt-status symbol-walk) (rpsw-status-trace-produced)))
                                                                        (list "runtime-program-image-fkb-symbol-capability-bound"
                                                                              envelope readiness admission symbol-request step-budget input-value
                                                                              symbol-walk (rpswc-no-bound-trace)
                                                                              (rpsw-receipt-status symbol-walk)
                                                                              (rpsw-receipt-reason symbol-walk))
                                                                        (if (not (rpsw-receipt-agrees? symbol-walk))
                                                                            (list "runtime-program-image-fkb-symbol-capability-bound"
                                                                                  envelope readiness admission symbol-request step-budget input-value
                                                                                  symbol-walk (rpswc-no-bound-trace)
                                                                                  (rpswc-status-investigate) (rpswc-reason-symbol-walk-agreement-mismatch))
                                                                            (if (not (rpiwt-trace? (rpsw-receipt-trace symbol-walk)))
                                                                                (list "runtime-program-image-fkb-symbol-capability-bound"
                                                                                      envelope readiness admission symbol-request step-budget input-value
                                                                                      symbol-walk (rpswc-no-bound-trace)
                                                                                      (rpswc-status-investigate) (rpswc-reason-malformed-bound-trace))
                                                                                (list "runtime-program-image-fkb-symbol-capability-bound"
                                                                                      envelope readiness admission symbol-request step-budget input-value
                                                                                      symbol-walk (rpsw-receipt-trace symbol-walk)
                                                                                      (rpswc-status-bound)
                                                                                      (rpsw-receipt-reason symbol-walk))))))))))))))))))))
))
