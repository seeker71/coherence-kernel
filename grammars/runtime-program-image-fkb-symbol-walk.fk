; runtime-program-image-fkb-symbol-walk.fk -- Layer 9h6 symbol-addressed PIF micro-walk.
;
; Layer 9h6 is the symbol-level runtime surface for the 9h5 computed
; micro-walker. It consumes a request-ready program-image envelope, an admitted
; 8h6 PIF byte admission, and an 8h8 symbol request. It resolves the request
; internally over the admitted PIF, then walks only the resolved function-root
; entry through 9h5. The receipt carries the computed resolution, micro-walk
; receipt, and trace so agreement is observable.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-fkb-byte-container.fk
;           form-stdlib/program-image-fkb-byte-file-witness.fk
;           form-stdlib/program-image-fkb-byte-decode.fk
;           form-stdlib/program-image-symbol-entry.fk
;           form-stdlib/runtime-program-image-fkb-walker-trace.fk
;           form-stdlib/runtime-program-image-fkb-micro-walker.fk

(do
    (defn rpsw-version () "runtime-program-image-fkb-symbol-walk-v1")

    (defn rpsw-feature (name status) (list "runtime-program-image-fkb-symbol-walk-feature" name status))
    (defn rpsw-feature-name (f) (nth f 1))
    (defn rpsw-feature-status (f) (nth f 2))
    (defn runtime-program-image-fkb-symbol-walk-manifest ()
        (list
            (rpsw-feature "layer-9h6-symbol-resolved-micro-walk" 1)
            (rpsw-feature "consumes-9e-envelope-8h6-admission-and-8h8-symbol-request" 1)
            (rpsw-feature "resolves-symbol-before-walk" 1)
            (rpsw-feature "symbol-resolution-computed-internally" 1)
            (rpsw-feature "runtime-requests-symbol-id-canonical-key-or-id-key" 1)
            (rpsw-feature "diagnostic-node-request-rejected-for-runtime" 1)
            (rpsw-feature "calls-9h5-computed-micro-walker" 1)
            (rpsw-feature "only-ready-symbol-resolution-walks" 1)
            (rpsw-feature "resolution-micro-walk-and-trace-must-agree" 1)
            (rpsw-feature "computed-trace-not-supplied-evidence" 1)
            (rpsw-feature "dependency-targets-carried-not-walked" 1)
            (rpsw-feature "9g-capability-binding-deferred" 1)
            (rpsw-feature "no-raw-entry-runtime-api" 1)
            (rpsw-feature "no-supplied-run-or-trace-input" 1)
            (rpsw-feature "no-9h3-or-9h4-consumption" 1)
            (rpsw-feature "no-table-payload-authority" 1)
            (rpsw-feature "no-presentation-lens-authority" 1)
            (rpsw-feature "no-artifact-io" 1)
            (rpsw-feature "no-generated-table-authority" 1)
            (rpsw-feature "no-selector-storage-or-champion-mutation" 1)
            (rpsw-feature "no-c-seed-growth" 1)))
    (defn runtime-program-image-fkb-symbol-walk-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rpsw-feature-name (head fs)) name)
                     (eq (rpsw-feature-status (head fs)) 1))
                1
                (runtime-program-image-fkb-symbol-walk-manifest-has? name (tail fs)))))

    (defn rpsw-status-trace-produced () (rpmw-status-trace-produced))
    (defn rpsw-status-investigate () (pise-status-investigate))
    (defn rpsw-status-refused () (pise-status-refused))

    (defn rpsw-reason-diagnostic-node-not-runtime-request () "diagnostic-node-not-runtime-request")
    (defn rpsw-reason-malformed-symbol-resolution () "malformed-symbol-resolution")
    (defn rpsw-reason-resolution-pif-mismatch () "resolution-pif-mismatch")
    (defn rpsw-reason-resolution-request-mismatch () "resolution-request-mismatch")
    (defn rpsw-reason-malformed-micro-walk-receipt () "malformed-micro-walk-receipt")
    (defn rpsw-reason-micro-walk-envelope-mismatch () "micro-walk-envelope-mismatch")
    (defn rpsw-reason-micro-walk-admission-mismatch () "micro-walk-admission-mismatch")
    (defn rpsw-reason-micro-walk-input-mismatch () "micro-walk-input-mismatch")
    (defn rpsw-reason-micro-walk-budget-mismatch () "micro-walk-budget-mismatch")
    (defn rpsw-reason-micro-walk-entry-mismatch () "micro-walk-entry-mismatch")
    (defn rpsw-reason-micro-walk-root-mismatch () "micro-walk-root-mismatch")
    (defn rpsw-reason-micro-walk-trace-malformed () "micro-walk-trace-malformed")
    (defn rpsw-reason-micro-walk-trace-mismatch () "micro-walk-trace-mismatch")
    (defn rpsw-reason-trace-identity-mismatch () "trace-identity-mismatch")
    (defn rpsw-reason-trace-entry-kind-mismatch () "trace-entry-kind-mismatch")
    (defn rpsw-reason-trace-entry-mismatch () "trace-entry-mismatch")
    (defn rpsw-reason-trace-root-mismatch () "trace-root-mismatch")
    (defn rpsw-reason-trace-budget-mismatch () "trace-budget-mismatch")
    (defn rpsw-reason-agreement-ready () "symbol-walk-agreement-ready")

    (defn rpsw-resolution-reason-manifest ()
        (list
            (pise-reason-ready)
            (pise-reason-malformed-request)
            (pise-reason-invalid-symbol-id)
            (pise-reason-empty-canonical-key)
            (pise-reason-canonical-key-not-found)
            (pise-reason-duplicate-canonical-key)
            (pise-reason-symbol-id-key-mismatch)
            (pise-reason-symbol-not-defined-by-node)
            (pise-reason-defined-node-not-function-root)
            (pise-reason-duplicate-function-root)))
    (defn rpsw-walk-reason-manifest ()
        (list
            (rpmw-reason-walk-completed)
            (rpmw-reason-step-budget-exhausted)
            (rpmw-reason-unsupported-tag)
            (rpmw-reason-child-out-of-range)
            (rpmw-reason-malformed-envelope)
            (rpmw-reason-non-program-image-envelope)
            (rpmw-reason-malformed-admission)
            (rpmw-reason-non-admitted-admission)
            (rpmw-reason-admission-decode-not-decoded)
            (rpmw-reason-admission-invalid-pif)
            (rpmw-reason-admission-decode-pif-mismatch)
            (rpmw-reason-artifact-identity-mismatch)
            (rpmw-reason-negative-step-budget)))
    (defn rpsw-defensive-reason-manifest ()
        (list
            (rpsw-reason-diagnostic-node-not-runtime-request)
            (rpsw-reason-malformed-symbol-resolution)
            (rpsw-reason-resolution-pif-mismatch)
            (rpsw-reason-resolution-request-mismatch)
            (rpsw-reason-malformed-micro-walk-receipt)
            (rpsw-reason-micro-walk-envelope-mismatch)
            (rpsw-reason-micro-walk-admission-mismatch)
            (rpsw-reason-micro-walk-input-mismatch)
            (rpsw-reason-micro-walk-budget-mismatch)
            (rpsw-reason-micro-walk-entry-mismatch)
            (rpsw-reason-micro-walk-root-mismatch)
            (rpsw-reason-micro-walk-trace-malformed)
            (rpsw-reason-micro-walk-trace-mismatch)
            (rpsw-reason-trace-identity-mismatch)
            (rpsw-reason-trace-entry-kind-mismatch)
            (rpsw-reason-trace-entry-mismatch)
            (rpsw-reason-trace-root-mismatch)
            (rpsw-reason-trace-budget-mismatch)))
    (defn rpsw-reason-manifest ()
        (append (rpsw-defensive-reason-manifest)
                (append (rpsw-resolution-reason-manifest)
                        (rpsw-walk-reason-manifest))))

    (defn rpsw-no-resolution () (list "runtime-program-image-fkb-symbol-walk-no-resolution"))
    (defn rpsw-no-resolution? (r)
        (if (eq (len r) 1)
            (str_eq (nth r 0) "runtime-program-image-fkb-symbol-walk-no-resolution")
            0))
    (defn rpsw-no-micro-walk () (list "runtime-program-image-fkb-symbol-walk-no-micro-walk"))
    (defn rpsw-no-micro-walk? (r)
        (if (eq (len r) 1)
            (str_eq (nth r 0) "runtime-program-image-fkb-symbol-walk-no-micro-walk")
            0))
    (defn rpsw-no-trace () (rpmw-no-trace))

    ; receipt = ("runtime-program-image-fkb-symbol-walk" envelope admission
    ;            symbol-request step-budget input-value symbol-resolution
    ;            micro-walk-receipt trace status reason)
    (defn rpsw-receipt-row (envelope admission symbol-request step-budget input-value symbol-resolution micro-walk trace status reason)
        (list "runtime-program-image-fkb-symbol-walk"
              envelope admission symbol-request step-budget input-value
              symbol-resolution micro-walk trace status reason))
    (defn rpsw-receipt? (r)
        (if (eq (len r) 11)
            (str_eq (nth r 0) "runtime-program-image-fkb-symbol-walk")
            0))
    (defn rpsw-receipt-envelope (r) (nth r 1))
    (defn rpsw-receipt-admission (r) (nth r 2))
    (defn rpsw-receipt-symbol-request (r) (nth r 3))
    (defn rpsw-receipt-step-budget (r) (nth r 4))
    (defn rpsw-receipt-input-value (r) (nth r 5))
    (defn rpsw-receipt-symbol-resolution (r) (nth r 6))
    (defn rpsw-receipt-micro-walk (r) (nth r 7))
    (defn rpsw-receipt-trace (r) (nth r 8))
    (defn rpsw-receipt-status (r) (nth r 9))
    (defn rpsw-receipt-reason (r) (nth r 10))

    (defn rpsw-refused (envelope admission symbol-request step-budget input-value reason)
        (rpsw-receipt-row envelope admission symbol-request step-budget input-value
                          (rpsw-no-resolution)
                          (rpsw-no-micro-walk)
                          (rpsw-no-trace)
                          (rpsw-status-refused)
                          reason))
    (defn rpsw-terminal-resolution (envelope admission symbol-request step-budget input-value resolution)
        (rpsw-receipt-row envelope admission symbol-request step-budget input-value resolution
                          (rpsw-no-micro-walk)
                          (rpsw-no-trace)
                          (pise-resolution-status resolution)
                          (pise-resolution-reason resolution)))
    (defn rpsw-produced (envelope admission symbol-request step-budget input-value resolution micro-walk trace)
        (rpsw-receipt-row envelope admission symbol-request step-budget input-value resolution micro-walk trace
                          (rpsw-status-trace-produced)
                          (rpmw-receipt-reason micro-walk)))
    (defn rpsw-micro-terminal (envelope admission symbol-request step-budget input-value resolution micro-walk)
        (rpsw-receipt-row envelope admission symbol-request step-budget input-value resolution micro-walk
                          (rpmw-receipt-trace micro-walk)
                          (rpmw-receipt-status micro-walk)
                          (rpmw-receipt-reason micro-walk)))
    (defn rpsw-investigate-micro (envelope admission symbol-request step-budget input-value resolution micro-walk trace reason)
        (rpsw-receipt-row envelope admission symbol-request step-budget input-value resolution micro-walk trace
                          (rpsw-status-investigate)
                          reason))

    (defn rpsw-diagnostic-request? (request)
        (if (pise-request? request)
            (str_eq (pise-request-mode request) (pise-mode-diagnostic-node))
            0))
    (defn rpsw-request-matches? (a b)
        (if (pise-request? a)
            (if (pise-request? b)
                (and (str_eq (pise-request-mode a) (pise-request-mode b))
                (and (eq (pise-request-symbol-id a) (pise-request-symbol-id b))
                (and (str_eq (pise-request-canonical-key a) (pise-request-canonical-key b))
                     (eq (pise-request-node-id a) (pise-request-node-id b)))))
                0)
            0))
    (defn rpsw-pif-metadata-matches? (a b)
        (and (str_eq (pif-envelope-source-path a) (pif-envelope-source-path b))
        (and (str_eq (pif-envelope-source-hash a) (pif-envelope-source-hash b))
        (and (eq (pif-envelope-source-mtime a) (pif-envelope-source-mtime b))
        (and (str_eq (pif-envelope-artifact-path a) (pif-envelope-artifact-path b))
        (and (str_eq (pif-envelope-content-hash a) (pif-envelope-content-hash b))
        (and (eq (pif-envelope-artifact-mtime a) (pif-envelope-artifact-mtime b))
             (eq (pif-envelope-seal-ok a) (pif-envelope-seal-ok b)))))))))
    (defn rpsw-pif-matches? (a b)
        (if (pif-envelope-valid? a)
            (if (pif-envelope-valid? b)
                (if (rpsw-pif-metadata-matches? a b)
                    (pifbd-bytes-eq? (pifbc-payload-bytes a)
                                     (pifbc-payload-bytes b))
                    0)
                0)
            0))
    (defn rpsw-envelope-identity-matches? (expected actual)
        (if (rale-envelope? expected)
            (if (rale-envelope? actual)
                (and (str_eq (rale-envelope-action actual) (rale-envelope-action expected))
                (and (eq (rale-envelope-route actual) (rale-envelope-route expected))
                (and (str_eq (rale-envelope-artifact-kind actual) (rale-envelope-artifact-kind expected))
                (and (str_eq (rale-envelope-artifact-path actual) (rale-envelope-artifact-path expected))
                (and (str_eq (rale-envelope-source-hash actual) (rale-envelope-source-hash expected))
                     (str_eq (rale-envelope-content-hash actual) (rale-envelope-content-hash expected)))))))
                0)
            0))
    (defn rpsw-admission-pif-matches? (expected actual)
        (if (pifbd-admission? expected)
            (if (pifbd-admission? actual)
                (rpsw-pif-matches? (pifbd-admission-pif expected)
                                   (pifbd-admission-pif actual))
                0)
            0))
    (defn rpsw-trace-fields-match? (a b)
        (if (rpiwt-trace? a)
            (if (rpiwt-trace? b)
                (and (str_eq (rpiwt-trace-artifact-path a) (rpiwt-trace-artifact-path b))
                (and (str_eq (rpiwt-trace-source-hash a) (rpiwt-trace-source-hash b))
                (and (str_eq (rpiwt-trace-content-hash a) (rpiwt-trace-content-hash b))
                (and (str_eq (rpiwt-trace-entry-kind a) (rpiwt-trace-entry-kind b))
                (and (eq (rpiwt-trace-entry-index a) (rpiwt-trace-entry-index b))
                (and (eq (rpiwt-trace-root-node a) (rpiwt-trace-root-node b))
                (and (eq (rpiwt-trace-step-budget a) (rpiwt-trace-step-budget b))
                (and (eq (rpiwt-trace-steps-used a) (rpiwt-trace-steps-used b))
                (and (eq (rpiwt-trace-output-count a) (rpiwt-trace-output-count b))
                (and (eq (rpiwt-trace-first-value a) (rpiwt-trace-first-value b))
                (and (eq (rpiwt-trace-exit-code a) (rpiwt-trace-exit-code b))
                (and (str_eq (rpiwt-trace-status a) (rpiwt-trace-status b))
                (and (str_eq (rpiwt-trace-stop-reason a) (rpiwt-trace-stop-reason b))
                     (str_eq (rpiwt-trace-detail a) (rpiwt-trace-detail b)))))))))))))))
                0)
            0))

    (defn rpsw-micro-agreement-reason (envelope admission resolution micro-walk step-budget input-value)
        (if (not (rpsw-envelope-identity-matches? envelope (rpmw-receipt-envelope micro-walk)))
            (rpsw-reason-micro-walk-envelope-mismatch)
            (if (not (rpsw-admission-pif-matches? admission (rpmw-receipt-admission micro-walk)))
                (rpsw-reason-micro-walk-admission-mismatch)
                (if (not (eq (rpmw-receipt-input-value micro-walk) input-value))
                    (rpsw-reason-micro-walk-input-mismatch)
                    (if (not (eq (rpmw-receipt-step-budget micro-walk) step-budget))
                        (rpsw-reason-micro-walk-budget-mismatch)
                        (if (not (eq (rpmw-receipt-entry-index micro-walk)
                                     (pise-resolution-entry-index resolution)))
                            (rpsw-reason-micro-walk-entry-mismatch)
                            (if (not (eq (rpmw-receipt-root-node micro-walk)
                                         (pise-resolution-root-node resolution)))
                                (rpsw-reason-micro-walk-root-mismatch)
                                (if (not (rpiwt-trace? (rpmw-receipt-trace micro-walk)))
                                    (rpsw-reason-micro-walk-trace-malformed)
                                    (rpsw-reason-agreement-ready)))))))))
    (defn rpsw-trace-agreement-reason (envelope pif resolution trace step-budget)
        (if (not (rpiwt-trace-identity-matches? envelope pif trace))
            (rpsw-reason-trace-identity-mismatch)
            (if (not (str_eq (rpiwt-trace-entry-kind trace)
                             (rpiwt-entry-kind-function-root)))
                (rpsw-reason-trace-entry-kind-mismatch)
                (if (not (eq (rpiwt-trace-entry-index trace)
                             (pise-resolution-entry-index resolution)))
                    (rpsw-reason-trace-entry-mismatch)
                    (if (not (eq (rpiwt-trace-root-node trace)
                                 (pise-resolution-root-node resolution)))
                        (rpsw-reason-trace-root-mismatch)
                        (if (not (eq (rpiwt-trace-step-budget trace) step-budget))
                            (rpsw-reason-trace-budget-mismatch)
                            (rpsw-reason-agreement-ready)))))))
    (defn rpsw-produced-agreement-reason (envelope admission symbol-request resolution micro-walk trace step-budget input-value)
        (do
            (let pif (pifbd-admission-pif admission))
            (if (not (pise-resolution? resolution))
                (rpsw-reason-malformed-symbol-resolution)
                (if (not (rpsw-pif-matches? (pise-resolution-pif resolution) pif))
                    (rpsw-reason-resolution-pif-mismatch)
                    (if (not (rpsw-request-matches? (pise-resolution-request resolution) symbol-request))
                        (rpsw-reason-resolution-request-mismatch)
                        (if (not (rpmw-receipt? micro-walk))
                            (rpsw-reason-malformed-micro-walk-receipt)
                            (do
                                (let micro-reason (rpsw-micro-agreement-reason
                                                      envelope admission resolution micro-walk
                                                      step-budget input-value))
                                (if (not (str_eq micro-reason (rpsw-reason-agreement-ready)))
                                    micro-reason
                                    (if (not (rpsw-trace-fields-match? trace (rpmw-receipt-trace micro-walk)))
                                        (rpsw-reason-micro-walk-trace-mismatch)
                                        (rpsw-trace-agreement-reason envelope pif resolution trace step-budget))))))))))
    (defn rpsw-receipt-agreement-reason (receipt)
        (if (rpsw-receipt? receipt)
            (do
                (let micro-walk (rpsw-receipt-micro-walk receipt))
                (if (not (rpmw-receipt? micro-walk))
                    (rpsw-reason-malformed-micro-walk-receipt)
                    (rpsw-produced-agreement-reason
                        (rpsw-receipt-envelope receipt)
                        (rpsw-receipt-admission receipt)
                        (rpsw-receipt-symbol-request receipt)
                        (rpsw-receipt-symbol-resolution receipt)
                        micro-walk
                        (rpsw-receipt-trace receipt)
                        (rpsw-receipt-step-budget receipt)
                        (rpsw-receipt-input-value receipt))))
            (rpsw-reason-malformed-micro-walk-receipt)))
    (defn rpsw-receipt-agrees? (receipt)
        (str_eq (rpsw-receipt-agreement-reason receipt)
                (rpsw-reason-agreement-ready)))

    (defn rpsw-walk-symbol (envelope admission symbol-request step-budget input-value)
        (if (not (rale-envelope? envelope))
            (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-malformed-envelope))
            (if (not (rpmw-program-image-envelope? envelope))
                (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-non-program-image-envelope))
                (if (not (pifbd-admission? admission))
                    (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-malformed-admission))
                    (if (not (rpmw-admission-status-admitted? admission))
                        (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-non-admitted-admission))
                        (if (not (rpmw-admission-decode-decoded? admission))
                            (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-admission-decode-not-decoded))
                            (if (not (rpmw-admission-pif-valid? admission))
                                (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-admission-invalid-pif))
                                (if (not (rpmw-admission-decode-matches-pif? admission))
                                    (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-admission-decode-pif-mismatch))
                                    (if (not (rpmw-pif-matches-envelope? envelope (pifbd-admission-pif admission)))
                                        (rpsw-refused envelope admission symbol-request step-budget input-value (rpmw-reason-artifact-identity-mismatch))
                                        (if (rpsw-diagnostic-request? symbol-request)
                                            (rpsw-refused envelope admission symbol-request step-budget input-value
                                                          (rpsw-reason-diagnostic-node-not-runtime-request))
                                            (do
                                                (let pif (pifbd-admission-pif admission))
                                                (let resolution (pise-resolve pif symbol-request))
                                                (if (not (pise-resolution? resolution))
                                                    (rpsw-investigate-micro envelope admission symbol-request step-budget input-value resolution
                                                                            (rpsw-no-micro-walk)
                                                                            (rpsw-no-trace)
                                                                            (rpsw-reason-malformed-symbol-resolution))
                                                    (if (not (str_eq (pise-resolution-status resolution) (pise-status-ready)))
                                                        (rpsw-terminal-resolution envelope admission symbol-request step-budget input-value resolution)
                                                        (do
                                                            (let micro-walk (rpmw-walk-entry envelope admission
                                                                                             (pise-resolution-entry-index resolution)
                                                                                             step-budget
                                                                                             input-value))
                                                            (if (not (rpmw-receipt? micro-walk))
                                                                (rpsw-investigate-micro envelope admission symbol-request step-budget input-value resolution micro-walk
                                                                                        (rpsw-no-trace)
                                                                                        (rpsw-reason-malformed-micro-walk-receipt))
                                                                (if (str_eq (rpmw-receipt-status micro-walk) (rpmw-status-refused))
                                                                    (rpsw-micro-terminal envelope admission symbol-request step-budget input-value resolution micro-walk)
                                                                    (if (not (str_eq (rpmw-receipt-status micro-walk) (rpmw-status-trace-produced)))
                                                                        (rpsw-investigate-micro envelope admission symbol-request step-budget input-value resolution micro-walk
                                                                                                (rpmw-receipt-trace micro-walk)
                                                                                                (rpsw-reason-malformed-micro-walk-receipt))
                                                                        (do
                                                                            (let trace (rpmw-receipt-trace micro-walk))
                                                                            (let agreement (rpsw-produced-agreement-reason
                                                                                                envelope admission symbol-request resolution
                                                                                                micro-walk trace step-budget input-value))
                                                                            (if (str_eq agreement (rpsw-reason-agreement-ready))
                                                                                (rpsw-produced envelope admission symbol-request step-budget input-value resolution micro-walk trace)
                                                                                (rpsw-investigate-micro envelope admission symbol-request step-budget input-value resolution micro-walk
                                                                                                        trace agreement))))))))))))))))))))
)
