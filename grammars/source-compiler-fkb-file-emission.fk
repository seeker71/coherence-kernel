; source-compiler-fkb-file-emission.fk -- compile receipt for ready .fkb file witness.
;
; Layer 8j1 is a sibling of 8j, not a replacement. It binds a compile-source
; request to a valid program-image PIF, a ready 8h5 byte-file witness, and an
; optional native dylib descriptor. It does not produce `sce-emission` rows and
; does not feed existing 8k/9h consumers yet.
;
; This layer has no table-payload argument and does not render `.tbl` text. The
; compile-output `embeds-table-payload` bit is interpreted only as: the program-image
; `.fkb` contains the table-shaped payload sections.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/str-byte-at.fk
;           form-stdlib/sha256.fk
;           form-stdlib/hex.fk
;           form-stdlib/form-fs.fk
;           form-stdlib/file-byte-window.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/source-artifact-probe.fk
;           form-stdlib/source-artifact-identity.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-fkb-byte-container.fk
;           form-stdlib/program-image-fkb-byte-file-witness.fk
;           form-stdlib/source-compiler-emission.fk

(do
    (defn scffe-version () "source-compiler-fkb-file-emission-v1")

    (defn scffe-feature (name status) (list "source-compiler-fkb-file-emission-feature" name status))
    (defn scffe-feature-name (f) (nth f 1))
    (defn scffe-feature-status (f) (nth f 2))
    (defn source-compiler-fkb-file-emission-manifest ()
        (list
            (scffe-feature "sibling-row-family-not-sce-emission" 1)
            (scffe-feature "compile-envelope-bound" 1)
            (scffe-feature "sac-compile-output-provenance" 1)
            (scffe-feature "program-image-fkb-file-witness-required" 1)
            (scffe-feature "fkb-descriptor-derived-from-pif" 1)
            (scffe-feature "embeds-table-payload-means-contained-table-payload" 1)
            (scffe-feature "no-external-table-payload-argument" 1)
            (scffe-feature "replays-8h5-witness" 1)
            (scffe-feature "replays-embedded-byte-container" 1)
            (scffe-feature "readback-window-checked" 1)
            (scffe-feature "readback-vouch-checked" 1)
            (scffe-feature "optional-native-dylib-descriptor" 1)
            (scffe-feature "route-policy-delegated-to-sad" 1)
            (scffe-feature "current-is-provided-field-consistency" 1)
            (scffe-feature "explicit-reason-manifest" 1)
            (scffe-feature "no-disk-io" 1)
            (scffe-feature "no-form-binary-io" 1)
            (scffe-feature "no-runtime-load-walk-call-exec" 1)
            (scffe-feature "no-selector-install" 1)
            (scffe-feature "no-c-seed-growth" 1)))
    (defn source-compiler-fkb-file-emission-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (scffe-feature-name (head fs)) name)
                     (eq (scffe-feature-status (head fs)) 1))
                1
                (source-compiler-fkb-file-emission-manifest-has? name (tail fs)))))

    (defn scffe-status-emitted () "emitted")
    (defn scffe-status-investigate () "investigate")
    (defn scffe-status-refused () "refused")

    (defn scffe-reason-emitted () "fkb-file-emission-ready")
    (defn scffe-reason-emitted-with-dylib () "fkb-file-emission-ready-with-dylib")
    (defn scffe-reason-malformed-compile-envelope () "malformed-compile-envelope")
    (defn scffe-reason-non-compile-envelope () "non-compile-envelope")
    (defn scffe-reason-malformed-compile-output () "malformed-compile-output")
    (defn scffe-reason-compile-output-does-not-write-fkb () "compile-output-does-not-write-fkb")
    (defn scffe-reason-compile-output-missing-table-payload () "compile-output-missing-contained-table-payload")
    (defn scffe-reason-compile-output-c-growth () "compile-output-c-growth")
    (defn scffe-reason-malformed-pif-envelope () "malformed-pif-envelope")
    (defn scffe-reason-pif-seal-invalid () "pif-seal-invalid")
    (defn scffe-reason-pif-table-invalid () "pif-table-invalid")
    (defn scffe-reason-source-identity-mismatch () "source-identity-mismatch")
    (defn scffe-reason-pif-envelope-stale () "pif-envelope-stale")
    (defn scffe-reason-malformed-fkb-witness () "malformed-fkb-witness")
    (defn scffe-reason-non-ready-fkb-witness () "non-ready-fkb-witness")
    (defn scffe-reason-fkb-witness-drift () "fkb-witness-drift")
    (defn scffe-reason-fkb-witness-pif-mismatch () "fkb-witness-pif-mismatch")
    (defn scffe-reason-fkb-witness-path-mismatch () "fkb-witness-path-mismatch")
    (defn scffe-reason-fkb-witness-content-hash-mismatch () "fkb-witness-content-hash-mismatch")
    (defn scffe-reason-dylib-not-requested () "dylib-not-requested")
    (defn scffe-reason-dylib-requested-missing () "dylib-requested-missing")
    (defn scffe-reason-malformed-dylib-descriptor () "malformed-dylib-descriptor")
    (defn scffe-reason-dylib-source-mismatch () "dylib-source-mismatch")
    (defn scffe-reason-dylib-policy-unsatisfied () "dylib-policy-unsatisfied")

    (defn scffe-reason-manifest ()
        (list
            (scffe-reason-emitted)
            (scffe-reason-emitted-with-dylib)
            (scffe-reason-malformed-compile-envelope)
            (scffe-reason-non-compile-envelope)
            (scffe-reason-malformed-compile-output)
            (scffe-reason-compile-output-does-not-write-fkb)
            (scffe-reason-compile-output-missing-table-payload)
            (scffe-reason-compile-output-c-growth)
            (scffe-reason-malformed-pif-envelope)
            (scffe-reason-pif-seal-invalid)
            (scffe-reason-pif-table-invalid)
            (scffe-reason-source-identity-mismatch)
            (scffe-reason-pif-envelope-stale)
            (scffe-reason-malformed-fkb-witness)
            (scffe-reason-non-ready-fkb-witness)
            (scffe-reason-fkb-witness-drift)
            (scffe-reason-fkb-witness-pif-mismatch)
            (scffe-reason-fkb-witness-path-mismatch)
            (scffe-reason-fkb-witness-content-hash-mismatch)
            (scffe-reason-dylib-not-requested)
            (scffe-reason-dylib-requested-missing)
            (scffe-reason-malformed-dylib-descriptor)
            (scffe-reason-dylib-source-mismatch)
            (scffe-reason-dylib-policy-unsatisfied)))

    (defn scffe-window? (w)
        (if (eq (len w) 8)
            (str_eq (nth w 0) "file-byte-window")
            0))
    (defn scffe-pif-metadata-match? (a b)
        (if (str_eq (pif-envelope-source-path a) (pif-envelope-source-path b))
            (if (str_eq (pif-envelope-source-hash a) (pif-envelope-source-hash b))
                (if (eq (pif-envelope-source-mtime a) (pif-envelope-source-mtime b))
                    (if (str_eq (pif-envelope-artifact-path a) (pif-envelope-artifact-path b))
                        (if (str_eq (pif-envelope-content-hash a) (pif-envelope-content-hash b))
                            (if (eq (pif-envelope-artifact-mtime a) (pif-envelope-artifact-mtime b))
                                (eq (pif-envelope-seal-ok a) (pif-envelope-seal-ok b))
                                0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn scffe-pif-match? (a b)
        (if (pif-envelope-valid? a)
            (if (pif-envelope-valid? b)
                (if (scffe-pif-metadata-match? a b)
                    (pifbf-bytes-eq? (pifbc-payload-bytes a) (pifbc-payload-bytes b))
                    0)
                0)
            0))
    (defn scffe-witness-container (w)
        (if (pifbf-witness? w) (pifbf-witness-container w) (pifbc-container (list) (empty) (pifbc-empty-vouch) (pifbc-status-refused) "missing")))
    (defn scffe-witness-pif (w)
        (if (pifbc-container? (scffe-witness-container w))
            (pifbc-container-pif (scffe-witness-container w))
            (list)))
    (defn scffe-witness-bytes (w)
        (if (pifbc-container? (scffe-witness-container w))
            (pifbc-container-bytes (scffe-witness-container w))
            (empty)))
    (defn scffe-witness-basic-ready? (w)
        (if (pifbf-witness? w)
            (if (str_eq (pifbf-witness-status w) (pifbf-status-ready))
                (str_eq (pifbf-witness-reason w) (pifbf-reason-ready))
                0)
            0))
    (defn scffe-witness-window-ready? (w bytes)
        (do
            (let window (pifbf-witness-window w))
            (if (scffe-window? window)
                (if (str_eq (fbw-window-status window) (fbw-status-ready))
                    (if (eq (fbw-window-requested-len window) (len bytes))
                        (if (eq (fbw-window-observed-len window) (len bytes))
                            (pifbf-bytes-eq? (fbw-window-bytes window) bytes)
                            0)
                        0)
                    0)
                0)))
    (defn scffe-witness-vouch-ready? (w pif bytes)
        (do
            (let vouch (pifbf-witness-readback-vouch w))
            (let expected (sai-vouch-content-bytes
                            (pif-envelope-artifact-path pif)
                            (pif-envelope-content-hash pif)
                            bytes))
            (and (sai-vouch-match? vouch)
            (and (sai-vouch-match? expected)
            (and (str_eq (sai-vouch-target vouch) (sai-vouch-target expected))
            (and (str_eq (sai-vouch-path vouch) (sai-vouch-path expected))
            (and (str_eq (sai-vouch-evidence-kind vouch) (sai-vouch-evidence-kind expected))
            (and (str_eq (sai-vouch-expected-hash vouch) (sai-vouch-expected-hash expected))
            (and (str_eq (sai-vouch-actual-hash vouch) (sai-vouch-actual-hash expected))
            (and (str_eq (sai-vouch-status vouch) (sai-vouch-status expected))
            (and (eq (sai-vouch-observed-size vouch) (len bytes))
            (and (eq (sai-vouch-material-size vouch) (len bytes))
            (and (eq (sai-vouch-observed-size expected) (len bytes))
                 (eq (sai-vouch-material-size expected) (len bytes)))))))))))))))
    (defn scffe-witness-internal-replay-ok? (w)
        (if (pifbf-witness? w)
            (do
                (let c (pifbf-witness-container w))
                (let pif (scffe-witness-pif w))
                (let bytes (scffe-witness-bytes w))
                (if (pifbc-container? c)
                    (if (pifbf-container-replay-ok? c)
                        (if (eq (pifbf-witness-wrote w) (len bytes))
                            (if (eq (pifbf-witness-observed-size w) (len bytes))
                                (if (scffe-witness-window-ready? w bytes)
                                    (scffe-witness-vouch-ready? w pif bytes)
                                    0)
                                0)
                            0)
                        0)
                    0))
            0))
    (defn scffe-witness-path-match? (w pif fkb)
        (do
            (let wpif (scffe-witness-pif w))
            (let path (pif-envelope-artifact-path pif))
            (let window (pifbf-witness-window w))
            (let vouch (pifbf-witness-readback-vouch w))
            (if (pif-envelope? wpif)
                (if (scffe-window? window)
                    (if (sai-vouch? vouch)
                        (and (str_eq (pifbf-witness-path w) path)
                        (and (str_eq (pif-envelope-artifact-path wpif) path)
                        (and (str_eq (sad-artifact-path fkb) path)
                        (and (str_eq (fbw-window-path window) path)
                             (str_eq (sai-vouch-path vouch) path)))))
                        0)
                    0)
                0)))
    (defn scffe-witness-content-hash-match? (w pif fkb)
        (do
            (let vouch (pifbf-witness-readback-vouch w))
            (let wpif (scffe-witness-pif w))
            (if (pif-envelope? wpif)
                (if (sai-vouch? vouch)
                    (and (str_eq (pif-envelope-content-hash pif) (sad-artifact-content-hash fkb))
                    (and (str_eq (pif-envelope-content-hash wpif) (pif-envelope-content-hash pif))
                    (and (str_eq (sai-vouch-expected-hash vouch) (pif-envelope-content-hash pif))
                         (str_eq (sai-vouch-actual-hash vouch) (pif-envelope-content-hash pif)))))
                    0)
                0)))

    ; row = ("source-compiler-fkb-file-emission" compile-envelope compile-output
    ;        pif-envelope fkb-witness dylib fkb-descriptor status reason)
    (defn scffe-emission (compile-envelope compile-output pif witness dylib fkb status reason)
        (list "source-compiler-fkb-file-emission" compile-envelope compile-output
              pif witness dylib fkb status reason))
    (defn scffe-emission? (e)
        (if (eq (len e) 9)
            (str_eq (nth e 0) "source-compiler-fkb-file-emission")
            0))
    (defn scffe-emission-compile-envelope (e) (nth e 1))
    (defn scffe-emission-compile-output (e) (nth e 2))
    (defn scffe-emission-pif-envelope (e) (nth e 3))
    (defn scffe-emission-fkb-witness (e) (nth e 4))
    (defn scffe-emission-dylib (e) (nth e 5))
    (defn scffe-emission-fkb-descriptor (e) (nth e 6))
    (defn scffe-emission-status (e) (nth e 7))
    (defn scffe-emission-reason (e) (nth e 8))
    (defn scffe-emitted? (e)
        (if (scffe-emission? e)
            (str_eq (scffe-emission-status e) (scffe-status-emitted))
            0))
    (defn scffe-investigate? (e)
        (if (scffe-emission? e)
            (str_eq (scffe-emission-status e) (scffe-status-investigate))
            0))
    (defn scffe-refused? (e)
        (if (scffe-emission? e)
            (str_eq (scffe-emission-status e) (scffe-status-refused))
            0))
    (defn scffe-row (compile-envelope compile-output pif witness dylib status reason)
        (scffe-emission compile-envelope compile-output pif witness dylib
                        (pif-descriptor-from-envelope pif)
                        status reason))
    (defn scffe-emitted-row (compile-envelope compile-output pif witness dylib reason)
        (scffe-row compile-envelope compile-output pif witness dylib (scffe-status-emitted) reason))
    (defn scffe-investigate-row (compile-envelope compile-output pif witness dylib reason)
        (scffe-row compile-envelope compile-output pif witness dylib (scffe-status-investigate) reason))
    (defn scffe-refused-row (compile-envelope compile-output pif witness dylib reason)
        (scffe-row compile-envelope compile-output pif witness dylib (scffe-status-refused) reason))

    (defn scffe-after-witness-ready (compile-envelope compile-output pif witness dylib source fkb)
        (if (eq (sce-compile-output-writes-dylib? compile-output) 0)
            (if (sce-no-dylib? dylib)
                (scffe-emitted-row compile-envelope compile-output pif witness dylib (scffe-reason-emitted))
                (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-dylib-not-requested)))
            (if (sce-no-dylib? dylib)
                (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-dylib-requested-missing))
                (if (not (sce-dylib-descriptor? dylib))
                    (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-malformed-dylib-descriptor))
                    (if (not (sce-dylib-source-match? source dylib))
                        (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-dylib-source-mismatch))
                        (if (not (sce-dylib-policy-satisfied? source fkb dylib))
                            (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-dylib-policy-unsatisfied))
                            (scffe-emitted-row compile-envelope compile-output pif witness dylib (scffe-reason-emitted-with-dylib))))))))

    (defn scffe-after-pif-policy (compile-envelope compile-output pif witness dylib source fkb)
        (if (not (pifbf-witness? witness))
            (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-malformed-fkb-witness))
            (if (not (scffe-witness-basic-ready? witness))
                (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-non-ready-fkb-witness))
                (if (not (scffe-witness-path-match? witness pif fkb))
                    (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-fkb-witness-path-mismatch))
                    (if (not (scffe-witness-content-hash-match? witness pif fkb))
                        (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-fkb-witness-content-hash-mismatch))
                        (if (not (scffe-pif-match? pif (scffe-witness-pif witness)))
                            (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-fkb-witness-pif-mismatch))
                            (if (not (scffe-witness-internal-replay-ok? witness))
                                (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-fkb-witness-drift))
                                (scffe-after-witness-ready compile-envelope compile-output pif witness dylib source fkb))))))))

    (defn scffe-emission-from-compile (compile-envelope compile-output pif witness dylib)
        (do
            (let source (sce-source-from-envelope compile-envelope))
            (let fkb (pif-descriptor-from-envelope pif))
            (if (not (rale-envelope? compile-envelope))
                (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-malformed-compile-envelope))
                (if (not (sad-source-valid? source))
                    (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-malformed-compile-envelope))
                    (if (not (sce-compile-envelope-ready? compile-envelope))
                        (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-non-compile-envelope))
                        (if (not (sce-compile-output? compile-output))
                            (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-malformed-compile-output))
                            (if (not (eq (sce-compile-output-writes-fkb? compile-output) 1))
                                (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-compile-output-does-not-write-fkb))
                                (if (not (eq (sce-compile-output-embeds-table-payload? compile-output) 1))
                                    (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-compile-output-missing-table-payload))
                                    (if (not (eq (sce-compile-output-no-c-growth? compile-output) 1))
                                        (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-compile-output-c-growth))
                                        (if (not (pif-envelope-shape-valid? pif))
                                            (scffe-refused-row compile-envelope compile-output pif witness dylib (scffe-reason-malformed-pif-envelope))
                                            (if (not (eq (pif-envelope-seal-ok pif) 1))
                                                (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-pif-seal-invalid))
                                                (if (not (pif-table-valid? (pif-envelope-table pif)))
                                                    (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-pif-table-invalid))
                                                    (if (not (sce-source-pif-match? source pif))
                                                        (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-source-identity-mismatch))
                                                        (if (not (sce-pif-current? source pif))
                                                            (scffe-investigate-row compile-envelope compile-output pif witness dylib (scffe-reason-pif-envelope-stale))
                                                            (scffe-after-pif-policy compile-envelope compile-output pif witness dylib source fkb))))))))))))))))
