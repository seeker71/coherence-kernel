; preludes: form/form-stdlib/core.fk, grammars/line-grammar.fk, grammars/bmf-core.fk, grammars/control-invite-grammar.fk
;
; control-invite-grammar-band -- the BMF control-invite grammar RECOGNIZES
; the eight native token invites inside free text and TRANSMUTES each match
; into a CONTROL-INVITE node, in order, skipping everything that is not an
; invite. Live-witnessed on the c-bootstrap fkwu (`fkwu --src`, no flatten,
; no walker) -- this grammar rests on bmf-core.fk's single-rule cursor
; matcher only, not the larger multi-rule bmf-grammar.fk engine.
;
; Verdict 1023 when every claim lands:
;   1    a bare invite with no surrounding text is recognized: "<CUT>" -> ("<CUT>")
;   2    an invite inside a longer utterance is found, text around it skipped
;   4    a stream of several DIFFERENT invites is recognized in ORDER
;   8    a stream with NO invites at all recognizes zero
;   16   the same tag repeated is counted correctly (not collapsed to one)
;   32   all eight tags are individually recognized (choice/cut/fail/stop/
;        undo/store/restore/timeout) -- the grammar's vocabulary is complete
;   64   every produced node carries the CONTROL-INVITE op as its category
;   128  cig-count tallies one specific tag across a mixed stream
;   256  a near-miss (a prefix of a real tag, not the tag itself) is NOT
;        recognized as an invite -- the literal match is exact, not fuzzy
;   512  invites separated by punctuation (no surrounding whitespace) still
;        match -- the cursor's literal match does not require word boundaries
(do
    (defn cib-score (cond bit) (if cond bit 0))

    (defn control-invite-grammar-band ()
        (do
            (let bare (cig-invites "<CUT>"))
            (let c1 (cib-score (and (eq (len bare) 1) (str_eq (head bare) "<CUT>")) 1))

            (let embedded (cig-invites "reasoning about it, <CHOICE> then continue"))
            (let c2 (cib-score (and (eq (len embedded) 1) (str_eq (head embedded) "<CHOICE>")) 2))

            (let seq (cig-invites "start <CHOICE> lane one <STORE> checkpoint <CUT> commit"))
            (let c3 (cib-score (and (eq (len seq) 3)
                                     (and (str_eq (nth seq 0) "<CHOICE>")
                                          (and (str_eq (nth seq 1) "<STORE>")
                                               (str_eq (nth seq 2) "<CUT>")))) 4))

            (let none (cig-invites "just an ordinary sentence with no invites in it"))
            (let c4 (cib-score (eq (len none) 0) 8))

            (let repeated (cig-invites "<TIMEOUT> retry <TIMEOUT> retry <TIMEOUT> give up"))
            (let c5 (cib-score (eq (len repeated) 3) 16))

            (let all8 (cig-invites "<CHOICE> <CUT> <FAIL> <STOP> <UNDO> <STORE> <RESTORE> <TIMEOUT>"))
            (let c6 (cib-score (eq (len all8) 8) 32))

            (let rule (cig-invite-rule))
            (let res (run-rule rule (cursor-str "<FAIL>")))
            (let c7 (cib-score (node_eq (node_category (run-node res)) (bp (cig-op))) 64))

            (let mixed (cig-invites "<CHOICE> then <FAIL> then <CHOICE> again"))
            (let c8 (cib-score (eq (cig-count "<CHOICE> then <FAIL> then <CHOICE> again" "<CHOICE>") 2) 128))

            ; "<CHOI" is a strict prefix of "<CHOICE>" and must NOT match --
            ; the literal is exact, so this stream carries zero invites.
            (let nearmiss (cig-invites "<CHOI incomplete tag, not an invite"))
            (let c9 (cib-score (eq (len nearmiss) 0) 256))

            (let punct (cig-invites "lane one,<CUT>lane two.<STOP>done"))
            (let c10 (cib-score (and (eq (len punct) 2)
                                      (and (str_eq (nth punct 0) "<CUT>")
                                           (str_eq (nth punct 1) "<STOP>"))) 512))

            (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 c10)))))))))))

    (control-invite-grammar-band)
)
