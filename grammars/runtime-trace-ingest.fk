; runtime-trace-ingest.fk -- Layer 10b trace evidence into learning rows.
;
; This layer consumes existing 9h4 join evidence and turns the carried trace
; into an observable learning/reasoning record. It does not produce runtime
; evidence, launch anything, load artifacts, mutate storage, install routes, or
; grow the C seed. A body lane result means freeze-eligible only.
;
; preludes: form-stdlib/core.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/runtime-program-image-fkb-capability-bound.fk form-stdlib/runtime-program-image-fkb-traced-capability-bound.fk

(do
    (defn rti-version () "runtime-trace-ingest-v1")

    (defn rti-feature (name status) (list "runtime-trace-ingest-feature" name status))
    (defn rti-feature-name (f) (nth f 1))
    (defn rti-feature-status (f) (nth f 2))
    (defn runtime-trace-ingest-manifest ()
        (list
            (rti-feature "layer-10b-learning-ingest-not-runtime" 1)
            (rti-feature "consumes-9h4-evidence-only" 1)
            (rti-feature "carried-trace-fields-preserved" 1)
            (rti-feature "9h4-provenance-preserved" 1)
            (rti-feature "memory-lane-separate-from-action" 1)
            (rti-feature "body-freeze-eligible-only-when-capability-bound" 1)
            (rti-feature "non-bound-rows-stay-liquid-witnessed" 1)
            (rti-feature "hard-statuses-become-high-priority-investigations" 1)
            (rti-feature "soft-statuses-become-repair-prompts" 1)
            (rti-feature "unknown-status-quarantines" 1)
            (rti-feature "malformed-evidence-refused" 1)
            (rti-feature "no-storage-mutation" 1)
            (rti-feature "no-artifact-load" 1)
            (rti-feature "no-native-call" 1)
            (rti-feature "no-selector-install" 1)
            (rti-feature "no-c-seed-growth" 1)))
    (defn runtime-trace-ingest-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rti-feature-name (head fs)) name)
                     (eq (rti-feature-status (head fs)) 1))
                1
                (runtime-trace-ingest-manifest-has? name (tail fs)))))

    (defn rti-memory-body () "body")
    (defn rti-memory-liquid () "liquid")
    (defn rti-memory-none () "none")

    (defn rti-action-witness () "witness")
    (defn rti-action-investigate () "investigate")
    (defn rti-action-quarantine () "quarantine")
    (defn rti-action-refused () "refused")

    (defn rti-prompt-body-freeze () "body-freeze-eligible")
    (defn rti-prompt-witness-only () "witness-only")
    (defn rti-prompt-oom () "oom-investigate")
    (defn rti-prompt-killed () "killed-investigate")
    (defn rti-prompt-stalled () "stall-investigate")
    (defn rti-prompt-timeout () "timeout-investigate")
    (defn rti-prompt-wrong-value () "wrong-value-investigate")
    (defn rti-prompt-loader-repair () "loader-repair")
    (defn rti-prompt-error-repair () "runtime-error-repair")
    (defn rti-prompt-unknown () "unknown-status-investigate")
    (defn rti-prompt-malformed () "malformed-evidence")

    (defn rti-reason-body-freeze-eligible () "body-freeze-eligible")
    (defn rti-reason-non-bound-witnessed () "non-bound-witnessed")
    (defn rti-reason-hard-runtime-investigate () "hard-runtime-investigate")
    (defn rti-reason-repair-runtime-investigate () "repair-runtime-investigate")
    (defn rti-reason-unknown-runtime-quarantine () "unknown-runtime-quarantine")
    (defn rti-reason-ok-stop-not-completed () "ok-stop-not-completed")
    (defn rti-reason-malformed-join () "malformed-join")
    (defn rti-reason-malformed-trace () "malformed-trace")
    (defn rti-reason-malformed-trace-bridge () "malformed-trace-bridge")
    (defn rti-reason-trace-not-ready () "trace-not-ready")
    (defn rti-reason-manifest ()
        (list
            (rti-reason-body-freeze-eligible)
            (rti-reason-non-bound-witnessed)
            (rti-reason-hard-runtime-investigate)
            (rti-reason-repair-runtime-investigate)
            (rti-reason-unknown-runtime-quarantine)
            (rti-reason-ok-stop-not-completed)
            (rti-reason-malformed-join)
            (rti-reason-malformed-trace)
            (rti-reason-malformed-trace-bridge)
            (rti-reason-trace-not-ready)))

    (defn rti-no-trace () (list "runtime-trace-ingest-no-trace"))
    (defn rti-status-none () "none")
    (defn rti-reason-none () "none")
    (defn rti-text-none () "")
    (defn rti-num-none () 0)

    ; record = ("runtime-trace-ingest-record" join trace artifact-path
    ;           source-hash content-hash entry-kind entry-index root-node
    ;           step-budget steps-used output-count first-value exit-code
    ;           trace-status stop-reason detail join-status join-reason
    ;           trace-bridge-status trace-bridge-reason capability-status
    ;           capability-reason top-attempt-present memory-lane action
    ;           prompt-class priority freeze-eligible reason)
    (defn rti-record-row (join trace artifact-path source-hash content-hash entry-kind entry-index root-node step-budget steps-used output-count first-value exit-code trace-status stop-reason detail join-status join-reason trace-bridge-status trace-bridge-reason capability-status capability-reason top-attempt-present memory-lane action prompt-class priority freeze-eligible reason)
        (list "runtime-trace-ingest-record"
              join trace artifact-path source-hash content-hash entry-kind
              entry-index root-node step-budget steps-used output-count
              first-value exit-code trace-status stop-reason detail
              join-status join-reason trace-bridge-status trace-bridge-reason
              capability-status capability-reason top-attempt-present
              memory-lane action prompt-class priority freeze-eligible reason))
    (defn rti-record? (r)
        (if (eq (len r) 30)
            (str_eq (nth r 0) "runtime-trace-ingest-record")
            0))
    (defn rti-record-join (r) (nth r 1))
    (defn rti-record-trace (r) (nth r 2))
    (defn rti-record-artifact-path (r) (nth r 3))
    (defn rti-record-source-hash (r) (nth r 4))
    (defn rti-record-content-hash (r) (nth r 5))
    (defn rti-record-entry-kind (r) (nth r 6))
    (defn rti-record-entry-index (r) (nth r 7))
    (defn rti-record-root-node (r) (nth r 8))
    (defn rti-record-step-budget (r) (nth r 9))
    (defn rti-record-steps-used (r) (nth r 10))
    (defn rti-record-output-count (r) (nth r 11))
    (defn rti-record-first-value (r) (nth r 12))
    (defn rti-record-exit-code (r) (nth r 13))
    (defn rti-record-trace-status (r) (nth r 14))
    (defn rti-record-stop-reason (r) (nth r 15))
    (defn rti-record-detail (r) (nth r 16))
    (defn rti-record-join-status (r) (nth r 17))
    (defn rti-record-join-reason (r) (nth r 18))
    (defn rti-record-trace-bridge-status (r) (nth r 19))
    (defn rti-record-trace-bridge-reason (r) (nth r 20))
    (defn rti-record-capability-status (r) (nth r 21))
    (defn rti-record-capability-reason (r) (nth r 22))
    (defn rti-record-top-attempt-present (r) (nth r 23))
    (defn rti-record-memory-lane (r) (nth r 24))
    (defn rti-record-action (r) (nth r 25))
    (defn rti-record-prompt-class (r) (nth r 26))
    (defn rti-record-priority (r) (nth r 27))
    (defn rti-record-freeze-eligible (r) (nth r 28))
    (defn rti-record-reason (r) (nth r 29))

    (defn rti-empty-record (join reason)
        (rti-record-row join (rti-no-trace)
                        (rti-text-none) (rti-text-none) (rti-text-none)
                        (rti-text-none) (rti-num-none) (rti-num-none)
                        (rti-num-none) (rti-num-none) (rti-num-none)
                        (rti-num-none) (rti-num-none)
                        (rti-status-none) (rti-status-none) (rti-text-none)
                        (rti-status-none) (rti-reason-none)
                        (rti-status-none) (rti-reason-none)
                        (rti-status-none) (rti-reason-none)
                        0
                        (rti-memory-none) (rti-action-refused)
                        (rti-prompt-malformed) 0 0 reason))

    (defn rti-join-bound? (join)
        (str_eq (rpiftc-join-status join) (rpiftc-status-bound)))
    (defn rti-ok-completed? (trace)
        (and (str_eq (rpiwt-trace-status trace) (rao-obs-ok))
             (str_eq (rpiwt-trace-stop-reason trace) (rpiwt-stop-completed))))
    (defn rti-ok-not-completed? (trace)
        (and (str_eq (rpiwt-trace-status trace) (rao-obs-ok))
             (not (str_eq (rpiwt-trace-stop-reason trace) (rpiwt-stop-completed)))))
    (defn rti-hard-status? (trace)
        (rao-hard-status? (rpiwt-trace-status trace)))
    (defn rti-soft-status? (trace)
        (rao-soft-status? (rpiwt-trace-status trace)))

    (defn rti-capability-status (join)
        (do
            (let cap (rpiftc-join-capability-join join))
            (if (rpifc-join? cap) (rpifc-join-status cap) (rti-status-none))))
    (defn rti-capability-reason (join)
        (do
            (let cap (rpiftc-join-capability-join join))
            (if (rpifc-join? cap) (rpifc-join-reason cap) (rti-reason-none))))
    (defn rti-top-attempt-present? (join)
        (if (rpiftc-no-attempt? (rpiftc-join-attempt join)) 0 1))

    (defn rti-prompt-for-hard (trace)
        (if (str_eq (rpiwt-trace-status trace) (rao-obs-oom-killed))
            (rti-prompt-oom)
            (if (str_eq (rpiwt-trace-status trace) (rao-obs-killed))
                (rti-prompt-killed)
                (if (str_eq (rpiwt-trace-status trace) (rao-obs-stalled))
                    (rti-prompt-stalled)
                    (if (str_eq (rpiwt-trace-status trace) (rao-obs-timeout))
                        (rti-prompt-timeout)
                        (rti-prompt-wrong-value))))))
    (defn rti-prompt-for-soft (trace)
        (if (str_eq (rpiwt-trace-status trace) (rao-obs-loader-missing))
            (rti-prompt-loader-repair)
            (rti-prompt-error-repair)))

    (defn rti-memory-for (join trace)
        (if (and (rti-join-bound? join) (rti-ok-completed? trace))
            (rti-memory-body)
            (if (or (rti-ok-completed? trace)
                    (or (eq (rti-hard-status? trace) 1)
                        (eq (rti-soft-status? trace) 1)))
                (rti-memory-liquid)
                (rti-memory-none))))
    (defn rti-action-for (join trace)
        (if (rti-ok-completed? trace)
            (rti-action-witness)
            (if (eq (rti-hard-status? trace) 1)
                (rti-action-investigate)
                (if (eq (rti-soft-status? trace) 1)
                    (rti-action-investigate)
                    (rti-action-quarantine)))))
    (defn rti-prompt-for (join trace)
        (if (rti-ok-completed? trace)
            (if (rti-join-bound? join)
                (rti-prompt-body-freeze)
                (rti-prompt-witness-only))
            (if (eq (rti-hard-status? trace) 1)
                (rti-prompt-for-hard trace)
                (if (eq (rti-soft-status? trace) 1)
                    (rti-prompt-for-soft trace)
                    (rti-prompt-unknown)))))
    (defn rti-priority-for (trace)
        (if (eq (rti-hard-status? trace) 1)
            100
            (if (eq (rti-soft-status? trace) 1)
                60
                (if (rti-ok-completed? trace) 10 40))))
    (defn rti-freeze-eligible-for (join trace)
        (if (and (rti-join-bound? join) (rti-ok-completed? trace)) 1 0))
    (defn rti-reason-for (join trace)
        (if (rti-ok-completed? trace)
            (if (rti-join-bound? join)
                (rti-reason-body-freeze-eligible)
                (rti-reason-non-bound-witnessed))
            (if (rti-ok-not-completed? trace)
                (rti-reason-ok-stop-not-completed)
                (if (eq (rti-hard-status? trace) 1)
                    (rti-reason-hard-runtime-investigate)
                    (if (eq (rti-soft-status? trace) 1)
                        (rti-reason-repair-runtime-investigate)
                        (rti-reason-unknown-runtime-quarantine))))))

    (defn rti-record-from-valid (join)
        (do
            (let trace (rpiftc-join-trace join))
            (let bridge (rpiftc-join-trace-bridge join))
            (rti-record-row join trace
                        (rpiwt-trace-artifact-path trace)
                        (rpiwt-trace-source-hash trace)
                        (rpiwt-trace-content-hash trace)
                        (rpiwt-trace-entry-kind trace)
                        (rpiwt-trace-entry-index trace)
                        (rpiwt-trace-root-node trace)
                        (rpiwt-trace-step-budget trace)
                        (rpiwt-trace-steps-used trace)
                        (rpiwt-trace-output-count trace)
                        (rpiwt-trace-first-value trace)
                        (rpiwt-trace-exit-code trace)
                        (rpiwt-trace-status trace)
                        (rpiwt-trace-stop-reason trace)
                        (rpiwt-trace-detail trace)
                        (rpiftc-join-status join)
                        (rpiftc-join-reason join)
                        (rpiwt-bridge-status bridge)
                        (rpiwt-bridge-reason bridge)
                        (rti-capability-status join)
                        (rti-capability-reason join)
                        (rti-top-attempt-present? join)
                        (rti-memory-for join trace)
                        (rti-action-for join trace)
                        (rti-prompt-for join trace)
                        (rti-priority-for trace)
                        (rti-freeze-eligible-for join trace)
                        (rti-reason-for join trace))))
    (defn rti-record-from-trace-refused (join reason)
        (do
            (let trace (rpiftc-join-trace join))
            (let bridge (rpiftc-join-trace-bridge join))
            (rti-record-row join trace
                        (rpiwt-trace-artifact-path trace)
                        (rpiwt-trace-source-hash trace)
                        (rpiwt-trace-content-hash trace)
                        (rpiwt-trace-entry-kind trace)
                        (rpiwt-trace-entry-index trace)
                        (rpiwt-trace-root-node trace)
                        (rpiwt-trace-step-budget trace)
                        (rpiwt-trace-steps-used trace)
                        (rpiwt-trace-output-count trace)
                        (rpiwt-trace-first-value trace)
                        (rpiwt-trace-exit-code trace)
                        (rpiwt-trace-status trace)
                        (rpiwt-trace-stop-reason trace)
                        (rpiwt-trace-detail trace)
                        (rpiftc-join-status join)
                        (rpiftc-join-reason join)
                        (if (rpiwt-bridge? bridge) (rpiwt-bridge-status bridge) (rti-status-none))
                        (if (rpiwt-bridge? bridge) (rpiwt-bridge-reason bridge) (rti-reason-none))
                        (rti-capability-status join)
                        (rti-capability-reason join)
                        (rti-top-attempt-present? join)
                        (rti-memory-none)
                        (rti-action-refused)
                        (rti-prompt-malformed)
                        0
                        0
                        reason)))

    (defn rti-record-from-join (join)
        (if (not (rpiftc-join? join))
            (rti-empty-record join (rti-reason-malformed-join))
            (do
                (let trace (rpiftc-join-trace join))
                (let bridge (rpiftc-join-trace-bridge join))
                (if (not (rpiwt-trace? trace))
                    (rti-empty-record join (rti-reason-malformed-trace))
                    (if (not (rpiwt-bridge? bridge))
                        (rti-record-from-trace-refused join (rti-reason-malformed-trace-bridge))
                        (if (not (str_eq (rpiwt-bridge-status bridge) (rpiwt-status-trace-ready)))
                            (rti-record-from-trace-refused join (rti-reason-trace-not-ready))
                            (rti-record-from-valid join)))))))
)
