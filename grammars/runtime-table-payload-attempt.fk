; runtime-table-payload-attempt.fk -- table-payload witness adapter into 9f attempts.
;
; This layer binds a request-ready program-image envelope, a valid 8h program
; image envelope, an exact 8i table-payload witness, and a supplied table-run row.
; When they match, it emits the 9f supplied-attempt row. It does not execute
; the table, walk binary program images, call native artifacts, install a
; selector, or grow the C seed.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/runtime-artifact-attempt-receipt.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-table-payload-emit.fk

(do
    (defn rtta-version () "runtime-table-payload-attempt-v1")

    (defn rtta-feature (name status) (list "runtime-table-payload-attempt-feature" name status))
    (defn rtta-feature-name (f) (nth f 1))
    (defn rtta-feature-status (f) (nth f 2))
    (defn runtime-table-payload-attempt-manifest ()
        (list
            (rtta-feature "table-payload-attempt-adapter-not-execution" 1)
            (rtta-feature "supplied-table-run-only" 1)
            (rtta-feature "binds-9e-8h-8i" 1)
            (rtta-feature "table-payload-witness-marker" 1)
            (rtta-feature "attempt-detail-marks-table-payload" 1)
            (rtta-feature "identity-from-rale-envelope" 1)
            (rtta-feature "text-equality-before-attempt" 1)
            (rtta-feature "table-path-bound-to-witness-path" 1)
            (rtta-feature "ok-requires-output-line" 1)
            (rtta-feature "hard-and-unknown-status-preserved" 1)
            (rtta-feature "oom-killed-investigates-through-9c" 1)
            (rtta-feature "no-binary-artifact-io" 1)
            (rtta-feature "no-program-image-load" 1)
            (rtta-feature "no-native-call" 1)
            (rtta-feature "no-selector-install" 1)
            (rtta-feature "no-c-seed-growth" 1)
            (rtta-feature "future-9h-still-pending" 1)))
    (defn runtime-table-payload-attempt-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rtta-feature-name (head fs)) name)
                     (eq (rtta-feature-status (head fs)) 1))
                1
                (runtime-table-payload-attempt-manifest-has? name (tail fs)))))

    (defn rtta-status-attempt-ready () "attempt-ready")
    (defn rtta-status-investigate () "investigate")
    (defn rtta-status-refused () "refused")

    (defn rtta-reason-table-run-bound () "table-run-bound")
    (defn rtta-reason-malformed-envelope () "malformed-envelope")
    (defn rtta-reason-non-program-image-envelope () "non-program-image-envelope")
    (defn rtta-reason-malformed-pif-envelope () "malformed-pif-envelope")
    (defn rtta-reason-invalid-pif-envelope () "invalid-pif-envelope")
    (defn rtta-reason-artifact-identity-mismatch () "artifact-identity-mismatch")
    (defn rtta-reason-malformed-witness () "malformed-table-payload-witness")
    (defn rtta-reason-empty-witness-text () "empty-witness-text")
    (defn rtta-reason-table-payload-mismatch () "table-payload-mismatch")
    (defn rtta-reason-malformed-table-run () "malformed-table-run")
    (defn rtta-reason-table-path-mismatch () "table-path-mismatch")
    (defn rtta-reason-empty-output () "empty-output")
    (defn rtta-reason-manifest ()
        (list
            (rtta-reason-table-run-bound)
            (rtta-reason-malformed-envelope)
            (rtta-reason-non-program-image-envelope)
            (rtta-reason-malformed-pif-envelope)
            (rtta-reason-invalid-pif-envelope)
            (rtta-reason-artifact-identity-mismatch)
            (rtta-reason-malformed-witness)
            (rtta-reason-empty-witness-text)
            (rtta-reason-table-payload-mismatch)
            (rtta-reason-malformed-table-run)
            (rtta-reason-table-path-mismatch)
            (rtta-reason-empty-output)))

    (defn rtta-table-payload-marker () "table-payload-witness")

    ; witness = ("runtime-table-payload-witness" table-path table-payload)
    (defn rtta-table-payload-witness (table-path table-payload)
        (list "runtime-table-payload-witness" table-path table-payload))
    (defn rtta-table-payload-witness? (w)
        (if (eq (len w) 3)
            (str_eq (nth w 0) "runtime-table-payload-witness")
            0))
    (defn rtta-witness-path (w) (nth w 1))
    (defn rtta-witness-text (w) (nth w 2))

    ; run = ("runtime-table-payload-supplied-run" table-path first-value
    ;        line-count exit-code status detail)
    (defn rtta-supplied-table-run (table-path first-value line-count exit-code status detail)
        (list "runtime-table-payload-supplied-run" table-path first-value
              line-count exit-code status detail))
    (defn rtta-supplied-table-run? (r)
        (if (eq (len r) 7)
            (str_eq (nth r 0) "runtime-table-payload-supplied-run")
            0))
    (defn rtta-run-path (r) (nth r 1))
    (defn rtta-run-first-value (r) (nth r 2))
    (defn rtta-run-line-count (r) (nth r 3))
    (defn rtta-run-exit-code (r) (nth r 4))
    (defn rtta-run-status (r) (nth r 5))
    (defn rtta-run-detail (r) (nth r 6))

    ; bridge = ("runtime-table-payload-attempt-bridge" envelope pif witness run
    ;           attempt status reason)
    (defn rtta-bridge-receipt (envelope pif-envelope witness run attempt status reason)
        (list "runtime-table-payload-attempt-bridge" envelope pif-envelope
              witness run attempt status reason))
    (defn rtta-bridge? (b)
        (if (eq (len b) 8)
            (str_eq (nth b 0) "runtime-table-payload-attempt-bridge")
            0))
    (defn rtta-bridge-envelope (b) (nth b 1))
    (defn rtta-bridge-pif-envelope (b) (nth b 2))
    (defn rtta-bridge-witness (b) (nth b 3))
    (defn rtta-bridge-run (b) (nth b 4))
    (defn rtta-bridge-attempt (b) (nth b 5))
    (defn rtta-bridge-status (b) (nth b 6))
    (defn rtta-bridge-reason (b) (nth b 7))

    (defn rtta-no-attempt () (raar-no-attempt))
    (defn rtta-no-attempt? (a) (raar-no-attempt? a))
    (defn rtta-investigate (envelope pif-envelope witness run reason)
        (rtta-bridge-receipt envelope pif-envelope witness run
                             (rtta-no-attempt)
                             (rtta-status-investigate)
                             reason))
    (defn rtta-refused (envelope pif-envelope witness run reason)
        (rtta-bridge-receipt envelope pif-envelope witness run
                             (rtta-no-attempt)
                             (rtta-status-refused)
                             reason))

    (defn rtta-program-image-envelope? (envelope)
        (if (rale-envelope? envelope)
            (if (str_eq (rale-envelope-status envelope) (rale-status-request-ready))
                (if (str_eq (rale-envelope-action envelope) (rap-act-run-program-image))
                    (if (eq (rale-envelope-route envelope) (sac-run-fkb))
                        (str_eq (rale-envelope-artifact-kind envelope) (sad-kind-program-image-fkb))
                        0)
                    0)
                0)
            0))
    (defn rtta-pif-matches-envelope? (envelope pif-envelope)
        (if (pif-envelope-valid? pif-envelope)
            (if (str_eq (pif-envelope-artifact-path pif-envelope) (rale-envelope-artifact-path envelope))
                (if (str_eq (pif-envelope-source-hash pif-envelope) (rale-envelope-source-hash envelope))
                    (str_eq (pif-envelope-content-hash pif-envelope) (rale-envelope-content-hash envelope))
                    0)
                0)
            0))
    (defn rtta-witness-valid? (witness)
        (if (rtta-table-payload-witness? witness)
            (if (gt (str_len (rtta-witness-path witness)) 0)
                (gt (str_len (rtta-witness-text witness)) 0)
                0)
            0))
    (defn rtta-witness-matches-pif? (witness pif-envelope)
        (if (rtta-witness-valid? witness)
            (str_eq (rtta-witness-text witness) (pite-table-payload-from-envelope pif-envelope))
            0))
    (defn rtta-run-readable? (run)
        (if (rtta-supplied-table-run? run)
            (if (gt (str_len (rtta-run-path run)) 0)
                (ge (rtta-run-line-count run) 0)
                0)
            0))
    (defn rtta-run-ok-empty-output? (run)
        (and (str_eq (rtta-run-status run) (rao-obs-ok))
             (eq (rtta-run-line-count run) 0)))
    (defn rtta-run-path-matches-witness? (run witness)
        (str_eq (rtta-run-path run) (rtta-witness-path witness)))

    (defn rtta-attempt-detail (run)
        (str_concat (rtta-table-payload-marker)
            (str_concat " first="
            (str_concat (int_to_str (rtta-run-first-value run))
            (str_concat " lines="
            (str_concat (int_to_str (rtta-run-line-count run))
            (str_concat " detail=" (rtta-run-detail run)))))))
    )
    (defn rtta-attempt-from-run (envelope run)
        (raar-supplied-attempt
            (rale-envelope-action envelope)
            (rale-envelope-route envelope)
            (rale-envelope-artifact-kind envelope)
            (rale-envelope-artifact-path envelope)
            (rale-envelope-source-hash envelope)
            (rale-envelope-content-hash envelope)
            (rtta-run-status run)
            (rtta-attempt-detail run)
            (rtta-run-exit-code run)))
    (defn rtta-attempt-ready (envelope pif-envelope witness run)
        (rtta-bridge-receipt envelope pif-envelope witness run
                             (rtta-attempt-from-run envelope run)
                             (rtta-status-attempt-ready)
                             (rtta-reason-table-run-bound)))

    (defn rtta-bridge-from-run (envelope pif-envelope witness run)
        (if (not (rale-envelope? envelope))
            (rtta-refused envelope pif-envelope witness run (rtta-reason-malformed-envelope))
            (if (not (rtta-program-image-envelope? envelope))
                (rtta-investigate envelope pif-envelope witness run (rtta-reason-non-program-image-envelope))
                (if (not (pif-envelope? pif-envelope))
                    (rtta-refused envelope pif-envelope witness run (rtta-reason-malformed-pif-envelope))
                    (if (not (pif-envelope-valid? pif-envelope))
                        (rtta-investigate envelope pif-envelope witness run (rtta-reason-invalid-pif-envelope))
                        (if (not (rtta-pif-matches-envelope? envelope pif-envelope))
                            (rtta-investigate envelope pif-envelope witness run (rtta-reason-artifact-identity-mismatch))
                            (if (not (rtta-table-payload-witness? witness))
                                (rtta-refused envelope pif-envelope witness run (rtta-reason-malformed-witness))
                                (if (not (rtta-witness-valid? witness))
                                    (rtta-investigate envelope pif-envelope witness run (rtta-reason-empty-witness-text))
                                    (if (not (rtta-witness-matches-pif? witness pif-envelope))
                                        (rtta-investigate envelope pif-envelope witness run (rtta-reason-table-payload-mismatch))
                                        (if (not (rtta-run-readable? run))
                                            (rtta-refused envelope pif-envelope witness run (rtta-reason-malformed-table-run))
                                            (if (not (rtta-run-path-matches-witness? run witness))
                                                (rtta-investigate envelope pif-envelope witness run (rtta-reason-table-path-mismatch))
                                                (if (rtta-run-ok-empty-output? run)
                                                    (rtta-investigate envelope pif-envelope witness run (rtta-reason-empty-output))
                                                    (rtta-attempt-ready envelope pif-envelope witness run)))))))))))))
)
