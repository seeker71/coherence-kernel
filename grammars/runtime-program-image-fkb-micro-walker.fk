; runtime-program-image-fkb-micro-walker.fk -- Layer 9h5 real PIF trace producer.
;
; Layer 9h5 is the first real trace producer after the terminal supplied-
; evidence 9h4 join. It consumes a request-ready program-image envelope plus an
; admitted byte-decoded PIF admission, walks the admitted in-memory PIF table
; with bounded fuel, and emits an existing rpiwt trace row plus a micro-walk
; receipt. It does not accept supplied runs, supplied traces, bridges, joins,
; host execution, artifact IO, selector mutation, or C-seed growth.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk

(do
    (defn rpmw-version () "runtime-program-image-fkb-micro-walker-v1")

    (defn rpmw-feature (name status) (list "runtime-program-image-fkb-micro-walker-feature" name status))
    (defn rpmw-feature-name (f) (nth f 1))
    (defn rpmw-feature-status (f) (nth f 2))
    (defn runtime-program-image-fkb-micro-walker-manifest ()
        (list
            (rpmw-feature "layer-9h5-first-real-trace-producer-after-9h4" 1)
            (rpmw-feature "9h4-remains-terminal-supplied-evidence-join" 1)
            (rpmw-feature "consumes-9e-envelope-and-8h6-admission-only" 1)
            (rpmw-feature "computes-trace-from-admitted-pif-table" 1)
            (rpmw-feature "bounded-fuel-every-recursive-walk" 1)
            (rpmw-feature "function-root-entry-only" 1)
            (rpmw-feature "flat-row-semantics-pinned" 1)
            (rpmw-feature "lit-add-sub-mul-le-if-subset" 1)
            (rpmw-feature "unsupported-tags-are-loud-errors" 1)
            (rpmw-feature "child-range-errors-are-loud" 1)
            (rpmw-feature "budget-exhaustion-is-timeout-trace" 1)
            (rpmw-feature "emits-rpiwt-trace-row" 1)
            (rpmw-feature "emits-micro-walk-receipt" 1)
            (rpmw-feature "no-supplied-run-or-trace-input" 1)
            (rpmw-feature "no-bridge-or-join-consumption" 1)
            (rpmw-feature "no-artifact-io" 1)
            (rpmw-feature "no-host-or-native-execution" 1)
            (rpmw-feature "no-generated-table-authority" 1)
            (rpmw-feature "no-selector-storage-or-champion-mutation" 1)
            (rpmw-feature "no-c-seed-growth" 1)))
    (defn runtime-program-image-fkb-micro-walker-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rpmw-feature-name (head fs)) name)
                     (eq (rpmw-feature-status (head fs)) 1))
                1
                (runtime-program-image-fkb-micro-walker-manifest-has? name (tail fs)))))

    (defn rpmw-status-trace-produced () "trace-produced")
    (defn rpmw-status-refused () "refused")

    (defn rpmw-reason-walk-completed () "walk-completed")
    (defn rpmw-reason-step-budget-exhausted () "step-budget-exhausted")
    (defn rpmw-reason-unsupported-tag () "unsupported-tag")
    (defn rpmw-reason-child-out-of-range () "child-out-of-range")
    (defn rpmw-reason-malformed-envelope () "malformed-envelope")
    (defn rpmw-reason-non-program-image-envelope () "non-program-image-envelope")
    (defn rpmw-reason-malformed-admission () "malformed-admission")
    (defn rpmw-reason-non-admitted-admission () "non-admitted-admission")
    (defn rpmw-reason-admission-decode-not-decoded () "admission-decode-not-decoded")
    (defn rpmw-reason-admission-invalid-pif () "admission-invalid-pif")
    (defn rpmw-reason-admission-decode-pif-mismatch () "admission-decode-pif-mismatch")
    (defn rpmw-reason-artifact-identity-mismatch () "artifact-identity-mismatch")
    (defn rpmw-reason-negative-entry-index () "negative-entry-index")
    (defn rpmw-reason-entry-index-out-of-range () "entry-index-out-of-range")
    (defn rpmw-reason-root-node-out-of-range () "root-node-out-of-range")
    (defn rpmw-reason-negative-step-budget () "negative-step-budget")
    (defn rpmw-reason-manifest ()
        (list
            (rpmw-reason-walk-completed)
            (rpmw-reason-step-budget-exhausted)
            (rpmw-reason-unsupported-tag)
            (rpmw-reason-child-out-of-range)
            (rpmw-reason-malformed-envelope)
            (rpmw-reason-non-program-image-envelope)
            (rpmw-reason-malformed-admission)
            (rpmw-reason-non-admitted-admission)
            (rpmw-reason-admission-decode-not-decoded)
            (rpmw-reason-admission-invalid-pif)
            (rpmw-reason-admission-decode-pif-mismatch)
            (rpmw-reason-artifact-identity-mismatch)
            (rpmw-reason-negative-entry-index)
            (rpmw-reason-entry-index-out-of-range)
            (rpmw-reason-root-node-out-of-range)
            (rpmw-reason-negative-step-budget)))

    (defn rpmw-no-trace () (list "runtime-program-image-fkb-micro-walker-no-trace"))
    (defn rpmw-no-result () (list "runtime-program-image-fkb-micro-walker-no-result"))
    (defn rpmw-marker () "program-image-fkb-micro-walker")
    (defn rpmw-detail (reason)
        (str_concat (rpmw-marker) (str_concat " reason=" reason)))

    ; result = ("runtime-program-image-fkb-micro-walker-result" value steps
    ;           trace-status stop-reason reason detail)
    (defn rpmw-result-row (value steps trace-status stop-reason reason detail)
        (list "runtime-program-image-fkb-micro-walker-result"
              value steps trace-status stop-reason reason detail))
    (defn rpmw-result? (r)
        (if (eq (len r) 7)
            (str_eq (nth r 0) "runtime-program-image-fkb-micro-walker-result")
            0))
    (defn rpmw-result-value (r) (nth r 1))
    (defn rpmw-result-steps (r) (nth r 2))
    (defn rpmw-result-trace-status (r) (nth r 3))
    (defn rpmw-result-stop-reason (r) (nth r 4))
    (defn rpmw-result-reason (r) (nth r 5))
    (defn rpmw-result-detail (r) (nth r 6))
    (defn rpmw-result-ok? (r)
        (if (rpmw-result? r)
            (str_eq (rpmw-result-trace-status r) (rao-obs-ok))
            0))
    (defn rpmw-result-ok (value steps)
        (rpmw-result-row value steps (rao-obs-ok) (rpiwt-stop-completed)
                         (rpmw-reason-walk-completed)
                         (rpmw-detail (rpmw-reason-walk-completed))))
    (defn rpmw-result-timeout (steps)
        (rpmw-result-row 0 steps (rao-obs-timeout) (rpiwt-stop-timeout)
                         (rpmw-reason-step-budget-exhausted)
                         (rpmw-detail (rpmw-reason-step-budget-exhausted))))
    (defn rpmw-result-error (steps reason)
        (rpmw-result-row 0 steps (rao-obs-error) (rpiwt-stop-error)
                         reason (rpmw-detail reason)))
    (defn rpmw-result-add-parent (r)
        (rpmw-result-row (rpmw-result-value r)
                         (add 1 (rpmw-result-steps r))
                         (rpmw-result-trace-status r)
                         (rpmw-result-stop-reason r)
                         (rpmw-result-reason r)
                         (rpmw-result-detail r)))

    ; receipt = ("runtime-program-image-fkb-micro-walker" envelope admission
    ;            entry-index root-node step-budget input-value trace result
    ;            status reason)
    (defn rpmw-receipt-row (envelope admission entry-index root-node step-budget input-value trace result status reason)
        (list "runtime-program-image-fkb-micro-walker"
              envelope admission entry-index root-node step-budget input-value
              trace result status reason))
    (defn rpmw-receipt? (r)
        (if (eq (len r) 11)
            (str_eq (nth r 0) "runtime-program-image-fkb-micro-walker")
            0))
    (defn rpmw-receipt-envelope (r) (nth r 1))
    (defn rpmw-receipt-admission (r) (nth r 2))
    (defn rpmw-receipt-entry-index (r) (nth r 3))
    (defn rpmw-receipt-root-node (r) (nth r 4))
    (defn rpmw-receipt-step-budget (r) (nth r 5))
    (defn rpmw-receipt-input-value (r) (nth r 6))
    (defn rpmw-receipt-trace (r) (nth r 7))
    (defn rpmw-receipt-result (r) (nth r 8))
    (defn rpmw-receipt-status (r) (nth r 9))
    (defn rpmw-receipt-reason (r) (nth r 10))
    (defn rpmw-refused (envelope admission entry-index step-budget input-value reason)
        (rpmw-receipt-row envelope admission entry-index -1 step-budget input-value
                          (rpmw-no-trace) (rpmw-no-result)
                          (rpmw-status-refused) reason))
    (defn rpmw-produced (envelope admission entry-index root-node step-budget input-value trace result)
        (rpmw-receipt-row envelope admission entry-index root-node step-budget input-value
                          trace result (rpmw-status-trace-produced)
                          (rpmw-result-reason result)))

    (defn rpmw-program-image-envelope? (envelope)
        (if (rale-envelope? envelope)
            (if (str_eq (rale-envelope-status envelope) (rale-status-request-ready))
                (if (str_eq (rale-envelope-action envelope) (rap-act-run-program-image))
                    (if (eq (rale-envelope-route envelope) (sac-run-fkb))
                        (str_eq (rale-envelope-artifact-kind envelope) (sad-kind-program-image-fkb))
                        0)
                    0)
                0)
            0))
    (defn rpmw-admission-status-admitted? (admission)
        (if (pifbd-admission? admission)
            (and (str_eq (pifbd-admission-status admission) (pifbd-status-admitted))
                 (str_eq (pifbd-admission-reason admission) (pifbd-reason-admitted)))
            0))
    (defn rpmw-admission-decode-decoded? (admission)
        (if (pifbd-admission? admission)
            (pifbd-decoded? (pifbd-admission-decode admission))
            0))
    (defn rpmw-admission-pif-valid? (admission)
        (if (pifbd-admission? admission)
            (pif-envelope-valid? (pifbd-admission-pif admission))
            0))
    (defn rpmw-admission-decode-matches-pif? (admission)
        (if (and (rpmw-admission-decode-decoded? admission)
                 (rpmw-admission-pif-valid? admission))
            (do
                (let payload (pifbd-decode-payload (pifbd-admission-decode admission)))
                (let pif (pifbd-admission-pif admission))
                (and (pifbd-payload-source-matches-pif? payload pif)
                (and (pifbd-payload-artifact-path-matches-pif? payload pif)
                (and (pifbd-payload-seal-matches-pif? payload pif)
                (and (pifbd-payload-table-matches-pif? payload pif)
                     (pifbd-payload-symbol-matches-pif? payload pif))))))
            0))
    (defn rpmw-pif-matches-envelope? (envelope pif)
        (if (pif-envelope-valid? pif)
            (if (str_eq (pif-envelope-artifact-path pif) (rale-envelope-artifact-path envelope))
                (if (str_eq (pif-envelope-source-hash pif) (rale-envelope-source-hash envelope))
                    (str_eq (pif-envelope-content-hash pif) (rale-envelope-content-hash envelope))
                    0)
                0)
            0))

    (defn rpmw-node-row (table node-id)
        (nth (pif-table-node-rows table) node-id))
    (defn rpmw-row-tag (row) (nth row 0))
    (defn rpmw-row-a (row) (nth row 1))
    (defn rpmw-row-b (row) (nth row 2))
    (defn rpmw-row-c (row) (nth row 3))
    (defn rpmw-node-id-valid? (table node-id)
        (if (ge node-id 0)
            (lt node-id (pif-table-nr table))
            0))
    (defn rpmw-entry-index-valid? (table entry-index)
        (if (ge entry-index 0)
            (lt entry-index (pif-table-nf table))
            0))
    (defn rpmw-binary-child-valid? (table row)
        (and (rpmw-node-id-valid? table (rpmw-row-a row))
             (rpmw-node-id-valid? table (rpmw-row-b row))))
    (defn rpmw-if-child-valid? (table row)
        (and (rpmw-node-id-valid? table (rpmw-row-a row))
        (and (rpmw-node-id-valid? table (rpmw-row-b row))
             (rpmw-node-id-valid? table (rpmw-row-c row)))))
    (defn rpmw-binary-value (tag left right)
        (if (eq tag 3)
            (add left right)
            (if (eq tag 4)
                (sub left right)
                (if (eq tag 42)
                    (mul left right)
                    (if (eq tag 5)
                        (if (le left right) 1 0)
                        0)))))
    (defn rpmw-binary-supported? (tag)
        (if (eq tag 3) 1
            (if (eq tag 4) 1
                (if (eq tag 42) 1
                    (if (eq tag 5) 1 0)))))

    (defn rpmw-eval-binary-after-left (table row budget input-value left)
        (if (not (rpmw-result-ok? left))
            (rpmw-result-add-parent left)
            (do
                (let remaining (sub (sub budget 1) (rpmw-result-steps left)))
                (if (le remaining 0)
                    (rpmw-result-timeout (add 1 (rpmw-result-steps left)))
                    (do
                        (let right (rpmw-eval-node table (rpmw-row-b row) remaining input-value))
                        (if (not (rpmw-result-ok? right))
                            (rpmw-result-row (rpmw-result-value right)
                                             (add 1 (add (rpmw-result-steps left) (rpmw-result-steps right)))
                                             (rpmw-result-trace-status right)
                                             (rpmw-result-stop-reason right)
                                             (rpmw-result-reason right)
                                             (rpmw-result-detail right))
                            (rpmw-result-ok
                                (rpmw-binary-value (rpmw-row-tag row)
                                                   (rpmw-result-value left)
                                                   (rpmw-result-value right))
                                (add 1 (add (rpmw-result-steps left) (rpmw-result-steps right))))))))))
    (defn rpmw-eval-binary (table row budget input-value)
        (if (not (rpmw-binary-child-valid? table row))
            (rpmw-result-error 1 (rpmw-reason-child-out-of-range))
            (rpmw-eval-binary-after-left table row budget input-value
                                         (rpmw-eval-node table (rpmw-row-a row) (sub budget 1) input-value))))

    (defn rpmw-eval-if-after-cond (table row budget input-value cond)
        (if (not (rpmw-result-ok? cond))
            (rpmw-result-add-parent cond)
            (do
                (let remaining (sub (sub budget 1) (rpmw-result-steps cond)))
                (if (le remaining 0)
                    (rpmw-result-timeout (add 1 (rpmw-result-steps cond)))
                    (do
                        (let branch (if (eq (rpmw-result-value cond) 0) (rpmw-row-c row) (rpmw-row-b row)))
                        (let out (rpmw-eval-node table branch remaining input-value))
                        (if (not (rpmw-result-ok? out))
                            (rpmw-result-row (rpmw-result-value out)
                                             (add 1 (add (rpmw-result-steps cond) (rpmw-result-steps out)))
                                             (rpmw-result-trace-status out)
                                             (rpmw-result-stop-reason out)
                                             (rpmw-result-reason out)
                                             (rpmw-result-detail out))
                            (rpmw-result-ok (rpmw-result-value out)
                                            (add 1 (add (rpmw-result-steps cond) (rpmw-result-steps out))))))))))
    (defn rpmw-eval-if (table row budget input-value)
        (if (not (rpmw-if-child-valid? table row))
            (rpmw-result-error 1 (rpmw-reason-child-out-of-range))
            (rpmw-eval-if-after-cond table row budget input-value
                                     (rpmw-eval-node table (rpmw-row-a row) (sub budget 1) input-value))))

    (defn rpmw-eval-node (table node-id budget input-value)
        (if (le budget 0)
            (rpmw-result-timeout 0)
            (if (not (rpmw-node-id-valid? table node-id))
                (rpmw-result-error 0 (rpmw-reason-child-out-of-range))
                (do
                    (let row (rpmw-node-row table node-id))
                    (let tag (rpmw-row-tag row))
                    (if (eq tag 1)
                        (rpmw-result-ok (rpmw-row-a row) 1)
                        (if (eq tag 2)
                            (rpmw-result-ok input-value 1)
                            (if (rpmw-binary-supported? tag)
                                (rpmw-eval-binary table row budget input-value)
                                (if (eq tag 6)
                                    (rpmw-eval-if table row budget input-value)
                                    (rpmw-result-error 1 (rpmw-reason-unsupported-tag))))))))))

    (defn rpmw-trace-from-result (envelope pif entry-index root-node step-budget result)
        (rpiwt-trace (rale-envelope-artifact-path envelope)
                     (pif-envelope-source-hash pif)
                     (pif-envelope-content-hash pif)
                     (rpiwt-entry-kind-function-root)
                     entry-index
                     root-node
                     step-budget
                     (rpmw-result-steps result)
                     (if (rpmw-result-ok? result) 1 0)
                     (if (rpmw-result-ok? result) (rpmw-result-value result) 0)
                     (if (rpmw-result-ok? result) 0 (if (str_eq (rpmw-result-trace-status result) (rao-obs-timeout)) 124 1))
                     (rpmw-result-trace-status result)
                     (rpmw-result-stop-reason result)
                     (rpmw-result-detail result)))

    (defn rpmw-walk-after-valid-entry (envelope admission entry-index step-budget input-value pif root-node)
        (do
            (let result (rpmw-eval-node (pif-envelope-table pif) root-node step-budget input-value))
            (let trace (rpmw-trace-from-result envelope pif entry-index root-node step-budget result))
            (rpmw-produced envelope admission entry-index root-node step-budget input-value trace result)))
    (defn rpmw-walk-after-ready (envelope admission entry-index step-budget input-value)
        (do
            (let pif (pifbd-admission-pif admission))
            (let table (pif-envelope-table pif))
            (if (lt entry-index 0)
                (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-negative-entry-index))
                (if (not (rpmw-entry-index-valid? table entry-index))
                    (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-entry-index-out-of-range))
                    (do
                        (let root-node (nth (pif-table-fn-roots table) entry-index))
                        (if (not (rpmw-node-id-valid? table root-node))
                            (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-root-node-out-of-range))
                            (if (lt step-budget 0)
                                (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-negative-step-budget))
                                (rpmw-walk-after-valid-entry envelope admission entry-index step-budget input-value pif root-node))))))))

    (defn rpmw-walk-entry (envelope admission entry-index step-budget input-value)
        (if (not (rale-envelope? envelope))
            (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-malformed-envelope))
            (if (not (rpmw-program-image-envelope? envelope))
                (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-non-program-image-envelope))
                (if (not (pifbd-admission? admission))
                    (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-malformed-admission))
                    (if (not (rpmw-admission-status-admitted? admission))
                        (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-non-admitted-admission))
                        (if (not (rpmw-admission-decode-decoded? admission))
                            (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-admission-decode-not-decoded))
                            (if (not (rpmw-admission-pif-valid? admission))
                                (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-admission-invalid-pif))
                                (if (not (rpmw-admission-decode-matches-pif? admission))
                                    (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-admission-decode-pif-mismatch))
                                    (if (not (rpmw-pif-matches-envelope? envelope (pifbd-admission-pif admission)))
                                        (rpmw-refused envelope admission entry-index step-budget input-value (rpmw-reason-artifact-identity-mismatch))
                                        (rpmw-walk-after-ready envelope admission entry-index step-budget input-value))))))))))
)
