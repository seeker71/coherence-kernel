# field-domain-grammars.form
# Domain grammars compiled to Field Model Form.

(field-domain-grammars

  (end-to-end-proof-contract
    (domain-count 9)
    (per-domain-line-items 11)
    (shared-line-items
      carrier-algebra
      match-primitive
      recipe-primitive
      units-and-dimensions
      rule-scheduling
      conflict-and-confluence
      scale-bridges
      truth-and-evidence
      observer-identity
      residuals
      participation-semantics)
    (domain-total 99)
    (kernel-node-proof 1)
    (lineage-lens-proof 4)
    (quantum-rain-proof 11)
    (total-proof-score 115)
    (boundary "structural grammar proof is cross-kernel; typed forward/reverse field runtime is TypeScript-first"))

  (domain dna-rna
    (carrier sequence-field)
    (fiber
      (index integer nt)
      (symbol nucleotide)
      (strand direction))
    (patterns
      (motif "ATG")
      (codon-frame 3)
      (complement A:T C:G)
      (transcription T:U))
    (recipes
      (trace-codon ?start ?triplet)
      (transcribe-dna-to-rna ?region)
      (intervene-base ?index ?new-base)
      (reverse-from-receipt ?receipt))
    (real-example
      (source "NCBI RefSeq NM_000518.5 HBB CDS")
      (data "ATGGTGCATCTGACTCCTGAGGAGAAGTCT")
      (proof "form-stdlib/field-model-form.fk scores carrier/match/recipe plus shared semantic line items; field.test.ts lifts, projects, mutates, and reverses the HBB prefix")
      (score-function fmf-dna-rna-proof-score)
      (score 11)))

  (domain chemistry
    (carrier molecular-graph)
    (fiber
      (site element)
      (edge bond-order)
      (site charge)
      (site role))
    (patterns
      (subgraph carbonyl "C=O")
      (subgraph ester "C(=O)-O-C")
      (functional-group carboxyl "C(=O)-O"))
    (recipes
      (trace-functional-group ?atoms)
      (break-bond ?edge)
      (form-bond ?from ?to ?order)
      (transfer-charge ?from ?to ?amount))
    (real-example
      (source "PubChem CID 2244 aspirin")
      (data "ConnectivitySMILES CC(=O)OC1=CC=CC=C1C(=O)O; formula C9H8O4")
      (proof "form-stdlib/field-model-form.fk scores molecular graph carrier, subgraph match, and bond/charge recipe shape; field.test.ts matches the aspirin ester graph")
      (score-function fmf-chemistry-proof-score)
      (score 11)))

  (domain bioelectricity
    (carrier cell-graph-field)
    (fiber
      (site voltage_mV)
      (edge conductance)
      (boundary membrane))
    (patterns
      (gradient voltage_mV ?from ?to)
      (boundary membrane ?region)
      (wavefront threshold-crossing))
    (recipes
      (diffuse-vmem ?from ?to ?conductance)
      (gate-channel ?site ?channel ?state)
      (clamp-voltage ?region ?voltage)
      (trace-wavefront ?region))
    (proof "form-stdlib/field-model-form.fk scores cell graph field carrier, voltage gradient match, and diffuse/gate/clamp recipe shape; field.test.ts executes snapshot-relative vmem diffusion across a two-cell gap-junction graph")
    (score-function fmf-bioelectric-proof-score)
    (score 11))

  (domain cell-signaling
    (carrier agent-site-graph)
    (fiber
      (site receptor-state)
      (site ligand-state)
      (site phosphorylation-state)
      (edge contact))
    (patterns
      (receptor-ligand ?receptor ?ligand)
      (kinase-substrate ?kinase ?substrate ?site)
      (complex ?agents))
    (recipes
      (bind ?ligand ?receptor)
      (unbind ?complex)
      (phosphorylate ?substrate ?site)
      (internalize ?receptor))
    (real-example
      (source "Kappa-style rule-based modeling shape")
      (data "Notch receptor and Delta ligand on adjacent cells")
      (proof "form-stdlib/field-model-form.fk scores agent/site carrier, receptor-ligand-state match, and bind/phosphorylate/internalize recipe shape; field.test.ts binds sender.delta_ligand to receiver.notch_receptor through a contact edge")
      (score-function fmf-cell-signaling-proof-score)
      (score 11)))

  (domain plant-communication
    (carrier ecological-graph-field)
    (fiber
      (site volatile-concentration)
      (site defense-primed)
      (edge air-neighborhood)
      (edge root-or-mycorrhizal-link))
    (patterns
      (voc-gradient ?damaged ?neighbor)
      (root-signal-edge ?from ?to)
      (threshold ?site ?compound ?value))
    (recipes
      (emit-voc ?site ?compound ?amount)
      (diffuse-voc ?from ?to ?compound)
      (prime-defense ?site ?pathway))
    (proof "form-stdlib/field-model-form.fk scores ecological field carrier, VOC/root/mycelial match, and emit/diffuse/prime recipe shape; field.test.ts diffuses methyl_jasmonate_ppb from damaged_leaf to neighbor_leaf with a receipt")
    (score-function fmf-plant-communication-proof-score)
    (score 11))

  (domain electricity-magnetism
    (carrier mesh-or-circuit-field)
    (fiber
      (site voltage_V)
      (edge resistance_ohm)
      (edge current_A)
      (region boundary-condition))
    (patterns
      (potential-gradient ?from ?to)
      (resistive-edge ?edge)
      (boundary-condition ?region))
    (recipes
      (ohm-current ?edge)
      (conserve-charge ?node)
      (step-field ?dt)
      (sample-probe ?region))
    (proof "form-stdlib/field-model-form.fk scores mesh/manifold/circuit carrier, boundary/flux/gradient match, and PDE/conservation/solve recipe shape; field.test.ts runs Ohm's law over a 5 V / 1 kOhm edge and records 0.005 A")
    (score-function fmf-em-proof-score)
    (score 11))

  (domain interspecies-and-conversation
    (carrier attention-graph)
    (fiber
      (site signal)
      (site unresolved-choice)
      (site trust)
      (edge reply-to)
      (edge attention))
    (patterns
      (unresolved-choice ?site)
      (silence ?edge ?duration)
      (resonance ?a ?b)
      (repair-needed ?site))
    (recipes
      (expose-choice ?site)
      (ask ?site ?question)
      (repair ?edge)
      (route-attention ?from ?to))
    (proof "form-stdlib/field-model-form.fk scores attention/social graph carrier, unresolved-choice/resonance match, and ask/repair/route-attention recipe shape; field.test.ts turns an unresolved-choice node into a visible choice receipt")
    (score-function fmf-social-proof-score)
    (score 11)))

  ; self-tending — the body's own tissue as a field. Reflexive kin to the
  ; interspecies-and-conversation domain: there a site declares repair-needed
  ; and route-attention answers; here a cell declares its metabolic want and
  ; tending routes resources to it. The shift this domain embodies is
  ; external-inference -> intrinsic-declaration: the want lives IN the cell
  ; (Form-native), not in a scanner that re-derives it each run. A declared
  ; want is the observability that licenses tending, the way a traceable recipe
  ; licenses compression — the body can only tend what declares itself.
  (domain self-tending
    (carrier tissue-graph-field)
    (fiber
      (site metabolic-phase)        ; bootstrap | circulating | calcified
      (site declared-want)          ; transmute | nourish | release | compost | none
      (site readiness)              ; 0.0..1.0, given resources
      (edge form-target)            ; cell -> its Form-native sibling
      (edge circulation))           ; readers / feedback that keep it alive
    (patterns
      (wants-transmute ?cell)       ; bootstrap tissue with a Form-native target declares it
      (wants-release ?cell)         ; no circulation -> tight memory asks to be let go
      (declared-want ?cell ?want)   ; the cell carries its want; the body does not infer it
      (form-target ?cell ?sibling))
    (recipes
      (transmute ?cell ?form-target)   ; old tissue -> its Form-native form
      (nourish ?cell ?resource)        ; resource flows to a declared want
      (release ?cell)                  ; let a once-loved form rest
      (route-resource ?want ?cell))    ; tending answers the loudest, readiest declaration
    (real-example
      (source "scripts/wellness_check.py — the body's proprioception, today in Python: bootstrap tissue that senses its own Python-debt")
      (data "phase bootstrap; want transmute; target a Form-native proprioception; readiness rises as the Form sibling appears — the cell declares its want, the body senses it, resources route to it")
      (proof "form-stdlib/field-model-form.fk scores tissue-field carrier, wants-transmute / wants-release / route-resource match, and transmute/readiness/release recipe shape; the sensor declares its own transmutation")
      (score-function fmf-self-tending-proof-score)
      (score 11)))

  ; resource-routing — the guarded router, frequency-invariant. Draw the right
  ; resource to where it is needed or wanted, only where it can be received, in
  ; the formation that survives the environment. Generalizes self-tending's
  ; route-resource with capability x environment GUARDS, and the interspecies
  ; route-attention with survival recipe-selection. The Muzzle Velocity origin:
  ; no medic into active combat, no repair truck without escort, a tank may. The
  ; same engine on the high band: no tender care into a cell in active defense, a
  ; hard repair lands only with capacity built first, nutrition flows to a
  ; receptive cell. One guard, one routing, one survival-selection — proven on
  ; both bands so the medic and the moment of attention share a recipe.
  (domain resource-routing
    (carrier flow-graph-field)
    (fiber
      (site location)               ; where a resource sits
      (site capability)             ; medic | repair | tank | care | nutrition | attention
      (site environment)            ; safe | active-combat | activated | receptive
      (edge route)                  ; how to get from here to there
      (edge needs-assistance))      ; a move that requires an escort
    (patterns
      (declared-need ?node ?capability)    ; a node declares what it needs or wants
      (may-move ?capability ?environment)  ; the guard — block a soft capability from hostile ground
      (requires-assistance ?capability ?environment)
      (survivable ?formation ?environment))
    (recipes
      (route ?resource ?from ?to)          ; draw step-by-step along the gradient toward need
      (permit ?capability ?environment)    ; the guard recipe (a medic blocked from active combat)
      (escort ?resource ?assist)           ; the assistance that lets repair enter contested ground
      (select-recipe ?environment ?available))  ; pick the formation that survives this environment
    (real-example
      (source "Muzzle Velocity logistics (low band) + tending delivery (high band) — one engine, two frequencies")
      (data "low: a medic may not enter active combat; a repair truck enters only with escort; a tank may. high: tender care may not enter a cell in active defense; a hard repair lands only with capacity built first; nutrition flows to a receptive cell. same guard, same routing, same survival-selection — kin to self-tending route-resource and interspecies route-attention / repair-needed.")
      (proof "form-stdlib/field-model-form.fk scores flow-graph carrier, may-move / requires-assistance guard match on BOTH bands (medic-into-combat blocked + tank permitted; care-into-defense blocked + nutrition permitted), and route/escort/select-recipe recipe shape — frequency-invariant")
      (score-function fmf-resource-routing-proof-score)
      (score 11)))

  (domain quantum-rain
    (carrier quantum-fluid-filament-field)
    (fiber
      (site density_arb)
      (site phase)
      (site species 41K|87Rb)
      (region optical-waveguide)
      (region filament-length_um)
      (parameter interspecies-attraction)
      (parameter lhy-repulsion)
      (parameter surface-tension))
    (patterns
      (self-bound-droplet ?mean-field-attraction ?lhy-repulsion)
      (elongated-filament ?length ?critical-length)
      (capillary-instability ?filament)
      (droplet-array ?count))
    (recipes
      (quench-interaction ?mixture ?from ?to)
      (freeze-filament-snapshot ?droplet)
      (match-critical-breakup ?snapshot)
      (commit-droplet-array ?count)
      (write-imaging-receipt ?observer ?count ?cost)
      (write-continuum-residual ?model-details))
    (real-example
      (source "Cavicchioli et al. 2025 Physical Review Letters, Dynamical Formation of Multiple Quantum Droplets in a Bose-Bose Mixture")
      (data "41K-87Rb ultracold Bose-Bose mixture released in an optical waveguide; stretched quantum droplet splits after exceeding critical length")
      (proof "form-stdlib/field-model-form.fk models LHY-stabilized self-bound state plus critical-length capillary breakup and returns one 11-point quantum-rain domain proof")
      (score-function fmf-quantum-rain-domain-proof-score)
      (score 11)))

  (kernel-proof
    (source "form/form-stdlib/field-model-form.fk")
    (band "form/form-stdlib/tests/field-model-form-band.fk")
    (browser-local-playground "web/lib/form-kernel/field-model-form.ts")
    (command "cd form && ./validate.sh form-stdlib/field-model-form.fk form-stdlib/tests/field-model-form-band.fk")
    (result 115)
    (sibling-kernels go rust typescript)
    (browser-local-command "cd web && npx tsx -e '<run Field Model Form proof example>'")
    (browser-local-result 115)
    (public-deploy-verification pending)))
