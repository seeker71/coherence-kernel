; stdlib-section-pressure.bmf
;
; BMF source for tracking where stdlib sections still sit on low-level Form
; scaffolding and what higher grammar should replace that shape over time.

section [section-grammar-pressure-language.bmf] {
  pressure ::= "pressure" "file" $file:string "section" $section:string "current" $current:string "highest" $highest:string "next" $next:string "defn" $defn:string "let" $let:string "bmf" $bmf:string "status" $status:string => sgp-emit-pressure <= sgp-reverse-pressure;
}
