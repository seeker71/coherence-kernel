; program-image-fkb-byte-container.fk -- canonical bytes for program-image fkb payloads.
;
; Layer 8h4 extends the program-image artifact contract with a deterministic
; byte container. It consumes a valid 8h program-image envelope, encodes the
; source identity and table payload into bytes, and vouches the resulting bytes
; against the envelope's declared content hash.
;
; This is not the dormant Form recipe-binary format and not a runtime cache
; loader. It does not read or write files, parse table payload, walk a program
; image, install a selector, produce attempts, or grow the C seed.
;
; Byte format:
;   magic:        46 4b 50 49 46 42 31 00  ; "FKPIFB1\0"
;   version:      u32 big-endian, currently 2
;   string:       u32 byte-length + raw bytes
;   signed int:   sign byte 0/1 + u32 magnitude, range [-2147483647, 2147483647]
;   payload:      magic version
;                 source-path source-hash source-mtime
;                 artifact-path seal-ok
;                 nf fn-roots nr node-rowsx4 ns string-byte-rows
;                 symbol-count symbol-rows node-symbol-count node-symbol-rows
;                 where each node-symbol-row carries dependency target pairs:
;                 dep-count (dep-symbol-id target-node-id)*
;
; `content-hash` and `artifact-mtime` are descriptor/probe metadata, not
; hash-covered payload fields.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/str-byte-at.fk
;           form-stdlib/sha256.fk
;           form-stdlib/hex.fk
;           form-stdlib/form-fs.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/source-artifact-probe.fk
;           form-stdlib/source-artifact-identity.fk
;           form-stdlib/program-image-fkb.fk

(do
    (defn pifbc-version () "program-image-fkb-byte-container-v2")
    (defn pifbc-byte-version () 2)
    (defn pifbc-max-signed () 2147483647)
    (defn pifbc-magic () (list 70 75 80 73 70 66 49 0))

    (defn pifbc-feature (name status) (list "program-image-fkb-byte-container-feature" name status))
    (defn pifbc-feature-name (f) (nth f 1))
    (defn pifbc-feature-status (f) (nth f 2))
    (defn program-image-fkb-byte-container-manifest ()
        (list
            (pifbc-feature "pure-deterministic-byte-container" 1)
            (pifbc-feature "consumes-valid-pif-envelope" 1)
            (pifbc-feature "magic-version-pinned" 1)
            (pifbc-feature "length-prefixed-strings" 1)
            (pifbc-feature "signed-int32ish-big-endian" 1)
            (pifbc-feature "table-section-order-pinned" 1)
            (pifbc-feature "symbol-section-order-pinned" 1)
            (pifbc-feature "symbol-dependencies-hash-covered" 1)
            (pifbc-feature "symbol-dependency-targets-hash-covered" 1)
            (pifbc-feature "content-hash-excluded-from-payload" 1)
            (pifbc-feature "artifact-mtime-excluded-from-payload" 1)
            (pifbc-feature "content-vouch-over-payload-bytes" 1)
            (pifbc-feature "hash-mismatch-investigates" 1)
            (pifbc-feature "out-of-range-refuses-container" 1)
            (pifbc-feature "no-disk-io" 1)
            (pifbc-feature "no-form-binary-io" 1)
            (pifbc-feature "no-whole-file-byte-io" 1)
            (pifbc-feature "no-table-payload-bridge" 1)
            (pifbc-feature "no-program-image-load" 1)
            (pifbc-feature "no-attempt-observation" 1)
            (pifbc-feature "no-selector-install" 1)
            (pifbc-feature "no-c-seed-growth" 1)))
    (defn program-image-fkb-byte-container-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (pifbc-feature-name (head fs)) name)
                     (eq (pifbc-feature-status (head fs)) 1))
                1
                (program-image-fkb-byte-container-manifest-has? name (tail fs)))))

    (defn pifbc-status-ready () "byte-container-ready")
    (defn pifbc-status-investigate () "investigate")
    (defn pifbc-status-refused () "refused")

    (defn pifbc-reason-ready () "byte-container-ready")
    (defn pifbc-reason-malformed-envelope () "malformed-pif-envelope")
    (defn pifbc-reason-invalid-envelope () "invalid-pif-envelope")
    (defn pifbc-reason-non-encodable-metadata () "non-encodable-metadata")
    (defn pifbc-reason-non-encodable-table () "non-encodable-table")
    (defn pifbc-reason-non-encodable-symbols () "non-encodable-symbols")
    (defn pifbc-reason-content-hash-malformed () "content-hash-malformed")
    (defn pifbc-reason-content-hash-mismatch () "content-hash-mismatch")

    (defn pifbc-byte? (b)
        (if (ge b 0) (if (le b 255) 1 0) 0))
    (defn pifbc-signed-ok? (n)
        (if (ge n (sub 0 (pifbc-max-signed)))
            (le n (pifbc-max-signed))
            0))
    (defn pifbc-unsigned-ok? (n)
        (if (ge n 0) (le n (pifbc-max-signed)) 0))
    (defn pifbc-abs (n)
        (if (lt n 0) (sub 0 n) n))
    (defn pifbc-signed-bytes (n)
        (if (lt n 0)
            (append-list (list 1) (u32-to-bytes (pifbc-abs n)))
            (append-list (list 0) (u32-to-bytes n))))
    (defn pifbc-string-bytes (s)
        (append-list (u32-to-bytes (str_len s)) (sai-string-bytes s)))

    (defn pifbc-int-list-encodable? (xs)
        (if (nil? xs)
            1
            (if (pifbc-signed-ok? (head xs))
                (pifbc-int-list-encodable? (tail xs))
                0)))
    (defn pifbc-node-row-encodable? (row)
        (if (eq (len row) 4)
            (pifbc-int-list-encodable? row)
            0))
    (defn pifbc-node-rows-encodable? (rows)
        (if (nil? rows)
            1
            (if (pifbc-node-row-encodable? (head rows))
                (pifbc-node-rows-encodable? (tail rows))
                0)))
    (defn pifbc-string-row-encodable? (row)
        (if (pifbc-unsigned-ok? (len row))
            (if (nil? row)
                1
                (if (pifbc-byte? (head row))
                    (pifbc-string-row-encodable? (tail row))
                    0))
            0))
    (defn pifbc-string-rows-encodable? (rows)
        (if (nil? rows)
            1
            (if (pifbc-string-row-encodable? (head rows))
                (pifbc-string-rows-encodable? (tail rows))
                0)))
    (defn pifbc-table-encodable? (t)
        (if (pif-table-valid? t)
            (if (pifbc-signed-ok? (pif-table-nf t))
                (if (pifbc-int-list-encodable? (pif-table-fn-roots t))
                    (if (pifbc-signed-ok? (pif-table-nr t))
                        (if (pifbc-node-rows-encodable? (pif-table-node-rows t))
                            (if (pifbc-signed-ok? (pif-table-ns t))
                                (pifbc-string-rows-encodable? (pif-table-string-byte-rows t))
                                0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn pifbc-symbol-row-encodable? (row)
        (if (pifbc-signed-ok? (pif-symbol-row-id row))
            (pifbc-unsigned-ok? (str_len (pif-symbol-row-key row)))
            0))
    (defn pifbc-symbol-rows-encodable? (rows)
        (if (nil? rows)
            1
            (if (pifbc-symbol-row-encodable? (head rows))
                (pifbc-symbol-rows-encodable? (tail rows))
                0)))
    (defn pifbc-symbol-dependency-target-encodable? (target)
        (if (pifbc-signed-ok? (pif-symbol-dependency-target-symbol target))
            (pifbc-signed-ok? (pif-symbol-dependency-target-node target))
            0))
    (defn pifbc-symbol-dependency-targets-encodable? (targets)
        (if (nil? targets)
            1
            (if (pifbc-symbol-dependency-target-encodable? (head targets))
                (pifbc-symbol-dependency-targets-encodable? (tail targets))
                0)))
    (defn pifbc-node-symbol-row-encodable? (row)
        (if (pifbc-signed-ok? (pif-node-symbol-row-node row))
            (if (pifbc-signed-ok? (pif-node-symbol-row-defined row))
                (if (pifbc-unsigned-ok? (len (pif-node-symbol-row-dependency-targets row)))
                    (pifbc-symbol-dependency-targets-encodable? (pif-node-symbol-row-dependency-targets row))
                    0)
                0)
            0))
    (defn pifbc-node-symbol-rows-encodable? (rows)
        (if (nil? rows)
            1
            (if (pifbc-node-symbol-row-encodable? (head rows))
                (pifbc-node-symbol-rows-encodable? (tail rows))
                0)))
    (defn pifbc-symbol-image-encodable? (img table)
        (if (pif-symbol-image-valid-for-table? img table)
            (if (pifbc-signed-ok? (pif-symbol-image-count img))
                (if (pifbc-signed-ok? (pif-symbol-image-node-count img))
                    (if (pifbc-symbol-rows-encodable? (pif-symbol-image-rows img))
                        (pifbc-node-symbol-rows-encodable? (pif-symbol-image-node-rows img))
                        0)
                    0)
                0)
            0))
    (defn pifbc-metadata-encodable? (e)
        (if (pif-envelope-shape-valid? e)
            (if (pifbc-signed-ok? (pif-envelope-source-mtime e))
                (if (pifbc-signed-ok? (pif-envelope-seal-ok e))
                    (if (pifbc-unsigned-ok? (str_len (pif-envelope-source-path e)))
                        (if (pifbc-unsigned-ok? (str_len (pif-envelope-source-hash e)))
                            (pifbc-unsigned-ok? (str_len (pif-envelope-artifact-path e)))
                            0)
                        0)
                    0)
                0)
            0))

    (defn pifbc-int-list-bytes (xs)
        (if (nil? xs)
            (empty)
            (append-list (pifbc-signed-bytes (head xs))
                         (pifbc-int-list-bytes (tail xs)))))
    (defn pifbc-node-rows-bytes (rows)
        (if (nil? rows)
            (empty)
            (append-list (pifbc-int-list-bytes (head rows))
                         (pifbc-node-rows-bytes (tail rows)))))
    (defn pifbc-string-row-bytes (row)
        (append-list (u32-to-bytes (len row)) row))
    (defn pifbc-string-rows-bytes (rows)
        (if (nil? rows)
            (empty)
            (append-list (pifbc-string-row-bytes (head rows))
                         (pifbc-string-rows-bytes (tail rows)))))
    (defn pifbc-table-bytes (t)
        (if (pifbc-table-encodable? t)
            (append-list (pifbc-signed-bytes (pif-table-nf t))
            (append-list (pifbc-int-list-bytes (pif-table-fn-roots t))
            (append-list (pifbc-signed-bytes (pif-table-nr t))
            (append-list (pifbc-node-rows-bytes (pif-table-node-rows t))
            (append-list (pifbc-signed-bytes (pif-table-ns t))
                         (pifbc-string-rows-bytes (pif-table-string-byte-rows t)))))))
            (empty)))
    (defn pifbc-symbol-row-bytes (row)
        (append-list (pifbc-signed-bytes (pif-symbol-row-id row))
                     (pifbc-string-bytes (pif-symbol-row-key row))))
    (defn pifbc-symbol-rows-bytes (rows)
        (if (nil? rows)
            (empty)
            (append-list (pifbc-symbol-row-bytes (head rows))
                         (pifbc-symbol-rows-bytes (tail rows)))))
    (defn pifbc-symbol-dependency-target-bytes (target)
        (append-list (pifbc-signed-bytes (pif-symbol-dependency-target-symbol target))
                     (pifbc-signed-bytes (pif-symbol-dependency-target-node target))))
    (defn pifbc-symbol-dependency-targets-bytes (targets)
        (if (nil? targets)
            (empty)
            (append-list (pifbc-symbol-dependency-target-bytes (head targets))
                         (pifbc-symbol-dependency-targets-bytes (tail targets)))))
    (defn pifbc-node-symbol-row-bytes (row)
        (append-list (pifbc-signed-bytes (pif-node-symbol-row-node row))
        (append-list (pifbc-signed-bytes (pif-node-symbol-row-defined row))
        (append-list (pifbc-signed-bytes (len (pif-node-symbol-row-dependency-targets row)))
                     (pifbc-symbol-dependency-targets-bytes (pif-node-symbol-row-dependency-targets row))))))
    (defn pifbc-node-symbol-rows-bytes (rows)
        (if (nil? rows)
            (empty)
            (append-list (pifbc-node-symbol-row-bytes (head rows))
                         (pifbc-node-symbol-rows-bytes (tail rows)))))
    (defn pifbc-symbol-image-bytes (img)
        (append-list (pifbc-signed-bytes (pif-symbol-image-count img))
        (append-list (pifbc-symbol-rows-bytes (pif-symbol-image-rows img))
        (append-list (pifbc-signed-bytes (pif-symbol-image-node-count img))
                     (pifbc-node-symbol-rows-bytes (pif-symbol-image-node-rows img))))))
    (defn pifbc-payload-bytes (e)
        (if (pif-envelope-valid? e)
            (if (pifbc-metadata-encodable? e)
                (if (pifbc-table-encodable? (pif-envelope-table e))
                    (if (pifbc-symbol-image-encodable? (pif-envelope-symbol-image e) (pif-envelope-table e))
                        (append-list (pifbc-magic)
                        (append-list (u32-to-bytes (pifbc-byte-version))
                        (append-list (pifbc-string-bytes (pif-envelope-source-path e))
                        (append-list (pifbc-string-bytes (pif-envelope-source-hash e))
                        (append-list (pifbc-signed-bytes (pif-envelope-source-mtime e))
                        (append-list (pifbc-string-bytes (pif-envelope-artifact-path e))
                        (append-list (pifbc-signed-bytes (pif-envelope-seal-ok e))
                        (append-list (pifbc-table-bytes (pif-envelope-table e))
                                     (pifbc-symbol-image-bytes (pif-envelope-symbol-image e))))))))))
                        (empty))
                    (empty))
                (empty))
            (empty)))

    (defn pifbc-empty-vouch ()
        (sai-vouch (sai-target-content-hash) "" (sai-evidence-supplied-bytes)
                   "" "" (sai-status-unobserved) 0 0))
    (defn pifbc-content-vouch (e bytes)
        (sai-vouch-content-bytes (pif-envelope-artifact-path e)
                                 (pif-envelope-content-hash e)
                                 bytes))

    ; row = ("program-image-fkb-byte-container" pif-envelope bytes vouch status reason)
    (defn pifbc-container (pif-envelope bytes vouch status reason)
        (list "program-image-fkb-byte-container" pif-envelope bytes vouch status reason))
    (defn pifbc-container? (c)
        (if (eq (len c) 6)
            (str_eq (nth c 0) "program-image-fkb-byte-container")
            0))
    (defn pifbc-container-pif (c) (nth c 1))
    (defn pifbc-container-bytes (c) (nth c 2))
    (defn pifbc-container-vouch (c) (nth c 3))
    (defn pifbc-container-status (c) (nth c 4))
    (defn pifbc-container-reason (c) (nth c 5))
    (defn pifbc-ready? (c)
        (if (pifbc-container? c)
            (str_eq (pifbc-container-status c) (pifbc-status-ready))
            0))

    (defn pifbc-container-from-envelope (e)
        (if (not (pif-envelope? e))
            (pifbc-container e (empty) (pifbc-empty-vouch) (pifbc-status-refused) (pifbc-reason-malformed-envelope))
            (if (not (pif-envelope-valid? e))
                (pifbc-container e (empty) (pifbc-empty-vouch) (pifbc-status-refused) (pifbc-reason-invalid-envelope))
                (if (not (pifbc-metadata-encodable? e))
                    (pifbc-container e (empty) (pifbc-empty-vouch) (pifbc-status-investigate) (pifbc-reason-non-encodable-metadata))
                    (if (not (pifbc-table-encodable? (pif-envelope-table e)))
                        (pifbc-container e (empty) (pifbc-empty-vouch) (pifbc-status-investigate) (pifbc-reason-non-encodable-table))
                        (if (not (pifbc-symbol-image-encodable? (pif-envelope-symbol-image e) (pif-envelope-table e)))
                            (pifbc-container e (empty) (pifbc-empty-vouch) (pifbc-status-investigate) (pifbc-reason-non-encodable-symbols))
                            (do
                                (let bytes (pifbc-payload-bytes e))
                                (let vouch (pifbc-content-vouch e bytes))
                                (if (sai-vouch-match? vouch)
                                    (pifbc-container e bytes vouch (pifbc-status-ready) (pifbc-reason-ready))
                                    (if (str_eq (sai-vouch-status vouch) (sai-status-malformed))
                                        (pifbc-container e bytes vouch (pifbc-status-refused) (pifbc-reason-content-hash-malformed))
                                        (pifbc-container e bytes vouch (pifbc-status-investigate) (pifbc-reason-content-hash-mismatch)))))))))))
)
