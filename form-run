#!/bin/sh
set -u

carrier_version="form-run-posix-v1"

if [ "${1-}" = "--self-witness" ]; then
    printf 'carrier=%s\n' "$0"
    printf 'version=%s\n' "$carrier_version"
    printf 'capture=stdout+stderr+exit\n'
    printf 'compaction=transparent-pending-form-native-classifier\n'
    printf '@form self-witness 0 0 0 0\n'
    exit 0
fi

if [ "$#" -eq 0 ]; then
    printf 'form-run: command required\n' >&2
    printf '@form usage 64 0 27 27\n'
    exit 64
fi

form_tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/form-run.XXXXXX") || exit 70
form_stdout="$form_tmp_dir/stdout"
form_stderr="$form_tmp_dir/stderr"
"$@" >"$form_stdout" 2>"$form_stderr"
form_exit=$?
form_stdout_bytes=$(wc -c <"$form_stdout" | tr -d ' ')
form_stderr_bytes=$(wc -c <"$form_stderr" | tr -d ' ')
form_shown_bytes=$((form_stdout_bytes + form_stderr_bytes))
form_kind=$(basename "$1")
if [ -s "$form_stdout" ]; then /bin/cat "$form_stdout"; fi
if [ -s "$form_stderr" ]; then /bin/cat "$form_stderr" >&2; fi
printf '@form %s %s %s %s %s\n' \
    "$form_kind" "$form_exit" "$form_stdout_bytes" "$form_stderr_bytes" "$form_shown_bytes"
/bin/rm -f "$form_stdout" "$form_stderr"
/bin/rmdir "$form_tmp_dir"
exit "$form_exit"
