; speech-corpus-french-repair-batch-0005.fk -- execute the first adaptive repair lane.
;
; Batch 0004 showed French was the lowest-yield cross-voice lane. The adaptive
; scheduler selected "repair-voice-family-and-shorten-phrases". This batch uses
; two cleaner local French voices and oracle-stable spoken aliases for the same
; consentful Coherence Network keys. These are repair-alias acquisition rows:
; they improve capture, not translation authority and not native ASR/TTS.
;
; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/coherence-network-self-corpus.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk

(do
    (defn scfr5-kind () "speech-corpus-french-repair-batch-0005")
    (defn scfr5-out-dir () (str_concat (temp_dir) "/speech-corpus-french-repair-batch-0005"))

    (defn scfr5-row (id key source-text spoken-alias voice)
        (list "speech-corpus-french-repair-row" id key source-text spoken-alias voice))
    (defn scfr5-id     (r) (nth r 1))
    (defn scfr5-key    (r) (nth r 2))
    (defn scfr5-source (r) (nth r 3))
    (defn scfr5-alias  (r) (nth r 4))
    (defn scfr5-voice  (r) (nth r 5))

    (defn scfr5-rows ()
        (list
            (scfr5-row 1 "common.yes" "Oui" "Oui" "Amélie")
            (scfr5-row 2 "common.yes" "Oui" "Oui" "Thomas")
            (scfr5-row 3 "common.no" "Non" "Non" "Amélie")
            (scfr5-row 4 "common.no" "Non" "Non" "Thomas")
            (scfr5-row 5 "common.back" "Retour" "Retour" "Amélie")
            (scfr5-row 6 "common.back" "Retour" "Retour" "Thomas")
            (scfr5-row 7 "common.close" "Fermer" "Fermez" "Amélie")
            (scfr5-row 8 "common.close" "Fermer" "Fermez" "Thomas")
            (scfr5-row 9 "common.cancel" "Annuler" "Annule" "Amélie")
            (scfr5-row 10 "common.cancel" "Annuler" "Annule" "Thomas")
            (scfr5-row 11 "common.save" "Enregistrer" "Enregistrez" "Amélie")
            (scfr5-row 12 "common.save" "Enregistrer" "Enregistrez" "Thomas")
            (scfr5-row 13 "common.submit" "Envoyer" "Envoyez" "Amélie")
            (scfr5-row 14 "common.submit" "Envoyer" "Envoyez" "Thomas")
            (scfr5-row 15 "nav.search" "Chercher" "Cherchez" "Amélie")
            (scfr5-row 16 "nav.search" "Chercher" "Cherchez" "Thomas")
            (scfr5-row 17 "nav.ideas" "Idées" "Idées" "Amélie")
            (scfr5-row 18 "nav.ideas" "Idées" "Idées" "Thomas")
            (scfr5-row 19 "nav.recipes" "Recettes" "Recette" "Amélie")
            (scfr5-row 20 "nav.recipes" "Recettes" "Recette" "Thomas")))

    (defn scfr5-stem (row)
        (mstal-cat4 (scfr5-out-dir) "/row-" (mstal-int-str (scfr5-id row)) ""))
    (defn scfr5-aiff (row) (str_concat (scfr5-stem row) ".aiff"))
    (defn scfr5-wav (row) (str_concat (scfr5-stem row) ".wav"))

    (defn scfr5-render (row)
        (do
            (let _mk (fs_mkdir (scfr5-out-dir)))
            (let _say (host-exec (mstal-say-command (scfr5-voice row) (scfr5-aiff row) (scfr5-alias row)) ""))
            (let _ff (host-exec (mstal-ffmpeg-command (scfr5-aiff row) (scfr5-wav row)) ""))
            (scfr5-wav row)))

    (defn scfr5-whisper-command (wav)
        (str_concat
            (str_concat "whisper-cli -m " (mstal-q (mstal-model)))
            (str_concat
                (str_concat " -f " (mstal-q wav))
                " -l fr -nt -np")))

    (defn scfr5-capture-row (row)
        (do
            (let wav (scfr5-render row))
            (let transcript (host-exec (scfr5-whisper-command wav) ""))
            (let wer (sw-wer (sw-tokens transcript) (sw-tokens (scfr5-alias row))))
            (list "speech-corpus-french-repair-receipt-row"
                  (scfr5-id row)
                  (scfr5-key row)
                  (scfr5-source row)
                  (scfr5-alias row)
                  (scfr5-voice row)
                  transcript
                  wer
                  (if (le wer 25) 1 0)
                  (mstal-audio-hash wav)
                  (file_size wav))))

    (defn scfr5-row-wer   (r) (nth r 7))
    (defn scfr5-row-ok    (r) (nth r 8))
    (defn scfr5-row-hash  (r) (nth r 9))
    (defn scfr5-row-bytes (r) (nth r 10))

    (defn scfr5-capture-loop (rows)
        (if (eq (len rows) 0) (empty)
            (cons (scfr5-capture-row (head rows))
                  (scfr5-capture-loop (tail rows)))))

    (defn scfr5-count-ok (rows)
        (if (eq (len rows) 0) 0
            (add (scfr5-row-ok (head rows)) (scfr5-count-ok (tail rows)))))
    (defn scfr5-count-hash (rows)
        (if (eq (len rows) 0) 0
            (add (if (gt (scfr5-row-hash (head rows)) 0) 1 0)
                 (scfr5-count-hash (tail rows)))))
    (defn scfr5-max-wer (rows)
        (if (eq (len rows) 0) 0
            (do
                (let rest (scfr5-max-wer (tail rows)))
                (if (gt (scfr5-row-wer (head rows)) rest) (scfr5-row-wer (head rows)) rest))))
    (defn scfr5-total-bytes (rows)
        (if (eq (len rows) 0) 0
            (add (scfr5-row-bytes (head rows)) (scfr5-total-bytes (tail rows)))))

    (defn scfr5-receipt-from (rows)
        (list (scfr5-kind)
              rows
              (len rows)
              (scfr5-count-ok rows)
              (scfr5-count-hash rows)
              (scfr5-max-wer rows)
              (scfr5-total-bytes rows)
              10
              2
              "repair-alias-french-corpus-audio-not-training-sufficient"
              1
              0
              0))

    (defn scfr5-run-receipt ()
        (if (eq (mstal-ready?) 1)
            (scfr5-receipt-from (scfr5-capture-loop (scfr5-rows)))
            (list (scfr5-kind) (empty) 0 0 0 100 0 10 2 "missing-host-tools" 1 0 0)))

    (defn scfr5-rec-kind        (r) (nth r 0))
    (defn scfr5-rec-count       (r) (nth r 2))
    (defn scfr5-rec-ok          (r) (nth r 3))
    (defn scfr5-rec-hash-count  (r) (nth r 4))
    (defn scfr5-rec-max-wer     (r) (nth r 5))
    (defn scfr5-rec-bytes       (r) (nth r 6))
    (defn scfr5-rec-keys        (r) (nth r 7))
    (defn scfr5-rec-voices      (r) (nth r 8))
    (defn scfr5-rec-status      (r) (nth r 9))
    (defn scfr5-rec-native-form (r) (nth r 10))
    (defn scfr5-rec-neural      (r) (nth r 11))
    (defn scfr5-rec-trained     (r) (nth r 12))

    0)
