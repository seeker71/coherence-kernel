; speech-loopback-recipe-ab.fk -- A/B recipe testing over real speech loopback receipts.
;
; Each arm is a recipe-id plus a measured local carrier receipt window. The body
; compares the incumbent and challenger only after the carrier receipts have
; passed the speech-loopback promotion guide. fail/timeout/undo are first-class
; controls: they keep the incumbent even when the challenger window looks good.
;
; preludes:
;   observe/stt-wer.fk
;   learn/speech-loopback-promotion.fk
;   presence/speech-loopback-carrier-receipt.fk

(do
    (defn slab-latency-score (receipts)
        (if (eq (len receipts) 0) 0
            (add (slc-latency-ms (head receipts))
                 (slab-latency-score (tail receipts)))))

    (defn slab-arm (recipe-id receipts max-wer min-conf max-latency
                    min-samples margin max-control-debt min-native-score)
        (list "speech-loopback-recipe-arm"
              recipe-id
              (slc-summary receipts max-wer min-conf max-latency
                           min-samples margin max-control-debt min-native-score)
              (slab-latency-score receipts)))

    (defn slab-arm-kind (a) (nth a 0))
    (defn slab-arm-recipe (a) (nth a 1))
    (defn slab-arm-summary (a) (nth a 2))
    (defn slab-arm-latency (a) (nth a 3))
    (defn slab-arm-count (a) (slc-summary-count (slab-arm-summary a)))
    (defn slab-arm-native (a) (slc-summary-native (slab-arm-summary a)))
    (defn slab-arm-oracle (a) (slc-summary-oracle (slab-arm-summary a)))
    (defn slab-arm-debt (a) (slc-summary-debt (slab-arm-summary a)))
    (defn slab-arm-route (a) (slc-summary-route (slab-arm-summary a)))

    (defn slab-challenger-score-better? (incumbent challenger)
        (if (gt (slab-arm-native challenger) (slab-arm-native incumbent)) 1 0))

    (defn slab-challenger-latency-better? (incumbent challenger)
        (if (and (eq (slab-arm-native challenger) (slab-arm-native incumbent))
                 (le (slab-arm-latency challenger) (slab-arm-latency incumbent))) 1 0))

    (defn slab-challenger-better? (incumbent challenger)
        (if (and (str_eq (slab-arm-route challenger) "native")
                 (and (le (slab-arm-debt challenger) (slab-arm-debt incumbent))
                      (or (eq (slab-challenger-score-better? incumbent challenger) 1)
                          (eq (slab-challenger-latency-better? incumbent challenger) 1)))) 1 0))

    (defn slab-decision-record (incumbent challenger chosen action)
        (list "speech-loopback-recipe-ab"
              (slab-arm-recipe incumbent)
              (slab-arm-recipe challenger)
              chosen
              action
              (slab-arm-route incumbent)
              (slab-arm-route challenger)
              (slab-arm-native incumbent)
              (slab-arm-native challenger)
              (slab-arm-debt incumbent)
              (slab-arm-debt challenger)
              (slab-arm-latency incumbent)
              (slab-arm-latency challenger)))

    (defn slab-decision (incumbent challenger fail timeout undo)
        (if (eq undo 1)
            (slab-decision-record incumbent challenger (slab-arm-recipe incumbent) "undo-incumbent")
            (if (eq timeout 1)
                (slab-decision-record incumbent challenger (slab-arm-recipe incumbent) "timeout-incumbent")
                (if (eq fail 1)
                    (slab-decision-record incumbent challenger (slab-arm-recipe incumbent) "fail-incumbent")
                    (if (eq (slab-challenger-better? incumbent challenger) 1)
                        (slab-decision-record incumbent challenger (slab-arm-recipe challenger) "cut-challenger")
                        (slab-decision-record incumbent challenger (slab-arm-recipe incumbent) "keep-incumbent"))))))

    (defn slab-decision-from-receipts
        (incumbent-recipe incumbent-receipts challenger-recipe challenger-receipts
         max-wer min-conf max-latency min-samples margin max-control-debt min-native-score
         fail timeout undo)
        (do
            (let incumbent (slab-arm incumbent-recipe incumbent-receipts
                                     max-wer min-conf max-latency
                                     min-samples margin max-control-debt min-native-score))
            (let challenger (slab-arm challenger-recipe challenger-receipts
                                      max-wer min-conf max-latency
                                      min-samples margin max-control-debt min-native-score))
            (slab-decision incumbent challenger fail timeout undo)))

    (defn slab-dec-kind (d) (nth d 0))
    (defn slab-dec-incumbent (d) (nth d 1))
    (defn slab-dec-challenger (d) (nth d 2))
    (defn slab-dec-chosen (d) (nth d 3))
    (defn slab-dec-action (d) (nth d 4))
    (defn slab-dec-inc-route (d) (nth d 5))
    (defn slab-dec-ch-route (d) (nth d 6))
    (defn slab-dec-inc-native (d) (nth d 7))
    (defn slab-dec-ch-native (d) (nth d 8))
    (defn slab-dec-inc-debt (d) (nth d 9))
    (defn slab-dec-ch-debt (d) (nth d 10))
    (defn slab-dec-inc-latency (d) (nth d 11))
    (defn slab-dec-ch-latency (d) (nth d 12))

    0)
