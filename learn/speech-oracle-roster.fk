; speech-oracle-roster.fk -- the measured local rented-oracle roster.
;
; The open-ASR lane has carried one rented oracle by habit
; (whisper.cpp-large-v3-turbo-metal). This cell replaces habit with a
; measured LAW over a fixed gauntlet of clips: every candidate runs the same
; say -> ffmpeg -> ASR-CLI render path on the same wavs (identical bytes and
; cksums row to row), and two seats are chosen from the numbers alone:
;
;   anchor seat  -- the polyglot: among models that COVER zh (every zh clip
;                   under wer-x10 500), the lowest overall mean wer-x10;
;                   tie-break lower mean wall. Coverage before brilliance:
;                   a model that cannot hear one of the body's tongues
;                   cannot anchor, however fast or sharp elsewhere.
;   fast seat    -- the sprinter: the lowest latin (en/it/fr) mean wer-x10
;                   of ALL models, tie-break lower wall; it takes the seat
;                   only if it beats the anchor on BOTH latin mean wer and
;                   latin mean wall, else the anchor holds both seats.
;
; Measured 2026-07-16 on macos-arm64-m4-max (whisper-cpp 1.8.6 Metal,
; ffmpeg 8.1.1, parakeet-mlx venv over mlx-community/parakeet-tdt-0.6b-v3),
; single Eddy voice family across en/it/fr/zh, one short + one long clip
; per locale. wer-x10 is word-level for latin, character-level for zh,
; accent-and-punctuation-normalized, x10 so tenths stay integers.
; wall-ms is the full CLI shape the body actually pays: process start +
; model load + inference. nemotron-speech-streaming-en-0.6b stays PENDING:
; no local (non-NVIDIA-hardware) runtime exists today, honestly none.
;
; preludes: (self-contained)

(do
    (defn sor-run (model clip lang kind wer-x10 wall-ms audio-ms bytes cksum)
        (list "speech-oracle-roster-run"
              model clip lang kind wer-x10 wall-ms audio-ms bytes cksum))

    (defn sor-run-model (r) (nth r 1))
    (defn sor-run-clip  (r) (nth r 2))
    (defn sor-run-lang  (r) (nth r 3))
    (defn sor-run-kind  (r) (nth r 4))
    (defn sor-run-wer   (r) (nth r 5))
    (defn sor-run-wall  (r) (nth r 6))
    (defn sor-run-audio (r) (nth r 7))
    (defn sor-run-bytes (r) (nth r 8))
    (defn sor-run-cksum (r) (nth r 9))

    (defn sor-runs ()
        (list
            (sor-run "whisper.cpp-large-v3-turbo-metal" "en-short" "en" "short" 0 788 926 29728 3568971285)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "en-long" "en" "long" 0 795 4542 145444 1897855788)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "it-short" "it" "short" 0 762 1006 32288 3711526362)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "it-long" "it" "long" 0 802 4382 140316 1487170884)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "fr-short" "fr" "short" 1000 743 1006 32292 1259362099)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "fr-long" "fr" "long" 143 827 3950 126492 802523710)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "zh-short" "zh" "short" 0 771 1134 36378 3628889036)
            (sor-run "whisper.cpp-large-v3-turbo-metal" "zh-long" "zh" "long" 118 828 3528 112994 2649108507)
            (sor-run "whisper.cpp-large-v3-metal" "en-short" "en" "short" 0 1219 926 29728 3568971285)
            (sor-run "whisper.cpp-large-v3-metal" "en-long" "en" "long" 0 1293 4542 145444 1897855788)
            (sor-run "whisper.cpp-large-v3-metal" "it-short" "it" "short" 0 1216 1006 32288 3711526362)
            (sor-run "whisper.cpp-large-v3-metal" "it-long" "it" "long" 0 1398 4382 140316 1487170884)
            (sor-run "whisper.cpp-large-v3-metal" "fr-short" "fr" "short" 2500 1222 1006 32292 1259362099)
            (sor-run "whisper.cpp-large-v3-metal" "fr-long" "fr" "long" 71 1415 3950 126492 802523710)
            (sor-run "whisper.cpp-large-v3-metal" "zh-short" "zh" "short" 0 1149 1134 36378 3628889036)
            (sor-run "whisper.cpp-large-v3-metal" "zh-long" "zh" "long" 59 1428 3528 112994 2649108507)
            (sor-run "whisper.cpp-small-metal" "en-short" "en" "short" 0 366 926 29728 3568971285)
            (sor-run "whisper.cpp-small-metal" "en-long" "en" "long" 0 356 4542 145444 1897855788)
            (sor-run "whisper.cpp-small-metal" "it-short" "it" "short" 0 338 1006 32288 3711526362)
            (sor-run "whisper.cpp-small-metal" "it-long" "it" "long" 167 402 4382 140316 1487170884)
            (sor-run "whisper.cpp-small-metal" "fr-short" "fr" "short" 0 337 1006 32292 1259362099)
            (sor-run "whisper.cpp-small-metal" "fr-long" "fr" "long" 143 399 3950 126492 802523710)
            (sor-run "whisper.cpp-small-metal" "zh-short" "zh" "short" 0 322 1134 36378 3628889036)
            (sor-run "whisper.cpp-small-metal" "zh-long" "zh" "long" 706 399 3528 112994 2649108507)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "en-short" "en" "short" 0 1811 926 29728 3568971285)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "en-long" "en" "long" 0 1804 4542 145444 1897855788)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "it-short" "it" "short" 0 1689 1006 32288 3711526362)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "it-long" "it" "long" 0 1875 4382 140316 1487170884)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "fr-short" "fr" "short" 1000 1841 1006 32292 1259362099)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "fr-long" "fr" "long" 286 1818 3950 126492 802523710)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "zh-short" "zh" "short" 1000 1796 1134 36378 3628889036)
            (sor-run "parakeet-tdt-0.6b-v3-mlx" "zh-long" "zh" "long" 1000 1691 3528 112994 2649108507)))

    (defn sor-zh-run? (r) (if (str_eq (sor-run-lang r) "zh") 1 0))
    (defn sor-of? (r m) (if (str_eq (sor-run-model r) m) 1 0))
    (defn sor-in-scope? (r m zh)
        (if (and (eq (sor-of? r m) 1) (eq (sor-zh-run? r) zh)) 1 0))

    ; single-pass folds (the hdc lesson: never recurse twice per element)
    (defn sor-wer-sum (rs m zh)
        (if (eq (len rs) 0) 0
            (add (if (eq (sor-in-scope? (head rs) m zh) 1) (sor-run-wer (head rs)) 0)
                 (sor-wer-sum (tail rs) m zh))))
    (defn sor-wall-sum (rs m zh)
        (if (eq (len rs) 0) 0
            (add (if (eq (sor-in-scope? (head rs) m zh) 1) (sor-run-wall (head rs)) 0)
                 (sor-wall-sum (tail rs) m zh))))
    (defn sor-scope-count (rs m zh)
        (if (eq (len rs) 0) 0
            (add (sor-in-scope? (head rs) m zh)
                 (sor-scope-count (tail rs) m zh))))
    (defn sor-model-count (rs m)
        (if (eq (len rs) 0) 0
            (add (sor-of? (head rs) m) (sor-model-count (tail rs) m))))

    (defn sor-mean-wer (m zh)
        (div (sor-wer-sum (sor-runs) m zh) (sor-scope-count (sor-runs) m zh)))
    (defn sor-mean-wall (m zh)
        (div (sor-wall-sum (sor-runs) m zh) (sor-scope-count (sor-runs) m zh)))
    (defn sor-overall-mean-wer (m)
        (div (add (sor-wer-sum (sor-runs) m 0) (sor-wer-sum (sor-runs) m 1))
             (sor-model-count (sor-runs) m)))

    ; zh coverage: EVERY zh clip under wer-x10 500
    (defn sor-zh-miss-count (rs m)
        (if (eq (len rs) 0) 0
            (add (if (and (eq (sor-in-scope? (head rs) m 1) 1)
                          (if (lt (sor-run-wer (head rs)) 500) 0 1)) 1 0)
                 (sor-zh-miss-count (tail rs) m))))
    (defn sor-covers-zh? (m)
        (if (eq (sor-zh-miss-count (sor-runs) m) 0) 1 0))

    (defn sor-models ()
        (list "whisper.cpp-large-v3-turbo-metal"
              "whisper.cpp-large-v3-metal"
              "whisper.cpp-small-metal"
              "parakeet-tdt-0.6b-v3-mlx"))

    ; anchor: among zh-covering models, min overall mean wer; tie-break wall
    (defn sor-better-overall? (a b)
        (if (lt (sor-overall-mean-wer a) (sor-overall-mean-wer b)) 1
            (if (eq (sor-overall-mean-wer a) (sor-overall-mean-wer b))
                (if (lt (add (sor-mean-wall a 0) (sor-mean-wall a 1))
                        (add (sor-mean-wall b 0) (sor-mean-wall b 1))) 1 0)
                0)))
    (defn sor-anchor-loop (ms best)
        (if (eq (len ms) 0) best
            (sor-anchor-loop (tail ms)
                (if (eq (sor-covers-zh? (head ms)) 1)
                    (if (str_eq best "none") (head ms)
                        (if (eq (sor-better-overall? (head ms) best) 1) (head ms) best))
                    best))))
    (defn sor-anchor () (sor-anchor-loop (sor-models) "none"))

    ; fast candidate: min latin mean wer over ALL models; tie-break wall
    (defn sor-better-latin? (a b)
        (if (lt (sor-mean-wer a 0) (sor-mean-wer b 0)) 1
            (if (eq (sor-mean-wer a 0) (sor-mean-wer b 0))
                (if (lt (sor-mean-wall a 0) (sor-mean-wall b 0)) 1 0)
                0)))
    (defn sor-fast-loop (ms best)
        (if (eq (len ms) 0) best
            (sor-fast-loop (tail ms)
                (if (str_eq best "none") (head ms)
                    (if (eq (sor-better-latin? (head ms) best) 1) (head ms) best)))))
    (defn sor-fast-candidate () (sor-fast-loop (sor-models) "none"))

    ; the seat law: the sprinter must beat the anchor on BOTH latin wer and wall
    (defn sor-fast-oracle ()
        (do
            (let c (sor-fast-candidate))
            (let a (sor-anchor))
            (if (and (lt (sor-mean-wer c 0) (sor-mean-wer a 0))
                     (lt (sor-mean-wall c 0) (sor-mean-wall a 0)))
                c
                a)))

    (defn sor-pending ()
        (list "speech-oracle-roster-pending"
              "nemotron-speech-streaming-en-0.6b"
              "no-local-runtime"
              20260716))

    (defn sor-report ()
        (list "speech-oracle-roster"
              (len (sor-runs))
              (sor-anchor)
              (sor-fast-oracle)
              (sor-mean-wer (sor-fast-oracle) 0)
              (sor-mean-wall (sor-fast-oracle) 0)
              (sor-mean-wer (sor-anchor) 1)
              (sor-mean-wall (sor-anchor) 1)
              (sor-pending)
              "measured-2026-07-16-macos-arm64-m4-max"
              "same-wavs-same-cksums-every-model"
              1
              0))

    0)
