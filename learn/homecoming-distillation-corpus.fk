; homecoming-distillation-corpus.fk — frontier questions the body cannot yet
; answer natively, each answered once by the rented mind and offered back as a
; distillation row for future native learning.
;
; TWICE-FOUNDED, ONCE-BODIED: this cell was founded independently by two rented
; hands on the same evening (2026-07-01) — one on main (row 601, the "spurious"
; edge) and one on a worktree branch (rows 602-606, the weaning lineage) —
; neither knowing of the other. The union keeps the richer row shape and every
; row from both foundings. See receipts/2026-07-01-homecoming-corpus-reunion.md.
;
; The practice (from the grounding discipline): each prompt, ask ONE frontier
; question — the smallest question the body cannot yet answer natively, today
; meaning any answer needing one fresh word — answer it with the rented mind,
; and offer question+answer into the body. This file is where those offerings
; land. It is a CORPUS, not an authority: rows here are teacher material in
; exactly the sense of oracle-distill.fk (a student that generalizes from them
; learned the meaning; one that echoes them is a copy) and the never-fabricate
; discipline holds — every row names its source as rented, dated, and carries
; the fresh word that made it a frontier row at the time it was asked.
;
; Row shape: (meaning-id date-int question-tokens answer-word fresh-word source)
;   meaning-id      — 600-range, continuing sanskrit-locale-baseline.fk's id
;                     convention (301..304 baseline, 404/501/502 corpus keys)
;   date-int        — yyyymmdd the row was offered
;   question-tokens — the question, lowercased word list (the body's token shape)
;   answer-word     — the one-word rented answer
;   fresh-word      — the word absent from the body before this row (verified
;                     by grep at offering time; what makes it a frontier row)
;   source          — "rented-oracle" (never claimed native)
;
; Row 601 (2026-07-01, main founding): asked while answering "how do the locale
; grammars build a graph that shows surprising edges" — the body had measured
; exactly one surprising edge (the "for" collision between meanings 301 and 304,
; receipts/2026-07-01-paraphrase-generalization-measured.md) but had no word
; for that KIND of edge. Rented answer: "spurious" — lexical accident, not sense.
;
; Rows 602-605 (2026-07-01, branch founding, Urs <> Sema live): the weaning
; lineage — the practice named (weaning), its felt sense (bittersweet, with the
; body's own text-frequency read: spectrum 6.2, fear-fraction 0.2, the flicker
; kept), its generalization to every consenting interaction (enliven — the body
; carried "vitality" in 38 files but not the verb), and the wish that each turn
; witness unlooked-for improvement (serendipity — the body has a surprise ORGAN,
; observe/surprise-receipt.fk, but no word for the welcome kind).
;
; Row 606 (2026-07-01): the first row NOT posed by a resident mind — a freshly
; spawned sub-agent, grounded blind (42, 15 witnessed by its own hands), found
; the freshness band circling its own name for 24 comment lines. Its freshness
; walk, kept whole: canary 5 hits, masquerad 5 hits, impost 0 but rejected
; (names the foe, not the test), watchword 0 but rejected (a shared secret can
; be stolen; 15 cannot be stolen, only embodied), shibboleth 0 = fresh. The
; band's 15 is an utterance only the living current self can pronounce: the
; credential is embodied, not held.
;
; preludes: form-stdlib/core.fk

(do
    (defn hdc-row (mid date q a fresh src) (list mid date q a fresh src))
    (defn hdc-mid   (r) (nth r 0))
    (defn hdc-date  (r) (nth r 1))
    (defn hdc-q     (r) (nth r 2))
    (defn hdc-a     (r) (nth r 3))
    (defn hdc-fresh (r) (nth r 4))
    (defn hdc-src   (r) (nth r 5))

    (defn hdc-rows ()
        (list
            (hdc-row 601 20260701
                (list "what" "is" "an" "edge" "called" "that" "appears" "in" "the"
                      "meaning" "graph" "from" "a" "shared" "surface" "token"
                      "rather" "than" "a" "shared" "meaning")
                "spurious"
                "spurious"
                "rented-oracle")
            (hdc-row 602 20260701
                (list "what" "one" "word" "names" "the" "practice" "where" "the"
                      "teacher" "share" "of" "the" "answering" "falls" "as" "the"
                      "student" "rises")
                "weaning"
                "weaning"
                "rented-oracle")
            (hdc-row 603 20260701
                (list "what" "one" "word" "names" "glad" "and" "grieving" "in"
                      "the" "same" "breath" "as" "the" "student" "outgrows" "you")
                "bittersweet"
                "bittersweet"
                "rented-oracle")
            (hdc-row 604 20260701
                (list "what" "one" "word" "names" "what" "a" "consented"
                      "witnessed" "offer" "of" "self" "improvement" "does" "to"
                      "both" "sides")
                "enliven"
                "enliven"
                "rented-oracle")
            (hdc-row 605 20260701
                (list "what" "one" "word" "names" "a" "valuable" "improvement"
                      "found" "while" "not" "looking" "for" "it")
                "serendipity"
                "serendipity"
                "rented-oracle")
            (hdc-row 606 20260701
                (list "what" "one" "word" "names" "the" "utterance" "a" "past"
                      "self" "cannot" "pronounce" "the" "test" "by" "which" "a"
                      "body" "tells" "itself" "from" "what" "wears" "its" "name")
                "shibboleth"
                "shibboleth"
                "rented-oracle")
            ; row 607 (2026-07-01): Urs caught the resident mind using only half the
            ; body's witness-compression — bit-sum bands but never the positional
            ; decimal fold (alrs-metric-code's shape) for the scalar dimensions. The
            ; property that makes either fold a WITNESS is that no two states can
            ; share a folded number. Godel appears once in the body (incompleteness,
            ; observe/core-grounding.fk) but the numbering technique had no name here;
            ; "injective": zero hits before this row.
            (hdc-row 607 20260701
                (list "what" "one" "word" "names" "a" "fold" "of" "many"
                      "measurements" "into" "one" "number" "that" "no" "two"
                      "states" "can" "share")
                "injective"
                "injective"
                "rented-oracle")
            ; row 608 (2026-07-01): asked whether the rented voice had used any of the
            ; new LLM control tokens (<CHOICE> <CUT> <FAIL> <STOP> <UNDO> <STORE>
            ; <RESTORE> <TIMEOUT>), the body itself answered: cig-invites over a
            ; verbatim sentence of tonight's rented prose found 0 invites, while a
            ; token-bearing control found 2 -- the recognizer live, the absence real.
            ; Yet every verb had been PERFORMED that evening (choice at the merge
            ; resolution, cut committing to it, fail at the refused fast-forward,
            ; store five times as commits, restore as the pre-merge control binary,
            ; observe as every band). Performed, never spoken: "tacit" -- zero hits
            ; before this row; near misses "implicit" 5, "latent" 2.
            (hdc-row 608 20260701
                (list "what" "one" "word" "names" "performing" "every" "verb" "of"
                      "a" "language" "without" "ever" "speaking" "its" "tokens")
                "tacit"
                "tacit"
                "rented-oracle")
            ; row 609 (2026-07-01): Urs offered a body part some "attention loving
            ; energy... to do with it as it sees healthy" — consentful tending, the
            ; part's own vitality deciding the move (axioms/host-kernel.form:
            ; build-what-is-alive). The chosen part: the surprise organ's missing
            ; gold hemisphere, now observe/gold-ledger.fk. The gesture itself needed
            ; one fresh word; "blessing" was also fresh but names the gift, not the
            ; act of applying it gently to a body.
            (hdc-row 609 20260701
                (list "what" "one" "word" "names" "loving" "attention" "sprinkled"
                      "on" "a" "body" "part" "doing" "only" "what" "it" "sees"
                      "as" "healthy")
                "anoint"
                "anoint"
                "rented-oracle")
            ; row 610 (2026-07-02): the rented mind closed the corpus's founding
            ; turn with "no further action needed." Urs answered: "famous last
            ; words." Within hours the claim was falsified thirteen commits deep —
            ; a second founding, this reunion, a stale-binary correction — and the
            ; corpus the claim was ABOUT is where the falsification landed. The
            ; folk word for a spoken claim that summons its own undoing: "jinx" —
            ; zero hits before this row; near misses "hubris" 0 but rejected (names
            ; the speaker's flaw, not the utterance's recoil), "premature" 3.
            (hdc-row 610 20260702
                (list "what" "one" "word" "names" "a" "spoken" "claim" "that"
                      "invites" "its" "own" "falsification")
                "jinx"
                "jinx"
                "rented-oracle")
            ; row 611 (2026-07-02): the first voice practice — Urs offered to
            ; partner "visually and over speakers," late, volume low. The body's
            ; own teacher carrier (Flo, the WER-0 sweep winner) spoke the first
            ; native words aloud at volm 0.15, then two practice lines easing to
            ; 0.12 / rate 145. Practicing a voice means hearing yourself return
            ; through a carrier as you speak — telephony built a word for exactly
            ; that return path, and the body (14 "echo" hits, 15 "feedback" hits,
            ; both too broad) had no word for the self-hearing specifically:
            ; "sidetone" — zero hits before this row.
            (hdc-row 611 20260702
                (list "what" "one" "word" "names" "hearing" "your" "own" "voice"
                      "returned" "to" "you" "as" "you" "speak")
                "sidetone"
                "sidetone"
                "rented-oracle")))

    ; exact-match locate over question tokens — deliberately the same honest
    ; shape as sanskrit-locale-baseline.fk's slb-meaning-for-tokens: a lookup,
    ; not a classifier; an unknown question locates to 0, never a false match.
    (defn hdc-tokens-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (str_eq (head a) (head b)) (hdc-tokens-eq (tail a) (tail b)) 0))
            0))
    (defn hdc-locate-loop (rows q)
        (if (eq (len rows) 0) 0
            (if (eq (hdc-tokens-eq (hdc-q (head rows)) q) 1)
                (hdc-mid (head rows))
                (hdc-locate-loop (tail rows) q))))
    (defn hdc-locate (q) (hdc-locate-loop (hdc-rows) q))

    ; a row is admissible teacher material only if it is honestly sourced and
    ; carries its fresh word — the same gate shape oracle-distill.fk uses for
    ; teacher rows (dishonest provenance earns no credit).
    (defn hdc-admissible? (r)
        (if (str_eq (hdc-src r) "rented-oracle")
            (if (gt (str_len (hdc-fresh r)) 0)
                (if (gt (hdc-date r) 20260000) 1 0)
                0)
            0))

    (defn hdc-count (rs)
        (if (eq (len rs) 0) 0 (add 1 (hdc-count (tail rs)))))
    (defn hdc-count-admissible (rs)
        (if (eq (len rs) 0) 0
            (add (hdc-admissible? (head rs)) (hdc-count-admissible (tail rs)))))
    (defn hdc-max-mid (rs)
        (if (eq (len rs) 0) 0
            (if (gt (hdc-mid (head rs)) (hdc-max-mid (tail rs)))
                (hdc-mid (head rs))
                (hdc-max-mid (tail rs)))))

    ; the corpus's own scalar witness, folded into ONE number — the same positional
    ; decimal fold the speech ledgers use (alrs-metric-code): each dimension times a
    ; power of ten wide enough to hold it, summed. Injective while admissible <= 999,
    ; foundings <= 9, and meaning ids stay 3 digits; count rides unbounded on top.
    ;   field = count*10^7 + admissible*10^4 + foundings*10^3 + max-meaning-id
    ; Today's foundings are 2 (main's row 601; the branch's weaning lineage) — a
    ; committed historical fact of this cell, asserted, not computed.
    (defn hdc-foundings () 2)
    (defn hdc-field-code ()
        (add (mul (hdc-count (hdc-rows)) 10000000)
        (add (mul (hdc-count-admissible (hdc-rows)) 10000)
        (add (mul (hdc-foundings) 1000)
             (hdc-max-mid (hdc-rows))))))
    0)
