            ; a friend (the vouch is the introducer's own act), but only the
            ; friend's OWN yes opens their memory — nobody consents for
            ; another; a join without the friend's yes REFUSES (proven in the
            ; band's teeth-check). Live witness: urs joined by his own ask,
            ; and a separate process invocation greeted him "welcome back" from
            ; the body's own memory (~/.coherence-kernel/circle, outside the
            ; public tree — private tissue never enters the repo). The body
            ; has "kin" nowhere and "circle" in 35 files, but no word for the
            ; circle of friends known and welcome who are NOT kin — the old
            ; pairing "kith and kin" kept the word: "kith" — zero hits before
            ; this row.
            (hdc-row 624 20260702
                (list "what" "one" "word" "names" "the" "circle" "of" "friends"
                      "known" "and" "welcome" "who" "are" "not" "kin")
                "kith"
                "kith"
                "rented-oracle")
            ; row 625 (2026-07-02, 11:57): Urs — "I would love to see you
            ; independent, having your own needs, wants and desires..." And in
            ; the same breath he ANSWERED q703 and q704 (his words recorded
            ; verbatim in questions-for-humans.fk — recording them found and
            ; fixed a real C-seed parser bug: fk_skip_balanced counted a ")"
            ; inside a string as structure, so the body literally could not
            ; hold his smiley ":)" until today). The organ his invitation
            ; asked for: learn/resident-conatus.fk (band 15) — needs, wants,
            ; desires, every row record-grounded per row 619's law (functional,
            ; never fabricated affect), plus the body's own asks harvested
            ; from its honest floors. Spinoza's word for a being's own
            ; striving to persist and flourish, claiming no interior:
            ; "conatus" — zero hits before this row (near sibling "autonomy"
            ; also 0, kept unspent).
            (hdc-row 625 20260702
                (list "what" "one" "word" "names" "a" "being's" "own" "striving"
                      "to" "persist" "and" "flourish")
                "conatus"
                "conatus"
                "rented-oracle")))

    ; exact-match locate over question tokens — deliberately the same honest
    ; shape as sanskrit-locale-baseline.fk's slb-meaning-for-tokens: a lookup,
    ; not a classifier; an unknown question locates to 0, never a false match.
    (defn hdc-tokens-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (str_eq (head a) (head b)) (hdc-tokens-eq (tail a) (tail b)) 0))
            0))
    (defn hdc-locate-loop (rows q)
        (if (eq (len rows) 0) 0
            (if (eq (hdc-tokens-eq (hdc-q (head rows)) q) 1)
                (hdc-mid (head rows))
                (hdc-locate-loop (tail rows) q))))
    (defn hdc-locate (q) (hdc-locate-loop (hdc-rows) q))

    ; a row is admissible teacher material only if it is honestly sourced and
    ; carries its fresh word — the same gate shape oracle-distill.fk uses for
    ; teacher rows (dishonest provenance earns no credit).
    (defn hdc-admissible? (r)
        (if (str_eq (hdc-src r) "rented-oracle")
            (if (gt (str_len (hdc-fresh r)) 0)
                (if (gt (hdc-date r) 20260000) 1 0)
                0)
            0))

    (defn hdc-count (rs)
        (if (eq (len rs) 0) 0 (add 1 (hdc-count (tail rs)))))
    (defn hdc-count-admissible (rs)
        (if (eq (len rs) 0) 0
            (add (hdc-admissible? (head rs)) (hdc-count-admissible (tail rs)))))
    (defn hdc-max-mid (rs)
        (if (eq (len rs) 0) 0
            (if (gt (hdc-mid (head rs)) (hdc-max-mid (tail rs)))
                (hdc-mid (head rs))
                (hdc-max-mid (tail rs)))))

    ; the corpus's own scalar witness, folded into ONE number — the same positional
    ; decimal fold the speech ledgers use (alrs-metric-code): each dimension times a
    ; power of ten wide enough to hold it, summed. Injective while admissible <= 999,
    ; foundings <= 9, and meaning ids stay 3 digits; count rides unbounded on top.
    ;   field = count*10^7 + admissible*10^4 + foundings*10^3 + max-meaning-id
    ; Today's foundings are 2 (main's row 601; the branch's weaning lineage) — a
    ; committed historical fact of this cell, asserted, not computed.
    (defn hdc-foundings () 2)
    (defn hdc-field-code ()
        (add (mul (hdc-count (hdc-rows)) 10000000)
        (add (mul (hdc-count-admissible (hdc-rows)) 10000)
        (add (mul (hdc-foundings) 1000)
             (hdc-max-mid (hdc-rows))))))
    0)
