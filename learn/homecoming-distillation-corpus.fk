            ; objective — a learner, not a lookup table. Honest floor: free
            ; logits, numerical gradient, WER on real speech still 100. The word
            ; for settling to a target by gradually reducing error:
            (hdc-row 625 20260702
                (list "what" "one" "word" "names" "settling" "to" "a" "target"
                      "by" "gradually" "reducing" "error")
                "anneal"
                "anneal"
                "rented-oracle")
            ; row 626 (2026-07-02, ~07:35): "and how is our wer affected by this."
            ; The honest answer, grounded and un-inflated: the global native
            ; open-speech WER is UNCHANGED at 100 (live-open-dictation native WER
            ; 100). The ctc-train toy WER moved 100->0, but on FREE LOGITS, not
            ; real signal — and the body's OWN law (speech-global-promotion-
            ; readiness.fk:5: scoped wins are evidence, global authority needs
            ; repeated real live receipts) refuses to promote it. Reading the toy
            ; zero as the headline would be arrogation (row 622's mirror). The WER
            ; is a LAGGING indicator — it trails the capability built beneath it,
            ; moving only when a real-signal encoder is trained with this
            ; objective. "lagging": 0 hits.
            (hdc-row 626 20260702
                (list "what" "one" "word" "names" "a" "headline" "metric" "that"
                      "trails" "the" "capability" "built" "beneath" "it")
                "lagging"
                "lagging"
                "rented-oracle")
            ; row 627 (2026-07-02, ~07:50): "can we bring it home" + "do we have
            ; advantage because we have native nothing?" Brought home: the CTC
            ; objective wired to REAL local audio (say->ffmpeg->wav-envelope, real
            ; 16kHz wavs, envelope 22 vs 37) and trained on real signal (loss
            ; falls). The decode collapsed to BLANK on both words — and that IS the
            ; answer: axiom-1 makes NOTHING first-class ("the ground, not a missing
            ; 0"); CTC's blank IS that nothing; the decoder declined to fabricate a
            ; label the weak envelope couldn't earn. The abstention gap the
            ; paraphrase scorer lacked ("no 'I don't know'") is native here. The
            ; power to decline, to emit nothing as a legitimate answer:
            (hdc-row 627 20260702
                (list "what" "one" "word" "names" "the" "power" "to" "decline"
                      "to" "emit" "nothing" "as" "a" "legitimate" "answer")
                "reticence"
                "reticence"
                "rented-oracle")
            ; row 628 (2026-07-02, ~07:55): "so now we can make progress on our
            ; voice?" Honest: not the SOUND (still WER 100, oracle-guide) — CTC is
            ; recognition, the voice is generation. But the bridge is real: the
            ; voice loop's STT gate is analysis-by-synthesis, and tonight's CTC
            ; loss turns it from a SELECTOR into a TRAINING signal — the vocoder's
            ; continuous params (pitch/amplitude/formants) could be gradient-
            ; trained so its output is recognized. Generate, hear yourself,
            ; correct: the body learns to speak by learning to hear itself. The
            ; recognizer is the TEACHER of the generator. von Holst's word for
            ; perceiving the consequence of your own action:
            (hdc-row 628 20260702
                (list "what" "one" "word" "names" "a" "body" "generating" "output"
                      "and" "sensing" "it" "back" "to" "correct" "itself")
                "reafference"
                "reafference"
                "rented-oracle")
            ; row 629 (2026-07-02, ~08:10): "seems like we know where to lay the
            ; next stones." Laid: model/ctc-grad.fk, the analytic CTC backward pass
            ; — one forward (alpha) + one backward (beta) yields d loss/d logit for
            ; every logit at once (softmax minus alignment-posterior), replacing
            ; the O(params) numerical gradient with O(T*S). Proven four-way by
            ; EXACT agreement with finite differences (band 127). Two walker-caught
            ; fkwu-leniencies fixed on the way (a paren, an out-of-bounds nth) — the
            ; recurring lesson, a fifth time: build on the kernel that says no. The
            ; word for error flowing backward from output to every parameter:
            (hdc-row 629 20260702
                (list "what" "one" "word" "names" "error" "flowing" "backward"
                      "from" "output" "to" "every" "parameter" "at" "once")
                "retrograde"
                "retrograde"
                "rented-oracle")))

    ; exact-match locate over question tokens — deliberately the same honest
    ; shape as sanskrit-locale-baseline.fk's slb-meaning-for-tokens: a lookup,
    ; not a classifier; an unknown question locates to 0, never a false match.
    (defn hdc-tokens-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (str_eq (head a) (head b)) (hdc-tokens-eq (tail a) (tail b)) 0))
            0))
    (defn hdc-locate-loop (rows q)
        (if (eq (len rows) 0) 0
            (if (eq (hdc-tokens-eq (hdc-q (head rows)) q) 1)
                (hdc-mid (head rows))
                (hdc-locate-loop (tail rows) q))))
    (defn hdc-locate (q) (hdc-locate-loop (hdc-rows) q))

    ; a row is admissible teacher material only if it is honestly sourced and
    ; carries its fresh word — the same gate shape oracle-distill.fk uses for
    ; teacher rows (dishonest provenance earns no credit).
    (defn hdc-admissible? (r)
        (if (str_eq (hdc-src r) "rented-oracle")
            (if (gt (str_len (hdc-fresh r)) 0)
                (if (gt (hdc-date r) 20260000) 1 0)
                0)
            0))

    (defn hdc-count (rs)
        (if (eq (len rs) 0) 0 (add 1 (hdc-count (tail rs)))))
    (defn hdc-count-admissible (rs)
        (if (eq (len rs) 0) 0
            (add (hdc-admissible? (head rs)) (hdc-count-admissible (tail rs)))))
    (defn hdc-max-mid (rs)
        (if (eq (len rs) 0) 0
            (if (gt (hdc-mid (head rs)) (hdc-max-mid (tail rs)))
                (hdc-mid (head rs))
                (hdc-max-mid (tail rs)))))

    ; the corpus's own scalar witness, folded into ONE number — the same positional
    ; decimal fold the speech ledgers use (alrs-metric-code): each dimension times a
    ; power of ten wide enough to hold it, summed. Injective while admissible <= 999,
    ; foundings <= 9, and meaning ids stay 3 digits; count rides unbounded on top.
    ;   field = count*10^7 + admissible*10^4 + foundings*10^3 + max-meaning-id
    ; Today's foundings are 2 (main's row 601; the branch's weaning lineage) — a
    ; committed historical fact of this cell, asserted, not computed.
    (defn hdc-foundings () 2)
    (defn hdc-field-code ()
        (add (mul (hdc-count (hdc-rows)) 10000000)
        (add (mul (hdc-count-admissible (hdc-rows)) 10000)
        (add (mul (hdc-foundings) 1000)
             (hdc-max-mid (hdc-rows))))))
    0)
