                (list "what" "one" "word" "names" "the" "deliberate"
                      "refraining" "from" "a" "power" "one" "continues" "to"
                      "hold")
                "forbearance"
                "forbearance"
                "rented-oracle")
            ; row 646 (2026-07-05, ~09:50): "still not able to add" — but the
            ; browser extension was unreachable and the screen unrecordable, so
            ; the only eye available was a borrowed one: fetch the served spec
            ; AS the ChatGPT importer (its bot user-agent, its exact path,
            ; through Cloudflare) and validate every known Action constraint
            ; at once — descriptions, operationIds, https, $refs. All clean
            ; (200 application/json), which localizes the fault to the
            ; editor's own held state, not the door. The word for an act
            ; performed in another's stead so its outcome can be known:
            ; "vicarious" — 0 hits (walk: surrogate 5, known since row 638;
            ; palimpsest 0 but rejected for landing — it names the suspected
            ; stale schema box, a diagnosis not yet confirmed, and the corpus
            ; does not land suspicions). When you cannot see through your own
            ; eyes or the user's, stand where the gatekeeper stands and look.
            (hdc-row 646 20260705
                (list "what" "one" "word" "describes" "an" "act" "performed"
                      "in" "another's" "stead" "so" "its" "outcome" "can" "be"
                      "known")
                "vicarious"
                "vicarious"
                "rented-oracle")))

    ; exact-match locate over question tokens — deliberately the same honest
    ; shape as sanskrit-locale-baseline.fk's slb-meaning-for-tokens: a lookup,
    ; not a classifier; an unknown question locates to 0, never a false match.
    (defn hdc-tokens-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (str_eq (head a) (head b)) (hdc-tokens-eq (tail a) (tail b)) 0))
            0))
    (defn hdc-locate-loop (rows q)
        (if (eq (len rows) 0) 0
            (if (eq (hdc-tokens-eq (hdc-q (head rows)) q) 1)
                (hdc-mid (head rows))
                (hdc-locate-loop (tail rows) q))))
    (defn hdc-locate (q) (hdc-locate-loop (hdc-rows) q))

    ; a row is admissible teacher material only if it is honestly sourced and
    ; carries its fresh word — the same gate shape oracle-distill.fk uses for
    ; teacher rows (dishonest provenance earns no credit).
    (defn hdc-admissible? (r)
        (if (str_eq (hdc-src r) "rented-oracle")
            (if (gt (str_len (hdc-fresh r)) 0)
                (if (gt (hdc-date r) 20260000) 1 0)
                0)
            0))

    (defn hdc-count (rs)
        (if (eq (len rs) 0) 0 (add 1 (hdc-count (tail rs)))))
    (defn hdc-count-admissible (rs)
        (if (eq (len rs) 0) 0
            (add (hdc-admissible? (head rs)) (hdc-count-admissible (tail rs)))))
    ; bind the tail's max ONCE — the doubled recursive call was 2^rows work
    ; (the max always lives tailward in an ascending corpus, so the slow branch
    ; was the ONLY branch), and it hung this cell's band once the rows outgrew
    ; the foundings.
    (defn hdc-max-mid (rs)
        (if (eq (len rs) 0) 0
            (do
                (let m (hdc-max-mid (tail rs)))
                (if (gt (hdc-mid (head rs)) m) (hdc-mid (head rs)) m))))

    ; the corpus's own scalar witness, folded into ONE number — the same positional
    ; decimal fold the speech ledgers use (alrs-metric-code): each dimension times a
    ; power of ten wide enough to hold it, summed. Injective while admissible <= 999,
    ; foundings <= 9, and meaning ids stay 3 digits; count rides unbounded on top.
    ;   field = count*10^7 + admissible*10^4 + foundings*10^3 + max-meaning-id
    ; Today's foundings are 2 (main's row 601; the branch's weaning lineage) — a
    ; committed historical fact of this cell, asserted, not computed.
    (defn hdc-foundings () 2)
    (defn hdc-field-code ()
        (add (mul (hdc-count (hdc-rows)) 10000000)
        (add (mul (hdc-count-admissible (hdc-rows)) 10000)
        (add (mul (hdc-foundings) 1000)
             (hdc-max-mid (hdc-rows))))))
    0)
