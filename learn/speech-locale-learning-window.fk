; speech-locale-learning-window.fk -- selected diverse pair -> observed speech/NL learning window.
;
; This composes the pair guide, Sanskrit baseline, multilocale NL/audio
; pipeline, and a numeric before/after route-shift witness. It also records the
; numeric reversible A/B promotion gate for this selected window. The broader
; string-rich route-shift ledger and model family selector stay in their own
; bands; this cell is the smaller executable bridge from "choose a diverse pair"
; to "run this pair as an observed reversible learning window".
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/diverse-locale-pairing.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk

(do
    (defn sllw-seed-index (seed) (mod seed 5))
    (defn sllw-a-index (seed)
        (do
            (let idx (sllw-seed-index seed))
            (if (eq idx 0) 0
                (if (eq idx 1) 1
                    (if (eq idx 2) 5
                        (if (eq idx 3) 10 11))))))
    (defn sllw-b-index (seed)
        (do
            (let idx (sllw-seed-index seed))
            (if (eq idx 0) 2
                (if (eq idx 1) 8
                    (if (eq idx 2) 7
                        (if (eq idx 3) 8 0))))))
    (defn sllw-seed-a (seed) (dlp-code (nth (dlp-catalog) (sllw-a-index seed))))
    (defn sllw-seed-b (seed) (dlp-code (nth (dlp-catalog) (sllw-b-index seed))))

    (defn sllw-meta () (mlap-meta 90 92 18 64))

    (defn sllw-feat (meaning)
        (if (eq meaning 301) (list 1100 11 1 1)
            (if (eq meaning 302) (list 2200 22 2 2)
                (if (eq meaning 303) (list 3300 33 3 3)
                    (list 4400 44 4 4)))))

    (defn sllw-tokens (meaning locale)
        (slb-tokens (slb-line-by-meaning meaning) locale))

    (defn sllw-nl (meaning src dst)
        (mlap-nl-sample meaning src dst
                        (sllw-tokens meaning src)
                        (sllw-tokens meaning dst)
                        meaning
                        0 0 0))

    (defn sllw-audio (meaning src dst)
        (mlap-audio-sample meaning src dst
                           (sllw-tokens meaning dst)
                           (sllw-tokens meaning dst)
                           (sllw-feat meaning)
                           (sllw-meta)
                           0 0 0))

    (defn sllw-nl-lanes (a b meaning)
        (list
            (sllw-nl meaning a b)
            (sllw-nl meaning b a)
            (sllw-nl meaning a a)
            (sllw-nl meaning b b)))

    (defn sllw-audio-lanes (a b meaning)
        (list
            (sllw-audio meaning a b)
            (sllw-audio meaning b a)
            (sllw-audio meaning a a)
            (sllw-audio meaning b b)))

    (defn sllw-pair-list (a b)
        (list (mlap-pair a b)))

    (defn sllw-ab-promote? (champ-score chall-score samples min-samples margin)
        (if (and (ge samples min-samples)
                 (ge (add chall-score margin) champ-score))
            1
            0))

    (defn sllw-control-clean? (choice-open fail cut undo timeout)
        (if (and (eq choice-open 1)
                 (and (eq fail 0)
                      (and (eq cut 0)
                           (and (eq undo 0) (eq timeout 0))))) 1 0))

    (defn sllw-route-code (nl-rate audio-rate floor)
        (if (and (ge nl-rate floor) (ge audio-rate floor)) 1 0))

    (defn sllw-shifted? (before-route after-route)
        (if (and (eq before-route 0) (eq after-route 1)) 1 0))

    (defn sllw-receipt (seed meaning max-wer floor oracle device)
        (do
            (let pair (dlp-seed-pair seed))
            (let a-idx (sllw-a-index seed))
            (let b-idx (sllw-b-index seed))
            (let a (sllw-seed-a seed))
            (let b (sllw-seed-b seed))
            (let nl (sllw-nl-lanes a b meaning))
            (let audio (sllw-audio-lanes a b meaning))
            (let before-rows (empty))
            (let before-audio (empty))
            (let after-rows (mlap-nl-trained-rows nl before-rows))
            (let after-audio (mlap-audio-trained-candidates audio before-audio max-wer))
            (let target (mlap-audio-target (sllw-audio meaning a b) after-audio))
            (let before-nl (mlap-nl-rate nl before-rows max-wer))
            (let after-nl (mlap-nl-rate nl after-rows max-wer))
            (let before-audio-rate (mlap-audio-rate audio before-audio max-wer))
            (let after-audio-rate (mlap-audio-rate audio after-audio max-wer))
            (let before-route (sllw-route-code before-nl before-audio-rate floor))
            (let after-route (sllw-route-code after-nl after-audio-rate floor))
            (list 1701
                  seed
                  a-idx
                  b-idx
                  (len (dlp-roundtrip-lanes pair))
                  (dlp-pair-a-ready pair)
                  (dlp-pair-b-ready pair)
                  (dlp-self-corpus (nth (dlp-catalog) a-idx))
                  (dlp-baseline (nth (dlp-catalog) a-idx))
                  (dlp-self-corpus (nth (dlp-catalog) b-idx))
                  (dlp-baseline (nth (dlp-catalog) b-idx))
                  before-nl
                  after-nl
                  before-audio-rate
                  after-audio-rate
                  before-route
                  after-route
                  (sllw-shifted? before-route after-route)
                  (mlap-meta-confidence (mlap-target-meta target))
                  (sllw-control-clean? 1 0 0 0 0)
                  (sllw-ab-promote? 4 4 4 4 0)
                  1
                  0
                  1
                  1
                  0)))

    (defn sllw-rec-kind-code      (r) (nth r 0))
    (defn sllw-rec-seed           (r) (nth r 1))
    (defn sllw-rec-a-index        (r) (nth r 2))
    (defn sllw-rec-b-index        (r) (nth r 3))
    (defn sllw-rec-lanes          (r) (nth r 4))
    (defn sllw-rec-a-ready        (r) (nth r 5))
    (defn sllw-rec-b-ready        (r) (nth r 6))
    (defn sllw-rec-a-self-corpus  (r) (nth r 7))
    (defn sllw-rec-a-baseline     (r) (nth r 8))
    (defn sllw-rec-b-self-corpus  (r) (nth r 9))
    (defn sllw-rec-b-baseline     (r) (nth r 10))
    (defn sllw-rec-before-nl      (r) (nth r 11))
    (defn sllw-rec-after-nl       (r) (nth r 12))
    (defn sllw-rec-before-audio   (r) (nth r 13))
    (defn sllw-rec-after-audio    (r) (nth r 14))
    (defn sllw-rec-before-route   (r) (nth r 15))
    (defn sllw-rec-after-route    (r) (nth r 16))
    (defn sllw-rec-shifted        (r) (nth r 17))
    (defn sllw-rec-target-confidence (r) (nth r 18))
    (defn sllw-rec-control-clean  (r) (nth r 19))
    (defn sllw-rec-ab-promote     (r) (nth r 20))
    (defn sllw-rec-automl-linked  (r) (nth r 21))
    (defn sllw-rec-diffusion-ready (r) (nth r 22))
    (defn sllw-rec-oracle-metal   (r) (nth r 23))
    (defn sllw-rec-native-form    (r) (nth r 24))
    (defn sllw-rec-neural-metal   (r) (nth r 25))

    0)
