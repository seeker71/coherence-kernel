; speech-global-authority-update.fk -- update global speech routes from live receipts.
;
; speech-live-receipt-intake.fk defines what counts as a real live receipt.
; This cell applies that intake to each global lane and returns the route update.
; Current rows are still empty and stay oracle-guide; demo rows prove the same
; law would move authority when carriers emit three clean real live receipts.
;
; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/speech-open-asr-trial-window-0002.fk
;   learn/speech-open-asr-trial-window-0003.fk
;   learn/sema-voice-trial-window.fk
;   learn/speech-current-status-ledger.fk
;   learn/speech-global-promotion-readiness.fk
;   learn/speech-live-receipt-intake.fk

(do
    (defn sgau-route (rows lane required max-wer min-confidence max-latency native-route)
        (if (eq (slri-ready? rows lane required max-wer min-confidence max-latency) 1)
            native-route
            "oracle-guide"))

    (defn sgau-lane-update (lane rows native-route)
        (do
            (let required 3)
            (let count (slri-count-lane rows lane 25 80 2000))
            (list "speech-global-authority-update-lane"
                  lane
                  count
                  required
                  (sgpr-max 0 (sub required count))
                  (sgau-route rows lane required 25 80 2000 native-route)
                  25
                  80
                  2000
                  "choice-cut-fail-undo-timeout-clean")))

    (defn sgau-lane-name     (u) (nth u 1))
    (defn sgau-lane-count    (u) (nth u 2))
    (defn sgau-lane-required (u) (nth u 3))
    (defn sgau-lane-missing  (u) (nth u 4))
    (defn sgau-lane-route    (u) (nth u 5))
    (defn sgau-lane-max-wer  (u) (nth u 6))
    (defn sgau-lane-min-conf (u) (nth u 7))
    (defn sgau-lane-max-latency (u) (nth u 8))
    (defn sgau-lane-controls (u) (nth u 9))

    (defn sgau-current-updates ()
        (do
            (let rows (slri-current-rows))
            (list
                (sgau-lane-update "live-open-dictation" rows "native-open-asr-source")
                (sgau-lane-update "sema-live-voice" rows "native-sema-voice"))))

    (defn sgau-demo-updates ()
        (do
            (let open-rows (slri-demo-open-rows))
            (let voice-rows (slri-demo-voice-rows))
            (list
                (sgau-lane-update "live-open-dictation" open-rows "native-open-asr-source")
                (sgau-lane-update "sema-live-voice" voice-rows "native-sema-voice"))))

    (defn sgau-count-route (updates route)
        (if (eq (len updates) 0) 0
            (add (if (str_eq (sgau-lane-route (head updates)) route) 1 0)
                 (sgau-count-route (tail updates) route))))

    (defn sgau-missing-total (updates)
        (if (eq (len updates) 0) 0
            (add (sgau-lane-missing (head updates)) (sgau-missing-total (tail updates)))))

    (defn sgau-report ()
        (do
            (let current (sgau-current-updates))
            (let demo (sgau-demo-updates))
            (list "speech-global-authority-update"
                  current
                  demo
                  (sgau-count-route current "oracle-guide")
                  (sgau-missing-total current)
                  (sgau-count-route demo "native-open-asr-source")
                  (sgau-count-route demo "native-sema-voice")
                  (sgau-missing-total demo)
                  "current-empty-receipts-stay-oracle-guide"
                  "three-clean-live-receipts-move-global-route"
                  1
                  0)))

    0)
