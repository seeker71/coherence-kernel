; speech-native-neural-pair-window-0036.fk -- thirty-sixth native neural pair window.
;
; The previous scheduler target named fr<->de, but de<->fr already landed in
; window 0017. This window corrects the next background pair movement to the
; uncovered fr<->it pair. Fresh Mac Metal local-oracle probes check the French
; and Italian renderings for the same neutral meaning, then the Form-native
; NL/audio micro-pair shifts from oracle-held to native within this closed pair
; window. This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw36-kind () "speech-native-neural-pair-window-0036")
    (defn snpw36-a () "fr")
    (defn snpw36-b () "it")
    (defn snpw36-meaning () 303)
    (defn snpw36-floor () 50)
    (defn snpw36-max-wer () 25)
    (defn snpw36-meta () (mlap-meta 96 96 12 79))
    (defn snpw36-feat () (list 3041 36 2 2))
    (defn snpw36-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw36-meaning)) locale))

    (defn snpw36-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0036-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw36-oracle-locale (r) (nth r 1))
    (defn snpw36-oracle-voice  (r) (nth r 2))
    (defn snpw36-oracle-transcript (r) (nth r 3))
    (defn snpw36-oracle-wer    (r) (nth r 4))
    (defn snpw36-oracle-bytes  (r) (nth r 5))
    (defn snpw36-oracle-cksum  (r) (nth r 6))
    (defn snpw36-oracle-name   (r) (nth r 7))
    (defn snpw36-oracle-device (r) (nth r 8))

    (defn snpw36-oracle-rows ()
        (list
            (snpw36-oracle-row "fr" "Thomas" "Je suis" 0 17908 3224208913)
            (snpw36-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw36-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw36-oracle-wer (head rows)) (snpw36-max-wer)) 1 0)
                 (snpw36-oracle-ok-loop (tail rows)))))
    (defn snpw36-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw36-oracle-bytes (head rows))
                 (snpw36-oracle-byte-total-loop (tail rows)))))

    (defn snpw36-nl (src dst)
        (mlap-nl-sample (snpw36-meaning) src dst
                         (snpw36-tokens src)
                         (snpw36-tokens dst)
                         (snpw36-meaning)
                         0 0 0))

    (defn snpw36-audio (src dst)
        (mlap-audio-sample (snpw36-meaning) src dst
                            (snpw36-tokens dst)
                            (snpw36-tokens dst)
                            (snpw36-feat)
                            (snpw36-meta)
                            0 0 0))

    (defn snpw36-nl-lanes ()
        (list
            (snpw36-nl (snpw36-a) (snpw36-b))
            (snpw36-nl (snpw36-b) (snpw36-a))
            (snpw36-nl (snpw36-a) (snpw36-a))
            (snpw36-nl (snpw36-b) (snpw36-b))))

    (defn snpw36-audio-lanes ()
        (list
            (snpw36-audio (snpw36-a) (snpw36-b))
            (snpw36-audio (snpw36-b) (snpw36-a))
            (snpw36-audio (snpw36-a) (snpw36-a))
            (snpw36-audio (snpw36-b) (snpw36-b))))

    (defn snpw36-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw36-receipt ()
        (do
            (let nl (snpw36-nl-lanes))
            (let audio (snpw36-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw36-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw36-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw36-max-wer)))
            (let oracle-rows (snpw36-oracle-rows))
            (let oracle-ok (snpw36-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw36-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw36-kind)
                  (snpw36-a)
                  (snpw36-b)
                  (snpw36-meaning)
                  1
                  2
                  36
                  72
                  36
                  36
                  before
                  after
                  (if (and (lt before (snpw36-floor)) (ge after (snpw36-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw36-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0036-trained-not-open-authority")))

    (defn snpw36-rec-kind            (r) (nth r 0))
    (defn snpw36-rec-a               (r) (nth r 1))
    (defn snpw36-rec-b               (r) (nth r 2))
    (defn snpw36-rec-meaning         (r) (nth r 3))
    (defn snpw36-rec-pair-increment  (r) (nth r 4))
    (defn snpw36-rec-directed-increment (r) (nth r 5))
    (defn snpw36-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw36-rec-cumulative-directed (r) (nth r 7))
    (defn snpw36-rec-epochs          (r) (nth r 8))
    (defn snpw36-rec-params          (r) (nth r 9))
    (defn snpw36-rec-before-rate     (r) (nth r 10))
    (defn snpw36-rec-after-rate      (r) (nth r 11))
    (defn snpw36-rec-shifted         (r) (nth r 12))
    (defn snpw36-rec-form-nl         (r) (nth r 13))
    (defn snpw36-rec-form-audio      (r) (nth r 14))
    (defn snpw36-rec-before-loss     (r) (nth r 15))
    (defn snpw36-rec-after-loss      (r) (nth r 16))
    (defn snpw36-rec-oracle-ok       (r) (nth r 17))
    (defn snpw36-rec-oracle-total    (r) (nth r 18))
    (defn snpw36-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw36-rec-oracle          (r) (nth r 20))
    (defn snpw36-rec-native-form     (r) (nth r 21))
    (defn snpw36-rec-neural          (r) (nth r 22))
    (defn snpw36-rec-open-authority  (r) (nth r 23))
    (defn snpw36-rec-status          (r) (nth r 24))

    0)
