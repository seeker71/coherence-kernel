; session-native-teaching.fk — this session's expensive oracle turns, captured as
; SELF-LABELS the native arm trains on, so we never buy the same correction twice.
;
; The pattern that ran live (2026-06-29): a rented frontier oracle (Claude) asserted
; structural claims FROM STALE MEMORY, and each time the BODY — read and TESTED —
; overturned them. Those corrections are the highest-value exemplars in the whole
; economy: maximal surprise (rented-guess != grounded-truth), and they all teach the
; SAME meta-label — ground in the body before trusting a rented assertion. That is
; cognitive sovereignty as a training signal (lc-cognitive-sovereignty).
;
; Each exemplar is (claim rented-guess grounded-truth) where guess != truth ⇒ surprise
; is high ⇒ a witnessed correction ⇒ a self-label. perception-cascade/oracle-distill
; consume exactly this shape: the settled (grounded) answer feeds back; native error
; to it drops; once native predicts "ground, don't assert" it stops paying the oracle.
;
; preludes: core.fk surprise-receipt.fk oracle-distill.fk
(do
    ; an exemplar: the rented guess vs the grounded truth, as a (predicted, actual) event
    ; for sr-surprise. guess/truth are coded ids; the point is guess != truth = a buy worth
    ; keeping. surprise >= 3 ⇒ it earned a self-label (sr-receipt?).
    (defn snt-exemplar (claim guess truth) (list claim guess truth))
    (defn snt-claim (e) (nth e 0))
    (defn snt-guess (e) (nth e 1))
    (defn snt-truth (e) (nth e 2))
    (defn snt-surprise (e) (sr-surprise (list (snt-guess e) (snt-truth e))))
    (defn snt-self-label? (e) (sr-receipt? (list (snt-guess e) (snt-truth e))))

    ; the session's four captured corrections (guess 0 = the rented assertion, truth = the
    ; grounded reality; coded so guess != truth):
    ;   flatten    rented: "doesn't stand on Windows" (0)  | ground: "direct source bootstrap stands; remaining gap is coverage/lowering" (9)
    ;   bin-go     rented: "bin-go is the seed" (0)         | ground: "fkwu-self-derivable; bin-go stale" (8)
    ;   pixel-walk rented: "must be C" (0)                  | ground: "Form recipe, lowered (stack-bound, not C)" (9)
    ;   jit        rented: "JIT must be in C" (0)           | ground: "JIT is Form; only install+call HAL" (9)
    (defn snt-corpus ()
        (list (snt-exemplar "flatten"    0 9)
              (snt-exemplar "bin-go"     0 8)
              (snt-exemplar "pixel-walk" 0 9)
              (snt-exemplar "jit"        0 9)))

    ; every captured correction shares ONE meta-label the native arm distills toward:
    ; prefer-ground-over-rented. od-distills? / od-sovereign? read the error-drop:
    ; before = high (the rented guess was wrong), after -> low, unseen-error low = sovereign.
    (defn snt-meta-distill () (list 1 9 2 2))   ; oracle teacher, error 9 -> 2, unseen 2 = sovereign
    (defn snt-count-self-labels (es)
        (if (eq (len es) 0) 0 (add (snt-self-label? (head es)) (snt-count-self-labels (tail es)))))

    (defn sntk (cond bit) (if cond bit 0))
    (defn session-native-teaching-check ()
        (add (add (add
            (sntk (eq (snt-count-self-labels (snt-corpus)) 4) 1)          ; all 4 corrections earned self-labels
            (sntk (eq (snt-surprise (snt-exemplar "jit" 0 9)) 9) 10))     ; the rented JIT guess was maximally surprising
            (sntk (eq (od-distills? (snt-meta-distill)) 1) 100))          ; native error to the grounded truth DROPS
            (sntk (eq (od-sovereign? (snt-meta-distill)) 1) 1000)))       ; and generalizes -> sovereign (ground beats rent)
    0)
