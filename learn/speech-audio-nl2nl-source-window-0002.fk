; speech-audio-nl2nl-source-window-0002.fk -- hi/it audio to neutral to audio.
;
; A second observed source-window bridge adds Hindi and Italian loopback rows.
; Source audio is heard by the local Metal oracle, native Form maps the
; transcript to a locale-neutral greeting meaning, then target text/audio is
; checked by the same local oracle. Host TTS and Whisper remain
; carriers/oracles; native ownership is the neutral route and target selection.
;
; preludes: observe/stt-wer.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk

(do
    (defn sanw2-kind () "speech-audio-nl2nl-source-window-0002")
    (defn sanw2-meaning () 601)
    (defn sanw2-max-wer () 25)

    (defn sanw2-row (id src dst src-truth src-heard dst-target dst-heard
                        src-hash dst-hash src-bytes dst-bytes)
        (list "speech-audio-nl2nl-source-window-row"
              id src dst src-truth src-heard dst-target dst-heard
              src-hash dst-hash src-bytes dst-bytes))

    (defn sanw2-row-src       (r) (nth r 2))
    (defn sanw2-row-dst       (r) (nth r 3))
    (defn sanw2-row-src-truth (r) (nth r 4))
    (defn sanw2-row-src-heard (r) (nth r 5))
    (defn sanw2-row-dst-text  (r) (nth r 6))
    (defn sanw2-row-dst-heard (r) (nth r 7))
    (defn sanw2-row-src-bytes (r) (nth r 10))
    (defn sanw2-row-dst-bytes (r) (nth r 11))

    (defn sanw2-rows ()
        (list
            (sanw2-row 9701 "hi" "it"
                       "namaste" "Namaste." "ciao" "Ciao!"
                       2559270416 4165678203 19888 25444)
            (sanw2-row 9702 "it" "hi"
                       "ciao" "Ciao!" "namaste" "Namaste."
                       4165678203 2559270416 25444 19888)))

    (defn sanw2-src-ok? (r)
        (sw-accept? (sw-tokens (sanw2-row-src-heard r))
                    (sw-tokens (sanw2-row-src-truth r))
                    (sanw2-max-wer)))
    (defn sanw2-dst-ok? (r)
        (sw-accept? (sw-tokens (sanw2-row-dst-heard r))
                    (sw-tokens (sanw2-row-dst-text r))
                    (sanw2-max-wer)))

    (defn sanw2-native-meaning (r)
        (if (str_eq (sanw2-row-src r) "hi")
            (if (eq (sanw2-src-ok? r) 1) (sanw2-meaning) 0)
            (if (str_eq (sanw2-row-src r) "it")
                (if (eq (sanw2-src-ok? r) 1) (sanw2-meaning) 0)
                0)))

    (defn sanw2-target-text (meaning dst)
        (if (eq meaning (sanw2-meaning))
            (if (str_eq dst "hi") "namaste"
                (if (str_eq dst "it") "ciao" ""))
            ""))

    (defn sanw2-native-ok? (r)
        (if (and (eq (sanw2-native-meaning r) (sanw2-meaning))
                 (and (str_eq (sanw2-target-text (sanw2-native-meaning r) (sanw2-row-dst r))
                              (sanw2-row-dst-text r))
                      (eq (sanw2-dst-ok? r) 1))) 1 0))

    (defn sanw2-row-bytes (r) (add (sanw2-row-src-bytes r) (sanw2-row-dst-bytes r)))

    (defn sanw2-count-src (rows)
        (if (eq (len rows) 0) 0
            (add (sanw2-src-ok? (head rows)) (sanw2-count-src (tail rows)))))
    (defn sanw2-count-dst (rows)
        (if (eq (len rows) 0) 0
            (add (sanw2-dst-ok? (head rows)) (sanw2-count-dst (tail rows)))))
    (defn sanw2-count-native (rows)
        (if (eq (len rows) 0) 0
            (add (sanw2-native-ok? (head rows)) (sanw2-count-native (tail rows)))))
    (defn sanw2-total-bytes (rows)
        (if (eq (len rows) 0) 0
            (add (sanw2-row-bytes (head rows)) (sanw2-total-bytes (tail rows)))))

    (defn sanw2-receipt ()
        (do
            (let rows (sanw2-rows))
            (list (sanw2-kind)
                  rows
                  (len rows)
                  (sanw2-count-src rows)
                  (sanw2-count-dst rows)
                  (sanw2-count-native rows)
                  (sanw2-total-bytes rows)
                  (sanw2-meaning)
                  "hi<->it"
                  "whisper.cpp-large-v3-turbo-metal"
                  "macos-arm64-m4-max"
                  "oracle-guided-source-window-audio-nl2nl-audio-bridge-not-native-vocoder"
                  1
                  1
                  0
                  0)))

    (defn sanw2-rec-kind      (r) (nth r 0))
    (defn sanw2-rec-count     (r) (nth r 2))
    (defn sanw2-rec-src-ok    (r) (nth r 3))
    (defn sanw2-rec-dst-ok    (r) (nth r 4))
    (defn sanw2-rec-native-ok (r) (nth r 5))
    (defn sanw2-rec-bytes     (r) (nth r 6))
    (defn sanw2-rec-meaning   (r) (nth r 7))
    (defn sanw2-rec-pair      (r) (nth r 8))
    (defn sanw2-rec-status    (r) (nth r 11))
    (defn sanw2-rec-native    (r) (nth r 12))
    (defn sanw2-rec-oracle    (r) (nth r 13))
    (defn sanw2-rec-vocoder   (r) (nth r 14))
    (defn sanw2-rec-neural    (r) (nth r 15))

    0)
