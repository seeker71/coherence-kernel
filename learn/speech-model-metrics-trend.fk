; speech-model-metrics-trend.fk -- before/after movement in speech model metrics.
;
; speech-model-metrics-report.fk is the current snapshot. This cell records the
; movement: which speech lanes shifted from oracle-guide to native, which are
; still held by the local oracle, and the current improvement deltas.

(do
    (defn smmt-delta (before after) (sub after before))
    (defn smmt-shifted? (before-route after-route)
        (if (and (str_eq before-route "oracle-guide")
                 (str_eq after-route "native")) 1 0))

    (defn smmt-row (name before-rate after-rate oracle-rate native-rate
                         before-route after-route quality wer)
        (list "speech-model-metrics-trend-row"
              name
              before-rate
              after-rate
              (smmt-delta before-rate after-rate)
              oracle-rate
              native-rate
              before-route
              after-route
              (smmt-shifted? before-route after-route)
              quality
              wer))

    (defn smmt-name         (r) (nth r 1))
    (defn smmt-before       (r) (nth r 2))
    (defn smmt-after        (r) (nth r 3))
    (defn smmt-delta-row    (r) (nth r 4))
    (defn smmt-oracle-rate  (r) (nth r 5))
    (defn smmt-native-rate  (r) (nth r 6))
    (defn smmt-before-route (r) (nth r 7))
    (defn smmt-after-route  (r) (nth r 8))
    (defn smmt-shifted-row  (r) (nth r 9))
    (defn smmt-quality      (r) (nth r 10))
    (defn smmt-wer          (r) (nth r 11))

    (defn smmt-mac-audio-row ()
        (smmt-row "mac-metal-reciprocal-audio" 0 83 100 83
                  "oracle-guide" "native" 83 17))
    (defn smmt-multiseed-row ()
        (smmt-row "multiseed-nl-audio" 0 100 100 100
                  "oracle-guide" "native" 100 0))
    (defn smmt-open-dictation-row ()
        (smmt-row "live-open-dictation" 0 0 100 0
                  "oracle-guide" "oracle-guide" 0 100))
    (defn smmt-sema-voice-row ()
        (smmt-row "sema-live-voice" 0 0 100 0
                  "oracle-guide" "oracle-guide" 0 100))

    (defn smmt-rows ()
        (list
            (smmt-mac-audio-row)
            (smmt-multiseed-row)
            (smmt-open-dictation-row)
            (smmt-sema-voice-row)))

    (defn smmt-shift-count (rows)
        (if (eq (len rows) 0) 0
            (add (smmt-shifted-row (head rows)) (smmt-shift-count (tail rows)))))

    (defn smmt-oracle-held-count (rows)
        (if (eq (len rows) 0) 0
            (add
                (if (str_eq (smmt-after-route (head rows)) "oracle-guide") 1 0)
                (smmt-oracle-held-count (tail rows)))))

    (defn smmt-average-native-loop (rows acc count)
        (if (eq (len rows) 0)
            (if (eq count 0) 0 (div acc count))
            (smmt-average-native-loop
                (tail rows)
                (add acc (smmt-native-rate (head rows)))
                (add count 1))))
    (defn smmt-average-native-rate (rows)
        (smmt-average-native-loop rows 0 0))

    (defn smmt-report ()
        (do
            (let rows (smmt-rows))
            (list "speech-model-metrics-trend"
                  rows
                  (len rows)
                  (smmt-shift-count rows)
                  (smmt-oracle-held-count rows)
                  (smmt-average-native-rate rows)
                  "native-shifted-where-reciprocal-closed-or-seeded; oracle-held-for-open-dictation-and-sema-live-voice"
                  1
                  0)))

    0)
