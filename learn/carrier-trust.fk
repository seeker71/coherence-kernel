; carrier-trust.fk — trust binds to WEIGHTS, not names: the homecoming-carrier
; comparison law.
;
; Grounded 2026-07-16 by reading three cards at the source (HuggingFace):
;   - openbmb/MiniCPM5-1B — 1,080,632,832 params ("Standard LlamaForCausalLM",
;     24 layers), English + Chinese explicit, Apache-2.0, 131,072 ctx, built-in
;     <think> template; method (RL+OPD) and evals published ON the card.
;   - GnLOLot/MiniCPM5-1B-Claude-Opus-Fable5-Thinking(-GGUF) — the same body
;     "post-trained on Fable 5 data": the card carries the frontier mind's NAME
;     but no dataset, no method, no benchmarks — an APOCRYPHAL layer (attributed,
;     unverifiable — and not disproven; held outside the canon until grounded).
;   - WeiboAI/VibeThinker-3B — 3B, fully documented (arXiv 2606.16140), the
;     prior roadmap-#1 candidate (receipts/2026-07-13-frontier-ingest-
;     vibethinker-3b.md).
;
; The law this cell makes observable:
;   1. Published evals bind to the WEIGHTS they measured. A weight-changing
;      fine-tune re-enters unmeasured — license and architecture survive the
;      change; evals do not.
;   2. An apocryphal layer adds exactly ZERO trust, however luminous the name
;      it carries. It is not negated either: the artifact is real and runs —
;      WITNESSED, never frozen (ki-ingest's fear-blocks-ice-not-sight, in the
;      carrier lane).
;   3. At equal trust the SMALLER carrier wins the recipe-data lane (one-Mac
;      plausibility, HOMECOMING.md roadmap #1); size never overrules trust.
;
; Honest floor: params/documented/apocryphal are scalars modeling the
; card-reading senses (params in millions, rounded from the card's exact
; figure); no weights were loaded, no eval was run here. The LOGIC — evals
; bind to weights, the name adds nothing, witnessed-not-frozen, smaller wins
; the lane at equal trust — is what the band proves.
;
; Sibling of model-compare.fk (which ranks TEACHERS for transfer; this ranks
; CARRIERS for the recipe-data lane — a different question, so a different cell).
;
; Self-contained over core. Four-way by learn/tests/carrier-trust-band.fk.
;
; preludes: form-stdlib/core.fk

(do
    ; a candidate carrier: (name params-millions documented apocryphal)
    ;   documented — 1 iff method + evals are published for THESE exact weights
    ;   apocryphal — 1 iff a layer is attributed to a named source with no
    ;                dataset, method, or evals shown
    (defn cwt-cand (name params documented apocryphal) (list name params documented apocryphal))
    (defn cwt-name       (c) (nth c 0))
    (defn cwt-params     (c) (nth c 1))
    (defn cwt-documented (c) (nth c 2))
    (defn cwt-apocryphal (c) (nth c 3))

    ; trust counts ONLY weight-bound documentation; the apocryphal layer adds nothing
    (defn cwt-trust (c) (cwt-documented c))

    ; the apocryphal carrier stays SEEN (it runs), never load-bearing
    (defn cwt-witnessed-not-frozen? (c)
        (if (eq (cwt-apocryphal c) 1) (if (eq (cwt-documented c) 0) 1 0) 0))
    (defn cwt-freezable? (c)
        (if (eq (cwt-documented c) 1) (if (eq (cwt-apocryphal c) 0) 1 0) 0))

    ; better carrier for the recipe-data lane: trust first; at equal trust the
    ; smaller wins; at equal size the un-apocryphal wins; 1 = first, 2 = second
    (defn cwt-better-carrier (a b)
        (if (gt (cwt-trust a) (cwt-trust b)) 1
        (if (gt (cwt-trust b) (cwt-trust a)) 2
        (if (lt (cwt-params a) (cwt-params b)) 1
        (if (lt (cwt-params b) (cwt-params a)) 2
        (if (lt (cwt-apocryphal a) (cwt-apocryphal b)) 1 2))))))

    ; ── the three real candidates, as their cards read 2026-07-16 ──
    (defn cwt-minicpm-base () (cwt-cand "minicpm5-1b-base" 1081 1 0))
    (defn cwt-fable5-ft ()    (cwt-cand "minicpm5-1b-claude-opus-fable5-thinking" 1081 0 1))
    (defn cwt-vibethinker ()  (cwt-cand "vibethinker-3b" 3000 1 0))

    ; ── self-check ──
    (defn cwtk (cond bit) (if cond bit 0))
    (defn cwt-base-over-ft ()    (cwtk (eq (cwt-better-carrier (cwt-minicpm-base) (cwt-fable5-ft)) 1) 1))       ; evals do not survive a weight change
    (defn cwt-name-adds-zero ()  (cwtk (eq (cwt-trust (cwt-fable5-ft)) 0) 10))                                  ; the frontier name buys no trust
    (defn cwt-ft-still-seen ()   (cwtk (eq (cwt-witnessed-not-frozen? (cwt-fable5-ft)) 1) 100))                 ; but the artifact stays witnessed
    (defn cwt-smaller-wins ()    (cwtk (eq (cwt-better-carrier (cwt-minicpm-base) (cwt-vibethinker)) 1) 1000))  ; equal trust -> the 1B takes the lane
    (defn cwt-trust-over-size () (cwtk (eq (cwt-better-carrier (cwt-vibethinker) (cwt-fable5-ft)) 1) 10000))    ; a documented 3B beats an apocryphal 1B
    (defn carrier-trust-check ()
        (add (add (add (add (cwt-base-over-ft) (cwt-name-adds-zero)) (cwt-ft-still-seen)) (cwt-smaller-wins)) (cwt-trust-over-size)))
)
