; metal-observed-sweep-bridge.fk -- connect live Metal audio to multiseed sweep.
;
; The multiseed sweep proves several reversible locale windows as Form-native
; closed-set learning. The live macOS carrier proves one real local-oracle audio
; route shift on Metal. This bridge keeps both true at once: the sweep can route
; as metal-anchored native guidance, while full all-locale Metal remains pending
; until more live pairs are observed.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/diverse-locale-pairing.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-locale-learning-window.fk
;   learn/multiseed-speech-learning-sweep.fk

(do
    (defn mosb-bit (cond) (if cond 1 0))

    (defn mosb-anchor (pair samples oracle-ok before-rate after-rate ab-rate ba-rate
                            shifted oracle-metal native-form neural-metal)
        (list "metal-observed-speech-anchor"
              pair samples oracle-ok before-rate after-rate ab-rate ba-rate
              shifted oracle-metal native-form neural-metal))

    (defn mosb-anchor-ready? (a floor)
        (if (eq
                (add
                    (add
                        (add (mosb-bit (ge (nth a 5) floor))
                             (mosb-bit (ge (nth a 6) floor)))
                        (add (mosb-bit (ge (nth a 7) floor))
                             (mosb-bit (eq (nth a 8) 1))))
                    (add
                        (add (mosb-bit (ge (mul (nth a 3) 2) (nth a 2)))
                             (mosb-bit (eq (nth a 9) 1)))
                        (add (mosb-bit (eq (nth a 10) 1))
                             (mosb-bit (eq (nth a 11) 0)))))
                8) 1 0))

    (defn mosb-sweep-ready? (windows ready route-native coverage-code neural-pending diffusion-pending floor)
        (if (eq
                (add
                    (add (mosb-bit (eq windows 5))
                         (mosb-bit (eq ready 5)))
                    (add
                        (add (mosb-bit (eq route-native 1))
                             (mosb-bit (eq coverage-code 2725)))
                        (add
                            (mosb-bit (eq neural-pending 5))
                            (mosb-bit (eq diffusion-pending 5)))))
                6) 1 0))

    (defn mosb-next-live-needed (observed target)
        (if (ge observed target) 0 (sub target observed)))

    (defn mosb-full-metal? (windows ready route-native coverage-code neural-pending diffusion-pending
                            a floor observed-live-pairs target-live-pairs)
        (if (eq
                (add
                    (add (mosb-sweep-ready? windows ready route-native coverage-code
                                            neural-pending diffusion-pending floor)
                         (mosb-anchor-ready? a floor))
                    (mosb-bit (ge observed-live-pairs target-live-pairs)))
                3) 1 0))

    (defn mosb-route (windows ready route-native coverage-code neural-pending diffusion-pending
                      a floor observed-live-pairs target-live-pairs)
        (if (eq (mosb-full-metal? windows ready route-native coverage-code neural-pending diffusion-pending
                                  a floor observed-live-pairs target-live-pairs) 1)
            "full-metal-native"
            (if (eq (add (mosb-sweep-ready? windows ready route-native coverage-code
                                            neural-pending diffusion-pending floor)
                         (mosb-anchor-ready? a floor)) 2)
                "metal-anchored-native-guide"
                "oracle-guide")))

    (defn mosb-receipt (device oracle windows ready route-native coverage-code
                        neural-pending diffusion-pending a floor observed-live-pairs target-live-pairs)
        (list "metal-observed-sweep-bridge"
              device
              oracle
              windows
              ready
              route-native
              coverage-code
              (nth a 1)
              (nth a 2)
              (nth a 3)
              (nth a 4)
              (nth a 5)
              (nth a 6)
              (nth a 7)
              (nth a 8)
              (mosb-anchor-ready? a floor)
              observed-live-pairs
              target-live-pairs
              (mosb-next-live-needed observed-live-pairs target-live-pairs)
              (mosb-route windows ready route-native coverage-code neural-pending diffusion-pending
                          a floor observed-live-pairs target-live-pairs)
              (mosb-full-metal? windows ready route-native coverage-code neural-pending diffusion-pending
                                a floor observed-live-pairs target-live-pairs)
              (nth a 9)
              (nth a 10)
              (mosb-bit (eq (nth a 11) 0))
              diffusion-pending))

    0)
