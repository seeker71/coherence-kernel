; speech-native-neural-pair-window-0024.fk -- twenty-fourth native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; id<->pt-br. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw24-kind () "speech-native-neural-pair-window-0024")
    (defn snpw24-a () "id")
    (defn snpw24-b () "pt-br")
    (defn snpw24-meaning () 303)
    (defn snpw24-floor () 50)
    (defn snpw24-max-wer () 25)
    (defn snpw24-meta () (mlap-meta 96 97 11 80))
    (defn snpw24-feat () (list 3040 32 2 2))
    (defn snpw24-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw24-meaning)) locale))

    (defn snpw24-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0024-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw24-oracle-locale (r) (nth r 1))
    (defn snpw24-oracle-voice  (r) (nth r 2))
    (defn snpw24-oracle-transcript (r) (nth r 3))
    (defn snpw24-oracle-wer    (r) (nth r 4))
    (defn snpw24-oracle-bytes  (r) (nth r 5))
    (defn snpw24-oracle-cksum  (r) (nth r 6))
    (defn snpw24-oracle-name   (r) (nth r 7))
    (defn snpw24-oracle-device (r) (nth r 8))

    (defn snpw24-oracle-rows ()
        (list
            (snpw24-oracle-row "id" "Damayanti" "Saya." 0 18496 1333292974)
            (snpw24-oracle-row "pt-br" "Flo (Portuguese (Brazil))" "Eu sou." 0 31774 1996659987)))

    (defn snpw24-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw24-oracle-wer (head rows)) (snpw24-max-wer)) 1 0)
                 (snpw24-oracle-ok-loop (tail rows)))))
    (defn snpw24-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw24-oracle-bytes (head rows))
                 (snpw24-oracle-byte-total-loop (tail rows)))))

    (defn snpw24-nl (src dst)
        (mlap-nl-sample (snpw24-meaning) src dst
                         (snpw24-tokens src)
                         (snpw24-tokens dst)
                         (snpw24-meaning)
                         0 0 0))

    (defn snpw24-audio (src dst)
        (mlap-audio-sample (snpw24-meaning) src dst
                            (snpw24-tokens dst)
                            (snpw24-tokens dst)
                            (snpw24-feat)
                            (snpw24-meta)
                            0 0 0))

    (defn snpw24-nl-lanes ()
        (list
            (snpw24-nl (snpw24-a) (snpw24-b))
            (snpw24-nl (snpw24-b) (snpw24-a))
            (snpw24-nl (snpw24-a) (snpw24-a))
            (snpw24-nl (snpw24-b) (snpw24-b))))

    (defn snpw24-audio-lanes ()
        (list
            (snpw24-audio (snpw24-a) (snpw24-b))
            (snpw24-audio (snpw24-b) (snpw24-a))
            (snpw24-audio (snpw24-a) (snpw24-a))
            (snpw24-audio (snpw24-b) (snpw24-b))))

    (defn snpw24-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw24-receipt ()
        (do
            (let nl (snpw24-nl-lanes))
            (let audio (snpw24-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw24-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw24-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw24-max-wer)))
            (let oracle-rows (snpw24-oracle-rows))
            (let oracle-ok (snpw24-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw24-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw24-kind)
                  (snpw24-a)
                  (snpw24-b)
                  (snpw24-meaning)
                  1
                  2
                  24
                  48
                  24
                  24
                  before
                  after
                  (if (and (lt before (snpw24-floor)) (ge after (snpw24-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw24-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0024-trained-not-open-authority")))

    (defn snpw24-rec-kind            (r) (nth r 0))
    (defn snpw24-rec-a               (r) (nth r 1))
    (defn snpw24-rec-b               (r) (nth r 2))
    (defn snpw24-rec-meaning         (r) (nth r 3))
    (defn snpw24-rec-pair-increment  (r) (nth r 4))
    (defn snpw24-rec-directed-increment (r) (nth r 5))
    (defn snpw24-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw24-rec-cumulative-directed (r) (nth r 7))
    (defn snpw24-rec-epochs          (r) (nth r 8))
    (defn snpw24-rec-params          (r) (nth r 9))
    (defn snpw24-rec-before-rate     (r) (nth r 10))
    (defn snpw24-rec-after-rate      (r) (nth r 11))
    (defn snpw24-rec-shifted         (r) (nth r 12))
    (defn snpw24-rec-form-nl         (r) (nth r 13))
    (defn snpw24-rec-form-audio      (r) (nth r 14))
    (defn snpw24-rec-before-loss     (r) (nth r 15))
    (defn snpw24-rec-after-loss      (r) (nth r 16))
    (defn snpw24-rec-oracle-ok       (r) (nth r 17))
    (defn snpw24-rec-oracle-total    (r) (nth r 18))
    (defn snpw24-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw24-rec-oracle          (r) (nth r 20))
    (defn snpw24-rec-native-form     (r) (nth r 21))
    (defn snpw24-rec-neural          (r) (nth r 22))
    (defn snpw24-rec-open-authority  (r) (nth r 23))
    (defn snpw24-rec-status          (r) (nth r 24))

    0)
