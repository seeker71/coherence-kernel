; speech-native-neural-pair-window-0002.fk -- second native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; en<->pt-br. It uses the same Form-native NL/audio baseline and enabled neural
; micro-kernel path, increasing trained neural pair coverage from one to two
; without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw2-kind () "speech-native-neural-pair-window-0002")
    (defn snpw2-a () "en")
    (defn snpw2-b () "pt-br")
    (defn snpw2-meaning () 301)
    (defn snpw2-floor () 50)
    (defn snpw2-max-wer () 25)
    (defn snpw2-meta () (mlap-meta 97 96 16 66))
    (defn snpw2-feat () (list 2500 25 2 2))
    (defn snpw2-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw2-meaning)) locale))

    (defn snpw2-nl (src dst)
        (mlap-nl-sample (snpw2-meaning) src dst
                        (snpw2-tokens src)
                        (snpw2-tokens dst)
                        (snpw2-meaning)
                        0 0 0))

    (defn snpw2-audio (src dst)
        (mlap-audio-sample (snpw2-meaning) src dst
                           (snpw2-tokens dst)
                           (snpw2-tokens dst)
                           (snpw2-feat)
                           (snpw2-meta)
                           0 0 0))

    (defn snpw2-nl-lanes ()
        (list
            (snpw2-nl (snpw2-a) (snpw2-b))
            (snpw2-nl (snpw2-b) (snpw2-a))
            (snpw2-nl (snpw2-a) (snpw2-a))
            (snpw2-nl (snpw2-b) (snpw2-b))))

    (defn snpw2-audio-lanes ()
        (list
            (snpw2-audio (snpw2-a) (snpw2-b))
            (snpw2-audio (snpw2-b) (snpw2-a))
            (snpw2-audio (snpw2-a) (snpw2-a))
            (snpw2-audio (snpw2-b) (snpw2-b))))

    (defn snpw2-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw2-receipt ()
        (do
            (let nl (snpw2-nl-lanes))
            (let audio (snpw2-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw2-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw2-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw2-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw2-neural-rate nl-rate audio-rate boot))
            (list (snpw2-kind)
                  (snpw2-a)
                  (snpw2-b)
                  (snpw2-meaning)
                  1
                  2
                  2
                  4
                  2
                  2
                  before
                  after
                  (if (and (lt before (snpw2-floor)) (ge after (snpw2-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0002-trained-not-open-authority")))

    (defn snpw2-rec-kind            (r) (nth r 0))
    (defn snpw2-rec-a               (r) (nth r 1))
    (defn snpw2-rec-b               (r) (nth r 2))
    (defn snpw2-rec-meaning         (r) (nth r 3))
    (defn snpw2-rec-pair-increment  (r) (nth r 4))
    (defn snpw2-rec-directed-increment (r) (nth r 5))
    (defn snpw2-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw2-rec-cumulative-directed (r) (nth r 7))
    (defn snpw2-rec-epochs          (r) (nth r 8))
    (defn snpw2-rec-params          (r) (nth r 9))
    (defn snpw2-rec-before-rate     (r) (nth r 10))
    (defn snpw2-rec-after-rate      (r) (nth r 11))
    (defn snpw2-rec-shifted         (r) (nth r 12))
    (defn snpw2-rec-form-nl         (r) (nth r 13))
    (defn snpw2-rec-form-audio      (r) (nth r 14))
    (defn snpw2-rec-before-loss     (r) (nth r 15))
    (defn snpw2-rec-after-loss      (r) (nth r 16))
    (defn snpw2-rec-oracle          (r) (nth r 17))
    (defn snpw2-rec-native-form     (r) (nth r 18))
    (defn snpw2-rec-neural          (r) (nth r 19))
    (defn snpw2-rec-open-authority  (r) (nth r 20))
    (defn snpw2-rec-status          (r) (nth r 21))

    0)
