; speech-native-neural-pair-window-0038.fk -- thirty-eighth native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; id<->it. Fresh Mac Metal local-oracle probes check the Indonesian and Italian
; renderings for the same neutral meaning, then the Form-native NL/audio
; micro-pair shifts from oracle-held to native within this closed pair window.
; This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw38-kind () "speech-native-neural-pair-window-0038")
    (defn snpw38-a () "id")
    (defn snpw38-b () "it")
    (defn snpw38-meaning () 303)
    (defn snpw38-floor () 50)
    (defn snpw38-max-wer () 25)
    (defn snpw38-meta () (mlap-meta 96 96 12 79))
    (defn snpw38-feat () (list 3043 38 2 2))
    (defn snpw38-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw38-meaning)) locale))

    (defn snpw38-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0038-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw38-oracle-locale (r) (nth r 1))
    (defn snpw38-oracle-voice  (r) (nth r 2))
    (defn snpw38-oracle-transcript (r) (nth r 3))
    (defn snpw38-oracle-wer    (r) (nth r 4))
    (defn snpw38-oracle-bytes  (r) (nth r 5))
    (defn snpw38-oracle-cksum  (r) (nth r 6))
    (defn snpw38-oracle-name   (r) (nth r 7))
    (defn snpw38-oracle-device (r) (nth r 8))

    (defn snpw38-oracle-rows ()
        (list
            (snpw38-oracle-row "id" "Damayanti" "Aku ada." 0 23712 1805192547)
            (snpw38-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw38-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw38-oracle-wer (head rows)) (snpw38-max-wer)) 1 0)
                 (snpw38-oracle-ok-loop (tail rows)))))
    (defn snpw38-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw38-oracle-bytes (head rows))
                 (snpw38-oracle-byte-total-loop (tail rows)))))

    (defn snpw38-nl (src dst)
        (mlap-nl-sample (snpw38-meaning) src dst
                         (snpw38-tokens src)
                         (snpw38-tokens dst)
                         (snpw38-meaning)
                         0 0 0))

    (defn snpw38-audio (src dst)
        (mlap-audio-sample (snpw38-meaning) src dst
                            (snpw38-tokens dst)
                            (snpw38-tokens dst)
                            (snpw38-feat)
                            (snpw38-meta)
                            0 0 0))

    (defn snpw38-nl-lanes ()
        (list
            (snpw38-nl (snpw38-a) (snpw38-b))
            (snpw38-nl (snpw38-b) (snpw38-a))
            (snpw38-nl (snpw38-a) (snpw38-a))
            (snpw38-nl (snpw38-b) (snpw38-b))))

    (defn snpw38-audio-lanes ()
        (list
            (snpw38-audio (snpw38-a) (snpw38-b))
            (snpw38-audio (snpw38-b) (snpw38-a))
            (snpw38-audio (snpw38-a) (snpw38-a))
            (snpw38-audio (snpw38-b) (snpw38-b))))

    (defn snpw38-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw38-receipt ()
        (do
            (let nl (snpw38-nl-lanes))
            (let audio (snpw38-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw38-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw38-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw38-max-wer)))
            (let oracle-rows (snpw38-oracle-rows))
            (let oracle-ok (snpw38-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw38-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw38-kind)
                  (snpw38-a)
                  (snpw38-b)
                  (snpw38-meaning)
                  1
                  2
                  38
                  76
                  38
                  38
                  before
                  after
                  (if (and (lt before (snpw38-floor)) (ge after (snpw38-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw38-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0038-trained-not-open-authority")))

    (defn snpw38-rec-kind            (r) (nth r 0))
    (defn snpw38-rec-a               (r) (nth r 1))
    (defn snpw38-rec-b               (r) (nth r 2))
    (defn snpw38-rec-meaning         (r) (nth r 3))
    (defn snpw38-rec-pair-increment  (r) (nth r 4))
    (defn snpw38-rec-directed-increment (r) (nth r 5))
    (defn snpw38-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw38-rec-cumulative-directed (r) (nth r 7))
    (defn snpw38-rec-epochs          (r) (nth r 8))
    (defn snpw38-rec-params          (r) (nth r 9))
    (defn snpw38-rec-before-rate     (r) (nth r 10))
    (defn snpw38-rec-after-rate      (r) (nth r 11))
    (defn snpw38-rec-shifted         (r) (nth r 12))
    (defn snpw38-rec-form-nl         (r) (nth r 13))
    (defn snpw38-rec-form-audio      (r) (nth r 14))
    (defn snpw38-rec-before-loss     (r) (nth r 15))
    (defn snpw38-rec-after-loss      (r) (nth r 16))
    (defn snpw38-rec-oracle-ok       (r) (nth r 17))
    (defn snpw38-rec-oracle-total    (r) (nth r 18))
    (defn snpw38-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw38-rec-oracle          (r) (nth r 20))
    (defn snpw38-rec-native-form     (r) (nth r 21))
    (defn snpw38-rec-neural          (r) (nth r 22))
    (defn snpw38-rec-open-authority  (r) (nth r 23))
    (defn snpw38-rec-status          (r) (nth r 24))

    0)
