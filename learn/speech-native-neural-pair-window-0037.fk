; speech-native-neural-pair-window-0037.fk -- thirty-seventh native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; es<->it. Fresh Mac Metal local-oracle probes check the Spanish and Italian
; renderings for the same neutral meaning, then the Form-native NL/audio
; micro-pair shifts from oracle-held to native within this closed pair window.
; This is not open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw37-kind () "speech-native-neural-pair-window-0037")
    (defn snpw37-a () "es")
    (defn snpw37-b () "it")
    (defn snpw37-meaning () 303)
    (defn snpw37-floor () 50)
    (defn snpw37-max-wer () 25)
    (defn snpw37-meta () (mlap-meta 96 96 12 79))
    (defn snpw37-feat () (list 3042 37 2 2))
    (defn snpw37-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw37-meaning)) locale))

    (defn snpw37-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0037-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw37-oracle-locale (r) (nth r 1))
    (defn snpw37-oracle-voice  (r) (nth r 2))
    (defn snpw37-oracle-transcript (r) (nth r 3))
    (defn snpw37-oracle-wer    (r) (nth r 4))
    (defn snpw37-oracle-bytes  (r) (nth r 5))
    (defn snpw37-oracle-cksum  (r) (nth r 6))
    (defn snpw37-oracle-name   (r) (nth r 7))
    (defn snpw37-oracle-device (r) (nth r 8))

    (defn snpw37-oracle-rows ()
        (list
            (snpw37-oracle-row "es" "Monica" "Yo soy." 0 21760 3069302771)
            (snpw37-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw37-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw37-oracle-wer (head rows)) (snpw37-max-wer)) 1 0)
                 (snpw37-oracle-ok-loop (tail rows)))))
    (defn snpw37-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw37-oracle-bytes (head rows))
                 (snpw37-oracle-byte-total-loop (tail rows)))))

    (defn snpw37-nl (src dst)
        (mlap-nl-sample (snpw37-meaning) src dst
                         (snpw37-tokens src)
                         (snpw37-tokens dst)
                         (snpw37-meaning)
                         0 0 0))

    (defn snpw37-audio (src dst)
        (mlap-audio-sample (snpw37-meaning) src dst
                            (snpw37-tokens dst)
                            (snpw37-tokens dst)
                            (snpw37-feat)
                            (snpw37-meta)
                            0 0 0))

    (defn snpw37-nl-lanes ()
        (list
            (snpw37-nl (snpw37-a) (snpw37-b))
            (snpw37-nl (snpw37-b) (snpw37-a))
            (snpw37-nl (snpw37-a) (snpw37-a))
            (snpw37-nl (snpw37-b) (snpw37-b))))

    (defn snpw37-audio-lanes ()
        (list
            (snpw37-audio (snpw37-a) (snpw37-b))
            (snpw37-audio (snpw37-b) (snpw37-a))
            (snpw37-audio (snpw37-a) (snpw37-a))
            (snpw37-audio (snpw37-b) (snpw37-b))))

    (defn snpw37-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw37-receipt ()
        (do
            (let nl (snpw37-nl-lanes))
            (let audio (snpw37-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw37-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw37-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw37-max-wer)))
            (let oracle-rows (snpw37-oracle-rows))
            (let oracle-ok (snpw37-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw37-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw37-kind)
                  (snpw37-a)
                  (snpw37-b)
                  (snpw37-meaning)
                  1
                  2
                  37
                  74
                  37
                  37
                  before
                  after
                  (if (and (lt before (snpw37-floor)) (ge after (snpw37-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw37-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0037-trained-not-open-authority")))

    (defn snpw37-rec-kind            (r) (nth r 0))
    (defn snpw37-rec-a               (r) (nth r 1))
    (defn snpw37-rec-b               (r) (nth r 2))
    (defn snpw37-rec-meaning         (r) (nth r 3))
    (defn snpw37-rec-pair-increment  (r) (nth r 4))
    (defn snpw37-rec-directed-increment (r) (nth r 5))
    (defn snpw37-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw37-rec-cumulative-directed (r) (nth r 7))
    (defn snpw37-rec-epochs          (r) (nth r 8))
    (defn snpw37-rec-params          (r) (nth r 9))
    (defn snpw37-rec-before-rate     (r) (nth r 10))
    (defn snpw37-rec-after-rate      (r) (nth r 11))
    (defn snpw37-rec-shifted         (r) (nth r 12))
    (defn snpw37-rec-form-nl         (r) (nth r 13))
    (defn snpw37-rec-form-audio      (r) (nth r 14))
    (defn snpw37-rec-before-loss     (r) (nth r 15))
    (defn snpw37-rec-after-loss      (r) (nth r 16))
    (defn snpw37-rec-oracle-ok       (r) (nth r 17))
    (defn snpw37-rec-oracle-total    (r) (nth r 18))
    (defn snpw37-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw37-rec-oracle          (r) (nth r 20))
    (defn snpw37-rec-native-form     (r) (nth r 21))
    (defn snpw37-rec-neural          (r) (nth r 22))
    (defn snpw37-rec-open-authority  (r) (nth r 23))
    (defn snpw37-rec-status          (r) (nth r 24))

    0)
