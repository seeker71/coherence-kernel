; speech-native-neural-pair-window-0032.fk -- thirty-second native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; de<->it. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw32-kind () "speech-native-neural-pair-window-0032")
    (defn snpw32-a () "de")
    (defn snpw32-b () "it")
    (defn snpw32-meaning () 303)
    (defn snpw32-floor () 50)
    (defn snpw32-max-wer () 25)
    (defn snpw32-meta () (mlap-meta 96 97 11 80))
    (defn snpw32-feat () (list 3040 32 2 2))
    (defn snpw32-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw32-meaning)) locale))

    (defn snpw32-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0032-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw32-oracle-locale (r) (nth r 1))
    (defn snpw32-oracle-voice  (r) (nth r 2))
    (defn snpw32-oracle-transcript (r) (nth r 3))
    (defn snpw32-oracle-wer    (r) (nth r 4))
    (defn snpw32-oracle-bytes  (r) (nth r 5))
    (defn snpw32-oracle-cksum  (r) (nth r 6))
    (defn snpw32-oracle-name   (r) (nth r 7))
    (defn snpw32-oracle-device (r) (nth r 8))

    (defn snpw32-oracle-rows ()
        (list
            (snpw32-oracle-row "de" "Anna" "Ich bin" 0 16068 3773526825)
            (snpw32-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw32-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw32-oracle-wer (head rows)) (snpw32-max-wer)) 1 0)
                 (snpw32-oracle-ok-loop (tail rows)))))
    (defn snpw32-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw32-oracle-bytes (head rows))
                 (snpw32-oracle-byte-total-loop (tail rows)))))

    (defn snpw32-nl (src dst)
        (mlap-nl-sample (snpw32-meaning) src dst
                         (snpw32-tokens src)
                         (snpw32-tokens dst)
                         (snpw32-meaning)
                         0 0 0))

    (defn snpw32-audio (src dst)
        (mlap-audio-sample (snpw32-meaning) src dst
                            (snpw32-tokens dst)
                            (snpw32-tokens dst)
                            (snpw32-feat)
                            (snpw32-meta)
                            0 0 0))

    (defn snpw32-nl-lanes ()
        (list
            (snpw32-nl (snpw32-a) (snpw32-b))
            (snpw32-nl (snpw32-b) (snpw32-a))
            (snpw32-nl (snpw32-a) (snpw32-a))
            (snpw32-nl (snpw32-b) (snpw32-b))))

    (defn snpw32-audio-lanes ()
        (list
            (snpw32-audio (snpw32-a) (snpw32-b))
            (snpw32-audio (snpw32-b) (snpw32-a))
            (snpw32-audio (snpw32-a) (snpw32-a))
            (snpw32-audio (snpw32-b) (snpw32-b))))

    (defn snpw32-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw32-receipt ()
        (do
            (let nl (snpw32-nl-lanes))
            (let audio (snpw32-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw32-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw32-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw32-max-wer)))
            (let oracle-rows (snpw32-oracle-rows))
            (let oracle-ok (snpw32-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw32-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw32-kind)
                  (snpw32-a)
                  (snpw32-b)
                  (snpw32-meaning)
                  1
                  2
                  32
                  64
                  32
                  32
                  before
                  after
                  (if (and (lt before (snpw32-floor)) (ge after (snpw32-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw32-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0032-trained-not-open-authority")))

    (defn snpw32-rec-kind            (r) (nth r 0))
    (defn snpw32-rec-a               (r) (nth r 1))
    (defn snpw32-rec-b               (r) (nth r 2))
    (defn snpw32-rec-meaning         (r) (nth r 3))
    (defn snpw32-rec-pair-increment  (r) (nth r 4))
    (defn snpw32-rec-directed-increment (r) (nth r 5))
    (defn snpw32-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw32-rec-cumulative-directed (r) (nth r 7))
    (defn snpw32-rec-epochs          (r) (nth r 8))
    (defn snpw32-rec-params          (r) (nth r 9))
    (defn snpw32-rec-before-rate     (r) (nth r 10))
    (defn snpw32-rec-after-rate      (r) (nth r 11))
    (defn snpw32-rec-shifted         (r) (nth r 12))
    (defn snpw32-rec-form-nl         (r) (nth r 13))
    (defn snpw32-rec-form-audio      (r) (nth r 14))
    (defn snpw32-rec-before-loss     (r) (nth r 15))
    (defn snpw32-rec-after-loss      (r) (nth r 16))
    (defn snpw32-rec-oracle-ok       (r) (nth r 17))
    (defn snpw32-rec-oracle-total    (r) (nth r 18))
    (defn snpw32-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw32-rec-oracle          (r) (nth r 20))
    (defn snpw32-rec-native-form     (r) (nth r 21))
    (defn snpw32-rec-neural          (r) (nth r 22))
    (defn snpw32-rec-open-authority  (r) (nth r 23))
    (defn snpw32-rec-status          (r) (nth r 24))

    0)
