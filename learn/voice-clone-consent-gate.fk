; voice-clone-consent-gate.fk — a voice is borrowed tissue: consent gates it.
;
; Frontier ingest, distilled from tetsuo-ai/voice_clone_lab (a Qwen3-TTS
; fine-tuning lab: extract -> clean -> chunk -> transcribe -> proofread ->
; train). Three teachings land here as executable gates, joined to organs
; this kernel already owns:
;
;   1. CONSENT IS A GATE, NOT A FOOTNOTE. The lab's rule — "only your own
;      voice or a voice with explicit written permission" — becomes a
;      fail-closed admission: self or written-permission pass; anything
;      else is refused with that sentence quoted back. This composes with the
;      body's reception-consent ethic (form-stdlib/reception-consent.fk).
;   2. THE PROOFREAD IS THE QUALITY KEYSTONE. "Bad transcripts are the #1
;      cause of weird pronunciation" — so training admission requires EVERY
;      chunk proofread by a human witness; one unproofread chunk refuses
;      the whole run, named, not averaged away.
;   3. HARDWARE FLOORS ARE STAGE-SPECIFIC. Training wants 24 GB, inference
;      8 GB — and the verdict for THIS host is computed live through
;      observe/model-fit.fk's measured floor, never assumed.
;
; What is deliberately NOT taken: the Python body, the model weights, the
; web UI. No cloning happens here — this organ is the gate a cloning lane
; must pass through before it may exist in this body.
;
; witnessed: 2026-07-19 -> 127 live fkwu (learn/tests/voice-clone-consent-gate-band.fk)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/model-fit.fk
(do
  ;; ---- the pipeline, as typed stages ----
  (defn vcg-stages ()
    (list "extract" "clean" "chunk" "transcribe" "proofread" "train"))

  ;; ---- consent row: (speaker kind) ; kind: self | written-permission | none ----
  (defn vcg-consent (speaker kind) (list speaker kind))
  (defn vcg-consent-ok? (c)
    (if (or (str_eq (nth c 1) "self")
            (str_eq (nth c 1) "written-permission")) 1 0))
  (defn vcg-consent-verdict (c)
    (if (eq (vcg-consent-ok? c) 1)
      (str_concat "admitted: consent kind '" (str_concat (nth c 1) "'"))
      "REFUSED: only your own voice, or a voice with explicit written permission from the speaker"))

  ;; ---- transcript chunks: (chunk-id proofread?) ; the keystone gate ----
  (defn vcg-all-proofread-go (chunks unread)
    (if (eq (len chunks) 0) unread
      (vcg-all-proofread-go (tail chunks)
        (if (eq (nth (head chunks) 1) 1) unread (add unread 1)))))
  (defn vcg-proofread-verdict (chunks)
    (do (let unread (vcg-all-proofread-go chunks 0))
        (if (eq unread 0) "admitted: every chunk proofread"
          (str_concat "REFUSED: " (str_concat (int_to_str unread)
            " chunk(s) unproofread - bad transcripts are the first wound, fix them before training")))))

  ;; ---- stage floors in MB, verdict computed from the LIVE host floor ----
  (defn vcg-train-floor-mb () 24576)
  (defn vcg-infer-floor-mb () 8192)
  (defn vcg-host-verdict ()
    (do (let floor (mf-host-floor))
        (let avail (nth floor 1))
        (if (lt avail 0) "host memory door absent"
          (if (ge avail (vcg-train-floor-mb))
            (str_concat "training-capable (" (str_concat (int_to_str avail) " MB available)"))
            (if (ge avail (vcg-infer-floor-mb))
              (str_concat "inference-only (" (str_concat (int_to_str avail)
                " MB available; training wants 24576 MB)"))
              (str_concat "neither (" (str_concat (int_to_str avail) " MB available)")))))))

  ;; ---- the full admission: all three gates, each named ----
  (defn vcg-cat (xs) (if (eq (len xs) 0) "" (str_concat (head xs) (vcg-cat (tail xs)))))
  (defn vcg-admit (consent chunks)
    (vcg-cat (list
      "consent gate:   " (vcg-consent-verdict consent) "\n"
      "keystone gate:  " (vcg-proofread-verdict chunks) "\n"
      "hardware floor: " (vcg-host-verdict) "\n"
      "admission: " (if (and (eq (vcg-consent-ok? consent) 1)
                             (eq (vcg-all-proofread-go chunks 0) 0))
        "OPEN (both gates passed; run within the measured floor)"
        "CLOSED (a gate refused; the refusal names itself above)") "\n")))
  0)
