; sema-voice-vocoder-oracle-bridge.fk -- TCAV sample rows enter Sema STT bar.
;
; The text-conditioned acoustic vocoder's sample row is:
;   kind id src dst meaning tokens target-text oracle-text meta audio-hash
;   local consent fail timeout undo
; This compact bridge consumes that row shape directly and lowers it into the
; Sema local-oracle receipt surface. Candidate search can consume the resulting
; local-oracle row in a split lane; the combined TCAV+search source file is over
; today's direct-source ceiling.
;
; preludes:
;   observe/stt-wer.fk
;   presence/formant-vocoder.fk
;   observe/speech-token-stream.fk
;   learn/sema-voice-sample-loop.fk
;   learn/sema-voice-local-oracle-receipt.fk

(do
    (defn svvob-tcav-row (id src dst meaning tokens target-text oracle-text meta audio-hash local consent fail timeout undo)
        (list "text-conditioned-acoustic-vocoder-sample"
              id src dst meaning tokens target-text oracle-text meta audio-hash local consent fail timeout undo))
    (defn svvob-id      (s) (nth s 1))
    (defn svvob-dst     (s) (nth s 3))
    (defn svvob-target  (s) (nth s 6))
    (defn svvob-oracle  (s) (nth s 7))
    (defn svvob-audio   (s) (nth s 9))
    (defn svvob-local   (s) (nth s 10))
    (defn svvob-consent (s) (nth s 11))
    (defn svvob-fail    (s) (nth s 12))
    (defn svvob-timeout (s) (nth s 13))
    (defn svvob-undo    (s) (nth s 14))

    (defn svvob-wer (s)
        (if (str_eq (svvob-oracle s) (svvob-target s)) 0
            (if (str_eq (svvob-oracle s) "") 100 33)))

    (defn svvob-sample (s)
        (svsl-sample (svsl-target)
                     88
                     (svsl-clamp (sub 100 (svvob-wer s)) 0 100)
                     (svvob-wer s)
                     120
                     (svvob-local s)
                     (svvob-audio s)
                     (svvob-fail s)
                     (svvob-timeout s)
                     (svvob-undo s)))

    (defn svvob-row (s oracle device)
        (svlor-row (svvob-id s)
                   (svvob-dst s)
                   (svvob-target s)
                   (svvob-oracle s)
                   oracle
                   device
                   (svvob-sample s)
                   (svlor-audio (svvob-audio s) 16000 1)
                   1
                   (svvob-consent s)
                   (svlor-controls (svvob-fail s) (svvob-timeout s) (svvob-undo s))))

    (defn svvob-receipt (incumbent s oracle device max-wer margin)
        (do
            (let rec (svlor-receipt incumbent (svvob-row s oracle device) (svsl-target) max-wer margin))
            (list "sema-voice-vocoder-oracle-bridge"
                  (svvob-id s)
                  (svvob-dst s)
                  (svvob-wer s)
                  (svlor-rec-route rec)
                  (svlor-rec-oracle-ok rec)
                  (svlor-rec-promoted rec)
                  (svlor-rec-oracle rec)
                  (svlor-rec-device rec)
                  (svlor-rec-audio-hash rec)
                  "text-conditioned-acoustic-vocoder"
                  (svlor-rec-native-form rec)
                  (svlor-rec-neural-vocoder rec))))

    0)
