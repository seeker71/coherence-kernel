; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/macos-sema-teacher-heldout-learning.fk
;
; macos-sema-teacher-heldout-learning-band -- held-out repeat learner contract.
;
; Verdict 65535:
;   1      receipt row names the held-out learner
;   2      training audio hash is carried
;   4      eval audio hash is carried
;   8      train/eval hashes differ
;   16     training feature rows are present
;   32     eval feature rows are present
;   64     training adds native prototypes beyond blank
;   128    oracle transcript is accepted
;   256    held-out native transcript is accepted
;   512    held-out success passes
;   1024   held-out WER is zero
;   2048   held-out confidence clears the native floor
;   4096   native Form true
;   8192   sample is marked held-out
;   16384  effective epoch count is one
;   32768  neural model remains false

(do
    (defn msth-band-score (cond bit) (if cond bit 0))
    (defn msth-band-train-features ()
        (mstal-envelope-feature-stream (mstal-band-env)))
    (defn msth-band-eval-features ()
        (mstal-envelope-feature-stream (mstal-band-env)))
    (defn msth-band-receipt ()
        (msth-receipt-from-features
            984711
            984712
            (msth-band-train-features)
            (msth-band-eval-features)
            (mstal-text)))

    (defn macos-sema-teacher-heldout-learning-band ()
        (do
            (let r (msth-band-receipt))
            (let c0 (msth-band-score (str_eq (msth-rec-kind r) (msth-kind)) 1))
            (let c1 (msth-band-score (eq (msth-rec-train-hash r) 984711) 2))
            (let c2 (msth-band-score (eq (msth-rec-eval-hash r) 984712) 4))
            (let c3 (msth-band-score (eq (msth-rec-different r) 1) 8))
            (let c4 (msth-band-score (eq (msth-rec-train-feats r) 3) 16))
            (let c5 (msth-band-score (eq (msth-rec-eval-feats r) 3) 32))
            (let c6 (msth-band-score (gt (msth-rec-prototypes r) 3) 64))
            (let c7 (msth-band-score (eq (sw-wer (sw-tokens (msth-rec-oracle r))
                                                 (sw-tokens (mstal-text))) 0) 128))
            (let c8 (msth-band-score (eq (sw-wer (sw-tokens (msth-rec-native r))
                                                 (sw-tokens (mstal-text))) 0) 256))
            (let c9 (msth-band-score (eq (msth-rec-ok r) 1) 512))
            (let c10 (msth-band-score (eq (msth-rec-wer r) 0) 1024))
            (let c11 (msth-band-score (ge (msth-rec-confidence r) 80) 2048))
            (let c12 (msth-band-score (eq (msth-rec-native-form r) 1) 4096))
            (let c13 (msth-band-score (eq (msth-rec-heldout r) 1) 8192))
            (let c14 (msth-band-score (eq (msth-rec-epochs r) 1) 16384))
            (let c15 (msth-band-score (eq (msth-rec-neural r) 0) 32768))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) (add c14 c15))))))

    (macos-sema-teacher-heldout-learning-band))
