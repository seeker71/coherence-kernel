; preludes: learn/speech-oracle-native-backlog.fk
;
; speech-oracle-native-backlog-band -- oracle-held speech gaps.
;
; Verdict 32767:
;   1     report row names the oracle/native backlog
;   2     two oracle-held speech gaps are recorded
;   4     live open dictation passes local oracle 4/4 = 100%
;   8     live open dictation native pass remains 0/4 = 0%
;   16    live open dictation next action trains segmented open ASR source
;   32    Sema live voice has a witnessed local-oracle teacher pass
;   64    Sema live voice native pass remains 0/1 = 0%
;   128   Sema voice oracle WER is 0 while native WER remains 100
;   256   Sema voice next action is render-and-oracle-next
;   512   native neural weight parameters admitted are 0
;   1024  two neural weight recipe lanes are pending
;   2048  native voice organs/components remain present
;   4096  C seed growth remains 0
;   8192  local oracle is named as guide until native receipts win
;   16384 native Form body true and neural ready false

(do
    (defn sonb-band-score (cond bit) (if cond bit 0))
    (defn sonb-rec-gaps        (r) (nth r 1))
    (defn sonb-rec-neural      (r) (nth r 2))
    (defn sonb-rec-body        (r) (nth r 3))
    (defn sonb-rec-gap-count   (r) (nth r 4))
    (defn sonb-rec-held-count  (r) (nth r 5))
    (defn sonb-rec-rule        (r) (nth r 6))
    (defn sonb-rec-native-form (r) (nth r 7))
    (defn sonb-rec-neural-ready (r) (nth r 8))

    (defn speech-oracle-native-backlog-band ()
        (do
            (let r (sonb-report))
            (let gaps (sonb-rec-gaps r))
            (let open (nth gaps 0))
            (let voice (nth gaps 1))
            (let neural (sonb-rec-neural r))
            (let body (sonb-rec-body r))
            (let c0 (sonb-band-score (str_eq (nth r 0) "speech-oracle-native-backlog") 1))
            (let c1 (sonb-band-score (and (eq (sonb-rec-gap-count r) 2)
                                          (eq (sonb-rec-held-count r) 2)) 2))
            (let c2 (sonb-band-score (and (str_eq (sonb-gap-name open) "live-open-dictation")
                                          (and (eq (sonb-gap-oracle-ok open) 4)
                                               (eq (sonb-gap-oracle-rate open) 100))) 4))
            (let c3 (sonb-band-score (and (eq (sonb-gap-native-ok open) 0)
                                          (and (eq (sonb-gap-native-total open) 4)
                                               (eq (sonb-gap-native-rate open) 0))) 8))
            (let c4 (sonb-band-score (and (str_eq (sonb-gap-next open) "train-live-segmented-open-asr-source")
                                          (str_eq (sonb-gap-target open) "native-segmented-acoustic-learning")) 16))
            (let c5 (sonb-band-score (and (str_eq (sonb-gap-name voice) "sema-live-voice")
                                          (and (eq (sonb-gap-oracle-ok voice) 1)
                                               (and (eq (sonb-gap-oracle-total voice) 1)
                                                    (eq (sonb-gap-oracle-rate voice) 100)))) 32))
            (let c6 (sonb-band-score (and (eq (sonb-gap-native-ok voice) 0)
                                          (and (eq (sonb-gap-native-total voice) 1)
                                               (eq (sonb-gap-native-rate voice) 0))) 64))
            (let c7 (sonb-band-score (and (eq (sonb-gap-oracle-wer voice) 0)
                                          (eq (sonb-gap-native-wer voice) 100)) 128))
            (let c8 (sonb-band-score (str_eq (sonb-gap-next voice) "render-and-oracle-next") 256))
            (let c9 (sonb-band-score (eq (nth neural 1) 0) 512))
            (let c10 (sonb-band-score (and (eq (nth neural 2) 2)
                                           (str_eq (nth neural 5) "admit-only-consented-local-recipe-data")) 1024))
            (let c11 (sonb-band-score (eq (nth body 1) 6) 2048))
            (let c12 (sonb-band-score (eq (nth body 4) 0) 4096))
            (let c13 (sonb-band-score (str_eq (sonb-rec-rule r) "local-oracle-teaches-until-native-receipts-win") 8192))
            (let c14 (sonb-band-score (and (eq (sonb-rec-native-form r) 1)
                                           (eq (sonb-rec-neural-ready r) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-oracle-native-backlog-band))
