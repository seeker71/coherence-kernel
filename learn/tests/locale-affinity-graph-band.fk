; locale-affinity-graph-band.fk — the affinity edges tell the known
; migration stories, and the fold is exact.
;
; preludes: form-stdlib/core.fk learn/coherence-network-self-corpus.fk learn/locale-affinity-graph.fk
;
; run: cat form/form-stdlib/core.fk learn/coherence-network-self-corpus.fk \
;          learn/locale-affinity-graph.fk learn/tests/locale-affinity-graph-band.fk > /tmp/lag.fk
;      ./fkwu --src /tmp/lag.fk    ; -> 63
;
; Verdict 63 when the graph stands.

(do
    (defn lagb-score (ok bit) (if ok bit 0))
    (defn locale-affinity-graph-band ()
        (do
    ; the Romance triangle is the heaviest kinship (family+script+typology)
    (let c0 (lagb-score (eq (lag-aff "es" "fr") 14) 1))
    ; Germanic kin with the typology bit dark — English's crossed isogloss
    (let c1 (lagb-score (eq (lag-aff "en" "de") 13) 2))
    ; the ancestor sits farther than the siblings stand to each other
    (let c2 (lagb-score (lt (lag-aff "la" "es") (lag-aff "es" "fr")) 4))
    ; zh is an isolate in this feature space (its bridges are audio windows)
    (let c3 (lagb-score (eq (lag-max-to "zh") 0) 8))
    ; nv-chr: neighbors by land, strangers by tongue — region bit only
    (let c4 (lagb-score (eq (lag-aff "nv" "chr") 1) 16))
    ; the fold: 11 locales | heaviest edge 14 | 2 isolates
    (let c5 (lagb-score (eq (lag-field-code) 111402) 32))
    (add c0 (add c1 (add c2 (add c3 (add c4 c5))))))
    )
    (locale-affinity-graph-band))
