; preludes: form-stdlib/channel-interface.fk form-stdlib/satsang.fk learn/satsang-oracle.fk
;
; satsang-oracle-live-band -- satsang-oracle-band.fk's three proposals were explicit synthetic
; examples (Model A/B/C, hand-authored to demonstrate the fold). This band's two proposals are
; a genuinely LIVE contribution instead: real parses of a NEW sentence, produced fresh in this
; session (2026-07-01) by an actual reasoning model (Claude, this session) rather than scripted
; in advance -- the honest middle step between "algorithm proven on synthetic fixtures" and
; "wired to a live multi-model council over HTTP" (still separate, still pending: this is one
; live voice, not a diverse council, and calls no network).
;
; The sentence: "Truth alone triumphs over every lie." A genuine segmentation choice arises for
; "triumphs over" -- English phrasal verbs are a real linguistic phenomenon, not a fabricated
; disagreement: is "over" its own word-leaf, or does "triumphs over" belong together as one
; lexical unit? Both are real, defensible parses; this band feeds BOTH to the fold and reports
; whatever it actually decides, honestly, rather than picking the outcome in advance.
;
;   Live parse 1 (word-per-token, this codebase's existing convention):
;     truth . alone . triumphs . over . every . lie . .          (7 leaves)
;   Live parse 2 (phrasal-verb-as-one-unit):
;     truth . alone . triumphs-over . every . lie . .             (6 leaves)
;
; Verdict 7:
;   1   the root itself does NOT survive (arity 7 vs 6 -- a real, honest limitation: the fold
;       requires exact ctor-tag+arity match to recurse at all, so two parses that substantially
;       agree in content but differ in ONE segmentation choice show as a full non-survival at
;       the root rather than partial word-level agreement -- named, not silently smoothed over)
;   2   the root's candidate tag is still named ("seq"), not dropped, matching satsang-oracle.fk's
;       own discipline that an open question retains what was offered
;   4   a tie (1 affirm, 1 dissent) does NOT crystallize -- sat-survives? requires STRICTLY more
;       affirm than dissent, so two voices split evenly correctly stays an open question rather
;       than a coin-flip false confidence

(do
    (defn solb-leaf (lemma) (sao-node lemma (empty)))
    (defn solb-seq (words) (sao-node "seq" words))

    ; Live parse 1 -- produced fresh this session, word-per-token.
    (defn solb-live-1 ()
        (solb-seq (list (solb-leaf "truth") (solb-leaf "alone") (solb-leaf "triumphs")
                        (solb-leaf "over") (solb-leaf "every") (solb-leaf "lie") (solb-leaf "."))))

    ; Live parse 2 -- produced fresh this session, phrasal-verb-as-one-unit.
    (defn solb-live-2 ()
        (solb-seq (list (solb-leaf "truth") (solb-leaf "alone") (solb-leaf "triumphs-over")
                        (solb-leaf "every") (solb-leaf "lie") (solb-leaf "."))))

    (defn solb-band-score (cond bit) (if cond bit 0))

    (defn satsang-oracle-live-band ()
        (do
            (let out (sao-witness-council (list (solb-live-1) (solb-live-2))))
            (let c0 (solb-band-score (str_eq (sao-out-status out) "open-question") 1))
            (let c1 (solb-band-score (str_eq (sao-out-tag out) "seq") 2))
            (let c2 (solb-band-score (and (eq (nth (sao-out-witness out) 0) 1)
                                          (eq (nth (sao-out-witness out) 1) 1)) 4))
            (add (add c0 c1) c2)))

    (satsang-oracle-live-band))
