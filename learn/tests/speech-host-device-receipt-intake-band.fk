; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/sema-voice-trial-window.fk
;   learn/speech-current-status-ledger.fk
;   learn/speech-global-promotion-readiness.fk
;   learn/speech-live-receipt-intake.fk
;   learn/speech-global-authority-update.fk
;   learn/speech-authority-model-selection.fk
;   learn/speech-host-device-receipt-intake.fk
;
; speech-host-device-receipt-intake-band -- device observations into authority rows.
;
; Verdict 32767:
;   1     report row names host/device receipt intake
;   2     current observations carry Android and macOS provenance
;   4     Android closed-prompt capture is evidence but not global open dictation
;   8     current Sema voice WER 100 earns no live native credit
;   16    shared Android open-dictation row has consent=0 and earns no credit
;   32    current global ASR/TTS counts remain 0/0
;   64    demo mixed Mac/Android open dictation gives 3/3 clean receipts
;   128   demo mixed Mac/Android Sema voice gives 3/3 clean receipts
;   256   demo authority updates choose native ASR/TTS routes
;   512   demo model selection has 2/2 global speech-native authority
;   1024  current model selection keeps ASR/TTS oracle-guided
;   2048  all selected arms still admit zero native neural parameters
;   4096  current live receipt intake remains empty underneath
;   8192  note names closed-prompt/shared-device boundary
;   16384 native Form true and neural ready false

(do
    (defn shd-band-score (cond bit) (if cond bit 0))

    (defn speech-host-device-receipt-intake-band ()
        (do
            (let r (shd-report))
            (let current-obs (nth r 1))
            (let current-rows (nth r 2))
            (let closed (nth current-obs 0))
            (let sema-row (nth current-rows 1))
            (let shared-row (nth current-rows 2))
            (let cur-updates (nth r 4))
            (let demo-updates (nth r 5))
            (let cur-open (nth cur-updates 0))
            (let cur-voice (nth cur-updates 1))
            (let demo-open (nth demo-updates 0))
            (let demo-voice (nth demo-updates 1))
            (let cur-selection (nth r 6))
            (let demo-selection (nth r 7))
            (let cur-asr (nth cur-selection 1))
            (let cur-tts (nth cur-selection 2))
            (let demo-asr (nth demo-selection 1))
            (let demo-tts (nth demo-selection 2))
            (let intake (slri-report))
            (let c0 (shd-band-score (str_eq (nth r 0) "speech-host-device-receipt-intake") 1))
            (let c1 (shd-band-score (and (eq (nth r 12) 2)
                                         (eq (nth r 13) 1)) 2))
            (let c2 (shd-band-score (and (str_eq (shd-platform closed) "android-arm64")
                                         (and (str_eq (shd-task closed) "closed-prompt-loopback")
                                              (eq (shd-global-scope closed) 0))) 4))
            (let c3 (shd-band-score (and (str_eq (slri-lane sema-row) "sema-live-voice")
                                         (and (eq (slri-native-wer sema-row) 100)
                                              (eq (slri-native-success? sema-row 25 80 2000) 0))) 8))
            (let c4 (shd-band-score (and (str_eq (slri-lane shared-row) "live-open-dictation")
                                         (and (eq (slri-consent shared-row) 0)
                                              (eq (slri-valid? shared-row) 0))) 16))
            (let c5 (shd-band-score (and (eq (nth r 8) 0)
                                         (and (eq (nth r 9) 0)
                                              (and (str_eq (sgau-lane-route cur-open) "oracle-guide")
                                                   (str_eq (sgau-lane-route cur-voice) "oracle-guide")))) 32))
            (let c6 (shd-band-score (and (eq (nth r 10) 3)
                                         (str_eq (sgau-lane-route demo-open) "native-open-asr-source")) 64))
            (let c7 (shd-band-score (and (eq (nth r 11) 3)
                                         (str_eq (sgau-lane-route demo-voice) "native-sema-voice")) 128))
            (let c8 (shd-band-score (and (str_eq (sams-arm-id demo-asr) "native-open-asr-source")
                                         (str_eq (sams-arm-id demo-tts) "native-sema-voice")) 256))
            (let c9 (shd-band-score (and (eq (nth demo-selection 5) 2)
                                         (eq (nth demo-selection 6) 0)) 512))
            (let c10 (shd-band-score (and (str_eq (sams-arm-authority cur-asr) "oracle-guide")
                                          (str_eq (sams-arm-authority cur-tts) "oracle-guide")) 1024))
            (let c11 (shd-band-score (and (eq (nth cur-selection 8) 0)
                                          (eq (nth demo-selection 8) 0)) 2048))
            (let c12 (shd-band-score (and (eq (nth intake 1) 0)
                                          (eq (nth intake 2) 0)) 4096))
            (let c13 (shd-band-score (str_eq (nth r 15)
                                             "closed-prompt-and-shared-device-observations-do-not-promote-global-speech") 8192))
            (let c14 (shd-band-score (and (eq (nth r 16) 1)
                                          (eq (nth r 17) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-host-device-receipt-intake-band))
