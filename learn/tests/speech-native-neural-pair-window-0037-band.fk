; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk
;   learn/speech-native-neural-pair-window-0037.fk
;
; speech-native-neural-pair-window-0037-band -- thirty-seventh neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0037
;   2      pair is es<->it
;   4      Sanskrit baseline meaning 303 is used
;   8      cumulative trained pairs are thirty-seven
;   16     cumulative directed routes are seventy-four
;   32     thirty-seven epochs and thirty-seven parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   two local Metal oracle rows pass the pair window
;   2048   open authority is false
;   4096   observed local wav bytes are carried
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0037, not open authority

(do
    (defn snpw37-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0037-band ()
        (do
            (let r (snpw37-receipt))
            (let c0 (snpw37-band-score (str_eq (snpw37-rec-kind r)
                                               "speech-native-neural-pair-window-0037") 1))
            (let c1 (snpw37-band-score (and (str_eq (snpw37-rec-a r) "es")
                                            (str_eq (snpw37-rec-b r) "it")) 2))
            (let c2 (snpw37-band-score (eq (snpw37-rec-meaning r) 303) 4))
            (let c3 (snpw37-band-score (eq (snpw37-rec-cumulative-pairs r) 37) 8))
            (let c4 (snpw37-band-score (eq (snpw37-rec-cumulative-directed r) 74) 16))
            (let c5 (snpw37-band-score (and (eq (snpw37-rec-epochs r) 37)
                                            (eq (snpw37-rec-params r) 37)) 32))
            (let c6 (snpw37-band-score (and (eq (snpw37-rec-before-rate r) 0)
                                            (eq (snpw37-rec-after-rate r) 100)) 64))
            (let c7 (snpw37-band-score (eq (snpw37-rec-shifted r) 1) 128))
            (let c8 (snpw37-band-score (and (eq (snpw37-rec-form-nl r) 100)
                                            (eq (snpw37-rec-form-audio r) 100)) 256))
            (let c9 (snpw37-band-score (and (eq (snpw37-rec-before-loss r) 1)
                                            (eq (snpw37-rec-after-loss r) 0)) 512))
            (let c10 (snpw37-band-score (and (eq (snpw37-rec-oracle-ok r) 2)
                                             (eq (snpw37-rec-oracle-total r) 2)) 1024))
            (let c11 (snpw37-band-score (eq (snpw37-rec-open-authority r) 0) 2048))
            (let c12 (snpw37-band-score (eq (snpw37-rec-oracle-bytes r) 38466) 4096))
            (let c13 (snpw37-band-score (and (eq (snpw37-rec-pair-increment r) 1)
                                             (eq (snpw37-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw37-band-score (str_eq (snpw37-rec-status r)
                                                "native-neural-micro-pair-0037-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0037-band))
