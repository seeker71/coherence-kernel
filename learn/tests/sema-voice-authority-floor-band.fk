; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/sema-voice-trial-window.fk
;   learn/sema-voice-trial-window-0002.fk
;   learn/sema-voice-trial-window-0003.fk
;   learn/sema-voice-trial-window-0004.fk
;   learn/sema-voice-trial-window-0005.fk
;   learn/sema-voice-authority-floor.fk
;
; sema-voice-authority-floor-band -- Sema voice never reports as 0/0.
;
; Verdict 32767:
;   1     report row names the Sema voice authority floor
;   2     live authority has oracle/native denominators 1/1, not 0/0
;   4     live authority is oracle 1/1 and native 0/1 with native WER 100
;   8     scoped TCAV training row passes oracle 5/5
;   16    scoped TCAV training row passes native 5/5
;   32    combined floor has oracle/native denominators 6/6
;   64    combined floor rates are oracle 100 and native 83
;   128   global live route remains oracle-guide
;   256   scoped route is native only inside the trial window
;   512   action renders and oracles the next live Sema sample
;   1024  status names nonzero floor with live authority held
;   2048  zero denominator would block the voice gate
;   4096  candidate and local Metal oracle/device are carried
;   8192  native Form true and neural ready false
;   16384 source rows distinguish live authority from scoped training

(do
    (defn svaf-band-a ()
        (do
            (let r (svaf-report))
            (let live (svaf-rec-live r))
            (let trial (svaf-rec-trial r))
            (add
                (add
                    (if (str_eq (svaf-rec-kind r) "sema-voice-authority-floor") 1 0)
                    (if (and (eq (svaf-row-oracle-total live) 1)
                             (eq (svaf-row-native-total live) 1)) 2 0))
                (add
                    (if (and (eq (svaf-row-oracle-ok live) 1)
                             (and (eq (svaf-row-native-ok live) 0)
                                  (eq (svaf-row-wer live) 100))) 4 0)
                    (if (and (eq (svaf-row-oracle-ok trial) 5)
                             (eq (svaf-row-oracle-total trial) 5)) 8 0)))))

    (defn svaf-band-b ()
        (do
            (let r (svaf-report))
            (let live (svaf-rec-live r))
            (let trial (svaf-rec-trial r))
            (let combined (svaf-rec-combined r))
            (add
                (add
                    (if (and (eq (svaf-row-native-ok trial) 5)
                             (eq (svaf-row-native-total trial) 5)) 16 0)
                    (if (and (eq (svaf-row-oracle-total combined) 6)
                             (eq (svaf-row-native-total combined) 6)) 32 0))
                (add
                    (if (and (eq (svaf-row-oracle-rate combined) 100)
                             (eq (svaf-row-native-rate combined) 83)) 64 0)
                    (if (str_eq (svaf-row-route live) "oracle-guide") 128 0)))))

    (defn svaf-band-c ()
        (do
            (let r (svaf-report))
            (let live (svaf-rec-live r))
            (let trial (svaf-rec-trial r))
            (let empty-row (svaf-row "empty" "none" 0 0 0 0 100 "oracle-guide" "invalid"))
            (add
                (add
                    (if (str_eq (svaf-row-route trial)
                                "native-sema-voice-trial-window") 256 0)
                    (if (str_eq (svaf-rec-action r)
                                "render-next-live-sema-sample-and-oracle") 512 0))
                (add
                    (if (str_eq (svaf-rec-status r)
                                "nonzero-training-floor-live-authority-still-held") 1024 0)
                    (if (and (eq (svaf-zero-denominator? empty-row) 1)
                             (str_eq
                                 (svaf-action live empty-row)
                                 "block-zero-denominator-voice-gate")) 2048 0)))))

    (defn svaf-band-d ()
        (do
            (let r (svaf-report))
            (let live (svaf-rec-live r))
            (let trial (svaf-rec-trial r))
            (add
                (if (and (str_eq (svaf-rec-candidate r)
                                 "tcav-five-window-cumulative")
                         (and (str_eq (svaf-rec-oracle r)
                                      "whisper.cpp-large-v3-turbo-metal")
                              (str_eq (svaf-rec-device r)
                                      "macos-arm64-m4-max"))) 4096 0)
                (add
                    (if (and (eq (svaf-rec-native-form r) 1)
                             (eq (svaf-rec-neural-ready r) 0)) 8192 0)
                    (if (and (str_eq (svaf-row-kind live)
                                     "sema-voice-live-authority-row")
                             (str_eq (svaf-row-kind trial)
                                     "sema-voice-scoped-training-row")) 16384 0)))))

    (add (add (svaf-band-a) (svaf-band-b))
         (add (svaf-band-c) (svaf-band-d))))
