; preludes: learn/metal-audio2audio-acoustic-authority.fk
;
; metal-audio2audio-acoustic-authority-band -- acoustic sweep summaries meet live Metal summaries.
;
; Verdict 32767:
;   1     receipt kind names the metal audio2audio acoustic authority
;   2     acoustic sweep summary carries ten rows and five locale pairs
;   4     every acoustic row passes and all five reciprocal pairs are ready
;   8     acoustic route is native-multilocale-audio2audio-acoustic
;   16    seven live Metal anchors are observed/ready with no live-pair debt
;   32    live anchor route is full-metal-native for the closed-prompt carrier
;   64    local oracle and device are carried from the acoustic sweep
;   128   combined route is metal-witnessed-audio2audio-acoustic
;   256   authority flag is earned only when acoustic and live summaries both pass
;   512   a short live target keeps the acoustic bridge on native guide
;   1024  a bad acoustic transcript routes oracle-guide
;   2048  local oracle, native Form, and Metal observation flags are present
;   4096  source authority is decoded-token only; live open mic remains pending
;   8192  neural Metal remains pending
;   16384 Unicode live anchors are ready and the boundary string is carried

(do
    (let rec (ma2aa-receipt
                10 5 10 5 1
                "whisper.cpp-large-v3-turbo"
                "macos-arm64-m4-max"
                1 1 0 1
                7 7 7 1
                7 7 7
                0 1
                5 7))
    (let c0 (if (str_eq (nth rec 0) "metal-audio2audio-acoustic-authority") 1 0))
    (let c1 (if (and (eq (nth rec 1) 10) (eq (nth rec 2) 5)) 2 0))
    (let c2 (if (and (eq (nth rec 3) 10) (eq (nth rec 4) 5)) 4 0))
    (let c3 (if (str_eq (nth rec 5) "native-multilocale-audio2audio-acoustic") 8 0))
    (let c4 (if (and (eq (nth rec 6) 7)
                     (and (eq (nth rec 7) 7)
                          (eq (nth rec 22) 0))) 16 0))
    (let c5 (if (str_eq (nth rec 9) "full-metal-native") 32 0))
    (let c6 (if (and (str_eq (nth rec 11) "whisper.cpp-large-v3-turbo")
                     (str_eq (nth rec 12) "macos-arm64-m4-max")) 64 0))
    (let c7 (if (str_eq (nth rec 10) "metal-witnessed-audio2audio-acoustic") 128 0))
    (let c8 (if (and (eq (nth rec 13) 1)
                     (and (eq (nth rec 14) 1)
                          (eq (nth rec 15) 1))) 256 0))
    (let c9 (if (and (str_eq
                        (ma2aa-route-from-ready
                            (ma2aa-acoustic-ready? 10 5 10 5 1 1 0 5)
                            (ma2aa-live-ready? 7 7 8 1 0 7 7 7 8))
                        "native-audio2audio-acoustic-guide")
                     (eq (ma2aa-live-ready? 7 7 8 1 0 7 7 7 8) 0)) 512 0))
    (let c10 (if (and (str_eq
                         (ma2aa-route-from-ready
                            (ma2aa-acoustic-ready? 10 5 8 4 0 1 0 5)
                            (ma2aa-live-ready? 7 7 7 0 1 7 7 7 7))
                         "oracle-guide")
                      (eq (ma2aa-acoustic-ready? 10 5 8 4 0 1 0 5) 0)) 1024 0))
    (let c11 (if (and (eq (nth rec 16) 1)
                      (and (eq (nth rec 17) 1)
                           (eq (nth rec 18) 1))) 2048 0))
    (let c12 (if (and (eq (nth rec 19) 1)
                      (and (eq (nth rec 20) 0)
                           (str_eq (nth rec 24) "decoded-token-source"))) 4096 0))
    (let c13 (if (eq (nth rec 21) 1) 8192 0))
    (let c14 (if (and (eq (nth rec 23) 1)
                      (str_eq (nth rec 25) "live-open-mic-pending")) 16384 0))
    (add
        (add
            (add (add c0 c1) (add c2 c3))
            (add (add c4 c5) (add c6 c7)))
        (add
            (add (add c8 c9) (add c10 c11))
            (add c12 (add c13 c14)))))
