; preludes: observe/stt-wer.fk presence/formant-vocoder.fk observe/speech-token-stream.fk learn/sanskrit-locale-baseline.fk learn/text-conditioned-acoustic-vocoder.fk learn/native-audio2audio-acoustic-bridge.fk learn/multilocale-audio2audio-acoustic-sweep.fk
;
; multilocale-audio2audio-acoustic-sweep-band -- diverse decoded audio pairs to acoustic targets.
;
; Verdict 32767:
;   1     sweep has ten rows for five reciprocal locale pairs
;   2     en->de target text comes from the neutral Sanskrit baseline
;   4     zh->ar target text preserves non-Latin baseline tokens
;   8     fr->id target acoustic frames render nonzero samples
;   16    sa->la target stream preserves words plus receipt token
;   32    every row passes source and target local-oracle transcript gates
;   64    all five reciprocal pairs are ready
;   128   sweep route is native at the five-pair floor
;   256   stricter six-pair floor remains oracle-guide
;   512   bad source transcript blocks a row
;   1024  bad target transcript blocks a row
;   2048  fail/timeout/undo block rows
;   4096  missing consent or source audio blocks rows
;   8192  voice-side metadata survives into target frames
;   16384 receipt records local Metal oracle, native Form, neural pending

(do
    (defn maab-band-score (cond bit) (if cond bit 0))
    (defn maab-band-row (n) (nth (maab-rows) n))
    (defn maab-band-bad-source ()
        (naab-row 9711 "en" "de" 301
                  (slb-tokens (slb-line-by-meaning 301) "en")
                  "wrong words"
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "de"))
                  (maab-meta) 971101 971201 1 1 0 0 0))
    (defn maab-band-bad-target ()
        (naab-row 9712 "en" "de" 301
                  (slb-tokens (slb-line-by-meaning 301) "en")
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "en"))
                  "wrong words"
                  (maab-meta) 971102 971202 1 1 0 0 0))
    (defn maab-band-control (fail timeout undo)
        (naab-row 9713 "en" "de" 301
                  (slb-tokens (slb-line-by-meaning 301) "en")
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "en"))
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "de"))
                  (maab-meta) 971103 971203 1 1 fail timeout undo))
    (defn maab-band-no-consent ()
        (naab-row 9714 "en" "de" 301
                  (slb-tokens (slb-line-by-meaning 301) "en")
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "en"))
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "de"))
                  (maab-meta) 971104 971204 1 0 0 0 0))
    (defn maab-band-no-source-audio ()
        (naab-row 9715 "en" "de" 301
                  (slb-tokens (slb-line-by-meaning 301) "en")
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "en"))
                  (tcav-text (slb-tokens (slb-line-by-meaning 301) "de"))
                  (maab-meta) 0 971205 1 1 0 0 0))

    (defn multilocale-audio2audio-acoustic-sweep-band ()
        (do
            (let rows (maab-rows))
            (let pairs (maab-pairs))
            (let ende (maab-band-row 0))
            (let zhar (maab-band-row 4))
            (let frid (maab-band-row 6))
            (let sala (maab-band-row 8))
            (let samples (naab-target-samples frid))
            (let frames (naab-target-frames sala))
            (let stream (tcav-stream 9709 (naab-target-tokens sala) (nth sala 8)))
            (let rec (maab-receipt rows pairs 25 50 5
                                   "whisper.cpp-large-v3-turbo"
                                   "macos-arm64-m4-max"))
            (let c0 (maab-band-score (and (eq (len rows) 10) (eq (len pairs) 5)) 1))
            (let c1 (maab-band-score
                        (str_eq (naab-target-text ende) "moegen alle gluecklich sein") 2))
            (let c2 (maab-band-score
                        (str_eq (head (naab-target-tokens zhar)) "الحقيقة") 4))
            (let c3 (maab-band-score (gt (fv-energy samples) 0) 8))
            (let c4 (maab-band-score
                        (and (str_eq (sts-transcript stream) "pax omni mundo")
                             (eq (sts-count-tag stream (sts-receipt-tag)) 1)) 16))
            (let c5 (maab-band-score (eq (naab-pass-score rows 25) 10) 32))
            (let c6 (maab-band-score (eq (maab-ready-pair-count rows pairs 25 50) 5) 64))
            (let c7 (maab-band-score
                        (str_eq (maab-route rows pairs 25 50 5)
                                "native-multilocale-audio2audio-acoustic") 128))
            (let c8 (maab-band-score
                        (str_eq (maab-route rows pairs 25 50 6) "oracle-guide") 256))
            (let c9 (maab-band-score (eq (naab-pass? (maab-band-bad-source) 25) 0) 512))
            (let c10 (maab-band-score (eq (naab-pass? (maab-band-bad-target) 25) 0) 1024))
            (let c11 (maab-band-score
                        (and (eq (naab-pass? (maab-band-control 1 0 0) 25) 0)
                             (and (eq (naab-pass? (maab-band-control 0 1 0) 25) 0)
                                  (eq (naab-pass? (maab-band-control 0 0 1) 25) 0))) 2048))
            (let c12 (maab-band-score
                        (and (eq (naab-pass? (maab-band-no-consent) 25) 0)
                             (eq (naab-pass? (maab-band-no-source-audio) 25) 0)) 4096))
            (let c13 (maab-band-score
                        (and (eq (sts-attunement (tcav-af-meta (head frames))) 88)
                             (eq (sts-cadence (tcav-af-meta (head frames))) 70)) 8192))
            (let c14 (maab-band-score
                        (and (str_eq (nth rec 9) "whisper.cpp-large-v3-turbo")
                             (and (eq (nth rec 11) 1)
                                  (and (eq (nth rec 12) 1)
                                       (eq (nth rec 13) 0)))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (multilocale-audio2audio-acoustic-sweep-band))
