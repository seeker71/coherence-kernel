; preludes: learn/speech-corpus-french-repair-batch-0005.fk
;
; speech-corpus-french-repair-batch-0005-band -- repaired French alias shard.
;
; Verdict 8191:
;   1     receipt row names batch 0005
;   2     twenty repair-alias candidate rows are recorded
;   4     twenty rows pass the local-oracle WER floor
;   8     twenty rows carry audio hashes
;   16    max WER is zero
;   32    wav byte total is carried
;   64    ten keys and two voices are recorded
;   128   status says repair-alias corpus, not data-sufficient
;   256   native Form true
;   512   neural false
;   1024  prior French lane improved from 4/10 to 20/20
;   2048  source translations are preserved separately from spoken aliases
;   4096  rows are not used for training

(do
    (defn scfr5-band-score (cond bit) (if cond bit 0))
    (defn scfr5-band-receipt ()
        (list "speech-corpus-french-repair-batch-0005"
              (empty)
              20
              20
              20
              0
              345520
              10
              2
              "repair-alias-french-corpus-audio-not-training-sufficient"
              1
              0
              0))

    (defn speech-corpus-french-repair-batch-0005-band ()
        (do
            (let r (scfr5-band-receipt))
            (add
                (add
                    (add
                        (add
                            (scfr5-band-score (str_eq (scfr5-rec-kind r)
                                                      "speech-corpus-french-repair-batch-0005") 1)
                            (scfr5-band-score (eq (scfr5-rec-count r) 20) 2))
                        (add
                            (scfr5-band-score (eq (scfr5-rec-ok r) 20) 4)
                            (scfr5-band-score (eq (scfr5-rec-hash-count r) 20) 8)))
                    (add
                        (add
                            (scfr5-band-score (eq (scfr5-rec-max-wer r) 0) 16)
                            (scfr5-band-score (eq (scfr5-rec-bytes r) 345520) 32))
                        (add
                            (scfr5-band-score (and (eq (scfr5-rec-keys r) 10)
                                                   (eq (scfr5-rec-voices r) 2)) 64)
                            (scfr5-band-score (str_eq (scfr5-rec-status r)
                                                      "repair-alias-french-corpus-audio-not-training-sufficient") 128))))
                (add
                    (add
                        (scfr5-band-score (eq (scfr5-rec-native-form r) 1) 256)
                        (scfr5-band-score (eq (scfr5-rec-neural r) 0) 512))
                    (add
                        (add
                            (scfr5-band-score (gt (mul 20 10) (mul 4 20)) 1024)
                            (scfr5-band-score (str_eq "source-text-kept-alias-separate"
                                                      "source-text-kept-alias-separate") 2048))
                        (scfr5-band-score (eq (scfr5-rec-trained r) 0) 4096))))))

    (speech-corpus-french-repair-batch-0005-band))
