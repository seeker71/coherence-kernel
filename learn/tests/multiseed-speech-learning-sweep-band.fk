; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/diverse-locale-pairing.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-locale-learning-window.fk learn/multiseed-speech-learning-sweep.fk
;
; multiseed-speech-learning-sweep-band -- five selected windows move together.
;
; Verdict 32767:
;   1      receipt kind names the multiseed sweep
;   2      five seeded windows are present
;   4      coverage code preserves the expected diverse seed lanes
;   8      all five windows satisfy the ready floor
;   16     all five windows shift from oracle-guide to native
;   32     all five windows start guided
;   64     all five windows end native
;   128    choice/cut/fail/undo/timeout controls are clean across the sweep
;   256    A/B recipe promotion succeeds across the sweep
;   512    local oracle Metal and Form-native flags are present across the sweep
;   1024   neural Metal and diffusion stay pending across the sweep
;   2048   receipt preserves the 50% floor and routes native
;   4096   ready-rate reaches 100%
;   8192   sweep includes non-Latin and Sanskrit/Latin lanes
;   16384  local oracle and device are carried in the receipt

(do
    (let rec (msls-receipt 25 50 "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"))
    (let c0 (if (str_eq (nth rec 0) "multiseed-speech-learning-sweep") 1 0))
    (let c1 (if (eq (nth rec 3) 5) 2 0))
    (let c2 (if (eq (nth rec 17) 2725) 4 0))
    (let c3 (if (eq (nth rec 4) 5) 8 0))
    (let c4 (if (eq (nth rec 6) 5) 16 0))
    (let c5 (if (eq (nth rec 7) 5) 32 0))
    (let c6 (if (eq (nth rec 8) 5) 64 0))
    (let c7 (if (eq (nth rec 9) 5) 128 0))
    (let c8 (if (eq (nth rec 10) 5) 256 0))
    (let c9 (if (eq (add (nth rec 11) (nth rec 12)) 10) 512 0))
    (let c10 (if (eq (add (nth rec 13) (nth rec 14)) 10) 1024 0))
    (let c11 (if (eq (add (if (eq (nth rec 15) 50) 1 0)
                           (if (str_eq (nth rec 16) "native") 1 0))
                       2) 2048 0))
    (let c12 (if (eq (nth rec 5) 100) 4096 0))
    (let c13 (if (eq (nth rec 18) 1) 8192 0))
    (let c14 (if (eq (add (if (str_eq (nth rec 2) "whisper.cpp-large-v3-turbo") 1 0)
                           (if (str_eq (nth rec 1) "macos-arm64-m4-max") 1 0))
                       2) 16384 0))
    (add
        (add
            (add (add c0 c1) (add c2 c3))
            (add (add c4 c5) (add c6 c7)))
        (add
            (add (add c8 c9) (add c10 c11))
            (add c12 (add c13 c14)))))
