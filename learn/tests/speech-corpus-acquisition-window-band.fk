; preludes:
;   learn/coherence-network-self-corpus.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk
;   learn/speech-corpus-acquisition-window.fk
;
; speech-corpus-acquisition-window-band -- self-corpus can fill the audio floor.
;
; Verdict 65535:
;   1      receipt row names the acquisition window
;   2      window selects 2000 keypaths
;   4      six ready locales are used
;   8      one voice per locale is planned
;   16     planned wavs reach 300
;   32     planned held-out rows reach 30
;   64     source corpus has 2064 keypaths
;   128    EN-parallel pair capacity is 10320
;   256    planned wavs meet the sufficiency floor
;   512    planned locales meet the sufficiency floor
;   1024   planned held-out rows meet the sufficiency floor
;   2048   selected macOS voices are named
;   4096   captured rows are present but still below the full planned window
;   8192   status names partially captured with training intake started
;   16384  native Form true and neural false
;   32768  cross-voice acquisition needs a separate five-locale/two-voice window

(do
    (defn scaw-band-score (cond bit) (if cond bit 0))

    (defn speech-corpus-acquisition-window-band ()
        (do
            (let r (scaw-receipt))
            (let b (scaw-rec-budget r))
            (let c0 (scaw-band-score (str_eq (scaw-rec-kind r) (scaw-kind)) 1))
            (let c1 (scaw-band-score (eq (scaw-budget-keypaths b) 2000) 2))
            (let c2 (scaw-band-score (eq (scaw-budget-locales b) 6) 4))
            (let c3 (scaw-band-score (eq (scaw-budget-voices b) 1) 8))
            (let c4 (scaw-band-score (eq (scaw-budget-wavs b) 12000) 16))
            (let c5 (scaw-band-score (eq (scaw-budget-heldout b) 1200) 32))
            (let c6 (scaw-band-score (eq (scaw-budget-corpus-keys b) 2064) 64))
            (let c7 (scaw-band-score (eq (scaw-budget-parallel-pairs b) 10320) 128))
            (let c8 (scaw-band-score (eq (scaw-rec-wav-floor r) 1) 256))
            (let c9 (scaw-band-score (eq (scaw-rec-locale-floor r) 1) 512))
            (let c10 (scaw-band-score (eq (scaw-rec-heldout-floor r) 1) 1024))
            (let c11 (scaw-band-score (eq (scaw-rec-voices-ready r) 1) 2048))
            (let c12 (scaw-band-score (and (eq (scaw-rec-captured r) 119)
                                           (lt (scaw-rec-captured r)
                                               (scaw-planned-wavs))) 4096))
            (let c13 (scaw-band-score (str_eq (scaw-rec-status r)
                                              "corpus-scale-window-open-training-intake-started") 8192))
            (let c14 (scaw-band-score (and (eq (scaw-rec-native-form r) 1)
                                           (eq (scaw-rec-neural r) 0)) 16384))
            (let c15 (scaw-band-score (and (eq (scaw-budget-crossvoice-locales b) 5)
                                           (and (eq (scaw-budget-crossvoice-voices b) 2)
                                                (and (eq (scaw-budget-crossvoice-wavs b) 20000)
                                                     (eq (scaw-budget-crossvoice-heldout b) 2000)))) 32768))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) (add c14 c15))))))

    (speech-corpus-acquisition-window-band))
