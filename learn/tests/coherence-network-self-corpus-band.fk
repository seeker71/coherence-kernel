; preludes: learn/coherence-network-self-corpus.fk
;
; coherence-network-self-corpus-band -- translated Coherence Network content is training material.
;
; Verdict 8191:
;   1    web/messages source has 2019 aligned keys
;   2    cli/lib/messages source has 45 aligned keys
;   4    combined key-path count is 2064
;   8    each source row names six translated locales
;   16   six locales are ready now
;   32   English and Indonesian are ready training locales
;   64   Chinese is a backfill target, not ready
;   128  Arabic is a backfill target, not ready
;   256  Latin is a backfill target, not ready
;   512  EN-to-other parallel pair count is 10320
;   1024 sources are owned/license/attribution ready
;   2048 German <-> Indonesian can train now
;   4096 missing target pairs cannot train before translation lands

(do
    (defn cnsc-band-score (cond bit) (if cond bit 0))
    (defn cnsc-web-source () (nth (cnsc-sources) 0))
    (defn cnsc-cli-source () (nth (cnsc-sources) 1))

    (defn cnsc-c0 () (cnsc-band-score (eq (cnsc-source-keypaths (cnsc-web-source)) 2019) 1))
    (defn cnsc-c1 () (cnsc-band-score (eq (cnsc-source-keypaths (cnsc-cli-source)) 45) 2))
    (defn cnsc-c2 () (cnsc-band-score (eq (cnsc-total-keypaths) 2064) 4))
    (defn cnsc-c3 ()
        (cnsc-band-score (and (eq (cnsc-source-locales (cnsc-web-source)) 6)
                              (eq (cnsc-source-locales (cnsc-cli-source)) 6)) 8))
    (defn cnsc-c4 () (cnsc-band-score (eq (cnsc-ready-count) 6) 16))
    (defn cnsc-c5 ()
        (cnsc-band-score (and (eq (cnsc-ready-code? "en") 1)
                              (eq (cnsc-ready-code? "id") 1)) 32))
    (defn cnsc-c6 ()
        (cnsc-band-score (and (eq (cnsc-ready-code? "zh") 0)
                              (eq (cnsc-backfill-code? "zh") 1)) 64))
    (defn cnsc-c7 ()
        (cnsc-band-score (and (eq (cnsc-ready-code? "ar") 0)
                              (eq (cnsc-backfill-code? "ar") 1)) 128))
    (defn cnsc-c8 ()
        (cnsc-band-score (and (eq (cnsc-ready-code? "la") 0)
                              (eq (cnsc-backfill-code? "la") 1)) 256))
    (defn cnsc-c9 () (cnsc-band-score (eq (cnsc-parallel-en-pairs) 10320) 512))
    (defn cnsc-c10 () (cnsc-band-score (eq (cnsc-self-corpus-ready?) 1) 1024))
    (defn cnsc-c11 () (cnsc-band-score (eq (cnsc-pair-ready? "de" "id") 1) 2048))
    (defn cnsc-c12 ()
        (cnsc-band-score (and (eq (cnsc-pair-ready? "zh" "ar") 0)
                              (eq (cnsc-pair-ready? "nv" "chr") 0)) 4096))

    (defn coherence-network-self-corpus-band ()
        (add
            (add
                (add (add (cnsc-c0) (cnsc-c1)) (add (cnsc-c2) (cnsc-c3)))
                (add (add (cnsc-c4) (cnsc-c5)) (add (cnsc-c6) (cnsc-c7))))
            (add
                (add (cnsc-c8) (cnsc-c9))
                (add (cnsc-c10) (add (cnsc-c11) (cnsc-c12))))))

    (coherence-network-self-corpus-band))
