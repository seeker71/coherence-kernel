; preludes: observe/stt-wer.fk presence/formant-vocoder.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk learn/sema-voice-oracle-miss-learning.fk learn/sema-voice-candidate-search.fk
;
; sema-voice-candidate-search-band -- ranked next voice recipes.
;
; Verdict 32767:
;   1     recipe row names the candidate search surface
;   2     text-conditioned recipe is native Form and not neural-ready
;   4     candidate row preserves the WER-100 live miss as before-WER
;   8     valid local oracle candidate can be scored
;   16    WER improvement is measured from live miss to candidate
;   32    best candidate wins over a rough formant retune
;   64    neural placeholder cannot score as ready
;   128   missing consent cannot score as valid
;   256   fail control cannot score as valid
;   512   passing oracle candidate can route native
;   1024  partial improvement stays oracle-guided
;   2048  receipt names render-and-oracle-next for nonpassing improvement
;   4096  receipt preserves local oracle and device
;   8192  receipt records native Form with neural vocoder not ready
;   16384 receipt names the candidate-search surface

(do
    (defn svcs-band-score (cond bit) (if cond bit 0))

    (defn sema-voice-candidate-search-band ()
        (do
            (let truth "Open speech flows.")
            (let target (svsl-target))
            (let rough-profile (svsl-profile "rough" 145 620 1250 2850 130 55 82 48 42 44 2))
            (let recipe (svcs-text-conditioned-recipe))
            (let exact-sample (svsl-sample (svsl-nudge rough-profile target 8) 88 94 0 110 1 982101 0 0 0))
            (let exact-row (svlor-row 982001 "en" truth truth
                                      "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"
                                      exact-sample (svlor-audio 982101 16000 1) 1 1
                                      (svlor-controls 0 0 0)))
            (let exact (svcs-candidate "exact-text-conditioned" recipe exact-row 100 "local-oracle-candidate"))
            (let partial-sample (svsl-sample (svsl-nudge rough-profile target 4) 75 70 33 130 1 982102 0 0 0))
            (let partial-row (svlor-row 982002 "en" truth "Open speech."
                                        "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"
                                        partial-sample (svlor-audio 982102 16000 1) 1 1
                                        (svlor-controls 0 0 0)))
            (let partial (svcs-candidate "partial-text-conditioned" recipe partial-row 100 "local-oracle-candidate"))
            (let rough-sample (svsl-sample (svsl-nudge rough-profile target 2) 60 45 100 180 1 982103 0 0 0))
            (let rough-row (svlor-row 982003 "en" truth ""
                                      "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"
                                      rough-sample (svlor-audio 982103 16000 1) 1 1
                                      (svlor-controls 0 0 0)))
            (let rough (svcs-candidate "rough-formant-retune" (svcs-formant-retune-recipe) rough-row 100 "formant-retune"))
            (let neural-sample (svsl-sample target 92 96 0 90 1 982104 0 0 0))
            (let neural-row (svlor-row 982004 "en" truth truth
                                       "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"
                                       neural-sample (svlor-audio 982104 16000 1) 1 1
                                       (svlor-controls 0 0 0)))
            (let neural (svcs-candidate "neural-pending" (svcs-neural-pending-recipe) neural-row 100 "pending-neural"))
            (let no-consent-sample (svsl-sample target 92 96 0 90 1 982105 0 0 0))
            (let no-consent-row (svlor-row 982005 "en" truth truth
                                           "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"
                                           no-consent-sample (svlor-audio 982105 16000 1) 1 0
                                           (svlor-controls 0 0 0)))
            (let no-consent (svcs-candidate "no-consent" recipe no-consent-row 100 "missing-consent"))
            (let fail-sample (svsl-sample target 92 96 0 90 1 982106 1 0 0))
            (let fail-row (svlor-row 982006 "en" truth truth
                                     "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"
                                     fail-sample (svlor-audio 982106 16000 1) 1 1
                                     (svlor-controls 1 0 0)))
            (let fail (svcs-candidate "fail-control" recipe fail-row 100 "fail-control"))
            (let best (svcs-best (list rough exact partial) target))
            (let rec-partial (svcs-receipt (svom-macos-live-miss) (list partial rough) target 25 20))
            (let rec-exact (svcs-receipt (svom-macos-live-miss) (list rough exact) target 25 20))
            (let c0 (svcs-band-score (str_eq (svcs-recipe-kind recipe) "sema-voice-candidate-recipe") 1))
            (let c1 (svcs-band-score (and (eq (svcs-recipe-native-form recipe) 1)
                                          (eq (svcs-recipe-neural-ready recipe) 0)) 2))
            (let c2 (svcs-band-score (eq (svcs-before-wer exact) 100) 4))
            (let c3 (svcs-band-score (gt (svcs-score exact target) 0) 8))
            (let c4 (svcs-band-score (eq (svcs-improvement exact) 100) 16))
            (let c5 (svcs-band-score (str_eq (svcs-id best) "exact-text-conditioned") 32))
            (let c6 (svcs-band-score (eq (svcs-score neural target) 0) 64))
            (let c7 (svcs-band-score (eq (svcs-valid? no-consent) 0) 128))
            (let c8 (svcs-band-score (eq (svcs-valid? fail) 0) 256))
            (let c9 (svcs-band-score (str_eq (svcs-route exact target 25 20) "native-sema-voice") 512))
            (let c10 (svcs-band-score (str_eq (svcs-route partial target 25 20) "oracle-guided-next-sample") 1024))
            (let c11 (svcs-band-score (str_eq (svcs-rec-action rec-partial) "render-and-oracle-next") 2048))
            (let c12 (svcs-band-score (and (str_eq (svcs-rec-oracle rec-partial) "whisper.cpp-large-v3-turbo")
                                           (str_eq (svcs-rec-device rec-partial) "macos-arm64-m4-max")) 4096))
            (let c13 (svcs-band-score (and (eq (svcs-rec-native-form rec-partial) 1)
                                           (eq (svcs-rec-neural-ready rec-partial) 0)) 8192))
            (let c14 (svcs-band-score (and (str_eq (svcs-rec-kind rec-exact) "sema-voice-candidate-search")
                                           (str_eq (svcs-rec-winner rec-exact) "exact-text-conditioned")) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (sema-voice-candidate-search-band))
