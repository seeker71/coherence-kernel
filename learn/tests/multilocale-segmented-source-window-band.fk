; preludes:
;   observe/stt-wer.fk
;   observe/speech-token-stream.fk
;   observe/open-asr-ctc.fk
;   observe/acoustic-token-emitter.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/segmented-acoustic-token-learning.fk
;   learn/multilocale-segmented-source-window.fk
;
; multilocale-segmented-source-window-band -- diverse source-ASR training window.
;
; Verdict 32767:
;   1     receipt names the multilocale segmented source window
;   2     six consentful samples across three reciprocal pairs are present
;   4     all six local oracle transcripts pass the WER bar
;   8     untrained prototypes do not pass native source ASR
;   16    trained prototypes pass all six native source ASR samples
;   32    three reciprocal locale pairs are ready
;   64    route shifts from oracle-guide to native multilocale segmented source
;   128   action promotes only after the shift
;   256   Sanskrit baseline is the source, not a flattened seed
;   512   zh and ar samples decode through Unicode token strings
;   1024  voice-side metadata survives the window
;   2048  local Metal oracle and device are carried
;   4096  native Form is true and neural Metal remains pending
;   8192  one missing pair keeps the window oracle-guided
;   16384 bad oracle text blocks native training credit

(do
    (defn mssw-band-score (cond bit) (if cond bit 0))
    (defn mssw-band-bad-oracle ()
        (satl-sample
            9510 302 "sa" "la"
            (mssw-text "sa")
            "wrong words"
            (slb-tokens (slb-line-by-meaning 302) "sa")
            (mssw-features "sa")
            (mssw-frame-stream (mssw-features "sa"))
            951010
            28
            (mssw-meta)
            1 0 0 0))

    (defn multilocale-segmented-source-window-band ()
        (do
            (let samples (mssw-samples))
            (let pairs (mssw-pairs))
            (let base (mssw-base-prototypes))
            (let trained (mssw-trained-prototypes))
            (let rec (mssw-live-window-receipt))
            (let one-pair (list (list "multilocale-segmented-source-pair" "sa" "la")
                                (list "multilocale-segmented-source-pair" "en" "zh")))
            (let bad-trained (satl-trained-prototypes (list (mssw-band-bad-oracle)) base 25 96))
            (let c0 (mssw-band-score (str_eq (nth rec 0)
                                             "multilocale-segmented-source-window") 1))
            (let c1 (mssw-band-score (and (eq (nth rec 1) 6)
                                          (eq (nth rec 2) 3)) 2))
            (let c2 (mssw-band-score (eq (nth rec 3) 6) 4))
            (let c3 (mssw-band-score (eq (nth rec 4) 0) 8))
            (let c4 (mssw-band-score (and (eq (nth rec 5) 6)
                                          (eq (nth rec 6) 100)) 16))
            (let c5 (mssw-band-score (eq (nth rec 7) 3) 32))
            (let c6 (mssw-band-score
                        (and (str_eq (nth rec 8) "oracle-guide")
                             (str_eq (nth rec 9)
                                     "native-multilocale-segmented-source")) 64))
            (let c7 (mssw-band-score
                        (str_eq (nth rec 10)
                                "promote-multilocale-segmented-source") 128))
            (let c8 (mssw-band-score
                        (str_eq (nth rec 11) "sanskrit-locale-baseline") 256))
            (let c9 (mssw-band-score
                        (and (str_eq (satl-decoded-text (mssw-sample 9504 "zh" "en" 950104) trained 2 80)
                                     (mssw-text "zh"))
                             (str_eq (satl-decoded-text (mssw-sample 9505 "ar" "en" 950105) trained 2 80)
                                     (mssw-text "ar"))) 512))
            (let c10 (mssw-band-score (eq (nth rec 17) 90) 1024))
            (let c11 (mssw-band-score
                        (and (str_eq (nth rec 12) "whisper.cpp-large-v3-turbo-metal")
                             (str_eq (nth rec 13) "macos-arm64-m4-max")) 2048))
            (let c12 (mssw-band-score
                        (and (eq (nth rec 14) 1)
                             (and (eq (nth rec 15) 1)
                                  (eq (nth rec 16) 0))) 4096))
            (let c13 (mssw-band-score
                        (str_eq
                            (mssw-route samples trained one-pair 25 2 80 2000 80 3)
                            "oracle-guide") 8192))
            (let c14 (mssw-band-score
                        (eq (satl-native-ok? (mssw-sample 9501 "sa" "la" 950101) bad-trained 25 2 80 2000) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (multilocale-segmented-source-window-band))
