; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/sema-voice-trial-window.fk
;
; sema-voice-trial-window-band -- execute the queued Sema voice trial.
;
; Verdict 32767:
;   1     report row names the Sema voice trial window
;   2     queued scheduler trial is trial-sema-voice-0001
;   4     challenger is text-conditioned acoustic vocoder
;   8     scheduled backlog carries oracle 100, native 0, native WER 100
;   16    receipt names the TCAV warm-mid cadence candidate
;   32    local oracle candidate passes the STT bar
;   64    native trial window passes
;   128   candidate WER is 0 after WER-100 live miss
;   256   trial route is native Sema voice for the window
;   512   voice target quality records 165/82/64/18
;   1024  action cuts TCAV challenger for this trial window
;   2048  clean choice/cut/fail/undo/timeout controls are recorded
;   4096  local Metal oracle/device are preserved
;   8192  model context keeps zero neural weights and zero C seed growth
;   16384 report marks native Form true and neural ready false

(do
    (defn svtw-band-score (cond bit) (if cond bit 0))
    (defn svtw-report-trial       (r) (nth r 1))
    (defn svtw-report-receipt     (r) (nth r 2))
    (defn svtw-report-before-oracle (r) (nth r 3))
    (defn svtw-report-before-native (r) (nth r 4))
    (defn svtw-report-before-wer  (r) (nth r 5))
    (defn svtw-report-oracle-ok   (r) (nth r 6))
    (defn svtw-report-native-ok   (r) (nth r 7))
    (defn svtw-report-after-wer   (r) (nth r 8))
    (defn svtw-report-action      (r) (nth r 9))
    (defn svtw-report-context     (r) (nth r 10))
    (defn svtw-report-scope       (r) (nth r 11))
    (defn svtw-report-native-form (r) (nth r 12))
    (defn svtw-report-neural-ready (r) (nth r 13))

    (defn sema-voice-trial-window-band ()
        (do
            (let r (svtw-report))
            (let trial (svtw-report-trial r))
            (let receipt (svtw-report-receipt r))
            (let context (svtw-report-context r))
            (let c0 (svtw-band-score (str_eq (nth r 0) "sema-voice-trial-window") 1))
            (let c1 (svtw-band-score (str_eq (snts-id trial) "trial-sema-voice-0001") 2))
            (let c2 (svtw-band-score (str_eq (snts-challenger trial) "text-conditioned-acoustic-vocoder") 4))
            (let c3 (svtw-band-score (and (eq (svtw-report-before-oracle r) 100)
                                          (and (eq (svtw-report-before-native r) 0)
                                               (eq (svtw-report-before-wer r) 100))) 8))
            (let c4 (svtw-band-score (and (str_eq (svtw-rec-kind receipt) "sema-voice-trial-window-receipt")
                                          (str_eq (svtw-rec-id receipt) "tcav-warm-mid-cadence-v1-window")) 16))
            (let c5 (svtw-band-score (eq (svtw-report-oracle-ok r) 1) 32))
            (let c6 (svtw-band-score (eq (svtw-report-native-ok r) 1) 64))
            (let c7 (svtw-band-score (and (eq (svtw-report-before-wer r) 100)
                                          (eq (svtw-report-after-wer r) 0)) 128))
            (let c8 (svtw-band-score (str_eq (svtw-rec-route receipt) "native-sema-voice-trial-window") 256))
            (let c9 (svtw-band-score (and (eq (svtw-rec-f0 receipt) 165)
                                          (and (eq (svtw-rec-warmth receipt) 82)
                                               (and (eq (svtw-rec-cadence receipt) 64)
                                                    (eq (svtw-rec-breath receipt) 18)))) 512))
            (let c10 (svtw-band-score (str_eq (svtw-report-action r) "cut-tcav-challenger-for-trial-window") 1024))
            (let c11 (svtw-band-score (str_eq (svtw-rec-controls receipt) "choice-cut-fail-undo-timeout-clean") 2048))
            (let c12 (svtw-band-score (and (str_eq (svtw-rec-oracle receipt) "whisper.cpp-large-v3-turbo-metal")
                                           (str_eq (svtw-rec-device receipt) "macos-arm64-m4-max")) 4096))
            (let c13 (svtw-band-score (and (eq (nth context 1) 0)
                                           (and (eq (nth context 6) 0)
                                                (str_eq (svtw-report-scope r) "trial-window-native-not-global-live-voice"))) 8192))
            (let c14 (svtw-band-score (and (eq (svtw-report-native-form r) 1)
                                           (eq (svtw-report-neural-ready r) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (sema-voice-trial-window-band))
