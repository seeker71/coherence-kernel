; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   observe/wav-sense.fk
;   learn/audio-locale-native-training.fk
;
; audio-locale-native-training-band -- reciprocal A/B audio model reaches 50%.
;
; Verdict 8191:
;   1    A->B direction is present
;   2    B->A direction is present
;   4    local oracle transcript passes WER
;   8    native nearest-prototype predicts a held-out A->B sample
;   16   native nearest-prototype predicts a held-out B->A sample
;   32   overall native success rate is at least 50%
;   64   reciprocal route is native at the 50% floor
;   128  one-way window cannot route native
;   256  bad oracle transcript blocks native credit
;   512  timeout blocks native credit
;   1024 receipt records the oracle name
;   2048 receipt names the training row
;   4096 oracle-valid training sample shifts a failed native prediction to success

(do
    (defn alnt-band-score (cond bit) (if cond bit 0))
    (defn alnt-band-truth-a () (list "the" "board" "is" "clear"))
    (defn alnt-band-truth-b () (list "die" "tafel" "ist" "leer"))
    (defn alnt-band-candidates ()
        (list
            (alnt-candidate 101 (alnt-band-truth-b) (list 1000 1 2 3 4))
            (alnt-candidate 201 (alnt-band-truth-a) (list 2000 6 7 8 9))))
    (defn alnt-band-ab ()
        (alnt-sample 101 "en" "de" (alnt-band-truth-b) (alnt-band-truth-b)
                     (list 1002 1 2 3 4) 0 0 0))
    (defn alnt-band-ba ()
        (alnt-sample 201 "de" "en" (alnt-band-truth-a) (alnt-band-truth-a)
                     (list 2002 6 7 8 9) 0 0 0))
    (defn alnt-band-aa ()
        (alnt-sample 201 "en" "en" (alnt-band-truth-a) (alnt-band-truth-a)
                     (list 2003 6 7 8 9) 0 0 0))
    (defn alnt-band-bb ()
        (alnt-sample 101 "de" "de" (alnt-band-truth-b) (alnt-band-truth-b)
                     (list 1003 1 2 3 4) 0 0 0))
    (defn alnt-band-bad-oracle ()
        (alnt-sample 101 "en" "de" (alnt-band-truth-b) (list "wrong")
                     (list 1002 1 2 3 4) 0 0 0))
    (defn alnt-band-timeout ()
        (alnt-sample 201 "de" "en" (alnt-band-truth-a) (alnt-band-truth-a)
                     (list 2002 6 7 8 9) 0 1 0))
    (defn alnt-band-hard ()
        (alnt-sample 101 "en" "de" (alnt-band-truth-b) (alnt-band-truth-b)
                     (list 2001 6 7 8 9) 0 0 0))

    (defn alnt-band-samples ()
        (list (alnt-band-ab) (alnt-band-ba) (alnt-band-aa) (alnt-band-bb)))
    (defn alnt-band-one-way ()
        (list (alnt-band-ab) (alnt-band-aa)))
    (defn alnt-band-receipt ()
        (alnt-receipt (alnt-band-samples) (alnt-band-candidates)
                      "en" "de" 25 50 "whisper.cpp-small" "macos-arm64"))

    (defn alnt-band-c0 () (alnt-band-score (eq (alnt-has-direction? (alnt-band-samples) "en" "de") 1) 1))
    (defn alnt-band-c1 () (alnt-band-score (eq (alnt-has-direction? (alnt-band-samples) "de" "en") 1) 2))
    (defn alnt-band-c2 () (alnt-band-score (eq (alnt-oracle-ok? (alnt-band-ab) 25) 1) 4))
    (defn alnt-band-c3 () (alnt-band-score (eq (alnt-native-ok? (alnt-band-ab) (alnt-band-candidates) 25) 1) 8))
    (defn alnt-band-c4 () (alnt-band-score (eq (alnt-native-ok? (alnt-band-ba) (alnt-band-candidates) 25) 1) 16))
    (defn alnt-band-c5 () (alnt-band-score (ge (alnt-native-rate (alnt-band-samples) (alnt-band-candidates) 25) 50) 32))
    (defn alnt-band-c6 () (alnt-band-score (str_eq (alnt-route (alnt-band-samples) (alnt-band-candidates) "en" "de" 25 50) "native") 64))
    (defn alnt-band-c7 () (alnt-band-score (str_eq (alnt-route (alnt-band-one-way) (alnt-band-candidates) "en" "de" 25 50) "oracle-guide") 128))
    (defn alnt-band-c8 () (alnt-band-score (eq (alnt-native-ok? (alnt-band-bad-oracle) (alnt-band-candidates) 25) 0) 256))
    (defn alnt-band-c9 () (alnt-band-score (eq (alnt-native-ok? (alnt-band-timeout) (alnt-band-candidates) 25) 0) 512))
    (defn alnt-band-c10 () (alnt-band-score (str_eq (alnt-rec-oracle (alnt-band-receipt)) "whisper.cpp-small") 1024))
    (defn alnt-band-c11 () (alnt-band-score (str_eq (alnt-rec-kind (alnt-band-receipt)) "audio-locale-native-training") 2048))
    (defn alnt-band-c12 ()
        (alnt-band-score
            (and (eq (alnt-native-ok? (alnt-band-hard) (alnt-band-candidates) 25) 0)
                 (eq (alnt-native-ok? (alnt-band-hard)
                                      (alnt-trained-candidates (list (alnt-band-hard)) (alnt-band-candidates) 25)
                                      25) 1))
            4096))

    (defn audio-locale-native-training-band ()
        (add
            (add
                (add (add (alnt-band-c0) (alnt-band-c1))
                     (add (alnt-band-c2) (alnt-band-c3)))
                (add (add (alnt-band-c4) (alnt-band-c5))
                     (add (alnt-band-c6) (alnt-band-c7))))
            (add
                (add (alnt-band-c8) (alnt-band-c9))
                (add (alnt-band-c10) (add (alnt-band-c11) (alnt-band-c12))))))

    (audio-locale-native-training-band))
