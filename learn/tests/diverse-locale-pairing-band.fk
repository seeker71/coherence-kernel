; preludes: learn/diverse-locale-pairing.fk
;
; diverse-locale-pairing-band -- far-apart, ready, reciprocal locale pairs.
;
; Verdict 8191:
;   1    English row is ready
;   2    Indonesian row is ready
;   4    Indigenous rows are named but not falsely marked ready
;   8    Sino-Tibetan <-> Semitic pair has high distance
;   16   best pair is ready on both sides
;   32   best pair avoids same-locale pairing
;   64   seeded pair is deterministic and ready
;   128  seeded pair exposes reciprocal A,B,B,A order
;   256  Chinese/Arabic train from baseline while full self-corpus bundles remain pending
;   512  near European pair scores lower than a far ready pair
;   1024 pair record names the diverse-locale-pair row
;   2048 seeded pair 2 chooses the Sanskrit/Latin baseline lane
;   4096 seeded pair exposes A->B, B->A, A->A, and B->B lanes

(do
    (defn dlp-band-score (cond bit) (if cond bit 0))
    (defn dlp-band-c0 ()
        (dlp-band-score (eq (dlp-ready? (nth (dlp-catalog) 1)) 1) 1))
    (defn dlp-band-c1 ()
        (dlp-band-score (eq (dlp-ready? (nth (dlp-catalog) 8)) 1) 2))
    (defn dlp-band-c2 ()
        (dlp-band-score (and (eq (dlp-indigenous-row-ready?) 0)
                             (str_eq (dlp-region (nth (dlp-catalog) 3)) "north-america")) 4))
    (defn dlp-band-c3 ()
        (dlp-band-score (ge (dlp-distance (nth (dlp-catalog) 0) (nth (dlp-catalog) 2)) 9) 8))
    (defn dlp-band-c4 ()
        (do
            (let best (dlp-best-pair))
            (dlp-band-score (and (eq (dlp-pair-a-ready best) 1)
                                 (eq (dlp-pair-b-ready best) 1)) 16)))
    (defn dlp-band-c5 ()
        (do
            (let best (dlp-best-pair))
            (dlp-band-score (not (str_eq (dlp-pair-a best) (dlp-pair-b best))) 32)))
    (defn dlp-band-c6 ()
        (do
            (let seeded (dlp-seed-pair 2))
            (dlp-band-score (and (eq (dlp-pair-a-ready seeded) 1)
                                 (eq (dlp-pair-b-ready seeded) 1)) 64)))
    (defn dlp-band-c7 ()
        (do
            (let recip (dlp-reciprocal-pairs (dlp-seed-pair 2)))
            (dlp-band-score (and (str_eq (nth recip 0) "sa")
                                 (and (str_eq (nth recip 1) "la")
                                      (and (str_eq (nth recip 2) "la")
                                           (str_eq (nth recip 3) "sa")))) 128)))
    (defn dlp-band-c8 ()
        (do
            (let zh (nth (dlp-catalog) 0))
            (let ar (nth (dlp-catalog) 2))
            (dlp-band-score (and (gt (dlp-pair-score zh ar) 0)
                                 (and (eq (dlp-self-corpus zh) 0)
                                      (and (eq (dlp-self-corpus ar) 0)
                                           (and (eq (dlp-baseline zh) 1)
                                                (eq (dlp-baseline ar) 1))))) 256)))
    (defn dlp-band-c9 ()
        (dlp-band-score
            (lt (dlp-pair-score (nth (dlp-catalog) 9) (nth (dlp-catalog) 10))
                (dlp-pair-score (nth (dlp-catalog) 9) (nth (dlp-catalog) 8))) 512))
    (defn dlp-band-c10 ()
        (dlp-band-score (str_eq (dlp-pair-kind (dlp-best-pair)) "diverse-locale-pair") 1024))
    (defn dlp-band-c11 ()
        (do
            (let seeded (dlp-seed-pair 2))
            (dlp-band-score (and (str_eq (dlp-pair-a seeded) "sa")
                                 (str_eq (dlp-pair-b seeded) "la")) 2048)))
    (defn dlp-band-c12 ()
        (do
            (let lanes (dlp-roundtrip-lanes (dlp-seed-pair 2)))
            (dlp-band-score (and (str_eq (nth lanes 0) "sa")
                                 (and (str_eq (nth lanes 1) "la")
                                      (and (str_eq (nth lanes 2) "la")
                                           (and (str_eq (nth lanes 3) "sa")
                                                (and (str_eq (nth lanes 4) "sa")
                                                     (and (str_eq (nth lanes 5) "sa")
                                                          (and (str_eq (nth lanes 6) "la")
                                                               (str_eq (nth lanes 7) "la")))))))) 4096)))

    (defn diverse-locale-pairing-band ()
        (add
            (add
                (add (add (dlp-band-c0) (dlp-band-c1)) (add (dlp-band-c2) (dlp-band-c3)))
                (add (add (dlp-band-c4) (dlp-band-c5)) (add (dlp-band-c6) (dlp-band-c7))))
            (add
                (add (dlp-band-c8) (dlp-band-c9))
                (add (dlp-band-c10) (add (dlp-band-c11) (dlp-band-c12))))))

    (diverse-locale-pairing-band))
