; preludes:
;   learn/diverse-locale-pairing.fk
;
; diverse-locale-pairing-band -- far-apart, ready, reciprocal locale pairs.
;
; Verdict 2047:
;   1    English row is ready
;   2    Indonesian row is ready
;   4    Indigenous rows are named but not falsely marked ready
;   8    Sino-Tibetan <-> Semitic pair has high distance
;   16   best pair is ready on both sides
;   32   best pair avoids same-locale pairing
;   64   seeded pair is deterministic and ready
;   128  seeded pair exposes reciprocal A,B,B,A order
;   256  missing Chinese/Arabic corpus cannot train before translation lands
;   512  near European pair scores lower than a far ready pair
;   1024 pair record names the diverse-locale-pair row

(do
    (defn dlp-band-score (cond bit) (if cond bit 0))
    (defn diverse-locale-pairing-band ()
        (do
            (let rows (dlp-catalog))
            (let zh (nth rows 0))
            (let en (nth rows 1))
            (let ar (nth rows 2))
            (let nv (nth rows 3))
            (let id (nth rows 7))
            (let de (nth rows 8))
            (let fr (nth rows 9))
            (let best (dlp-best-pair))
            (let seeded (dlp-seed-pair 2))
            (let recip (dlp-reciprocal-pairs seeded))
            (let near (dlp-pair-score de fr))
            (let distant (dlp-pair-score de id))
            (let c0 (dlp-band-score (eq (dlp-ready? en) 1) 1))
            (let c1 (dlp-band-score (eq (dlp-ready? id) 1) 2))
            (let c2 (dlp-band-score (and (eq (dlp-indigenous-row-ready?) 0)
                                         (str_eq (dlp-region nv) "north-america")) 4))
            (let c3 (dlp-band-score (ge (dlp-distance zh ar) 9) 8))
            (let c4 (dlp-band-score (and (eq (dlp-pair-a-ready best) 1)
                                         (eq (dlp-pair-b-ready best) 1)) 16))
            (let c5 (dlp-band-score (not (str_eq (dlp-pair-a best) (dlp-pair-b best))) 32))
            (let c6 (dlp-band-score (and (eq (dlp-pair-a-ready seeded) 1)
                                         (eq (dlp-pair-b-ready seeded) 1)) 64))
            (let c7 (dlp-band-score (and (str_eq (nth recip 0) (dlp-pair-a seeded))
                                         (str_eq (nth recip 2) (dlp-pair-b seeded))) 128))
            (let c8 (dlp-band-score (eq (dlp-pair-score zh ar) 0) 256))
            (let c9 (dlp-band-score (lt near distant) 512))
            (let c10 (dlp-band-score (str_eq (dlp-pair-kind best) "diverse-locale-pair") 1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add c8 (add c9 c10)))))

    (diverse-locale-pairing-band))
