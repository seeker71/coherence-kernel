; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-heldout-repeat-learning.fk
;
; speech-corpus-heldout-repeat-learning-band -- scoped held-out repeats.
;
; Verdict 16383:
;   1     receipt names the held-out learner
;   2     six trained prototypes are present
;   4     six held-out eval rows are present
;   8     local oracle accepts six eval transcripts
;   16    native classifier accepts six eval wavs
;   32    train/eval wav hashes differ
;   64    max oracle WER clears floor
;   128   eval wav bytes are carried
;   256   status names scoped held-out, not global authority
;   512   native Form true
;   1024  held-out true
;   2048  global authority false
;   4096  neural false
;   8192  sufficiency gate still false

(do
    (defn schr-band-proto (id locale key text feature)
        (schr-prototype id locale key text feature))
    (defn schr-band-prototypes ()
        (list
            (schr-band-proto 1 "en" "common.close" "Close" (list 1 9 8 3 0 0 0 0))
            (schr-band-proto 2 "de" "common.close" "Schließen" (list 0 4 2 2 0 0 0 0))
            (schr-band-proto 3 "es" "common.save" "Guardar" (list 2 4 5 4 0 0 0 0))
            (schr-band-proto 4 "fr" "common.yes" "Oui" (list 4 8 8 8 8 6 3 0))
            (schr-band-proto 5 "id" "common.close" "Tutup" (list 5 5 0 1 9 6 0 0))
            (schr-band-proto 6 "pt-br" "common.back" "Voltar" (list 3 4 1 5 0 0 0 0))))

    (defn schr-band-eval-row (id locale key text oracle wer native-ok train-hash eval-hash bytes)
        (list "speech-corpus-heldout-eval-row"
              id locale key text oracle wer (if (le wer (schr-max-wer)) 1 0)
              text native-ok train-hash eval-hash
              (if (eq train-hash eval-hash) 0 1)
              bytes))

    (defn schr-band-evals ()
        (list
            (schr-band-eval-row 1 "en" "common.close" "Close" "Close" 0 1 991001 991101 30050)
            (schr-band-eval-row 2 "de" "common.close" "Schließen" "Schließen" 0 1 991002 991102 31780)
            (schr-band-eval-row 3 "es" "common.save" "Guardar" "Guardar" 0 1 991003 991103 31252)
            (schr-band-eval-row 4 "fr" "common.yes" "Oui" "Oui" 0 1 991004 991104 9948)
            (schr-band-eval-row 5 "id" "common.close" "Tutup" "Tutup" 0 1 991005 991105 14630)
            (schr-band-eval-row 6 "pt-br" "common.back" "Voltar" "Voltar" 0 1 991006 991106 33824)))

    (defn speech-corpus-heldout-repeat-learning-band ()
        (do
            (let r (schr-receipt-from (schr-band-prototypes) (schr-band-evals)))
            (add
                (add
                    (add (if (str_eq (schr-rec-kind r) (schr-kind)) 1 0)
                         (if (eq (schr-rec-protos r) 6) 2 0))
                    (add (if (eq (schr-rec-evals r) 6) 4 0)
                         (if (eq (schr-rec-oracle-ok r) 6) 8 0)))
                (add
                    (add (if (eq (schr-rec-native-ok r) 6) 16 0)
                         (if (eq (schr-rec-diff r) 6) 32 0))
                    (add
                        (add (if (le (schr-rec-max-wer r) (schr-max-wer)) 64 0)
                             (if (gt (schr-rec-bytes r) 100000) 128 0))
                        (add
                            (add (if (str_eq (schr-rec-status r)
                                             "scoped-heldout-repeat-not-global-authority") 256 0)
                                 (if (eq (schr-rec-native r) 1) 512 0))
                            (add
                                (add (if (eq (schr-rec-heldout r) 1) 1024 0)
                                     (if (eq (schr-rec-global r) 0) 2048 0))
                                (add (if (eq (schr-rec-neural r) 0) 4096 0)
                                     (if (eq (slds-sufficient (slds-current)) 0) 8192 0)))))))))

    (speech-corpus-heldout-repeat-learning-band))
