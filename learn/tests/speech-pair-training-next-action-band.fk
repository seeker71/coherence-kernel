; preludes:
;   learn/speech-neural-pair-coverage.fk
;   learn/speech-pair-training-next-action.fk
;
; speech-pair-training-next-action-band -- choose next pair-training movement.
;
; Verdict 32767:
;   1      report row names next action
;   2      neural pair count is twenty
;   4      current Form pair windows are eight
;   8      current capture rows are still under the 12000 floor
;   16     action trains the next native neural pair window
;   32     selected next pair is es<->id
;   64     Form pair count stays 8 -> 8 in the planned action
;   128    neural pair count moves 20 -> 21 in the planned action
;   256    action carries 211/12000 capture state
;   512    native Form is true
;   1024   neural bootstrap ready is true
;   2048   reason names neural micro-pair training enabled
;   4096   status names neural pair micro-kernel receipts
;   8192   priority is the second-stage neural action
;   16384  coverage keeps broad neural bp at 3636

(do
    (defn sptn-band-score (cond bit) (if cond bit 0))

    (defn speech-pair-training-next-action-band ()
        (do
            (let r (sptn-report))
            (let action (sptn-rec-action r))
            (let coverage (sptn-rec-coverage r))
            (let c0 (sptn-band-score (str_eq (sptn-rec-kind r)
                                             "speech-pair-training-next-action-report") 1))
            (let c1 (sptn-band-score (eq (sptn-rec-neural-pairs r) 20) 2))
            (let c2 (sptn-band-score (eq (sptn-rec-form-pairs r) 8) 4))
            (let c3 (sptn-band-score (eq (sptn-rec-under-floor r) 1) 8))
            (let c4 (sptn-band-score (str_eq (sptn-action-route action)
                                             "train-native-neural-pair-window") 16))
            (let c5 (sptn-band-score (and (str_eq (sptn-action-a action) "es")
                                          (str_eq (sptn-action-b action) "id")) 32))
            (let c6 (sptn-band-score (and (eq (sptn-action-form-before action) 8)
                                          (eq (sptn-action-form-after action) 8)) 64))
            (let c7 (sptn-band-score (and (eq (sptn-action-neural-before action) 20)
                                          (eq (sptn-action-neural-after action) 21)) 128))
            (let c8 (sptn-band-score (and (eq (sptn-action-capture-before action) 211)
                                          (eq (sptn-action-capture-floor action) 12000)) 256))
            (let c9 (sptn-band-score (eq (sptn-action-native-form action) 1) 512))
            (let c10 (sptn-band-score (eq (sptn-action-neural-ready action) 1) 1024))
            (let c11 (sptn-band-score (str_eq (sptn-action-reason action)
                                              "neural-micro-pair-training-enabled") 2048))
            (let c12 (sptn-band-score (str_eq (sptn-rec-status r)
                                              "run-next-native-neural-pair-window-with-micro-kernel-receipts") 4096))
            (let c13 (sptn-band-score (eq (sptn-action-priority action) 2) 8192))
            (let c14 (sptn-band-score (eq (snpc-rec-neural-bp coverage) 3636) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-pair-training-next-action-band))
