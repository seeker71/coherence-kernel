; preludes:
;   learn/sanskrit-locale-baseline.fk
;
; sanskrit-locale-baseline-band -- romanized Sanskrit baseline with ready locales.
;
; Verdict 2047:
;   1    four baseline meaning rows exist
;   2    ten ready locales are usable now
;   4    Sanskrit source tokens exist
;   8    Chinese and Arabic script tokens exist
;   16   Indonesian is ready for diverse pair training
;   32   Chinese is ready in the baseline, not backfill here
;   64   Arabic is ready in the baseline, not backfill here
;   128  Navajo is not consent-ready in this cell
;   256  Chinese to Arabic is a ready pair
;   512  English to English is not treated as a cross pair
;   1024 row kind names the baseline

(do
    (defn slb-band-score (cond bit) (if cond bit 0))
    (defn sanskrit-locale-baseline-band ()
        (do
            (let rows (slb-lines))
            (let row301 (slb-line-by-meaning 301))
            (let row302 (slb-line-by-meaning 302))
            (let c0 (slb-band-score (eq (len rows) 4) 1))
            (let c1 (slb-band-score (eq (slb-ready-locale-count) 10) 2))
            (let c2 (slb-band-score (gt (len (slb-tokens row301 "sa")) 0) 4))
            (let c3 (slb-band-score (and (eq (slb-line-ready? row302 "zh") 1)
                                         (eq (slb-line-ready? row302 "ar") 1)) 8))
            (let c4 (slb-band-score (eq (slb-locale-ready? "id") 1) 16))
            (let c5 (slb-band-score (and (eq (slb-locale-ready? "zh") 1)
                                         (eq (slb-locale-backfill? "zh") 0)) 32))
            (let c6 (slb-band-score (and (eq (slb-locale-ready? "ar") 1)
                                         (eq (slb-locale-backfill? "ar") 0)) 64))
            (let c7 (slb-band-score (eq (slb-locale-ready? "nv") 0) 128))
            (let c8 (slb-band-score (eq (slb-pair-ready? "zh" "ar") 1) 256))
            (let c9 (slb-band-score (eq (slb-pair-ready? "en" "en") 0) 512))
            (let c10 (slb-band-score (str_eq (slb-kind row301) "sanskrit-locale-baseline") 1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add c8 (add c9 c10)))))

    (sanskrit-locale-baseline-band))
