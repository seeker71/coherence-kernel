; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk
;   learn/speech-native-neural-pair-window-0042.fk
;
; speech-native-neural-pair-window-0042-band -- forty-second neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0042
;   2      pair is sa<->it
;   4      Sanskrit baseline meaning 303 is used
;   8      cumulative trained pairs are forty-two
;   16     cumulative directed routes are eighty-four
;   32     forty-two epochs and forty-two parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   two local Metal oracle rows pass the pair window
;   2048   open authority is false
;   4096   observed local wav bytes are carried
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0042, not open authority

(do
    (defn snpw42-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0042-band ()
        (do
            (let r (snpw42-receipt))
            (let c0 (snpw42-band-score (str_eq (snpw42-rec-kind r)
                                               "speech-native-neural-pair-window-0042") 1))
            (let c1 (snpw42-band-score (and (str_eq (snpw42-rec-a r) "sa")
                                            (str_eq (snpw42-rec-b r) "it")) 2))
            (let c2 (snpw42-band-score (eq (snpw42-rec-meaning r) 303) 4))
            (let c3 (snpw42-band-score (eq (snpw42-rec-cumulative-pairs r) 42) 8))
            (let c4 (snpw42-band-score (eq (snpw42-rec-cumulative-directed r) 84) 16))
            (let c5 (snpw42-band-score (and (eq (snpw42-rec-epochs r) 42)
                                            (eq (snpw42-rec-params r) 42)) 32))
            (let c6 (snpw42-band-score (and (eq (snpw42-rec-before-rate r) 0)
                                            (eq (snpw42-rec-after-rate r) 100)) 64))
            (let c7 (snpw42-band-score (eq (snpw42-rec-shifted r) 1) 128))
            (let c8 (snpw42-band-score (and (eq (snpw42-rec-form-nl r) 100)
                                            (eq (snpw42-rec-form-audio r) 100)) 256))
            (let c9 (snpw42-band-score (and (eq (snpw42-rec-before-loss r) 1)
                                            (eq (snpw42-rec-after-loss r) 0)) 512))
            (let c10 (snpw42-band-score (and (eq (snpw42-rec-oracle-ok r) 2)
                                             (eq (snpw42-rec-oracle-total r) 2)) 1024))
            (let c11 (snpw42-band-score (eq (snpw42-rec-open-authority r) 0) 2048))
            (let c12 (snpw42-band-score (eq (snpw42-rec-oracle-bytes r) 44216) 4096))
            (let c13 (snpw42-band-score (and (eq (snpw42-rec-pair-increment r) 1)
                                             (eq (snpw42-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw42-band-score (str_eq (snpw42-rec-status r)
                                                "native-neural-micro-pair-0042-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0042-band))
