; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk learn/speech-native-neural-pair-window-0039.fk
;
; speech-native-neural-pair-window-0039-band -- thirty-ninth neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0039
;   2      pair is it<->pt-br
;   4      Sanskrit baseline meaning 303 is used
;   8      cumulative trained pairs are thirty-nine
;   16     cumulative directed routes are seventy-eight
;   32     thirty-nine epochs and thirty-nine parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   two local Metal oracle rows pass the pair window
;   2048   open authority is false
;   4096   observed local wav bytes are carried
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0039, not open authority

(do
    (defn snpw39-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0039-band ()
        (do
            (let r (snpw39-receipt))
            (let c0 (snpw39-band-score (str_eq (snpw39-rec-kind r)
                                               "speech-native-neural-pair-window-0039") 1))
            (let c1 (snpw39-band-score (and (str_eq (snpw39-rec-a r) "it")
                                            (str_eq (snpw39-rec-b r) "pt-br")) 2))
            (let c2 (snpw39-band-score (eq (snpw39-rec-meaning r) 303) 4))
            (let c3 (snpw39-band-score (eq (snpw39-rec-cumulative-pairs r) 39) 8))
            (let c4 (snpw39-band-score (eq (snpw39-rec-cumulative-directed r) 78) 16))
            (let c5 (snpw39-band-score (and (eq (snpw39-rec-epochs r) 39)
                                            (eq (snpw39-rec-params r) 39)) 32))
            (let c6 (snpw39-band-score (and (eq (snpw39-rec-before-rate r) 0)
                                            (eq (snpw39-rec-after-rate r) 100)) 64))
            (let c7 (snpw39-band-score (eq (snpw39-rec-shifted r) 1) 128))
            (let c8 (snpw39-band-score (and (eq (snpw39-rec-form-nl r) 100)
                                            (eq (snpw39-rec-form-audio r) 100)) 256))
            (let c9 (snpw39-band-score (and (eq (snpw39-rec-before-loss r) 1)
                                            (eq (snpw39-rec-after-loss r) 0)) 512))
            (let c10 (snpw39-band-score (and (eq (snpw39-rec-oracle-ok r) 2)
                                             (eq (snpw39-rec-oracle-total r) 2)) 1024))
            (let c11 (snpw39-band-score (eq (snpw39-rec-open-authority r) 0) 2048))
            (let c12 (snpw39-band-score (eq (snpw39-rec-oracle-bytes r) 48480) 4096))
            (let c13 (snpw39-band-score (and (eq (snpw39-rec-pair-increment r) 1)
                                             (eq (snpw39-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw39-band-score (str_eq (snpw39-rec-status r)
                                                "native-neural-micro-pair-0039-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0039-band))
