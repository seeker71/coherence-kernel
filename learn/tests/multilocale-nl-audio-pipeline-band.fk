; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk
;
; multilocale-nl-audio-pipeline-band -- end-to-end NL/audio reciprocal learning.
;
; Verdict 8191:
;   1    five reciprocal locale pairs are present
;   2    untrained NL route stays below the 50% floor
;   4    untrained audio route stays below the 50% floor
;   8    oracle-valid NL samples train to 100%
;   16   oracle-valid audio samples train to 100%
;   32   receipt route flips from oracle-guide to native after learning
;   64   shift witness records below-floor to native movement
;   128  timeout blocks NL credit
;   256  bad oracle transcript blocks audio credit
;   512  invalid audio metadata blocks audio credit
;   1024 audio target preserves affect metadata
;   2048 receipt records Metal oracle plus Form-native learner
;   4096 receipt keeps native neural Metal as pending, not faked

(do
    (defn mlap-band-score (cond bit) (if cond bit 0))
    (defn mlap-band-row (meaning) (slb-line-by-meaning meaning))
    (defn mlap-band-tokens (meaning locale) (slb-tokens (mlap-band-row meaning) locale))
    (defn mlap-band-meta () (mlap-meta 88 91 24 63))
    (defn mlap-band-bad-meta () (mlap-meta 101 91 24 63))

    (defn mlap-band-feat (meaning)
        (if (eq meaning 301) (list 1000 10 1 1)
            (if (eq meaning 302) (list 2000 20 2 2)
                (if (eq meaning 303) (list 3000 30 3 3)
                    (list 4000 40 4 4)))))

    (defn mlap-band-nl (meaning src dst)
        (mlap-nl-sample meaning src dst
                         (mlap-band-tokens meaning src)
                         (mlap-band-tokens meaning dst)
                         meaning
                         0 0 0))
    (defn mlap-band-audio (meaning src dst)
        (mlap-audio-sample meaning src dst
                            (mlap-band-tokens meaning dst)
                            (mlap-band-tokens meaning dst)
                            (mlap-band-feat meaning)
                            (mlap-band-meta)
                            0 0 0))

    (defn mlap-band-nl-samples ()
        (list
            (mlap-band-nl 301 "en" "de")
            (mlap-band-nl 301 "de" "en")
            (mlap-band-nl 302 "en" "es")
            (mlap-band-nl 302 "es" "en")
            (mlap-band-nl 302 "zh" "ar")
            (mlap-band-nl 302 "ar" "zh")
            (mlap-band-nl 303 "fr" "id")
            (mlap-band-nl 303 "id" "fr")
            (mlap-band-nl 304 "sa" "la")
            (mlap-band-nl 304 "la" "sa")))

    (defn mlap-band-audio-samples ()
        (list
            (mlap-band-audio 301 "en" "de")
            (mlap-band-audio 301 "de" "en")
            (mlap-band-audio 302 "en" "es")
            (mlap-band-audio 302 "es" "en")
            (mlap-band-audio 302 "zh" "ar")
            (mlap-band-audio 302 "ar" "zh")
            (mlap-band-audio 303 "fr" "id")
            (mlap-band-audio 303 "id" "fr")
            (mlap-band-audio 304 "sa" "la")
            (mlap-band-audio 304 "la" "sa")))

    (defn mlap-band-pairs ()
        (list
            (mlap-pair "en" "de")
            (mlap-pair "en" "es")
            (mlap-pair "zh" "ar")
            (mlap-pair "fr" "id")
            (mlap-pair "sa" "la")))

    (defn mlap-band-before-rows () (list (slb-line-by-meaning 301)))
    (defn mlap-band-before-audio-candidates ()
        (list (pid-candidate 301 (mlap-band-tokens 301 "de") (mlap-band-feat 301))))

    (defn mlap-band-timeout-nl ()
        (mlap-nl-sample 301 "en" "de"
                         (mlap-band-tokens 301 "en")
                         (mlap-band-tokens 301 "de")
                         301
                         0 1 0))
    (defn mlap-band-bad-audio ()
        (mlap-audio-sample 301 "en" "de"
                            (mlap-band-tokens 301 "de")
                            (list "wrong")
                            (mlap-band-feat 301)
                            (mlap-band-meta)
                            0 0 0))
    (defn mlap-band-bad-meta-audio ()
        (mlap-audio-sample 301 "en" "de"
                            (mlap-band-tokens 301 "de")
                            (mlap-band-tokens 301 "de")
                            (mlap-band-feat 301)
                            (mlap-band-bad-meta)
                            0 0 0))

    (defn multilocale-nl-audio-pipeline-band ()
        (do
            (let nl (mlap-band-nl-samples))
            (let audio (mlap-band-audio-samples))
            (let pairs (mlap-band-pairs))
            (let before-rows (mlap-band-before-rows))
            (let before-audio (mlap-band-before-audio-candidates))
            (let after-rows (mlap-nl-trained-rows nl before-rows))
            (let after-audio (mlap-audio-trained-candidates audio before-audio 25))
            (let rec (mlap-receipt nl audio after-rows after-audio pairs 25 50
                                   "whisper.cpp-large-v3-turbo"
                                   "macos-arm64-m4-max"))
            (let target (mlap-audio-target (mlap-band-audio 304 "sa" "la") after-audio))
            (let c0 (mlap-band-score (eq (len pairs) 5) 1))
            (let c1 (mlap-band-score (lt (mlap-nl-rate nl before-rows 25) 50) 2))
            (let c2 (mlap-band-score (lt (mlap-audio-rate audio before-audio 25) 50) 4))
            (let c3 (mlap-band-score (eq (mlap-nl-rate nl after-rows 25) 100) 8))
            (let c4 (mlap-band-score (eq (mlap-audio-rate audio after-audio 25) 100) 16))
            (let c5 (mlap-band-score (str_eq (mlap-rec-route rec) "native") 32))
            (let c6 (mlap-band-score (eq (mlap-shift? nl audio before-rows after-rows before-audio after-audio pairs 25 50) 1) 64))
            (let c7 (mlap-band-score (eq (mlap-nl-native-ok? (mlap-band-timeout-nl) after-rows 25) 0) 128))
            (let c8 (mlap-band-score (eq (mlap-audio-native-ok? (mlap-band-bad-audio) after-audio 25) 0) 256))
            (let c9 (mlap-band-score (eq (mlap-audio-native-ok? (mlap-band-bad-meta-audio) after-audio 25) 0) 512))
            (let c10 (mlap-band-score (and (str_eq (mlap-target-kind target) "multilocale-audio-target")
                                           (eq (mlap-meta-confidence (mlap-target-meta target)) 88)) 1024))
            (let c11 (mlap-band-score (and (eq (mlap-rec-oracle-metal rec) 1)
                                           (eq (mlap-rec-native-form rec) 1)) 2048))
            (let c12 (mlap-band-score (eq (mlap-rec-native-neural-metal rec) 0) 4096))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add c8 c9)
                    (add c10 (add c11 c12))))))

    (multilocale-nl-audio-pipeline-band))
