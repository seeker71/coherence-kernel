; speech-teacher-committee-band.fk -- proof of the agreement gate.
;
; preludes: learn/speech-teacher-committee.fk
;
;   1     report row names the committee
;   2     8 measured pair-rows
;   4     admitted 4 (agreement)
;   8     held 4 (disagreement)
;   16    purity: worst witness wer-x10 among admitted rows is 0 -- on this
;         gauntlet every admitted row is clean on BOTH witnesses
;   32    the poisoned fr-short clip is present and HELD (the committee
;         caught what majority-vote among turbo+parakeet would have passed)
;   64    the latin pair crosses architectures (whisper vs transducer)
;
; run: cat learn/speech-teacher-committee.fk \
;          learn/tests/speech-teacher-committee-band.fk > /tmp/stc.fk
;      ./fkwu --src /tmp/stc.fk    ; -> 127
;
; Verdict 127 when every assertion holds.

(do
    (defn stcb-score (ok bit) (if ok bit 0))

    (defn speech-teacher-committee-band ()
        (do
            (let r (stc-report))
            (let c0 (stcb-score (str_eq (nth r 0) "speech-teacher-committee") 1))
            (let c1 (stcb-score (eq (nth r 1) 8) 2))
            (let c2 (stcb-score (eq (stc-admitted-count (stc-rows)) 4) 4))
            (let c3 (stcb-score (eq (stc-held-count (stc-rows)) 4) 8))
            (let c4 (stcb-score (eq (stc-purity-max-wer) 0) 16))
            (let c5 (stcb-score (eq (stc-poison-caught?) 1) 32))
            (let c6 (stcb-score (eq (stc-latin-cross-arch?) 1) 64))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6))))))))

    (speech-teacher-committee-band))
