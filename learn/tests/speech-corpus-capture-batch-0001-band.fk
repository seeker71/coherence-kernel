; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/coherence-network-self-corpus.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-acquisition-window.fk learn/speech-corpus-capture-batch-0001.fk
;
; speech-corpus-capture-batch-0001-band -- captured corpus audio row contract.
;
; Verdict 4095:
;   1     receipt row names batch 0001
;   2     six rows are present
;   4     six rows pass oracle WER floor
;   8     six rows carry audio hashes
;   16    max WER clears floor
;   32    status says captured but not data-sufficient
;   64    native Form true
;   128   neural false
;   256   self-corpus is ready
;   512   acquisition plan covers wav floor
;   1024  sufficiency gate still false
;   2048  acquisition window remains below the full planned capture floor

(do
    (defn sccb-band-score (cond bit) (if cond bit 0))
    (defn sccb-band-row (id locale key text wer hash)
        (list "speech-corpus-capture-receipt-row"
              id locale key text text wer (if (le wer 25) 1 0) hash 8 1 0))
    (defn sccb-band-rows ()
        (list
            (sccb-band-row 1 "en" "common.tryAgain" "Try again" 0 991001)
            (sccb-band-row 2 "de" "common.tryAgain" "Erneut versuchen" 0 991002)
            (sccb-band-row 3 "es" "nav.search" "Buscar" 0 991003)
            (sccb-band-row 4 "fr" "nav.vision" "Vision" 0 991004)
            (sccb-band-row 5 "id" "common.tryAgain" "Coba lagi" 0 991005)
            (sccb-band-row 6 "pt-br" "common.tryAgain" "Tentar novamente" 0 991006)))
    (defn sccb-band-receipt ()
        (sccb-receipt-from (sccb-band-rows)))

    (defn speech-corpus-capture-batch-0001-band ()
        (do
            (let r (sccb-band-receipt))
            (let c0 (sccb-band-score (str_eq (sccb-rec-kind r) (sccb-kind)) 1))
            (let c1 (sccb-band-score (eq (sccb-rec-count r) 6) 2))
            (let c2 (sccb-band-score (eq (sccb-rec-ok r) 6) 4))
            (let c3 (sccb-band-score (eq (sccb-rec-hash-count r) 6) 8))
            (let c4 (sccb-band-score (le (sccb-rec-max-wer r) 25) 16))
            (let c5 (sccb-band-score (str_eq (sccb-rec-status r)
                                             "captured-corpus-audio-not-training-sufficient") 32))
            (let c6 (sccb-band-score (eq (sccb-rec-native-form r) 1) 64))
            (let c7 (sccb-band-score (eq (sccb-rec-neural r) 0) 128))
            (let c8 (sccb-band-score (eq (cnsc-self-corpus-ready?) 1) 256))
            (let c9 (sccb-band-score (eq (scaw-plan-meets-wav-floor?) 1) 512))
            (let c10 (sccb-band-score (eq (slds-sufficient (slds-current)) 0) 1024))
            (let c11 (sccb-band-score (lt (scaw-rec-captured (scaw-receipt))
                                          (scaw-planned-wavs)) 2048))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) (add c10 c11)))))

    (speech-corpus-capture-batch-0001-band))
