; spurious-edge-walker-band.fk — proof of the proactive bridge walker, and of
; what its first walk actually found.
;
; preludes: form-stdlib/core.fk learn/sanskrit-locale-baseline.fk learn/spurious-edge-walker.fk
;
; The body had measured exactly one meaning-graph collision, by failure at
; query time (the "for" bridge). This band proves the walker that finds
; table-internal bridges AT REST, and pins the real result of walking the
; whole baseline (4 meanings x 11 token layers):
;   - exactly 4 internal edges exist, ALL between 301 and 304
;   - sa "bhavantu" and zh "愿" are found (kinship showing through surface)
;   - the form layer itself bridges 301<->304 ("wish", "wellbeing") — so the
;     classifier reads every surface edge as KIN, zero as spurious
;   - English has ZERO internal edges: the measured "for" collision is a
;     query-time edge (out-of-vocabulary paraphrase vs row surface), a class
;     a table walk cannot see — asserted here as documentation, not failure
;   - the folded witness: 4*10^6 + 2*10^4 + 0*10^2 + 0 = 4020000
;
; Verdict 255 when every assertion holds.

(do
    (defn sewb-score (ok bit) (if ok bit 0))
    (defn spurious-edge-walker-band ()
        (do
    (let c0 (sewb-score (eq (sew-count-all) 4) 1))
    (let c1 (sewb-score (eq (sew-edge-found? "sa" "bhavantu" 301 304) 1) 2))
    (let c2 (sewb-score (eq (sew-edge-found? "zh" "愿" 301 304) 1) 4))
    (let c3 (sewb-score (eq (sew-edge-found? "form" "wish" 301 304) 1) 8))
    (let c4 (sewb-score (eq (sew-count-locale "en") 0) 16))          ; the "for" edge is query-time, not table-internal
    (let c5 (sewb-score (eq (sew-kin? 301 304) 1) 32))               ; the form layer declares 301/304 kin
    (let c6 (sewb-score (and (eq (sew-kin-count) 2) (eq (sew-spurious-count) 0)) 64))
    (let c7 (sewb-score (eq (sew-field-code) 4020000) 128))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (spurious-edge-walker-band))
