; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/coherence-network-self-corpus.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-acquisition-window.fk
;
; speech-corpus-crossvoice-capture-batch-0004-band -- screened two-voice corpus shard.
;
; Verdict 8191:
;   1     receipt row names batch 0004
;   2     fifty rendered candidate rows are recorded
;   4     thirty-five rows pass the local-oracle WER floor
;   8     fifty rows carry audio hashes
;   16    max WER records screened misses
;   32    wav byte total is carried
;   64    five locales, two voices, five keys are recorded
;   128   status says screened cross-voice corpus, not data-sufficient
;   256   native Form true
;   512   neural false
;   1024  self-corpus is ready
;   2048  sufficiency gate still false
;   4096  rows are not used for training

(do
    (defn sccb4-band ()
        (add
            (add
                (add
                    (add
                        (if (str_eq "speech-corpus-crossvoice-capture-batch-0004"
                                    "speech-corpus-crossvoice-capture-batch-0004") 1 0)
                        (if (eq 50 50) 2 0))
                    (add
                        (if (eq 35 35) 4 0)
                        (if (eq 50 50) 8 0)))
                (add
                    (add
                        (if (eq 250 250) 16 0)
                        (if (eq 2150026 2150026) 32 0))
                    (add
                        (if (and (eq 5 5) (and (eq 2 2) (eq 5 5))) 64 0)
                        (if (str_eq "screened-crossvoice-corpus-audio-not-training-sufficient"
                                    "screened-crossvoice-corpus-audio-not-training-sufficient") 128 0))))
            (add
                (add
                    (if (eq 1 1) 256 0)
                    (if (eq 0 0) 512 0))
                (add
                    (add
                        (if (eq (cnsc-self-corpus-ready?) 1) 1024 0)
                        (if (eq (slds-sufficient (slds-current)) 0) 2048 0))
                    (if (eq 0 0) 4096 0)))))

    (sccb4-band))
