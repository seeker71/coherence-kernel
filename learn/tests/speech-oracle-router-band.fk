; speech-oracle-router-band.fk -- proof of the routed committee.
;
; preludes: learn/speech-oracle-roster.fk learn/speech-oracle-router.fk
;
; Second measurement (2026-07-17, healed fr-short, one-session walls). The
; router's identity shifted with the reseated anchor: no longer the accuracy
; win over turbo, now the SPEED arm against the large-v3 anchor.
;
;   1     report row names the router
;   2     all 8 gauntlet clips resolve to exactly one measured roster row
;   4     routed mean wer-x10 is 25 (2.5%)
;   8     routed mean wall is 1280ms
;   16    the anchor's overall mean wer-x10 is 16 -- the router CONCEDES
;         accuracy to the anchor now (25 vs 16), by 0.9 points
;   32    the anchor's overall mean wall is 2228ms
;   64    the zh seat is a zh-covering model (coverage survives routing)
;   128   the router's claim: 1.7x the anchor's speed (speed-gain-x10 = 17),
;         and strictly faster in absolute wall
;
; run: cat learn/speech-oracle-roster.fk learn/speech-oracle-router.fk \
;          learn/tests/speech-oracle-router-band.fk > /tmp/sorr.fk
;      ./fkwu --src /tmp/sorr.fk    ; -> 255
;
; Verdict 255 when every assertion holds.

(do
    (defn sorrb-score (ok bit) (if ok bit 0))

    (defn speech-oracle-router-band ()
        (do
            (let r (sorr-report))
            (let c0 (sorrb-score (str_eq (nth r 0) "speech-oracle-router") 1))
            (let c1 (sorrb-score (eq (sorr-resolved (sorr-clips)) 8) 2))
            (let c2 (sorrb-score (eq (sorr-mean-wer) 25) 4))
            (let c3 (sorrb-score (eq (sorr-mean-wall) 1280) 8))
            (let c4 (sorrb-score (eq (sor-overall-mean-wer (sor-anchor)) 16) 16))
            (let c5 (sorrb-score (eq (sor-overall-mean-wall (sor-anchor)) 2228) 32))
            (let c6 (sorrb-score (eq (sorr-zh-seat-covered?) 1) 64))
            (let c7 (sorrb-score (and (eq (sorr-speed-gain-x10) 17)
                                      (lt (sorr-mean-wall)
                                          (sor-overall-mean-wall (sor-anchor)))) 128))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))

    (speech-oracle-router-band))
