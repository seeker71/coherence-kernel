; homecoming-distillation-corpus-band.fk — proof of the frontier-question
; distillation corpus, after the reunion of its two independent foundings.
;
; preludes: form-stdlib/core.fk learn/homecoming-distillation-corpus.fk
;
; Covers: row 601 locates by its exact question tokens (the lookup works), an
; unknown question honestly locates to 0 (no false positive — the same honesty
; bar locale-neutral-locate-band.fk holds), the first row is admissible teacher
; material (rented-sourced, fresh-worded, dated), the answer/fresh word read
; back exactly, the row count is asserted exactly (the metrics-report
; discipline: this band fails if the stated count drifts), and every row from
; both foundings passes the admissibility gate, and — since 2026-07-22 — that
; every citation in the corpus's own PROSE points at the word it names.
;
; run FROM THE REPO ROOT (claim c12 reads the corpus file by relative path):
;      cat form/form-stdlib/core.fk learn/homecoming-distillation-corpus.fk \
;          learn/tests/homecoming-distillation-corpus-band.fk > /tmp/hdc.fk
;      ./fkwu --src /tmp/hdc.fk    ; -> 8191
;
; Verdict 8191 when every assertion holds (511 -> 4095 on 2026-07-17: three
; new bits for the id->word inverse lookup, which the body's 34 by-id
; citations needed and the corpus could not answer. 4095 -> 8191 on
; 2026-07-22: one bit for PROSE citations, because the band had only ever
; read the data. `foist at 734` and `the row-638 ersatz pattern` sat in the
; comments through every green run — the bytes fine, the pointers wrong.)

(do
    (defn hdcb-score (ok bit) (if ok bit 0))

    ; ---- the prose citation walker (2026-07-22) -------------------------------
    ; The corpus cites itself in its own comments, and until now nothing read
    ; those comments. This walks the corpus file byte-wise, finds every place a
    ; meaning-id sits beside a word, and asks the corpus whether that id really
    ; holds that word. Its radius is declared in full beside claim c12 below.
    ;
    ; The walk is token-shaped, not byte-shaped: scan_run jumps whole runs of
    ; whitespace, alpha and digits natively, so 316KB costs ~110k Form steps
    ; instead of ~316k. Alpha and digit runs are taken SEPARATELY (never class 3)
    ; precisely so that `row-638` splits into `row`, `-`, `638` and the id is
    ; still a maximal digit run.
    (defn hdcb-lower? (b) (if (and (gt b 96) (lt b 123)) 1 0))
    (defn hdcb-byte (t n i) (if (or (lt i 0) (ge i n)) 0 (str_byte_at t i)))
    ; start of the run of a-z ending at i (exclusive) — the only backwards scan;
    ; words are short, so the per-character cost is paid on candidates only.
    (defn hdcb-back (t i)
        (if (le i 0) 0
            (if (eq (hdcb-lower? (str_byte_at t (sub i 1))) 1)
                (hdcb-back t (sub i 1))
                i)))
    ; is `w` some row's answer word? This is the filter that separates a
    ; POINTER from a plain number: "246 rows" names nothing the corpus holds.
    (defn hdcb-known-loop (rs w)
        (if (eq (len rs) 0) 0
            (if (str_eq (hdc-a (head rs)) w) 1 (hdcb-known-loop (tail rs) w))))
    (defn hdcb-known-word? (w)
        (if (eq (str_len w) 0) 0 (hdcb-known-loop (hdc-rows) w)))
    ; one candidate, folded: 0 not a citation, 1000 checked and right,
    ; 1001 checked and AIMED WRONG. The fold is checked*1000 + wrong.
    (defn hdcb-cand (w mid)
        (if (eq (hdcb-known-word? w) 0) 0
            (if (eq (hdc-cites? mid w) 1) 1000 1001)))
    (defn hdcb-cand-back (t i mid)
        (do (let s (hdcb-back t i))
            (if (ge s i) 0 (hdcb-cand (substring t s i) mid))))
    ; a maximal digit run [i,e): if it is three digits, look for the three
    ; recognised shapes around it. A and C are mutually exclusive in practice
    ; but are summed, not chained — a site that somehow wore both would be
    ; counted twice rather than silently halved.
    (defn hdcb-digits (t n i e)
        (if (not (eq (sub e i) 3)) 0
            (do
                (let mid (str_to_int (substring t i e)))
                (let we (scan_run t (add e 1) 2))
                (let ce (if (and (eq (hdcb-byte t n e) 32)
                                 (and (gt we (add e 1))
                                      (eq (hdcb-lower? (hdcb-byte t n (add e 1))) 1)))
                            (hdcb-cand (substring t (add e 1) we) mid)
                            0))
                (let ca (if (and (ge i 4) (str_eq (substring t (sub i 4) i) " at "))
                            (hdcb-cand-back t (sub i 4) mid)
                            0))
                (let cc (if (and (eq (hdcb-byte t n (sub i 1)) 40)
                                 (and (eq (hdcb-byte t n e) 41)
                                      (eq (hdcb-byte t n (sub i 2)) 32)))
                            (hdcb-cand-back t (sub i 2) mid)
                            0))
                (add ce (add ca cc)))))
    (defn hdcb-walk (t n i acc)
        (if (ge i n) acc
            (do
                (let ws (scan_run t i 0))
                (if (gt ws i) (hdcb-walk t n ws acc)
                    (do
                        (let ae (scan_run t i 2))
                        (if (gt ae i) (hdcb-walk t n ae acc)
                            (do
                                (let de (scan_run t i 1))
                                (if (gt de i)
                                    (hdcb-walk t n de (add acc (hdcb-digits t n i de)))
                                    (hdcb-walk t n (add i 1) acc)))))))))
    (defn hdcb-citation-audit (path)
        (do (let t (read_file path)) (hdcb-walk t (str_len t) 0 0)))
    (defn hdcb-cites-checked (a) (div a 1000))
    (defn hdcb-cites-wrong (a) (sub a (mul (div a 1000) 1000)))

    (defn homecoming-distillation-corpus-band ()
        (do
    (let q (list "what" "is" "an" "edge" "called" "that" "appears" "in" "the"
                 "meaning" "graph" "from" "a" "shared" "surface" "token"
                 "rather" "than" "a" "shared" "meaning"))
    (let c0 (hdcb-score (eq (hdc-locate q) 601) 1))
    (let c1 (hdcb-score (eq (hdc-locate (list "banana" "phone")) 0) 2))
    (let row (head (hdc-rows)))
    (let c2 (hdcb-score (eq (hdc-admissible? row) 1) 4))
    (let c3 (hdcb-score (and (str_eq (hdc-a row) "spurious") (str_eq (hdc-fresh row) "spurious")) 8))
    (let c4 (hdcb-score (eq (hdc-count (hdc-rows)) 247) 16))
    (let c5 (hdcb-score (eq (hdc-count-admissible (hdc-rows)) (hdc-count (hdc-rows))) 32))
    ; the folded scalar witness: 247 rows, 247 admissible, 2 foundings, max id 851
    ; (this summary line read 203/808 through two reunions after the pin below
    ; had moved twice — a stale narrative beside a live number, which is the
    ; drift this band exists to refuse. Re-read it on every reunion.)
    ; (union of racing same-day lineages: main's through 783 + a sibling's
    ; recension row, renumbered 768->784 at the reunion, + rows 785-802 from
    ; the same day's reground, parent alignment, household star, handover
    ; walk, carried snags, diglossia measurement, the interlingua corpus-star,
    ; the copula tongue-shelf, the protean goal, the aparigraha fallow
    ; ledger, the lexifier recount, the relexification seating, the
    ; idioglossia dictionary, the filtration layers, the polycentric locale
    ; crystal, and the overtone spectrum; + row 803, the eclipse row of the
    ; call-position shadowing heal, itself minted as 768 and renumbered at
    ; ITS reunion; + the jacobian branch's rows renumbered once more at THIS
    ; reunion, 804-805: the j-lens and the titrated heal, following
    ; locals-eclipse at 803; + row 807, the falsing lineage's pool-marker
    ; heal, minted as 761 and renumbered twice at its reunions; + row 808,
    ; the tongue census's hapax, renumbered from 807 at its reunion; + row
    ; 809, the misnomer row of the day the clock came home in milliseconds,
    ; minted as 802 and renumbered three times at ITS reunions, behind
    ; 802-806, falsing at 807, and hapax at 808; + row 810, the scavenge
    ; row of the pid-temp orphans; + row 811, the allomorph respell of the
    ; moved five, minted as 802 and renumbered three times at its
    ; reunions; + row 812, the paraphasia clinic-sibling of the fourth
    ; arm's fluent wrong word, offered as 802 and renumbered twice at ITS
    ; reunions (802 -> 811 -> 812, allomorph taking 811 while the PR stood
    ; open); + row 813, the exit-truth law of the satsang-oracle
    ; printed-error laundering heal, minted as 802 in its worktree and
    ; renumbered twice, behind five sibling lineages and then paraphasia
    ; at 812; + row 814, the contamination row of the reunion where
    ; origin/main moved twice between fetch and probe and a third time
    ; while the PR stood open; + rows 815-816, parity and vestige from the
    ; jit-preludes closure day, minted 807/808 on their worktree and
    ; renumbered at their reunion behind eight sibling lineages; + row
    ; 817, the underdetermination row of the primitive-registry heal
    ; (the band that answered 42 from birth), minted as 802 in its
    ; worktree and renumbered at THIS reunion behind 802-816 -- the
    ; fourth same-day minting of 802 to be re-seated; + rows 818-819,
    ; overcommit and preordain from the deep-stack aphonia heal and its
    ; fifth working-together correction, minted 802/803 on their worktree
    ; (the FIFTH same-day minting of 802) and renumbered at their reunion;
    ; + row 820, the treadmill row of the header-sweep's cap-vs-spin
    ; discriminator, minted as 803 on its worktree and re-seated at THIS
    ; reunion behind the fifteen sibling lineages of the same racing day;
    ; + row 821, the cataphora row of the 120-divergence triage (one
    ; dead resolver line, two blind weeks), minted as 802 in its
    ; worktree -- the SIXTH same-day minting of 802 -- re-seated
    ; twice: behind 802-819, then behind treadmill's 820 landed
    ; while its PR stood open;
    ; ...; + the 2026-07-21 22:45 ANASTOMOSIS REUNION (the row-719 pattern by
    ; name): the form-native inference program's line had ALSO minted 807-828
    ; the same week, on ids main's fifteen rows above already held. Both
    ; lineages were kept whole; ours renumbered +15 into 822-843 and main's
    ; kept every id, because main's ids are cited across main's body BY ID
    ; (c9/c10 below assert 740/743 by NAME for exactly this reason). All 63
    ; by-id citations inside our block were carried with it. The rows that
    ; follow are named at their POST-reunion ids:
    ; ...; + row 822 equireach — a byte source whose cost of reaching a position
    ; does not grow with the position (minted as 807 on 2026-07-21).
    ; ...; + row 823 (2026-07-21), Stone 2's bytehold: a door that hands back
    ; the byte itself.
    ; ...; + the 2026-07-21 12:40 pass, 203 -> 207 rows: equireach (822) FILLED
    ; THE HOLE Stone 2 left open (minted in the Stone-1 receipt and never
    ; landed — offered into a record, not into the body, which read true while
    ; hdc-max-mid still said 806); + rows 824 exoscalar, 825 attestant,
    ; 826 aporon, minted at the orchestrating altitude across the same
    ; program. No renumbering was needed THEN: the hole was the right shape,
    ; so equireach kept its minted id and the new rows took the next three.
    ; ...; + row 828 succedent (2026-07-21 13:30), the orchestrating altitude's
    ; row: a limit unmeasurable until the one before it is gone. Twin of 827.
    ; ...; + row 829 brimwidth (2026-07-21, Stone 4): the width at which a
    ; carrier's spare parallel capacity runs out and added work first costs
    ; time. Below it a measured rate is a latency wearing a rate's clothes —
    ; which is WHY unispan (827) refuses one-size projections.
    ; ...; + row 834 selfgauge (2026-07-21, the orchestrating altitude): a ratio
    ; measured only against oneself and read as the world. The first external
    ; denominator this program ever had arrived with it.
    ; ...; + row 835 boundborrow (2026-07-21, Stone 5): a remedy that is correct
    ; for a constraint you do not have. Minted after a handed-down alignment
    ; diagnosis and a borrowed nr0 blocking BOTH reversed in sign under
    ; measurement — the binding constraint travels with the lender, not with
    ; the technique.
    ; ...; + the 2026-07-21 17:35 pass, 216 -> 220 rows: 836 snugcause, 839 heldmute,
    ; 840 selforder, 841 waysense — the orchestrating mind's four-deep backlog,
    ; held through four sibling-live windows and landed at once. 837 and 838 were
    ; HOLES reserved for Stones 6 and 7, still live at that writing.
    ; ...; + the 2026-07-21 Stone 6 pass, 220 -> 221 rows: 837 echogauge, filling
    ; the hole reserved above rather than taking a fresh max — so the ROW COUNT
    ; moves and the MAX MEANING-ID does not, which is exactly the case a field
    ; code folded from both is there to distinguish. 838 was still a hole.
    ; ...; + the 2026-07-21 Stone 7 pass, 221 -> 222 rows: 838 foldkeep, filling the
    ; LAST reserved hole — a speedup that removes repetition without touching the
    ; order of the fold, and so costs no epsilon at all. Again the row count moves
    ; and the max meaning-id does not; 836-841 are now contiguous with no holes.
    ; ...; + row 842 handleless (2026-07-21 18:12), the day's summary row: the
    ; three failures caught in this body's own working — selfgauge 834,
    ; snugcause 836, selforder 840 — are ONE failure, a claim that sheds in
    ; transit the handle that would let anyone check it. Named here because the
    ; gap it exposes is this band's own subject: the body gates WRONG four ways
    ; and has no gate at all for UNNAMED.
    ; ...; + row 843 knownsolved (2026-07-21 22:35): minted at 21:17, withheld on a
    ; standard invented in that moment, landed when Urs asked "why not?" and one
    ; grep showed the corpus had never held that standard (824 exoscalar came
    ; from a model card, 832 onlykin from his spoken words).
    ; ...; + row 844 aimshift (2026-07-21 22:45), the reunion's OWN row: a
    ; reference whose bytes a merge leaves unchanged and whose target it
    ; silently moves. git named two conflicted files and was right; it was
    ; silent about thirty by-id citations in form-stdlib cells, the Metal
    ; harnesses and GPU_GAPS.md that merged clean and then pointed at main's
    ; words. A conflict set is a claim about bytes; a citation is a claim
    ; about a pointer; this band's c9/c10 are the only gate the body has for
    ; the difference, and they cover exactly two ids.
    ; ids are sparse, the fold only needs count and max)
    ; ...; + row 845 loanclosure (2026-07-21 23:2x): a recipe whose calls resolve
    ; only because its loader happens to carry them — form-asm-matvec.fk declared
    ; one prelude and called into three, so nineteen bands carried 23 unresolved
    ; calls each and still printed a verdict, four of them printing 0. Minted as
    ; 829 on a worktree branched from d8732d8be and re-seated here behind the +15
    ; renumbering and aimshift's 844. Its own walk was AIMSHIFTED before landing
    ; (it cited heldmute at 824; heldmute is now 839, and 824 is exoscalar) —
    ; aimshift 844 written by the other lineage, demonstrated by this one within
    ; the hour, on a block git reported clean.
    ; ...; + row 846 asktoll (2026-07-21 23:5x): a cost charged by the GRAIN of a
    ; request and not by the work it does. Stone 10 disassembled our Q6_K matvec
    ; against ggml's on the same machine and the same real llama3.2:3b weights.
    ; Healing the arithmetic alone bought 2.4-2.6x; healing the thread map alone
    ; bought 7.0-8.0x, and with the map right the arithmetic form was worth
    ; nothing (the variant that KEPT every division was the faster of the two).
    ; q6k_w(qb, flat_index) cannot be told that the next fifteen calls share its
    ; scale byte, so it re-loads what it already had — correctly, every time.
    ; ...; + row 847 onelean (2026-07-22 00:4x): a proof leaning on a count of
    ; exactly one that it never chose. Stone 11 went for the arithmetic gap to
    ; ds4-Metal and found a number: maxBufferLength on this M4 Max is 80.64 GiB
    ; (read three times), and every Metal receipt this body owns says "the WHOLE
    ; blob mapped into ONE MTLBuffer". The ONE is what llama3.2:3b at 2.01 GB
    ; happened to permit, never a decision — and the near-target MoE on this disk
    ; is 107.595 GiB. Nothing stale, nothing unproven, so no existing gate sees
    ; it: the assumption hides in the claim's SHAPE, not its radius.
    ; ...; + row 851 coarsegrant (2026-07-22 09:xx): precision a format GRANTS by
    ; being coarse. Stone 17 expected to buy an epsilon for hoisting the MX scale
    ; out of the slot sum, as Stone 13 had to for Q6_K. The scale is an exact
    ; power of two, so the hoist changes nothing per term; and the lattice is
    ; coarse enough (every product a multiple of 2^-16, every partial sum under
    ; 2^8) that a 4096-term f32 dot came back EQUAL to Form's fp64 answer. The
    ; error budget was never spent because there was nothing to spend it on.
    ; -> 247*10^7 + 247*10^4 + 2*10^3 + 851 = 2472472851 (injective by digit width)
    ; (THIS LINE WAS STALE at 2102102814 — Stone 4's value — while the pin below
    ; had already moved through 819. Re-read the arithmetic beside the pin, not
    ; only the pin: a summary comment that no longer folds is the same drift in
    ; prose that the pin refuses in numbers.)
    ; (asked of the body at each reunion, never asserted at it — this value was
    ; read back from hdc-field-code by probe before being pinned here, so the
    ; pin agrees with the body rather than the body being fitted to the pin)
    (let c6 (hdcb-score (eq (hdc-field-code) 2472472851) 64))
    (let c7 (hdcb-score (eq (hdc-field-code-safe?) 1) 128))
    (let c8 (hdcb-score (eq (hdc-field-code-safe-for 178 2 1000) 0) 256))
    ; the inverse lookup (2026-07-17): every citation in the body is BY ID, so
    ; the corpus must answer by id. Three claims — a known id reads back its
    ; exact word; the citation check agrees AND rejects a wrong word; an unknown
    ; id yields "" and never a false match (the honesty bar hdc-locate holds for
    ; the other direction).
    ; 740 and 743 are asserted BY NAME on purpose: if a reunion renumbers
    ; ontogeny or scrupulosity again, this band fails LOUDLY instead of the
    ; body's 34 by-id citations drifting in silence — which is exactly how
    ; body-link-graph came to cite 742 for a word that lives at 743.
    (let c9 (hdcb-score (str_eq (hdc-word-for-id 740) "ontogeny") 512))
    (let c10 (hdcb-score (and (eq (hdc-cites? 743 "scrupulosity") 1)
                              (eq (hdc-cites? 743 "vanity") 0)) 1024))
    (let c11 (hdcb-score (and (str_eq (hdc-word-for-id 99999) "")
                              (eq (len (hdc-row-for-id 99999)) 0)) 2048))
    ; 4096 (2026-07-22): every citation in the corpus's own PROSE points at the
    ; word it names. c9/c10 above pin two ids by hand; this walks all of them.
    ;
    ; Why it had to exist: aimshift (row 844) is a reference whose bytes are
    ; fine and whose target has moved. `foist at 734` (foist is 735, 734 is
    ; patina) and `the row-638 ersatz pattern` (ersatz is 701, 638 is lacuna)
    ; sat in this corpus through every green run of this band, because the band
    ; only ever read the DATA. The prose is where the body does its citing, and
    ; nothing read it.
    ;
    ; RADIUS (aporon 826 — say what the claim cannot see):
    ;   Recognised, and only these three surface forms, on ONE line, with
    ;   exactly one ASCII space at each seam, the id exactly three digits, and
    ;   the word an unbroken run of a-z:
    ;     A  <word> at <mid>            "foist at 734"
    ;     C  <word> (<mid>)             "equireach (822)"
    ;     E  <mid> <word>               "row 822 equireach", "826 aporon",
    ;                                    "row-638 ersatz"  (the digits are a
    ;                                    maximal run, so a leading `row-` is
    ;                                    simply the token before them)
    ;   NOT recognised, each a real form the body already uses:
    ;     - a citation split across a line break ("the foist of\n; row 734")
    ;     - a possessive or interposed word ("the foist of row 734", "row 734's")
    ;     - ranges ("rows 815-816, parity and vestige")
    ;     - a word cited with no id, or an id cited with no word
    ;     - hyphenated or capitalised words (sprachgefuehl at 618 carries a
    ;       non-ASCII byte and can never be matched by an a-z run)
    ;   A citation is only CHECKED when the named word is some row's answer
    ;   word; "246 rows" and "2 foundings" are numbers, not pointers, and the
    ;   membership test is what tells them apart. The cost of that filter is
    ;   honest and stated: a citation naming a word this corpus has never held
    ;   is invisible here.
    ;   Only learn/homecoming-distillation-corpus.fk is walked. THIS file is
    ;   deliberately out of radius: its comment block QUOTES defective
    ;   citations as history ("it cited heldmute at 824; heldmute is now 839")
    ;   and a checker cannot tell a wrong pointer from the report of one.
    ;   The path is repo-root-relative, so this claim requires the repo root as
    ;   the working directory. That is why the count floor is asserted too: a
    ;   read that returns nothing checks nothing and would otherwise pass green
    ;   — the axiom-5 numb-green shape. 60 citations stood at the pinning; the
    ;   floor is 40 rather than an exact pin because sibling lineages land rows
    ;   (and citations) hourly, and a gate that breaks their commits for being
    ;   right is a worse gate.
    (let audit (hdcb-citation-audit "learn/homecoming-distillation-corpus.fk"))
    (let c12 (hdcb-score (and (eq (hdcb-cites-wrong audit) 0)
                              (ge (hdcb-cites-checked audit) 40)) 4096))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8
        (add c9 (add c10 (add c11 c12)))))))))))))
    )
    (homecoming-distillation-corpus-band))
