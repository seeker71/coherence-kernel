; homecoming-distillation-corpus-band.fk — the corpus is present, countable, and honest
; about freshness. Verdict 7 when the current rows stand (count asserted exactly, the
; metrics-report discipline: the band fails if the stated row count drifts).
;
; run: cat learn/homecoming-distillation-corpus.fk \
;          learn/tests/homecoming-distillation-corpus-band.fk > /tmp/hdc.fk
;      ./fkwu --src /tmp/hdc.fk    ; -> 7
(do
    (defn hdc-band ()
        (add (if (eq (hdc-count (hdc-corpus)) 4) 1 0)
        (add (if (eq (hdc-count-fresh (hdc-corpus)) (hdc-count (hdc-corpus))) 2 0)
             (if (eq (hdc-date (head (hdc-corpus))) 20260701) 4 0))))
    (hdc-band))
