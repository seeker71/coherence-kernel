; preludes: learn/speech-locale-coverage-matrix.fk
;
; speech-locale-coverage-matrix-band -- per-locale speech coverage report.
;
; Verdict 32767:
;   1     report row names the locale coverage matrix
;   2     thirteen locales are recorded
;   4     eleven locales are ready now
;   8     eight locales have live anchors or carrier-live rows
;   16    two Indigenous locale rows remain consent-pending
;   32    twelve pair rows are recorded
;   64    ten pair rows route native
;   128   two pair rows remain oracle-guided
;   256   en<->zh records 10/12 = 83
;   512   en<->ar records 12/12 = 100
;   1024  sa<->la seeded pair routes native
;   2048  open dictation remains oracle-held
;   4096  Sema live voice remains oracle-held
;   8192  Navajo row is consent-pending
;   16384 report marks native Form true and neural ready false

(do
    (defn slcm-band-score (cond bit) (if cond bit 0))
    (defn slcm-rec-locales (r) (nth r 1))
    (defn slcm-rec-pairs   (r) (nth r 2))

    (defn slcm-find-pair (pairs a b)
        (if (eq (len pairs) 0) (slcm-pair "" "" "" 0 0 0 "")
            (if (and (str_eq (slcm-pair-a (head pairs)) a)
                     (str_eq (slcm-pair-b (head pairs)) b))
                (head pairs)
                (slcm-find-pair (tail pairs) a b))))

    (defn slcm-find-locale (rows code)
        (if (eq (len rows) 0) (slcm-locale "" 0 0 0 0 0 0 0 "")
            (if (str_eq (slcm-code (head rows)) code)
                (head rows)
                (slcm-find-locale (tail rows) code))))

    (defn speech-locale-coverage-matrix-band ()
        (do
            (let r (slcm-report))
            (let locales (slcm-rec-locales r))
            (let pairs (slcm-rec-pairs r))
            (let enzh (slcm-find-pair pairs "en" "zh"))
            (let enar (slcm-find-pair pairs "en" "ar"))
            (let sala (slcm-find-pair pairs "sa" "la"))
            (let open (slcm-find-pair pairs "open" "dictation"))
            (let voice (slcm-find-pair pairs "sema" "voice"))
            (let nv (slcm-find-locale locales "nv"))
            (let c0 (slcm-band-score (str_eq (nth r 0) "speech-locale-coverage-matrix") 1))
            (let c1 (slcm-band-score (eq (nth r 3) 13) 2))
            (let c2 (slcm-band-score (eq (nth r 4) 11) 4))
            (let c3 (slcm-band-score (eq (nth r 5) 8) 8))
            (let c4 (slcm-band-score (eq (nth r 6) 2) 16))
            (let c5 (slcm-band-score (eq (nth r 7) 12) 32))
            (let c6 (slcm-band-score (eq (nth r 8) 10) 64))
            (let c7 (slcm-band-score (eq (nth r 9) 2) 128))
            (let c8 (slcm-band-score (and (eq (slcm-pair-native-ok enzh) 10)
                                          (and (eq (slcm-pair-total enzh) 12)
                                               (eq (slcm-pair-native-rate enzh) 83))) 256))
            (let c9 (slcm-band-score (and (eq (slcm-pair-native-ok enar) 12)
                                          (eq (slcm-pair-native-rate enar) 100)) 512))
            (let c10 (slcm-band-score (str_eq (slcm-pair-route sala) "native") 1024))
            (let c11 (slcm-band-score (str_eq (slcm-pair-route open) "oracle-guide") 2048))
            (let c12 (slcm-band-score (str_eq (slcm-pair-route voice) "oracle-guide") 4096))
            (let c13 (slcm-band-score (and (str_eq (slcm-status nv) "consent-pending")
                                           (eq (slcm-ready nv) 0)) 8192))
            (let c14 (slcm-band-score (and (eq (nth r 10) 1)
                                           (eq (nth r 11) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-locale-coverage-matrix-band))
