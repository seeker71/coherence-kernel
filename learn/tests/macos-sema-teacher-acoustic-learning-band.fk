; preludes:
;   observe/stt-wer.fk
;   observe/wav-sense.fk
;   learn/macos-sema-teacher-acoustic-learning.fk
;
; macos-sema-teacher-acoustic-learning-band -- teacher wav learner contract.
;
; Verdict 4095:
;   1     receipt row names the teacher acoustic learner
;   2     audio hash is carried
;   4     eight wav-envelope windows are recorded
;   8     three token feature rows are used
;   16    training adds native prototypes beyond blank
;   32    oracle transcript is accepted
;   64    native decoded transcript is accepted
;   128   native success passes
;   256   native WER is zero
;   512   min confidence clears the native floor
;   1024  native Form true
;   2048  neural model remains false

(do
    (defn mstal-band-score (cond bit) (if cond bit 0))
    (defn mstal-band-env () (list 4 1 2 2 3 1 0 0))
    (defn mstal-band-features ()
        (mstal-envelope-feature-stream (mstal-band-env)))
    (defn mstal-band-frames ()
        (do
            (let features (mstal-band-features))
            (let trained (mstal-trained features))
            (mstal-frames (mstal-frame-features features) trained 2 80)))
    (defn mstal-band-native ()
        (mstal-decoded-text (mstal-band-frames)))
    (defn mstal-band-receipt ()
        (do
            (let features (mstal-band-features))
            (let trained (mstal-trained features))
            (let frames (mstal-frames (mstal-frame-features features) trained 2 80))
            (let native (mstal-decoded-text frames))
            (list (mstal-kind)
                  984777
                  (len (mstal-band-env))
                  (len features)
                  (len trained)
                  (mstal-text)
                  native
                  (if (and (sw-accept? (sw-tokens (mstal-text)) (sw-tokens (mstal-text)) (mstal-max-wer))
                           (sw-accept? (sw-tokens native) (sw-tokens (mstal-text)) (mstal-max-wer))) 1 0)
                  (sw-wer (sw-tokens native) (sw-tokens (mstal-text)))
                  (mstal-min-conf frames)
                  (mstal-device)
                  (mstal-oracle)
                  1
                  0)))

    (defn macos-sema-teacher-acoustic-learning-band ()
        (do
            (let r (mstal-band-receipt))
            (let c0 (mstal-band-score (str_eq (mstal-rec-kind r) (mstal-kind)) 1))
            (let c1 (mstal-band-score (eq (mstal-rec-hash r) 984777) 2))
            (let c2 (mstal-band-score (eq (mstal-rec-env-count r) 8) 4))
            (let c3 (mstal-band-score (eq (mstal-rec-features r) 3) 8))
            (let c4 (mstal-band-score (gt (mstal-rec-prototypes r) 3) 16))
            (let c5 (mstal-band-score (eq (sw-wer (sw-tokens (mstal-rec-oracle r)) (sw-tokens (mstal-text))) 0) 32))
            (let c6 (mstal-band-score (eq (sw-wer (sw-tokens (mstal-rec-native r)) (sw-tokens (mstal-text))) 0) 64))
            (let c7 (mstal-band-score (eq (mstal-rec-ok r) 1) 128))
            (let c8 (mstal-band-score (eq (mstal-rec-wer r) 0) 256))
            (let c9 (mstal-band-score (ge (mstal-rec-confidence r) 80) 512))
            (let c10 (mstal-band-score (eq (mstal-rec-native-form r) 1) 1024))
            (let c11 (mstal-band-score (eq (mstal-rec-neural r) 0) 2048))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) (add c10 c11)))))

    (macos-sema-teacher-acoustic-learning-band))
