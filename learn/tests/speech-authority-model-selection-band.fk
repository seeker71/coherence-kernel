; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-live-receipt-intake.fk
;   learn/speech-global-authority-update.fk
;   learn/speech-authority-model-selection.fk
;
; speech-authority-model-selection-band -- route model arms by live authority.
;
; Verdict 32767:
;   1     report row names authority model selection
;   2     current ASR remains prototype-asr under oracle-guide
;   4     current TTS remains Sema sample loop under oracle-guide
;   8     current speech arms have 0/2 global native authority
;   16    current selected model has zero native neural parameters admitted
;   32    current NL2NL/audio2audio arms remain selected and native/scoped
;   64    demo ASR selects native-open-asr-source after 3/3 receipts
;   128   demo TTS selects native-sema-voice after 3/3 receipts
;   256   demo speech arms have 2/2 global native authority
;   512   receipt thresholds and clean controls still come from global update
;   1024  both selections still have four arms
;   2048  demo keeps zero admitted neural parameters; native does not mean neural here
;   4096  current and demo notes are explicit
;   8192  report marks native Form true and neural ready false
;   16384 current speech authority remains 0/2 native and 2/2 oracle-guided

(do
    (defn sams-band-score (cond bit) (if cond bit 0))

    (defn speech-authority-model-selection-band ()
        (do
            (let r (sams-report))
            (let current (nth r 1))
            (let demo (nth r 2))
            (let cur-asr (nth current 1))
            (let cur-tts (nth current 2))
            (let cur-nl (nth current 3))
            (let cur-audio (nth current 4))
            (let demo-asr (nth demo 1))
            (let demo-tts (nth demo 2))
            (let demo-updates (sgau-demo-updates))
            (let demo-open (nth demo-updates 0))
            (let demo-voice (nth demo-updates 1))
            (let c0 (sams-band-score (str_eq (nth r 0) "speech-authority-model-selection-report") 1))
            (let c1 (sams-band-score (and (str_eq (sams-arm-id cur-asr) "prototype-asr")
                                          (and (str_eq (sams-arm-authority cur-asr) "oracle-guide")
                                               (str_eq (sams-arm-note cur-asr) "oracle-guide"))) 2))
            (let c2 (sams-band-score (and (str_eq (sams-arm-id cur-tts) "sema-voice-sample-loop")
                                          (and (str_eq (sams-arm-authority cur-tts) "oracle-guide")
                                               (str_eq (sams-arm-note cur-tts) "oracle-guide"))) 4))
            (let c3 (sams-band-score (and (eq (nth current 5) 0)
                                          (eq (nth current 6) 2)) 8))
            (let c4 (sams-band-score (eq (nth current 8) 0) 16))
            (let c5 (sams-band-score (and (str_eq (sams-arm-id cur-nl) "closed-set-locale-form")
                                          (and (str_eq (sams-arm-authority cur-nl) "native-form-anchor")
                                               (and (str_eq (sams-arm-id cur-audio) "native-source-window-audio2audio-acoustic")
                                                    (str_eq (sams-arm-authority cur-audio) "metal-scoped-native")))) 32))
            (let c6 (sams-band-score (and (str_eq (sams-arm-id demo-asr) "native-open-asr-source")
                                          (and (str_eq (sams-arm-authority demo-asr) "global-native")
                                               (eq (sams-arm-count demo-asr) 3))) 64))
            (let c7 (sams-band-score (and (str_eq (sams-arm-id demo-tts) "native-sema-voice")
                                          (and (str_eq (sams-arm-authority demo-tts) "global-native")
                                               (eq (sams-arm-count demo-tts) 3))) 128))
            (let c8 (sams-band-score (and (eq (nth demo 5) 2)
                                          (eq (nth demo 6) 0)) 256))
            (let c9 (sams-band-score (and (eq (sgau-lane-max-wer demo-open) 25)
                                          (and (eq (sgau-lane-min-conf demo-open) 80)
                                               (and (eq (sgau-lane-max-latency demo-voice) 2000)
                                                    (str_eq (sgau-lane-controls demo-voice)
                                                            "choice-cut-fail-undo-timeout-clean")))) 512))
            (let c10 (sams-band-score (and (eq (nth current 7) 4)
                                           (eq (nth demo 7) 4)) 1024))
            (let c11 (sams-band-score (eq (nth demo 8) 0) 2048))
            (let c12 (sams-band-score (and (str_eq (nth current 12) "current-real-live-receipts-keep-speech-oracle-guided")
                                           (str_eq (nth demo 12) "demo-clean-real-live-receipts-promote-speech-native")) 4096))
            (let c13 (sams-band-score (and (eq (nth r 6) 1)
                                           (eq (nth r 7) 0)) 8192))
            (let c14 (sams-band-score (and (eq (nth current 5) 0)
                                           (eq (nth current 6) 2)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-authority-model-selection-band))
