; preludes:
;   learn/speech-neural-pair-coverage.fk
;   learn/speech-pair-training-next-action.fk
;   learn/speech-open-asr-tts-target-model.fk
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-authority-learning-priority.fk
;
; speech-authority-learning-priority-band -- prioritize authority gaps.
;
; Verdict 32767:
;   1      report row names authority learning priority
;   2      current neural coverage is thirty-seven pairs
;   4      current directed routes are seventy-four
;   8      current native neural params are thirty-seven
;   16     background pair scheduler advances to next 0038 id<->it
;   32     open ASR and Sema voice gaps are both 100
;   64     Sema voice remains measured 0/1 native with oracle 1/1
;   128    next authority trial is open ASR 0001
;   256    selected authority action trains live segmented open ASR source
;   512    selected target is native segmented acoustic learning
;   1024   promotion and control rules include measured A/B safeguards
;   2048   authority gap is forced ahead of pair-window drift
;   4096   chosen action is the authority action, not the pair id
;   8192   route remains oracle-guide until receipts pass
;   16384  status names gap priority, native Form true, open authority false

(do
    (defn salp-band-score (cond bit) (if cond bit 0))

    (defn speech-authority-learning-priority-band ()
        (do
            (let r (salp-report))
            (let c0 (salp-band-score (str_eq (salp-rec-kind r)
                                             "speech-authority-learning-priority") 1))
            (let c1 (salp-band-score (eq (salp-rec-neural-pairs r) 37) 2))
            (let c2 (salp-band-score (eq (salp-rec-neural-directed r) 74) 4))
            (let c3 (salp-band-score (eq (salp-rec-neural-params r) 37) 8))
            (let c4 (salp-band-score (and (str_eq (salp-rec-pair-id r)
                                                  "next-native-neural-pair-window-0038")
                                          (and (str_eq (salp-rec-pair-a r) "id")
                                               (str_eq (salp-rec-pair-b r) "it"))) 16))
            (let c5 (salp-band-score (and (eq (salp-rec-open-gap r) 100)
                                          (eq (salp-rec-voice-gap r) 100)) 32))
            (let c6 (salp-band-score (and (eq (salp-rec-voice-native-ok r) 0)
                                          (and (eq (salp-rec-voice-native-total r) 1)
                                               (and (eq (salp-rec-voice-oracle-ok r) 1)
                                                    (eq (salp-rec-voice-oracle-total r) 1)))) 64))
            (let c7 (salp-band-score (and (str_eq (salp-rec-trial-id r) "trial-open-asr-0001")
                                          (str_eq (salp-rec-trial-gap r) "live-open-dictation")) 128))
            (let c8 (salp-band-score (str_eq (salp-rec-trial-action r)
                                             "train-live-segmented-open-asr-source") 256))
            (let c9 (salp-band-score (str_eq (salp-rec-trial-target r)
                                             "native-segmented-acoustic-learning") 512))
            (let c10 (salp-band-score (and (str_eq (salp-rec-promote r)
                                                   "native-rate>=50-and-wer<=25-clean-controls")
                                           (str_eq (salp-rec-control r)
                                                   "choice-cut-fail-undo-timeout")) 1024))
            (let c11 (salp-band-score (eq (salp-rec-force-authority r) 1) 2048))
            (let c12 (salp-band-score (str_eq (salp-rec-choice r)
                                              "train-live-segmented-open-asr-source") 4096))
            (let c13 (salp-band-score (str_eq (salp-rec-route r) "oracle-guide") 8192))
            (let c14 (salp-band-score (and (str_eq (salp-rec-status r)
                                                    "authority-gap-outranks-pair-window-until-open-receipts-pass")
                                           (and (eq (salp-rec-native-form r) 1)
                                                (eq (salp-rec-open-authority r) 0))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-authority-learning-priority-band))
