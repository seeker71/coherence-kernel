; preludes: learn/speech-native-neural-bootstrap.fk
;
; speech-native-neural-bootstrap-band -- one enabled native neural slot.
;
; Verdict 32767:
;   1      receipt row names the bootstrap
;   2      one enabled slot exists
;   4      one native neural parameter is admitted
;   8      one training epoch is recorded
;   16     weight moves 1 -> 2
;   32     prediction moves 1 -> 2
;   64     loss moves 1 -> 0
;   128    one sample is used
;   256    oracle and native scoped rates are 100
;   512    no trained locale pair is claimed
;   1024   bootstrap-ready is true
;   2048   route-enabled is true
;   4096   native Form is true
;   8192   learning rate is one
;   16384  status refuses pair authority

(do
    (defn snnb-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-bootstrap-band ()
        (do
            (let r (snnb-receipt))
            (let c0 (snnb-band-score (str_eq (snnb-rec-kind r)
                                             "speech-native-neural-bootstrap") 1))
            (let c1 (snnb-band-score (eq (snnb-rec-enabled-slots r) 1) 2))
            (let c2 (snnb-band-score (eq (snnb-rec-param-count r) 1) 4))
            (let c3 (snnb-band-score (eq (snnb-rec-epochs r) 1) 8))
            (let c4 (snnb-band-score (and (eq (snnb-rec-before-weight r) 1)
                                          (eq (snnb-rec-after-weight r) 2)) 16))
            (let c5 (snnb-band-score (and (eq (snnb-rec-before-pred r) 1)
                                          (eq (snnb-rec-after-pred r) 2)) 32))
            (let c6 (snnb-band-score (and (eq (snnb-rec-before-loss r) 1)
                                          (eq (snnb-rec-after-loss r) 0)) 64))
            (let c7 (snnb-band-score (eq (snnb-rec-samples r) 1) 128))
            (let c8 (snnb-band-score (and (eq (snnb-rec-oracle-rate r) 100)
                                          (eq (snnb-rec-native-rate r) 100)) 256))
            (let c9 (snnb-band-score (eq (snnb-rec-pair-trained r) 0) 512))
            (let c10 (snnb-band-score (eq (snnb-rec-bootstrap-ready r) 1) 1024))
            (let c11 (snnb-band-score (eq (snnb-rec-route-enabled r) 1) 2048))
            (let c12 (snnb-band-score (eq (snnb-rec-native-form r) 1) 4096))
            (let c13 (snnb-band-score (eq (snnb-rec-rate r) 1) 8192))
            (let c14 (snnb-band-score (str_eq (snnb-rec-status r)
                                              "enabled-native-neural-bootstrap-not-pair-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-bootstrap-band))
