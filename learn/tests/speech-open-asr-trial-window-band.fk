; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;
; speech-open-asr-trial-window-band -- execute the scheduled ASR trial.
;
; Verdict 32767:
;   1     report row names the open-ASR trial window
;   2     scheduler selected trial-open-asr-0001
;   4     challenger is native segmented acoustic learning
;   8     scheduled backlog starts oracle 100 / native 0
;   16    segmented receipt names en<->de trial window
;   32    oracle-clean trial has two samples and two oracle passes
;   64    compact native trial receipt earns two native passes
;   128   trial native rate reaches 100 over a 50 floor
;   256   receipt routes native for the window
;   512   neutral baseline target records German tokens for meaning 303
;   1024  action cuts challenger for this trial window
;   2048  clean choice/cut/fail/undo/timeout controls are recorded
;   4096  local Metal oracle/device are preserved
;   8192  model context keeps zero neural weights and zero C seed growth
;   16384 report marks native Form true and neural ready false

(do
    (defn soat-band-score (cond bit) (if cond bit 0))
    (defn soat-rec-trial       (r) (nth r 1))
    (defn soat-rec-receipt     (r) (nth r 2))
    (defn soat-rec-before-oracle (r) (nth r 3))
    (defn soat-rec-before-native (r) (nth r 4))
    (defn soat-rec-oracle-ok   (r) (nth r 5))
    (defn soat-rec-native-ok   (r) (nth r 6))
    (defn soat-rec-native-rate (r) (nth r 7))
    (defn soat-rec-action      (r) (nth r 8))
    (defn soat-rec-controls    (r) (nth r 9))
    (defn soat-rec-context     (r) (nth r 10))
    (defn soat-rec-scope       (r) (nth r 11))
    (defn soat-rec-native-form (r) (nth r 12))
    (defn soat-rec-neural-ready (r) (nth r 13))

    (defn speech-open-asr-trial-window-band ()
        (do
            (let r (soat-report))
            (let trial (soat-rec-trial r))
            (let receipt (soat-rec-receipt r))
            (let context (soat-rec-context r))
            (let c0 (soat-band-score (str_eq (nth r 0) "speech-open-asr-trial-window") 1))
            (let c1 (soat-band-score (str_eq (snts-id trial) "trial-open-asr-0001") 2))
            (let c2 (soat-band-score (str_eq (snts-challenger trial) "native-segmented-acoustic-learning") 4))
            (let c3 (soat-band-score (and (eq (soat-rec-before-oracle r) 100)
                                          (eq (soat-rec-before-native r) 0)) 8))
            (let c4 (soat-band-score (and (str_eq (soat-receipt-kind receipt) "speech-open-asr-segmented-trial-receipt")
                                          (and (str_eq (soat-receipt-src receipt) "en")
                                               (str_eq (soat-receipt-dst receipt) "de"))) 16))
            (let c5 (soat-band-score (and (eq (soat-receipt-count receipt) 2)
                                          (eq (soat-rec-oracle-ok r) 2)) 32))
            (let c6 (soat-band-score (eq (soat-rec-native-ok r) 2) 64))
            (let c7 (soat-band-score (and (eq (soat-rec-native-rate r) 100)
                                          (eq (soat-receipt-floor receipt) 50)) 128))
            (let c8 (soat-band-score (str_eq (soat-receipt-route receipt) "native") 256))
            (let c9 (soat-band-score (and (eq (soat-receipt-meaning receipt) 303)
                                          (str_eq (head (soat-receipt-target receipt)) "ich")) 512))
            (let c10 (soat-band-score (str_eq (soat-rec-action r) "cut-challenger-for-trial-window") 1024))
            (let c11 (soat-band-score (str_eq (soat-rec-controls r) "choice-cut-fail-undo-timeout-clean") 2048))
            (let c12 (soat-band-score (and (str_eq (soat-receipt-oracle receipt) "whisper.cpp-large-v3-turbo-metal")
                                           (str_eq (soat-receipt-device receipt) "macos-arm64-m4-max")) 4096))
            (let c13 (soat-band-score (and (eq (nth context 1) 0)
                                           (and (eq (nth context 6) 0)
                                                (str_eq (soat-rec-scope r) "trial-window-native-not-global-authority"))) 8192))
            (let c14 (soat-band-score (and (eq (soat-rec-native-form r) 1)
                                           (eq (soat-rec-neural-ready r) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-open-asr-trial-window-band))
