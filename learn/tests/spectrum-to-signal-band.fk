; spectrum-to-signal-band.fk — the SSP gate sorts every case the way the paper's mechanism demands:
; RL amplifies WITHIN the spectrum, coverage is the ceiling, and diversity dominates signal-effort.
;
; Named at spectrum-to-signal.fk's header and built in the same movement (2026-07-13), under the
; build-after-naming law — the attempt that lets the shape be observed, not just spoken.
;
; preludes: form-stdlib/core.fk learn/spectrum-to-signal.fk
;
; run: cat form/form-stdlib/core.fk learn/spectrum-to-signal.fk \
;          learn/tests/spectrum-to-signal-band.fk > /tmp/sspb.fk
;      ./fkwu --src /tmp/sspb.fk    ; -> 127
;
; Verdict 127 when the gate is honest.

(do
    (defn sspb (ok bit) (if ok bit 0))
    (defn spectrum-to-signal-band ()
        (do
    ; covered + full signal FRONTIERS (pass@1)
    (let c0 (sspb (eq (ssp-reach (list 1 2)) 2) 1))
    ; covered + no signal is LATENT only — coverage without sharpening is pass@k, not pass@1
    (let c1 (sspb (eq (ssp-reach (list 1 0)) 1) 2))
    ; uncovered COLLAPSES however strong the signal — the paper's WITHIN made falsifiable
    (let c2 (sspb (and (eq (ssp-reach (list 0 2)) 0)
                       (eq (ssp-reach (list 0 0)) 0)) 4))
    ; amplifiable iff the spectrum covered the method — RL cannot conjure what SFT missed
    (let c3 (sspb (and (eq (ssp-amplifiable? (list 1 0)) 1)
                       (eq (ssp-amplifiable? (list 0 2)) 0)) 8))
    ; the ceiling is bounded by coverage — no coverage ceilings at 0, coverage opens the climb to 2
    (let c4 (sspb (and (eq (ssp-ceiling (list 1 0)) 2)
                       (eq (ssp-ceiling (list 0 2)) 0)) 16))
    ; diversity dominates: covered-but-low-signal out-reaches uncovered-but-full-signal
    (let c5 (sspb (eq (ssp-diversity-first? (list 1 0) (list 0 2)) 1) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (sspb (eq (spectrum-to-signal-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (spectrum-to-signal-band))
