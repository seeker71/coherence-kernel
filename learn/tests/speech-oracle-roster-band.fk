; speech-oracle-roster-band.fk -- proof of the measured rented-oracle roster.
;
; preludes: learn/speech-oracle-roster.fk
;
; Pins the 2026-07-17 one-session gauntlet exactly (the metrics-report
; discipline: this band fails if any stated number drifts), and proves the
; seat law selected from the numbers alone. This is the SECOND measurement
; of this cell: healing the fr-short clip (one added syllable) reseated
; everything the founding session had chosen -- the anchor moved from turbo
; to large-v3 (overall 32 vs 16 once the poison stopped charging turbo
; nothing and large-v3 2500), and the fast seat moved from small to turbo
; under the corrected strictly-faster law.
;
;   1     report row names the roster
;   2     32 measured runs (4 models x 8 clips)
;   4     anchor seat: whisper.cpp-large-v3-metal (the polyglot -- zh
;         coverage, overall mean wer-x10 16, the lowest of the covering ears)
;   8     fast seat: whisper.cpp-large-v3-turbo-metal (latin 23 at 1175ms --
;         the most accurate of the strictly-faster-than-anchor ears; small
;         is faster still at 684ms but latin 51)
;   16    fast seat latin mean wer-x10 is 23 (2.3%)
;   32    fast seat latin mean wall is 1175ms
;   64    anchor zh mean wer-x10 is 29 (2.9% CER)
;   128   anchor zh mean wall is 2282ms
;   256   challenger parakeet-tdt-0.6b-v3-mlx measured latin 47, wall 2361 --
;         STRICTLY DOMINATED by the turbo ear on both axes this session
;   512   coverage split: anchor covers zh, challenger does not
;   1024  nemotron-speech-streaming stays honestly pending, no local runtime
;   2048  same-wavs law: all four models heard identical bytes -- the
;         en-short cksum AND the healed fr-short cksum each appear exactly
;         four times
;
; run: cat learn/speech-oracle-roster.fk \
;          learn/tests/speech-oracle-roster-band.fk > /tmp/sor.fk
;      ./fkwu --src /tmp/sor.fk    ; -> 4095
;
; Verdict 4095 when every assertion holds.

(do
    (defn sorb-score (ok bit) (if ok bit 0))

    (defn sorb-cksum-count (rs ck)
        (if (eq (len rs) 0) 0
            (add (if (eq (sor-run-cksum (head rs)) ck) 1 0)
                 (sorb-cksum-count (tail rs) ck))))

    (defn speech-oracle-roster-band ()
        (do
            (let r (sor-report))
            (let c0 (sorb-score (str_eq (nth r 0) "speech-oracle-roster") 1))
            (let c1 (sorb-score (eq (nth r 1) 32) 2))
            (let c2 (sorb-score (str_eq (sor-anchor) "whisper.cpp-large-v3-metal") 4))
            (let c3 (sorb-score (str_eq (sor-fast-oracle) "whisper.cpp-large-v3-turbo-metal") 8))
            (let c4 (sorb-score (eq (sor-mean-wer (sor-fast-oracle) 0) 23) 16))
            (let c5 (sorb-score (eq (sor-mean-wall (sor-fast-oracle) 0) 1175) 32))
            (let c6 (sorb-score (eq (sor-mean-wer (sor-anchor) 1) 29) 64))
            (let c7 (sorb-score (eq (sor-mean-wall (sor-anchor) 1) 2282) 128))
            (let c8 (sorb-score (and (eq (sor-mean-wer "parakeet-tdt-0.6b-v3-mlx" 0) 47)
                                     (and (eq (sor-mean-wall "parakeet-tdt-0.6b-v3-mlx" 0) 2361)
                                          (and (gt (sor-mean-wer "parakeet-tdt-0.6b-v3-mlx" 0)
                                                   (sor-mean-wer "whisper.cpp-large-v3-turbo-metal" 0))
                                               (gt (sor-mean-wall "parakeet-tdt-0.6b-v3-mlx" 0)
                                                   (sor-mean-wall "whisper.cpp-large-v3-turbo-metal" 0))))) 256))
            (let c9 (sorb-score (and (eq (sor-covers-zh? (sor-anchor)) 1)
                                     (eq (sor-covers-zh? "parakeet-tdt-0.6b-v3-mlx") 0)) 512))
            (let c10 (sorb-score (and (str_eq (nth (sor-pending) 1) "nemotron-speech-streaming-en-0.6b")
                                      (str_eq (nth (sor-pending) 2) "no-local-runtime")) 1024))
            (let c11 (sorb-score (and (eq (sorb-cksum-count (sor-runs) 3568971285) 4)
                                      (eq (sorb-cksum-count (sor-runs) 4243204481) 4)) 2048))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
                (add c8 (add c9 (add c10 c11)))))))))))))

    (speech-oracle-roster-band))
