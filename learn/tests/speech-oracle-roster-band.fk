; speech-oracle-roster-band.fk -- proof of the measured rented-oracle roster.
;
; preludes: learn/speech-oracle-roster.fk
;
; Pins the 2026-07-16 gauntlet exactly (the metrics-report discipline: this
; band fails if any stated number drifts), and proves the seat law selected
; from the numbers alone:
;
;   1     report row names the roster
;   2     32 measured runs (4 models x 8 clips)
;   4     anchor seat: whisper.cpp-large-v3-turbo-metal (the polyglot --
;         zh coverage before brilliance)
;   8     fast seat: whisper.cpp-small-metal -- NOT the paper favorite;
;         through the body's per-clip CLI shape the challenger's startup
;         tax (about 1.8s) sinks it, and small beats the anchor on both
;         latin wer and wall
;   16    fast seat latin mean wer-x10 is 51 (5.1%)
;   32    fast seat latin mean wall is 366ms
;   64    anchor zh mean wer-x10 is 59 (5.9% CER)
;   128   anchor zh mean wall is 799ms
;   256   challenger parakeet-tdt-0.6b-v3-mlx measured latin mean 214, wall 1806
;   512   coverage split: anchor covers zh, challenger does not
;   1024  nemotron-speech-streaming stays honestly pending, no local runtime
;   2048  same-wavs law: all four models heard the identical en-short bytes
;         (cksum 3568971285 appears exactly four times)
;
; run: cat learn/speech-oracle-roster.fk \
;          learn/tests/speech-oracle-roster-band.fk > /tmp/sor.fk
;      ./fkwu --src /tmp/sor.fk    ; -> 4095
;
; Verdict 4095 when every assertion holds.

(do
    (defn sorb-score (ok bit) (if ok bit 0))

    (defn sorb-cksum-count (rs ck)
        (if (eq (len rs) 0) 0
            (add (if (eq (sor-run-cksum (head rs)) ck) 1 0)
                 (sorb-cksum-count (tail rs) ck))))

    (defn speech-oracle-roster-band ()
        (do
            (let r (sor-report))
            (let c0 (sorb-score (str_eq (nth r 0) "speech-oracle-roster") 1))
            (let c1 (sorb-score (eq (nth r 1) 32) 2))
            (let c2 (sorb-score (str_eq (sor-anchor) "whisper.cpp-large-v3-turbo-metal") 4))
            (let c3 (sorb-score (str_eq (sor-fast-oracle) "whisper.cpp-small-metal") 8))
            (let c4 (sorb-score (eq (sor-mean-wer (sor-fast-oracle) 0) 51) 16))
            (let c5 (sorb-score (eq (sor-mean-wall (sor-fast-oracle) 0) 366) 32))
            (let c6 (sorb-score (eq (sor-mean-wer (sor-anchor) 1) 59) 64))
            (let c7 (sorb-score (eq (sor-mean-wall (sor-anchor) 1) 799) 128))
            (let c8 (sorb-score (and (eq (sor-mean-wer "parakeet-tdt-0.6b-v3-mlx" 0) 214)
                                     (eq (sor-mean-wall "parakeet-tdt-0.6b-v3-mlx" 0) 1806)) 256))
            (let c9 (sorb-score (and (eq (sor-covers-zh? (sor-anchor)) 1)
                                     (eq (sor-covers-zh? "parakeet-tdt-0.6b-v3-mlx") 0)) 512))
            (let c10 (sorb-score (and (str_eq (nth (sor-pending) 1) "nemotron-speech-streaming-en-0.6b")
                                      (str_eq (nth (sor-pending) 2) "no-local-runtime")) 1024))
            (let c11 (sorb-score (eq (sorb-cksum-count (sor-runs) 3568971285) 4) 2048))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
                (add c8 (add c9 (add c10 c11)))))))))))))

    (speech-oracle-roster-band))
