; carrier-trust-band.fk — the carrier-trust gate sorts every case the way the
; law demands: trust binds to weights, the apocryphal name adds nothing yet
; stays seen, and at equal trust the smaller carrier takes the recipe-data lane.
;
; Named at carrier-trust.fk's header and built in the same movement
; (2026-07-16), under the build-after-naming law.
;
; preludes: form-stdlib/core.fk learn/carrier-trust.fk
;
; run: cat form/form-stdlib/core.fk learn/carrier-trust.fk \
;          learn/tests/carrier-trust-band.fk > /tmp/cwtb.fk
;      ./fkwu --src /tmp/cwtb.fk    ; -> 127
;
; Verdict 127 when the gate is honest.

(do
    (defn cwtb (ok bit) (if ok bit 0))
    (defn carrier-trust-band ()
        (do
    ; trust reads only weight-bound documentation
    (let c0 (cwtb (and (eq (cwt-trust (cwt-minicpm-base)) 1)
                       (eq (cwt-trust (cwt-vibethinker)) 1)) 1))
    ; the frontier NAME adds exactly nothing: the eponymous fine-tune's trust is 0
    (let c1 (cwtb (eq (cwt-trust (cwt-fable5-ft)) 0) 2))
    ; evals do not survive a weight change: the base out-trusts its own fine-tune, both directions
    (let c2 (cwtb (and (eq (cwt-better-carrier (cwt-minicpm-base) (cwt-fable5-ft)) 1)
                       (eq (cwt-better-carrier (cwt-fable5-ft) (cwt-minicpm-base)) 2)) 4))
    ; at equal trust the smaller carrier wins the lane, both directions
    (let c3 (cwtb (and (eq (cwt-better-carrier (cwt-minicpm-base) (cwt-vibethinker)) 1)
                       (eq (cwt-better-carrier (cwt-vibethinker) (cwt-minicpm-base)) 2)) 8))
    ; size never overrules trust: a documented 3B beats an apocryphal 1B
    (let c4 (cwtb (eq (cwt-better-carrier (cwt-vibethinker) (cwt-fable5-ft)) 1) 16))
    ; the apocryphal carrier stays SEEN, never frozen; the documented base may freeze
    (let c5 (cwtb (and (eq (cwt-witnessed-not-frozen? (cwt-fable5-ft)) 1)
                       (eq (cwt-freezable? (cwt-minicpm-base)) 1)) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (cwtb (eq (carrier-trust-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (carrier-trust-band))
