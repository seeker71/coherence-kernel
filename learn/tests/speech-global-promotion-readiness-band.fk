; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/sema-voice-trial-window.fk
;   learn/speech-current-status-ledger.fk
;   learn/speech-global-promotion-readiness.fk
;
; speech-global-promotion-readiness-band -- global authority promotion gate.
;
; Verdict 32767:
;   1     report row names the promotion readiness ledger
;   2     two global live lanes are tracked
;   4     open dictation has scoped native evidence 2/2
;   8     Sema live voice has scoped native evidence 1/1
;   16    open dictation still has 0/3 real live native receipts
;   32    Sema live voice still has 0/3 real live native receipts
;   64    both lanes require WER <= 25 and clean controls
;   128   both scoped windows are native training evidence
;   256   no lane is globally native-ready yet
;   512   both lanes remain oracle-guide globally
;   1024  six total live receipts are still missing
;   2048  threshold rule names three real live receipts per lane
;   4096  scoped windows are explicitly not global authority
;   8192  native Form true and neural ready false
;   16384 current status ledger still composes underneath

(do
    (defn sgpr-band-score (cond bit) (if cond bit 0))
    (defn sgpr-rec-lanes       (r) (nth r 1))
    (defn sgpr-rec-count       (r) (nth r 2))
    (defn sgpr-rec-ready       (r) (nth r 3))
    (defn sgpr-rec-oracle      (r) (nth r 4))
    (defn sgpr-rec-missing     (r) (nth r 5))
    (defn sgpr-rec-threshold   (r) (nth r 6))
    (defn sgpr-rec-scope       (r) (nth r 7))
    (defn sgpr-rec-native-form (r) (nth r 8))
    (defn sgpr-rec-neural-ready (r) (nth r 9))

    (defn speech-global-promotion-readiness-band ()
        (do
            (let r (sgpr-report))
            (let lanes (sgpr-rec-lanes r))
            (let open (nth lanes 0))
            (let voice (nth lanes 1))
            (let status (smcl-report))
            (let c0 (sgpr-band-score (str_eq (nth r 0) "speech-global-promotion-readiness") 1))
            (let c1 (sgpr-band-score (eq (sgpr-rec-count r) 2) 2))
            (let c2 (sgpr-band-score (and (str_eq (sgpr-lane-name open) "live-open-dictation")
                                          (and (eq (sgpr-lane-scoped-ok open) 2)
                                               (eq (sgpr-lane-scoped-total open) 2))) 4))
            (let c3 (sgpr-band-score (and (str_eq (sgpr-lane-name voice) "sema-live-voice")
                                          (and (eq (sgpr-lane-scoped-ok voice) 1)
                                               (eq (sgpr-lane-scoped-total voice) 1))) 8))
            (let c4 (sgpr-band-score (and (eq (sgpr-lane-live-ok open) 0)
                                          (and (eq (sgpr-lane-live-required open) 3)
                                               (eq (sgpr-lane-missing open) 3))) 16))
            (let c5 (sgpr-band-score (and (eq (sgpr-lane-live-ok voice) 0)
                                          (and (eq (sgpr-lane-live-required voice) 3)
                                               (eq (sgpr-lane-missing voice) 3))) 32))
            (let c6 (sgpr-band-score (and (eq (sgpr-lane-max-wer open) 25)
                                          (and (eq (sgpr-lane-max-wer voice) 25)
                                               (and (eq (sgpr-lane-clean open) 1)
                                                    (eq (sgpr-lane-clean voice) 1)))) 64))
            (let c7 (sgpr-band-score (and (eq (sgpr-lane-native-window open) 1)
                                          (eq (sgpr-lane-native-window voice) 1)) 128))
            (let c8 (sgpr-band-score (eq (sgpr-rec-ready r) 0) 256))
            (let c9 (sgpr-band-score (and (eq (sgpr-rec-oracle r) 2)
                                          (and (str_eq (sgpr-lane-route open) "oracle-guide")
                                               (str_eq (sgpr-lane-route voice) "oracle-guide"))) 512))
            (let c10 (sgpr-band-score (eq (sgpr-rec-missing r) 6) 1024))
            (let c11 (sgpr-band-score (str_eq (sgpr-rec-threshold r) "need-three-real-live-native-receipts-per-lane") 2048))
            (let c12 (sgpr-band-score (str_eq (sgpr-rec-scope r) "scoped-native-windows-are-training-evidence-not-global-authority") 4096))
            (let c13 (sgpr-band-score (and (eq (sgpr-rec-native-form r) 1)
                                           (eq (sgpr-rec-neural-ready r) 0)) 8192))
            (let c14 (sgpr-band-score (and (str_eq (nth status 0) "speech-current-status-ledger")
                                           (str_eq (nth status 6) "global-live-authority-still-oracle-held")) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-global-promotion-readiness-band))
