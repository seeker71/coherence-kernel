; preludes:
;   learn/speech-model-metrics-report.fk
;
; speech-model-metrics-report-band -- aggregate speech model report.
;
; Verdict 32767:
;   1     report row names the metrics surface
;   2     model size reports zero native neural weight parameters admitted today
;   4     four selected arms are recorded
;   8     composition names ASR/TTS/NL2NL/audio2audio selected arms
;   16    Sanskrit baseline and TCAV are named as composition support
;   32    vocoder oracle bridge and live segmented carrier are named
;   64    closed-prompt live Metal anchors are 7/7 = 100%
;   128   en<->zh anchor rate is 10/12 = 83%
;   256   en<->ar anchor rate is 12/12 = 100%
;   512   live open dictation oracle rate is 4/4 = 100%
;   1024  live open dictation native rate is 0/4 = 0%
;   2048  Sema live voice live-native pass is 0/1 = 0%
;   4096  Sema live voice WER remains 100, oracle-guide, with native machinery present
;   8192  voice target quality carries warm mid/cadence/breath facts
;   16384 report marks native Form true, neural ready false, and learning data honest but insufficient

(do
    (defn smmr-band-score (cond bit) (if cond bit 0))
    (defn smmr-rec-size        (r) (nth r 1))
    (defn smmr-rec-comp        (r) (nth r 2))
    (defn smmr-rec-closed      (r) (nth r 3))
    (defn smmr-rec-open        (r) (nth r 4))
    (defn smmr-rec-voice       (r) (nth r 5))
    (defn smmr-rec-quality     (r) (nth r 6))
    (defn smmr-rec-native-form (r) (nth r 7))
    (defn smmr-rec-neural      (r) (nth r 8))
    (defn smmr-rec-learning    (r) (nth r 9))
    (defn smmr-rec-acquisition (r) (nth r 10))
    (defn smmr-rec-capture     (r) (nth r 11))
    (defn smmr-rec-sufficiency (r) (nth r 12))

    (defn speech-model-metrics-report-band ()
        (do
            (let r (smmr-report))
            (let size (smmr-rec-size r))
            (let comp (smmr-rec-comp r))
            (let closed (smmr-rec-closed r))
            (let open (smmr-rec-open r))
            (let voice (smmr-rec-voice r))
            (let quality (smmr-rec-quality r))
            (let learning (smmr-rec-learning r))
            (let acquisition (smmr-rec-acquisition r))
            (let capture (smmr-rec-capture r))
            (let sufficiency (smmr-rec-sufficiency r))
            (let c0 (smmr-band-score (str_eq (nth r 0) "speech-model-metrics-report") 1))
            (let c1 (smmr-band-score (eq (nth size 1) 0) 2))
            (let c2 (smmr-band-score (eq (nth size 2) 4) 4))
            (let c3 (smmr-band-score (and (str_eq (nth comp 1) "prototype-asr")
                                          (and (str_eq (nth comp 2) "sema-voice-sample-loop")
                                               (and (str_eq (nth comp 3) "closed-set-locale-form")
                                                    (str_eq (nth comp 4) "native-source-window-audio2audio-acoustic")))) 8))
            (let c4 (smmr-band-score (and (str_eq (nth comp 5) "sanskrit-locale-baseline")
                                          (str_eq (nth comp 6) "text-conditioned-acoustic-vocoder")) 16))
            (let c5 (smmr-band-score (and (str_eq (nth comp 7) "sema-voice-vocoder-oracle-bridge")
                                          (str_eq (nth comp 8) "live-segmented-feature-carrier")) 32))
            (let c6 (smmr-band-score (and (eq (nth closed 1) 7)
                                          (and (eq (nth closed 2) 7)
                                               (eq (nth closed 3) 100))) 64))
            (let c7 (smmr-band-score (and (eq (nth closed 4) 10)
                                          (and (eq (nth closed 5) 12)
                                               (eq (nth closed 6) 83))) 128))
            (let c8 (smmr-band-score (and (eq (nth closed 7) 12)
                                          (and (eq (nth closed 8) 12)
                                               (eq (nth closed 9) 100))) 256))
            (let c9 (smmr-band-score (and (eq (nth open 1) 4)
                                          (and (eq (nth open 2) 4)
                                               (eq (nth open 3) 100))) 512))
            (let c10 (smmr-band-score (and (eq (nth open 4) 0)
                                           (and (eq (nth open 5) 4)
                                                (eq (nth open 6) 0))) 1024))
            (let c11 (smmr-band-score (and (eq (nth voice 4) 0)
                                           (and (eq (nth voice 5) 1)
                                                (eq (nth voice 6) 0))) 2048))
            (let c12 (smmr-band-score (and (eq (nth voice 7) 100)
                                           (and (str_eq (nth voice 8) "oracle-guide")
                                                (eq (nth voice 9) 1))) 4096))
            (let c13 (smmr-band-score (and (eq (nth quality 1) 165)
                                           (and (eq (nth quality 2) 82)
                                                (and (eq (nth quality 3) 64)
                                                     (eq (nth quality 5) 18)))) 8192))
            (let c14 (smmr-band-score (and (eq (smmr-rec-native-form r) 1)
                                           (and (eq (smmr-rec-neural r) 0)
                                                (and (eq (nth learning 1) 11)
                                                     (and (eq (nth learning 2) 484572)
                                                          (and (eq (nth learning 4) 11)
                                                               (and (eq (nth learning 6) 1)
                                                                    (and (eq (nth learning 7) 0)
                                                                         (and (eq (nth learning 10) 100)
                                                                              (and (eq (nth learning 11) 1)
                                                                                  (and (eq (nth learning 13) 100)
                                                                                        (and (eq (nth capture 1) 6)
                                                                                             (and (eq (nth capture 2) 6)
                                                                                                  (and (eq (nth capture 3) 0)
                                                                                                       (and (eq (nth acquisition 4) 300)
                                                                                                            (and (eq (nth acquisition 5) 30)
                                                                                                                 (and (eq (nth sufficiency 1) 11)
                                                                                                                      (and (eq (nth sufficiency 2) 300)
                                                                                                                           (and (eq (nth sufficiency 3) 6)
                                                                                                                                (and (eq (nth sufficiency 11) 0)
                                                                                                                                     (str_eq (nth sufficiency 12)
                                                                                                                                             "plumbing-smoke-not-data-sufficient-training")))))))))))))))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-model-metrics-report-band))
