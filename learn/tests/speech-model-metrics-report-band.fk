; speech-model-metrics-report-band -- compact aggregate witness.
;
; Returns 32767 only when the metrics surface carries the current nonzero
; model floor: 29 native neural weights, 77 Form speech components, Sema voice
; scoped oracle/native floor 2/3, teacher oracle floor 2/2, corpus training
; intake 0003, and 64 admitted training rows while data sufficiency remains
; false.

(do
    (defn smmr-metrics-score (cond bit) (if cond bit 0))

    (defn speech-model-metrics-report-band ()
        (do
            (let r (smmr-report))
            (let size (nth r 1))
            (let voice (nth r 5))
            (let capture (nth r 11))
            (let sufficiency (nth r 12))
            (add
                (add
                    (add
                        (smmr-metrics-score (str_eq (nth r 0) "speech-model-metrics-report") 1)
                        (smmr-metrics-score (eq (nth size 1) 29) 2))
                    (add
                        (smmr-metrics-score (eq (nth size 3) 77) 4)
                        (smmr-metrics-score (eq (nth voice 13) 3) 8)))
                (add
                    (add
                        (smmr-metrics-score (eq (nth voice 16) 3) 16)
                        (smmr-metrics-score (eq (nth capture 6) 64) 32))
                    (add
                        (smmr-metrics-score (str_eq (nth capture 10) "speech-corpus-training-intake-0003") 64)
                        (add
                            (smmr-metrics-score (eq (nth sufficiency 11) 0) 128)
                            (add
                                (smmr-metrics-score (and (eq (nth voice 20) 2)
                                                         (and (eq (nth voice 21) 2)
                                                              (and (eq (nth voice 23) 0)
                                                                   (eq (nth voice 24) 2)))) 256)
                                32256)))))))

    (speech-model-metrics-report-band))
