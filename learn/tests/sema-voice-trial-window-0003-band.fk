; preludes: learn/speech-oracle-native-backlog.fk learn/speech-next-trial-scheduler.fk learn/sema-voice-trial-window.fk learn/sema-voice-trial-window-0002.fk learn/sema-voice-trial-window-0003.fk
;
; sema-voice-trial-window-0003-band -- third scoped Sema voice trial.
;
; Verdict 32767:
;   1     report row names Sema voice trial window 0003
;   2     queued scheduler trial is trial-sema-voice-0001
;   4     challenger remains text-conditioned acoustic vocoder
;   8     scheduled backlog carries oracle 100, native 0, native WER 100
;   16    cumulative receipt names the three-window voice receipt
;   32    local oracle candidates pass three of three
;   64    native trial window passes three of three
;   128   latest candidate WER is 0 after WER-100 live miss
;   256   trial route is native Sema voice for the window
;   512   voice target quality records 165/82/64/18
;   1024  action cuts TCAV challenger for this trial window
;   2048  clean choice/cut/fail/undo/timeout controls are recorded
;   4096  local Metal oracle/device and third phrase are preserved
;   8192  scoped oracle/native rates are 100
;   16384 report marks native Form true and neural ready false

(do
    (defn svtw3-band-score (cond bit) (if cond bit 0))

    (defn sema-voice-trial-window-0003-band ()
        (do
            (let r (svtw3-report))
            (let trial (nth r 1))
            (let receipt (nth r 2))
            (let context (nth r 10))
            (let c0 (svtw3-band-score (str_eq (nth r 0) "sema-voice-trial-window-0003") 1))
            (let c1 (svtw3-band-score (str_eq (snts-id trial) "trial-sema-voice-0001") 2))
            (let c2 (svtw3-band-score (str_eq (snts-challenger trial) "text-conditioned-acoustic-vocoder") 4))
            (let c3 (svtw3-band-score (and (eq (nth r 3) 100)
                                           (and (eq (nth r 4) 0)
                                                (eq (nth r 5) 100))) 8))
            (let c4 (svtw3-band-score (str_eq (svtw-rec-kind receipt)
                                              "sema-voice-trial-window-receipt-0003") 16))
            (let c5 (svtw3-band-score (and (eq (svtw-rec-oracle-ok receipt) 3)
                                           (eq (svtw2-rec-count receipt) 3)) 32))
            (let c6 (svtw3-band-score (and (eq (svtw-rec-native-ok receipt) 3)
                                           (eq (svtw2-rec-count receipt) 3)) 64))
            (let c7 (svtw3-band-score (and (eq (nth r 5) 100)
                                           (eq (svtw-rec-wer receipt) 0)) 128))
            (let c8 (svtw3-band-score (str_eq (svtw-rec-route receipt)
                                              "native-sema-voice-trial-window") 256))
            (let c9 (svtw3-band-score (and (eq (svtw-rec-f0 receipt) 165)
                                           (and (eq (svtw-rec-warmth receipt) 82)
                                                (and (eq (svtw-rec-cadence receipt) 64)
                                                     (eq (svtw-rec-breath receipt) 18)))) 512))
            (let c10 (svtw3-band-score (str_eq (nth r 9) "cut-tcav-challenger-for-trial-window") 1024))
            (let c11 (svtw3-band-score (str_eq (svtw-rec-controls receipt)
                                               "choice-cut-fail-undo-timeout-clean") 2048))
            (let c12 (svtw3-band-score (and (str_eq (svtw-rec-oracle receipt) "whisper.cpp-large-v3-turbo-metal")
                                            (and (str_eq (svtw-rec-device receipt) "macos-arm64-m4-max")
                                                 (and (str_eq (svtw2-rec-last-truth receipt) "Speech becomes clearer.")
                                                      (eq (svtw3-rec-wav-bytes receipt) 43638)))) 4096))
            (let c13 (svtw3-band-score (and (eq (svtw2-rec-oracle-rate receipt) 100)
                                            (and (eq (svtw2-rec-native-rate receipt) 100)
                                                 (str_eq (nth r 11) "trial-window-native-not-global-live-voice"))) 8192))
            (let c14 (svtw3-band-score (and (eq (nth r 12) 1)
                                            (and (eq (nth r 13) 0)
                                                 (eq (nth context 6) 0))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (sema-voice-trial-window-0003-band))
