; preludes: learn/speech-oracle-native-backlog.fk learn/speech-next-trial-scheduler.fk learn/speech-open-asr-trial-window.fk learn/speech-open-asr-trial-window-0002.fk learn/speech-open-asr-trial-window-0003.fk
;
; speech-open-asr-trial-window-0003-band -- third scoped open-ASR window.
;
; Verdict 32767:
;   1     report names open-ASR trial window 0003
;   2     scheduler still targets live open dictation
;   4     cumulative scoped receipt count is six
;   8     local oracle accepts six of six
;   16    native segmented learner accepts six of six
;   32    native scoped rate is 100
;   64    promotion action cuts challenger for the trial window
;   128   route is native inside the scoped receipt
;   256   floor remains 50
;   512   Form native true and neural-ready false
;   1024  status keeps global authority boundary
;   2048  third window adds ar/zh rows
;   4096  meaning remains Sanskrit baseline 303
;   8192  control row is clean
;   16384 report keeps open authority false

(do
    (defn soat3-band-score (cond bit) (if cond bit 0))

    (defn speech-open-asr-trial-window-0003-band ()
        (do
            (let r (soat3-report))
            (let trial (nth r 1))
            (let receipt (nth r 2))
            (let c0 (soat3-band-score (str_eq (nth r 0) "speech-open-asr-trial-window-0003") 1))
            (let c1 (soat3-band-score (str_eq (snts-gap trial) "live-open-dictation") 2))
            (let c2 (soat3-band-score (eq (soat-receipt-count receipt) 6) 4))
            (let c3 (soat3-band-score (eq (soat-receipt-oracle-ok receipt) 6) 8))
            (let c4 (soat3-band-score (eq (soat-receipt-native-ok receipt) 6) 16))
            (let c5 (soat3-band-score (eq (soat-receipt-native-rate receipt) 100) 32))
            (let c6 (soat3-band-score (str_eq (nth r 8) "cut-challenger-for-trial-window") 64))
            (let c7 (soat3-band-score (str_eq (soat-receipt-route receipt) "native") 128))
            (let c8 (soat3-band-score (eq (soat-receipt-floor receipt) 50) 256))
            (let c9 (soat3-band-score (and (eq (soat-receipt-native-form receipt) 1)
                                           (eq (soat-receipt-neural-ready receipt) 0)) 512))
            (let c10 (soat3-band-score (str_eq (nth r 11) "trial-window-native-not-global-authority") 1024))
            (let c11 (soat3-band-score (and (str_eq (soat-receipt-src receipt) "multi")
                                            (str_eq (soat-receipt-dst receipt) "multi")) 2048))
            (let c12 (soat3-band-score (eq (soat-receipt-meaning receipt) 303) 4096))
            (let c13 (soat3-band-score (str_eq (nth r 9) "choice-cut-fail-undo-timeout-clean") 8192))
            (let c14 (soat3-band-score (eq (nth r 13) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-open-asr-trial-window-0003-band))
