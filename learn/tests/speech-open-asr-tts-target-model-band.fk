; preludes:
;   learn/speech-open-asr-tts-target-model.fk
;
; speech-open-asr-tts-target-model-band -- target open ASR/TTS parity or better.
;
; Verdict 32767:
;   1      report row names target model
;   2      open ASR target is enabled
;   4      open TTS target is enabled
;   8      beat-oracle target is enabled
;   16     target rate is 100
;   32     current open ASR native/oracle rates are separated
;   64     current Sema voice native/oracle eval lanes are 0/1 and 0/1
;   128    seven neural pairs are enabled
;   256    seven neural parameters are enabled
;   512    open ASR gap is 100
;   1024   Sema voice gap is 100
;   2048   current authority is not yet ready
;   4096   route is enabled
;   8192   status names full open ASR/TTS target
;   16384  target is above current native rates

(do
    (defn soatm-band-score (cond bit) (if cond bit 0))

    (defn speech-open-asr-tts-target-model-band ()
        (do
            (let r (soatm-report))
            (let c0 (soatm-band-score (str_eq (soatm-rec-kind r)
                                              "speech-open-asr-tts-target-model") 1))
            (let c1 (soatm-band-score (eq (soatm-rec-target-asr r) 1) 2))
            (let c2 (soatm-band-score (eq (soatm-rec-target-tts r) 1) 4))
            (let c3 (soatm-band-score (eq (soatm-rec-beat-oracle r) 1) 8))
            (let c4 (soatm-band-score (eq (soatm-rec-target-rate r) 100) 16))
            (let c5 (soatm-band-score (and (eq (soatm-rec-open-asr-native r) 0)
                                           (eq (soatm-rec-open-asr-oracle r) 100)) 32))
            (let c6 (soatm-band-score (and (eq (soatm-rec-voice-native r) 0)
                                           (and (eq (soatm-rec-voice-oracle r) 0)
                                                (and (eq (soatm-rec-voice-native-pass r) 0)
                                                     (and (eq (soatm-rec-voice-native-total r) 1)
                                                          (and (eq (soatm-rec-voice-oracle-pass r) 0)
                                                               (eq (soatm-rec-voice-oracle-total r) 1)))))) 64))
            (let c7 (soatm-band-score (eq (soatm-rec-neural-pairs r) 7) 128))
            (let c8 (soatm-band-score (eq (soatm-rec-params r) 7) 256))
            (let c9 (soatm-band-score (eq (soatm-rec-open-asr-gap r) 100) 512))
            (let c10 (soatm-band-score (eq (soatm-rec-voice-gap r) 100) 1024))
            (let c11 (soatm-band-score (eq (soatm-rec-authority-ready r) 0) 2048))
            (let c12 (soatm-band-score (eq (soatm-rec-route-enabled r) 1) 4096))
            (let c13 (soatm-band-score (str_eq (soatm-rec-status r)
                                               "target-full-open-asr-tts-parity-or-better") 8192))
            (let c14 (soatm-band-score (and (gt (soatm-rec-target-rate r)
                                               (soatm-rec-open-asr-native r))
                                            (gt (soatm-rec-target-rate r)
                                                (soatm-rec-voice-native r))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-open-asr-tts-target-model-band))
