; preludes:
;   learn/speech-corpus-adaptive-acquisition.fk
;
; speech-corpus-adaptive-acquisition-band -- batch 0004 observations change next capture recipe.
;
; Verdict 32767:
;   1      report row names adaptive acquisition
;   2      five locale decisions are present
;   4      35/50 admitted rows are carried
;   8      observed wav bytes are carried
;   16     two lanes expand
;   32     one lane retries A/B
;   64     two lanes repair
;   128    next decision targets French as the lowest-yield repair lane
;   256    French repair recipe is selected
;   512    controls are clean
;   1024   English expands
;   2048   Spanish retries
;   4096   German repairs
;   8192   observation changes the next capture recipe
;   16384  native Form true and neural false

(do
    (defn scaa-band-score (cond bit) (if cond bit 0))
    (defn scaa-rec-rows       (r) (nth r 1))
    (defn scaa-rec-decisions  (r) (nth r 2))
    (defn scaa-rec-next       (r) (nth r 3))
    (defn scaa-rec-ok         (r) (nth r 4))
    (defn scaa-rec-total      (r) (nth r 5))
    (defn scaa-rec-bytes      (r) (nth r 6))
    (defn scaa-rec-expand     (r) (nth r 7))
    (defn scaa-rec-retry      (r) (nth r 8))
    (defn scaa-rec-repair     (r) (nth r 9))
    (defn scaa-rec-rule       (r) (nth r 10))
    (defn scaa-rec-native     (r) (nth r 11))
    (defn scaa-rec-neural     (r) (nth r 12))

    (defn speech-corpus-adaptive-acquisition-band ()
        (do
            (let r (scaa-report))
            (let ds (scaa-rec-decisions r))
            (let en (nth ds 0))
            (let de (nth ds 1))
            (let es (nth ds 2))
            (let next (scaa-rec-next r))
            (let c0 (scaa-band-score (str_eq (nth r 0) "speech-corpus-adaptive-acquisition") 1))
            (let c1 (scaa-band-score (and (eq (len (scaa-rec-rows r)) 5)
                                          (eq (len ds) 5)) 2))
            (let c2 (scaa-band-score (and (eq (scaa-rec-ok r) 35)
                                          (eq (scaa-rec-total r) 50)) 4))
            (let c3 (scaa-band-score (eq (scaa-rec-bytes r) 2150026) 8))
            (let c4 (scaa-band-score (eq (scaa-rec-expand r) 2) 16))
            (let c5 (scaa-band-score (eq (scaa-rec-retry r) 1) 32))
            (let c6 (scaa-band-score (eq (scaa-rec-repair r) 2) 64))
            (let c7 (scaa-band-score (and (str_eq (scaa-dec-locale next) "fr")
                                          (eq (scaa-dec-rate next) 40)) 128))
            (let c8 (scaa-band-score (str_eq (scaa-dec-recipe next)
                                             "repair-voice-family-and-shorten-phrases") 256))
            (let c9 (scaa-band-score (str_eq (scaa-dec-ctl next)
                                             "choice-cut-fail-undo-timeout-clean") 512))
            (let c10 (scaa-band-score (str_eq (scaa-dec-action en) "expand") 1024))
            (let c11 (scaa-band-score (str_eq (scaa-dec-action es) "retry-ab") 2048))
            (let c12 (scaa-band-score (str_eq (scaa-dec-action de) "repair") 4096))
            (let c13 (scaa-band-score (str_eq (scaa-rec-rule r)
                                              "observed-batch-0004-changes-next-capture-recipe") 8192))
            (let c14 (scaa-band-score (and (eq (scaa-rec-native r) 1)
                                           (eq (scaa-rec-neural r) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-corpus-adaptive-acquisition-band))
