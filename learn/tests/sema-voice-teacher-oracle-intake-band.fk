; preludes: observe/stt-wer.fk presence/formant-vocoder.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk presence/macos-sema-voice-teacher-carrier.fk learn/speech-live-receipt-intake.fk learn/sema-voice-teacher-oracle-intake.fk
;
; sema-voice-teacher-oracle-intake-band -- real teacher oracle evidence.
;
; Verdict 32767:
;   1     report row names the Sema voice teacher oracle intake
;   2     teacher row carries the witnessed live sample id and hash
;   4     local teacher WER is 0
;   8     lowered Sema local-oracle row is valid
;   16    local oracle receipt passes the oracle bar
;   32    local oracle receipt routes through native-sema-voice sample law
;   64    speech receipt is local, consented, audio-present, and clean
;   128   oracle side is 1/1 at 100 percent
;   256   native side is still 0/1 at 0 percent
;   512   native authority success rejects the teacher row
;   1024  route explicitly says oracle-teacher-positive-native-held
;   2048  boundary refuses native Sema authority
;   4096  device and local Metal oracle are preserved
;   8192  native Form true and neural vocoder pending
;   16384 teacher carrier still marks host teacher, not native authority

(do
    (defn svtoi-band-score (cond bit) (if cond bit 0))

    (defn sema-voice-teacher-oracle-intake-band ()
        (do
            (let r (svtoi-report))
            (let teacher (svtoi-rec-teacher r))
            (let receipt (svtoi-rec-oracle-receipt r))
            (let speech (svtoi-rec-speech-row r))
            (let c0 (svtoi-band-score (str_eq (svtoi-rec-kind r) "sema-voice-teacher-oracle-intake") 1))
            (let c1 (svtoi-band-score (and (eq (mstc-row-id teacher) 983002)
                                           (eq (mstc-row-hash teacher) 497318870)) 2))
            (let c2 (svtoi-band-score (eq (mstc-row-wer teacher) 0) 4))
            (let c3 (svtoi-band-score (eq (svlor-valid? (mstc-row-svlor teacher)) 1) 8))
            (let c4 (svtoi-band-score (eq (svlor-rec-oracle-ok receipt) 1) 16))
            (let c5 (svtoi-band-score (str_eq (svlor-rec-route receipt) "native-sema-voice") 32))
            (let c6 (svtoi-band-score (and (eq (slri-valid? speech) 1)
                                           (eq (slri-audio-hash speech) 497318870)) 64))
            (let c7 (svtoi-band-score (and (eq (svtoi-rec-oracle-ok r) 1)
                                           (and (eq (svtoi-rec-oracle-total r) 1)
                                                (eq (svtoi-rec-oracle-rate r) 100))) 128))
            (let c8 (svtoi-band-score (and (eq (svtoi-rec-native-ok r) 0)
                                           (and (eq (svtoi-rec-native-total r) 1)
                                                (eq (svtoi-rec-native-rate r) 0))) 256))
            (let c9 (svtoi-band-score (eq (svtoi-rec-native-success r) 0) 512))
            (let c10 (svtoi-band-score (str_eq (svtoi-rec-route r) "oracle-teacher-positive-native-held") 1024))
            (let c11 (svtoi-band-score (str_eq (svtoi-rec-boundary r)
                                               "host-teacher-training-evidence-not-native-sema-authority") 2048))
            (let c12 (svtoi-band-score (and (str_eq (svtoi-rec-device r) "macos-arm64-m4-max")
                                            (str_eq (svtoi-rec-oracle r) "whisper.cpp-large-v3-turbo-metal")) 4096))
            (let c13 (svtoi-band-score (and (eq (svtoi-rec-native-form r) 1)
                                            (eq (svtoi-rec-neural-ready r) 0)) 8192))
            (let c14 (svtoi-band-score (str_eq (mstc-row-authority teacher)
                                               "host-teacher-not-native-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (sema-voice-teacher-oracle-intake-band))
