; preludes: observe/stt-wer.fk learn/speech-loopback-promotion.fk form/form-stdlib/observed-auto-learning.fk learn/open-dictation-transcript-learning.fk
;
; open-dictation-transcript-learning-band -- free transcript receipts.
;
; Verdict 16383:
;   1     oracle-only row is valid local open dictation
;   2     oracle transcript reaches the side-channel truth
;   4     oracle-only row does not claim native success
;   8     native candidate can succeed when it supplies the same free text
;   16    oracle-only window stays on oracle
;   32    clean native transcript window can route native
;   64    fail/undo/timeout create control debt
;   128   observed mode is online reversible A/B
;   256   control action honors fail/undo/timeout
;   512   summary preserves count and transcript scores
;   1024  promotion sample carries oracle credit
;   2048  prompt-free transcript keeps locale and sample id, not a prompt id
;   4096  summary kind names open dictation
;   8192  token WER sees the transcript as words, not a prompt id

(do
    (defn odtl-test-text () "Open speech flows.")
    (defn odtl-test-oracle-row ()
        (odtl-row 7001 "en" (odtl-test-text) (odtl-test-text) ""
                  (odtl-audio 818181 16000 1) 1 (odtl-native 0 0 1200) 1
                  (odtl-control-row 1 0 0 0 0)))
    (defn odtl-test-native-row ()
        (odtl-row 7002 "en" (odtl-test-text) (odtl-test-text) (odtl-test-text)
                  (odtl-audio 828282 16000 1) 1 (odtl-native 1 92 1200) 1
                  (odtl-control-row 1 0 0 0 0)))
    (defn odtl-test-fail-row ()
        (odtl-row 7003 "en" (odtl-test-text) (odtl-test-text) (odtl-test-text)
                  (odtl-audio 838383 16000 1) 1 (odtl-native 1 92 1200) 1
                  (odtl-control-row 1 0 1 0 0)))
    (defn odtl-test-timeout-row ()
        (odtl-row 7004 "en" (odtl-test-text) (odtl-test-text) (odtl-test-text)
                  (odtl-audio 848484 16000 1) 1 (odtl-native 1 92 1200) 1
                  (odtl-control-row 1 0 0 1 0)))
    (defn odtl-test-undo-row ()
        (odtl-row 7005 "en" (odtl-test-text) (odtl-test-text) (odtl-test-text)
                  (odtl-audio 858585 16000 1) 1 (odtl-native 1 92 1200) 1
                  (odtl-control-row 1 0 0 0 1)))

    (defn odtl-band-score (cond bit) (if cond bit 0))

    (defn open-dictation-transcript-learning-band ()
        (do
            (let oracle-row (odtl-test-oracle-row))
            (let native-row (odtl-test-native-row))
            (let fail-row (odtl-test-fail-row))
            (let timeout-row (odtl-test-timeout-row))
            (let undo-row (odtl-test-undo-row))
            (let oracle-window (list oracle-row oracle-row oracle-row oracle-row))
            (let native-window (list native-row native-row native-row native-row))
            (let native-summary (odtl-summary native-window 25 80 2000 4 0 0 3))
            (let oracle-summary (odtl-summary oracle-window 25 80 2000 4 0 0 3))
            (let sample (odtl-to-promotion-sample oracle-row 25 80 2000))
            (let c0 (odtl-band-score (eq (odtl-valid? oracle-row) 1) 1))
            (let c1 (odtl-band-score (and (eq (odtl-oracle-success? oracle-row 25) 1)
                                          (eq (odtl-oracle-wer oracle-row) 0)) 2))
            (let c2 (odtl-band-score (eq (odtl-native-success? oracle-row 25 80 2000) 0) 4))
            (let c3 (odtl-band-score (eq (odtl-native-success? native-row 25 80 2000) 1) 8))
            (let c4 (odtl-band-score (str_eq (odtl-summary-route oracle-summary) "oracle") 16))
            (let c5 (odtl-band-score (str_eq (odtl-summary-route native-summary) "native") 32))
            (let c6 (odtl-band-score (and (eq (slp-control-debt (odtl-to-promotion-sample fail-row 25 80 2000)) 1)
                                          (and (eq (slp-control-debt (odtl-to-promotion-sample timeout-row 25 80 2000)) 1)
                                               (eq (slp-control-debt (odtl-to-promotion-sample undo-row 25 80 2000)) 1))) 64))
            (let c7 (odtl-band-score (str_eq (odtl-mode oracle-row 1) "online-reversible-ab") 128))
            (let c8 (odtl-band-score (and (str_eq (odtl-control-action fail-row) "fail-stop")
                                          (and (str_eq (odtl-control-action undo-row) "undo-last-change")
                                               (str_eq (odtl-control-action timeout-row) "timeout-as-nothing"))) 256))
            (let c9 (odtl-band-score (and (eq (odtl-summary-count native-summary) 4)
                                          (and (eq (odtl-summary-native native-summary) 4)
                                               (eq (odtl-summary-oracle native-summary) 4))) 512))
            (let c10 (odtl-band-score (and (eq (slp-oracle-success sample) 1)
                                           (eq (slp-native-success sample) 0)) 1024))
            (let c11 (odtl-band-score (and (eq (odtl-sample-id oracle-row) 7001)
                                           (str_eq (odtl-locale oracle-row) "en")) 2048))
            (let c12 (odtl-band-score (str_eq (odtl-summary-kind native-summary) "open-dictation-transcript-summary") 4096))
            (let c13 (odtl-band-score (and (eq (len (odtl-truth-tokens oracle-row)) 3)
                                           (eq (sw-wer (odtl-oracle-tokens oracle-row) (odtl-truth-tokens oracle-row)) 0)) 8192))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 c13)))))

    (open-dictation-transcript-learning-band))
