; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk learn/speech-native-neural-pair-window-0018.fk
;
; speech-native-neural-pair-window-0018-band -- eighteenth non-zero neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0018
;   2      pair is de<->id
;   4      Sanskrit baseline meaning 301 is used
;   8      cumulative trained pairs are eighteen
;   16     cumulative directed routes are thirty-six
;   32     eighteen epochs and eighteen parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   oracle/native/neural flags are true
;   2048   open authority is false
;   4096   after rate clears floor
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0018, not open authority

(do
    (defn snpw18-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0018-band ()
        (do
            (let r (snpw18-receipt))
            (let c0 (snpw18-band-score (str_eq (snpw18-rec-kind r)
                                               "speech-native-neural-pair-window-0018") 1))
            (let c1 (snpw18-band-score (and (str_eq (snpw18-rec-a r) "de")
                                            (str_eq (snpw18-rec-b r) "id")) 2))
            (let c2 (snpw18-band-score (eq (snpw18-rec-meaning r) 301) 4))
            (let c3 (snpw18-band-score (eq (snpw18-rec-cumulative-pairs r) 18) 8))
            (let c4 (snpw18-band-score (eq (snpw18-rec-cumulative-directed r) 36) 16))
            (let c5 (snpw18-band-score (and (eq (snpw18-rec-epochs r) 18)
                                            (eq (snpw18-rec-params r) 18)) 32))
            (let c6 (snpw18-band-score (and (eq (snpw18-rec-before-rate r) 0)
                                            (eq (snpw18-rec-after-rate r) 100)) 64))
            (let c7 (snpw18-band-score (eq (snpw18-rec-shifted r) 1) 128))
            (let c8 (snpw18-band-score (and (eq (snpw18-rec-form-nl r) 100)
                                            (eq (snpw18-rec-form-audio r) 100)) 256))
            (let c9 (snpw18-band-score (and (eq (snpw18-rec-before-loss r) 1)
                                            (eq (snpw18-rec-after-loss r) 0)) 512))
            (let c10 (snpw18-band-score (and (eq (snpw18-rec-oracle r) 1)
                                             (and (eq (snpw18-rec-native-form r) 1)
                                                  (eq (snpw18-rec-neural r) 1))) 1024))
            (let c11 (snpw18-band-score (eq (snpw18-rec-open-authority r) 0) 2048))
            (let c12 (snpw18-band-score (ge (snpw18-rec-after-rate r) 50) 4096))
            (let c13 (snpw18-band-score (and (eq (snpw18-rec-pair-increment r) 1)
                                             (eq (snpw18-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw18-band-score (str_eq (snpw18-rec-status r)
                                                "native-neural-micro-pair-0018-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0018-band))
