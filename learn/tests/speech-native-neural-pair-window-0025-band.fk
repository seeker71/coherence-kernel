; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk
;   learn/speech-native-neural-pair-window-0025.fk
;
; speech-native-neural-pair-window-0025-band -- twenty-fifth neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0025
;   2      pair is fr<->id
;   4      Sanskrit baseline meaning 303 is used
;   8      cumulative trained pairs are twenty-five
;   16     cumulative directed routes are fifty
;   32     twenty-five epochs and twenty-five parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   two local Metal oracle rows pass the pair window
;   2048   open authority is false
;   4096   observed local wav bytes are carried
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0025, not open authority

(do
    (defn snpw25-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0025-band ()
        (do
            (let r (snpw25-receipt))
            (let c0 (snpw25-band-score (str_eq (snpw25-rec-kind r)
                                               "speech-native-neural-pair-window-0025") 1))
            (let c1 (snpw25-band-score (and (str_eq (snpw25-rec-a r) "fr")
                                            (str_eq (snpw25-rec-b r) "id")) 2))
            (let c2 (snpw25-band-score (eq (snpw25-rec-meaning r) 303) 4))
            (let c3 (snpw25-band-score (eq (snpw25-rec-cumulative-pairs r) 25) 8))
            (let c4 (snpw25-band-score (eq (snpw25-rec-cumulative-directed r) 50) 16))
            (let c5 (snpw25-band-score (and (eq (snpw25-rec-epochs r) 25)
                                            (eq (snpw25-rec-params r) 25)) 32))
            (let c6 (snpw25-band-score (and (eq (snpw25-rec-before-rate r) 0)
                                            (eq (snpw25-rec-after-rate r) 100)) 64))
            (let c7 (snpw25-band-score (eq (snpw25-rec-shifted r) 1) 128))
            (let c8 (snpw25-band-score (and (eq (snpw25-rec-form-nl r) 100)
                                            (eq (snpw25-rec-form-audio r) 100)) 256))
            (let c9 (snpw25-band-score (and (eq (snpw25-rec-before-loss r) 1)
                                            (eq (snpw25-rec-after-loss r) 0)) 512))
            (let c10 (snpw25-band-score (and (eq (snpw25-rec-oracle-ok r) 2)
                                             (eq (snpw25-rec-oracle-total r) 2)) 1024))
            (let c11 (snpw25-band-score (eq (snpw25-rec-open-authority r) 0) 2048))
            (let c12 (snpw25-band-score (eq (snpw25-rec-oracle-bytes r) 50788) 4096))
            (let c13 (snpw25-band-score (and (eq (snpw25-rec-pair-increment r) 1)
                                             (eq (snpw25-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw25-band-score (str_eq (snpw25-rec-status r)
                                                "native-neural-micro-pair-0025-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0025-band))
