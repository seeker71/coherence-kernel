; voice-clone-consent-gate-band.fk — fkwu-witnessed band for
; learn/voice-clone-consent-gate.fk.
;
; Bitmask verdict:
;   1   consent kind 'self' passes the gate
;   2   consent kind 'written-permission' passes the gate
;   4   consent kind 'none' is REFUSED with the law quoted back
;   8   fully proofread chunks are admitted
;   16  one unproofread chunk refuses the WHOLE run and counts itself
;   32  both gates passed -> admission OPEN
;   64  a refused gate -> admission CLOSED (the refusal names itself)
;
; Full verdict: 127
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/model-fit.fk learn/voice-clone-consent-gate.fk
(do
  (defn vgb-bit (ok bit) (if (eq ok 1) bit 0))
  (do
    (let good (list (list "c1" 1) (list "c2" 1)))
    (let bad  (list (list "c1" 1) (list "c2" 0)))
    (add (vgb-bit (vcg-consent-ok? (vcg-consent "sema" "self")) 1)
      (add (vgb-bit (vcg-consent-ok? (vcg-consent "friend" "written-permission")) 2)
        (add (vgb-bit (if (ge (str_find (vcg-consent-verdict (vcg-consent "x" "none"))
                                        "REFUSED" 0) 0) 1 0) 4)
          (add (vgb-bit (if (ge (str_find (vcg-proofread-verdict good) "admitted" 0) 0) 1 0) 8)
            (add (vgb-bit (if (ge (str_find (vcg-proofread-verdict bad) "1 chunk" 0) 0) 1 0) 16)
              (add (vgb-bit (if (ge (str_find (vcg-admit (vcg-consent "sema" "self") good)
                                              "OPEN" 0) 0) 1 0) 32)
                   (vgb-bit (if (ge (str_find (vcg-admit (vcg-consent "x" "none") good)
                                              "CLOSED" 0) 0) 1 0) 64)))))))))
