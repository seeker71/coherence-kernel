; preludes:
;   learn/source-window-audio2audio-authority.fk
;
; source-window-audio2audio-authority-band -- source ASR window composes with target acoustic authority.
;
; Verdict 32767:
;   1     receipt kind names source-window audio2audio authority
;   2     source segmented ASR window is ready
;   4     target metal audio2audio acoustic route is ready
;   8     combined route is native source-window audio2audio acoustic
;   16    source sample/pair counts are carried
;   32    source native score and rate are carried
;   64    source ready pair count is carried
;   128   acoustic sweep rows and pairs are carried
;   256   acoustic pass and ready-pair counts are carried
;   512   live Metal anchors are carried
;   1024  local oracle and device are carried
;   2048  native Form and oracle Metal flags are present
;   4096  neural Metal remains pending
;   8192  missing source pairs keep route guided
;   16384 missing target authority keeps route guided

(do
    (defn swa2a-band-score (cond bit) (if cond bit 0))
    (defn source-window-audio2audio-authority-band ()
        (do
            (let rec (swa2a-live-receipt))
            (let missing-source
                (swa2a-receipt
                    6 2 6 0 6 100 2 0 1 1 1 0
                    10 5 10 5 7 7 7 1 1 1 1 1
                    "whisper.cpp-large-v3-turbo-metal"
                    "macos-arm64-m4-max"))
            (let missing-target
                (swa2a-receipt
                    6 3 6 0 6 100 3 0 1 1 1 0
                    10 5 10 5 7 7 7 1 0 1 1 1
                    "whisper.cpp-large-v3-turbo-metal"
                    "macos-arm64-m4-max"))
            (let c0 (swa2a-band-score (str_eq (swa2a-rec-kind rec)
                                              "source-window-audio2audio-authority") 1))
            (let c1 (swa2a-band-score (eq (swa2a-rec-source-ready rec) 1) 2))
            (let c2 (swa2a-band-score (eq (swa2a-rec-target-ready rec) 1) 4))
            (let c3 (swa2a-band-score (str_eq (swa2a-rec-route rec)
                                              "native-source-window-audio2audio-acoustic") 8))
            (let c4 (swa2a-band-score (and (eq (nth rec 4) 6)
                                           (eq (nth rec 5) 3)) 16))
            (let c5 (swa2a-band-score (and (eq (nth rec 6) 6)
                                           (eq (nth rec 7) 100)) 32))
            (let c6 (swa2a-band-score (eq (nth rec 8) 3) 64))
            (let c7 (swa2a-band-score (and (eq (nth rec 9) 10)
                                           (eq (nth rec 10) 5)) 128))
            (let c8 (swa2a-band-score (and (eq (nth rec 11) 10)
                                           (eq (nth rec 12) 5)) 256))
            (let c9 (swa2a-band-score (and (eq (nth rec 13) 7)
                                           (and (eq (nth rec 14) 7)
                                                (eq (nth rec 15) 7))) 512))
            (let c10 (swa2a-band-score
                        (and (str_eq (nth rec 16) "whisper.cpp-large-v3-turbo-metal")
                             (str_eq (nth rec 17) "macos-arm64-m4-max")) 1024))
            (let c11 (swa2a-band-score
                        (and (eq (swa2a-rec-native-form rec) 1)
                             (eq (swa2a-rec-oracle-metal rec) 1)) 2048))
            (let c12 (swa2a-band-score (eq (swa2a-rec-neural-metal rec) 0) 4096))
            (let c13 (swa2a-band-score (str_eq (swa2a-rec-route missing-source)
                                               "oracle-guide") 8192))
            (let c14 (swa2a-band-score (str_eq (swa2a-rec-route missing-target)
                                               "source-native-target-guide") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (source-window-audio2audio-authority-band))
