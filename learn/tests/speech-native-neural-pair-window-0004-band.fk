; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk learn/speech-native-neural-pair-window-0004.fk
;
; speech-native-neural-pair-window-0004-band -- fourth non-zero neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0004
;   2      pair is en<->zh
;   4      Sanskrit baseline meaning 303 is used
;   8      cumulative trained pairs are four
;   16     cumulative directed routes are eight
;   32     four epochs and four parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   oracle/native/neural flags are true
;   2048   open authority is false
;   4096   after rate clears floor
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0004, not open authority

(do
    (defn snpw4-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0004-band ()
        (do
            (let r (snpw4-receipt))
            (let c0 (snpw4-band-score (str_eq (snpw4-rec-kind r)
                                              "speech-native-neural-pair-window-0004") 1))
            (let c1 (snpw4-band-score (and (str_eq (snpw4-rec-a r) "en")
                                           (str_eq (snpw4-rec-b r) "zh")) 2))
            (let c2 (snpw4-band-score (eq (snpw4-rec-meaning r) 303) 4))
            (let c3 (snpw4-band-score (eq (snpw4-rec-cumulative-pairs r) 4) 8))
            (let c4 (snpw4-band-score (eq (snpw4-rec-cumulative-directed r) 8) 16))
            (let c5 (snpw4-band-score (and (eq (snpw4-rec-epochs r) 4)
                                           (eq (snpw4-rec-params r) 4)) 32))
            (let c6 (snpw4-band-score (and (eq (snpw4-rec-before-rate r) 0)
                                           (eq (snpw4-rec-after-rate r) 100)) 64))
            (let c7 (snpw4-band-score (eq (snpw4-rec-shifted r) 1) 128))
            (let c8 (snpw4-band-score (and (eq (snpw4-rec-form-nl r) 100)
                                           (eq (snpw4-rec-form-audio r) 100)) 256))
            (let c9 (snpw4-band-score (and (eq (snpw4-rec-before-loss r) 1)
                                           (eq (snpw4-rec-after-loss r) 0)) 512))
            (let c10 (snpw4-band-score (and (eq (snpw4-rec-oracle r) 1)
                                            (and (eq (snpw4-rec-native-form r) 1)
                                                 (eq (snpw4-rec-neural r) 1))) 1024))
            (let c11 (snpw4-band-score (eq (snpw4-rec-open-authority r) 0) 2048))
            (let c12 (snpw4-band-score (ge (snpw4-rec-after-rate r) 50) 4096))
            (let c13 (snpw4-band-score (and (eq (snpw4-rec-pair-increment r) 1)
                                            (eq (snpw4-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw4-band-score (str_eq (snpw4-rec-status r)
                                               "native-neural-micro-pair-0004-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0004-band))
