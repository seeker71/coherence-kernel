; preludes:
;   observe/stt-wer.fk
;   observe/wav-sense.fk
;   learn/macos-sema-teacher-acoustic-learning.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk
;   learn/speech-audio-nl2nl-multikey-bridge.fk
;
; speech-audio-nl2nl-multikey-bridge-band -- multi-key audio bridge.
;
; Verdict 8191:
;   1     receipt names the multi-key bridge
;   2     six reciprocal routes are present
;   4     source audio oracle accepts all six
;   8     target audio oracle accepts all six
;   16    native neutral routing emits all six target texts
;   32    wav bytes are carried
;   64    status names oracle-guided multi-key bridge, not native vocoder
;   128   two neutral keys are present
;   256   native Form route true
;   512   local oracle true
;   1024  native vocoder false
;   2048  neural false
;   4096  data sufficiency still false

(do
    (defn sanm-band-row (id key src dst src-ok dst-ok native-ok bytes)
        (list "speech-audio-nl2nl-multikey-row" id key src dst "" 0 "" "" 0 0
              src-ok dst-ok native-ok bytes))
    (defn sanm-band-rows ()
        (list
            (sanm-band-row 1 "nav.search" "de" "es" 1 1 1 56882)
            (sanm-band-row 2 "nav.search" "es" "de" 1 1 1 56882)
            (sanm-band-row 3 "nav.vision" "en" "fr" 1 1 1 47796)
            (sanm-band-row 4 "nav.vision" "fr" "en" 1 1 1 47796)
            (sanm-band-row 5 "nav.vision" "id" "pt-br" 1 1 1 47914)
            (sanm-band-row 6 "nav.vision" "pt-br" "id" 1 1 1 47862)))

    (defn speech-audio-nl2nl-multikey-bridge-band ()
        (do
            (let r (sanm-receipt-from (sanm-band-rows)))
            (add
                (add
                    (add (if (str_eq (sanm-rec-kind r) (sanm-kind)) 1 0)
                         (if (eq (sanm-rec-count r) 6) 2 0))
                    (add (if (eq (sanm-rec-src-ok r) 6) 4 0)
                         (if (eq (sanm-rec-dst-ok r) 6) 8 0)))
                (add
                    (add (if (eq (sanm-rec-native-ok r) 6) 16 0)
                         (if (ge (sanm-rec-bytes r) 300000) 32 0))
                    (add
                        (add (if (str_eq (sanm-rec-status r)
                                         "oracle-guided-multikey-audio-nl2nl-audio-bridge-not-native-vocoder") 64 0)
                             (if (eq (sanm-rec-keys r) 2) 128 0))
                        (add
                            (add (if (eq (sanm-rec-native r) 1) 256 0)
                                 (if (eq (sanm-rec-oracle r) 1) 512 0))
                            (add
                                (add (if (eq (sanm-rec-vocoder r) 0) 1024 0)
                                     (if (eq (sanm-rec-neural r) 0) 2048 0))
                                (if (eq (slds-sufficient (slds-current)) 0) 4096 0))))))))

    (speech-audio-nl2nl-multikey-bridge-band))
