; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk
;   learn/speech-native-neural-pair-window-0002.fk
;
; speech-native-neural-pair-window-0002-band -- second non-zero neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0002
;   2      pair is en<->pt-br
;   4      Sanskrit baseline meaning 301 is used
;   8      cumulative trained pairs are two
;   16     cumulative directed routes are four
;   32     two epochs and two parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   oracle/native/neural flags are true
;   2048   open authority is false
;   4096   after rate clears floor
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0002, not open authority

(do
    (defn snpw2-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0002-band ()
        (do
            (let r (snpw2-receipt))
            (let c0 (snpw2-band-score (str_eq (snpw2-rec-kind r)
                                              "speech-native-neural-pair-window-0002") 1))
            (let c1 (snpw2-band-score (and (str_eq (snpw2-rec-a r) "en")
                                           (str_eq (snpw2-rec-b r) "pt-br")) 2))
            (let c2 (snpw2-band-score (eq (snpw2-rec-meaning r) 301) 4))
            (let c3 (snpw2-band-score (eq (snpw2-rec-cumulative-pairs r) 2) 8))
            (let c4 (snpw2-band-score (eq (snpw2-rec-cumulative-directed r) 4) 16))
            (let c5 (snpw2-band-score (and (eq (snpw2-rec-epochs r) 2)
                                           (eq (snpw2-rec-params r) 2)) 32))
            (let c6 (snpw2-band-score (and (eq (snpw2-rec-before-rate r) 0)
                                           (eq (snpw2-rec-after-rate r) 100)) 64))
            (let c7 (snpw2-band-score (eq (snpw2-rec-shifted r) 1) 128))
            (let c8 (snpw2-band-score (and (eq (snpw2-rec-form-nl r) 100)
                                           (eq (snpw2-rec-form-audio r) 100)) 256))
            (let c9 (snpw2-band-score (and (eq (snpw2-rec-before-loss r) 1)
                                           (eq (snpw2-rec-after-loss r) 0)) 512))
            (let c10 (snpw2-band-score (and (eq (snpw2-rec-oracle r) 1)
                                            (and (eq (snpw2-rec-native-form r) 1)
                                                 (eq (snpw2-rec-neural r) 1))) 1024))
            (let c11 (snpw2-band-score (eq (snpw2-rec-open-authority r) 0) 2048))
            (let c12 (snpw2-band-score (ge (snpw2-rec-after-rate r) 50) 4096))
            (let c13 (snpw2-band-score (and (eq (snpw2-rec-pair-increment r) 1)
                                            (eq (snpw2-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw2-band-score (str_eq (snpw2-rec-status r)
                                               "native-neural-micro-pair-0002-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0002-band))
