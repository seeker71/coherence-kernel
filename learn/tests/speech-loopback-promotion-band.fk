; preludes: observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk presence/native-speech-loopback.fk learn/speech-loopback-promotion.fk
;
; speech-loopback-promotion-band -- route shifts from oracle to native by receipts.
;
; Verdict 2047:
;   1    loopback receipt turns into a native-success sample
;   2    native score counts clean native successes
;   4    oracle score counts clean oracle successes
;   8    native reaches oracle over a clean window
;   16   clean long window promotes native
;   32   short window does not promote
;   64   failed sample creates control debt
;   128  failed window routes oracle
;   256  native regression routes oracle
;   512  receipt records native authority
;   1024 receipt records oracle fallback after regression

(do
    (defn slp-band-score (cond bit) (if cond bit 0))
    (defn slp-band-a-frames () (list (fv-frame 1 4 2 10 100 200 0)))
    (defn slp-band-b-frames () (list (fv-frame 2 6 3 20 200 300 0)))
    (defn slp-band-a-words () (list "we" "are"))
    (defn slp-band-b-words () (list "go" "home"))
    (defn slp-band-candidates ()
        (list
            (pid-candidate 1 (slp-band-a-words) (fv-fingerprint (slp-band-a-frames)))
            (pid-candidate 2 (slp-band-b-words) (fv-fingerprint (slp-band-b-frames)))))
    (defn slp-band-a-receipt ()
        (nsl-receipt 1 (slp-band-a-words) (slp-band-a-frames) (slp-band-candidates) 0 80 10))
    (defn slp-band-good-sample ()
        (slp-sample-from-loopback (slp-band-a-receipt) 1 0 0 0))
    (defn slp-band-fail-sample ()
        (slp-sample 0 1 1 0 0))
    (defn slp-band-bad-sample ()
        (slp-sample 0 1 0 0 0))
    (defn slp-band-clean-window ()
        (list (slp-band-good-sample) (slp-band-good-sample) (slp-band-good-sample) (slp-band-good-sample)))
    (defn slp-band-short-window ()
        (list (slp-band-good-sample) (slp-band-good-sample)))
    (defn slp-band-failed-window ()
        (list (slp-band-good-sample) (slp-band-good-sample) (slp-band-fail-sample) (slp-band-good-sample)))
    (defn slp-band-regress-window ()
        (list (slp-band-good-sample) (slp-band-bad-sample) (slp-band-bad-sample) (slp-band-bad-sample)))

    (defn speech-loopback-promotion-band ()
        (do
            (let good (slp-band-good-sample))
            (let clean (slp-band-clean-window))
            (let short (slp-band-short-window))
            (let failed (slp-band-failed-window))
            (let regress (slp-band-regress-window))
            (let native-rec (slp-receipt clean 4 0 0 3))
            (let oracle-rec (slp-receipt regress 4 0 0 3))
            (let c0 (slp-band-score (eq (slp-native-success good) 1) 1))
            (let c1 (slp-band-score (eq (slp-native-score clean) 4) 2))
            (let c2 (slp-band-score (eq (slp-oracle-score clean) 4) 4))
            (let c3 (slp-band-score (eq (slp-reaches? clean 0) 1) 8))
            (let c4 (slp-band-score (str_eq (slp-route clean 4 0 0 3) "native") 16))
            (let c5 (slp-band-score (str_eq (slp-route short 4 0 0 3) "oracle") 32))
            (let c6 (slp-band-score (eq (slp-control-debt-score failed) 1) 64))
            (let c7 (slp-band-score (str_eq (slp-route failed 4 0 0 3) "oracle") 128))
            (let c8 (slp-band-score (str_eq (slp-route regress 4 0 0 3) "oracle") 256))
            (let c9 (slp-band-score (str_eq (slp-rec-route native-rec) "native") 512))
            (let c10 (slp-band-score (str_eq (slp-rec-route oracle-rec) "oracle") 1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add c8 (add c9 c10)))))
    (speech-loopback-promotion-band))
