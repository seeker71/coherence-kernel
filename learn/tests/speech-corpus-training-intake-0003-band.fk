; preludes:
;   learn/speech-corpus-training-intake-0001.fk
;   learn/speech-corpus-training-intake-0002.fk
;   learn/speech-corpus-training-intake-0003.fk
;
; speech-corpus-training-intake-0003-band -- screened batch 0003 enters training.
;
; Verdict 32767:
;   1     report names the third corpus training intake
;   2     thirty-four screened captured rows are selected
;   4     all thirty-four rows are local-oracle accepted
;   8     all thirty-four rows are admitted for training
;   16    batch intake rate is 100
;   32    cumulative training rows move to 64
;   64    cumulative intake rate remains 100
;   128   six locales are represented
;   256   thirty-four audio hashes are present
;   512   max WER is at the admitted floor, 25
;   1024  batch and cumulative bytes are carried
;   2048  data sufficient floor remains 12000 and false
;   4096  route names native prototype training intake
;   8192  native Form true and neural false
;   16384 global authority remains false

(do
    (defn scti3-band-score (cond bit) (if cond bit 0))

    (defn speech-corpus-training-intake-0003-band ()
        (do
            (let r (scti3-report))
            (let c0 (scti3-band-score (str_eq (scti3-rec-kind r)
                                              "speech-corpus-training-intake-0003") 1))
            (let c1 (scti3-band-score (eq (scti3-rec-count r) 34) 2))
            (let c2 (scti3-band-score (eq (scti3-rec-oracle-ok r) 34) 4))
            (let c3 (scti3-band-score (eq (scti3-rec-admitted r) 34) 8))
            (let c4 (scti3-band-score (eq (scti3-rec-rate r) 100) 16))
            (let c5 (scti3-band-score (eq (scti3-rec-total r) 64) 32))
            (let c6 (scti3-band-score (eq (scti3-rec-total-rate r) 100) 64))
            (let c7 (scti3-band-score (eq (scti3-rec-locales r) 6) 128))
            (let c8 (scti3-band-score (eq (scti3-rec-hash-count r) 34) 256))
            (let c9 (scti3-band-score (eq (scti3-rec-max-wer r) 25) 512))
            (let c10 (scti3-band-score (and (eq (scti3-rec-bytes r) 1272388)
                                            (eq (scti3-rec-total-bytes r) 2065622)) 1024))
            (let c11 (scti3-band-score (and (eq (scti3-rec-floor r) 12000)
                                            (eq (scti3-rec-sufficient r) 0)) 2048))
            (let c12 (scti3-band-score (and (str_eq (scti3-rec-route r)
                                                     "native-prototype-training-intake")
                                            (str_eq (scti3-rec-status r)
                                                    "screened-corpus-training-intake-expanded-not-data-sufficient")) 4096))
            (let c13 (scti3-band-score (and (eq (scti3-rec-native-form r) 1)
                                            (eq (scti3-rec-neural r) 0)) 8192))
            (let c14 (scti3-band-score (eq (scti3-rec-authority r) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-corpus-training-intake-0003-band))
