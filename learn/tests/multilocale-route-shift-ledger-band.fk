; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/multilocale-route-shift-ledger.fk
;
; multilocale-route-shift-ledger-band -- per-pair shift witness.
;
; Verdict 4095:
;   1    ledger records five reciprocal pairs
;   2    all five pairs shift from oracle-guide to native
;   4    all five pairs route native after learning
;   8    all five pairs routed oracle-guide before learning
;   16   en<->de row preserves mixed before evidence, not a flattened claim
;   32   zh<->ar row routes native after learning
;   64   receipt route is native
;   128  one-way evidence still routes oracle-guide
;   256  receipt records Metal oracle plus Form-native learner
;   512  native neural Metal remains pending, not faked
;   1024 receipt preserves the requested floor
;   2048 zh<->ar row has full after NL/audio rates

(do
    (defn mrsl-band-score (cond bit) (if cond bit 0))
    (defn mrsl-band-row (meaning) (slb-line-by-meaning meaning))
    (defn mrsl-band-tokens (meaning locale) (slb-tokens (mrsl-band-row meaning) locale))
    (defn mrsl-band-meta () (mlap-meta 88 91 24 63))

    (defn mrsl-band-feat (meaning)
        (if (eq meaning 301) (list 1000 10 1 1)
            (if (eq meaning 302) (list 2000 20 2 2)
                (if (eq meaning 303) (list 3000 30 3 3)
                    (list 4000 40 4 4)))))

    (defn mrsl-band-nl (meaning src dst)
        (mlap-nl-sample meaning src dst
                         (mrsl-band-tokens meaning src)
                         (mrsl-band-tokens meaning dst)
                         meaning
                         0 0 0))

    (defn mrsl-band-audio (meaning src dst)
        (mlap-audio-sample meaning src dst
                            (mrsl-band-tokens meaning dst)
                            (mrsl-band-tokens meaning dst)
                            (mrsl-band-feat meaning)
                            (mrsl-band-meta)
                            0 0 0))

    (defn mrsl-band-nl-samples ()
        (list
            (mrsl-band-nl 301 "en" "de")
            (mrsl-band-nl 301 "de" "en")
            (mrsl-band-nl 302 "en" "es")
            (mrsl-band-nl 302 "es" "en")
            (mrsl-band-nl 302 "zh" "ar")
            (mrsl-band-nl 302 "ar" "zh")
            (mrsl-band-nl 303 "fr" "id")
            (mrsl-band-nl 303 "id" "fr")
            (mrsl-band-nl 304 "sa" "la")
            (mrsl-band-nl 304 "la" "sa")))

    (defn mrsl-band-audio-samples ()
        (list
            (mrsl-band-audio 301 "en" "de")
            (mrsl-band-audio 301 "de" "en")
            (mrsl-band-audio 302 "en" "es")
            (mrsl-band-audio 302 "es" "en")
            (mrsl-band-audio 302 "zh" "ar")
            (mrsl-band-audio 302 "ar" "zh")
            (mrsl-band-audio 303 "fr" "id")
            (mrsl-band-audio 303 "id" "fr")
            (mrsl-band-audio 304 "sa" "la")
            (mrsl-band-audio 304 "la" "sa")))

    (defn mrsl-band-pairs ()
        (list
            (mlap-pair "en" "de")
            (mlap-pair "en" "es")
            (mlap-pair "zh" "ar")
            (mlap-pair "fr" "id")
            (mlap-pair "sa" "la")))

    (defn mrsl-band-before-rows () (list (slb-line-by-meaning 301)))
    (defn mrsl-band-before-audio-candidates ()
        (list (pid-candidate 999 (list "not" "ready") (list 9 9 9 9))))

    (defn mrsl-band-one-way-nl ()
        (list (mrsl-band-nl 301 "en" "de")))
    (defn mrsl-band-one-way-audio ()
        (list (mrsl-band-audio 301 "en" "de")))

    (defn multilocale-route-shift-ledger-band ()
        (do
            (let nl (mrsl-band-nl-samples))
            (let audio (mrsl-band-audio-samples))
            (let pairs (mrsl-band-pairs))
            (let before-rows (mrsl-band-before-rows))
            (let before-audio (mrsl-band-before-audio-candidates))
            (let after-rows (mlap-nl-trained-rows nl before-rows))
            (let after-audio (mlap-audio-trained-candidates audio before-audio 25))
            (let rows (mrsl-ledger pairs nl audio before-rows after-rows before-audio after-audio 25 50))
            (let rec (mrsl-receipt rows 50 "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"))
            (let ende (mrsl-find-row rows "en" "de"))
            (let zhar (mrsl-find-row rows "zh" "ar"))
            (let one-way-route
                (mrsl-pair-route (mrsl-band-one-way-nl)
                                 (mrsl-band-one-way-audio)
                                 after-rows after-audio 25 50
                                 (mlap-pair "en" "de")))
            (let c0 (mrsl-band-score (eq (len rows) 5) 1))
            (let c1 (mrsl-band-score (eq (mrsl-shift-count rows) 5) 2))
            (let c2 (mrsl-band-score (eq (mrsl-after-native-count rows) 5) 4))
            (let c3 (mrsl-band-score (eq (mrsl-before-oracle-count rows) 5) 8))
            (let c4 (mrsl-band-score (and (eq (mrsl-row-before-nl ende) 100)
                                          (eq (mrsl-row-before-audio ende) 0)) 16))
            (let c5 (mrsl-band-score (str_eq (mrsl-row-after-route zhar) "native") 32))
            (let c6 (mrsl-band-score (str_eq (mrsl-rec-route rec) "native") 64))
            (let c7 (mrsl-band-score (str_eq one-way-route "oracle-guide") 128))
            (let c8 (mrsl-band-score (and (eq (mrsl-rec-oracle-metal rec) 1)
                                          (eq (mrsl-rec-native-form rec) 1)) 256))
            (let c9 (mrsl-band-score (eq (mrsl-rec-neural-metal rec) 0) 512))
            (let c10 (mrsl-band-score (eq (mrsl-rec-floor rec) 50) 1024))
            (let c11 (mrsl-band-score (and (eq (mrsl-row-after-nl zhar) 100)
                                           (eq (mrsl-row-after-audio zhar) 100)) 2048))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) (add c10 c11)))))

    (multilocale-route-shift-ledger-band))
