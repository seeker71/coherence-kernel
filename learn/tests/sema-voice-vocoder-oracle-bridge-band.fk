; preludes: observe/stt-wer.fk presence/formant-vocoder.fk observe/speech-token-stream.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk learn/sema-voice-vocoder-oracle-bridge.fk
;
; sema-voice-vocoder-oracle-bridge-band -- TCAV rows feed Sema STT bar.
;
; Verdict 32767:
;   1     bridge row converts TCAV sample to Sema local-oracle row
;   2     exact transcript row is valid
;   4     exact transcript reaches zero WER
;   8     exact transcript passes the local oracle bar
;   16    exact transcript can promote through the Sema voice receipt
;   32    partial transcript stays oracle-guided
;   64    empty transcript fails oracle success
;   128   missing consent blocks validity
;   256   fail control blocks validity
;   512   Latin sample from Sanskrit baseline shape passes the same bridge
;   1024  receipt preserves WER and route
;   2048  receipt preserves oracle/device
;   4096  receipt preserves audio hash and source
;   8192  receipt records native Form with neural vocoder pending
;   16384 receipt names the bridge surface

(do
    (defn svvob-band-score (cond bit) (if cond bit 0))

    (defn sema-voice-vocoder-oracle-bridge-band ()
        (do
            (let oracle "whisper.cpp-large-v3-turbo")
            (let device "macos-arm64-m4-max")
            (let meta (sts-meta 91 82 64 8 44 88))
            (let tokens (list "open" "speech" "flows"))
            (let inc (svsl-sample (svsl-profile "rough" 145 620 1250 2850 130 55 82 48 42 44 2)
                                  56 70 100 180 1 960001 0 0 0))
            (let good (svvob-tcav-row 9601 "en" "en" 0 tokens "open speech flows" "open speech flows" meta 960101 1 1 0 0 0))
            (let partial (svvob-tcav-row 9602 "en" "en" 0 tokens "open speech flows" "open speech" meta 960102 1 1 0 0 0))
            (let empty-row (svvob-tcav-row 9603 "en" "en" 0 tokens "open speech flows" "" meta 960103 1 1 0 0 0))
            (let denied (svvob-tcav-row 9604 "en" "en" 0 tokens "open speech flows" "open speech flows" meta 960104 1 0 0 0 0))
            (let failed (svvob-tcav-row 9605 "en" "en" 0 tokens "open speech flows" "open speech flows" meta 960105 1 1 1 0 0))
            (let la (svvob-tcav-row 9606 "sa" "la" 302 (list "veritas" "sola" "vincit") "veritas sola vincit" "veritas sola vincit" meta 960106 1 1 0 0 0))
            (let good-row (svvob-row good oracle device))
            (let good-rec (svvob-receipt inc good oracle device 25 20))
            (let partial-rec (svvob-receipt inc partial oracle device 25 20))
            (let la-rec (svvob-receipt inc la oracle device 25 20))
            (let c0 (svvob-band-score (str_eq (svlor-kind good-row) "sema-voice-local-oracle-row") 1))
            (let c1 (svvob-band-score (eq (svlor-valid? good-row) 1) 2))
            (let c2 (svvob-band-score (eq (svlor-oracle-wer good-row) 0) 4))
            (let c3 (svvob-band-score (eq (svlor-oracle-success? good-row 25) 1) 8))
            (let c4 (svvob-band-score (str_eq (nth good-rec 4) "native-sema-voice") 16))
            (let c5 (svvob-band-score (str_eq (nth partial-rec 4) "oracle-guide") 32))
            (let c6 (svvob-band-score (eq (svlor-oracle-success? (svvob-row empty-row oracle device) 25) 0) 64))
            (let c7 (svvob-band-score (eq (svlor-valid? (svvob-row denied oracle device)) 0) 128))
            (let c8 (svvob-band-score (eq (svlor-valid? (svvob-row failed oracle device)) 0) 256))
            (let c9 (svvob-band-score (and (str_eq (svvob-dst la) "la")
                                           (str_eq (nth la-rec 4) "native-sema-voice")) 512))
            (let c10 (svvob-band-score (and (eq (nth good-rec 3) 0)
                                            (str_eq (nth good-rec 4) "native-sema-voice")) 1024))
            (let c11 (svvob-band-score (and (str_eq (nth good-rec 7) oracle)
                                            (str_eq (nth good-rec 8) device)) 2048))
            (let c12 (svvob-band-score (and (eq (nth good-rec 9) 960101)
                                            (str_eq (nth good-rec 10)
                                                    "text-conditioned-acoustic-vocoder")) 4096))
            (let c13 (svvob-band-score (and (eq (nth good-rec 11) 1)
                                            (eq (nth good-rec 12) 0)) 8192))
            (let c14 (svvob-band-score (str_eq (nth good-rec 0)
                                               "sema-voice-vocoder-oracle-bridge") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (sema-voice-vocoder-oracle-bridge-band))
