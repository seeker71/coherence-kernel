; preludes:
;   observe/stt-wer.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk
;   learn/speech-audio-nl2nl-source-window-0002.fk
;
; speech-audio-nl2nl-source-window-0002-band -- hi/it source-window audio bridge.
;
; Verdict 32767:
;   1     receipt names source-window audio NL2NL bridge
;   2     two reciprocal routes are present
;   4     source audio oracle accepts both rows
;   8     target audio oracle accepts both rows
;   16    native neutral routing emits both target texts
;   32    observed wav bytes are carried
;   64    meaning is neutral greeting 601
;   128   pair is hi<->it
;   256   status names oracle-guided source-window bridge
;   512   native Form route true
;   1024  local oracle true
;   2048  native vocoder false
;   4096  neural false
;   8192  data sufficiency still false
;   16384 source and target audio hashes are nonzero

(do
    (defn sanw2-band-score (cond bit) (if cond bit 0))

    (defn sanw2-band-a ()
        (do
            (let r (sanw2-receipt))
            (add
                (add (sanw2-band-score (str_eq (sanw2-rec-kind r) (sanw2-kind)) 1)
                     (sanw2-band-score (eq (sanw2-rec-count r) 2) 2))
                (add (sanw2-band-score (eq (sanw2-rec-src-ok r) 2) 4)
                     (sanw2-band-score (eq (sanw2-rec-dst-ok r) 2) 8)))))

    (defn sanw2-band-b ()
        (do
            (let r (sanw2-receipt))
            (add
                (add (sanw2-band-score (eq (sanw2-rec-native-ok r) 2) 16)
                     (sanw2-band-score (eq (sanw2-rec-bytes r) 90664) 32))
                (add (sanw2-band-score (eq (sanw2-rec-meaning r) 601) 64)
                     (sanw2-band-score (str_eq (sanw2-rec-pair r) "hi<->it") 128)))))

    (defn sanw2-band-c ()
        (do
            (let r (sanw2-receipt))
            (add
                (add (sanw2-band-score
                        (str_eq (sanw2-rec-status r)
                                "oracle-guided-source-window-audio-nl2nl-audio-bridge-not-native-vocoder") 256)
                     (sanw2-band-score (eq (sanw2-rec-native r) 1) 512))
                (add (sanw2-band-score (eq (sanw2-rec-oracle r) 1) 1024)
                     (sanw2-band-score (eq (sanw2-rec-vocoder r) 0) 2048)))))

    (defn sanw2-band-d ()
        (do
            (let r (sanw2-receipt))
            (let rows (nth r 1))
            (let first (head rows))
            (let second (head (tail rows)))
            (add
                (add (sanw2-band-score (eq (sanw2-rec-neural r) 0) 4096)
                     (sanw2-band-score (eq (slds-sufficient (slds-current)) 0) 8192))
                (sanw2-band-score
                    (and (gt (nth first 8) 0)
                         (and (gt (nth first 9) 0)
                              (and (gt (nth second 8) 0)
                                   (gt (nth second 9) 0)))) 16384))))

    (defn speech-audio-nl2nl-source-window-0002-band ()
        (add (add (sanw2-band-a) (sanw2-band-b))
             (add (sanw2-band-c) (sanw2-band-d))))

    (speech-audio-nl2nl-source-window-0002-band))
