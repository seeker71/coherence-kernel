; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-crossvoice-learning.fk
;
; speech-corpus-crossvoice-learning-band -- controlled cross-voice transfer.
;
; Verdict 65535:
;   1      receipt names the cross-voice learner
;   2      six candidate rows are recorded
;   4      six eval rows are present
;   8      six local oracle eval transcripts pass
;   16     six native same-text-vs-control distances pass
;   32     train/eval hashes differ
;   64     max WER clears floor
;   128    native distance margin is positive
;   256    wav byte total is carried
;   512    status names controlled cross-voice, not global authority
;   1024   native Form true
;   2048   held-out true
;   4096   cross-voice true
;   8192   global authority false
;   16384  neural false
;   32768  sufficiency gate still false

(do
    (defn sccv-band-row (id locale key train-voice eval-voice control-key text wer same-d control-d bytes)
        (list "speech-corpus-crossvoice-eval-row"
              id locale key train-voice eval-voice control-key text text wer (if (le wer (sccv-max-wer)) 1 0)
              same-d control-d (if (lt same-d control-d) 1 0)
              995000 (add 995000 id) 1 bytes))
    (defn sccv-band-rows ()
        (list
            (sccv-band-row 1 "en" "hatiSuci.reg.enter" "Flo (English (US))" "Daniel"
                           "hatiSuci.add.button" "Enter the house" 0 2 14 108094)
            (sccv-band-row 2 "en" "hatiSuci.invite.heading" "Eddy (English (US))" "Flo (English (US))"
                           "hatiSuci.market.heading" "Invite someone" 0 4 15 129632)
            (sccv-band-row 3 "fr" "hatiSuci.add.detailPlaceholder" "Jacques" "Eddy (French (France))"
                           "hatiSuci.add.heading" "De quoi avez-vous besoin ?" 0 0 12 140842)
            (sccv-band-row 4 "pt-br" "hatiSuci.market.heading" "Reed (Portuguese (Brazil))" "Eddy (Portuguese (Brazil))"
                           "hatiSuci.invite.heading" "Do mercado" 0 0 10 116604)
            (sccv-band-row 5 "pt-br" "hatiSuci.invite.heading" "Reed (Portuguese (Brazil))" "Eddy (Portuguese (Brazil))"
                           "hatiSuci.add.detailPlaceholder" "Convidar alguém" 0 1 10 145644)
            (sccv-band-row 6 "es" "hatiSuci.market.heading" "Reed (Spanish (Spain))" "Eddy (Spanish (Spain))"
                           "hatiSuci.reg.enter" "Del mercado" 0 0 8 114244)))
    (defn sccv-band-score (cond bit) (if cond bit 0))
    (defn sccv-band-receipt ()
        (sccv-receipt-from (sccv-band-rows)))

    (defn speech-corpus-crossvoice-learning-band ()
        (do
            (let r (sccv-band-receipt))
            (add
                (add
                    (add (sccv-band-score (str_eq (sccv-rec-kind r) (sccv-kind)) 1)
                         (sccv-band-score (eq (sccv-rec-candidates r) 6) 2))
                    (add (sccv-band-score (eq (sccv-rec-evals r) 6) 4)
                         (sccv-band-score (eq (sccv-rec-oracle-ok r) 6) 8)))
                (add
                    (add (sccv-band-score (eq (sccv-rec-native-ok r) 6) 16)
                         (sccv-band-score (eq (sccv-rec-diff r) 6) 32))
                    (add
                        (add (sccv-band-score (le (sccv-rec-max-wer r) (sccv-max-wer)) 64)
                             (sccv-band-score (gt (sccv-rec-margin r) 0) 128))
                        (add
                            (add (sccv-band-score (gt (sccv-rec-bytes r) 700000) 256)
                                 (sccv-band-score (str_eq (sccv-rec-status r)
                                                          "controlled-crossvoice-ab-not-global-authority") 512))
                            (add
                                (add (sccv-band-score (eq (sccv-rec-native r) 1) 1024)
                                     (sccv-band-score (eq (sccv-rec-heldout r) 1) 2048))
                                (add
                                    (add (sccv-band-score (eq (sccv-rec-cross r) 1) 4096)
                                         (sccv-band-score (eq (sccv-rec-global r) 0) 8192))
                                    (add (sccv-band-score (eq (sccv-rec-neural r) 0) 16384)
                                         (sccv-band-score (eq (slds-sufficient (slds-current)) 0) 32768)))))))))

    (speech-corpus-crossvoice-learning-band))
