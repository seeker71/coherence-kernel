; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk
;
; locale-neutral-locate-band -- proves the reverse direction the rest of the
; body never walks: locale-specific surface tokens -> the neutral meaning
; Blueprint they belong to (not meaning -> tokens, and not asserted as given
; test data). Every existing multilocale-nl-audio-pipeline sample builds a
; meaning id and its tokens together and takes the meaning on faith; this
; band recomputes the meaning FROM raw tokens via slb-meaning-for-tokens and
; checks it against what was asserted, both directions, across the pipeline's
; own real sample set.
;
; Verdict 255:
;   1    en tokens for meaning 302 locate to 302
;   2    de tokens for meaning 302 locate to 302
;   4    en and de independently locate the SAME meaning (cross-locale pivot holds)
;   8    a genuine cross-locale mismatch (en 302 vs de 301) is correctly rejected
;   16   tokens outside the baseline honestly locate to 0, not a false positive
;   32   es and en both locate meaning 302 (three-locale consistency)
;   64   a real pipeline sample (meaning 302, en->es) locates honestly both sides
;   128  every sample in the pipeline's own 10-sample nl set locates honestly both sides

(do
    (defn lnl-band-score (cond bit) (if cond bit 0))

    (defn lnl-sample (meaning src dst)
        (mlap-nl-sample meaning src dst
                         (slb-tokens (slb-line-by-meaning meaning) src)
                         (slb-tokens (slb-line-by-meaning meaning) dst)
                         meaning 0 0 0))

    (defn lnl-pipeline-samples ()
        (list
            (lnl-sample 301 "en" "de")
            (lnl-sample 301 "de" "en")
            (lnl-sample 302 "en" "es")
            (lnl-sample 302 "es" "en")
            (lnl-sample 302 "zh" "ar")
            (lnl-sample 302 "ar" "zh")
            (lnl-sample 303 "fr" "id")
            (lnl-sample 303 "id" "fr")
            (lnl-sample 304 "sa" "la")
            (lnl-sample 304 "la" "sa")))

    (defn locale-neutral-locate-band ()
        (do
            (let en-302 (slb-tokens (slb-line-by-meaning 302) "en"))
            (let de-302 (slb-tokens (slb-line-by-meaning 302) "de"))
            (let es-302 (slb-tokens (slb-line-by-meaning 302) "es"))
            (let de-301 (slb-tokens (slb-line-by-meaning 301) "de"))
            (let c0 (lnl-band-score (eq (slb-meaning-for-tokens "en" en-302) 302) 1))
            (let c1 (lnl-band-score (eq (slb-meaning-for-tokens "de" de-302) 302) 2))
            (let c2 (lnl-band-score (eq (slb-locate-cross-locale? "en" en-302 "de" de-302) 1) 4))
            (let c3 (lnl-band-score (eq (slb-locate-cross-locale? "en" en-302 "de" de-301) 0) 8))
            (let c4 (lnl-band-score (eq (slb-meaning-for-tokens "en" (list "banana" "phone")) 0) 16))
            (let c5 (lnl-band-score (eq (slb-locate-cross-locale? "es" es-302 "en" en-302) 1) 32))
            (let c6 (lnl-band-score (eq (mlap-nl-meaning-located? (lnl-sample 302 "en" "es")) 1) 64))
            (let c7 (lnl-band-score (eq (mlap-nl-all-located? (lnl-pipeline-samples)) 1) 128))
            (add
                (add (add c0 c1) (add c2 c3))
                (add (add c4 c5) (add c6 c7)))))

    (locale-neutral-locate-band))
