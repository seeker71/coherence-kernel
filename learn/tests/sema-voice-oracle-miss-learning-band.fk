; preludes: learn/sema-voice-local-oracle-receipt.fk learn/sema-voice-oracle-miss-learning.fk
;
; sema-voice-oracle-miss-learning-band -- live WER miss becomes an AutoML action.
;
; Verdict 32767:
;   1     merged live Mac probe is present and valid as evidence
;   2     WER-100 probe is a miss, not a pass
;   4     miss action trains a text-conditioned acoustic vocoder
;   8     next candidate names text-conditioned-acoustic-vocoder
;   16    priority is the WER gap plus learning pressure
;   32    authority stays oracle-guide on miss
;   64    passing live row can promote native Sema voice
;   128   missing audio routes to carrier repair
;   256   fail row routes to carrier repair
;   512   recipe includes g2p and phoneme timing
;   1024  recipe includes acoustic token and segmented learning
;   2048  receipt preserves live verdict and field code
;   4096  receipt preserves WER 100 and local oracle/device
;   8192  receipt marks trainable native Form, neural vocoder not ready
;   16384 receipt names the miss-learning surface

(do
    (defn svom-band-score (cond bit) (if cond bit 0))
    (defn svom-band-rec () (svom-receipt (svom-macos-live-miss) 25))

    (defn svom-band-miss-score ()
        (add
            (add
                (svom-band-score
                    (and (str_eq (svom-kind (svom-macos-live-miss)) "sema-voice-oracle-live")
                         (eq (svom-carrier-ok? (svom-macos-live-miss)) 1)) 1)
                (svom-band-score
                    (and (eq (svom-miss? (svom-macos-live-miss) 25) 1)
                         (eq (svom-pass? (svom-macos-live-miss) 25) 0)) 2))
            (add
                (svom-band-score
                    (str_eq (svom-action (svom-macos-live-miss) 25)
                            "train-text-conditioned-acoustic-vocoder") 4)
                (svom-band-score
                    (str_eq (svom-next-candidate (svom-macos-live-miss) 25)
                            "text-conditioned-acoustic-vocoder") 8))))

    (defn svom-band-route-score ()
        (add
            (add
                (svom-band-score (eq (svom-priority (svom-macos-live-miss) 25) 125) 16)
                (svom-band-score (str_eq (svom-authority (svom-macos-live-miss) 25) "oracle-guide") 32))
            (add
                (svom-band-score
                    (and (eq (svom-pass? (svom-passing-live) 25) 1)
                         (str_eq (svom-action (svom-passing-live) 25)
                                 "promote-native-sema-voice")) 64)
                (svom-band-score
                    (str_eq (svom-next-candidate (svom-no-audio-live) 25)
                            "repair-live-carrier") 128))))

    (defn svom-band-recipe-score ()
        (add
            (add
                (svom-band-score (str_eq (svom-action (svom-fail-live) 25) "repair-carrier") 256)
                (svom-band-score
                    (and (eq (svom-recipe-has? (svom-recipe) "g2p") 1)
                         (eq (svom-recipe-has? (svom-recipe) "phoneme-timing") 1)) 512))
            (svom-band-score
                (and (eq (svom-recipe-has? (svom-recipe) "acoustic-token-emitter") 1)
                     (eq (svom-recipe-has? (svom-recipe) "segmented-acoustic-learning") 1)) 1024)))

    (defn svom-band-receipt-score ()
        (add
            (add
                (svom-band-score
                    (and (eq (svom-rec-verdict (svom-band-rec)) 479)
                         (eq (svom-rec-field-code (svom-band-rec)) 110100002)) 2048)
                (svom-band-score
                    (and (eq (svom-rec-wer (svom-band-rec)) 100)
                         (and (str_eq (svom-rec-oracle (svom-band-rec)) "whisper.cpp-large-v3-turbo")
                              (str_eq (svom-rec-device (svom-band-rec)) "macos-arm64-m4-max"))) 4096))
            (add
                (svom-band-score
                    (and (eq (svom-rec-trainable (svom-band-rec)) 1)
                         (and (eq (svom-rec-native-form (svom-band-rec)) 1)
                              (eq (svom-rec-neural-vocoder-ready (svom-band-rec)) 0))) 8192)
                (svom-band-score
                    (str_eq (svom-rec-kind (svom-band-rec))
                            "sema-voice-oracle-miss-learning") 16384))))

    (defn sema-voice-oracle-miss-learning-band ()
        (add
            (add (svom-band-miss-score) (svom-band-route-score))
            (add (svom-band-recipe-score) (svom-band-receipt-score))))

    (sema-voice-oracle-miss-learning-band))
