; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-form-pair-window-0008.fk
;   learn/speech-native-neural-bootstrap.fk
;   learn/speech-native-neural-pair-window-0001.fk
;
; speech-native-neural-pair-window-0001-band -- first non-zero neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0001
;   2      pair is en<->fr
;   4      trained unordered neural pair count is one
;   8      trained directed routes are two
;   16     one epoch and one parameter are used
;   32     neural rate moves 0 -> 100
;   64     route shifts
;   128    underlying Form NL/audio rates are 100
;   256    bootstrap loss moves 1 -> 0
;   512    oracle is carried
;   1024   native Form is carried
;   2048   neural flag is true
;   4096   open authority is false
;   8192   after rate clears floor
;   16384  status names micro-pair, not open authority

(do
    (defn snpw1-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0001-band ()
        (do
            (let r (snpw1-receipt))
            (let c0 (snpw1-band-score (str_eq (snpw1-rec-kind r)
                                              "speech-native-neural-pair-window-0001") 1))
            (let c1 (snpw1-band-score (and (str_eq (snpw1-rec-a r) "en")
                                           (str_eq (snpw1-rec-b r) "fr")) 2))
            (let c2 (snpw1-band-score (eq (snpw1-rec-pairs r) 1) 4))
            (let c3 (snpw1-band-score (eq (snpw1-rec-directed r) 2) 8))
            (let c4 (snpw1-band-score (and (eq (snpw1-rec-epochs r) 1)
                                           (eq (snpw1-rec-params r) 1)) 16))
            (let c5 (snpw1-band-score (and (eq (snpw1-rec-before-rate r) 0)
                                           (eq (snpw1-rec-after-rate r) 100)) 32))
            (let c6 (snpw1-band-score (eq (snpw1-rec-shifted r) 1) 64))
            (let c7 (snpw1-band-score (and (eq (snpw1-rec-form-nl r) 100)
                                           (eq (snpw1-rec-form-audio r) 100)) 128))
            (let c8 (snpw1-band-score (and (eq (snpw1-rec-before-loss r) 1)
                                           (eq (snpw1-rec-after-loss r) 0)) 256))
            (let c9 (snpw1-band-score (eq (snpw1-rec-oracle r) 1) 512))
            (let c10 (snpw1-band-score (eq (snpw1-rec-native-form r) 1) 1024))
            (let c11 (snpw1-band-score (eq (snpw1-rec-neural r) 1) 2048))
            (let c12 (snpw1-band-score (eq (snpw1-rec-open-authority r) 0) 4096))
            (let c13 (snpw1-band-score (ge (snpw1-rec-after-rate r) 50) 8192))
            (let c14 (snpw1-band-score (str_eq (snpw1-rec-status r)
                                               "native-neural-micro-pair-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0001-band))
