; preludes:
;   observe/stt-wer.fk
;   observe/wav-sense.fk
;   learn/macos-sema-teacher-acoustic-learning.fk
;   learn/coherence-network-self-corpus.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk
;   learn/speech-corpus-acquisition-window.fk
;   learn/speech-corpus-capture-batch-0002.fk
;
; speech-corpus-capture-batch-0002-band -- second captured audio batch.
;
; Verdict 8191:
;   1     receipt row names batch 0002
;   2     twenty-four rows are present
;   4     twenty-four rows pass oracle WER floor
;   8     twenty-four rows carry audio hashes
;   16    max WER clears floor
;   32    wav byte total is carried
;   64    status says captured but not data-sufficient
;   128   native Form true
;   256   neural false
;   512   self-corpus is ready
;   1024  acquisition plan covers wav floor
;   2048  sufficiency gate still false
;   4096  rows are not used for training

(do
    (defn sccb2-band-score (cond bit) (if cond bit 0))
    (defn sccb2-band-row (id locale key text wer hash bytes)
        (list "speech-corpus-capture-receipt-row"
              id locale key text text wer (if (le wer 25) 1 0) hash 8 bytes))
    (defn sccb2-band-rows ()
        (list
            (sccb2-band-row 1 "en" "common.close" "Close" 0 992001 30050)
            (sccb2-band-row 2 "en" "common.cancel" "Cancel" 0 992002 31074)
            (sccb2-band-row 3 "en" "common.submit" "Submit" 0 992003 31268)
            (sccb2-band-row 4 "en" "nav.search" "Search" 0 992004 29732)
            (sccb2-band-row 5 "de" "common.close" "Schließen" 0 992005 31780)
            (sccb2-band-row 6 "de" "common.yes" "Ja" 0 992006 23070)
            (sccb2-band-row 7 "de" "common.no" "Nein" 0 992007 26646)
            (sccb2-band-row 8 "de" "nav.search" "Suche" 0 992008 27682)
            (sccb2-band-row 9 "es" "common.save" "Guardar" 0 992009 31252)
            (sccb2-band-row 10 "es" "common.yes" "Sí" 0 992010 22560)
            (sccb2-band-row 11 "es" "common.no" "No" 0 992011 21530)
            (sccb2-band-row 12 "es" "hatiSuci.status.open" "Abierto" 0 992012 27166)
            (sccb2-band-row 13 "fr" "common.yes" "Oui" 0 992013 9948)
            (sccb2-band-row 14 "fr" "common.no" "Non" 0 992014 9614)
            (sccb2-band-row 15 "fr" "nav.ideas" "Idées" 0 992015 12606)
            (sccb2-band-row 16 "fr" "nav.assets" "Ressources" 0 992016 25016)
            (sccb2-band-row 17 "id" "common.close" "Tutup" 0 992017 14630)
            (sccb2-band-row 18 "id" "common.cancel" "Batal" 0 992018 17672)
            (sccb2-band-row 19 "id" "common.save" "Simpan" 0 992019 20352)
            (sccb2-band-row 20 "id" "common.submit" "Kirim" 0 992020 16106)
            (sccb2-band-row 21 "pt-br" "common.back" "Voltar" 0 992021 33824)
            (sccb2-band-row 22 "pt-br" "common.no" "Não" 0 992022 25628)
            (sccb2-band-row 23 "pt-br" "nav.vision" "Visão" 0 992023 30752)
            (sccb2-band-row 24 "pt-br" "hatiSuci.act.complete" "Feito" 0 992024 30752)))
    (defn sccb2-band-receipt ()
        (sccb2-receipt-from (sccb2-band-rows)))

    (defn speech-corpus-capture-batch-0002-band ()
        (do
            (let r (sccb2-band-receipt))
            (add
                (add
                    (add
                        (add
                            (sccb2-band-score (str_eq (sccb2-rec-kind r) (sccb2-kind)) 1)
                            (sccb2-band-score (eq (sccb2-rec-count r) 24) 2))
                        (add
                            (sccb2-band-score (eq (sccb2-rec-ok r) 24) 4)
                            (sccb2-band-score (eq (sccb2-rec-hash-count r) 24) 8)))
                    (add
                        (add
                            (sccb2-band-score (le (sccb2-rec-max-wer r) 25) 16)
                            (sccb2-band-score (ge (sccb2-rec-bytes r) 500000) 32))
                        (add
                            (sccb2-band-score (str_eq (sccb2-rec-status r)
                                                      "captured-corpus-audio-not-training-sufficient") 64)
                            (sccb2-band-score (eq (sccb2-rec-native-form r) 1) 128))))
                (add
                    (add
                        (sccb2-band-score (eq (sccb2-rec-neural r) 0) 256)
                        (sccb2-band-score (eq (cnsc-self-corpus-ready?) 1) 512))
                    (add
                        (add
                            (sccb2-band-score (eq (scaw-plan-meets-wav-floor?) 1) 1024)
                            (sccb2-band-score (eq (slds-sufficient (slds-current)) 0) 2048))
                        (sccb2-band-score (eq (sccb2-rec-trained r) 0) 4096))))))

    (speech-corpus-capture-batch-0002-band))
