; preludes:
;   learn/metal-observed-sweep-bridge.fk
;   learn/metal-live-pair-anchors.fk
;
; metal-live-pair-anchors-band -- three live Metal pair anchors are held.
;
; Verdict 32767:
;   1      receipt kind names the live anchor set
;   2      target is five live pair anchors and observed count is three
;   4      all observed anchors are ready, leaving two more
;   8      route remains metal-anchored native guidance
;   16     full-metal-native is refused
;   32     en-de, en-es, and en-id anchors are all ready
;   64     after-native rates are 83, 100, and 100
;   128    en-de A->B and B->A rates are over floor
;   256    en-es and en-id reciprocal rates are 100
;   512    all anchors shifted
;   1024   oracle-ok and sample totals match live receipts
;   2048   local oracle Metal and Form-native flags are present
;   4096   native neural Metal remains pending for all anchors
;   8192   floor is preserved
;   16384  remaining live-pair debt prevents full-metal-native

(do
    (let rec (mlpa-receipt 50 5))
    (let c0 (if (str_eq (nth rec 0) "metal-live-pair-anchors") 1 0))
    (let c1 (if (eq (add (if (eq (nth rec 1) 5) 1 0)
                          (if (eq (nth rec 2) 3) 1 0)) 2) 2 0))
    (let c2 (if (eq (add (if (eq (nth rec 3) 3) 1 0)
                          (if (eq (nth rec 4) 2) 1 0)) 2) 4 0))
    (let c3 (if (str_eq (nth rec 5) "metal-anchored-native-guide") 8 0))
    (let c4 (if (eq (nth rec 6) 0) 16 0))
    (let c5 (if (eq (add (add (nth rec 7) (nth rec 8)) (nth rec 22)) 3) 32 0))
    (let c6 (if (eq (add (add (if (eq (nth rec 9) 83) 1 0)
                               (if (eq (nth rec 10) 100) 1 0))
                          (if (eq (nth rec 23) 100) 1 0)) 3) 64 0))
    (let c7 (if (eq (add (if (ge (nth rec 11) 50) 1 0)
                          (if (ge (nth rec 12) 50) 1 0)) 2) 128 0))
    (let c8 (if (eq (add (add (if (eq (nth rec 13) 100) 1 0)
                               (if (eq (nth rec 14) 100) 1 0))
                          (add (if (eq (nth rec 24) 100) 1 0)
                               (if (eq (nth rec 25) 100) 1 0))) 4) 256 0))
    (let c9 (if (eq (nth rec 15) 3) 512 0))
    (let c10 (if (eq (add (if (eq (nth rec 16) 34) 1 0)
                           (if (eq (nth rec 17) 36) 1 0)) 2) 1024 0))
    (let c11 (if (eq (add (nth rec 18) (nth rec 19)) 6) 2048 0))
    (let c12 (if (eq (nth rec 20) 3) 4096 0))
    (let c13 (if (eq (nth rec 21) 50) 8192 0))
    (let c14 (if (eq (add (if (gt (nth rec 4) 0) 1 0)
                           (if (eq (nth rec 6) 0) 1 0)) 2) 16384 0))
    (add
        (add
            (add (add c0 c1) (add c2 c3))
            (add (add c4 c5) (add c6 c7)))
        (add
            (add (add c8 c9) (add c10 c11))
            (add c12 (add c13 c14)))))
