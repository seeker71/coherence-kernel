; preludes: learn/metal-observed-sweep-bridge.fk learn/metal-live-pair-anchors.fk
;
; metal-live-pair-anchors-band -- seven live Metal pair anchors are held.
;
; Verdict 32767:
;   1      receipt kind names the live anchor set
;   2      target is seven live pair anchors and observed count is seven
;   4      all observed anchors are ready, leaving no remaining live-pair debt
;   8      route is full-metal-native
;   16     full-metal-native is accepted
;   32     all seven anchors are ready
;   64     after-native rates are 83, 100, 100, 83, 100, 83, and 100
;   128    en-de A->B and B->A rates are over floor
;   256    en-es/en-id/en-it/en-ar are 100 and en-fr/en-zh reciprocal rates are over floor
;   512    all anchors shifted
;   1024   oracle-ok and sample totals match live receipts
;   2048   local oracle Metal and Form-native flags are present
;   4096   native neural Metal remains pending for all anchors
;   8192   floor is preserved
;   16384  no remaining live-pair debt allows full-metal-native

(do
    (let rec (mlpa-receipt 50 7))
    (let c0 (if (str_eq (nth rec 0) "metal-live-pair-anchors") 1 0))
    (let c1 (if (eq (add (if (eq (nth rec 1) 7) 1 0)
                          (if (eq (nth rec 2) 7) 1 0)) 2) 2 0))
    (let c2 (if (eq (add (if (eq (nth rec 3) 7) 1 0)
                          (if (eq (nth rec 4) 0) 1 0)) 2) 4 0))
    (let c3 (if (str_eq (nth rec 5) "full-metal-native") 8 0))
    (let c4 (if (eq (nth rec 6) 1) 16 0))
    (let c5 (if (eq (add (add (nth rec 7) (nth rec 8))
                          (add (add (nth rec 22) (nth rec 26))
                               (add (add (nth rec 30) (nth rec 34))
                                    (nth rec 38)))) 7) 32 0))
    (let c6 (if (eq (add (add (if (eq (nth rec 9) 83) 1 0)
                               (if (eq (nth rec 10) 100) 1 0))
                          (add (if (eq (nth rec 23) 100) 1 0)
                               (add (if (eq (nth rec 27) 83) 1 0)
                                    (add (if (eq (nth rec 31) 100) 1 0)
                                         (add (if (eq (nth rec 35) 83) 1 0)
                                              (if (eq (nth rec 39) 100) 1 0)))))) 7) 64 0))
    (let c7 (if (eq (add (if (ge (nth rec 11) 50) 1 0)
                          (if (ge (nth rec 12) 50) 1 0)) 2) 128 0))
    (let c8 (if (eq (add (add (if (eq (nth rec 13) 100) 1 0)
                               (if (eq (nth rec 14) 100) 1 0))
                          (add (if (eq (nth rec 24) 100) 1 0)
                               (add (if (eq (nth rec 25) 100) 1 0)
                                    (add (if (ge (nth rec 28) 50) 1 0)
                                         (add (if (ge (nth rec 29) 50) 1 0)
                                              (add (if (eq (nth rec 32) 100) 1 0)
                                                   (add (if (eq (nth rec 33) 100) 1 0)
                                                        (add (if (ge (nth rec 36) 50) 1 0)
                                                             (add (if (ge (nth rec 37) 50) 1 0)
                                                                  (add (if (eq (nth rec 40) 100) 1 0)
                                                                       (if (eq (nth rec 41) 100) 1 0)))))))))) 12) 256 0))
    (let c9 (if (eq (nth rec 15) 7) 512 0))
    (let c10 (if (eq (add (if (eq (nth rec 16) 78) 1 0)
                           (if (eq (nth rec 17) 84) 1 0)) 2) 1024 0))
    (let c11 (if (eq (add (nth rec 18) (nth rec 19)) 14) 2048 0))
    (let c12 (if (eq (nth rec 20) 7) 4096 0))
    (let c13 (if (eq (nth rec 21) 50) 8192 0))
    (let c14 (if (eq (add (if (eq (nth rec 4) 0) 1 0)
                           (if (eq (nth rec 6) 1) 1 0)) 2) 16384 0))
    (add
        (add
            (add (add c0 c1) (add c2 c3))
            (add (add c4 c5) (add c6 c7)))
        (add
            (add (add c8 c9) (add c10 c11))
            (add c12 (add c13 c14)))))
