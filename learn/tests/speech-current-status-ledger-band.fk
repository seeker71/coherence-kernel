; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/sema-voice-trial-window.fk
;   learn/sema-voice-trial-window-0002.fk
;   learn/sema-voice-authority-floor.fk
;   learn/speech-corpus-training-intake-0001.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/speech-open-asr-trial-window-0002.fk
;   learn/speech-open-asr-trial-window-0003.fk
;   learn/speech-current-status-ledger.fk
;
; speech-current-status-ledger-band -- current speech model status.
;
; Verdict 32767:
;   1     report row names the current status ledger
;   2     model size records nonzero admitted native neural weights
;   4     selected arms, component count, voice organs, scoped windows, and C seed are recorded
;   8     composition names ASR/TTS/NL2NL/audio2audio and local oracle A/B trials
;   16    global live authority aggregate is oracle 5/5 and native 0/5
;   32    live open dictation global row remains oracle 4/4 and native 0/4
;   64    Sema live voice global row is oracle 1/1, native 0/1, native WER 100
;   128   open-ASR scoped trial is native 6/6 at rate 100
;   256   Sema voice scoped trial is native 2/2 with WER 0
;   512   combined scoped trials are oracle 8/8 and native 8/8
;   1024  voice quality target and scoped TCAV window agree on 165/82/64/18
;   2048  scoped trials are explicitly not global authority
;   4096  status names global oracle-held and scoped native cuts
;   8192  C seed growth remains 0 and neural ready is nonzero
;   16384 report marks native Form true

(do
    (defn smcl-band-score (cond bit) (if cond bit 0))
    (defn smcl-rec-size        (r) (nth r 1))
    (defn smcl-rec-comp        (r) (nth r 2))
    (defn smcl-rec-global      (r) (nth r 3))
    (defn smcl-rec-scoped      (r) (nth r 4))
    (defn smcl-rec-quality     (r) (nth r 5))
    (defn smcl-rec-global-note (r) (nth r 6))
    (defn smcl-rec-scoped-note (r) (nth r 7))
    (defn smcl-rec-native-form (r) (nth r 8))
    (defn smcl-rec-neural-ready (r) (nth r 9))

    (defn speech-current-status-ledger-band ()
        (do
            (let r (smcl-report))
            (let smcl-band-size-row (smcl-rec-size r))
            (let smcl-band-comp-row (smcl-rec-comp r))
            (let smcl-band-global-row (smcl-rec-global r))
            (let smcl-band-open-global-row (nth smcl-band-global-row 1))
            (let smcl-band-voice-global-row (nth smcl-band-global-row 2))
            (let smcl-band-scoped-row (smcl-rec-scoped r))
            (let smcl-band-open-trial-row (nth smcl-band-scoped-row 1))
            (let smcl-band-voice-trial-row (nth smcl-band-scoped-row 2))
            (let smcl-band-quality-row (smcl-rec-quality r))
            (let c0 (smcl-band-score (str_eq (nth r 0) "speech-current-status-ledger") 1))
            (let c1 (smcl-band-score (eq (nth smcl-band-size-row 1) 21) 2))
            (let c2 (smcl-band-score (and (eq (nth smcl-band-size-row 2) 4)
                                          (and (eq (nth smcl-band-size-row 3) 24)
                                               (and (eq (nth smcl-band-size-row 4) 6)
                                                    (and (eq (nth smcl-band-size-row 5) 5)
                                                         (eq (nth smcl-band-size-row 6) 0))))) 4))
            (let c3 (smcl-band-score (and (str_eq (nth smcl-band-comp-row 1) "prototype-asr")
                                          (and (str_eq (nth smcl-band-comp-row 4) "text-conditioned-acoustic-vocoder")
                                               (and (str_eq (nth smcl-band-comp-row 5) "closed-set-locale-form")
                                                    (str_eq (nth smcl-band-comp-row 8) "local-oracle-guided-ab-trials")))) 8))
            (let c4 (smcl-band-score (and (eq (nth smcl-band-global-row 3) 5)
                                          (and (eq (nth smcl-band-global-row 4) 5)
                                               (and (eq (nth smcl-band-global-row 6) 0)
                                                    (eq (nth smcl-band-global-row 7) 5)))) 16))
            (let c5 (smcl-band-score (and (eq (nth smcl-band-open-global-row 1) 4)
                                          (and (eq (nth smcl-band-open-global-row 2) 4)
                                               (and (eq (nth smcl-band-open-global-row 4) 0)
                                                    (eq (nth smcl-band-open-global-row 5) 4)))) 32))
            (let c6 (smcl-band-score (and (eq (nth smcl-band-voice-global-row 1) 1)
                                          (and (eq (nth smcl-band-voice-global-row 2) 1)
                                               (and (eq (nth smcl-band-voice-global-row 4) 0)
                                                    (and (eq (nth smcl-band-voice-global-row 5) 1)
                                                         (eq (nth smcl-band-voice-global-row 7) 100))))) 64))
            (let c7 (smcl-band-score (and (eq (nth smcl-band-open-trial-row 3) 6)
                                          (and (eq (nth smcl-band-open-trial-row 4) 6)
                                               (eq (nth smcl-band-open-trial-row 5) 100))) 128))
            (let c8 (smcl-band-score (and (eq (nth smcl-band-voice-trial-row 3) 2)
                                          (and (eq (nth smcl-band-voice-trial-row 4) 2)
                                               (eq (nth smcl-band-voice-trial-row 5) 0))) 256))
            (let c9 (smcl-band-score (and (eq (nth smcl-band-scoped-row 3) 8)
                                          (and (eq (nth smcl-band-scoped-row 4) 8)
                                               (and (eq (nth smcl-band-scoped-row 6) 8)
                                                    (eq (nth smcl-band-scoped-row 7) 8)))) 512))
            (let c10 (smcl-band-score (and (eq (nth smcl-band-quality-row 1) 165)
                                           (and (eq (nth smcl-band-quality-row 2) 82)
                                                (and (eq (nth smcl-band-quality-row 3) 64)
                                                     (and (eq (nth smcl-band-quality-row 5) 18)
                                                          (and (eq (nth smcl-band-quality-row 6) 165)
                                                               (eq (nth smcl-band-quality-row 9) 18)))))) 1024))
            (let c11 (smcl-band-score (and (str_eq (nth smcl-band-open-trial-row 7) "trial-window-native-not-global-authority")
                                           (str_eq (nth smcl-band-voice-trial-row 7) "trial-window-native-not-global-live-voice")) 2048))
            (let c12 (smcl-band-score (and (str_eq (smcl-rec-global-note r) "global-live-authority-still-oracle-held")
                                           (str_eq (smcl-rec-scoped-note r) "scoped-trials-cut-native-challengers")) 4096))
            (let c13 (smcl-band-score (and (eq (nth smcl-band-size-row 6) 0)
                                           (eq (smcl-rec-neural-ready r) 1)) 8192))
            (let c14 (smcl-band-score (eq (smcl-rec-native-form r) 1) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-current-status-ledger-band))
