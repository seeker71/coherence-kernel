; preludes:
;   learn/speech-current-status-ledger.fk
;
; speech-current-status-ledger-band -- current speech model status smoke witness.
;
; Verdict 32767:
;   1     report row names the current status ledger
;   2     model size records thirty-four admitted native neural weights
;   4     model size records 50 current components
;   8     fifteen scoped native trial windows are counted
;   16    global live aggregate is oracle 5/5
;   32    global live native remains 0/5
;   64    open-ASR scoped trial is native 20/20
;   128   combined scoped trials are native 25/25
;   256   Sema live voice oracle is 1/1
;   512   Sema live voice native remains 0/1
;   1024  voice quality target carries F0 165
;   2048  voice quality target carries breath 18
;   4096  status names global oracle-held
;   8192  C seed growth remains 0 and neural ready is nonzero
;   16384 report marks native Form true

(do
    (defn smcl-band-score (cond bit) (if cond bit 0))

    (defn speech-current-status-ledger-band ()
        (add
            (add
                (add
                    (add
                        (smcl-band-score (str_eq (nth (smcl-report) 0) "speech-current-status-ledger") 1)
                        (smcl-band-score (eq (nth (smcl-size) 1) 34) 2))
                    (add
                        (smcl-band-score (eq (nth (smcl-size) 3) 50) 4)
                        (smcl-band-score (eq (nth (smcl-size) 5) 15) 8)))
                (add
                    (add
                        (smcl-band-score (and (eq (nth (smcl-global-live) 3) 5)
                                              (eq (nth (smcl-global-live) 4) 5)) 16)
                        (smcl-band-score (and (eq (nth (smcl-global-live) 6) 0)
                                              (eq (nth (smcl-global-live) 7) 5)) 32))
                    (add
                        (smcl-band-score (and (eq (nth (smcl-open-trial) 3) 20)
                                              (eq (nth (smcl-open-trial) 4) 20)) 64)
                        (smcl-band-score (and (eq (nth (smcl-scoped-trials) 6) 25)
                                              (eq (nth (smcl-scoped-trials) 7) 25)) 128))))
            (add
                (add
                    (add
                        (smcl-band-score (and (eq (nth (smcl-voice-live-row) 1) 1)
                                              (eq (nth (smcl-voice-live-row) 2) 1)) 256)
                        (smcl-band-score (and (eq (nth (smcl-voice-live-row) 4) 0)
                                              (eq (nth (smcl-voice-live-row) 5) 1)) 512))
                    (add
                        (smcl-band-score (eq (nth (smcl-voice-quality) 1) 165) 1024)
                        (smcl-band-score (eq (nth (smcl-voice-quality) 5) 18) 2048)))
                (add
                    (add
                        (smcl-band-score (str_eq (nth (smcl-report) 6)
                                                 "global-live-authority-still-oracle-held") 4096)
                        (smcl-band-score (and (eq (nth (smcl-size) 6) 0)
                                              (eq (nth (smcl-report) 9) 1)) 8192))
                    (smcl-band-score (eq (nth (smcl-report) 8) 1) 16384)))))

    (speech-current-status-ledger-band))
