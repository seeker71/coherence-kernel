; voice-clone-consent-band.fk — fkwu-witnessed band for
; learn/voice-clone-consent.fk.
;
; Bitmask verdict:
;   1   consent kind 'self' is admitted
;   2   consent kind 'written-permission' is admitted
;   4   consent kind 'none' is not admitted, with the rule offered back
;   8   fully proofread chunks read as ready
;   16  one unproofread chunk pauses the run and counts itself
;   32  both doors open -> admission open
;   64  a closed door -> admission not yet (the reason names itself)
;
; Full verdict: 127
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/model-fit.fk learn/voice-clone-consent.fk
(do
  (defn vcb-bit (ok bit) (if (eq ok 1) bit 0))
  (do
    (let good (list (list "c1" 1) (list "c2" 1)))
    (let bad  (list (list "c1" 1) (list "c2" 0)))
    (add (vcb-bit (vcc-consent-ok? (vcc-consent "sema" "self")) 1)
      (add (vcb-bit (vcc-consent-ok? (vcc-consent "friend" "written-permission")) 2)
        (add (vcb-bit (if (ge (str_find (vcc-consent-verdict (vcc-consent "x" "none"))
                                        "not admitted" 0) 0) 1 0) 4)
          (add (vcb-bit (if (ge (str_find (vcc-proofread-verdict good) "ready" 0) 0) 1 0) 8)
            (add (vcb-bit (if (ge (str_find (vcc-proofread-verdict bad) "1 chunk" 0) 0) 1 0) 16)
              (add (vcb-bit (if (ge (str_find (vcc-admit (vcc-consent "sema" "self") good)
                                              "admission: open" 0) 0) 1 0) 32)
                   (vcb-bit (if (ge (str_find (vcc-admit (vcc-consent "x" "none") good)
                                              "not yet" 0) 0) 1 0) 64)))))))))
