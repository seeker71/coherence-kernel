; streaming-context-retention-band.fk — anchor + recent window + sparse
; trajectory memory retain the contexts a long stream needs without pretending
; every old intermediate remains load-bearing.
;
; preludes: form/form-stdlib/core.fk learn/streaming-context-retention.fk

(do
    (defn scrb (ok bit) (if ok bit 0))
    (defn streaming-context-retention-band ()
        (do
    (let c0 (scrb (eq (scr-context-class (list 10000 1 0) 128) 1) 1))
    (let c1 (scrb (eq (scr-context-class (list 8 0 0) 128) 2) 2))
    (let c2 (scrb (eq (scr-context-class (list 10000 0 1) 128) 4) 4))
    (let c3 (scrb (eq (scr-context-class (list 10000 0 0) 128) 0) 8))
    (let c4 (scrb (and (eq (scr-retained? (list 10000 1 0) 128) 1)
                       (eq (scr-retained? (list 8 0 0) 128) 1)) 16))
    (let c5 (scrb (and (eq (scr-retained? (list 10000 0 1) 128) 1)
                       (eq (scr-retained? (list 10000 0 0) 128) 0)) 32))
    (let c6 (scrb (eq (streaming-context-retention-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (streaming-context-retention-band))
