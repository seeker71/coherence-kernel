; preludes:
;   form/form-stdlib/somatic-coherence-loop.fk
;   form/form-stdlib/form-cli-router.fk
;   form/form-stdlib/form-cli-sufficiency.fk
;   form/form-stdlib/observed-auto-learning.fk
;   learn/speech-model-auto-selection.fk
;
; speech-model-auto-selection-band -- model search, AutoML, A/B promotion.
;
; Verdict 4095:
;   1    candidate catalog includes the ASR prototype
;   2    ASR selects nearest-prototype wav-feature model
;   4    TTS selects Form source-filter formant vocoder
;   8    NL2NL selects locale-neutral closed-set Form route
;   16   Audio2Audio selects ASR -> neutral form -> formant route
;   32   diffusion/codec speech is present but not ready
;   64   transformer is trainable but not live-selected yet
;   128  live observed AutoML enters reversible A/B mode
;   256  A/B authority can promote challenger
;   512  fail/undo/timeout controls hold or stop instead of promoting
;   1024 auto-research is active
;   2048 AutoML selection is active

(do
    (defn smas-band-score (cond bit) (if cond bit 0))
    (defn speech-model-auto-selection-band ()
        (do
            (let rec (smas-receipt))
            (let diffusion (smas-candidate-for "diffusion-codec-speech"))
            (let transformer (smas-candidate-for "small-transformer-nl"))
            (let c0 (smas-band-score (str_eq (smas-kind (smas-candidate-for "prototype-asr")) "speech-model-candidate") 1))
            (let c1 (smas-band-score (str_eq (smas-rec-asr rec) "prototype-asr") 2))
            (let c2 (smas-band-score (str_eq (smas-rec-tts rec) "formant-vocoder") 4))
            (let c3 (smas-band-score (str_eq (smas-rec-nl rec) "closed-set-locale-form") 8))
            (let c4 (smas-band-score (str_eq (smas-rec-audio rec) "prototype-asr-formant-audio2audio") 16))
            (let c5 (smas-band-score (and (str_eq (smas-id diffusion) "diffusion-codec-speech")
                                          (eq (smas-ready? diffusion) 0)) 32))
            (let c6 (smas-band-score (and (eq (smas-trainable transformer) 1)
                                          (not (str_eq (smas-rec-nl rec) "small-transformer-nl"))) 64))
            (let c7 (smas-band-score (str_eq (smas-rec-mode rec) "online-reversible-ab") 128))
            (let c8 (smas-band-score (str_eq (smas-ab-authority 8 8 10 10 0) "challenger") 256))
            (let c9 (smas-band-score (and (str_eq (smas-control-action 1 1 0 0 0) "fail-stop")
                                          (and (str_eq (smas-control-action 1 0 0 1 0) "undo-last-change")
                                               (str_eq (smas-control-action 1 0 0 0 1) "timeout-as-nothing"))) 512))
            (let c10 (smas-band-score (eq (smas-rec-research rec) 1) 1024))
            (let c11 (smas-band-score (eq (smas-rec-automl rec) 1) 2048))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) (add c10 c11)))))

    (speech-model-auto-selection-band))
