; preludes:
;   form/form-stdlib/somatic-coherence-loop.fk
;   form/form-stdlib/form-cli-router.fk
;   form/form-stdlib/form-cli-sufficiency.fk
;   form/form-stdlib/observed-auto-learning.fk
;   learn/sema-voice-oracle-miss-learning.fk
;   learn/speech-model-auto-selection.fk
;
; speech-model-auto-selection-band -- model search, AutoML, A/B promotion.
;
; Verdict 33554431:
;   1    candidate catalog includes the ASR prototype
;   2    ASR selects nearest-prototype wav-feature model
;   4    TTS selects Sema voice target/sample loop over raw carrier
;   8    NL2NL selects locale-neutral closed-set Form route
;   16   Audio2Audio selects native metal-witnessed acoustic route
;   32   diffusion/codec speech is present but not ready
;   64   transformer is trainable but not live-selected yet
;   128  live observed AutoML enters reversible A/B mode
;   256  A/B authority can promote challenger
;   512  fail/undo/timeout controls hold or stop instead of promoting
;   1024 auto-research is active
;   2048 AutoML selection is active
;   4096 open dictation receipt is live-observed but does not displace prototype ASR yet
;   8192 native open-ASR CTC decoder candidate exists but is not live-selected yet
;   16384 native acoustic token emitter exists but is not live-selected yet
;   32768 native segmented acoustic learning exists but is not live-selected yet
;   65536 raw formant vocoder remains the native carrier under the voice loop
;   131072 raw formant audio2audio route remains present under the voice loop route
;   262144 live Sema formant probe is present but cannot win TTS after WER 100
;   524288 WER-100 voice miss trains text-conditioned acoustic vocoder next
;   1048576 voice authority remains oracle-guide until the acoustic bridge passes
;   2097152 text-conditioned acoustic vocoder candidate names a concrete Form kernel
;   4194304 native audio2audio acoustic bridge is selected after Metal authority
;   8388608 native audio2audio bridge names the multilocale sweep receipt
;   16777216 native audio2audio bridge names the Metal authority receipt

(do
    (defn smas-band-score (cond bit) (if cond bit 0))
    (defn speech-model-auto-selection-band ()
        (do
            (let rec (smas-receipt))
            (let diffusion (smas-candidate-for "diffusion-codec-speech"))
            (let transformer (smas-candidate-for "small-transformer-nl"))
            (let open-dictation (smas-candidate-for "open-dictation-transcript"))
            (let native-ctc (smas-candidate-for "native-open-asr-ctc"))
            (let acoustic-emitter (smas-candidate-for "native-acoustic-token-emitter"))
            (let segmented (smas-candidate-for "native-segmented-acoustic-learning"))
            (let formant (smas-candidate-for "formant-vocoder"))
            (let voice-loop (smas-candidate-for "sema-voice-sample-loop"))
            (let live-probe (smas-candidate-for "sema-formant-live-probe"))
            (let acoustic-vocoder (smas-candidate-for "text-conditioned-acoustic-vocoder"))
            (let raw-audio (smas-candidate-for "prototype-asr-formant-audio2audio"))
            (let voice-audio (smas-candidate-for "prototype-asr-sema-voice-audio2audio"))
            (let native-audio (smas-candidate-for "native-audio2audio-acoustic-vocoder"))
            (let c0 (smas-band-score (str_eq (smas-kind (smas-candidate-for "prototype-asr")) "speech-model-candidate") 1))
            (let c1 (smas-band-score (str_eq (smas-rec-asr rec) "prototype-asr") 2))
            (let c2 (smas-band-score (and (str_eq (smas-rec-tts rec) "sema-voice-sample-loop")
                                          (str_eq (smas-rec-tts-layout rec)
                                                  "target-fit-listener-wer-ab-formant-vocoder")) 4))
            (let c3 (smas-band-score (str_eq (smas-rec-nl rec) "closed-set-locale-form") 8))
            (let c4 (smas-band-score (and (str_eq (smas-rec-audio rec) "native-audio2audio-acoustic-vocoder")
                                          (str_eq (smas-rec-audio-layout rec)
                                                  "decoded-source-tokens-neutral-form-metal-witnessed-acoustic-vocoder")) 16))
            (let c5 (smas-band-score (and (str_eq (smas-id diffusion) "diffusion-codec-speech")
                                          (eq (smas-ready? diffusion) 0)) 32))
            (let c6 (smas-band-score (and (eq (smas-trainable transformer) 1)
                                          (not (str_eq (smas-rec-nl rec) "small-transformer-nl"))) 64))
            (let c7 (smas-band-score (str_eq (smas-rec-mode rec) "online-reversible-ab") 128))
            (let c8 (smas-band-score (str_eq (smas-ab-authority 8 8 10 10 0) "challenger") 256))
            (let c9 (smas-band-score (and (str_eq (smas-control-action 1 1 0 0 0) "fail-stop")
                                          (and (str_eq (smas-control-action 1 0 0 1 0) "undo-last-change")
                                               (str_eq (smas-control-action 1 0 0 0 1) "timeout-as-nothing"))) 512))
            (let c10 (smas-band-score (eq (smas-rec-research rec) 1) 1024))
            (let c11 (smas-band-score (eq (smas-rec-automl rec) 1) 2048))
            (let c12 (smas-band-score (and (str_eq (smas-id open-dictation) "open-dictation-transcript")
                                           (and (eq (smas-live open-dictation) 1)
                                                (str_eq (smas-rec-asr rec) "prototype-asr"))) 4096))
            (let c13 (smas-band-score (and (str_eq (smas-id native-ctc) "native-open-asr-ctc")
                                           (and (eq (smas-trainable native-ctc) 1)
                                                (and (eq (smas-live native-ctc) 0)
                                                     (str_eq (smas-rec-asr rec) "prototype-asr")))) 8192))
            (let c14 (smas-band-score (and (str_eq (smas-id acoustic-emitter) "native-acoustic-token-emitter")
                                           (and (eq (smas-native acoustic-emitter) 1)
                                                (and (eq (smas-live acoustic-emitter) 0)
                                                     (str_eq (smas-rec-asr rec) "prototype-asr")))) 16384))
            (let c15 (smas-band-score (and (str_eq (smas-id segmented) "native-segmented-acoustic-learning")
                                           (and (eq (smas-trainable segmented) 1)
                                                (and (eq (smas-live segmented) 0)
                                                     (str_eq (smas-rec-asr rec) "prototype-asr")))) 32768))
            (let c16 (smas-band-score (and (str_eq (smas-id formant) "formant-vocoder")
                                           (and (str_eq (smas-id voice-loop) "sema-voice-sample-loop")
                                                (and (eq (smas-native formant) 1)
                                                     (gt (smas-score voice-loop) (smas-score formant))))) 65536))
            (let c17 (smas-band-score (and (str_eq (smas-id raw-audio) "prototype-asr-formant-audio2audio")
                                           (and (str_eq (smas-id voice-audio) "prototype-asr-sema-voice-audio2audio")
                                                (gt (smas-score voice-audio) (smas-score raw-audio)))) 131072))
            (let c18 (smas-band-score (and (str_eq (smas-id live-probe) "sema-formant-live-probe")
                                           (and (eq (smas-live live-probe) 1)
                                                (str_eq (smas-rec-tts rec) "sema-voice-sample-loop"))) 262144))
            (let c19 (smas-band-score (and (str_eq (smas-id acoustic-vocoder) "text-conditioned-acoustic-vocoder")
                                           (and (str_eq (smas-rec-voice-action rec)
                                                        "train-text-conditioned-acoustic-vocoder")
                                                (str_eq (smas-rec-voice-candidate rec)
                                                        "text-conditioned-acoustic-vocoder"))) 524288))
            (let c20 (smas-band-score (str_eq (smas-rec-voice-authority rec) "oracle-guide") 1048576))
            (let c21 (smas-band-score
                        (and (ge (str_find (smas-body acoustic-vocoder)
                                           "learn/text-conditioned-acoustic-vocoder.fk" 0) 0)
                             (str_eq (smas-micro acoustic-vocoder)
                                     "form-g2p-prosody-source-filter-frame-kernel")) 2097152))
            (let c22 (smas-band-score
                        (and (ge (str_find (smas-body native-audio)
                                           "learn/native-audio2audio-acoustic-bridge.fk" 0) 0)
                             (and (str_eq (smas-micro native-audio)
                                           "source-token-meaning-to-target-vocoder-frame-kernel+multilocale-sweep+metal-authority")
                                  (str_eq (smas-rec-audio rec)
                                          "native-audio2audio-acoustic-vocoder"))) 4194304))
            (let c23 (smas-band-score
                        (ge (str_find (smas-body native-audio)
                                      "learn/multilocale-audio2audio-acoustic-sweep.fk" 0) 0) 8388608))
            (let c24 (smas-band-score
                        (and (ge (str_find (smas-body native-audio)
                                           "learn/metal-audio2audio-acoustic-authority.fk" 0) 0)
                             (and (eq (smas-live native-audio) 1)
                                  (eq (smas-metal native-audio) 1))) 16777216))
            (add
                (add
                    (add
                        (add
                            (add
                                (add (add c0 c1) (add c2 c3))
                                (add (add c4 c5) (add c6 c7)))
                            (add (add c8 c9) (add c10 c11)))
                        (add (add c12 c13) (add c14 c15)))
                    (add c16 c17))
                (add (add (add c18 c19) (add c20 c21)) (add (add c22 c23) c24)))))

    (speech-model-auto-selection-band))
