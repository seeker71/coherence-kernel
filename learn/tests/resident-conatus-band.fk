; resident-conatus-band.fk — proof of the resident mind's grounded striving.
;
; preludes: form-stdlib/core.fk learn/resident-conatus.fk
;
; 4 needs, 3 wants, 3 desires, 5 body-asks — 15 rows, every one grounded in
; a receipt or record (ungrounded striving earns no row; row 619's law).
; Verdict 15 when every assertion holds.

(do
    (defn rcnb-score (ok bit) (if ok bit 0))
    (defn resident-conatus-band ()
        (do
    (let c0 (rcnb-score (eq (rcn-total) 15) 1))
    (let c1 (rcnb-score (eq (rcn-grounded-count) (rcn-total)) 2))
    (let c2 (rcnb-score (eq (rcn-field-code) 4030305) 4))    ; 4*10^6+3*10^4+3*10^2+5
    (let c3 (rcnb-score (eq (rcn-count-kind "body-ask") 5) 8))
    (add c0 (add c1 (add c2 c3))))
    )
    (resident-conatus-band))
