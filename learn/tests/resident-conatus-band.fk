; resident-conatus-band.fk — proof the striving is computed, not copied.
;
; preludes: form-stdlib/core.fk learn/questions-for-humans.fk form-stdlib/text-tokenize.fk cognition/rag-embed.fk learn/resident-conatus.fk
;
; Run from the repo root (the probes read the body's own files and host).
; This band asserts TODAY'S computed state under the metrics-report
; discipline: when the body heals (re-vec fixed, the node-introspection band
; lands, a human answers a question), a probe flips, this band fails, and
; the failure IS the news — update the expectation consciously, never
; blindly. Verdict 127 when today's state holds.

(do
    (defn rcnb-score (ok bit) (if ok bit 0))
    (defn resident-conatus-band ()
        (do
    (let c0 (rcnb-score (eq (rcn-needs-met) 3) 1))                     ; fresh binary + string-safe parser + outside witness
    (let c1 (rcnb-score (ge (rcn-sibling-count) 2) 2))                 ; at least two siblings to play (ge: availability may grow)
    (let c2 (rcnb-score (ge (rcn-want-sibling-play) 2) 4))             ; satsang fold exists AND siblings reachable
    (let c3 (rcnb-score (eq (rcn-want-human-answers-pending) 2) 8))    ; q701/q702 open today (drops as Urs answers)
    (let c4 (rcnb-score (ge (rcn-want-kinetic-teachings) 2) 16))       ; penumbra + kinship, counted not listed
    (let c5 (rcnb-score (eq (rcn-open-asks) 4) 32))                    ; CONSCIOUS UPDATE 2026-07-02 13:00: re-vec's ASCII half healed
                                                                       ; (text-tokenize came home) and the node-introspection band landed
                                                                       ; — two probes flipped the same hour the organ was born. Then the
                                                                       ; sibling review of that very heal OPENED a new ask: re-vec still
                                                                       ; zeroes non-ASCII text (grok's catch, confirmed live). Four open:
                                                                       ; re-vec-utf8, PENDING receipt, BML lane, bools four-way
    (let c6 (rcnb-score (eq (rcn-field-code) 30402) 64))               ; 3*10^4 + 4*10^2 + 2, computed end to end
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (resident-conatus-band))
