; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/coherence-network-self-corpus.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-acquisition-window.fk learn/speech-corpus-capture-batch-0003.fk
;
; speech-corpus-capture-batch-0003-band -- screened phrase audio batch.
;
; Verdict 8191:
;   1     receipt row names batch 0003
;   2     thirty-four admitted rows are present
;   4     thirty-four rows pass oracle WER floor
;   8     thirty-four rows carry audio hashes
;   16    max WER clears floor
;   32    wav byte total is carried
;   64    60 candidates and 34 admitted rows are recorded
;   128   status says screened but not data-sufficient
;   256   native Form true
;   512   neural false
;   1024  self-corpus is ready
;   2048  sufficiency gate still false
;   4096  rows are not used for training

(do
    (defn sccb3-band-score (cond bit) (if cond bit 0))
    (defn sccb3-band-row (id locale key text wer hash bytes)
        (list "speech-corpus-capture-receipt-row"
              id locale key text text wer (if (le wer 25) 1 0) hash 8 bytes))
    (defn sccb3-band-rows ()
        (list
            (sccb3-band-row 1 "en" "hatiSuci.reg.enter" "Enter the house" 0 993001 44580)
            (sccb3-band-row 2 "es" "hatiSuci.reg.enter" "Entrar en la casa" 0 993002 43550)
            (sccb3-band-row 3 "fr" "hatiSuci.reg.enter" "Entrer dans la maison" 25 993003 34104)
            (sccb3-band-row 4 "id" "hatiSuci.reg.enter" "Masuk ke rumah" 0 993004 33728)
            (sccb3-band-row 5 "pt-br" "hatiSuci.reg.enter" "Entrar na casa" 0 993005 47136)
            (sccb3-band-row 6 "id" "hatiSuci.join.watch" "Lihat papan" 0 993006 28508)
            (sccb3-band-row 7 "en" "hatiSuci.invite.heading" "Invite someone" 0 993007 43040)
            (sccb3-band-row 8 "id" "hatiSuci.invite.heading" "Undang seseorang" 0 993008 35970)
            (sccb3-band-row 9 "pt-br" "hatiSuci.invite.heading" "Convidar alguém" 0 993009 40804)
            (sccb3-band-row 10 "fr" "hatiSuci.add.heading" "Demandez au champ" 0 993010 28928)
            (sccb3-band-row 11 "id" "hatiSuci.add.heading" "Minta bantuan" 0 993011 34842)
            (sccb3-band-row 12 "en" "hatiSuci.add.detailPlaceholder" "What do you need?" 0 993012 44566)
            (sccb3-band-row 13 "de" "hatiSuci.add.detailPlaceholder" "Was brauchst du?" 0 993013 41504)
            (sccb3-band-row 14 "fr" "hatiSuci.add.detailPlaceholder" "De quoi avez-vous besoin ?" 0 993014 38218)
            (sccb3-band-row 15 "id" "hatiSuci.add.detailPlaceholder" "Apa yang Anda butuhkan?" 0 993015 51204)
            (sccb3-band-row 16 "pt-br" "hatiSuci.add.detailPlaceholder" "O que você precisa?" 0 993016 64028)
            (sccb3-band-row 17 "en" "hatiSuci.add.button" "Send to the board" 0 993017 50212)
            (sccb3-band-row 18 "de" "hatiSuci.add.button" "An die Tafel senden" 0 993018 51232)
            (sccb3-band-row 19 "es" "hatiSuci.add.button" "Enviar al tablón" 0 993019 40478)
            (sccb3-band-row 20 "id" "hatiSuci.add.button" "Kirim ke papan" 0 993020 34312)
            (sccb3-band-row 21 "de" "hatiSuci.board.heading" "Die Tafel" 0 993021 34812)
            (sccb3-band-row 22 "fr" "hatiSuci.board.heading" "Le tableau" 0 993022 20660)
            (sccb3-band-row 23 "id" "hatiSuci.board.heading" "Papan" 0 993023 15894)
            (sccb3-band-row 24 "pt-br" "hatiSuci.board.heading" "O quadro" 0 993024 34332)
            (sccb3-band-row 25 "en" "hatiSuci.board.everyoneSees" "everyone sees" 0 993025 47140)
            (sccb3-band-row 26 "fr" "hatiSuci.board.everyoneSees" "tout le monde voit" 0 993026 28928)
            (sccb3-band-row 27 "id" "hatiSuci.board.everyoneSees" "semua melihat" 0 993027 32614)
            (sccb3-band-row 28 "en" "hatiSuci.market.heading" "From the market" 0 993028 43552)
            (sccb3-band-row 29 "es" "hatiSuci.market.heading" "Del mercado" 0 993029 35350)
            (sccb3-band-row 30 "fr" "hatiSuci.market.heading" "Du marché" 0 993030 22920)
            (sccb3-band-row 31 "id" "hatiSuci.market.heading" "Dari pasar" 0 993031 29710)
            (sccb3-band-row 32 "pt-br" "hatiSuci.market.heading" "Do mercado" 0 993032 37904)
            (sccb3-band-row 33 "es" "hatiSuci.gather.heading" "Encuentros" 0 993033 34334)
            (sccb3-band-row 34 "id" "hatiSuci.gather.heading" "Pertemuan" 0 993034 23294)))
    (defn sccb3-band-receipt ()
        (sccb3-receipt-from (sccb3-band-rows)))

    (defn speech-corpus-capture-batch-0003-band ()
        (do
            (let r (sccb3-band-receipt))
            (add
                (add
                    (add
                        (add
                            (sccb3-band-score (str_eq (sccb3-rec-kind r) (sccb3-kind)) 1)
                            (sccb3-band-score (eq (sccb3-rec-count r) 34) 2))
                        (add
                            (sccb3-band-score (eq (sccb3-rec-ok r) 34) 4)
                            (sccb3-band-score (eq (sccb3-rec-hash-count r) 34) 8)))
                    (add
                        (add
                            (sccb3-band-score (le (sccb3-rec-max-wer r) 25) 16)
                            (sccb3-band-score (ge (sccb3-rec-bytes r) 1200000) 32))
                        (add
                            (sccb3-band-score (and (eq (sccb3-rec-candidates r) 60)
                                                  (eq (sccb3-rec-admitted r) 34)) 64)
                            (sccb3-band-score (str_eq (sccb3-rec-status r)
                                                      "screened-phrase-corpus-audio-not-training-sufficient") 128))))
                (add
                    (add
                        (sccb3-band-score (eq (sccb3-rec-native-form r) 1) 256)
                        (sccb3-band-score (eq (sccb3-rec-neural r) 0) 512))
                    (add
                        (add
                            (sccb3-band-score (eq (cnsc-self-corpus-ready?) 1) 1024)
                            (sccb3-band-score (eq (slds-sufficient (slds-current)) 0) 2048))
                        (sccb3-band-score (eq (sccb3-rec-trained r) 0) 4096))))))

    (speech-corpus-capture-batch-0003-band))
