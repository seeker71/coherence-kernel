; preludes:
;   learn/bidirectional-locale-roundtrip.fk
;
; bidirectional-locale-roundtrip-band -- guide A->B and B->A into balance.
;
; Verdict 2047:
;   1    A->B succeeds when text, audio, meaning, and improvement all pass
;   2    B->A succeeds independently
;   4    mono-locale A loop succeeds
;   8    mono-locale B loop succeeds
;   16   balanced four-loop window is trusted as native
;   32   one-way A->B-only window asks for a return path
;   64   one-way A->B-only window routes to oracle-guide
;   128  meaning mismatch blocks success
;   256  timeout blocks success
;   512  balanced receipt records both directions
;   1024 balanced receipt names the row

(do
    (defn blr-band-score (cond bit) (if cond bit 0))
    (defn blr-band-good (src dst src-text dst-text)
        (blr-dir src dst src-text dst-text
                 777 777
                 20 90 100
                 1 1
                 0 0 0))
    (defn blr-band-meaning-bad ()
        (blr-dir "en" "de" "we are here" "wir sind hier"
                 777 778
                 20 90 100
                 1 1
                 0 0 0))
    (defn blr-band-timeout ()
        (blr-dir "de" "en" "wir sind hier" "we are here"
                 777 777
                 20 90 100
                 1 1
                 0 1 0))
    (defn blr-band-balanced ()
        (list
            (blr-band-good "en" "de" "we are here" "wir sind hier")
            (blr-band-good "de" "en" "wir sind hier" "we are here")
            (blr-band-good "en" "en" "we are here" "we are here")
            (blr-band-good "de" "de" "wir sind hier" "wir sind hier")))
    (defn blr-band-one-way ()
        (list
            (blr-band-good "en" "de" "we are here" "wir sind hier")
            (blr-band-good "en" "en" "we are here" "we are here")
            (blr-band-good "de" "de" "wir sind hier" "wir sind hier")))

    (defn bidirectional-locale-roundtrip-band ()
        (do
            (let balanced (blr-band-balanced))
            (let oneway (blr-band-one-way))
            (let rec (blr-receipt balanced "en" "de"))
            (let c0 (blr-band-score (eq (blr-has-success? balanced "en" "de") 1) 1))
            (let c1 (blr-band-score (eq (blr-has-success? balanced "de" "en") 1) 2))
            (let c2 (blr-band-score (eq (blr-has-success? balanced "en" "en") 1) 4))
            (let c3 (blr-band-score (eq (blr-has-success? balanced "de" "de") 1) 8))
            (let c4 (blr-band-score (str_eq (blr-route balanced "en" "de") "native") 16))
            (let c5 (blr-band-score (eq (blr-needs-return-path? oneway "en" "de") 1) 32))
            (let c6 (blr-band-score (str_eq (blr-route oneway "en" "de") "oracle-guide") 64))
            (let c7 (blr-band-score (eq (blr-success? (blr-band-meaning-bad)) 0) 128))
            (let c8 (blr-band-score (eq (blr-success? (blr-band-timeout)) 0) 256))
            (let c9 (blr-band-score (and (eq (blr-rec-ab rec) 1)
                                         (eq (blr-rec-ba rec) 1)) 512))
            (let c10 (blr-band-score (str_eq (blr-rec-kind rec) "bidirectional-locale-roundtrip") 1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add c8 (add c9 c10)))))

    (bidirectional-locale-roundtrip-band))
