; preludes:
;   observe/stt-wer.fk
;   presence/formant-vocoder.fk
;   observe/speech-token-stream.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/text-conditioned-acoustic-vocoder.fk
;
; text-conditioned-acoustic-vocoder-band -- native text -> acoustic voice frames.
;
; Verdict 32767:
;   1     sample row names the text-conditioned acoustic vocoder
;   2     "open speech flows" maps to twelve phones
;   4     acoustic frames preserve phone identity and frame kind
;   8     voice-side metadata changes duration through cadence/hesitation
;   16    acoustic frames render nonzero native samples
;   32    special speech-token stream preserves words plus receipt token
;   64    current miss-like oracle transcript routes oracle-guide with WER 100
;   128   recorded Sema WER miss drives train-text-conditioned-acoustic-vocoder
;   256   exact local transcript can promote native-acoustic-vocoder
;   512   fail control blocks native pass
;   1024  missing consent blocks native pass
;   2048  Sanskrit baseline can target Latin text through neutral meaning
;   4096  audio2audio direction and voice meta survive in the sample
;   8192  receipt marks native Form micro-kernel with neural Metal pending
;   16384 receipt preserves oracle/device/audio evidence

(do
    (defn tcav-band-score (cond bit) (if cond bit 0))
    (defn tcav-band-meta () (sts-meta 91 82 64 8 44 88))
    (defn tcav-band-fast-meta () (sts-meta 91 82 92 0 44 88))
    (defn tcav-band-slow-meta () (sts-meta 91 82 20 40 44 88))
    (defn tcav-band-tokens () (list "open" "speech" "flows"))
    (defn tcav-band-good ()
        (tcav-sample-from-tokens 9501 "en" "en" 0 (tcav-band-tokens)
                                 "open speech flows" (tcav-band-meta)
                                 950101 1 1 0 0 0))
    (defn tcav-band-miss ()
        (tcav-sample-from-tokens 9502 "en" "en" 0 (tcav-band-tokens)
                                 "" (tcav-band-meta)
                                 950102 1 1 0 0 0))
    (defn tcav-band-pass ()
        (do
            (let s (tcav-band-good))
            (tcav-sample-from-tokens 9503 (tcav-src s) (tcav-dst s) (tcav-meaning s)
                                     (tcav-tokens s) (tcav-target-text s)
                                     (tcav-meta s) 950103 1 1 0 0 0)))
    (defn tcav-band-fail ()
        (do
            (let s (tcav-band-good))
            (tcav-sample-from-tokens 9504 (tcav-src s) (tcav-dst s) (tcav-meaning s)
                                     (tcav-tokens s) (tcav-target-text s)
                                     (tcav-meta s) 950104 1 1 1 0 0)))
    (defn tcav-band-no-consent ()
        (do
            (let s (tcav-band-good))
            (tcav-sample-from-tokens 9505 (tcav-src s) (tcav-dst s) (tcav-meaning s)
                                     (tcav-tokens s) (tcav-target-text s)
                                     (tcav-meta s) 950105 1 0 0 0 0)))
    (defn tcav-band-la ()
        (tcav-sample 9506 "sa" "la" 302 "veritas sola vincit" (tcav-band-meta)
                     950106 1 1 0 0 0))

    (defn text-conditioned-acoustic-vocoder-band ()
        (do
            (let good (tcav-band-good))
            (let miss (tcav-band-miss))
            (let pass (tcav-band-pass))
            (let failed (tcav-band-fail))
            (let denied (tcav-band-no-consent))
            (let la (tcav-band-la))
            (let frames (tcav-frames good))
            (let samples (tcav-samples good))
            (let stream (tcav-stream (tcav-id good) (tcav-tokens good) (tcav-meta good)))
            (let fast-frame (tcav-vocoder-frame "aa" (tcav-sema-profile) (tcav-band-fast-meta)))
            (let slow-frame (tcav-vocoder-frame "aa" (tcav-sema-profile) (tcav-band-slow-meta)))
            (let rec (tcav-receipt miss 25 "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"))
            (let c0 (tcav-band-score
                        (str_eq (tcav-kind good) "text-conditioned-acoustic-vocoder-sample") 1))
            (let c1 (tcav-band-score
                        (and (eq (len (tcav-phones good)) 12)
                             (str_eq (head (tcav-phones good)) "ow")) 2))
            (let c2 (tcav-band-score
                        (and (str_eq (tcav-af-kind (head frames)) "text-conditioned-acoustic-frame")
                             (str_eq (tcav-af-phone (head frames)) "ow")) 4))
            (let c3 (tcav-band-score
                        (lt (fv-duration fast-frame) (fv-duration slow-frame)) 8))
            (let c4 (tcav-band-score
                        (and (gt (len samples) (len frames))
                             (gt (fv-energy samples) 0)) 16))
            (let c5 (tcav-band-score
                        (and (str_eq (sts-transcript stream) "open speech flows")
                             (eq (sts-count-tag stream (sts-receipt-tag)) 1)) 32))
            (let c6 (tcav-band-score
                        (and (str_eq (tcav-route miss 25) "oracle-guide")
                             (eq (tcav-oracle-wer miss) 100)) 64))
            (let c7 (tcav-band-score
                        (str_eq (tcav-action miss 25)
                                "train-text-conditioned-acoustic-vocoder") 128))
            (let c8 (tcav-band-score
                        (and (eq (tcav-pass? pass 25) 1)
                             (str_eq (tcav-route pass 25) "native-acoustic-vocoder")) 256))
            (let c9 (tcav-band-score
                        (and (eq (tcav-pass? failed 25) 0)
                             (str_eq (tcav-action failed 25)
                                     "repair-text-conditioned-carrier")) 512))
            (let c10 (tcav-band-score
                        (and (eq (tcav-pass? denied 25) 0)
                             (eq (tcav-valid? denied) 0)) 1024))
            (let c11 (tcav-band-score
                        (and (eq (tcav-meaning la) 302)
                             (str_eq (tcav-target-text la) "veritas sola vincit")) 2048))
            (let c12 (tcav-band-score
                        (and (str_eq (tcav-src la) "sa")
                             (and (str_eq (tcav-dst la) "la")
                                  (eq (sts-attunement (tcav-meta la)) 88))) 4096))
            (let c13 (tcav-band-score
                        (and (eq (tcav-rec-native-form rec) 1)
                             (and (eq (tcav-rec-micro-kernel rec) 1)
                                  (eq (tcav-rec-neural-metal rec) 0))) 8192))
            (let c14 (tcav-band-score
                        (and (str_eq (tcav-rec-oracle rec) "whisper.cpp-large-v3-turbo")
                             (and (str_eq (tcav-rec-device rec) "macos-arm64-m4-max")
                                  (eq (tcav-rec-audio-hash rec) 950102))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (text-conditioned-acoustic-vocoder-band))
