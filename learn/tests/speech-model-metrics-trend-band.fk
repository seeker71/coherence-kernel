; preludes:
;   learn/speech-model-metrics-trend.fk
;
; speech-model-metrics-trend-band -- before/after speech model movement.
;
; Verdict 32767:
;   1     report row names the trend surface
;   2     four trend rows are included
;   4     mac metal reciprocal audio moved 0 -> 83
;   8     mac metal reciprocal audio shifted oracle-guide -> native
;   16    multiseed NL/audio moved 0 -> 100
;   32    multiseed NL/audio shifted oracle-guide -> native
;   64    live open dictation remains native 0, oracle 100
;   128   live open dictation stays oracle-guide
;   256   Sema live voice remains oracle 100, native 0, with WER 100
;   512   Sema live voice stays oracle-guide
;   1024  two lanes shifted native
;   2048  two lanes remain oracle-held
;   4096  average native rate across the four reported lanes is 45
;   8192  report summary names shifted and held boundaries
;   16384 report marks native Form true and neural ready false

(do
    (defn smmt-band-score (cond bit) (if cond bit 0))
    (defn smmt-rec-rows        (r) (nth r 1))
    (defn smmt-rec-count       (r) (nth r 2))
    (defn smmt-rec-shifted     (r) (nth r 3))
    (defn smmt-rec-held        (r) (nth r 4))
    (defn smmt-rec-average     (r) (nth r 5))
    (defn smmt-rec-summary     (r) (nth r 6))
    (defn smmt-rec-native-form (r) (nth r 7))
    (defn smmt-rec-neural      (r) (nth r 8))

    (defn speech-model-metrics-trend-band ()
        (do
            (let r (smmt-report))
            (let mac (smmt-mac-audio-row))
            (let multi (smmt-multiseed-row))
            (let open (smmt-open-dictation-row))
            (let voice (smmt-sema-voice-row))
            (let c0 (smmt-band-score (str_eq (nth r 0) "speech-model-metrics-trend") 1))
            (let c1 (smmt-band-score (eq (smmt-rec-count r) 4) 2))
            (let c2 (smmt-band-score (and (eq (smmt-before mac) 0)
                                          (eq (smmt-after mac) 83)) 4))
            (let c3 (smmt-band-score (eq (smmt-shifted-row mac) 1) 8))
            (let c4 (smmt-band-score (and (eq (smmt-before multi) 0)
                                          (eq (smmt-after multi) 100)) 16))
            (let c5 (smmt-band-score (eq (smmt-shifted-row multi) 1) 32))
            (let c6 (smmt-band-score (and (eq (smmt-native-rate open) 0)
                                          (eq (smmt-oracle-rate open) 100)) 64))
            (let c7 (smmt-band-score (str_eq (smmt-after-route open) "oracle-guide") 128))
            (let c8 (smmt-band-score (and (eq (smmt-oracle-rate voice) 100)
                                          (and (eq (smmt-native-rate voice) 0)
                                               (eq (smmt-wer voice) 100))) 256))
            (let c9 (smmt-band-score (str_eq (smmt-after-route voice) "oracle-guide") 512))
            (let c10 (smmt-band-score (eq (smmt-rec-shifted r) 2) 1024))
            (let c11 (smmt-band-score (eq (smmt-rec-held r) 2) 2048))
            (let c12 (smmt-band-score (eq (smmt-rec-average r) 45) 4096))
            (let c13 (smmt-band-score (str_eq (smmt-rec-summary r)
                                              "native-shifted-where-reciprocal-closed-or-seeded; oracle-held-for-open-dictation-and-sema-live-voice") 8192))
            (let c14 (smmt-band-score (and (eq (smmt-rec-native-form r) 1)
                                           (eq (smmt-rec-neural r) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-model-metrics-trend-band))
