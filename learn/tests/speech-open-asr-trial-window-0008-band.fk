; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/speech-open-asr-trial-window-0002.fk
;   learn/speech-open-asr-trial-window-0003.fk
;   learn/speech-open-asr-trial-window-0004.fk
;   learn/speech-open-asr-trial-window-0005.fk
;   learn/speech-open-asr-trial-window-0006.fk
;   learn/speech-open-asr-trial-window-0007.fk
;   learn/speech-open-asr-trial-window-0008.fk
;
; speech-open-asr-trial-window-0008-band -- observed de/it open-ASR source window.
;
; Verdict 32767:
;   1     report names open-ASR trial window 0008
;   2     scheduler still targets live open dictation
;   4     cumulative scoped receipt count is sixteen
;   8     local oracle accepts sixteen of sixteen
;   16    native segmented learner accepts sixteen of sixteen
;   32    native scoped rate is 100
;   64    promotion action cuts challenger for the trial window
;   128   route is native inside the scoped receipt
;   256   floor remains 50
;   512   Form native true and neural-ready false
;   1024  status keeps global authority boundary
;   2048  eighth window carries de+it observed loopback rows
;   4096  observed wav bytes are preserved
;   8192  control row is clean
;   16384 report keeps open authority false

(do
    (defn soat8-band-score (cond bit) (if cond bit 0))

    (defn speech-open-asr-trial-window-0008-band ()
        (do
            (let r (soat8-report))
            (let trial (nth r 1))
            (let receipt (nth r 2))
            (let c0 (soat8-band-score (str_eq (nth r 0) "speech-open-asr-trial-window-0008") 1))
            (let c1 (soat8-band-score (str_eq (snts-gap trial) "live-open-dictation") 2))
            (let c2 (soat8-band-score (eq (soat-receipt-count receipt) 16) 4))
            (let c3 (soat8-band-score (eq (soat-receipt-oracle-ok receipt) 16) 8))
            (let c4 (soat8-band-score (eq (soat-receipt-native-ok receipt) 16) 16))
            (let c5 (soat8-band-score (eq (soat-receipt-native-rate receipt) 100) 32))
            (let c6 (soat8-band-score (str_eq (nth r 8) "cut-challenger-for-trial-window") 64))
            (let c7 (soat8-band-score (str_eq (soat-receipt-route receipt) "native") 128))
            (let c8 (soat8-band-score (eq (soat-receipt-floor receipt) 50) 256))
            (let c9 (soat8-band-score (and (eq (soat-receipt-native-form receipt) 1)
                                           (eq (soat-receipt-neural-ready receipt) 0)) 512))
            (let c10 (soat8-band-score (str_eq (nth r 11) "trial-window-native-not-global-authority") 1024))
            (let c11 (soat8-band-score (str_eq (nth r 13) "de+it-metal-loopback") 2048))
            (let c12 (soat8-band-score (eq (nth r 12) 32774) 4096))
            (let c13 (soat8-band-score (str_eq (nth r 9) "choice-cut-fail-undo-timeout-clean") 8192))
            (let c14 (soat8-band-score (eq (nth r 15) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-open-asr-trial-window-0008-band))
