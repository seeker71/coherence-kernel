; preludes: learn/speech-oracle-native-backlog.fk learn/speech-next-trial-scheduler.fk learn/speech-open-asr-trial-window.fk learn/speech-open-asr-trial-window-0002.fk learn/speech-open-asr-trial-window-0003.fk learn/speech-open-asr-trial-window-0004.fk learn/speech-open-asr-trial-window-0005.fk learn/speech-open-asr-trial-window-0006.fk learn/speech-open-asr-trial-window-0007.fk learn/speech-open-asr-trial-window-0008.fk learn/speech-open-asr-trial-window-0009.fk learn/speech-open-asr-trial-window-0010.fk
;
; speech-open-asr-trial-window-0010-band -- observed fi/ja open-ASR source window.
;
; Verdict 32767:
;   1     report names open-ASR trial window 0010
;   2     scheduler still targets live open dictation
;   4     cumulative scoped receipt count is twenty
;   8     local oracle accepts twenty of twenty
;   16    native segmented learner accepts twenty of twenty
;   32    native scoped rate is 100
;   64    promotion action cuts challenger for the trial window
;   128   route is native inside the scoped receipt
;   256   floor remains 50
;   512   Form native true and neural-ready false
;   1024  status keeps global authority boundary
;   2048  tenth window carries fi+ja observed loopback rows
;   4096  observed wav bytes are preserved
;   8192  control row is clean
;   16384 report keeps open authority false

(do
    (defn soat10-band-score (cond bit) (if cond bit 0))

    (defn speech-open-asr-trial-window-0010-band ()
        (do
            (let r (soat10-report))
            (let trial (nth r 1))
            (let receipt (nth r 2))
            (let c0 (soat10-band-score (str_eq (nth r 0) "speech-open-asr-trial-window-0010") 1))
            (let c1 (soat10-band-score (str_eq (snts-gap trial) "live-open-dictation") 2))
            (let c2 (soat10-band-score (eq (soat-receipt-count receipt) 20) 4))
            (let c3 (soat10-band-score (eq (soat-receipt-oracle-ok receipt) 20) 8))
            (let c4 (soat10-band-score (eq (soat-receipt-native-ok receipt) 20) 16))
            (let c5 (soat10-band-score (eq (soat-receipt-native-rate receipt) 100) 32))
            (let c6 (soat10-band-score (str_eq (nth r 8) "cut-challenger-for-trial-window") 64))
            (let c7 (soat10-band-score (str_eq (soat-receipt-route receipt) "native") 128))
            (let c8 (soat10-band-score (eq (soat-receipt-floor receipt) 50) 256))
            (let c9 (soat10-band-score (and (eq (soat-receipt-native-form receipt) 1)
                                            (eq (soat-receipt-neural-ready receipt) 0)) 512))
            (let c10 (soat10-band-score (str_eq (nth r 11) "trial-window-native-not-global-authority") 1024))
            (let c11 (soat10-band-score (str_eq (nth r 13) "fi+ja-metal-loopback") 2048))
            (let c12 (soat10-band-score (eq (nth r 12) 83506) 4096))
            (let c13 (soat10-band-score (str_eq (nth r 9) "choice-cut-fail-undo-timeout-clean") 8192))
            (let c14 (soat10-band-score (eq (nth r 15) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-open-asr-trial-window-0010-band))
