; preludes:
;   observe/stt-wer.fk
;   observe/wav-sense.fk
;   learn/macos-sema-teacher-acoustic-learning.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk
;   learn/speech-audio-nl2nl-bridge.fk
;
; speech-audio-nl2nl-bridge-band -- oracle-guided audio NL2NL bridge.
;
; Verdict 4095:
;   1     receipt names the bridge
;   2     six reciprocal routes are present
;   4     source audio oracle accepts all six
;   8     target audio oracle accepts all six
;   16    native neutral routing emits all six target texts
;   32    wav bytes are carried
;   64    status names oracle-guided bridge, not native vocoder
;   128   native Form route true
;   256   local oracle true
;   512   native vocoder false
;   1024  neural false
;   2048  data sufficiency still false

(do
    (defn sanb-band-row (id src dst src-ok dst-ok native-ok bytes)
        (list "speech-audio-nl2nl-row" id src dst "" (sanb-meaning) "" "" 0 0 src-ok dst-ok native-ok bytes))
    (defn sanb-band-rows ()
        (list
            (sanb-band-row 1 "en" "de" 1 1 1 40240)
            (sanb-band-row 2 "de" "en" 1 1 1 40240)
            (sanb-band-row 3 "es" "pt-br" 1 1 1 47158)
            (sanb-band-row 4 "pt-br" "es" 1 1 1 47158)
            (sanb-band-row 5 "fr" "id" 1 1 1 34292)
            (sanb-band-row 6 "id" "fr" 1 1 1 34260)))

    (defn speech-audio-nl2nl-bridge-band ()
        (do
            (let r (sanb-receipt-from (sanb-band-rows)))
            (add
                (add
                    (add (if (str_eq (sanb-rec-kind r) (sanb-kind)) 1 0)
                         (if (eq (sanb-rec-count r) 6) 2 0))
                    (add (if (eq (sanb-rec-src-ok r) 6) 4 0)
                         (if (eq (sanb-rec-dst-ok r) 6) 8 0)))
                (add
                    (add (if (eq (sanb-rec-native-ok r) 6) 16 0)
                         (if (ge (sanb-rec-bytes r) 200000) 32 0))
                    (add
                        (add (if (str_eq (sanb-rec-status r)
                                         "oracle-guided-audio-nl2nl-audio-bridge-not-native-vocoder") 64 0)
                             (if (eq (sanb-rec-native r) 1) 128 0))
                        (add
                            (add (if (eq (sanb-rec-oracle r) 1) 256 0)
                                 (if (eq (sanb-rec-vocoder r) 0) 512 0))
                            (add (if (eq (sanb-rec-neural r) 0) 1024 0)
                                 (if (eq (slds-sufficient (slds-current)) 0) 2048 0))))))))

    (speech-audio-nl2nl-bridge-band))
