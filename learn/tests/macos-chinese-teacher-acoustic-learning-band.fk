; preludes:
;   observe/stt-wer.fk
;   observe/wav-sense.fk
;   learn/macos-sema-teacher-acoustic-learning.fk
;   learn/macos-chinese-teacher-acoustic-learning.fk
;
; macos-chinese-teacher-acoustic-learning-band -- Chinese teacher learner contract.
;
; Verdict 16383:
;   1     receipt row names the Chinese teacher acoustic learner
;   2     locale is zh
;   4     Sanskrit baseline meaning 303 is carried
;   8     audio hash is carried
;   16    eight wav-envelope windows are recorded
;   32    three token feature rows are used
;   64    training adds Chinese prototypes beyond blank
;   128   oracle transcript is accepted
;   256   native decoded transcript is accepted
;   512   native success passes
;   1024  native WER is zero
;   2048  min confidence clears the native floor
;   4096  native Form true
;   8192  neural model remains false

(do
    (defn mztal-band-score (cond bit) (if cond bit 0))
    (defn mztal-band-env () (list 4 2 3 3 0 0 0 0))
    (defn mztal-band-features ()
        (mstal-envelope-feature-stream (mztal-band-env)))
    (defn mztal-band-receipt ()
        (do
            (let features (mztal-band-features))
            (let trained (mztal-trained features))
            (let frames (mstal-frames (mstal-frame-features features) trained 2 80))
            (let native (mstal-decoded-text frames))
            (list (mztal-kind)
                  (mztal-locale)
                  (mztal-meaning)
                  984977
                  (len (mztal-band-env))
                  (len features)
                  (len trained)
                  (mztal-text)
                  native
                  (if (and (sw-accept? (sw-tokens (mztal-text)) (mztal-tokens) (mstal-max-wer))
                           (sw-accept? (sw-tokens native) (mztal-tokens) (mstal-max-wer))) 1 0)
                  (sw-wer (sw-tokens native) (mztal-tokens))
                  (mstal-min-conf frames)
                  (mstal-device)
                  (mstal-oracle)
                  1
                  0)))

    (defn macos-chinese-teacher-acoustic-learning-band ()
        (do
            (let r (mztal-band-receipt))
            (let c0 (mztal-band-score (str_eq (mztal-rec-kind r) (mztal-kind)) 1))
            (let c1 (mztal-band-score (str_eq (mztal-rec-locale r) "zh") 2))
            (let c2 (mztal-band-score (eq (mztal-rec-meaning r) 303) 4))
            (let c3 (mztal-band-score (eq (mztal-rec-hash r) 984977) 8))
            (let c4 (mztal-band-score (eq (mztal-rec-env-count r) 8) 16))
            (let c5 (mztal-band-score (eq (mztal-rec-features r) 3) 32))
            (let c6 (mztal-band-score (gt (mztal-rec-prototypes r) 2) 64))
            (let c7 (mztal-band-score (eq (sw-wer (sw-tokens (mztal-rec-oracle r)) (mztal-tokens)) 0) 128))
            (let c8 (mztal-band-score (eq (sw-wer (sw-tokens (mztal-rec-native r)) (mztal-tokens)) 0) 256))
            (let c9 (mztal-band-score (eq (mztal-rec-ok r) 1) 512))
            (let c10 (mztal-band-score (eq (mztal-rec-wer r) 0) 1024))
            (let c11 (mztal-band-score (ge (mztal-rec-confidence r) 80) 2048))
            (let c12 (mztal-band-score (eq (mztal-rec-native-form r) 1) 4096))
            (let c13 (mztal-band-score (eq (mztal-rec-neural r) 0) 8192))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 c13)))))

    (macos-chinese-teacher-acoustic-learning-band))
