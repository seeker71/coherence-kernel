; preludes: observe/stt-wer.fk presence/formant-vocoder.fk learn/sema-voice-sample-loop.fk learn/sema-voice-local-oracle-receipt.fk learn/speech-live-receipt-intake.fk learn/sema-voice-teacher-oracle-intake-0002.fk
;
; sema-voice-teacher-oracle-intake-0002-band -- second real teacher row.
;
; Verdict 32767:
;   1      report row names teacher oracle intake 0002
;   2      teacher row carries the witnessed live sample id and cksum
;   4      local teacher WER is 0
;   8      lowered Sema local-oracle row is valid
;   16     local oracle receipt passes the oracle bar
;   32     local oracle receipt routes through native-sema-voice sample law
;   64     speech receipt is local, consented, audio-present, and clean
;   128    cumulative teacher oracle side is 2/2 at 100 percent
;   256    cumulative native side is still 0/2 at 0 percent
;   512    native authority success rejects the teacher row
;   1024   route explicitly says oracle-teacher-positive-native-held
;   2048   boundary refuses native Sema authority
;   4096   observed wav bytes and local Metal oracle are preserved
;   8192   native Form true and neural vocoder pending
;   16384 teacher row still marks host teacher, not native authority

(do
    (defn svtoi2-band-score (cond bit) (if cond bit 0))

    (defn sema-voice-teacher-oracle-intake-0002-band ()
        (do
            (let r (svtoi2-report))
            (let teacher (svtoi2-rec-teacher r))
            (let receipt (svtoi2-rec-oracle-receipt r))
            (let speech (svtoi2-rec-speech-row r))
            (let c0 (svtoi2-band-score (str_eq (svtoi2-rec-kind r)
                                                "sema-voice-teacher-oracle-intake-0002") 1))
            (let c1 (svtoi2-band-score (and (eq (svtoi2-row-id teacher) 983003)
                                            (eq (svtoi2-row-hash teacher) 1857953984)) 2))
            (let c2 (svtoi2-band-score (eq (svtoi2-row-wer teacher) 0) 4))
            (let c3 (svtoi2-band-score (eq (svlor-valid? (svtoi2-row-svlor teacher)) 1) 8))
            (let c4 (svtoi2-band-score (eq (svlor-rec-oracle-ok receipt) 1) 16))
            (let c5 (svtoi2-band-score (str_eq (svlor-rec-route receipt) "native-sema-voice") 32))
            (let c6 (svtoi2-band-score (and (eq (slri-valid? speech) 1)
                                            (eq (slri-audio-hash speech) 1857953984)) 64))
            (let c7 (svtoi2-band-score (and (eq (svtoi2-rec-oracle-ok r) 2)
                                            (and (eq (svtoi2-rec-oracle-total r) 2)
                                                 (eq (svtoi2-rec-oracle-rate r) 100))) 128))
            (let c8 (svtoi2-band-score (and (eq (svtoi2-rec-native-ok r) 0)
                                            (and (eq (svtoi2-rec-native-total r) 2)
                                                 (eq (svtoi2-rec-native-rate r) 0))) 256))
            (let c9 (svtoi2-band-score (eq (svtoi2-rec-native-success r) 0) 512))
            (let c10 (svtoi2-band-score (str_eq (svtoi2-rec-route r)
                                                "oracle-teacher-positive-native-held") 1024))
            (let c11 (svtoi2-band-score (str_eq (svtoi2-rec-boundary r)
                                                "host-teacher-training-evidence-not-native-sema-authority") 2048))
            (let c12 (svtoi2-band-score (and (eq (svtoi2-rec-bytes r) 41694)
                                             (and (str_eq (svtoi2-rec-device r) "macos-arm64-m4-max")
                                                  (str_eq (svtoi2-rec-oracle r)
                                                          "whisper.cpp-large-v3-turbo-metal"))) 4096))
            (let c13 (svtoi2-band-score (and (eq (svtoi2-rec-native-form r) 1)
                                             (eq (svtoi2-rec-neural-ready r) 0)) 8192))
            (let c14 (svtoi2-band-score (str_eq (svtoi2-row-authority teacher)
                                                "host-teacher-not-native-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (sema-voice-teacher-oracle-intake-0002-band))
