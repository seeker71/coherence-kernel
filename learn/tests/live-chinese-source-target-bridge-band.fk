; preludes:
;   observe/stt-wer.fk
;   observe/wav-sense.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/macos-sema-teacher-acoustic-learning.fk
;   learn/macos-chinese-teacher-acoustic-learning.fk
;   learn/live-chinese-source-target-bridge.fk
;
; live-chinese-source-target-bridge-band -- live-source to target acoustic contract.
;
; Verdict 8191:
;   1     receipt row names the bridge
;   2     source locale is zh
;   4     target locale is en
;   8     neutral meaning 303 is carried
;   16    source audio hash is carried
;   32    source ASR is accepted
;   64    target tokens are present
;   128   target acoustic frames are present
;   256   target frame energy is positive
;   512   route shifts to native source-target acoustic
;   1024  confidence clears native floor
;   2048  native Form true
;   4096  neural model remains false

(do
    (defn lzst-band-score (cond bit) (if cond bit 0))
    (defn lzst-band-source ()
        (list (mztal-kind)
              "zh"
              303
              984977
              8
              3
              3
              (mztal-text)
              (mztal-text)
              1
              0
              96
              (mstal-device)
              (mstal-oracle)
              1
              0))
    (defn lzst-band-receipt ()
        (lzst-receipt-from (lzst-band-source) "en"))

    (defn live-chinese-source-target-bridge-band ()
        (do
            (let r (lzst-band-receipt))
            (let c0 (lzst-band-score (str_eq (lzst-rec-kind r) (lzst-kind)) 1))
            (let c1 (lzst-band-score (str_eq (lzst-rec-src r) "zh") 2))
            (let c2 (lzst-band-score (str_eq (lzst-rec-dst r) "en") 4))
            (let c3 (lzst-band-score (eq (lzst-rec-meaning r) 303) 8))
            (let c4 (lzst-band-score (eq (lzst-rec-hash r) 984977) 16))
            (let c5 (lzst-band-score (eq (lzst-rec-source-ok r) 1) 32))
            (let c6 (lzst-band-score (eq (lzst-rec-target-toks r) 2) 64))
            (let c7 (lzst-band-score (eq (lzst-rec-frames r) 2) 128))
            (let c8 (lzst-band-score (gt (lzst-rec-energy r) 0) 256))
            (let c9 (lzst-band-score (str_eq (lzst-rec-route r) "native-source-target-acoustic") 512))
            (let c10 (lzst-band-score (ge (lzst-rec-confidence r) 80) 1024))
            (let c11 (lzst-band-score (eq (lzst-rec-native-form r) 1) 2048))
            (let c12 (lzst-band-score (eq (lzst-rec-neural r) 0) 4096))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add c8 c9)
                    (add (add c10 c11) c12)))))

    (live-chinese-source-target-bridge-band))
