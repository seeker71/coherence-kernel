; preludes:
;   observe/stt-wer.fk
;   learn/speech-loopback-promotion.fk
;   presence/speech-loopback-carrier-receipt.fk
;   learn/speech-loopback-recipe-ab.fk
;
; speech-loopback-recipe-ab-band -- recipe A/B testing over local loopback receipts.
;
; Verdict 2047:
;   1    arm records recipe id and receipt count
;   2    incumbent can route native with margin slack
;   4    challenger score win cuts over
;   8    equal-score lower-latency challenger cuts over
;   16   short challenger window keeps incumbent
;   32   cloud/control debt blocks challenger
;   64   fail control keeps incumbent
;   128  timeout control keeps incumbent
;   256  undo control keeps incumbent
;   512  cut receipt carries challenger-native route
;   1024 latency comparison is measured in the decision

(do
    (defn slab-band-score (cond bit) (if cond bit 0))
    (defn slab-band-truth () (list "we" "are"))
    (defn slab-band-receipt (sid native latency tts-local fail timeout undo)
        (slc-receipt sid 10 111 222 16000 1
                     tts-local 1
                     (slab-band-truth)
                     (slab-band-truth)
                     native
                     95 latency
                     fail timeout undo))
    (defn slab-band-good (sid latency)
        (slab-band-receipt sid (slab-band-truth) latency 1 0 0 0))
    (defn slab-band-bad-native (sid latency)
        (slab-band-receipt sid (list "go" "home") latency 1 0 0 0))
    (defn slab-band-cloud (sid latency)
        (slab-band-receipt sid (slab-band-truth) latency 0 0 0 0))

    (defn slab-band-incumbent-window ()
        (list (slab-band-good 1 60)
              (slab-band-good 2 60)
              (slab-band-good 3 60)
              (slab-band-bad-native 4 60)))
    (defn slab-band-challenger-window ()
        (list (slab-band-good 5 40)
              (slab-band-good 6 40)
              (slab-band-good 7 40)
              (slab-band-good 8 40)))
    (defn slab-band-slow-window ()
        (list (slab-band-good 9 80)
              (slab-band-good 10 80)
              (slab-band-good 11 80)
              (slab-band-good 12 80)))
    (defn slab-band-fast-window ()
        (list (slab-band-good 13 30)
              (slab-band-good 14 30)
              (slab-band-good 15 30)
              (slab-band-good 16 30)))
    (defn slab-band-short-window ()
        (list (slab-band-good 17 30)
              (slab-band-good 18 30)))
    (defn slab-band-cloud-window ()
        (list (slab-band-good 19 30)
              (slab-band-good 20 30)
              (slab-band-good 21 30)
              (slab-band-cloud 22 30)))

    (defn slab-band-decision (inc challenger fail timeout undo)
        (slab-decision-from-receipts
            100 inc
            200 challenger
            10 80 100
            4 1 0 3
            fail timeout undo))

    (defn speech-loopback-recipe-ab-band ()
        (do
            (let inc (slab-band-incumbent-window))
            (let chal (slab-band-challenger-window))
            (let short (slab-band-short-window))
            (let cloud (slab-band-cloud-window))
            (let slow (slab-band-slow-window))
            (let fast (slab-band-fast-window))
            (let inc-arm (slab-arm 100 inc 10 80 100 4 1 0 3))
            (let score-cut (slab-band-decision inc chal 0 0 0))
            (let latency-cut (slab-band-decision slow fast 0 0 0))
            (let short-keep (slab-band-decision inc short 0 0 0))
            (let cloud-keep (slab-band-decision inc cloud 0 0 0))
            (let fail-keep (slab-band-decision inc chal 1 0 0))
            (let timeout-keep (slab-band-decision inc chal 0 1 0))
            (let undo-keep (slab-band-decision inc chal 0 0 1))
            (let c0 (slab-band-score
                (and (eq (slab-arm-recipe inc-arm) 100)
                     (eq (slab-arm-count inc-arm) 4))
                1))
            (let c1 (slab-band-score
                (and (str_eq (slab-arm-route inc-arm) "native")
                     (eq (slab-arm-native inc-arm) 3))
                2))
            (let c2 (slab-band-score
                (and (eq (slab-dec-chosen score-cut) 200)
                     (str_eq (slab-dec-action score-cut) "cut-challenger"))
                4))
            (let c3 (slab-band-score
                (and (eq (slab-dec-chosen latency-cut) 200)
                     (str_eq (slab-dec-action latency-cut) "cut-challenger"))
                8))
            (let c4 (slab-band-score
                (and (eq (slab-dec-chosen short-keep) 100)
                     (str_eq (slab-dec-action short-keep) "keep-incumbent"))
                16))
            (let c5 (slab-band-score
                (and (eq (slab-dec-chosen cloud-keep) 100)
                     (gt (slab-dec-ch-debt cloud-keep) 0))
                32))
            (let c6 (slab-band-score
                (and (eq (slab-dec-chosen fail-keep) 100)
                     (str_eq (slab-dec-action fail-keep) "fail-incumbent"))
                64))
            (let c7 (slab-band-score
                (and (eq (slab-dec-chosen timeout-keep) 100)
                     (str_eq (slab-dec-action timeout-keep) "timeout-incumbent"))
                128))
            (let c8 (slab-band-score
                (and (eq (slab-dec-chosen undo-keep) 100)
                     (str_eq (slab-dec-action undo-keep) "undo-incumbent"))
                256))
            (let c9 (slab-band-score
                (and (str_eq (slab-dec-ch-route score-cut) "native")
                     (eq (slab-dec-ch-native score-cut) 4))
                512))
            (let c10 (slab-band-score
                (and (lt (slab-dec-ch-latency latency-cut) (slab-dec-inc-latency latency-cut))
                     (eq (slab-dec-ch-native latency-cut) (slab-dec-inc-native latency-cut)))
                1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add c8 (add c9 c10)))))

    (speech-loopback-recipe-ab-band))
