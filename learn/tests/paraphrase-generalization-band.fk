; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;
; paraphrase-generalization-band -- measures, instead of asserting, how far
; exact-match locate (slb-meaning-for-tokens) and overlap-match locate
; (mlap-text-meaning, already shipped in multilocale-nl-audio-pipeline.fk)
; actually generalize to English paraphrases of the 4 baseline meanings that
; were never in the training data. 20 hand-written held-out paraphrases,
; 5 per meaning, none copied verbatim from slb-lines().
;
; Verdict: exact_correct*100 + overlap_correct (both counts 0..20, so the
; two fields never collide).

(do
    (defn pgb-case (meaning tokens) (list meaning tokens))
    (defn pgb-meaning (c) (nth c 0))
    (defn pgb-tokens  (c) (nth c 1))

    (defn pgb-cases ()
        (list
            ; meaning 301 canonical en: (may all be happy)
            (pgb-case 301 (list "wish" "all" "beings" "happiness"))
            (pgb-case 301 (list "hope" "everyone" "is" "happy"))
            (pgb-case 301 (list "all" "beings" "be" "happy"))
            (pgb-case 301 (list "happiness" "for" "everyone"))
            (pgb-case 301 (list "let" "all" "be" "happy"))

            ; meaning 302 canonical en: (truth alone triumphs)
            (pgb-case 302 (list "truth" "alone" "wins"))
            (pgb-case 302 (list "only" "truth" "prevails"))
            (pgb-case 302 (list "truth" "wins" "alone"))
            (pgb-case 302 (list "truth" "triumphs"))
            (pgb-case 302 (list "victory" "belongs" "to" "truth"))

            ; meaning 303 canonical en: (i am)
            (pgb-case 303 (list "i" "exist"))
            (pgb-case 303 (list "i" "am" "here"))
            (pgb-case 303 (list "here" "i" "am"))
            (pgb-case 303 (list "i" "myself" "am"))
            (pgb-case 303 (list "existence" "is" "present"))

            ; meaning 304 canonical en: (peace for every world)
            (pgb-case 304 (list "peace" "for" "all" "worlds"))
            (pgb-case 304 (list "peace" "for" "every" "realm"))
            (pgb-case 304 (list "global" "peace" "now"))
            (pgb-case 304 (list "peace" "everywhere"))
            (pgb-case 304 (list "every" "world" "wants" "peace"))))

    (defn pgb-exact-correct? (c)
        (if (eq (slb-meaning-for-tokens "en" (pgb-tokens c)) (pgb-meaning c)) 1 0))
    (defn pgb-overlap-correct? (c)
        (if (eq (mlap-text-meaning (pgb-tokens c) "en" (slb-lines)) (pgb-meaning c)) 1 0))

    (defn pgb-count-loop (cases fn)
        (if (eq (len cases) 0) 0
            (add (fn (head cases)) (pgb-count-loop (tail cases) fn))))

    (defn paraphrase-generalization-band ()
        (do
            (let cases (pgb-cases))
            (let exact-correct (pgb-count-loop cases pgb-exact-correct?))
            (let overlap-correct (pgb-count-loop cases pgb-overlap-correct?))
            (add (mul exact-correct 100) overlap-correct)))

    (paraphrase-generalization-band))
