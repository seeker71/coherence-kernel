; deixis-strata-locate-band.fk — the strata-weighted, tie-abstaining locate
; over the same 20 held-out paraphrases the original band measured.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/word-strata.fk learn/tests/paraphrase-generalization-band.fk
;
; The measured movement (2026-07-02, four-way fkwu/Go/Rust/TS):
;   before (mlap-text-meaning, receipts/2026-07-01-paraphrase-generalization-
;   measured.md): 18 correct, 2 WRONG, 0 abstained — and one of the 18 was
;   right only by the same "for" stopword accident that made another wrong.
;   after (strata weights content 2 / deictic 1 / grammatical 0, ties abstain):
;   17 correct, 0 WRONG, 3 honestly abstained.
; The scorer stopped lying: both old wrongs became abstentions, and the
; lucky case ("peace for all worlds", a true 2-2 content tie between "all"
; and "peace" once the accident is removed) now abstains instead of
; guessing. Plural "worlds" vs "world" names the morphology gap, next.
;
; Verdict fold: correct*10^4 + wrong*10^2 + abstain = 170003.

(do
    (defn wsl-overlap-score (tokens row-tokens)
        (if (eq (len tokens) 0) 0
            (add (if (eq (mlap-token-member? row-tokens (head tokens)) 1)
                     (ws-weight (head tokens))
                     0)
                 (wsl-overlap-score (tail tokens) row-tokens))))
    ; track best AND second-best; a tie at the top is ambiguity -> abstain (0)
    (defn wsl-best2-loop (tokens locale rows bm bs ss)
        (if (eq (len rows) 0)
            (if (gt bs 0) (if (gt bs ss) bm 0) 0)
            (do (let s (wsl-overlap-score tokens (slb-tokens (head rows) locale)))
                (if (gt s bs)
                    (wsl-best2-loop tokens locale (tail rows) (slb-meaning (head rows)) s bs)
                    (if (gt s ss)
                        (wsl-best2-loop tokens locale (tail rows) bm bs s)
                        (wsl-best2-loop tokens locale (tail rows) bm bs ss))))))
    (defn wsl-locate (tokens locale) (wsl-best2-loop tokens locale (slb-lines) 0 0 0))
    (defn wsl-count (cases correct wrong abstain)
        (if (eq (len cases) 0) (add (mul correct 10000) (add (mul wrong 100) abstain))
            (do (let c (head cases))
                (let got (wsl-locate (pgb-tokens c) "en"))
                (if (eq got (pgb-meaning c))
                    (wsl-count (tail cases) (add correct 1) wrong abstain)
                    (if (eq got 0)
                        (wsl-count (tail cases) correct wrong (add abstain 1))
                        (wsl-count (tail cases) correct (add wrong 1) abstain))))))
    (defn deixis-strata-locate-band ()
        (if (eq (wsl-count (pgb-cases) 0 0 0) 170003) 170003 0))
    (deixis-strata-locate-band))
