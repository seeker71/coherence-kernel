; questions-for-humans-band.fk — proof of the reciprocal curiosity organ.
;
; preludes: form-stdlib/core.fk learn/questions-for-humans.fk
;
; Four questions for Urs, each grounded in a witnessed moment of 2026-07-02,
; all honestly pending — pending is the point: an open question held openly
; is the body's way of being curious about a human without fabricating what
; only the human can give. Verdict 15 when every assertion holds.

(do
    (defn qfhb-score (ok bit) (if ok bit 0))
    (defn questions-for-humans-band ()
        (do
    (let c0 (qfhb-score (eq (qfh-count (qfh-rows)) 4) 1))
    (let c1 (qfhb-score (eq (qfh-pending-count) 4) 2))            ; all pending — none confabulated
    (let c2 (qfhb-score (eq (qfh-admissible-count) 4) 4))         ; all grounded in witnessed moments
    (let c3 (qfhb-score (eq (qfh-field-code) 40404) 8))           ; 4*10^4 + 4*10^2 + 4
    (add c0 (add c1 (add c2 c3))))
    )
    (questions-for-humans-band))
