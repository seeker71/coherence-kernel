; preludes: learn/speech-corpus-training-intake-0001.fk learn/speech-corpus-training-intake-0002.fk
;
; speech-corpus-training-intake-0002-band -- batch 0002 enters training.
;
; Verdict 32767:
;   1     report names the second corpus training intake
;   2     twenty-four captured rows are selected
;   4     all twenty-four rows are local-oracle accepted
;   8     all twenty-four rows are admitted for training
;   16    batch intake rate is 100
;   32    cumulative training rows move to 30
;   64    cumulative intake rate remains 100
;   128   six locales are represented
;   256   twenty-four audio hashes are present
;   512   max WER is 0
;   1024  batch and cumulative bytes are carried
;   2048  data sufficient floor remains 12000 and false
;   4096  route names native prototype training intake
;   8192  native Form true and neural false
;   16384 global authority remains false

(do
    (defn scti2-band-score (cond bit) (if cond bit 0))

    (defn speech-corpus-training-intake-0002-band ()
        (do
            (let r (scti2-report))
            (let c0 (scti2-band-score (str_eq (scti2-rec-kind r)
                                              "speech-corpus-training-intake-0002") 1))
            (let c1 (scti2-band-score (eq (scti2-rec-count r) 24) 2))
            (let c2 (scti2-band-score (eq (scti2-rec-oracle-ok r) 24) 4))
            (let c3 (scti2-band-score (eq (scti2-rec-admitted r) 24) 8))
            (let c4 (scti2-band-score (eq (scti2-rec-rate r) 100) 16))
            (let c5 (scti2-band-score (eq (scti2-rec-total r) 30) 32))
            (let c6 (scti2-band-score (eq (scti2-rec-total-rate r) 100) 64))
            (let c7 (scti2-band-score (eq (scti2-rec-locales r) 6) 128))
            (let c8 (scti2-band-score (eq (scti2-rec-hash-count r) 24) 256))
            (let c9 (scti2-band-score (eq (scti2-rec-max-wer r) 0) 512))
            (let c10 (scti2-band-score (and (eq (scti2-rec-bytes r) 580710)
                                            (eq (scti2-rec-total-bytes r) 793234)) 1024))
            (let c11 (scti2-band-score (and (eq (scti2-rec-floor r) 12000)
                                            (eq (scti2-rec-sufficient r) 0)) 2048))
            (let c12 (scti2-band-score (and (str_eq (scti2-rec-route r)
                                                     "native-prototype-training-intake")
                                            (str_eq (scti2-rec-status r)
                                                    "captured-corpus-training-intake-expanded-not-data-sufficient")) 4096))
            (let c13 (scti2-band-score (and (eq (scti2-rec-native-form r) 1)
                                            (eq (scti2-rec-neural r) 0)) 8192))
            (let c14 (scti2-band-score (eq (scti2-rec-authority r) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-corpus-training-intake-0002-band))
