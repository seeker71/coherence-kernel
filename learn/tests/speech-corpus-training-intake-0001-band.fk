; preludes:
;   learn/speech-corpus-training-intake-0001.fk
;
; speech-corpus-training-intake-0001-band -- captured rows enter training.
;
; Verdict 32767:
;   1     report names the first corpus training intake
;   2     six captured rows are selected
;   4     all six rows are local-oracle accepted
;   8     all six rows are admitted for training
;   16    intake rate is 100
;   32    six locales are represented
;   64    six audio hashes are present
;   128   max WER is 0
;   256   observed wav bytes from batch 0001 are carried
;   512   data sufficient floor remains 12000
;   1024  data sufficiency remains false
;   2048  route names native prototype training intake
;   4096  status names started but not data sufficient
;   8192  native Form true and neural false
;   16384 global authority remains false

(do
    (defn scti-band-score (cond bit) (if cond bit 0))

    (defn speech-corpus-training-intake-0001-band ()
        (do
            (let r (scti-report))
            (let c0 (scti-band-score (str_eq (scti-rec-kind r)
                                             "speech-corpus-training-intake-0001") 1))
            (let c1 (scti-band-score (eq (scti-rec-count r) 6) 2))
            (let c2 (scti-band-score (eq (scti-rec-oracle-ok r) 6) 4))
            (let c3 (scti-band-score (eq (scti-rec-admitted r) 6) 8))
            (let c4 (scti-band-score (eq (scti-rec-rate r) 100) 16))
            (let c5 (scti-band-score (eq (scti-rec-locales r) 6) 32))
            (let c6 (scti-band-score (eq (scti-rec-hash-count r) 6) 64))
            (let c7 (scti-band-score (eq (scti-rec-max-wer r) 0) 128))
            (let c8 (scti-band-score (eq (scti-rec-bytes r) 212524) 256))
            (let c9 (scti-band-score (eq (scti-rec-floor r) 12000) 512))
            (let c10 (scti-band-score (eq (scti-rec-sufficient r) 0) 1024))
            (let c11 (scti-band-score (str_eq (scti-rec-route r)
                                              "native-prototype-training-intake") 2048))
            (let c12 (scti-band-score (str_eq (scti-rec-status r)
                                              "captured-corpus-training-started-not-data-sufficient") 4096))
            (let c13 (scti-band-score (and (eq (scti-rec-native-form r) 1)
                                           (eq (scti-rec-neural r) 0)) 8192))
            (let c14 (scti-band-score (eq (scti-rec-authority r) 0) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-corpus-training-intake-0001-band))
