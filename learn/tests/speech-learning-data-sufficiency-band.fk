; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk
;
; speech-learning-data-sufficiency-band -- prove current speech data is too small.
;
; Verdict 65535:
;   1      report row names the data sufficiency surface
;   2      current wav count is 232
;   4      required wav floor is 12000
;   8      current locales meet floor
;   16     held-out repeat rows are below floor
;   32     cross-phrase rows are six
;   64     cross-voice rows are six
;   128    data-sufficient flag is false
;   256    status names tiny corpus, not training
;   512    wav underfloor bit is true
;   1024   locale underfloor bit is false
;   2048   held-out underfloor bit is true
;   4096   phrase underfloor bit is true
;   8192   voice underfloor bit is true
;   16384 native Form true and neural false
;   32768 scale gap says this is smoke instrumentation, not model learning

(do
    (defn slds-band-score (cond bit) (if cond bit 0))
    (defn slds-rec-data        (r) (nth r 1))
    (defn slds-rec-wav-under   (r) (nth r 2))
    (defn slds-rec-loc-under   (r) (nth r 3))
    (defn slds-rec-held-under  (r) (nth r 4))
    (defn slds-rec-phrase-under (r) (nth r 5))
    (defn slds-rec-voice-under (r) (nth r 6))
    (defn slds-rec-native-form (r) (nth r 8))
    (defn slds-rec-neural      (r) (nth r 9))
    (defn slds-rec-scale-gap   (r) (nth r 10))

    (defn speech-learning-data-sufficiency-band ()
        (do
            (let report (slds-report))
            (let data (slds-rec-data report))
            (let gap (slds-rec-scale-gap report))
            (let c0 (slds-band-score (str_eq (nth report 0) (slds-kind)) 1))
            (let c1 (slds-band-score (eq (slds-current-wavs data) 232) 2))
            (let c2 (slds-band-score (eq (slds-required-wavs data) 12000) 4))
            (let c3 (slds-band-score (eq (slds-rec-loc-under report) 0) 8))
            (let c4 (slds-band-score (eq (slds-rec-held-under report) 1) 16))
            (let c5 (slds-band-score (eq (slds-current-phrases data) 6) 32))
            (let c6 (slds-band-score (eq (slds-current-voices data) 6) 64))
            (let c7 (slds-band-score (eq (slds-sufficient data) 0) 128))
            (let c8 (slds-band-score (str_eq (slds-status data)
                                             "tiny-corpus-not-data-sufficient-training") 256))
            (let c9 (slds-band-score (eq (slds-rec-wav-under report) 1) 512))
            (let c10 (slds-band-score (eq (slds-rec-loc-under report) 0) 1024))
            (let c11 (slds-band-score (eq (slds-rec-held-under report) 1) 2048))
            (let c12 (slds-band-score (eq (slds-rec-phrase-under report) 1) 4096))
            (let c13 (slds-band-score (eq (slds-rec-voice-under report) 1) 8192))
            (let c14 (slds-band-score (and (eq (slds-rec-native-form report) 1)
                                           (eq (slds-rec-neural report) 0)) 16384))
            (let c15 (slds-band-score (and (str_eq (nth gap 0) "speech-learning-scale-gap")
                                           (and (eq (nth gap 3) 11768)
                                                (and (lt (nth gap 4) 200)
                                                     (and (eq (nth gap 8) 0)
                                                          (str_eq (nth gap 9)
                                                                  "repaired-instrumentation-corpus-still-not-model-learning"))))) 32768))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) (add c14 c15))))))

    (speech-learning-data-sufficiency-band))
