; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   observe/wav-sense.fk
;   learn/audio-locale-native-training.fk
;   learn/audio-locale-route-shift-ledger.fk
;
; audio-locale-route-shift-ledger-band -- before/after audio route movement.
;
; Verdict 8191:
;   1    receipt kind names the audio route-shift ledger
;   2    before route is oracle-guide
;   4    after route is native
;   8    receipt records a real shift
;   16   before native rate is below the floor
;   32   after native rate reaches the floor
;   64   A->B direction reaches native after learning
;   128  B->A direction reaches native after learning
;   256  one-way evidence still routes oracle-guide
;   512  bad oracle sample cannot create a shift
;   1024 receipt preserves oracle and device names
;   2048 native neural Metal remains pending
;   4096 metric code preserves before/after movement

(do
    (defn alrs-band-score (cond bit) (if cond bit 0))
    (defn alrs-band-truth-a () (list "the" "board" "is" "clear"))
    (defn alrs-band-truth-b () (list "die" "tafel" "ist" "leer"))
    (defn alrs-band-before-candidates ()
        (list (alnt-candidate 999 (list "not" "ready") (list 9 9 9 9))))
    (defn alrs-band-ab ()
        (alnt-sample 101 "en" "de" (alrs-band-truth-b) (alrs-band-truth-b)
                     (list 1002 1 2 3 4) 0 0 0))
    (defn alrs-band-ba ()
        (alnt-sample 201 "de" "en" (alrs-band-truth-a) (alrs-band-truth-a)
                     (list 2002 6 7 8 9) 0 0 0))
    (defn alrs-band-aa ()
        (alnt-sample 201 "en" "en" (alrs-band-truth-a) (alrs-band-truth-a)
                     (list 2003 6 7 8 9) 0 0 0))
    (defn alrs-band-bb ()
        (alnt-sample 101 "de" "de" (alrs-band-truth-b) (alrs-band-truth-b)
                     (list 1003 1 2 3 4) 0 0 0))
    (defn alrs-band-bad-oracle ()
        (alnt-sample 101 "en" "de" (alrs-band-truth-b) (list "wrong")
                     (list 1002 1 2 3 4) 0 0 0))

    (defn alrs-band-samples ()
        (list (alrs-band-ab) (alrs-band-ba) (alrs-band-aa) (alrs-band-bb)))
    (defn alrs-band-one-way ()
        (list (alrs-band-ab) (alrs-band-aa)))

    (defn audio-locale-route-shift-ledger-band ()
        (do
            (let before (alrs-band-before-candidates))
            (let samples (alrs-band-samples))
            (let rec (alrs-trained-receipt samples before "en" "de" 25 50
                                           "whisper.cpp-large-v3-turbo"
                                           "macos-arm64-m4-max"))
            (let one-way-after (alnt-trained-candidates (alrs-band-one-way) before 25))
            (let bad-rec (alrs-trained-receipt (list (alrs-band-bad-oracle)) before "en" "de" 25 50
                                                "whisper.cpp-large-v3-turbo"
                                                "macos-arm64-m4-max"))
            (let c0 (alrs-band-score (str_eq (alrs-rec-kind rec) "audio-locale-route-shift-ledger") 1))
            (let c1 (alrs-band-score (str_eq (alrs-rec-before-route rec) "oracle-guide") 2))
            (let c2 (alrs-band-score (str_eq (alrs-rec-after-route rec) "native") 4))
            (let c3 (alrs-band-score (eq (alrs-rec-shifted rec) 1) 8))
            (let c4 (alrs-band-score (lt (alrs-rec-before-rate rec) (alrs-rec-floor rec)) 16))
            (let c5 (alrs-band-score (ge (alrs-rec-after-rate rec) (alrs-rec-floor rec)) 32))
            (let c6 (alrs-band-score (ge (alrs-rec-after-ab rec) 50) 64))
            (let c7 (alrs-band-score (ge (alrs-rec-after-ba rec) 50) 128))
            (let c8 (alrs-band-score
                (str_eq (alnt-route (alrs-band-one-way) one-way-after "en" "de" 25 50) "oracle-guide")
                256))
            (let c9 (alrs-band-score (eq (alrs-rec-shifted bad-rec) 0) 512))
            (let c10 (alrs-band-score (and (str_eq (alrs-rec-oracle rec) "whisper.cpp-large-v3-turbo")
                                           (str_eq (alrs-rec-device rec) "macos-arm64-m4-max")) 1024))
            (let c11 (alrs-band-score (eq (alrs-rec-neural-metal rec) 0) 2048))
            (let c12 (alrs-band-score (gt (alrs-metric-code rec) 4000000000000) 4096))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add c8 c9)
                    (add c10 (add c11 c12))))))

    (audio-locale-route-shift-ledger-band))
