; preludes: learn/speech-model-metrics-report.fk learn/speech-oracle-native-backlog.fk learn/speech-next-trial-scheduler.fk learn/speech-open-asr-trial-window.fk learn/speech-open-asr-trial-window-0002.fk learn/speech-open-asr-trial-window-0003.fk learn/sema-voice-trial-window.fk learn/sema-voice-trial-window-0002.fk learn/speech-current-status-ledger.fk learn/speech-global-promotion-readiness.fk learn/speech-live-receipt-intake.fk learn/speech-global-authority-update.fk
;
; speech-global-authority-update-band -- apply live receipt intake to global routes.
;
; Verdict 32767:
;   1     report row names global authority update
;   2     current open dictation route remains oracle-guide with 0/3 receipts
;   4     current Sema voice route remains oracle-guide with 0/3 receipts
;   8     current aggregate has two oracle-guided lanes
;   16    current aggregate is missing six receipts
;   32    demo open dictation moves to native-open-asr-source with 3/3 receipts
;   64    demo Sema voice moves to native-sema-voice with 3/3 receipts
;   128   demo aggregate has no missing receipts
;   256   WER/confidence/latency thresholds are preserved
;   512   clean control contract is preserved
;   1024  current-empty receipt note is explicit
;   2048  three-clean live receipt note is explicit
;   4096  live receipt intake still reports current count zero
;   8192  native Form true and neural ready false
;   16384 promotion readiness still composes underneath

(do
    (defn sgau-band-score (cond bit) (if cond bit 0))

    (defn speech-global-authority-update-band ()
        (do
            (let r (sgau-report))
            (let current (nth r 1))
            (let demo (nth r 2))
            (let cur-open (nth current 0))
            (let cur-voice (nth current 1))
            (let demo-open (nth demo 0))
            (let demo-voice (nth demo 1))
            (let intake (slri-report))
            (let readiness (sgpr-report))
            (let c0 (sgau-band-score (str_eq (nth r 0) "speech-global-authority-update") 1))
            (let c1 (sgau-band-score (and (str_eq (sgau-lane-name cur-open) "live-open-dictation")
                                          (and (eq (sgau-lane-count cur-open) 0)
                                               (and (eq (sgau-lane-missing cur-open) 3)
                                                    (str_eq (sgau-lane-route cur-open) "oracle-guide")))) 2))
            (let c2 (sgau-band-score (and (str_eq (sgau-lane-name cur-voice) "sema-live-voice")
                                          (and (eq (sgau-lane-count cur-voice) 0)
                                               (and (eq (sgau-lane-missing cur-voice) 3)
                                                    (str_eq (sgau-lane-route cur-voice) "oracle-guide")))) 4))
            (let c3 (sgau-band-score (eq (nth r 3) 2) 8))
            (let c4 (sgau-band-score (eq (nth r 4) 6) 16))
            (let c5 (sgau-band-score (and (eq (sgau-lane-count demo-open) 3)
                                          (and (eq (sgau-lane-missing demo-open) 0)
                                               (str_eq (sgau-lane-route demo-open) "native-open-asr-source"))) 32))
            (let c6 (sgau-band-score (and (eq (sgau-lane-count demo-voice) 3)
                                          (and (eq (sgau-lane-missing demo-voice) 0)
                                               (str_eq (sgau-lane-route demo-voice) "native-sema-voice"))) 64))
            (let c7 (sgau-band-score (eq (nth r 7) 0) 128))
            (let c8 (sgau-band-score (and (eq (sgau-lane-max-wer demo-open) 25)
                                          (and (eq (sgau-lane-min-conf demo-open) 80)
                                               (eq (sgau-lane-max-latency demo-open) 2000))) 256))
            (let c9 (sgau-band-score (and (str_eq (sgau-lane-controls demo-open) "choice-cut-fail-undo-timeout-clean")
                                          (str_eq (sgau-lane-controls demo-voice) "choice-cut-fail-undo-timeout-clean")) 512))
            (let c10 (sgau-band-score (str_eq (nth r 8) "current-empty-receipts-stay-oracle-guide") 1024))
            (let c11 (sgau-band-score (str_eq (nth r 9) "three-clean-live-receipts-move-global-route") 2048))
            (let c12 (sgau-band-score (and (eq (nth intake 1) 0)
                                           (eq (nth intake 2) 0)) 4096))
            (let c13 (sgau-band-score (and (eq (nth r 10) 1)
                                           (eq (nth r 11) 0)) 8192))
            (let c14 (sgau-band-score (and (str_eq (nth readiness 0) "speech-global-promotion-readiness")
                                           (eq (nth readiness 5) 6)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-global-authority-update-band))
