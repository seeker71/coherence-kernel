; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-form-pair-window-0008.fk
;
; speech-form-pair-window-0008-band -- en<->fr Form-native pair window.
;
; Verdict 32767:
;   1      receipt row names window 0008
;   2      selected pair is en<->fr
;   4      Sanskrit baseline meaning 304 is used
;   8      four NL lanes are present
;   16     four audio lanes are present
;   32     before NL/audio routes are zero
;   64     after NL rate reaches 100
;   128    after audio rate reaches 100
;   256    route shifts from guide to native
;   512    local oracle is carried
;   1024   native Form is true
;   2048   neural false
;   4096   controls clean
;   8192   diffusion/neural training remain false
;   16384  status refuses neural training claim

(do
    (defn sfw8-band-score (cond bit) (if cond bit 0))

    (defn speech-form-pair-window-0008-band ()
        (do
            (let r (sfw8-receipt))
            (let c0 (sfw8-band-score (str_eq (sfw8-rec-kind r)
                                             "speech-form-pair-window-0008") 1))
            (let c1 (sfw8-band-score (and (str_eq (sfw8-rec-a r) "en")
                                          (str_eq (sfw8-rec-b r) "fr")) 2))
            (let c2 (sfw8-band-score (eq (sfw8-rec-meaning r) 304) 4))
            (let c3 (sfw8-band-score (eq (sfw8-rec-nl-lanes r) 4) 8))
            (let c4 (sfw8-band-score (eq (sfw8-rec-audio-lanes r) 4) 16))
            (let c5 (sfw8-band-score (and (eq (sfw8-rec-before-nl r) 0)
                                          (eq (sfw8-rec-before-audio r) 0)) 32))
            (let c6 (sfw8-band-score (eq (sfw8-rec-after-nl r) 100) 64))
            (let c7 (sfw8-band-score (eq (sfw8-rec-after-audio r) 100) 128))
            (let c8 (sfw8-band-score (and (eq (sfw8-rec-before-route r) 0)
                                          (and (eq (sfw8-rec-after-route r) 1)
                                               (eq (sfw8-rec-shifted r) 1))) 256))
            (let c9 (sfw8-band-score (eq (sfw8-rec-oracle r) 1) 512))
            (let c10 (sfw8-band-score (eq (sfw8-rec-native-form r) 1) 1024))
            (let c11 (sfw8-band-score (eq (sfw8-rec-neural r) 0) 2048))
            (let c12 (sfw8-band-score (eq (sfw8-rec-control r) 1) 4096))
            (let c13 (sfw8-band-score (and (eq (sfw8-rec-diffusion r) 0)
                                           (eq (sfw8-rec-trained-neural r) 0)) 8192))
            (let c14 (sfw8-band-score (str_eq (sfw8-rec-status r)
                                              "form-native-pair-window-not-neural-training") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-form-pair-window-0008-band))
