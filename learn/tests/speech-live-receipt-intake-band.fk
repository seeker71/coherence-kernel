; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/speech-open-asr-trial-window-0002.fk
;   learn/speech-open-asr-trial-window-0003.fk
;   learn/sema-voice-trial-window.fk
;   learn/speech-current-status-ledger.fk
;   learn/speech-global-promotion-readiness.fk
;   learn/speech-live-receipt-intake.fk
;
; speech-live-receipt-intake-band -- real live receipt intake for promotion.
;
; Verdict 32767:
;   1     report row names live receipt intake
;   2     current real live open-ASR receipt count is 0
;   4     current real live Sema voice receipt count is 0
;   8     required live receipts per lane is 3
;   16    three clean open-ASR rows would satisfy the lane
;   32    three clean Sema voice rows would satisfy the lane
;   64    missing audio rejects open-ASR receipt credit
;   128   fail control rejects Sema voice receipt credit
;   256   valid rows require local, consent, audio, clean controls
;   512   native WER, oracle WER, confidence, and latency gates are enforced
;   1024  current intake remains empty, not faked
;   2048  intake names three clean real live receipts as promotion input
;   4096  promotion-readiness still reports six missing receipts underneath
;   8192  native Form true and neural ready false
;   16384 current status ledger still reports global oracle-held authority

(do
    (defn slri-band-score (cond bit) (if cond bit 0))

    (defn speech-live-receipt-intake-band ()
        (do
            (let r (slri-report))
            (let open-demo (slri-demo-open-rows))
            (let voice-demo (slri-demo-voice-rows))
            (let dirty (slri-dirty-rows))
            (let readiness (sgpr-report))
            (let status (smcl-report))
            (let c0 (slri-band-score (str_eq (nth r 0) "speech-live-receipt-intake") 1))
            (let c1 (slri-band-score (eq (nth r 1) 0) 2))
            (let c2 (slri-band-score (eq (nth r 2) 0) 4))
            (let c3 (slri-band-score (eq (nth r 3) 3) 8))
            (let c4 (slri-band-score (eq (nth r 4) 1) 16))
            (let c5 (slri-band-score (eq (nth r 5) 1) 32))
            (let c6 (slri-band-score (eq (slri-count-lane dirty "live-open-dictation" 25 80 2000) 0) 64))
            (let c7 (slri-band-score (eq (slri-count-lane dirty "sema-live-voice" 25 80 2000) 0) 128))
            (let c8 (slri-band-score (and (eq (slri-valid? (nth open-demo 0)) 1)
                                          (and (eq (slri-valid? (nth voice-demo 0)) 1)
                                               (eq (slri-valid? (nth dirty 0)) 0))) 256))
            (let c9 (slri-band-score (and (eq (slri-native-success? (nth open-demo 0) 25 80 2000) 1)
                                          (and (eq (slri-native-success? (nth voice-demo 0) 25 80 2000) 1)
                                               (eq (slri-native-success? (nth dirty 1) 25 80 2000) 0))) 512))
            (let c10 (slri-band-score (str_eq (nth r 8) "current-real-live-receipts-empty") 1024))
            (let c11 (slri-band-score (str_eq (nth r 9) "three-clean-real-live-receipts-promote-a-lane") 2048))
            (let c12 (slri-band-score (eq (nth readiness 5) 6) 4096))
            (let c13 (slri-band-score (and (eq (nth r 10) 1)
                                           (eq (nth r 11) 0)) 8192))
            (let c14 (slri-band-score (and (str_eq (nth status 0) "speech-current-status-ledger")
                                           (str_eq (nth status 6) "global-live-authority-still-oracle-held")) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-live-receipt-intake-band))
