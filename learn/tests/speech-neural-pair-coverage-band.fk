; preludes:
;   learn/speech-neural-pair-coverage.fk
;
; speech-neural-pair-coverage-band -- neural pair training remains zero.
;
; Verdict 32767:
;   1      report row names neural pair coverage
;   2      neural pair count is nine
;   4      neural directed pair count is eighteen
;   8      nine neural epochs and nine parameters are enabled
;   16     broad ready pair space is 55 / 110 directed
;   32     Sanskrit baseline pair space is 45 / 90 directed
;   64     eight Form-native reciprocal pair windows are present
;   128    those eight windows cover sixteen directed cross-locale directions
;   256    roundtrip lanes carry A->B, B->A, A->A, and B->B per window
;   512    Form seeded windows have ready rate 100
;   1024   all eight windows still mark neural Metal pending
;   2048   all eight windows still mark diffusion pending
;   4096   neural broad coverage is non-zero: 1636 basis points
;   8192   Form broad/baseline coverage is 1454/1777 basis points
;   16384  status names observed neural micro-pairs, with native Form true and neural ready

(do
    (defn snpc-band-score (cond bit) (if cond bit 0))

    (defn speech-neural-pair-coverage-band ()
        (do
            (let r (snpc-report))
            (let c0 (snpc-band-score (str_eq (snpc-rec-kind r) "speech-neural-pair-coverage") 1))
            (let c1 (snpc-band-score (eq (snpc-rec-neural-pairs r) 9) 2))
            (let c2 (snpc-band-score (eq (snpc-rec-neural-directed r) 18) 4))
            (let c3 (snpc-band-score (and (eq (snpc-rec-neural-epochs r) 9)
                                          (eq (snpc-rec-neural-params r) 9)) 8))
            (let c4 (snpc-band-score (and (eq (snpc-rec-broad-pairs r) 55)
                                          (eq (snpc-rec-broad-directed r) 110)) 16))
            (let c5 (snpc-band-score (and (eq (snpc-rec-baseline-pairs r) 45)
                                          (eq (snpc-rec-baseline-directed r) 90)) 32))
            (let c6 (snpc-band-score (eq (snpc-rec-form-pairs r) 8) 64))
            (let c7 (snpc-band-score (eq (snpc-rec-form-directed r) 16) 128))
            (let c8 (snpc-band-score (eq (snpc-rec-form-roundtrip-lanes r) 32) 256))
            (let c9 (snpc-band-score (eq (snpc-rec-form-ready-rate r) 100) 512))
            (let c10 (snpc-band-score (eq (snpc-rec-neural-pending r) 8) 1024))
            (let c11 (snpc-band-score (eq (snpc-rec-diffusion-pending r) 8) 2048))
            (let c12 (snpc-band-score (eq (snpc-rec-neural-bp r) 1636) 4096))
            (let c13 (snpc-band-score (and (eq (snpc-rec-form-broad-bp r) 1454)
                                           (eq (snpc-rec-form-baseline-bp r) 1777)) 8192))
            (let c14 (snpc-band-score (and (str_eq (snpc-rec-status r)
                                                    "native-neural-micro-pair-windows-observed")
                                           (and (eq (snpc-rec-native-form r) 1)
                                                (eq (snpc-rec-neural-ready r) 1))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-neural-pair-coverage-band))
