; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;
; speech-next-trial-scheduler-band -- choose next oracle-to-native trial.
;
; Verdict 32767:
;   1     report row names the scheduler
;   2     two backlog trials are scheduled
;   4     open ASR trial is first priority
;   8     open ASR challenger is native segmented acoustic learning
;   16    open ASR uses oracle-passing live dictation as source
;   32    open ASR oracle rate is 100 and native rate is 0
;   64    open ASR promotion rule requires native rate and WER floor
;   128   Sema voice trial targets TCAV candidate search
;   256   Sema voice has local-oracle authority while native remains 0
;   512   Sema voice promotion rule requires oracle WER improvement first
;   1024  clean choice/cut/fail/undo/timeout controls are named
;   2048  model context records zero admitted neural weights
;   4096  model context records native voice organs present
;   8192  no C seed growth is recorded
;   16384 report marks native Form true and neural ready false

(do
    (defn snts-band-score (cond bit) (if cond bit 0))
    (defn snts-rec-trials      (r) (nth r 1))
    (defn snts-rec-next        (r) (nth r 2))
    (defn snts-rec-context     (r) (nth r 3))
    (defn snts-rec-count       (r) (nth r 4))
    (defn snts-rec-held        (r) (nth r 5))
    (defn snts-rec-rule        (r) (nth r 6))
    (defn snts-rec-native-form (r) (nth r 7))
    (defn snts-rec-neural-ready (r) (nth r 8))

    (defn speech-next-trial-scheduler-band ()
        (do
            (let r (snts-report))
            (let trials (snts-rec-trials r))
            (let next (snts-rec-next r))
            (let voice (nth trials 1))
            (let context (snts-rec-context r))
            (let c0 (snts-band-score (str_eq (nth r 0) "speech-next-trial-scheduler") 1))
            (let c1 (snts-band-score (and (eq (snts-rec-count r) 2)
                                          (eq (snts-rec-held r) 2)) 2))
            (let c2 (snts-band-score (and (str_eq (snts-id next) "trial-open-asr-0001")
                                          (eq (snts-priority next) 1)) 4))
            (let c3 (snts-band-score (str_eq (snts-challenger next) "native-segmented-acoustic-learning") 8))
            (let c4 (snts-band-score (str_eq (snts-source next) "oracle-passing-live-dictation-window") 16))
            (let c5 (snts-band-score (and (eq (snts-oracle-rate next) 100)
                                          (eq (snts-native-rate next) 0)) 32))
            (let c6 (snts-band-score (str_eq (snts-promote next) "native-rate>=50-and-wer<=25-clean-controls") 64))
            (let c7 (snts-band-score (and (str_eq (snts-gap voice) "sema-live-voice")
                                          (str_eq (snts-target voice) "text-conditioned-acoustic-vocoder-candidate-search")) 128))
            (let c8 (snts-band-score (and (eq (snts-oracle-rate voice) 100)
                                          (eq (snts-native-rate voice) 0)) 256))
            (let c9 (snts-band-score (str_eq (snts-promote voice) "oracle-wer<=25-then-candidate-search-promote") 512))
            (let c10 (snts-band-score (and (str_eq (snts-control next) "choice-cut-fail-undo-timeout")
                                           (str_eq (snts-control voice) "choice-cut-fail-undo-timeout")) 1024))
            (let c11 (snts-band-score (eq (nth context 1) 0) 2048))
            (let c12 (snts-band-score (eq (nth context 3) 6) 4096))
            (let c13 (snts-band-score (and (eq (nth context 6) 0)
                                           (str_eq (nth context 7) "native-form-scheduler-no-c-seed-growth")) 8192))
            (let c14 (snts-band-score (and (eq (snts-rec-native-form r) 1)
                                           (eq (snts-rec-neural-ready r) 0)) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-next-trial-scheduler-band))
