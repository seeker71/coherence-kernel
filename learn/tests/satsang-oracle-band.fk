; preludes: form-stdlib/channel-interface.fk form-stdlib/satsang.fk learn/satsang-oracle.fk
;
; satsang-oracle-band -- witnesses the folding algorithm against three committed
; EXAMPLE proposals (NOT live model output -- see satsang-oracle.fk's honest seam
; note), for the sentence "the choice point becomes visible ." Each word is a
; zero-arity leaf node (tag = lemma), the sentence a "seq" node over six children.
;
; Model A: the choice point becomes visible .
; Model B: the choice point turns   visible .   (dissents at position 3)
; Model C: the start  point grows   visible .   (dissents at positions 1 and 3)
;
; Verdict 511:
;   1    root "seq" is solid (all three models propose the same shape)
;   2    position 0 "the" is solid, unanimous (3 affirm, 0 dissent)
;   4    position 1 "choice" is solid DESPITE a dissent (2 affirm, 1 dissent, survives)
;   8    position 1's dissent stays VISIBLE in the record (dissented count is 1, not 0)
;   16   position 3 is an open question (1 affirm, 2 dissent, does NOT survive)
;   32   position 3's own tag is still named (the anchor's proposal, "becomes"),
;        even though it stayed open -- the open question is a NAMED node, not a gap
;   64   positions 2, 4, 5 are solid and unanimous
;   128  exactly 6 nodes total crystallized solid (root + 5 of 6 words), matching
;        sao-count-tree, not asserted by hand
;   256  exactly 1 node total is an open question, matching sao-count-tree

(do
    (defn sob-leaf (lemma) (sao-node lemma (empty)))
    (defn sob-seq (words) (sao-node "seq" words))

    (defn sob-model-a ()
        (sob-seq (list (sob-leaf "the") (sob-leaf "choice") (sob-leaf "point")
                       (sob-leaf "becomes") (sob-leaf "visible") (sob-leaf "."))))
    (defn sob-model-b ()
        (sob-seq (list (sob-leaf "the") (sob-leaf "choice") (sob-leaf "point")
                       (sob-leaf "turns") (sob-leaf "visible") (sob-leaf "."))))
    (defn sob-model-c ()
        (sob-seq (list (sob-leaf "the") (sob-leaf "start") (sob-leaf "point")
                       (sob-leaf "grows") (sob-leaf "visible") (sob-leaf "."))))

    (defn sob-band-score (cond bit) (if cond bit 0))

    (defn satsang-oracle-band ()
        (do
            (let out (sao-witness-council (list (sob-model-a) (sob-model-b) (sob-model-c))))
            (let children (sao-out-children out))
            (let pos0 (nth children 0))
            (let pos1 (nth children 1))
            (let pos2 (nth children 2))
            (let pos3 (nth children 3))
            (let pos4 (nth children 4))
            (let pos5 (nth children 5))

            (let c0 (sob-band-score (str_eq (sao-out-status out) "solid") 1))
            (let c1 (sob-band-score (and (str_eq (sao-out-status pos0) "solid")
                                    (and (eq (nth (sao-out-witness pos0) 0) 3)
                                         (eq (nth (sao-out-witness pos0) 1) 0))) 2))
            (let c2 (sob-band-score (str_eq (sao-out-status pos1) "solid") 4))
            (let c3 (sob-band-score (eq (nth (sao-out-witness pos1) 1) 1) 8))
            (let c4 (sob-band-score (str_eq (sao-out-status pos3) "open-question") 16))
            (let c5 (sob-band-score (str_eq (sao-out-tag pos3) "becomes") 32))
            (let c6 (sob-band-score (and (str_eq (sao-out-status pos2) "solid")
                                    (and (str_eq (sao-out-status pos4) "solid")
                                         (str_eq (sao-out-status pos5) "solid"))) 64))
            (let c7 (sob-band-score (eq (sao-count-tree out "solid") 6) 128))
            (let c8 (sob-band-score (eq (sao-count-tree out "open-question") 1) 256))

            (add
                (add (add c0 c1) (add c2 c3))
                (add (add c4 c5) (add c6 (add c7 c8))))))

    (satsang-oracle-band))
