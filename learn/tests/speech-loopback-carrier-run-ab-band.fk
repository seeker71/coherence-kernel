; preludes:
;   form/form-stdlib/hati-os-targets.fk
;   form/form-stdlib/host-os-membrane.fk
;   observe/stt-wer.fk
;   learn/speech-loopback-promotion.fk
;   presence/speech-loopback-carrier-receipt.fk
;   learn/speech-loopback-recipe-ab.fk
;   presence/speech-loopback-carrier-run.fk
;
; speech-loopback-carrier-run-ab-band -- carrier-gated recipe A/B.
;
; Verdict 2047:
;   1    ready carrier can feed the A/B decision cell
;   2    incumbent routes native with one miss
;   4    challenger cuts over when native score wins
;   8    run record preserves Android target
;   16   run record preserves ready state
;   32   run record preserves cut action
;   64   missing capture turns the same window into fail-incumbent
;   128  timeout keeps incumbent
;   256  undo keeps incumbent
;   512  challenger native evidence is recorded
;   1024 challenger lower latency is recorded

(do
    (defn slrab-score (cond bit) (if cond bit 0))
    (defn slrab-truth () (list "we" "are"))
    (defn slrab-cap ()
        (slr-capability "android-arm64" 1 1 1 1 16000 1 1))
    (defn slrab-nocap ()
        (slr-capability "android-arm64" 1 0 1 1 16000 1 1))
    (defn slrab-receipt (sid native latency fail timeout undo)
        (slc-receipt sid 10 111 222 16000 1
                     1 1
                     (slrab-truth)
                     (slrab-truth)
                     native
                     95 latency
                     fail timeout undo))
    (defn slrab-good (sid latency)
        (slrab-receipt sid (slrab-truth) latency 0 0 0))
    (defn slrab-bad (sid latency)
        (slrab-receipt sid (list "go" "home") latency 0 0 0))
    (defn slrab-incumbent ()
        (list (slrab-good 1 60)
              (slrab-good 2 60)
              (slrab-good 3 60)
              (slrab-bad 4 60)))
    (defn slrab-challenger ()
        (list (slrab-good 5 40)
              (slrab-good 6 40)
              (slrab-good 7 40)
              (slrab-good 8 40)))
    (defn slrab-decision (cap fail timeout undo)
        (slr-decision-from-receipts cap 100 (slrab-incumbent) 200 (slrab-challenger)
                                    10 80 100 4 1 0 3 fail timeout undo))

    (defn speech-loopback-carrier-run-ab-band ()
        (do
            (let cap (slrab-cap))
            (let nocap (slrab-nocap))
            (let ready (slrab-decision cap 0 0 0))
            (let unready (slrab-decision nocap 0 0 0))
            (let timeoutd (slrab-decision cap 0 1 0))
            (let undod (slrab-decision cap 0 0 1))
            (let run (slr-run-record 77 cap ready))
            (let c0 (slrab-score (eq (slr-ready? cap) 1) 1))
            (let c1 (slrab-score (and (str_eq (slab-dec-inc-route ready) "native")
                                      (eq (slab-dec-inc-native ready) 3)) 2))
            (let c2 (slrab-score (and (eq (slab-dec-chosen ready) 200)
                                      (str_eq (slab-dec-action ready) "cut-challenger")) 4))
            (let c3 (slrab-score (str_eq (slr-run-target run) "android-arm64") 8))
            (let c4 (slrab-score (eq (slr-run-ready run) 1) 16))
            (let c5 (slrab-score (str_eq (slr-run-action run) "cut-challenger") 32))
            (let c6 (slrab-score (and (eq (slab-dec-chosen unready) 100)
                                      (str_eq (slab-dec-action unready) "fail-incumbent")) 64))
            (let c7 (slrab-score (and (eq (slab-dec-chosen timeoutd) 100)
                                      (str_eq (slab-dec-action timeoutd) "timeout-incumbent")) 128))
            (let c8 (slrab-score (and (eq (slab-dec-chosen undod) 100)
                                      (str_eq (slab-dec-action undod) "undo-incumbent")) 256))
            (let c9 (slrab-score (eq (slr-run-ch-native run) 4) 512))
            (let c10 (slrab-score (lt (slr-run-ch-latency run) (slr-run-inc-latency run)) 1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add c8 (add c9 c10)))))

    (speech-loopback-carrier-run-ab-band))
