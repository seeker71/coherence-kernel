; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk learn/speech-native-neural-pair-window-0005.fk
;
; speech-native-neural-pair-window-0005-band -- fifth non-zero neural pair.
;
; Verdict 32767:
;   1      receipt row names neural pair window 0005
;   2      pair is en<->ar
;   4      Sanskrit baseline meaning 304 is used
;   8      cumulative trained pairs are five
;   16     cumulative directed routes are ten
;   32     five epochs and five parameters are recorded
;   64     neural rate moves 0 -> 100
;   128    route shifts
;   256    underlying Form NL/audio rates are 100
;   512    bootstrap loss moves 1 -> 0
;   1024   oracle/native/neural flags are true
;   2048   open authority is false
;   4096   after rate clears floor
;   8192   pair increment is one and directed increment is two
;   16384  status names micro-pair 0005, not open authority

(do
    (defn snpw5-band-score (cond bit) (if cond bit 0))

    (defn speech-native-neural-pair-window-0005-band ()
        (do
            (let r (snpw5-receipt))
            (let c0 (snpw5-band-score (str_eq (snpw5-rec-kind r)
                                              "speech-native-neural-pair-window-0005") 1))
            (let c1 (snpw5-band-score (and (str_eq (snpw5-rec-a r) "en")
                                           (str_eq (snpw5-rec-b r) "ar")) 2))
            (let c2 (snpw5-band-score (eq (snpw5-rec-meaning r) 304) 4))
            (let c3 (snpw5-band-score (eq (snpw5-rec-cumulative-pairs r) 5) 8))
            (let c4 (snpw5-band-score (eq (snpw5-rec-cumulative-directed r) 10) 16))
            (let c5 (snpw5-band-score (and (eq (snpw5-rec-epochs r) 5)
                                           (eq (snpw5-rec-params r) 5)) 32))
            (let c6 (snpw5-band-score (and (eq (snpw5-rec-before-rate r) 0)
                                           (eq (snpw5-rec-after-rate r) 100)) 64))
            (let c7 (snpw5-band-score (eq (snpw5-rec-shifted r) 1) 128))
            (let c8 (snpw5-band-score (and (eq (snpw5-rec-form-nl r) 100)
                                           (eq (snpw5-rec-form-audio r) 100)) 256))
            (let c9 (snpw5-band-score (and (eq (snpw5-rec-before-loss r) 1)
                                           (eq (snpw5-rec-after-loss r) 0)) 512))
            (let c10 (snpw5-band-score (and (eq (snpw5-rec-oracle r) 1)
                                            (and (eq (snpw5-rec-native-form r) 1)
                                                 (eq (snpw5-rec-neural r) 1))) 1024))
            (let c11 (snpw5-band-score (eq (snpw5-rec-open-authority r) 0) 2048))
            (let c12 (snpw5-band-score (ge (snpw5-rec-after-rate r) 50) 4096))
            (let c13 (snpw5-band-score (and (eq (snpw5-rec-pair-increment r) 1)
                                            (eq (snpw5-rec-directed-increment r) 2)) 8192))
            (let c14 (snpw5-band-score (str_eq (snpw5-rec-status r)
                                               "native-neural-micro-pair-0005-trained-not-open-authority") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add c12 (add c13 c14))))))

    (speech-native-neural-pair-window-0005-band))
