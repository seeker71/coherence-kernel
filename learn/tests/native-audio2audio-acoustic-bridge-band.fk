; preludes: observe/stt-wer.fk presence/formant-vocoder.fk observe/speech-token-stream.fk learn/sanskrit-locale-baseline.fk learn/text-conditioned-acoustic-vocoder.fk learn/native-audio2audio-acoustic-bridge.fk
;
; native-audio2audio-acoustic-bridge-band -- decoded audio A to acoustic audio B.
;
; Verdict 32767:
;   1     row names the native audio2audio acoustic bridge
;   2     source Sanskrit tokens carry neutral meaning 302
;   4     target Latin text is rendered from the neutral meaning
;   8     target acoustic frames render nonzero native samples
;   16    target speech token stream preserves words plus receipt token
;   32    exact sa->la source and target transcripts pass
;   64    reciprocal sa<->la window routes native at the 50 floor
;   128   one-way window remains oracle-guided
;   256   bad source transcript blocks the row
;   512   bad target transcript blocks the row
;   1024  fail, timeout, and undo controls block pass
;   2048  missing consent or audio blocks pass
;   4096  voice-side metadata survives into target acoustic frames
;   8192  receipt records local Metal oracle and native Form, neural pending
;   16384 receipt preserves direction counts and target frame/sample evidence

(do
    (defn naab-band-score (cond bit) (if cond bit 0))
    (defn naab-band-meta () (sts-meta 92 82 71 8 44 88))
    (defn naab-band-row () (slb-line-by-meaning 302))
    (defn naab-band-sa ()
        (naab-row 9601 "sa" "la" 302
                  (slb-tokens (naab-band-row) "sa")
                  "satyam eva jayate"
                  "veritas sola vincit"
                  (naab-band-meta)
                  960101 960201 1 1 0 0 0))
    (defn naab-band-la ()
        (naab-row 9602 "la" "sa" 302
                  (slb-tokens (naab-band-row) "la")
                  "veritas sola vincit"
                  "satyam eva jayate"
                  (naab-band-meta)
                  960102 960202 1 1 0 0 0))
    (defn naab-band-bad-source ()
        (naab-row 9603 "sa" "la" 302
                  (slb-tokens (naab-band-row) "sa")
                  "wrong words"
                  "veritas sola vincit"
                  (naab-band-meta)
                  960103 960203 1 1 0 0 0))
    (defn naab-band-bad-target ()
        (naab-row 9604 "sa" "la" 302
                  (slb-tokens (naab-band-row) "sa")
                  "satyam eva jayate"
                  "wrong words"
                  (naab-band-meta)
                  960104 960204 1 1 0 0 0))
    (defn naab-band-control (fail timeout undo)
        (naab-row 9605 "sa" "la" 302
                  (slb-tokens (naab-band-row) "sa")
                  "satyam eva jayate"
                  "veritas sola vincit"
                  (naab-band-meta)
                  960105 960205 1 1 fail timeout undo))
    (defn naab-band-no-consent ()
        (naab-row 9606 "sa" "la" 302
                  (slb-tokens (naab-band-row) "sa")
                  "satyam eva jayate"
                  "veritas sola vincit"
                  (naab-band-meta)
                  960106 960206 1 0 0 0 0))
    (defn naab-band-no-audio ()
        (naab-row 9607 "sa" "la" 302
                  (slb-tokens (naab-band-row) "sa")
                  "satyam eva jayate"
                  "veritas sola vincit"
                  (naab-band-meta)
                  0 960207 1 1 0 0 0))

    (defn native-audio2audio-acoustic-bridge-band ()
        (do
            (let sa (naab-band-sa))
            (let la (naab-band-la))
            (let rows (list sa la))
            (let target (naab-target-sample sa))
            (let frames (naab-target-frames sa))
            (let samples (naab-target-samples sa))
            (let stream (tcav-stream 9601 (naab-target-tokens sa) (nth sa 8)))
            (let rec (naab-receipt rows "sa" "la" 25 50
                                   "whisper.cpp-large-v3-turbo"
                                   "macos-arm64-m4-max"))
            (let c0 (naab-band-score
                        (str_eq (nth sa 0) "native-audio2audio-acoustic-bridge-row") 1))
            (let c1 (naab-band-score (eq (nth sa 4) 302) 2))
            (let c2 (naab-band-score
                        (str_eq (naab-target-text sa) "veritas sola vincit") 4))
            (let c3 (naab-band-score
                        (and (gt (len frames) 0) (gt (fv-energy samples) 0)) 8))
            (let c4 (naab-band-score
                        (and (str_eq (sts-transcript stream) "veritas sola vincit")
                             (eq (sts-count-tag stream (sts-receipt-tag)) 1)) 16))
            (let c5 (naab-band-score
                        (and (eq (naab-source-ok? sa 25) 1)
                             (eq (naab-target-ok? sa 25) 1)) 32))
            (let c6 (naab-band-score
                        (str_eq (naab-window-route rows "sa" "la" 25 50)
                                "native-audio2audio-acoustic-vocoder") 64))
            (let c7 (naab-band-score
                        (str_eq (naab-window-route (list sa) "sa" "la" 25 50)
                                "oracle-guide") 128))
            (let c8 (naab-band-score (eq (naab-pass? (naab-band-bad-source) 25) 0) 256))
            (let c9 (naab-band-score (eq (naab-pass? (naab-band-bad-target) 25) 0) 512))
            (let c10 (naab-band-score
                        (and (eq (naab-pass? (naab-band-control 1 0 0) 25) 0)
                             (and (eq (naab-pass? (naab-band-control 0 1 0) 25) 0)
                                  (eq (naab-pass? (naab-band-control 0 0 1) 25) 0))) 1024))
            (let c11 (naab-band-score
                        (and (eq (naab-pass? (naab-band-no-consent) 25) 0)
                             (eq (naab-pass? (naab-band-no-audio) 25) 0)) 2048))
            (let c12 (naab-band-score
                        (and (eq (sts-attunement (tcav-af-meta (head frames))) 88)
                             (eq (sts-cadence (tcav-af-meta (head frames))) 71)) 4096))
            (let c13 (naab-band-score
                        (and (str_eq (nth rec 9) "whisper.cpp-large-v3-turbo")
                             (and (eq (nth rec 11) 1)
                                  (and (eq (nth rec 12) 1)
                                       (eq (nth rec 13) 0)))) 8192))
            (let c14 (naab-band-score
                        (and (eq (nth rec 6) 1)
                             (and (eq (nth rec 7) 1)
                                  (and (gt (nth rec 14) 0)
                                       (gt (nth rec 15) 0)))) 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (native-audio2audio-acoustic-bridge-band))
