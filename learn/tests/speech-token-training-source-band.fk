; preludes: observe/speech-token-stream.fk learn/speech-token-training-source.fk
;
; speech-token-training-source-band -- token labels from oracle/corpus/state.
;
; Verdict 32767:
;   1     local oracle rows can train transcript words and metadata
;   2     consentful corpus rows can augment text token training
;   4     internal state rows can train metadata only
;   8     internal state is blocked from claiming transcript truth
;   16    missing consent blocks both word and metadata training
;   32    fail/undo/timeout/cut controls block training credit
;   64    local oracle stream preserves identity/provenance/route tokens
;   128   control tokens are present in the stream
;   256   evidence and memory/scope tokens are present in the stream
;   512   words roundtrip through the training stream
;   1024  inferred confidence and hesitation come from internal state
;   2048  inferred warmth/cadence/excitement/attunement come from internal state
;   4096  all stream token rows carry valid voice-side metadata
;   8192  aggregate receipt separates word rows from metadata rows
;   16384 source set names oracle, corpus, and internal-state lanes

(do
    (defn stts-band-score (cond bit) (if cond bit 0))
    (defn stts-band-words () (list "satyam" "eva" "jayate"))
    (defn stts-band-oracle ()
        (stts-local-oracle-row
            9501
            "whisper.cpp-large-v3-turbo-metal"
            "audio"
            (stts-band-words)
            0
            950101
            (sts-meta 94 76 72 8 31 84)))
    (defn stts-band-corpus ()
        (stts-corpus-row
            9502
            "sanskrit-locale-baseline"
            (stts-band-words)
            (sts-meta 90 80 70 10 30 86)))
    (defn stts-band-state ()
        (stts-internal-row
            9503
            (stts-internal-state 3 8 4 2 4)
            (stts-band-words)
            (stts-controls 1 0 0 0 0)))
    (defn stts-band-no-consent ()
        (stts-row 9504 "consentful-corpus" "blocked-corpus" "text-sidecar" "translated-corpus"
                  "words+meta" 0 (stts-band-words) (sts-meta 90 80 70 10 30 86)
                  (stts-controls 1 0 0 0 0) "missing-consent" "corpus-line"))
    (defn stts-band-fail ()
        (stts-row 9505 "local-oracle" "whisper.cpp-local" "audio" "local-oracle-transcript"
                  "words+meta" 1 (stts-band-words) (sts-meta 90 80 70 10 30 86)
                  (stts-controls 1 1 0 0 0) "fail-control" "utterance"))

    (defn speech-token-training-source-band ()
        (do
            (let oracle (stts-band-oracle))
            (let corpus (stts-band-corpus))
            (let state (stts-band-state))
            (let blocked (stts-band-no-consent))
            (let fail (stts-band-fail))
            (let stream (stts-training-stream oracle))
            (let state-meta (stts-meta state))
            (let receipt (stts-receipt (list oracle corpus state blocked fail)))
            (let c0 (stts-band-score (and (eq (stts-can-train-words? oracle) 1)
                                          (eq (stts-can-train-meta? oracle) 1)) 1))
            (let c1 (stts-band-score (eq (stts-can-train-words? corpus) 1) 2))
            (let c2 (stts-band-score (and (eq (stts-can-train-words? state) 0)
                                          (eq (stts-can-train-meta? state) 1)) 4))
            (let c3 (stts-band-score (eq (stts-word-truth? state) 0) 8))
            (let c4 (stts-band-score (and (eq (stts-can-train-words? blocked) 0)
                                          (eq (stts-can-train-meta? blocked) 0)) 16))
            (let c5 (stts-band-score (and (eq (stts-can-train-words? fail) 0)
                                          (eq (stts-clean-controls? (stts-controls-row fail)) 0)) 32))
            (let c6 (stts-band-score (and (eq (sts-count-tag stream (sts-node-tag)) 1)
                                          (and (eq (sts-count-tag stream (sts-source-tag)) 1)
                                               (eq (sts-count-tag stream (sts-channel-tag)) 1))) 64))
            (let c7 (stts-band-score (and (eq (sts-count-tag stream (sts-choice-tag)) 1)
                                          (and (eq (sts-count-tag stream (sts-fail-tag)) 1)
                                               (and (eq (sts-count-tag stream (sts-cut-tag)) 1)
                                                    (and (eq (sts-count-tag stream (sts-undo-tag)) 1)
                                                         (eq (sts-count-tag stream (sts-timeout-tag)) 1))))) 128))
            (let c8 (stts-band-score (and (eq (sts-count-tag stream (sts-observe-tag)) 1)
                                          (and (eq (sts-count-tag stream (sts-grade-tag)) 1)
                                               (and (eq (sts-count-tag stream (sts-memory-tag)) 1)
                                                    (eq (sts-count-tag stream (sts-scope-tag)) 1)))) 256))
            (let c9 (stts-band-score (str_eq (sts-transcript stream) "satyam eva jayate") 512))
            (let c10 (stts-band-score (and (eq (sts-confidence state-meta) 60)
                                           (eq (sts-hesitation state-meta) 60)) 1024))
            (let c11 (stts-band-score (and (eq (sts-warmth state-meta) 80)
                                           (and (eq (sts-cadence state-meta) 60)
                                                (and (eq (sts-excitement state-meta) 40)
                                                     (eq (sts-attunement state-meta) 100)))) 2048))
            (let c12 (stts-band-score (eq (sts-meta-valid-stream? stream) 1) 4096))
            (let c13 (stts-band-score (and (eq (stts-rec-count receipt) 5)
                                           (and (eq (stts-rec-word-rows receipt) 2)
                                                (eq (stts-rec-meta-rows receipt) 3))) 8192))
            (let c14 (stts-band-score (str_eq (stts-rec-sources receipt)
                                              "local-oracle+consentful-corpus+internal-state") 16384))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) c14)))))

    (speech-token-training-source-band))
