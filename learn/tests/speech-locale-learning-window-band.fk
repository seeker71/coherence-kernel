; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/diverse-locale-pairing.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-locale-learning-window.fk
;
; speech-locale-learning-window-band -- selected pair becomes observed window.
;
; Verdict 16383:
;   1     receipt kind code names the speech locale learning window
;   2     seed 2 selects the Sanskrit/Latin baseline lane
;   4     both pair sides are ready
;   8     readiness comes from baseline rows, not full self-corpus bundles
;   16    pair exposes A->B, B->A, A->A, B->B lanes
;   32    before route code is oracle-guide
;   64    after route code is native
;   128   route-shift flag is set
;   256   NL and audio rates reach 100 after learning
;   512   audio target keeps affect metadata
;   1024  AutoML/model-selector lineage is linked while diffusion stays unready
;   2048  clean controls and A/B evidence promote the challenger
;   4096  local oracle/Metal and Form-native flags are present
;   8192  neural Metal remains pending, not faked

(do
    (defn sllw-band-score (cond bit) (if cond bit 0))

    (defn sllw-band-rec ()
        (sllw-receipt 2 304 25 50
                      "whisper.cpp-large-v3-turbo"
                      "macos-arm64-m4-max"))
    (defn sllw-band-c0 ()
        (sllw-band-score (eq (sllw-rec-kind-code (sllw-band-rec)) 1701) 1))
    (defn sllw-band-c1 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-a-index rec) 5)
                                  (eq (sllw-rec-b-index rec) 7)) 2)))
    (defn sllw-band-c2 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-a-ready rec) 1)
                                  (eq (sllw-rec-b-ready rec) 1)) 4)))
    (defn sllw-band-c3 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-a-self-corpus rec) 0)
                                  (and (eq (sllw-rec-b-self-corpus rec) 0)
                                       (and (eq (sllw-rec-a-baseline rec) 1)
                                            (eq (sllw-rec-b-baseline rec) 1)))) 8)))
    (defn sllw-band-c4 ()
        (sllw-band-score (eq (sllw-rec-lanes (sllw-band-rec)) 8) 16))
    (defn sllw-band-c5 ()
        (sllw-band-score (eq (sllw-rec-before-route (sllw-band-rec)) 0) 32))
    (defn sllw-band-c6 ()
        (sllw-band-score (eq (sllw-rec-after-route (sllw-band-rec)) 1) 64))
    (defn sllw-band-c7 ()
        (sllw-band-score (eq (sllw-rec-shifted (sllw-band-rec)) 1) 128))
    (defn sllw-band-c8 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-after-nl rec) 100)
                                  (eq (sllw-rec-after-audio rec) 100)) 256)))
    (defn sllw-band-c9 ()
        (sllw-band-score (eq (sllw-rec-target-confidence (sllw-band-rec)) 90) 512))
    (defn sllw-band-c10 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-automl-linked rec) 1)
                                  (eq (sllw-rec-diffusion-ready rec) 0)) 1024)))
    (defn sllw-band-c11 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-control-clean rec) 1)
                                  (eq (sllw-rec-ab-promote rec) 1)) 2048)))
    (defn sllw-band-c12 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-oracle-metal rec) 1)
                                  (eq (sllw-rec-native-form rec) 1)) 4096)))
    (defn sllw-band-c13 ()
        (do
            (let rec (sllw-band-rec))
            (sllw-band-score (and (eq (sllw-rec-neural-metal rec) 0)
                                  (eq (sllw-rec-diffusion-ready rec) 0)) 8192)))

    (defn speech-locale-learning-window-band ()
        (add
            (add
                (add (add (sllw-band-c0) (sllw-band-c1))
                     (add (sllw-band-c2) (sllw-band-c3)))
                (add (add (sllw-band-c4) (sllw-band-c5))
                     (add (sllw-band-c6) (sllw-band-c7))))
            (add
                (add (add (sllw-band-c8) (sllw-band-c9))
                     (add (sllw-band-c10) (sllw-band-c11)))
                (add (sllw-band-c12) (sllw-band-c13)))))

    (speech-locale-learning-window-band))
