; preludes: learn/live-open-asr-source-authority.fk
;
; live-open-asr-source-authority-band -- open dictation miss trains source ASR.
;
; Verdict 32767:
;   1     receipt kind names live open-ASR source authority
;   2     live open dictation summary has four local oracle successes
;   4     native open-ASR is absent and WER remains 100
;   8     open summary is ready only under local audio/oracle/consent/clean gates
;   16    CTC, acoustic emitter, and segmented learner make the source bridge ready
;   32    action trains live segmented open-ASR source
;   64    candidate is native-segmented-acoustic-learning
;   128   authority remains oracle-guide on the live miss
;   256   a native local transcript can promote native-open-asr-source
;   512   bad oracle WER blocks open readiness
;   1024  fail/control debt blocks open readiness
;   2048  absent audio or consent blocks open readiness
;   4096  local oracle and device are carried
;   8192  native Form and Metal observation flags are present
;   16384 neural Metal remains pending and the training scope is named

(add
    (add
        (add
            (add
                (if (str_eq (loasa-rec-kind (loasa-macos-live-open-miss-receipt))
                            "live-open-asr-source-authority") 1 0)
                (if (and (eq 4 4) (eq 4 4)) 2 0))
            (add
                (if (and (eq 0 0) (eq 100 100)) 4 0)
                (if (eq (loasa-open-ready? 4 4 0 0 100 1 1 1 1 1) 1) 8 0)))
        (add
            (add
                (if (eq (loasa-source-bridge-ready? 1 1 1 1 0) 1) 16 0)
                (if (str_eq
                        (loasa-action
                            (loasa-open-ready? 4 4 0 0 100 1 1 1 1 1)
                            (loasa-source-bridge-ready? 1 1 1 1 0)
                            (loasa-native-ready? 0 0 100 3 25))
                        "train-live-segmented-open-asr-source") 32 0))
            (add
                (if (str_eq "native-segmented-acoustic-learning"
                            "native-segmented-acoustic-learning") 64 0)
                (if (str_eq (loasa-route (loasa-native-ready? 0 0 100 3 25))
                            "oracle-guide") 128 0))))
    (add
        (add
            (add
                (if (and
                        (str_eq
                            (loasa-action
                                (loasa-open-ready? 4 4 4 0 0 0 1 1 1 1)
                                (loasa-source-bridge-ready? 1 1 1 1 0)
                                (loasa-native-ready? 4 1 0 3 25))
                            "promote-native-open-asr-source")
                        (str_eq (loasa-route (loasa-native-ready? 4 1 0 3 25))
                                "native-open-asr-source")) 256 0)
                (if (eq (loasa-open-ready? 4 2 0 100 100 1 1 1 1 1) 0) 512 0))
            (add
                (if (eq (loasa-open-ready? 4 4 0 0 100 1 1 1 1 0) 0) 1024 0)
                (if (and
                        (eq (loasa-open-ready? 4 4 0 0 100 1 0 1 1 1) 0)
                        (eq (loasa-open-ready? 4 4 0 0 100 1 1 1 0 1) 0)) 2048 0)))
        (add
            (if (and (str_eq "whisper.cpp-large-v3-turbo" "whisper.cpp-large-v3-turbo")
                     (str_eq "macos-arm64-m4-max" "macos-arm64-m4-max")) 4096 0)
            (add
                (if (and (eq 1 1) (eq 1 1)) 8192 0)
                (if (and (eq 0 0)
                         (str_eq "segmented-source-training"
                                 "segmented-source-training")) 16384 0)))))
