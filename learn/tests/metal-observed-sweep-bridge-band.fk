; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/diverse-locale-pairing.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-locale-learning-window.fk
;   learn/multiseed-speech-learning-sweep.fk
;   learn/metal-observed-sweep-bridge.fk
;
; metal-observed-sweep-bridge-band -- live Metal anchor gates the sweep.
;
; Verdict 32767:
;   1      receipt kind names the bridge
;   2      multiseed sweep carries five windows and five ready windows
;   4      sweep route and coverage code are native/2725
;   8      live Metal anchor is en-de with twelve samples
;   16     live oracle ok and post-train native rate match the observed run
;   32     live A->B and B->A rates are over the requested floor
;   64     live route shifted from guided to native
;   128    anchor is ready over the floor
;   256    six live pairs are observed and the target is reached
;   512    route is full-metal-native
;   1024   full all-locale Metal native is claimed for the closed prompt carrier
;   2048   local oracle Metal and Form-native flags are present
;   4096   neural/diffusion remain pending
;   8192   local oracle and device are carried from the sweep
;   16384  observed-live-pairs at target enables full-metal-native

(do
    (let sweep (msls-receipt 25 50 "whisper.cpp-large-v3-turbo" "macos-arm64-m4-max"))
    (let anchor (mosb-anchor "en-de" 12 10 0 83 66 100 1 1 1 0))
    (let rec (mosb-receipt
                "macos-arm64-m4-max"
                "whisper.cpp-large-v3-turbo"
                5
                5
                1
                2725
                5
                5
                anchor
                50
                6
                6))
    (let c0 (if (str_eq (nth rec 0) "metal-observed-sweep-bridge") 1 0))
    (let c1 (if (eq (add (nth rec 3) (nth rec 4)) 10) 2 0))
    (let c2 (if (eq (add (if (eq (nth rec 5) 1) 1 0)
                          (if (eq (nth rec 6) 2725) 1 0)) 2) 4 0))
    (let c3 (if (eq (add (if (str_eq (nth rec 7) "en-de") 1 0)
                          (if (eq (nth rec 8) 12) 1 0)) 2) 8 0))
    (let c4 (if (eq (add (if (eq (nth rec 9) 10) 1 0)
                          (if (eq (nth rec 11) 83) 1 0)) 2) 16 0))
    (let c5 (if (eq (add (if (ge (nth rec 12) 50) 1 0)
                          (if (ge (nth rec 13) 50) 1 0)) 2) 32 0))
    (let c6 (if (eq (add (if (eq (nth rec 10) 0) 1 0)
                          (if (eq (nth rec 14) 1) 1 0)) 2) 64 0))
    (let c7 (if (eq (nth rec 15) 1) 128 0))
    (let c8 (if (eq (add (add (if (eq (nth rec 16) 6) 1 0)
                               (if (eq (nth rec 17) 6) 1 0))
                          (if (eq (nth rec 18) 0) 1 0)) 3) 256 0))
    (let c9 (if (str_eq (nth rec 19) "full-metal-native") 512 0))
    (let c10 (if (eq (nth rec 20) 1) 1024 0))
    (let c11 (if (eq (add (nth rec 21) (nth rec 22)) 2) 2048 0))
    (let c12 (if (eq (add (nth rec 23) (if (eq (nth rec 24) 5) 1 0)) 2) 4096 0))
    (let c13 (if (eq (add (if (str_eq (nth rec 2) "whisper.cpp-large-v3-turbo") 1 0)
                           (if (str_eq (nth rec 1) "macos-arm64-m4-max") 1 0)) 2) 8192 0))
    (let c14 (if (eq (add (if (eq (nth rec 16) (nth rec 17)) 1 0)
                           (if (str_eq (nth rec 19) "full-metal-native") 1 0)) 2) 16384 0))
    (add
        (add
            (add (add c0 c1) (add c2 c3))
            (add (add c4 c5) (add c6 c7)))
        (add
            (add (add c8 c9) (add c10 c11))
            (add c12 (add c13 c14)))))
