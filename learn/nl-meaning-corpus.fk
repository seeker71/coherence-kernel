; nl-meaning-corpus.fk -- a real, hand-authored corpus for nl-meaning-net.fk's trained
; classifier: 4 meaning classes (the same 4 rows sanskrit-locale-baseline.fk anchors:
; 301 wellbeing/happiness, 302 truth triumphs, 303 self/existence, 304 world peace),
; ~50 examples per class, mixing short paraphrases with genuinely complex/compound
; sentences and a handful of real multi-locale baseline renderings.
;
; HONEST SOURCING: these are hand-authored for this training demo, not scraped from
; an external corpus -- labeled as such per this body's never-fabricate discipline.
; Class ids are plain 0..3, mapped 1:1 to meanings 301/302/303/304.
;
; preludes: learn/sanskrit-locale-baseline.fk

(do
    (defn nmc-ex (text class-id) (list text class-id))
    (defn nmc-ex-text  (e) (nth e 0))
    (defn nmc-ex-class (e) (nth e 1))

    ; --- class 0: wellbeing / happiness (meaning 301) ---
    (defn nmc-class0 ()
        (list
            (nmc-ex "may all be happy" 0)
            (nmc-ex "wish all beings happiness" 0)
            (nmc-ex "hope everyone is happy" 0)
            (nmc-ex "all beings be happy" 0)
            (nmc-ex "happiness for everyone" 0)
            (nmc-ex "let all be happy" 0)
            (nmc-ex "may every being find joy" 0)
            (nmc-ex "wishing happiness to all creatures" 0)
            (nmc-ex "let everyone feel contentment" 0)
            (nmc-ex "may joy fill every heart" 0)
            (nmc-ex "happiness to every living being" 0)
            (nmc-ex "all creatures deserve to be happy" 0)
            (nmc-ex "let happiness spread to everyone" 0)
            (nmc-ex "wishing every soul contentment and joy" 0)
            (nmc-ex "may all people everywhere find happiness" 0)
            (nmc-ex "happiness and wellbeing for all beings" 0)
            (nmc-ex "let every creature know joy and peace of mind" 0)
            (nmc-ex "may all who suffer find happiness soon" 0)
            (nmc-ex "wishing joy to friends family and strangers alike" 0)
            (nmc-ex "happiness is the wish extended to every being" 0)
            (nmc-ex "let contentment reach every corner of the world" 0)
            (nmc-ex "all beings without exception deserve happiness" 0)
            (nmc-ex "may this happiness be shared with all who live" 0)
            (nmc-ex "joy and gladness to every living creature" 0)
            (nmc-ex "wishing all beings freedom from suffering and full happiness" 0)
            (nmc-ex "happy may all beings be" 0)
            (nmc-ex "may every sentient being know happiness" 0)
            (nmc-ex "let all hearts be filled with gladness" 0)
            (nmc-ex "hoping happiness finds every being everywhere" 0)
            (nmc-ex "wishing contentment and joy for all creatures great and small" 0)
            (nmc-ex "the wish that all beings everywhere may be happy" 0)
            (nmc-ex "happiness for all without exception or condition" 0)
            (nmc-ex "may gladness and ease belong to every being" 0)
            (nmc-ex "let every being rest in happiness and ease" 0)
            (nmc-ex "wishing every creature comfort and happiness always" 0)
            (nmc-ex "may all be happy" 0)
            (nmc-ex "sarve bhavantu sukhinah" 0)
            (nmc-ex "moegen alle gluecklich sein" 0)
            (nmc-ex "que todos sean felices" 0)
            (nmc-ex "que tous soient heureux" 0)
            (nmc-ex "semoga semua bahagia" 0)
            (nmc-ex "may every being everywhere be free from suffering and happy" 0)
            (nmc-ex "let happiness and ease belong to all who draw breath" 0)
            (nmc-ex "wishing lasting joy to every being in every place" 0)
            (nmc-ex "may all beings live in happiness and safety" 0)
            (nmc-ex "let every heart know gladness today and always" 0)
            (nmc-ex "happiness to all who walk this earth" 0)
            (nmc-ex "may contentment be the birthright of every being" 0)
            (nmc-ex "wishing every living thing peace of mind and joy" 0)
            (nmc-ex "let all beings be free and happy always" 0)
            (nmc-ex "may joy and ease fill the lives of all creatures" 0)
            (nmc-ex "happiness without limit to every being everywhere" 0)
            (nmc-ex "wishing all beings health happiness and peace" 0)))

    ; --- class 1: truth triumphs (meaning 302) ---
    (defn nmc-class1 ()
        (list
            (nmc-ex "truth alone triumphs" 1)
            (nmc-ex "truth alone wins" 1)
            (nmc-ex "only truth prevails" 1)
            (nmc-ex "truth wins alone" 1)
            (nmc-ex "truth triumphs" 1)
            (nmc-ex "victory belongs to truth" 1)
            (nmc-ex "in the end truth always wins" 1)
            (nmc-ex "truth alone stands victorious" 1)
            (nmc-ex "nothing but the truth prevails" 1)
            (nmc-ex "truth conquers every falsehood" 1)
            (nmc-ex "the truth will always come out on top" 1)
            (nmc-ex "falsehood cannot defeat the truth" 1)
            (nmc-ex "truth alone is victorious over lies" 1)
            (nmc-ex "no matter what only truth survives" 1)
            (nmc-ex "truth is the only thing that truly wins" 1)
            (nmc-ex "however long it takes truth prevails in the end" 1)
            (nmc-ex "lies may spread but truth alone endures and triumphs" 1)
            (nmc-ex "when falsehood and truth contend truth always wins" 1)
            (nmc-ex "truth alone triumphs never falsehood" 1)
            (nmc-ex "the victory of truth over deception is certain" 1)
            (nmc-ex "truth stands firm and eventually triumphs over all lies" 1)
            (nmc-ex "only what is true can ultimately prevail" 1)
            (nmc-ex "truth alone shall triumph in every trial" 1)
            (nmc-ex "however dark the lie truth alone will triumph" 1)
            (nmc-ex "truth wins because falsehood cannot sustain itself" 1)
            (nmc-ex "let truth triumph over every deception" 1)
            (nmc-ex "the truth always rises above every lie" 1)
            (nmc-ex "truth is victorious no matter the opposition" 1)
            (nmc-ex "in every contest between truth and lies truth prevails" 1)
            (nmc-ex "truth alone endures when all falsehood fades away" 1)
            (nmc-ex "though lies may win for a while truth triumphs in the end" 1)
            (nmc-ex "truth is the only victor when falsehood is unmasked" 1)
            (nmc-ex "truth alone is unshakeable and always triumphant" 1)
            (nmc-ex "no lie can withstand the eventual triumph of truth" 1)
            (nmc-ex "truth prevails" 1)
            (nmc-ex "satyam eva jayate" 1)
            (nmc-ex "die wahrheit allein siegt" 1)
            (nmc-ex "solo la verdad triunfa" 1)
            (nmc-ex "seule la verite triomphe" 1)
            (nmc-ex "kebenaran saja menang" 1)
            (nmc-ex "truth outlasts every lie that is ever told" 1)
            (nmc-ex "no deception can outlive the truth forever" 1)
            (nmc-ex "truth alone remains standing when lies collapse" 1)
            (nmc-ex "eventually truth wins even against the strongest lies" 1)
            (nmc-ex "the triumph of truth over falsehood is inevitable" 1)
            (nmc-ex "truth cannot be permanently buried by lies" 1)
            (nmc-ex "in the long run truth always comes out ahead" 1)
            (nmc-ex "falsehood fades but truth alone remains victorious" 1)
            (nmc-ex "truth wins every time it is truly tested" 1)
            (nmc-ex "no amount of deceit can stop truth from triumphing" 1)
            (nmc-ex "truth ultimately defeats every lie told against it" 1)
            (nmc-ex "truth's victory over falsehood is only a matter of time" 1)))

    ; --- class 2: self / existence (meaning 303) ---
    (defn nmc-class2 ()
        (list
            (nmc-ex "i am" 2)
            (nmc-ex "i exist" 2)
            (nmc-ex "i am here" 2)
            (nmc-ex "here i am" 2)
            (nmc-ex "i myself am" 2)
            (nmc-ex "i simply exist" 2)
            (nmc-ex "my existence is present" 2)
            (nmc-ex "i am present in this moment" 2)
            (nmc-ex "the self that i am exists now" 2)
            (nmc-ex "i know that i exist" 2)
            (nmc-ex "my presence is real and undeniable" 2)
            (nmc-ex "i am the one who is here" 2)
            (nmc-ex "existence itself confirms that i am" 2)
            (nmc-ex "here and now i simply am" 2)
            (nmc-ex "i am the awareness that is present" 2)
            (nmc-ex "whatever else is true i am here" 2)
            (nmc-ex "my being exists independent of circumstance" 2)
            (nmc-ex "i am aware that i am present" 2)
            (nmc-ex "the fact of my existence cannot be denied" 2)
            (nmc-ex "i remain present regardless of what changes around me" 2)
            (nmc-ex "at the center of all experience i simply am" 2)
            (nmc-ex "my presence persists through every passing moment" 2)
            (nmc-ex "i exist prior to any thought about existing" 2)
            (nmc-ex "before anything else is known i am" 2)
            (nmc-ex "i am the constant presence beneath all change" 2)
            (nmc-ex "i affirm my own existence in this instant" 2)
            (nmc-ex "i am here now as i have always been" 2)
            (nmc-ex "the self persists as pure presence" 2)
            (nmc-ex "i am the witness that is always present" 2)
            (nmc-ex "i exist as the one aware of all experience" 2)
            (nmc-ex "i am, simply and completely, here" 2)
            (nmc-ex "my presence needs no further proof than itself" 2)
            (nmc-ex "i am that which remains when all else is set aside" 2)
            (nmc-ex "i am present" 2)
            (nmc-ex "aham asmi" 2)
            (nmc-ex "ich bin" 2)
            (nmc-ex "yo soy" 2)
            (nmc-ex "je suis" 2)
            (nmc-ex "aku ada" 2)
            (nmc-ex "i exist here and now regardless of circumstance" 2)
            (nmc-ex "my own presence is the one thing i cannot doubt" 2)
            (nmc-ex "i am the constant thread running through every moment" 2)
            (nmc-ex "existence precedes every question i could ask about it" 2)
            (nmc-ex "i am, and that simple fact needs no further argument" 2)
            (nmc-ex "beneath every thought there remains the fact that i am" 2)
            (nmc-ex "i am present before i am anything else" 2)
            (nmc-ex "my being here is the ground beneath every experience" 2)
            (nmc-ex "i am the one constant amid all that changes" 2)
            (nmc-ex "existence itself is the quiet fact of my presence" 2)
            (nmc-ex "i remain, simply present, however things unfold" 2)))

    ; --- class 3: world peace (meaning 304) ---
    (defn nmc-class3 ()
        (list
            (nmc-ex "peace for every world" 3)
            (nmc-ex "peace for all worlds" 3)
            (nmc-ex "peace for every realm" 3)
            (nmc-ex "global peace now" 3)
            (nmc-ex "peace everywhere" 3)
            (nmc-ex "every world wants peace" 3)
            (nmc-ex "may peace reach every corner of every world" 3)
            (nmc-ex "let there be peace across all worlds and realms" 3)
            (nmc-ex "peace to all beings in every world that exists" 3)
            (nmc-ex "may every world and every being live in peace" 3)
            (nmc-ex "world peace for every nation and every people" 3)
            (nmc-ex "peace among all worlds not just one" 3)
            (nmc-ex "let peace spread across every world without exception" 3)
            (nmc-ex "may every realm however distant know lasting peace" 3)
            (nmc-ex "peace for all the worlds that turn beneath the stars" 3)
            (nmc-ex "let every world find peace instead of conflict" 3)
            (nmc-ex "may harmony and peace govern every world" 3)
            (nmc-ex "peace for all worlds seen and unseen" 3)
            (nmc-ex "every corner of every world deserves peace" 3)
            (nmc-ex "let all realms live together without war" 3)
            (nmc-ex "peace to the whole of creation in every world" 3)
            (nmc-ex "may every world know the peace that all beings seek" 3)
            (nmc-ex "let there be lasting peace throughout every world" 3)
            (nmc-ex "world upon world may all find peace together" 3)
            (nmc-ex "peace that extends to every world without limit" 3)
            (nmc-ex "may every world however far away rest in peace" 3)
            (nmc-ex "let peace be the shared inheritance of every world" 3)
            (nmc-ex "peace to all realms whether near or distant" 3)
            (nmc-ex "may harmony reign in every world that exists" 3)
            (nmc-ex "let every world set down its weapons and find peace" 3)
            (nmc-ex "peace for the whole of every world and every people in it" 3)
            (nmc-ex "may all worlds however many there are know true peace" 3)
            (nmc-ex "peace for every world" 3)
            (nmc-ex "lokah samastah sukhino bhavantu" 3)
            (nmc-ex "frieden fuer jede welt" 3)
            (nmc-ex "paz para cada mundo" 3)
            (nmc-ex "paix pour chaque monde" 3)
            (nmc-ex "damai untuk setiap dunia" 3)
            (nmc-ex "may every world large or small come to know peace" 3)
            (nmc-ex "let peace take root in every world without exception" 3)
            (nmc-ex "peace for all the worlds that have ever existed" 3)
            (nmc-ex "may conflict end and peace begin in every world" 3)
            (nmc-ex "let every world lay down its weapons for the sake of peace" 3)
            (nmc-ex "peace for every world known and yet undiscovered" 3)
            (nmc-ex "may every world find its way to lasting peace" 3)
            (nmc-ex "let peace be granted to every world without condition" 3)
            (nmc-ex "world peace extended to every realm that exists" 3)
            (nmc-ex "may all the worlds together finally know peace" 3)
            (nmc-ex "let every world share equally in a lasting peace" 3)))

    ; append doesn't exist as a working builtin on this fkwu build (confirmed:
    ; `(append (list 1 2) (list 3))` -> nothing) -- a real cons-based concat instead.
    (defn nmc-concat (a b)
        (if (eq (len a) 0) b (cons (head a) (nmc-concat (tail a) b))))
    (defn nmc-all ()
        (nmc-concat (nmc-class0) (nmc-concat (nmc-class1) (nmc-concat (nmc-class2) (nmc-class3)))))

    0)
