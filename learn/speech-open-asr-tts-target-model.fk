; speech-open-asr-tts-target-model.fk -- target full open ASR/TTS parity or better.
;
; The native neural micro-pair is not the ceiling. This cell makes the desired
; model explicit: train toward open ASR and Sema TTS that reach or beat the local
; oracle, with current authority measured separately from the target.

(do
    (defn soatm-kind () "speech-open-asr-tts-target-model")
    (defn soatm-target-open-asr () 1)
    (defn soatm-target-open-tts () 1)
    (defn soatm-target-beat-oracle () 1)
    (defn soatm-target-rate () 100)
    (defn soatm-current-open-asr-native-rate () 0)
    (defn soatm-current-open-asr-oracle-rate () 100)
    (defn soatm-current-sema-voice-native-rate () 0)
    (defn soatm-current-sema-voice-oracle-rate () 0)
    (defn soatm-current-sema-voice-native-pass () 0)
    (defn soatm-current-sema-voice-native-total () 1)
    (defn soatm-current-sema-voice-oracle-pass () 0)
    (defn soatm-current-sema-voice-oracle-total () 1)
    (defn soatm-enabled-neural-pairs () 7)
    (defn soatm-enabled-params () 7)
    (defn soatm-current-authority-ready () 0)
    (defn soatm-route-enabled () 1)

    (defn soatm-gap (target current)
        (if (ge target current) (sub target current) 0))

    (defn soatm-report ()
        (list (soatm-kind)
              (soatm-target-open-asr)
              (soatm-target-open-tts)
              (soatm-target-beat-oracle)
              (soatm-target-rate)
              (soatm-current-open-asr-native-rate)
              (soatm-current-open-asr-oracle-rate)
              (soatm-current-sema-voice-native-rate)
              (soatm-current-sema-voice-oracle-rate)
              (soatm-enabled-neural-pairs)
              (soatm-enabled-params)
              (soatm-gap (soatm-target-rate) (soatm-current-open-asr-native-rate))
              (soatm-gap (soatm-target-rate) (soatm-current-sema-voice-native-rate))
              (soatm-current-authority-ready)
              (soatm-route-enabled)
              "target-full-open-asr-tts-parity-or-better"
              (soatm-current-sema-voice-native-pass)
              (soatm-current-sema-voice-native-total)
              (soatm-current-sema-voice-oracle-pass)
              (soatm-current-sema-voice-oracle-total)))

    (defn soatm-rec-kind              (r) (nth r 0))
    (defn soatm-rec-target-asr        (r) (nth r 1))
    (defn soatm-rec-target-tts        (r) (nth r 2))
    (defn soatm-rec-beat-oracle       (r) (nth r 3))
    (defn soatm-rec-target-rate       (r) (nth r 4))
    (defn soatm-rec-open-asr-native   (r) (nth r 5))
    (defn soatm-rec-open-asr-oracle   (r) (nth r 6))
    (defn soatm-rec-voice-native      (r) (nth r 7))
    (defn soatm-rec-voice-oracle      (r) (nth r 8))
    (defn soatm-rec-neural-pairs      (r) (nth r 9))
    (defn soatm-rec-params            (r) (nth r 10))
    (defn soatm-rec-open-asr-gap      (r) (nth r 11))
    (defn soatm-rec-voice-gap         (r) (nth r 12))
    (defn soatm-rec-authority-ready   (r) (nth r 13))
    (defn soatm-rec-route-enabled     (r) (nth r 14))
    (defn soatm-rec-status            (r) (nth r 15))
    (defn soatm-rec-voice-native-pass (r) (nth r 16))
    (defn soatm-rec-voice-native-total (r) (nth r 17))
    (defn soatm-rec-voice-oracle-pass (r) (nth r 18))
    (defn soatm-rec-voice-oracle-total (r) (nth r 19))

    0)
