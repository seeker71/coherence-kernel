; speech-native-neural-pair-window-0028.fk -- twenty-eighth native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; zh<->de. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw28-kind () "speech-native-neural-pair-window-0028")
    (defn snpw28-a () "zh")
    (defn snpw28-b () "de")
    (defn snpw28-meaning () 303)
    (defn snpw28-floor () 50)
    (defn snpw28-max-wer () 25)
    (defn snpw28-meta () (mlap-meta 96 97 11 80))
    (defn snpw28-feat () (list 3040 32 2 2))
    (defn snpw28-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw28-meaning)) locale))

    (defn snpw28-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0028-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw28-oracle-locale (r) (nth r 1))
    (defn snpw28-oracle-voice  (r) (nth r 2))
    (defn snpw28-oracle-transcript (r) (nth r 3))
    (defn snpw28-oracle-wer    (r) (nth r 4))
    (defn snpw28-oracle-bytes  (r) (nth r 5))
    (defn snpw28-oracle-cksum  (r) (nth r 6))
    (defn snpw28-oracle-name   (r) (nth r 7))
    (defn snpw28-oracle-device (r) (nth r 8))

    (defn snpw28-oracle-rows ()
        (list
            (snpw28-oracle-row "zh" "Tingting" "我在。" 0 15064 3568659029)
            (snpw28-oracle-row "de" "Eddy (German (Germany))" "Ich bin" 0 29216 2691094203)))

    (defn snpw28-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw28-oracle-wer (head rows)) (snpw28-max-wer)) 1 0)
                 (snpw28-oracle-ok-loop (tail rows)))))
    (defn snpw28-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw28-oracle-bytes (head rows))
                 (snpw28-oracle-byte-total-loop (tail rows)))))

    (defn snpw28-nl (src dst)
        (mlap-nl-sample (snpw28-meaning) src dst
                         (snpw28-tokens src)
                         (snpw28-tokens dst)
                         (snpw28-meaning)
                         0 0 0))

    (defn snpw28-audio (src dst)
        (mlap-audio-sample (snpw28-meaning) src dst
                            (snpw28-tokens dst)
                            (snpw28-tokens dst)
                            (snpw28-feat)
                            (snpw28-meta)
                            0 0 0))

    (defn snpw28-nl-lanes ()
        (list
            (snpw28-nl (snpw28-a) (snpw28-b))
            (snpw28-nl (snpw28-b) (snpw28-a))
            (snpw28-nl (snpw28-a) (snpw28-a))
            (snpw28-nl (snpw28-b) (snpw28-b))))

    (defn snpw28-audio-lanes ()
        (list
            (snpw28-audio (snpw28-a) (snpw28-b))
            (snpw28-audio (snpw28-b) (snpw28-a))
            (snpw28-audio (snpw28-a) (snpw28-a))
            (snpw28-audio (snpw28-b) (snpw28-b))))

    (defn snpw28-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw28-receipt ()
        (do
            (let nl (snpw28-nl-lanes))
            (let audio (snpw28-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw28-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw28-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw28-max-wer)))
            (let oracle-rows (snpw28-oracle-rows))
            (let oracle-ok (snpw28-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw28-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw28-kind)
                  (snpw28-a)
                  (snpw28-b)
                  (snpw28-meaning)
                  1
                  2
                  28
                  56
                  28
                  28
                  before
                  after
                  (if (and (lt before (snpw28-floor)) (ge after (snpw28-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw28-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0028-trained-not-open-authority")))

    (defn snpw28-rec-kind            (r) (nth r 0))
    (defn snpw28-rec-a               (r) (nth r 1))
    (defn snpw28-rec-b               (r) (nth r 2))
    (defn snpw28-rec-meaning         (r) (nth r 3))
    (defn snpw28-rec-pair-increment  (r) (nth r 4))
    (defn snpw28-rec-directed-increment (r) (nth r 5))
    (defn snpw28-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw28-rec-cumulative-directed (r) (nth r 7))
    (defn snpw28-rec-epochs          (r) (nth r 8))
    (defn snpw28-rec-params          (r) (nth r 9))
    (defn snpw28-rec-before-rate     (r) (nth r 10))
    (defn snpw28-rec-after-rate      (r) (nth r 11))
    (defn snpw28-rec-shifted         (r) (nth r 12))
    (defn snpw28-rec-form-nl         (r) (nth r 13))
    (defn snpw28-rec-form-audio      (r) (nth r 14))
    (defn snpw28-rec-before-loss     (r) (nth r 15))
    (defn snpw28-rec-after-loss      (r) (nth r 16))
    (defn snpw28-rec-oracle-ok       (r) (nth r 17))
    (defn snpw28-rec-oracle-total    (r) (nth r 18))
    (defn snpw28-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw28-rec-oracle          (r) (nth r 20))
    (defn snpw28-rec-native-form     (r) (nth r 21))
    (defn snpw28-rec-neural          (r) (nth r 22))
    (defn snpw28-rec-open-authority  (r) (nth r 23))
    (defn snpw28-rec-status          (r) (nth r 24))

    0)
