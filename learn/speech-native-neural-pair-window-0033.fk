; speech-native-neural-pair-window-0033.fk -- thirty-third native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; fr<->ar. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw33-kind () "speech-native-neural-pair-window-0033")
    (defn snpw33-a () "fr")
    (defn snpw33-b () "ar")
    (defn snpw33-meaning () 303)
    (defn snpw33-floor () 50)
    (defn snpw33-max-wer () 25)
    (defn snpw33-meta () (mlap-meta 96 97 11 80))
    (defn snpw33-feat () (list 3040 32 2 2))
    (defn snpw33-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw33-meaning)) locale))

    (defn snpw33-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0033-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw33-oracle-locale (r) (nth r 1))
    (defn snpw33-oracle-voice  (r) (nth r 2))
    (defn snpw33-oracle-transcript (r) (nth r 3))
    (defn snpw33-oracle-wer    (r) (nth r 4))
    (defn snpw33-oracle-bytes  (r) (nth r 5))
    (defn snpw33-oracle-cksum  (r) (nth r 6))
    (defn snpw33-oracle-name   (r) (nth r 7))
    (defn snpw33-oracle-device (r) (nth r 8))

    (defn snpw33-oracle-rows ()
        (list
            (snpw33-oracle-row "fr" "Thomas" "Je suis" 0 17908 3224208913)
            (snpw33-oracle-row "ar" "Majed" "أنا." 0 10906 3840888175)))

    (defn snpw33-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw33-oracle-wer (head rows)) (snpw33-max-wer)) 1 0)
                 (snpw33-oracle-ok-loop (tail rows)))))
    (defn snpw33-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw33-oracle-bytes (head rows))
                 (snpw33-oracle-byte-total-loop (tail rows)))))

    (defn snpw33-nl (src dst)
        (mlap-nl-sample (snpw33-meaning) src dst
                         (snpw33-tokens src)
                         (snpw33-tokens dst)
                         (snpw33-meaning)
                         0 0 0))

    (defn snpw33-audio (src dst)
        (mlap-audio-sample (snpw33-meaning) src dst
                            (snpw33-tokens dst)
                            (snpw33-tokens dst)
                            (snpw33-feat)
                            (snpw33-meta)
                            0 0 0))

    (defn snpw33-nl-lanes ()
        (list
            (snpw33-nl (snpw33-a) (snpw33-b))
            (snpw33-nl (snpw33-b) (snpw33-a))
            (snpw33-nl (snpw33-a) (snpw33-a))
            (snpw33-nl (snpw33-b) (snpw33-b))))

    (defn snpw33-audio-lanes ()
        (list
            (snpw33-audio (snpw33-a) (snpw33-b))
            (snpw33-audio (snpw33-b) (snpw33-a))
            (snpw33-audio (snpw33-a) (snpw33-a))
            (snpw33-audio (snpw33-b) (snpw33-b))))

    (defn snpw33-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw33-receipt ()
        (do
            (let nl (snpw33-nl-lanes))
            (let audio (snpw33-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw33-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw33-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw33-max-wer)))
            (let oracle-rows (snpw33-oracle-rows))
            (let oracle-ok (snpw33-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw33-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw33-kind)
                  (snpw33-a)
                  (snpw33-b)
                  (snpw33-meaning)
                  1
                  2
                  33
                  66
                  33
                  33
                  before
                  after
                  (if (and (lt before (snpw33-floor)) (ge after (snpw33-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw33-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0033-trained-not-open-authority")))

    (defn snpw33-rec-kind            (r) (nth r 0))
    (defn snpw33-rec-a               (r) (nth r 1))
    (defn snpw33-rec-b               (r) (nth r 2))
    (defn snpw33-rec-meaning         (r) (nth r 3))
    (defn snpw33-rec-pair-increment  (r) (nth r 4))
    (defn snpw33-rec-directed-increment (r) (nth r 5))
    (defn snpw33-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw33-rec-cumulative-directed (r) (nth r 7))
    (defn snpw33-rec-epochs          (r) (nth r 8))
    (defn snpw33-rec-params          (r) (nth r 9))
    (defn snpw33-rec-before-rate     (r) (nth r 10))
    (defn snpw33-rec-after-rate      (r) (nth r 11))
    (defn snpw33-rec-shifted         (r) (nth r 12))
    (defn snpw33-rec-form-nl         (r) (nth r 13))
    (defn snpw33-rec-form-audio      (r) (nth r 14))
    (defn snpw33-rec-before-loss     (r) (nth r 15))
    (defn snpw33-rec-after-loss      (r) (nth r 16))
    (defn snpw33-rec-oracle-ok       (r) (nth r 17))
    (defn snpw33-rec-oracle-total    (r) (nth r 18))
    (defn snpw33-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw33-rec-oracle          (r) (nth r 20))
    (defn snpw33-rec-native-form     (r) (nth r 21))
    (defn snpw33-rec-neural          (r) (nth r 22))
    (defn snpw33-rec-open-authority  (r) (nth r 23))
    (defn snpw33-rec-status          (r) (nth r 24))

    0)
