; diverse-locale-pairing.fk -- choose far-apart, corpus-ready A/B locale pairs.
;
; Training should not live in one comfortable language corridor. This guide
; prefers distant families/scripts/typologies while keeping consent and corpus
; readiness explicit. "Native American" is not a locale; rows name specific
; Indigenous languages only when a consentful corpus row exists.
;
; Row shape:
;   code family script typology region corpus-ready consent-ready weight

(do
    (defn dlp-locale (code family script typology region corpus consent weight)
        (list "diverse-locale" code family script typology region corpus consent weight))
    (defn dlp-kind     (l) (nth l 0))
    (defn dlp-code     (l) (nth l 1))
    (defn dlp-family   (l) (nth l 2))
    (defn dlp-script   (l) (nth l 3))
    (defn dlp-typology (l) (nth l 4))
    (defn dlp-region   (l) (nth l 5))
    (defn dlp-corpus   (l) (nth l 6))
    (defn dlp-consent  (l) (nth l 7))
    (defn dlp-weight   (l) (nth l 8))

    (defn dlp-ready? (l)
        (if (and (eq (dlp-corpus l) 1) (eq (dlp-consent l) 1)) 1 0))

    (defn dlp-catalog ()
        (list
            (dlp-locale "zh" "sino-tibetan" "han" "analytic-tonal" "east-asia" 0 1 10)
            (dlp-locale "en" "indo-european-germanic" "latin" "analytic-stress" "europe" 1 1 6)
            (dlp-locale "ar" "afro-asiatic-semitic" "arabic" "templatic-root" "west-asia" 0 1 9)
            (dlp-locale "nv" "dene" "latin" "polysynthetic-tonal" "north-america" 0 0 10)
            (dlp-locale "chr" "iroquoian" "cherokee" "polysynthetic" "north-america" 0 0 10)
            (dlp-locale "es" "indo-european-romance" "latin" "fusional-stress" "europe-americas" 1 1 5)
            (dlp-locale "la" "indo-european-romance" "latin" "fusional-classical" "europe" 0 1 5)
            (dlp-locale "id" "austronesian" "latin" "analytic-affix" "southeast-asia" 1 1 8)
            (dlp-locale "de" "indo-european-germanic" "latin" "fusional-stress" "europe" 1 1 6)
            (dlp-locale "fr" "indo-european-romance" "latin" "fusional-stress" "europe" 1 1 5)
            (dlp-locale "pt-br" "indo-european-romance" "latin" "fusional-stress" "south-america" 1 1 5)))

    (defn dlp-diff (a b)
        (if (str_eq a b) 0 1))
    (defn dlp-distance (a b)
        (add
            (add
                (mul (dlp-diff (dlp-family a) (dlp-family b)) 4)
                (mul (dlp-diff (dlp-script a) (dlp-script b)) 3))
            (add
                (mul (dlp-diff (dlp-typology a) (dlp-typology b)) 2)
                (dlp-diff (dlp-region a) (dlp-region b)))))
    (defn dlp-pair-score (a b)
        (if (and (eq (dlp-ready? a) 1)
                 (and (eq (dlp-ready? b) 1)
                      (not (str_eq (dlp-code a) (dlp-code b)))))
            (add (add (dlp-distance a b) (dlp-weight a)) (dlp-weight b))
            0))

    (defn dlp-pair (a b score)
        (list "diverse-locale-pair" (dlp-code a) (dlp-code b) score
              (dlp-distance a b) (dlp-ready? a) (dlp-ready? b)))
    (defn dlp-pair-kind  (p) (nth p 0))
    (defn dlp-pair-a     (p) (nth p 1))
    (defn dlp-pair-b     (p) (nth p 2))
    (defn dlp-pair-score-of (p) (nth p 3))
    (defn dlp-pair-distance (p) (nth p 4))
    (defn dlp-pair-a-ready (p) (nth p 5))
    (defn dlp-pair-b-ready (p) (nth p 6))

    (defn dlp-empty-pair () (list "diverse-locale-pair" "" "" 0 0 0 0))

    (defn dlp-best-with (a rows best)
        (if (eq (len rows) 0) best
            (do
                (let b (head rows))
                (let score (dlp-pair-score a b))
                (let candidate (dlp-pair a b score))
                (if (gt score (dlp-pair-score-of best))
                    (dlp-best-with a (tail rows) candidate)
                    (dlp-best-with a (tail rows) best)))))

    (defn dlp-best-loop (rows all best)
        (if (eq (len rows) 0) best
            (do
                (let candidate (dlp-best-with (head rows) all best))
                (if (gt (dlp-pair-score-of candidate) (dlp-pair-score-of best))
                    (dlp-best-loop (tail rows) all candidate)
                    (dlp-best-loop (tail rows) all best)))))

    (defn dlp-best-pair ()
        (dlp-best-loop (dlp-catalog) (dlp-catalog) (dlp-empty-pair)))

    ; Deterministic pseudo-random choice for reproducible receipts. A live
    ; carrier can pass a real random seed later; the guide maps it onto the
    ; ready diverse pool without changing the scoring law.
    (defn dlp-seed-pair (seed)
        (do
            (let rows (dlp-catalog))
            (let idx (mod seed 4))
            (if (eq idx 0) (dlp-pair (nth rows 8) (nth rows 7) (dlp-pair-score (nth rows 8) (nth rows 7)))
                (if (eq idx 1) (dlp-pair (nth rows 1) (nth rows 7) (dlp-pair-score (nth rows 1) (nth rows 7)))
                    (if (eq idx 2) (dlp-pair (nth rows 9) (nth rows 7) (dlp-pair-score (nth rows 9) (nth rows 7)))
                        (dlp-pair (nth rows 10) (nth rows 7) (dlp-pair-score (nth rows 10) (nth rows 7))))))))

    (defn dlp-reciprocal-pairs (pair)
        (list (dlp-pair-a pair) (dlp-pair-b pair) (dlp-pair-b pair) (dlp-pair-a pair)))

    (defn dlp-indigenous-row-ready? ()
        (if (or (eq (dlp-ready? (nth (dlp-catalog) 3)) 1)
                (eq (dlp-ready? (nth (dlp-catalog) 4)) 1)) 1 0))

    0)
