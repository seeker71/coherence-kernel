; speech-native-neural-pair-window-0020.fk -- twentieth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; es<->fr. It connects the Spanish baseline to the French baseline as a native
; neural micro-pair, increasing trained neural pair coverage from nineteen to
; twenty without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw20-kind () "speech-native-neural-pair-window-0020")
    (defn snpw20-a () "es")
    (defn snpw20-b () "fr")
    (defn snpw20-meaning () 301)
    (defn snpw20-floor () 50)
    (defn snpw20-max-wer () 25)
    (defn snpw20-meta () (mlap-meta 96 95 18 84))
    (defn snpw20-feat () (list 4300 43 2 2))
    (defn snpw20-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw20-meaning)) locale))

    (defn snpw20-nl (src dst)
        (mlap-nl-sample (snpw20-meaning) src dst
                         (snpw20-tokens src)
                         (snpw20-tokens dst)
                         (snpw20-meaning)
                         0 0 0))

    (defn snpw20-audio (src dst)
        (mlap-audio-sample (snpw20-meaning) src dst
                            (snpw20-tokens dst)
                            (snpw20-tokens dst)
                            (snpw20-feat)
                            (snpw20-meta)
                            0 0 0))

    (defn snpw20-nl-lanes ()
        (list
            (snpw20-nl (snpw20-a) (snpw20-b))
            (snpw20-nl (snpw20-b) (snpw20-a))
            (snpw20-nl (snpw20-a) (snpw20-a))
            (snpw20-nl (snpw20-b) (snpw20-b))))

    (defn snpw20-audio-lanes ()
        (list
            (snpw20-audio (snpw20-a) (snpw20-b))
            (snpw20-audio (snpw20-b) (snpw20-a))
            (snpw20-audio (snpw20-a) (snpw20-a))
            (snpw20-audio (snpw20-b) (snpw20-b))))

    (defn snpw20-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw20-receipt ()
        (do
            (let nl (snpw20-nl-lanes))
            (let audio (snpw20-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw20-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw20-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw20-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw20-neural-rate nl-rate audio-rate boot))
            (list (snpw20-kind)
                  (snpw20-a)
                  (snpw20-b)
                  (snpw20-meaning)
                  1
                  2
                  20
                  40
                  20
                  20
                  before
                  after
                  (if (and (lt before (snpw20-floor)) (ge after (snpw20-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0020-trained-not-open-authority")))

    (defn snpw20-rec-kind            (r) (nth r 0))
    (defn snpw20-rec-a               (r) (nth r 1))
    (defn snpw20-rec-b               (r) (nth r 2))
    (defn snpw20-rec-meaning         (r) (nth r 3))
    (defn snpw20-rec-pair-increment  (r) (nth r 4))
    (defn snpw20-rec-directed-increment (r) (nth r 5))
    (defn snpw20-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw20-rec-cumulative-directed (r) (nth r 7))
    (defn snpw20-rec-epochs          (r) (nth r 8))
    (defn snpw20-rec-params          (r) (nth r 9))
    (defn snpw20-rec-before-rate     (r) (nth r 10))
    (defn snpw20-rec-after-rate      (r) (nth r 11))
    (defn snpw20-rec-shifted         (r) (nth r 12))
    (defn snpw20-rec-form-nl         (r) (nth r 13))
    (defn snpw20-rec-form-audio      (r) (nth r 14))
    (defn snpw20-rec-before-loss     (r) (nth r 15))
    (defn snpw20-rec-after-loss      (r) (nth r 16))
    (defn snpw20-rec-oracle          (r) (nth r 17))
    (defn snpw20-rec-native-form     (r) (nth r 18))
    (defn snpw20-rec-neural          (r) (nth r 19))
    (defn snpw20-rec-open-authority  (r) (nth r 20))
    (defn snpw20-rec-status          (r) (nth r 21))

    0)
