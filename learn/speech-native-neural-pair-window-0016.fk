; speech-native-neural-pair-window-0016.fk -- sixteenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; de<->es. It connects the German baseline to the Spanish baseline as a native
; neural micro-pair, increasing trained neural pair coverage from fifteen to
; sixteen without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw16-kind () "speech-native-neural-pair-window-0016")
    (defn snpw16-a () "de")
    (defn snpw16-b () "es")
    (defn snpw16-meaning () 301)
    (defn snpw16-floor () 50)
    (defn snpw16-max-wer () 25)
    (defn snpw16-meta () (mlap-meta 96 95 16 80))
    (defn snpw16-feat () (list 3900 39 2 2))
    (defn snpw16-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw16-meaning)) locale))

    (defn snpw16-nl (src dst)
        (mlap-nl-sample (snpw16-meaning) src dst
                         (snpw16-tokens src)
                         (snpw16-tokens dst)
                         (snpw16-meaning)
                         0 0 0))

    (defn snpw16-audio (src dst)
        (mlap-audio-sample (snpw16-meaning) src dst
                            (snpw16-tokens dst)
                            (snpw16-tokens dst)
                            (snpw16-feat)
                            (snpw16-meta)
                            0 0 0))

    (defn snpw16-nl-lanes ()
        (list
            (snpw16-nl (snpw16-a) (snpw16-b))
            (snpw16-nl (snpw16-b) (snpw16-a))
            (snpw16-nl (snpw16-a) (snpw16-a))
            (snpw16-nl (snpw16-b) (snpw16-b))))

    (defn snpw16-audio-lanes ()
        (list
            (snpw16-audio (snpw16-a) (snpw16-b))
            (snpw16-audio (snpw16-b) (snpw16-a))
            (snpw16-audio (snpw16-a) (snpw16-a))
            (snpw16-audio (snpw16-b) (snpw16-b))))

    (defn snpw16-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw16-receipt ()
        (do
            (let nl (snpw16-nl-lanes))
            (let audio (snpw16-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw16-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw16-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw16-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw16-neural-rate nl-rate audio-rate boot))
            (list (snpw16-kind)
                  (snpw16-a)
                  (snpw16-b)
                  (snpw16-meaning)
                  1
                  2
                  16
                  32
                  16
                  16
                  before
                  after
                  (if (and (lt before (snpw16-floor)) (ge after (snpw16-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0016-trained-not-open-authority")))

    (defn snpw16-rec-kind            (r) (nth r 0))
    (defn snpw16-rec-a               (r) (nth r 1))
    (defn snpw16-rec-b               (r) (nth r 2))
    (defn snpw16-rec-meaning         (r) (nth r 3))
    (defn snpw16-rec-pair-increment  (r) (nth r 4))
    (defn snpw16-rec-directed-increment (r) (nth r 5))
    (defn snpw16-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw16-rec-cumulative-directed (r) (nth r 7))
    (defn snpw16-rec-epochs          (r) (nth r 8))
    (defn snpw16-rec-params          (r) (nth r 9))
    (defn snpw16-rec-before-rate     (r) (nth r 10))
    (defn snpw16-rec-after-rate      (r) (nth r 11))
    (defn snpw16-rec-shifted         (r) (nth r 12))
    (defn snpw16-rec-form-nl         (r) (nth r 13))
    (defn snpw16-rec-form-audio      (r) (nth r 14))
    (defn snpw16-rec-before-loss     (r) (nth r 15))
    (defn snpw16-rec-after-loss      (r) (nth r 16))
    (defn snpw16-rec-oracle          (r) (nth r 17))
    (defn snpw16-rec-native-form     (r) (nth r 18))
    (defn snpw16-rec-neural          (r) (nth r 19))
    (defn snpw16-rec-open-authority  (r) (nth r 20))
    (defn snpw16-rec-status          (r) (nth r 21))

    0)
