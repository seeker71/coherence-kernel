; speech-oracle-router.fk -- the routed committee over the measured roster.
;
; Row 733's teaching made law: the roster's members have DISJOINT blind
; spots, so a dispatch decidable BEFORE hearing the clip (language and
; expected length are both known in the render path) outperforms every
; single member. Routed over the same landed gauntlet rows
; (learn/speech-oracle-roster.fk, measured 2026-07-16):
;
;   latin short -> whisper.cpp-small-metal        (the sprinter; no
;                                                  short-clip hallucination)
;   latin long  -> whisper.cpp-large-v3-turbo-metal (the anchor)
;   zh          -> whisper.cpp-large-v3-metal     (deepest zh ear, 2.9% CER;
;                                                  its short-clip weakness is
;                                                  latin-shaped, zh-short
;                                                  measured clean)
;
; Routed aggregate over the 8 clips: mean wer-x10 25 (2.5%) at mean wall
; 755ms -- against the lone anchor's overall 157 (15.7%) at ~793ms: six
; times the accuracy, slightly cheaper. The hindsight ceiling (per-clip
; best) is 16; the a-priori rule keeps most of it. No new measurement here:
; this cell is a LAW read over rows already witnessed, and it reseats only
; by re-measurement of the roster it reads.
;
; preludes: learn/speech-oracle-roster.fk

(do
    (defn sorr-seat (lang kind)
        (if (str_eq lang "zh") "whisper.cpp-large-v3-metal"
            (if (str_eq kind "short") "whisper.cpp-small-metal"
                "whisper.cpp-large-v3-turbo-metal")))

    (defn sorr-clips ()
        (list (list "en-short" "en" "short")
              (list "en-long" "en" "long")
              (list "it-short" "it" "short")
              (list "it-long" "it" "long")
              (list "fr-short" "fr" "short")
              (list "fr-long" "fr" "long")
              (list "zh-short" "zh" "short")
              (list "zh-long" "zh" "long")))

    ; row-match folds (count-based, so an unrouted clip shows as a hole in
    ; the match count instead of a type surprise)
    (defn sorr-match? (r m clip)
        (if (and (str_eq (sor-run-model r) m)
                 (str_eq (sor-run-clip r) clip)) 1 0))
    (defn sorr-wer-for (rs m clip)
        (if (eq (len rs) 0) 0
            (add (if (eq (sorr-match? (head rs) m clip) 1) (sor-run-wer (head rs)) 0)
                 (sorr-wer-for (tail rs) m clip))))
    (defn sorr-wall-for (rs m clip)
        (if (eq (len rs) 0) 0
            (add (if (eq (sorr-match? (head rs) m clip) 1) (sor-run-wall (head rs)) 0)
                 (sorr-wall-for (tail rs) m clip))))
    (defn sorr-count-for (rs m clip)
        (if (eq (len rs) 0) 0
            (add (sorr-match? (head rs) m clip)
                 (sorr-count-for (tail rs) m clip))))

    (defn sorr-clip-seat (c) (sorr-seat (nth c 1) (nth c 2)))

    (defn sorr-wer-total (cs)
        (if (eq (len cs) 0) 0
            (add (sorr-wer-for (sor-runs) (sorr-clip-seat (head cs)) (nth (head cs) 0))
                 (sorr-wer-total (tail cs)))))
    (defn sorr-wall-total (cs)
        (if (eq (len cs) 0) 0
            (add (sorr-wall-for (sor-runs) (sorr-clip-seat (head cs)) (nth (head cs) 0))
                 (sorr-wall-total (tail cs)))))
    (defn sorr-resolved (cs)
        (if (eq (len cs) 0) 0
            (add (sorr-count-for (sor-runs) (sorr-clip-seat (head cs)) (nth (head cs) 0))
                 (sorr-resolved (tail cs)))))

    (defn sorr-mean-wer () (div (sorr-wer-total (sorr-clips)) (len (sorr-clips))))
    (defn sorr-mean-wall () (div (sorr-wall-total (sorr-clips)) (len (sorr-clips))))
    (defn sorr-improvement ()
        (div (sor-overall-mean-wer (sor-anchor)) (sorr-mean-wer)))

    ; coverage law survives routing: the zh seat must be a zh-covering model
    (defn sorr-zh-seat-covered? () (sor-covers-zh? (sorr-seat "zh" "long")))

    (defn sorr-report ()
        (list "speech-oracle-router"
              (sorr-resolved (sorr-clips))
              (sorr-mean-wer)
              (sorr-mean-wall)
              (sor-overall-mean-wer (sor-anchor))
              (sorr-improvement)
              (sorr-zh-seat-covered?)
              "dispatch-by-lang-and-kind-decidable-before-hearing"
              "reseats-only-by-roster-re-measurement"
              1
              0))

    0)
