; tool-channel.fk - native tool/channel catalog and planner.
;
; This file plans tool calls only. It never executes a host process, reads a
; file, sends HTTP, or invokes a kernel route. Cells and recipes discover
; protocols, providers, applets, and options here, then receive an explicit
; invocation plan. Wrong or missing capability returns tool/no-plan.

(do
    (defn tc-protocol (name provider capability native effect)
        (list name provider capability native effect))
    (defn tc-protocol-name (p) (nth p 0))
    (defn tc-protocol-provider (p) (nth p 1))
    (defn tc-protocol-capability (p) (nth p 2))
    (defn tc-protocol-native (p) (nth p 3))
    (defn tc-protocol-effect (p) (nth p 4))
    (defn tc-empty-protocol () (tc-protocol "" "" "" 0 ""))

    (defn tc-protocols ()
        (list
            (tc-protocol "host:exec" "host" "cap.host.exec" 0 "process")
            (tc-protocol "host:process" "host" "cap.host.process" 1 "process-table")
            (tc-protocol "host:usage" "host" "cap.host.usage" 1 "resource-usage")
            (tc-protocol "host:file" "host" "cap.host.file" 0 "filesystem")
            (tc-protocol "gpu:compute" "accelerator" "cap.compute.gpu" 1 "parallel-compute")
            (tc-protocol "dsp:signal" "accelerator" "cap.compute.dsp" 1 "signal-kernel")
            (tc-protocol "mlx:array" "accelerator" "cap.compute.mlx" 1 "apple-array-compute")
            (tc-protocol "http:request" "http" "cap.http.request" 1 "network")
            (tc-protocol "kernel:call" "kernel" "cap.kernel.call" 1 "call")
            (tc-protocol "kernel:route" "kernel" "cap.kernel.route" 1 "route")
            (tc-protocol "hati.mesh:presence" "mesh" "cap.mesh.presence" 1 "organ-presence")
            (tc-protocol "stream:read" "stream" "cap.stream.read" 1 "stream")
            (tc-protocol "store:query" "store" "cap.store.query" 1 "store")))

    (defn tc-provider (name protocol capability)
        (list name protocol capability))
    (defn tc-provider-name (p) (nth p 0))
    (defn tc-provider-protocol (p) (nth p 1))
    (defn tc-provider-capability (p) (nth p 2))
    (defn tc-providers ()
        (list
            (tc-provider "host" "host:exec" "cap.host.exec")
            (tc-provider "process" "host:process" "cap.host.process")
            (tc-provider "usage" "host:usage" "cap.host.usage")
            (tc-provider "file" "host:file" "cap.host.file")
            (tc-provider "gpu" "gpu:compute" "cap.compute.gpu")
            (tc-provider "dsp" "dsp:signal" "cap.compute.dsp")
            (tc-provider "mlx" "mlx:array" "cap.compute.mlx")
            (tc-provider "http" "http:request" "cap.http.request")
            (tc-provider "kernel" "kernel:call" "cap.kernel.call")
            (tc-provider "route" "kernel:route" "cap.kernel.route")
            (tc-provider "mesh" "hati.mesh:presence" "cap.mesh.presence")
            (tc-provider "stream" "stream:read" "cap.stream.read")
            (tc-provider "store" "store:query" "cap.store.query")))

    (defn tc-tool (name protocol capability op projection input output)
        (list name protocol capability op projection input output))
    (defn tc-tool-name (t) (nth t 0))
    (defn tc-tool-protocol (t) (nth t 1))
    (defn tc-tool-capability (t) (nth t 2))
    (defn tc-tool-op (t) (nth t 3))
    (defn tc-tool-projection (t) (nth t 4))
    (defn tc-tool-input (t) (nth t 5))
    (defn tc-tool-output (t) (nth t 6))
    (defn tc-empty-tool () (tc-tool "" "" "" "" "" "" ""))

    (defn tc-tools ()
        (list
            (tc-tool "exec" "host:exec" "cap.host.exec" "exec" "protocol" "argv" "stdout")
            (tc-tool "processes" "host:process" "cap.host.process" "process-snapshot" "host-resource" "selector" "process-rows")
            (tc-tool "usage" "host:usage" "cap.host.usage" "usage-sample" "host-resource" "sample-window" "usage-sample")
            (tc-tool "file" "host:file" "cap.host.file" "file" "protocol" "path" "bytes")
            (tc-tool "gpu-kernel" "gpu:compute" "cap.compute.gpu" "dispatch" "accelerator" "tensor-or-buffer" "compute-receipt")
            (tc-tool "dsp-kernel" "dsp:signal" "cap.compute.dsp" "dispatch" "accelerator" "pcm-or-signal-buffer" "signal-receipt")
            (tc-tool "mlx-kernel" "mlx:array" "cap.compute.mlx" "dispatch" "accelerator" "mlx-array" "array-receipt")
            (tc-tool "http" "http:request" "cap.http.request" "request" "protocol" "request" "response")
            (tc-tool "call" "kernel:call" "cap.kernel.call" "call" "protocol" "args" "value")
            (tc-tool "route" "kernel:route" "cap.kernel.route" "route" "protocol" "request" "response")
            (tc-tool "announce-organ" "hati.mesh:presence" "cap.mesh.presence" "announce" "protocol" "organ-presence" "receipt")
            (tc-tool "stream" "stream:read" "cap.stream.read" "read" "protocol" "cursor" "event")
            (tc-tool "query" "store:query" "cap.store.query" "query" "protocol" "selector" "rows")
            (tc-tool "grep" "stream:read" "cap.stream.read" "grep" "shell-applet" "stream+needle" "matches")
            (tc-tool "find" "host:file" "cap.host.file" "find" "shell-applet" "root+pattern" "paths")
            (tc-tool "awk" "stream:read" "cap.stream.read" "awk" "shell-applet" "stream+program" "rows")
            (tc-tool "fields" "stream:read" "cap.stream.read" "fields" "shell-applet" "stream+field" "values")
            (tc-tool "group" "store:query" "cap.store.query" "group" "shell-applet" "rows+key" "groups")
            (tc-tool "xpath" "kernel:call" "cap.kernel.call" "path-select" "shell-applet" "tree+path" "nodes")
            (tc-tool "xmlpath" "kernel:call" "cap.kernel.call" "path-select" "shell-applet" "xml+path" "nodes")
            (tc-tool "words" "kernel:call" "cap.kernel.call" "words" "catalog" "none" "tools")
            (tc-tool "providers" "kernel:call" "cap.kernel.call" "providers" "catalog" "none" "providers")
            (tc-tool "queries" "kernel:call" "cap.kernel.call" "queries" "catalog" "none" "queries")
            (tc-tool "which" "kernel:call" "cap.kernel.call" "which" "catalog" "tool-name" "tool")
            (tc-tool "plan" "kernel:call" "cap.kernel.call" "plan" "catalog" "tool-name" "plan")))

    (defn tc-find-protocol (name rows)
        (if (eq (len rows) 0) (tc-empty-protocol)
            (if (str_eq (tc-protocol-name (head rows)) name)
                (head rows)
                (tc-find-protocol name (tail rows)))))
    (defn tc-protocol-by-name (name) (tc-find-protocol name (tc-protocols)))

    (defn tc-find-tool (name rows)
        (if (eq (len rows) 0) (tc-empty-tool)
            (if (str_eq (tc-tool-name (head rows)) name)
                (head rows)
                (tc-find-tool name (tail rows)))))
    (defn tc-which (name) (tc-find-tool name (tc-tools)))

    (defn tc-capability-matches? (expected provided)
        (if (str_eq expected provided) 1 0))
    (defn tc-protocol-carries? (protocol-name capability)
        (tc-capability-matches? (tc-protocol-capability (tc-protocol-by-name protocol-name)) capability))
    (defn tc-native-option? (tool-name)
        (tc-protocol-native (tc-protocol-by-name (tc-tool-protocol (tc-which tool-name)))))

    (defn tc-plan (status tool protocol capability op witness)
        (list status tool protocol capability op witness))
    (defn tc-plan-status (p) (nth p 0))
    (defn tc-plan-tool-name (p) (nth p 1))
    (defn tc-plan-protocol (p) (nth p 2))
    (defn tc-plan-capability (p) (nth p 3))
    (defn tc-plan-op (p) (nth p 4))
    (defn tc-plan-witness (p) (nth p 5))

    (defn tc-plan-tool-row (tool capability)
        (if (str_eq (tc-tool-name tool) "")
            (tc-plan "tool/no-plan" "" "" capability "" "missing-tool")
            (if (eq (tc-protocol-carries? (tc-tool-protocol tool) capability) 1)
                (tc-plan "tool/plan" (tc-tool-name tool) (tc-tool-protocol tool) capability (tc-tool-op tool) "capability-explicit")
                (tc-plan "tool/no-plan" (tc-tool-name tool) (tc-tool-protocol tool) capability (tc-tool-op tool) "missing-capability"))))
    (defn tc-plan-tool (tool-name capability)
        (tc-plan-tool-row (tc-which tool-name) capability))
    (defn tc-plan-request (protocol-name capability op)
        (if (eq (tc-protocol-carries? protocol-name capability) 1)
            (tc-plan "tool/plan" "" protocol-name capability op "capability-explicit")
            (tc-plan "tool/no-plan" "" protocol-name capability op "missing-capability")))

    (defn tc-words () (tc-tools))
    (defn tc-provider-catalog () (tc-providers))
    (defn tc-query-catalog () (list "which" "plan" "words" "providers" "queries"))

    0)
