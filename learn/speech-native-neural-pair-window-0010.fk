; speech-native-neural-pair-window-0010.fk -- tenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; zh<->ar. It is the first native neural micro-pair whose two endpoints are
; both non-Latin Unicode scripts, increasing trained neural pair coverage from
; nine to ten without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw10-kind () "speech-native-neural-pair-window-0010")
    (defn snpw10-a () "zh")
    (defn snpw10-b () "ar")
    (defn snpw10-meaning () 302)
    (defn snpw10-floor () 50)
    (defn snpw10-max-wer () 25)
    (defn snpw10-meta () (mlap-meta 99 99 16 74))
    (defn snpw10-feat () (list 3300 33 2 2))
    (defn snpw10-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw10-meaning)) locale))

    (defn snpw10-nl (src dst)
        (mlap-nl-sample (snpw10-meaning) src dst
                         (snpw10-tokens src)
                         (snpw10-tokens dst)
                         (snpw10-meaning)
                         0 0 0))

    (defn snpw10-audio (src dst)
        (mlap-audio-sample (snpw10-meaning) src dst
                            (snpw10-tokens dst)
                            (snpw10-tokens dst)
                            (snpw10-feat)
                            (snpw10-meta)
                            0 0 0))

    (defn snpw10-nl-lanes ()
        (list
            (snpw10-nl (snpw10-a) (snpw10-b))
            (snpw10-nl (snpw10-b) (snpw10-a))
            (snpw10-nl (snpw10-a) (snpw10-a))
            (snpw10-nl (snpw10-b) (snpw10-b))))

    (defn snpw10-audio-lanes ()
        (list
            (snpw10-audio (snpw10-a) (snpw10-b))
            (snpw10-audio (snpw10-b) (snpw10-a))
            (snpw10-audio (snpw10-a) (snpw10-a))
            (snpw10-audio (snpw10-b) (snpw10-b))))

    (defn snpw10-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw10-receipt ()
        (do
            (let nl (snpw10-nl-lanes))
            (let audio (snpw10-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw10-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw10-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw10-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw10-neural-rate nl-rate audio-rate boot))
            (list (snpw10-kind)
                  (snpw10-a)
                  (snpw10-b)
                  (snpw10-meaning)
                  1
                  2
                  10
                  20
                  10
                  10
                  before
                  after
                  (if (and (lt before (snpw10-floor)) (ge after (snpw10-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0010-trained-not-open-authority")))

    (defn snpw10-rec-kind            (r) (nth r 0))
    (defn snpw10-rec-a               (r) (nth r 1))
    (defn snpw10-rec-b               (r) (nth r 2))
    (defn snpw10-rec-meaning         (r) (nth r 3))
    (defn snpw10-rec-pair-increment  (r) (nth r 4))
    (defn snpw10-rec-directed-increment (r) (nth r 5))
    (defn snpw10-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw10-rec-cumulative-directed (r) (nth r 7))
    (defn snpw10-rec-epochs          (r) (nth r 8))
    (defn snpw10-rec-params          (r) (nth r 9))
    (defn snpw10-rec-before-rate     (r) (nth r 10))
    (defn snpw10-rec-after-rate      (r) (nth r 11))
    (defn snpw10-rec-shifted         (r) (nth r 12))
    (defn snpw10-rec-form-nl         (r) (nth r 13))
    (defn snpw10-rec-form-audio      (r) (nth r 14))
    (defn snpw10-rec-before-loss     (r) (nth r 15))
    (defn snpw10-rec-after-loss      (r) (nth r 16))
    (defn snpw10-rec-oracle          (r) (nth r 17))
    (defn snpw10-rec-native-form     (r) (nth r 18))
    (defn snpw10-rec-neural          (r) (nth r 19))
    (defn snpw10-rec-open-authority  (r) (nth r 20))
    (defn snpw10-rec-status          (r) (nth r 21))

    0)
