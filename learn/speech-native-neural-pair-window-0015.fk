; speech-native-neural-pair-window-0015.fk -- fifteenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; ar<->la. It connects the Arabic baseline to the Latin baseline as a native
; neural micro-pair, increasing trained neural pair coverage from fourteen to
; fifteen without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw15-kind () "speech-native-neural-pair-window-0015")
    (defn snpw15-a () "ar")
    (defn snpw15-b () "la")
    (defn snpw15-meaning () 301)
    (defn snpw15-floor () 50)
    (defn snpw15-max-wer () 25)
    (defn snpw15-meta () (mlap-meta 98 96 16 79))
    (defn snpw15-feat () (list 3800 38 2 2))
    (defn snpw15-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw15-meaning)) locale))

    (defn snpw15-nl (src dst)
        (mlap-nl-sample (snpw15-meaning) src dst
                         (snpw15-tokens src)
                         (snpw15-tokens dst)
                         (snpw15-meaning)
                         0 0 0))

    (defn snpw15-audio (src dst)
        (mlap-audio-sample (snpw15-meaning) src dst
                            (snpw15-tokens dst)
                            (snpw15-tokens dst)
                            (snpw15-feat)
                            (snpw15-meta)
                            0 0 0))

    (defn snpw15-nl-lanes ()
        (list
            (snpw15-nl (snpw15-a) (snpw15-b))
            (snpw15-nl (snpw15-b) (snpw15-a))
            (snpw15-nl (snpw15-a) (snpw15-a))
            (snpw15-nl (snpw15-b) (snpw15-b))))

    (defn snpw15-audio-lanes ()
        (list
            (snpw15-audio (snpw15-a) (snpw15-b))
            (snpw15-audio (snpw15-b) (snpw15-a))
            (snpw15-audio (snpw15-a) (snpw15-a))
            (snpw15-audio (snpw15-b) (snpw15-b))))

    (defn snpw15-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw15-receipt ()
        (do
            (let nl (snpw15-nl-lanes))
            (let audio (snpw15-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw15-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw15-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw15-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw15-neural-rate nl-rate audio-rate boot))
            (list (snpw15-kind)
                  (snpw15-a)
                  (snpw15-b)
                  (snpw15-meaning)
                  1
                  2
                  15
                  30
                  15
                  15
                  before
                  after
                  (if (and (lt before (snpw15-floor)) (ge after (snpw15-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0015-trained-not-open-authority")))

    (defn snpw15-rec-kind            (r) (nth r 0))
    (defn snpw15-rec-a               (r) (nth r 1))
    (defn snpw15-rec-b               (r) (nth r 2))
    (defn snpw15-rec-meaning         (r) (nth r 3))
    (defn snpw15-rec-pair-increment  (r) (nth r 4))
    (defn snpw15-rec-directed-increment (r) (nth r 5))
    (defn snpw15-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw15-rec-cumulative-directed (r) (nth r 7))
    (defn snpw15-rec-epochs          (r) (nth r 8))
    (defn snpw15-rec-params          (r) (nth r 9))
    (defn snpw15-rec-before-rate     (r) (nth r 10))
    (defn snpw15-rec-after-rate      (r) (nth r 11))
    (defn snpw15-rec-shifted         (r) (nth r 12))
    (defn snpw15-rec-form-nl         (r) (nth r 13))
    (defn snpw15-rec-form-audio      (r) (nth r 14))
    (defn snpw15-rec-before-loss     (r) (nth r 15))
    (defn snpw15-rec-after-loss      (r) (nth r 16))
    (defn snpw15-rec-oracle          (r) (nth r 17))
    (defn snpw15-rec-native-form     (r) (nth r 18))
    (defn snpw15-rec-neural          (r) (nth r 19))
    (defn snpw15-rec-open-authority  (r) (nth r 20))
    (defn snpw15-rec-status          (r) (nth r 21))

    0)
