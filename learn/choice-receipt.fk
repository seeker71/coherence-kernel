; choice-receipt.fk - shared branch/trust receipt compression.
;
; preludes: form-stdlib/core.fk
;
; A choice receipt records what was expressed, where it executed, which branch
; was selected, what happened, and the witness trace counts. Its value cell keeps
; branch-prediction feedback distinct from core alignment/knowing/trust. The
; signature is intentionally smaller but must still preserve category, certainty
; bucket, selected path, witness, coordinate, value kind, and
; success/fail/silence texture.

; Registered Blueprint coordinates from form/user-blueprint-registry.md.
; Keep these as integer tags so emitted fourth-kernel tables compare tags with
; the same cheap path used by kernel-http and other four-way route rows.
(let CR-TAG-CHOICE-CANDIDATE 1736)
(let CR-TAG-CHOICE-TRACE 1737)
(let CR-TAG-CHOICE-VALUE 1738)
(let CR-TAG-CHOICE-RECEIPT 1739)
(let CR-TAG-CHOICE-SIGNATURE 1743)

(defn cr-bool-score (ok score) (if ok score 0))
(defn cr-tagged? (value tag arity)
    (if (eq (len value) arity) (eq (nth value 0) tag) false))
(defn cr-nonempty-string? (value) (gt (str_len value) 0))

(defn cr-outcome-success () "success")
(defn cr-outcome-fail () "fail")
(defn cr-outcome-silence () "silence")
(defn cr-outcome-known? (outcome)
    (or (str_eq outcome (cr-outcome-success))
        (or (str_eq outcome (cr-outcome-fail))
            (str_eq outcome (cr-outcome-silence)))))
(defn cr-outcome-code (outcome)
    (if (str_eq outcome (cr-outcome-success)) 1
        (if (str_eq outcome (cr-outcome-fail)) 0
            (if (str_eq outcome (cr-outcome-silence)) (sub 0 1) (sub 0 9)))))

(defn cr-certainty-bucket (certainty)
    (if (le certainty 0) 0
        (if (le certainty 25) 1
            (if (le certainty 50) 2
                (if (le certainty 75) 3
                    (if (le certainty 90) 4 5))))))
(defn cr-count-bucket (count)
    (if (le count 0) 0
        (if (eq count 1) 1
            (if (eq count 2) 2
                (if (le count 4) 3
                    (if (le count 8) 4 5))))))
(defn cr-value-bucket (value) (cr-certainty-bucket value))

(defn cr-choice-candidate (path category eligible pressure score evidence)
    (list CR-TAG-CHOICE-CANDIDATE path category eligible pressure score evidence))
(defn cr-choice-candidate? (candidate)
    (cr-tagged? candidate CR-TAG-CHOICE-CANDIDATE 7))
(defn cr-candidate-path (candidate) (nth candidate 1))
(defn cr-candidate-category (candidate) (nth candidate 2))
(defn cr-candidate-eligible? (candidate) (nth candidate 3))
(defn cr-candidate-pressure (candidate) (nth candidate 4))
(defn cr-candidate-score (candidate) (nth candidate 5))
(defn cr-candidate-evidence (candidate) (nth candidate 6))
(defn cr-choice-candidate-valid? (candidate)
    (if (cr-choice-candidate? candidate)
        (and (cr-nonempty-string? (cr-candidate-path candidate))
             (and (cr-nonempty-string? (cr-candidate-category candidate))
                  (and (ge (cr-candidate-pressure candidate) 0)
                       (cr-nonempty-string? (cr-candidate-evidence candidate)))))
        false))
(defn cr-choice-candidates-valid? (candidates)
    (if (nil? candidates) true
        (if (cr-choice-candidate-valid? (head candidates))
            (cr-choice-candidates-valid? (tail candidates))
            false)))

(defn cr-choice-trace (attempts successes failures silences)
    (list CR-TAG-CHOICE-TRACE attempts successes failures silences))
(defn cr-choice-trace? (trace) (cr-tagged? trace CR-TAG-CHOICE-TRACE 5))
(defn cr-trace-attempts (trace) (nth trace 1))
(defn cr-trace-successes (trace) (nth trace 2))
(defn cr-trace-failures (trace) (nth trace 3))
(defn cr-trace-silences (trace) (nth trace 4))
(defn cr-choice-trace-valid? (trace)
    (if (cr-choice-trace? trace)
        (and (ge (cr-trace-attempts trace) 0)
             (and (ge (cr-trace-successes trace) 0)
                  (and (ge (cr-trace-failures trace) 0)
                       (ge (cr-trace-silences trace) 0))))
        false))
(defn cr-trace-total (trace)
    (add (cr-trace-successes trace)
         (add (cr-trace-failures trace) (cr-trace-silences trace))))

(defn cr-kind-branch-feedback () "branch-prediction-feedback")
(defn cr-kind-core-alignment () "core-alignment-knowing-trust")
(defn cr-choice-value (kind branch-feedback alignment knowing trust)
    (list CR-TAG-CHOICE-VALUE kind branch-feedback alignment knowing trust))
(defn cr-choice-value? (value) (cr-tagged? value CR-TAG-CHOICE-VALUE 6))
(defn cr-value-kind (value) (nth value 1))
(defn cr-value-branch-feedback (value) (nth value 2))
(defn cr-value-alignment (value) (nth value 3))
(defn cr-value-knowing (value) (nth value 4))
(defn cr-value-trust (value) (nth value 5))
(defn cr-value-kind-known? (kind)
    (or (str_eq kind (cr-kind-branch-feedback))
        (str_eq kind (cr-kind-core-alignment))))
(defn cr-score-valid? (score) (and (ge score 0) (le score 100)))
(defn cr-choice-value-valid? (value)
    (if (cr-choice-value? value)
        (and (cr-value-kind-known? (cr-value-kind value))
             (and (cr-score-valid? (cr-value-branch-feedback value))
                  (and (cr-score-valid? (cr-value-alignment value))
                       (and (cr-score-valid? (cr-value-knowing value))
                            (cr-score-valid? (cr-value-trust value))))))
        false))
(defn cr-choice-value-worth-learning? (value)
    (if (cr-choice-value-valid? value)
        (and (ge (cr-value-alignment value) 70)
             (and (ge (cr-value-knowing value) 70)
                  (ge (cr-value-trust value) 70)))
        false))

(defn cr-choice-receipt (expression surface category candidates selected-path outcome certainty value why who where when-tick cost trace)
    (list CR-TAG-CHOICE-RECEIPT expression surface category candidates selected-path outcome certainty value why who where when-tick cost trace))
(defn cr-choice-receipt? (receipt) (cr-tagged? receipt CR-TAG-CHOICE-RECEIPT 15))
(defn cr-receipt-expression (receipt) (nth receipt 1))
(defn cr-receipt-surface (receipt) (nth receipt 2))
(defn cr-receipt-category (receipt) (nth receipt 3))
(defn cr-receipt-candidates (receipt) (nth receipt 4))
(defn cr-receipt-selected-path (receipt) (nth receipt 5))
(defn cr-receipt-outcome (receipt) (nth receipt 6))
(defn cr-receipt-certainty (receipt) (nth receipt 7))
(defn cr-receipt-value (receipt) (nth receipt 8))
(defn cr-receipt-why (receipt) (nth receipt 9))
(defn cr-receipt-who (receipt) (nth receipt 10))
(defn cr-receipt-where (receipt) (nth receipt 11))
(defn cr-receipt-when (receipt) (nth receipt 12))
(defn cr-receipt-cost (receipt) (nth receipt 13))
(defn cr-receipt-trace (receipt) (nth receipt 14))

(defn cr-selection-shape-valid? (receipt)
    (if (str_eq (cr-receipt-outcome receipt) (cr-outcome-silence))
        (str_eq (cr-receipt-selected-path receipt) "none")
        (and (cr-nonempty-string? (cr-receipt-selected-path receipt))
             (not (str_eq (cr-receipt-selected-path receipt) "none")))))
(defn cr-outcome-trace-agrees? (receipt)
    (do
        (let trace (cr-receipt-trace receipt))
        (if (str_eq (cr-receipt-outcome receipt) (cr-outcome-success))
            (gt (cr-trace-successes trace) 0)
            (if (str_eq (cr-receipt-outcome receipt) (cr-outcome-fail))
                (gt (cr-trace-failures trace) 0)
                (if (str_eq (cr-receipt-outcome receipt) (cr-outcome-silence))
                    (gt (cr-trace-silences trace) 0)
                    false)))))
(defn cr-receipt-text-valid? (receipt)
    (and (cr-nonempty-string? (cr-receipt-expression receipt))
         (and (cr-nonempty-string? (cr-receipt-surface receipt))
              (cr-nonempty-string? (cr-receipt-category receipt)))))
(defn cr-receipt-certainty-valid? (receipt)
    (and (ge (cr-receipt-certainty receipt) 0)
         (le (cr-receipt-certainty receipt) 100)))
(defn cr-receipt-attribution-valid? (receipt)
    (and (cr-nonempty-string? (cr-receipt-why receipt))
         (and (cr-nonempty-string? (cr-receipt-who receipt))
              (cr-nonempty-string? (cr-receipt-where receipt)))))
(defn cr-receipt-measure-valid? (receipt)
    (and (ge (cr-receipt-when receipt) 0) (ge (cr-receipt-cost receipt) 0)))
(defn cr-receipt-structure-valid? (receipt)
    (and (cr-choice-candidates-valid? (cr-receipt-candidates receipt))
         (and (cr-outcome-known? (cr-receipt-outcome receipt))
              (and (cr-choice-value-valid? (cr-receipt-value receipt))
                   (cr-choice-trace-valid? (cr-receipt-trace receipt))))))
(defn cr-receipt-witness-valid? (receipt)
    (and (cr-selection-shape-valid? receipt) (cr-outcome-trace-agrees? receipt)))
(defn cr-choice-receipt-valid? (receipt)
    (if (cr-choice-receipt? receipt)
        (and (cr-receipt-text-valid? receipt)
             (and (cr-receipt-certainty-valid? receipt)
                  (and (cr-receipt-attribution-valid? receipt)
                       (and (cr-receipt-measure-valid? receipt)
                            (and (cr-receipt-structure-valid? receipt)
                                 (cr-receipt-witness-valid? receipt))))))
        false))

(defn cr-choice-signature (receipt)
    (do
        (let trace (cr-receipt-trace receipt))
        (let value (cr-receipt-value receipt))
        (list CR-TAG-CHOICE-SIGNATURE
              (cr-receipt-expression receipt)
              (cr-receipt-surface receipt)
              (cr-receipt-category receipt)
              (cr-receipt-selected-path receipt)
              (cr-outcome-code (cr-receipt-outcome receipt))
              (cr-certainty-bucket (cr-receipt-certainty receipt))
              (cr-count-bucket (len (cr-receipt-candidates receipt)))
              (cr-value-kind value)
              (cr-value-bucket (cr-value-branch-feedback value))
              (cr-value-bucket (cr-value-alignment value))
              (cr-value-bucket (cr-value-knowing value))
              (cr-value-bucket (cr-value-trust value))
              (cr-receipt-who receipt)
              (cr-receipt-where receipt)
              (cr-trace-attempts trace)
              (cr-trace-successes trace)
              (cr-trace-failures trace)
              (cr-trace-silences trace))))
(defn cr-choice-signature? (signature)
    (cr-tagged? signature CR-TAG-CHOICE-SIGNATURE 19))
(defn cr-signature-expression (signature) (nth signature 1))
(defn cr-signature-surface (signature) (nth signature 2))
(defn cr-signature-category (signature) (nth signature 3))
(defn cr-signature-selected-path (signature) (nth signature 4))
(defn cr-signature-outcome-code (signature) (nth signature 5))
(defn cr-signature-certainty-bucket (signature) (nth signature 6))
(defn cr-signature-candidate-count-bucket (signature) (nth signature 7))
(defn cr-signature-value-kind (signature) (nth signature 8))
(defn cr-signature-branch-feedback-bucket (signature) (nth signature 9))
(defn cr-signature-alignment-bucket (signature) (nth signature 10))
(defn cr-signature-knowing-bucket (signature) (nth signature 11))
(defn cr-signature-trust-bucket (signature) (nth signature 12))
(defn cr-signature-who (signature) (nth signature 13))
(defn cr-signature-where (signature) (nth signature 14))
(defn cr-signature-attempts (signature) (nth signature 15))
(defn cr-signature-successes (signature) (nth signature 16))
(defn cr-signature-failures (signature) (nth signature 17))
(defn cr-signature-silences (signature) (nth signature 18))

(defn cr-choice-signature-values-preserve? (receipt signature)
    (do
        (let value (cr-receipt-value receipt))
        (and (str_eq (cr-signature-value-kind signature) (cr-value-kind value))
             (and (eq (cr-signature-branch-feedback-bucket signature) (cr-value-bucket (cr-value-branch-feedback value)))
                  (and (eq (cr-signature-alignment-bucket signature) (cr-value-bucket (cr-value-alignment value)))
                       (and (eq (cr-signature-knowing-bucket signature) (cr-value-bucket (cr-value-knowing value)))
                            (eq (cr-signature-trust-bucket signature) (cr-value-bucket (cr-value-trust value)))))))))
(defn cr-choice-signature-trace-preserves? (receipt signature)
    (do
        (let trace (cr-receipt-trace receipt))
        (and (eq (cr-signature-attempts signature) (cr-trace-attempts trace))
             (and (eq (cr-signature-successes signature) (cr-trace-successes trace))
                  (and (eq (cr-signature-failures signature) (cr-trace-failures trace))
                       (eq (cr-signature-silences signature) (cr-trace-silences trace)))))))
(defn cr-choice-signature-surface-preserves? (receipt signature)
    (and (str_eq (cr-signature-expression signature) (cr-receipt-expression receipt))
         (and (str_eq (cr-signature-surface signature) (cr-receipt-surface receipt))
              (and (str_eq (cr-signature-category signature) (cr-receipt-category receipt))
                   (and (str_eq (cr-signature-selected-path signature) (cr-receipt-selected-path receipt))
                        (and (eq (cr-signature-outcome-code signature) (cr-outcome-code (cr-receipt-outcome receipt)))
                             (and (eq (cr-signature-certainty-bucket signature) (cr-certainty-bucket (cr-receipt-certainty receipt)))
                                  (eq (cr-signature-candidate-count-bucket signature) (cr-count-bucket (len (cr-receipt-candidates receipt)))))))))))
(defn cr-choice-signature-attribution-preserves? (receipt signature)
    (and (str_eq (cr-signature-who signature) (cr-receipt-who receipt))
         (str_eq (cr-signature-where signature) (cr-receipt-where receipt))))
(defn cr-choice-signature-preserves? (receipt signature)
    (if (cr-choice-signature? signature)
        (and (cr-choice-signature-surface-preserves? receipt signature)
             (and (cr-choice-signature-values-preserve? receipt signature)
                  (and (cr-choice-signature-attribution-preserves? receipt signature)
                       (cr-choice-signature-trace-preserves? receipt signature))))
        false))

0
