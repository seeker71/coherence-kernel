; speech-native-neural-pair-window-0003.fk -- third native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; en<->id. It uses the same Form-native NL/audio baseline and enabled neural
; micro-kernel path, increasing trained neural pair coverage from two to three
; without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw3-kind () "speech-native-neural-pair-window-0003")
    (defn snpw3-a () "en")
    (defn snpw3-b () "id")
    (defn snpw3-meaning () 302)
    (defn snpw3-floor () 50)
    (defn snpw3-max-wer () 25)
    (defn snpw3-meta () (mlap-meta 98 96 15 67))
    (defn snpw3-feat () (list 2600 26 2 2))
    (defn snpw3-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw3-meaning)) locale))

    (defn snpw3-nl (src dst)
        (mlap-nl-sample (snpw3-meaning) src dst
                        (snpw3-tokens src)
                        (snpw3-tokens dst)
                        (snpw3-meaning)
                        0 0 0))

    (defn snpw3-audio (src dst)
        (mlap-audio-sample (snpw3-meaning) src dst
                           (snpw3-tokens dst)
                           (snpw3-tokens dst)
                           (snpw3-feat)
                           (snpw3-meta)
                           0 0 0))

    (defn snpw3-nl-lanes ()
        (list
            (snpw3-nl (snpw3-a) (snpw3-b))
            (snpw3-nl (snpw3-b) (snpw3-a))
            (snpw3-nl (snpw3-a) (snpw3-a))
            (snpw3-nl (snpw3-b) (snpw3-b))))

    (defn snpw3-audio-lanes ()
        (list
            (snpw3-audio (snpw3-a) (snpw3-b))
            (snpw3-audio (snpw3-b) (snpw3-a))
            (snpw3-audio (snpw3-a) (snpw3-a))
            (snpw3-audio (snpw3-b) (snpw3-b))))

    (defn snpw3-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw3-receipt ()
        (do
            (let nl (snpw3-nl-lanes))
            (let audio (snpw3-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw3-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw3-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw3-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw3-neural-rate nl-rate audio-rate boot))
            (list (snpw3-kind)
                  (snpw3-a)
                  (snpw3-b)
                  (snpw3-meaning)
                  1
                  2
                  3
                  6
                  3
                  3
                  before
                  after
                  (if (and (lt before (snpw3-floor)) (ge after (snpw3-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0003-trained-not-open-authority")))

    (defn snpw3-rec-kind            (r) (nth r 0))
    (defn snpw3-rec-a               (r) (nth r 1))
    (defn snpw3-rec-b               (r) (nth r 2))
    (defn snpw3-rec-meaning         (r) (nth r 3))
    (defn snpw3-rec-pair-increment  (r) (nth r 4))
    (defn snpw3-rec-directed-increment (r) (nth r 5))
    (defn snpw3-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw3-rec-cumulative-directed (r) (nth r 7))
    (defn snpw3-rec-epochs          (r) (nth r 8))
    (defn snpw3-rec-params          (r) (nth r 9))
    (defn snpw3-rec-before-rate     (r) (nth r 10))
    (defn snpw3-rec-after-rate      (r) (nth r 11))
    (defn snpw3-rec-shifted         (r) (nth r 12))
    (defn snpw3-rec-form-nl         (r) (nth r 13))
    (defn snpw3-rec-form-audio      (r) (nth r 14))
    (defn snpw3-rec-before-loss     (r) (nth r 15))
    (defn snpw3-rec-after-loss      (r) (nth r 16))
    (defn snpw3-rec-oracle          (r) (nth r 17))
    (defn snpw3-rec-native-form     (r) (nth r 18))
    (defn snpw3-rec-neural          (r) (nth r 19))
    (defn snpw3-rec-open-authority  (r) (nth r 20))
    (defn snpw3-rec-status          (r) (nth r 21))

    0)
