; speech-native-neural-pair-window-0012.fk -- twelfth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; zh<->sa. It connects the Han-script Chinese baseline to the Sanskrit source
; baseline as a native neural micro-pair, increasing trained neural pair
; coverage from eleven to twelve without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw12-kind () "speech-native-neural-pair-window-0012")
    (defn snpw12-a () "zh")
    (defn snpw12-b () "sa")
    (defn snpw12-meaning () 301)
    (defn snpw12-floor () 50)
    (defn snpw12-max-wer () 25)
    (defn snpw12-meta () (mlap-meta 99 99 16 76))
    (defn snpw12-feat () (list 3500 35 2 2))
    (defn snpw12-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw12-meaning)) locale))

    (defn snpw12-nl (src dst)
        (mlap-nl-sample (snpw12-meaning) src dst
                         (snpw12-tokens src)
                         (snpw12-tokens dst)
                         (snpw12-meaning)
                         0 0 0))

    (defn snpw12-audio (src dst)
        (mlap-audio-sample (snpw12-meaning) src dst
                            (snpw12-tokens dst)
                            (snpw12-tokens dst)
                            (snpw12-feat)
                            (snpw12-meta)
                            0 0 0))

    (defn snpw12-nl-lanes ()
        (list
            (snpw12-nl (snpw12-a) (snpw12-b))
            (snpw12-nl (snpw12-b) (snpw12-a))
            (snpw12-nl (snpw12-a) (snpw12-a))
            (snpw12-nl (snpw12-b) (snpw12-b))))

    (defn snpw12-audio-lanes ()
        (list
            (snpw12-audio (snpw12-a) (snpw12-b))
            (snpw12-audio (snpw12-b) (snpw12-a))
            (snpw12-audio (snpw12-a) (snpw12-a))
            (snpw12-audio (snpw12-b) (snpw12-b))))

    (defn snpw12-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw12-receipt ()
        (do
            (let nl (snpw12-nl-lanes))
            (let audio (snpw12-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw12-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw12-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw12-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw12-neural-rate nl-rate audio-rate boot))
            (list (snpw12-kind)
                  (snpw12-a)
                  (snpw12-b)
                  (snpw12-meaning)
                  1
                  2
                  12
                  24
                  12
                  12
                  before
                  after
                  (if (and (lt before (snpw12-floor)) (ge after (snpw12-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0012-trained-not-open-authority")))

    (defn snpw12-rec-kind            (r) (nth r 0))
    (defn snpw12-rec-a               (r) (nth r 1))
    (defn snpw12-rec-b               (r) (nth r 2))
    (defn snpw12-rec-meaning         (r) (nth r 3))
    (defn snpw12-rec-pair-increment  (r) (nth r 4))
    (defn snpw12-rec-directed-increment (r) (nth r 5))
    (defn snpw12-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw12-rec-cumulative-directed (r) (nth r 7))
    (defn snpw12-rec-epochs          (r) (nth r 8))
    (defn snpw12-rec-params          (r) (nth r 9))
    (defn snpw12-rec-before-rate     (r) (nth r 10))
    (defn snpw12-rec-after-rate      (r) (nth r 11))
    (defn snpw12-rec-shifted         (r) (nth r 12))
    (defn snpw12-rec-form-nl         (r) (nth r 13))
    (defn snpw12-rec-form-audio      (r) (nth r 14))
    (defn snpw12-rec-before-loss     (r) (nth r 15))
    (defn snpw12-rec-after-loss      (r) (nth r 16))
    (defn snpw12-rec-oracle          (r) (nth r 17))
    (defn snpw12-rec-native-form     (r) (nth r 18))
    (defn snpw12-rec-neural          (r) (nth r 19))
    (defn snpw12-rec-open-authority  (r) (nth r 20))
    (defn snpw12-rec-status          (r) (nth r 21))

    0)
