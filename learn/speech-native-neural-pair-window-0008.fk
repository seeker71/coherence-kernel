; speech-native-neural-pair-window-0008.fk -- eighth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; en<->es. It uses the same Form-native NL/audio baseline and enabled neural
; micro-kernel path, increasing trained neural pair coverage from seven to eight
; without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw8-kind () "speech-native-neural-pair-window-0008")
    (defn snpw8-a () "en")
    (defn snpw8-b () "es")
    (defn snpw8-meaning () 302)
    (defn snpw8-floor () 50)
    (defn snpw8-max-wer () 25)
    (defn snpw8-meta () (mlap-meta 98 98 15 72))
    (defn snpw8-feat () (list 3100 31 2 2))
    (defn snpw8-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw8-meaning)) locale))

    (defn snpw8-nl (src dst)
        (mlap-nl-sample (snpw8-meaning) src dst
                        (snpw8-tokens src)
                        (snpw8-tokens dst)
                        (snpw8-meaning)
                        0 0 0))

    (defn snpw8-audio (src dst)
        (mlap-audio-sample (snpw8-meaning) src dst
                           (snpw8-tokens dst)
                           (snpw8-tokens dst)
                           (snpw8-feat)
                           (snpw8-meta)
                           0 0 0))

    (defn snpw8-nl-lanes ()
        (list
            (snpw8-nl (snpw8-a) (snpw8-b))
            (snpw8-nl (snpw8-b) (snpw8-a))
            (snpw8-nl (snpw8-a) (snpw8-a))
            (snpw8-nl (snpw8-b) (snpw8-b))))

    (defn snpw8-audio-lanes ()
        (list
            (snpw8-audio (snpw8-a) (snpw8-b))
            (snpw8-audio (snpw8-b) (snpw8-a))
            (snpw8-audio (snpw8-a) (snpw8-a))
            (snpw8-audio (snpw8-b) (snpw8-b))))

    (defn snpw8-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw8-receipt ()
        (do
            (let nl (snpw8-nl-lanes))
            (let audio (snpw8-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw8-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw8-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw8-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw8-neural-rate nl-rate audio-rate boot))
            (list (snpw8-kind)
                  (snpw8-a)
                  (snpw8-b)
                  (snpw8-meaning)
                  1
                  2
                  8
                  16
                  8
                  8
                  before
                  after
                  (if (and (lt before (snpw8-floor)) (ge after (snpw8-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0008-trained-not-open-authority")))

    (defn snpw8-rec-kind            (r) (nth r 0))
    (defn snpw8-rec-a               (r) (nth r 1))
    (defn snpw8-rec-b               (r) (nth r 2))
    (defn snpw8-rec-meaning         (r) (nth r 3))
    (defn snpw8-rec-pair-increment  (r) (nth r 4))
    (defn snpw8-rec-directed-increment (r) (nth r 5))
    (defn snpw8-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw8-rec-cumulative-directed (r) (nth r 7))
    (defn snpw8-rec-epochs          (r) (nth r 8))
    (defn snpw8-rec-params          (r) (nth r 9))
    (defn snpw8-rec-before-rate     (r) (nth r 10))
    (defn snpw8-rec-after-rate      (r) (nth r 11))
    (defn snpw8-rec-shifted         (r) (nth r 12))
    (defn snpw8-rec-form-nl         (r) (nth r 13))
    (defn snpw8-rec-form-audio      (r) (nth r 14))
    (defn snpw8-rec-before-loss     (r) (nth r 15))
    (defn snpw8-rec-after-loss      (r) (nth r 16))
    (defn snpw8-rec-oracle          (r) (nth r 17))
    (defn snpw8-rec-native-form     (r) (nth r 18))
    (defn snpw8-rec-neural          (r) (nth r 19))
    (defn snpw8-rec-open-authority  (r) (nth r 20))
    (defn snpw8-rec-status          (r) (nth r 21))

    0)
