; speech-native-neural-pair-window-0005.fk -- fifth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; en<->ar. It uses the same Form-native NL/audio baseline and enabled neural
; micro-kernel path, increasing trained neural pair coverage from four to five
; without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw5-kind () "speech-native-neural-pair-window-0005")
    (defn snpw5-a () "en")
    (defn snpw5-b () "ar")
    (defn snpw5-meaning () 304)
    (defn snpw5-floor () 50)
    (defn snpw5-max-wer () 25)
    (defn snpw5-meta () (mlap-meta 99 98 14 69))
    (defn snpw5-feat () (list 2800 28 2 2))
    (defn snpw5-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw5-meaning)) locale))

    (defn snpw5-nl (src dst)
        (mlap-nl-sample (snpw5-meaning) src dst
                        (snpw5-tokens src)
                        (snpw5-tokens dst)
                        (snpw5-meaning)
                        0 0 0))

    (defn snpw5-audio (src dst)
        (mlap-audio-sample (snpw5-meaning) src dst
                           (snpw5-tokens dst)
                           (snpw5-tokens dst)
                           (snpw5-feat)
                           (snpw5-meta)
                           0 0 0))

    (defn snpw5-nl-lanes ()
        (list
            (snpw5-nl (snpw5-a) (snpw5-b))
            (snpw5-nl (snpw5-b) (snpw5-a))
            (snpw5-nl (snpw5-a) (snpw5-a))
            (snpw5-nl (snpw5-b) (snpw5-b))))

    (defn snpw5-audio-lanes ()
        (list
            (snpw5-audio (snpw5-a) (snpw5-b))
            (snpw5-audio (snpw5-b) (snpw5-a))
            (snpw5-audio (snpw5-a) (snpw5-a))
            (snpw5-audio (snpw5-b) (snpw5-b))))

    (defn snpw5-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw5-receipt ()
        (do
            (let nl (snpw5-nl-lanes))
            (let audio (snpw5-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw5-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw5-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw5-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw5-neural-rate nl-rate audio-rate boot))
            (list (snpw5-kind)
                  (snpw5-a)
                  (snpw5-b)
                  (snpw5-meaning)
                  1
                  2
                  5
                  10
                  5
                  5
                  before
                  after
                  (if (and (lt before (snpw5-floor)) (ge after (snpw5-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0005-trained-not-open-authority")))

    (defn snpw5-rec-kind            (r) (nth r 0))
    (defn snpw5-rec-a               (r) (nth r 1))
    (defn snpw5-rec-b               (r) (nth r 2))
    (defn snpw5-rec-meaning         (r) (nth r 3))
    (defn snpw5-rec-pair-increment  (r) (nth r 4))
    (defn snpw5-rec-directed-increment (r) (nth r 5))
    (defn snpw5-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw5-rec-cumulative-directed (r) (nth r 7))
    (defn snpw5-rec-epochs          (r) (nth r 8))
    (defn snpw5-rec-params          (r) (nth r 9))
    (defn snpw5-rec-before-rate     (r) (nth r 10))
    (defn snpw5-rec-after-rate      (r) (nth r 11))
    (defn snpw5-rec-shifted         (r) (nth r 12))
    (defn snpw5-rec-form-nl         (r) (nth r 13))
    (defn snpw5-rec-form-audio      (r) (nth r 14))
    (defn snpw5-rec-before-loss     (r) (nth r 15))
    (defn snpw5-rec-after-loss      (r) (nth r 16))
    (defn snpw5-rec-oracle          (r) (nth r 17))
    (defn snpw5-rec-native-form     (r) (nth r 18))
    (defn snpw5-rec-neural          (r) (nth r 19))
    (defn snpw5-rec-open-authority  (r) (nth r 20))
    (defn snpw5-rec-status          (r) (nth r 21))

    0)
