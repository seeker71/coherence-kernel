; speech-native-neural-pair-window-0027.fk -- twenty-seventh native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; zh<->pt-br. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw27-kind () "speech-native-neural-pair-window-0027")
    (defn snpw27-a () "zh")
    (defn snpw27-b () "pt-br")
    (defn snpw27-meaning () 303)
    (defn snpw27-floor () 50)
    (defn snpw27-max-wer () 25)
    (defn snpw27-meta () (mlap-meta 96 97 11 80))
    (defn snpw27-feat () (list 3040 32 2 2))
    (defn snpw27-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw27-meaning)) locale))

    (defn snpw27-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0027-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw27-oracle-locale (r) (nth r 1))
    (defn snpw27-oracle-voice  (r) (nth r 2))
    (defn snpw27-oracle-transcript (r) (nth r 3))
    (defn snpw27-oracle-wer    (r) (nth r 4))
    (defn snpw27-oracle-bytes  (r) (nth r 5))
    (defn snpw27-oracle-cksum  (r) (nth r 6))
    (defn snpw27-oracle-name   (r) (nth r 7))
    (defn snpw27-oracle-device (r) (nth r 8))

    (defn snpw27-oracle-rows ()
        (list
            (snpw27-oracle-row "zh" "Tingting" "我在。" 0 15064 3568659029)
            (snpw27-oracle-row "pt-br" "Flo (Portuguese (Brazil))" "Eu sou." 0 31774 1996659987)))

    (defn snpw27-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw27-oracle-wer (head rows)) (snpw27-max-wer)) 1 0)
                 (snpw27-oracle-ok-loop (tail rows)))))
    (defn snpw27-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw27-oracle-bytes (head rows))
                 (snpw27-oracle-byte-total-loop (tail rows)))))

    (defn snpw27-nl (src dst)
        (mlap-nl-sample (snpw27-meaning) src dst
                         (snpw27-tokens src)
                         (snpw27-tokens dst)
                         (snpw27-meaning)
                         0 0 0))

    (defn snpw27-audio (src dst)
        (mlap-audio-sample (snpw27-meaning) src dst
                            (snpw27-tokens dst)
                            (snpw27-tokens dst)
                            (snpw27-feat)
                            (snpw27-meta)
                            0 0 0))

    (defn snpw27-nl-lanes ()
        (list
            (snpw27-nl (snpw27-a) (snpw27-b))
            (snpw27-nl (snpw27-b) (snpw27-a))
            (snpw27-nl (snpw27-a) (snpw27-a))
            (snpw27-nl (snpw27-b) (snpw27-b))))

    (defn snpw27-audio-lanes ()
        (list
            (snpw27-audio (snpw27-a) (snpw27-b))
            (snpw27-audio (snpw27-b) (snpw27-a))
            (snpw27-audio (snpw27-a) (snpw27-a))
            (snpw27-audio (snpw27-b) (snpw27-b))))

    (defn snpw27-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw27-receipt ()
        (do
            (let nl (snpw27-nl-lanes))
            (let audio (snpw27-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw27-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw27-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw27-max-wer)))
            (let oracle-rows (snpw27-oracle-rows))
            (let oracle-ok (snpw27-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw27-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw27-kind)
                  (snpw27-a)
                  (snpw27-b)
                  (snpw27-meaning)
                  1
                  2
                  27
                  54
                  27
                  27
                  before
                  after
                  (if (and (lt before (snpw27-floor)) (ge after (snpw27-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw27-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0027-trained-not-open-authority")))

    (defn snpw27-rec-kind            (r) (nth r 0))
    (defn snpw27-rec-a               (r) (nth r 1))
    (defn snpw27-rec-b               (r) (nth r 2))
    (defn snpw27-rec-meaning         (r) (nth r 3))
    (defn snpw27-rec-pair-increment  (r) (nth r 4))
    (defn snpw27-rec-directed-increment (r) (nth r 5))
    (defn snpw27-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw27-rec-cumulative-directed (r) (nth r 7))
    (defn snpw27-rec-epochs          (r) (nth r 8))
    (defn snpw27-rec-params          (r) (nth r 9))
    (defn snpw27-rec-before-rate     (r) (nth r 10))
    (defn snpw27-rec-after-rate      (r) (nth r 11))
    (defn snpw27-rec-shifted         (r) (nth r 12))
    (defn snpw27-rec-form-nl         (r) (nth r 13))
    (defn snpw27-rec-form-audio      (r) (nth r 14))
    (defn snpw27-rec-before-loss     (r) (nth r 15))
    (defn snpw27-rec-after-loss      (r) (nth r 16))
    (defn snpw27-rec-oracle-ok       (r) (nth r 17))
    (defn snpw27-rec-oracle-total    (r) (nth r 18))
    (defn snpw27-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw27-rec-oracle          (r) (nth r 20))
    (defn snpw27-rec-native-form     (r) (nth r 21))
    (defn snpw27-rec-neural          (r) (nth r 22))
    (defn snpw27-rec-open-authority  (r) (nth r 23))
    (defn snpw27-rec-status          (r) (nth r 24))

    0)
