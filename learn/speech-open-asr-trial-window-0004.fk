; speech-open-asr-trial-window-0004.fk -- fourth scoped open-ASR source window.
;
; This window adds a real local Mac loopback pair for the scheduler's
; background de<->pt-br lane while keeping authority on the open-ASR source
; task. The local oracle rows came from macOS say -> ffmpeg -> whisper.cpp on
; Apple Metal; punctuation/case are normalized before the oracle pass.
;
; preludes: learn/speech-oracle-native-backlog.fk learn/speech-next-trial-scheduler.fk learn/speech-open-asr-trial-window.fk learn/speech-open-asr-trial-window-0002.fk learn/speech-open-asr-trial-window-0003.fk

(do
    (defn soat4-sample (id locale voice truth heard oracle-ok native-ok audio-hash bytes latency consent fail timeout undo)
        (list "speech-open-asr-trial-sample-0004"
              id locale voice truth heard oracle-ok native-ok audio-hash bytes latency consent fail timeout undo))
    (defn soat4-sample-oracle (s) (nth s 6))
    (defn soat4-sample-native (s) (nth s 7))
    (defn soat4-sample-bytes  (s) (nth s 9))
    (defn soat4-sample-clean? (s)
        (if (and (eq (nth s 11) 1)
                 (eq (add (add (nth s 12) (nth s 13)) (nth s 14)) 0)) 1 0))

    (defn soat4-samples ()
        (list
            (soat4-sample 9407 "de" "Flo (German (Germany))"
                          "ich bin" "Ich bin..." 1 1 108967973 29216 42 1 0 0 0)
            (soat4-sample 9408 "pt-br" "Flo (Portuguese (Brazil))"
                          "eu sou" "Eu sou." 1 1 1996659987 31774 44 1 0 0 0)))

    (defn soat4-count-oracle (samples)
        (if (eq (len samples) 0) 0
            (add
                (if (eq (soat4-sample-clean? (head samples)) 1)
                    (soat4-sample-oracle (head samples))
                    0)
                (soat4-count-oracle (tail samples)))))

    (defn soat4-count-native (samples)
        (if (eq (len samples) 0) 0
            (add
                (if (eq (soat4-sample-clean? (head samples)) 1)
                    (soat4-sample-native (head samples))
                    0)
                (soat4-count-native (tail samples)))))

    (defn soat4-count-bytes (samples)
        (if (eq (len samples) 0) 0
            (add
                (if (eq (soat4-sample-clean? (head samples)) 1)
                    (soat4-sample-bytes (head samples))
                    0)
                (soat4-count-bytes (tail samples)))))

    (defn soat4-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn soat4-segmented-receipt ()
        (do
            (let previous (soat3-segmented-receipt))
            (let samples (soat4-samples))
            (let count (add (soat-receipt-count previous) (len samples)))
            (let oracle-ok (add (soat-receipt-oracle-ok previous) (soat4-count-oracle samples)))
            (let native-ok (add (soat-receipt-native-ok previous) (soat4-count-native samples)))
            (list "speech-open-asr-segmented-trial-receipt-0004"
                  "macos-arm64-m4-max"
                  "whisper.cpp-large-v3-turbo-metal"
                  "multi"
                  "multi"
                  count
                  oracle-ok
                  native-ok
                  (soat4-rate native-ok count)
                  50
                  "native"
                  303
                  "aham-asmi"
                  (list "ich" "bin" "eu" "sou")
                  1
                  0
                  (soat4-count-bytes samples)
                  "de+pt-br-metal-loopback")))

    (defn soat4-report ()
        (do
            (let trial (soat-next-trial))
            (let receipt (soat4-segmented-receipt))
            (list "speech-open-asr-trial-window-0004"
                  trial
                  receipt
                  (snts-oracle-rate trial)
                  (snts-native-rate trial)
                  (soat-receipt-oracle-ok receipt)
                  (soat-receipt-native-ok receipt)
                  (soat-receipt-native-rate receipt)
                  (soat-promote-action receipt)
                  "choice-cut-fail-undo-timeout-clean"
                  (snts-model-context)
                  "trial-window-native-not-global-authority"
                  (nth receipt 16)
                  (nth receipt 17)
                  1
                  0)))

    0)
