; speech-native-neural-pair-window-0014.fk -- fourteenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; zh<->la. It connects the Han-script Chinese baseline to the Latin baseline as
; a native neural micro-pair, increasing trained neural pair coverage from
; thirteen to fourteen without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw14-kind () "speech-native-neural-pair-window-0014")
    (defn snpw14-a () "zh")
    (defn snpw14-b () "la")
    (defn snpw14-meaning () 301)
    (defn snpw14-floor () 50)
    (defn snpw14-max-wer () 25)
    (defn snpw14-meta () (mlap-meta 98 97 16 78))
    (defn snpw14-feat () (list 3700 37 2 2))
    (defn snpw14-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw14-meaning)) locale))

    (defn snpw14-nl (src dst)
        (mlap-nl-sample (snpw14-meaning) src dst
                         (snpw14-tokens src)
                         (snpw14-tokens dst)
                         (snpw14-meaning)
                         0 0 0))

    (defn snpw14-audio (src dst)
        (mlap-audio-sample (snpw14-meaning) src dst
                            (snpw14-tokens dst)
                            (snpw14-tokens dst)
                            (snpw14-feat)
                            (snpw14-meta)
                            0 0 0))

    (defn snpw14-nl-lanes ()
        (list
            (snpw14-nl (snpw14-a) (snpw14-b))
            (snpw14-nl (snpw14-b) (snpw14-a))
            (snpw14-nl (snpw14-a) (snpw14-a))
            (snpw14-nl (snpw14-b) (snpw14-b))))

    (defn snpw14-audio-lanes ()
        (list
            (snpw14-audio (snpw14-a) (snpw14-b))
            (snpw14-audio (snpw14-b) (snpw14-a))
            (snpw14-audio (snpw14-a) (snpw14-a))
            (snpw14-audio (snpw14-b) (snpw14-b))))

    (defn snpw14-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw14-receipt ()
        (do
            (let nl (snpw14-nl-lanes))
            (let audio (snpw14-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw14-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw14-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw14-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw14-neural-rate nl-rate audio-rate boot))
            (list (snpw14-kind)
                  (snpw14-a)
                  (snpw14-b)
                  (snpw14-meaning)
                  1
                  2
                  14
                  28
                  14
                  14
                  before
                  after
                  (if (and (lt before (snpw14-floor)) (ge after (snpw14-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0014-trained-not-open-authority")))

    (defn snpw14-rec-kind            (r) (nth r 0))
    (defn snpw14-rec-a               (r) (nth r 1))
    (defn snpw14-rec-b               (r) (nth r 2))
    (defn snpw14-rec-meaning         (r) (nth r 3))
    (defn snpw14-rec-pair-increment  (r) (nth r 4))
    (defn snpw14-rec-directed-increment (r) (nth r 5))
    (defn snpw14-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw14-rec-cumulative-directed (r) (nth r 7))
    (defn snpw14-rec-epochs          (r) (nth r 8))
    (defn snpw14-rec-params          (r) (nth r 9))
    (defn snpw14-rec-before-rate     (r) (nth r 10))
    (defn snpw14-rec-after-rate      (r) (nth r 11))
    (defn snpw14-rec-shifted         (r) (nth r 12))
    (defn snpw14-rec-form-nl         (r) (nth r 13))
    (defn snpw14-rec-form-audio      (r) (nth r 14))
    (defn snpw14-rec-before-loss     (r) (nth r 15))
    (defn snpw14-rec-after-loss      (r) (nth r 16))
    (defn snpw14-rec-oracle          (r) (nth r 17))
    (defn snpw14-rec-native-form     (r) (nth r 18))
    (defn snpw14-rec-neural          (r) (nth r 19))
    (defn snpw14-rec-open-authority  (r) (nth r 20))
    (defn snpw14-rec-status          (r) (nth r 21))

    0)
