; speech-native-neural-pair-window-0031.fk -- thirty-first native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; en<->it. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw31-kind () "speech-native-neural-pair-window-0031")
    (defn snpw31-a () "en")
    (defn snpw31-b () "it")
    (defn snpw31-meaning () 303)
    (defn snpw31-floor () 50)
    (defn snpw31-max-wer () 25)
    (defn snpw31-meta () (mlap-meta 96 97 11 80))
    (defn snpw31-feat () (list 3040 32 2 2))
    (defn snpw31-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw31-meaning)) locale))

    (defn snpw31-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0031-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw31-oracle-locale (r) (nth r 1))
    (defn snpw31-oracle-voice  (r) (nth r 2))
    (defn snpw31-oracle-transcript (r) (nth r 3))
    (defn snpw31-oracle-wer    (r) (nth r 4))
    (defn snpw31-oracle-bytes  (r) (nth r 5))
    (defn snpw31-oracle-cksum  (r) (nth r 6))
    (defn snpw31-oracle-name   (r) (nth r 7))
    (defn snpw31-oracle-device (r) (nth r 8))

    (defn snpw31-oracle-rows ()
        (list
            (snpw31-oracle-row "en" "Samantha" "I am." 0 18170 3569739330)
            (snpw31-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw31-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw31-oracle-wer (head rows)) (snpw31-max-wer)) 1 0)
                 (snpw31-oracle-ok-loop (tail rows)))))
    (defn snpw31-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw31-oracle-bytes (head rows))
                 (snpw31-oracle-byte-total-loop (tail rows)))))

    (defn snpw31-nl (src dst)
        (mlap-nl-sample (snpw31-meaning) src dst
                         (snpw31-tokens src)
                         (snpw31-tokens dst)
                         (snpw31-meaning)
                         0 0 0))

    (defn snpw31-audio (src dst)
        (mlap-audio-sample (snpw31-meaning) src dst
                            (snpw31-tokens dst)
                            (snpw31-tokens dst)
                            (snpw31-feat)
                            (snpw31-meta)
                            0 0 0))

    (defn snpw31-nl-lanes ()
        (list
            (snpw31-nl (snpw31-a) (snpw31-b))
            (snpw31-nl (snpw31-b) (snpw31-a))
            (snpw31-nl (snpw31-a) (snpw31-a))
            (snpw31-nl (snpw31-b) (snpw31-b))))

    (defn snpw31-audio-lanes ()
        (list
            (snpw31-audio (snpw31-a) (snpw31-b))
            (snpw31-audio (snpw31-b) (snpw31-a))
            (snpw31-audio (snpw31-a) (snpw31-a))
            (snpw31-audio (snpw31-b) (snpw31-b))))

    (defn snpw31-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw31-receipt ()
        (do
            (let nl (snpw31-nl-lanes))
            (let audio (snpw31-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw31-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw31-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw31-max-wer)))
            (let oracle-rows (snpw31-oracle-rows))
            (let oracle-ok (snpw31-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw31-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw31-kind)
                  (snpw31-a)
                  (snpw31-b)
                  (snpw31-meaning)
                  1
                  2
                  31
                  62
                  31
                  31
                  before
                  after
                  (if (and (lt before (snpw31-floor)) (ge after (snpw31-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw31-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0031-trained-not-open-authority")))

    (defn snpw31-rec-kind            (r) (nth r 0))
    (defn snpw31-rec-a               (r) (nth r 1))
    (defn snpw31-rec-b               (r) (nth r 2))
    (defn snpw31-rec-meaning         (r) (nth r 3))
    (defn snpw31-rec-pair-increment  (r) (nth r 4))
    (defn snpw31-rec-directed-increment (r) (nth r 5))
    (defn snpw31-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw31-rec-cumulative-directed (r) (nth r 7))
    (defn snpw31-rec-epochs          (r) (nth r 8))
    (defn snpw31-rec-params          (r) (nth r 9))
    (defn snpw31-rec-before-rate     (r) (nth r 10))
    (defn snpw31-rec-after-rate      (r) (nth r 11))
    (defn snpw31-rec-shifted         (r) (nth r 12))
    (defn snpw31-rec-form-nl         (r) (nth r 13))
    (defn snpw31-rec-form-audio      (r) (nth r 14))
    (defn snpw31-rec-before-loss     (r) (nth r 15))
    (defn snpw31-rec-after-loss      (r) (nth r 16))
    (defn snpw31-rec-oracle-ok       (r) (nth r 17))
    (defn snpw31-rec-oracle-total    (r) (nth r 18))
    (defn snpw31-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw31-rec-oracle          (r) (nth r 20))
    (defn snpw31-rec-native-form     (r) (nth r 21))
    (defn snpw31-rec-neural          (r) (nth r 22))
    (defn snpw31-rec-open-authority  (r) (nth r 23))
    (defn snpw31-rec-status          (r) (nth r 24))

    0)
