; speech-host-device-receipt-intake.fk -- host/device observations into live receipts.
;
; Real carriers arrive as device observations first: macOS CoreAudio/Whisper,
; Android AAudio capture, Windows WASAPI, or another local host membrane. This
; cell keeps provenance and shared-device safety as compact metadata, then lowers
; the audio facts into the existing speech-live-receipt row shape. Closed-prompt
; Android capture is useful evidence, but it is not open dictation or Sema live
; voice authority.
;
; preludes:
;   learn/speech-model-metrics-report.fk
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/sema-voice-trial-window.fk
;   learn/speech-current-status-ledger.fk
;   learn/speech-global-promotion-readiness.fk
;   learn/speech-live-receipt-intake.fk
;   learn/speech-global-authority-update.fk
;   learn/speech-authority-model-selection.fk

(do
    (defn shd-observation (id platform lane task evidence shared-safe global-scope)
        (list "speech-host-device-observation"
              id platform lane task evidence shared-safe global-scope))

    (defn shd-kind         (o) (nth o 0))
    (defn shd-id           (o) (nth o 1))
    (defn shd-platform     (o) (nth o 2))
    (defn shd-lane         (o) (nth o 3))
    (defn shd-task         (o) (nth o 4))
    (defn shd-evidence     (o) (nth o 5))
    (defn shd-shared-safe  (o) (nth o 6))
    (defn shd-global-scope (o) (nth o 7))

    (defn shd-current-observations ()
        (list
            (shd-observation 9901 "android-arm64" "closed-prompt-loopback"
                             "closed-prompt-loopback"
                             "android-aaudio-capture-learning-receipt" 1 0)
            (shd-observation 9902 "macos-arm64" "sema-live-voice"
                             "sema-live-voice"
                             "current-sema-formant-wer-100" 1 1)
            (shd-observation 9903 "android-arm64" "live-open-dictation"
                             "open-dictation"
                             "shared-device-not-safe-yet" 0 1)))

    (defn shd-count-platform (observations platform)
        (if (eq (len observations) 0) 0
            (add (if (str_eq (shd-platform (head observations)) platform) 1 0)
                 (shd-count-platform (tail observations) platform))))

    (defn shd-count-global-scope (observations)
        (if (eq (len observations) 0) 0
            (add (shd-global-scope (head observations))
                 (shd-count-global-scope (tail observations)))))

    (defn shd-current-live-rows ()
        (list
            (slri-row "closed-prompt-loopback" 9901 "android-aaudio-phone"
                      "local-prompt-label" 446225 16000 1 "we are"
                      0 0 95 90 1 1 0 0 0)
            (slri-row "sema-live-voice" 9902 "macos-arm64-m4-max"
                      "whisper.cpp-large-v3-turbo-metal" 110100002 16000 1
                      "Open speech flows." 100 100 0 0 1 1 0 0 0)
            (slri-row "live-open-dictation" 9903 "android-aaudio-phone"
                      "local-android-stt-oracle" 230002 16000 1
                      "open speech flows" 0 0 91 142 1 0 0 0 0)))

    (defn shd-demo-open-rows ()
        (list
            (slri-row "live-open-dictation" 9911 "macos-arm64-m4-max"
                      "whisper.cpp-large-v3-turbo-metal" 991101 16000 1
                      "open speech flows" 0 0 92 130 1 1 0 0 0)
            (slri-row "live-open-dictation" 9912 "android-aaudio-phone"
                      "local-android-stt-oracle" 991102 16000 1
                      "truth alone triumphs" 0 0 91 150 1 1 0 0 0)
            (slri-row "live-open-dictation" 9913 "macos-arm64-m4-max"
                      "whisper.cpp-large-v3-turbo-metal" 991103 16000 1
                      "i am" 0 0 90 136 1 1 0 0 0)))

    (defn shd-demo-voice-rows ()
        (list
            (slri-row "sema-live-voice" 9921 "android-aaudio-phone"
                      "local-android-stt-oracle" 992101 16000 1
                      "Open speech flows." 0 0 94 118 1 1 0 0 0)
            (slri-row "sema-live-voice" 9922 "macos-arm64-m4-max"
                      "whisper.cpp-large-v3-turbo-metal" 992102 16000 1
                      "Open speech flows." 0 0 93 114 1 1 0 0 0)
            (slri-row "sema-live-voice" 9923 "android-aaudio-phone"
                      "local-android-stt-oracle" 992103 16000 1
                      "Open speech flows." 0 0 92 122 1 1 0 0 0)))

    (defn shd-append (a b)
        (if (eq (len a) 0) b
            (cons (head a) (shd-append (tail a) b))))

    (defn shd-demo-live-rows ()
        (shd-append (shd-demo-open-rows) (shd-demo-voice-rows)))

    (defn shd-authority-updates (rows)
        (list
            (sgau-lane-update "live-open-dictation" rows "native-open-asr-source")
            (sgau-lane-update "sema-live-voice" rows "native-sema-voice")))

    (defn shd-report ()
        (do
            (let current-obs (shd-current-observations))
            (let current-rows (shd-current-live-rows))
            (let demo-rows (shd-demo-live-rows))
            (let current-updates (shd-authority-updates current-rows))
            (let demo-updates (shd-authority-updates demo-rows))
            (let current-selection (sams-selection current-updates "host-device-current-keeps-global-speech-oracle-guided"))
            (let demo-selection (sams-selection demo-updates "host-device-demo-promotes-global-speech-native"))
            (list "speech-host-device-receipt-intake"
                  current-obs
                  current-rows
                  demo-rows
                  current-updates
                  demo-updates
                  current-selection
                  demo-selection
                  (slri-count-lane current-rows "live-open-dictation" 25 80 2000)
                  (slri-count-lane current-rows "sema-live-voice" 25 80 2000)
                  (slri-count-lane demo-rows "live-open-dictation" 25 80 2000)
                  (slri-count-lane demo-rows "sema-live-voice" 25 80 2000)
                  (shd-count-platform current-obs "android-arm64")
                  (shd-count-platform current-obs "macos-arm64")
                  (shd-count-global-scope current-obs)
                  "closed-prompt-and-shared-device-observations-do-not-promote-global-speech"
                  1
                  0)))

    0)
