; speech-native-neural-pair-window-0018.fk -- eighteenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; de<->id. It connects the German baseline to the Indonesian baseline as a
; native neural micro-pair, increasing trained neural pair coverage from
; seventeen to eighteen without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw18-kind () "speech-native-neural-pair-window-0018")
    (defn snpw18-a () "de")
    (defn snpw18-b () "id")
    (defn snpw18-meaning () 301)
    (defn snpw18-floor () 50)
    (defn snpw18-max-wer () 25)
    (defn snpw18-meta () (mlap-meta 95 96 17 82))
    (defn snpw18-feat () (list 4100 41 2 2))
    (defn snpw18-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw18-meaning)) locale))

    (defn snpw18-nl (src dst)
        (mlap-nl-sample (snpw18-meaning) src dst
                         (snpw18-tokens src)
                         (snpw18-tokens dst)
                         (snpw18-meaning)
                         0 0 0))

    (defn snpw18-audio (src dst)
        (mlap-audio-sample (snpw18-meaning) src dst
                            (snpw18-tokens dst)
                            (snpw18-tokens dst)
                            (snpw18-feat)
                            (snpw18-meta)
                            0 0 0))

    (defn snpw18-nl-lanes ()
        (list
            (snpw18-nl (snpw18-a) (snpw18-b))
            (snpw18-nl (snpw18-b) (snpw18-a))
            (snpw18-nl (snpw18-a) (snpw18-a))
            (snpw18-nl (snpw18-b) (snpw18-b))))

    (defn snpw18-audio-lanes ()
        (list
            (snpw18-audio (snpw18-a) (snpw18-b))
            (snpw18-audio (snpw18-b) (snpw18-a))
            (snpw18-audio (snpw18-a) (snpw18-a))
            (snpw18-audio (snpw18-b) (snpw18-b))))

    (defn snpw18-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw18-receipt ()
        (do
            (let nl (snpw18-nl-lanes))
            (let audio (snpw18-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw18-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw18-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw18-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw18-neural-rate nl-rate audio-rate boot))
            (list (snpw18-kind)
                  (snpw18-a)
                  (snpw18-b)
                  (snpw18-meaning)
                  1
                  2
                  18
                  36
                  18
                  18
                  before
                  after
                  (if (and (lt before (snpw18-floor)) (ge after (snpw18-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0018-trained-not-open-authority")))

    (defn snpw18-rec-kind            (r) (nth r 0))
    (defn snpw18-rec-a               (r) (nth r 1))
    (defn snpw18-rec-b               (r) (nth r 2))
    (defn snpw18-rec-meaning         (r) (nth r 3))
    (defn snpw18-rec-pair-increment  (r) (nth r 4))
    (defn snpw18-rec-directed-increment (r) (nth r 5))
    (defn snpw18-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw18-rec-cumulative-directed (r) (nth r 7))
    (defn snpw18-rec-epochs          (r) (nth r 8))
    (defn snpw18-rec-params          (r) (nth r 9))
    (defn snpw18-rec-before-rate     (r) (nth r 10))
    (defn snpw18-rec-after-rate      (r) (nth r 11))
    (defn snpw18-rec-shifted         (r) (nth r 12))
    (defn snpw18-rec-form-nl         (r) (nth r 13))
    (defn snpw18-rec-form-audio      (r) (nth r 14))
    (defn snpw18-rec-before-loss     (r) (nth r 15))
    (defn snpw18-rec-after-loss      (r) (nth r 16))
    (defn snpw18-rec-oracle          (r) (nth r 17))
    (defn snpw18-rec-native-form     (r) (nth r 18))
    (defn snpw18-rec-neural          (r) (nth r 19))
    (defn snpw18-rec-open-authority  (r) (nth r 20))
    (defn snpw18-rec-status          (r) (nth r 21))

    0)
