; constellation-learning-lane.fk -- a transcript teaching merged into the
; ingest / learning / reasoning lane.
;
; Source: the 2026-07-03 transcript on constellation thinking
; (https://youtu.be/pAjm2cIu-Fo). The transcript's invariant teaching is not
; stored as a pile of words: meaning appears from positions and relations.
;
; This cell keeps that shape small and runnable:
;   - ingest: deep, fear-free invariant meaning can freeze into the body
;     through knowledge-ingest.fk.
;   - recall: a constellation asks for more than a single grounded hit when
;     there are multiple positions and edges.
;   - learning: an equivalent challenger in the same context may replace the
;     champion; an equivalent challenger from another context is retained as
;     parallax instead of collapsed into a binary winner.
;   - reasoning: a graph of taught edges is searched and returns a trace; a
;     missing path fails honestly.
;
; Honest floor: toy integer positions and linear skill edges. The law is the
; route shape, not a full semantic graph.
;
; preludes: ingest/knowledge-ingest.fk learn/recipe-learning.fk learn/sema-reason-search.fk

(do
    (defn cll-unit () (list 5 0))             ; deep, fear-free teaching unit
    (defn cll-ingest-state () (ki-ingest (cll-unit)))

    (defn cll-constellation? (positions edges)
        (if (ge positions 2)
            (if (ge edges 1) 1 0)
            0))

    ; A single point can retrieve as a single hit. A constellation keeps the
    ; field wide enough for the positions to stay visible.
    (defn cll-retrieval-width (positions edges)
        (if (eq (cll-constellation? positions edges) 1) positions 1))

    ; Route codes:
    ;   0 = reject / hold champion
    ;   1 = replace champion in the same context
    ;   2 = preserve as context-parallax, not a binary loss
    (defn cll-learn-route (champ chall equiv same-context)
        (if (eq equiv 0)
            0
            (if (eq same-context 1)
                (if (eq (c-id (consider champ chall equiv)) (c-id chall)) 1 0)
                2)))

    (defn cll-learn-result (route champion parallax)
        (list route champion parallax))
    (defn cll-result-route (r) (nth r 0))
    (defn cll-result-champion (r) (nth r 1))
    (defn cll-result-parallax (r) (nth r 2))

    ; The route code alone is not preservation. This single-challenger result
    ; keeps the challenger visible when it belongs to another context; stream
    ; accumulation is a later layer.
    (defn cll-consider-with-parallax (champ chall equiv same-context)
        (do (let route (cll-learn-route champ chall equiv same-context))
            (if (eq route 2)
                (cll-learn-result route champ (list chall))
                (if (eq route 1)
                    (cll-learn-result route chall (list))
                    (cll-learn-result route champ (list))))))

    ; A small meaning graph: position 0 -> 1 -> 2 -> 3. The decoy 0 -> 8
    ; proves the search is not a fixed path and still returns honest no-path
    ; for an unreachable goal.
    (defn cll-reg () (list
        (list 0 8 9)
        (list 0 1 2)
        (list 1 2 3)
        (list 2 3 4)))

    (defn cll-reason-value () (reason (cll-reg) 0 3 1))
    (defn cll-reason-depth () (reason-len (cll-reg) 0 3))
    (defn cll-reason-miss () (reason (cll-reg) 0 9 1))

    (defn cllk (ok bit) (if ok bit 0))
    (defn constellation-learning-lane-check ()
        (do
            (let champ (cand 1 10))
            (let chall (cand 2 30))
            (let para (cll-consider-with-parallax champ chall 1 0))
            (let same (cll-consider-with-parallax champ chall 1 1))
            (add (add (add (add (add (add (add (add (add
                (cllk (eq (cll-ingest-state) 2) 1)
                (cllk (eq (cll-retrieval-width 3 2) 3) 2))
                (cllk (eq (cll-retrieval-width 1 0) 1) 4))
                (cllk (eq (cll-learn-route champ chall 1 0) 2) 8))
                (cllk (eq (cll-learn-route champ chall 1 1) 1) 16))
                (cllk (eq (cll-reason-value) 24) 32))
                (cllk (eq (cll-reason-depth) 3) 64))
                (cllk (eq (cll-reason-miss) -1) 128))
                (cllk (and (eq (cll-result-route para) 2)
                           (and (eq (len (cll-result-parallax para)) 1)
                                (eq (c-id (head (cll-result-parallax para))) 2))) 256))
                (cllk (and (eq (cll-result-route same) 1)
                           (and (eq (c-id (cll-result-champion same)) 2)
                                (eq (len (cll-result-parallax same)) 0))) 512))))

    0)
