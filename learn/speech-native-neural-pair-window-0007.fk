; speech-native-neural-pair-window-0007.fk -- seventh native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; en<->de. It uses the same Form-native NL/audio baseline and enabled neural
; micro-kernel path, increasing trained neural pair coverage from six to seven
; without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw7-kind () "speech-native-neural-pair-window-0007")
    (defn snpw7-a () "en")
    (defn snpw7-b () "de")
    (defn snpw7-meaning () 302)
    (defn snpw7-floor () 50)
    (defn snpw7-max-wer () 25)
    (defn snpw7-meta () (mlap-meta 98 97 15 71))
    (defn snpw7-feat () (list 3000 30 2 2))
    (defn snpw7-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw7-meaning)) locale))

    (defn snpw7-nl (src dst)
        (mlap-nl-sample (snpw7-meaning) src dst
                        (snpw7-tokens src)
                        (snpw7-tokens dst)
                        (snpw7-meaning)
                        0 0 0))

    (defn snpw7-audio (src dst)
        (mlap-audio-sample (snpw7-meaning) src dst
                           (snpw7-tokens dst)
                           (snpw7-tokens dst)
                           (snpw7-feat)
                           (snpw7-meta)
                           0 0 0))

    (defn snpw7-nl-lanes ()
        (list
            (snpw7-nl (snpw7-a) (snpw7-b))
            (snpw7-nl (snpw7-b) (snpw7-a))
            (snpw7-nl (snpw7-a) (snpw7-a))
            (snpw7-nl (snpw7-b) (snpw7-b))))

    (defn snpw7-audio-lanes ()
        (list
            (snpw7-audio (snpw7-a) (snpw7-b))
            (snpw7-audio (snpw7-b) (snpw7-a))
            (snpw7-audio (snpw7-a) (snpw7-a))
            (snpw7-audio (snpw7-b) (snpw7-b))))

    (defn snpw7-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw7-receipt ()
        (do
            (let nl (snpw7-nl-lanes))
            (let audio (snpw7-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw7-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw7-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw7-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw7-neural-rate nl-rate audio-rate boot))
            (list (snpw7-kind)
                  (snpw7-a)
                  (snpw7-b)
                  (snpw7-meaning)
                  1
                  2
                  7
                  14
                  7
                  7
                  before
                  after
                  (if (and (lt before (snpw7-floor)) (ge after (snpw7-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0007-trained-not-open-authority")))

    (defn snpw7-rec-kind            (r) (nth r 0))
    (defn snpw7-rec-a               (r) (nth r 1))
    (defn snpw7-rec-b               (r) (nth r 2))
    (defn snpw7-rec-meaning         (r) (nth r 3))
    (defn snpw7-rec-pair-increment  (r) (nth r 4))
    (defn snpw7-rec-directed-increment (r) (nth r 5))
    (defn snpw7-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw7-rec-cumulative-directed (r) (nth r 7))
    (defn snpw7-rec-epochs          (r) (nth r 8))
    (defn snpw7-rec-params          (r) (nth r 9))
    (defn snpw7-rec-before-rate     (r) (nth r 10))
    (defn snpw7-rec-after-rate      (r) (nth r 11))
    (defn snpw7-rec-shifted         (r) (nth r 12))
    (defn snpw7-rec-form-nl         (r) (nth r 13))
    (defn snpw7-rec-form-audio      (r) (nth r 14))
    (defn snpw7-rec-before-loss     (r) (nth r 15))
    (defn snpw7-rec-after-loss      (r) (nth r 16))
    (defn snpw7-rec-oracle          (r) (nth r 17))
    (defn snpw7-rec-native-form     (r) (nth r 18))
    (defn snpw7-rec-neural          (r) (nth r 19))
    (defn snpw7-rec-open-authority  (r) (nth r 20))
    (defn snpw7-rec-status          (r) (nth r 21))

    0)
