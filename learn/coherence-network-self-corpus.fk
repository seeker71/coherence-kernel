; coherence-network-self-corpus.fk -- use our translated Coherence Network body as training material.
;
; Ground observed in ~/source/Coherence-Network:
;   web/messages/{en,de,es,fr,id,pt-br}.json       2019 shared keys each
;   cli/lib/messages/{en,de,es,fr,id,pt-br}.json     45 shared keys each
;
; The corpus is ours and already translated, so it is a consentful self-corpus.
; Languages that are valuable but not yet translated are backfill targets, not
; ready training rows.

(do
    (defn cnsc-source (surface path keypaths locales owned license attribution)
        (list "coherence-network-source" surface path keypaths locales owned license attribution))
    (defn cnsc-source-kind        (s) (nth s 0))
    (defn cnsc-source-surface     (s) (nth s 1))
    (defn cnsc-source-path        (s) (nth s 2))
    (defn cnsc-source-keypaths    (s) (nth s 3))
    (defn cnsc-source-locales     (s) (nth s 4))
    (defn cnsc-source-owned       (s) (nth s 5))
    (defn cnsc-source-license     (s) (nth s 6))
    (defn cnsc-source-attribution (s) (nth s 7))

    (defn cnsc-sources ()
        (list
            (cnsc-source "web" "Coherence-Network/web/messages" 2019 6 1 1 1)
            (cnsc-source "cli" "Coherence-Network/cli/lib/messages" 45 6 1 1 1)))

    (defn cnsc-source-ready? (s)
        (if (and (eq (cnsc-source-owned s) 1)
                 (and (eq (cnsc-source-license s) 1)
                      (and (eq (cnsc-source-attribution s) 1)
                           (and (ge (cnsc-source-locales s) 2)
                                (gt (cnsc-source-keypaths s) 0))))) 1 0))

    (defn cnsc-all-sources-ready-loop (sources)
        (if (eq (len sources) 0) 1
            (if (eq (cnsc-source-ready? (head sources)) 1)
                (cnsc-all-sources-ready-loop (tail sources))
                0)))
    (defn cnsc-all-sources-ready? () (cnsc-all-sources-ready-loop (cnsc-sources)))

    (defn cnsc-total-keypaths-loop (sources)
        (if (eq (len sources) 0) 0
            (add (cnsc-source-keypaths (head sources))
                 (cnsc-total-keypaths-loop (tail sources)))))
    (defn cnsc-total-keypaths () (cnsc-total-keypaths-loop (cnsc-sources)))

    (defn cnsc-locale (code family script typology region translated accepted consent backfill)
        (list "coherence-network-locale" code family script typology region translated accepted consent backfill))
    (defn cnsc-loc-kind       (l) (nth l 0))
    (defn cnsc-loc-code       (l) (nth l 1))
    (defn cnsc-loc-family     (l) (nth l 2))
    (defn cnsc-loc-script     (l) (nth l 3))
    (defn cnsc-loc-typology   (l) (nth l 4))
    (defn cnsc-loc-region     (l) (nth l 5))
    (defn cnsc-loc-translated (l) (nth l 6))
    (defn cnsc-loc-accepted   (l) (nth l 7))
    (defn cnsc-loc-consent    (l) (nth l 8))
    (defn cnsc-loc-backfill   (l) (nth l 9))

    (defn cnsc-locales ()
        (list
            (cnsc-locale "en" "indo-european-germanic" "latin" "analytic-stress" "europe" 1 1 1 0)
            (cnsc-locale "de" "indo-european-germanic" "latin" "fusional-stress" "europe" 1 1 1 0)
            (cnsc-locale "es" "indo-european-romance" "latin" "fusional-stress" "europe-americas" 1 1 1 0)
            (cnsc-locale "fr" "indo-european-romance" "latin" "fusional-stress" "europe" 1 1 1 0)
            (cnsc-locale "id" "austronesian" "latin" "analytic-affix" "southeast-asia" 1 1 1 0)
            (cnsc-locale "pt-br" "indo-european-romance" "latin" "fusional-stress" "south-america" 1 1 1 0)
            (cnsc-locale "zh" "sino-tibetan" "han" "analytic-tonal" "east-asia" 0 0 1 1)
            (cnsc-locale "ar" "afro-asiatic-semitic" "arabic" "templatic-root" "west-asia" 0 0 1 1)
            (cnsc-locale "la" "indo-european-romance" "latin" "fusional-classical" "europe" 0 0 1 1)
            (cnsc-locale "nv" "dene" "latin" "polysynthetic-tonal" "north-america" 0 0 0 0)
            (cnsc-locale "chr" "iroquoian" "cherokee" "polysynthetic" "north-america" 0 0 0 0)))

    (defn cnsc-ready? (l)
        (if (and (eq (cnsc-loc-translated l) 1)
                 (and (eq (cnsc-loc-accepted l) 1)
                      (eq (cnsc-loc-consent l) 1))) 1 0))

    (defn cnsc-backfill? (l)
        (if (and (eq (cnsc-loc-backfill l) 1)
                 (and (eq (cnsc-loc-translated l) 0)
                      (eq (cnsc-loc-consent l) 1))) 1 0))

    (defn cnsc-locale-by-code-loop (rows code)
        (if (eq (len rows) 0) (empty)
            (if (str_eq (cnsc-loc-code (head rows)) code)
                (head rows)
                (cnsc-locale-by-code-loop (tail rows) code))))
    (defn cnsc-locale-by-code (code) (cnsc-locale-by-code-loop (cnsc-locales) code))

    (defn cnsc-ready-code? (code)
        (do
            (let row (cnsc-locale-by-code code))
            (if (gt (len row) 0) (cnsc-ready? row) 0)))

    (defn cnsc-backfill-code? (code)
        (do
            (let row (cnsc-locale-by-code code))
            (if (gt (len row) 0) (cnsc-backfill? row) 0)))

    (defn cnsc-ready-count-loop (rows)
        (if (eq (len rows) 0) 0
            (add (cnsc-ready? (head rows))
                 (cnsc-ready-count-loop (tail rows)))))
    (defn cnsc-ready-count () (cnsc-ready-count-loop (cnsc-locales)))

    (defn cnsc-backfill-count-loop (rows)
        (if (eq (len rows) 0) 0
            (add (cnsc-backfill? (head rows))
                 (cnsc-backfill-count-loop (tail rows)))))
    (defn cnsc-backfill-count () (cnsc-backfill-count-loop (cnsc-locales)))

    (defn cnsc-pair-ready? (a b)
        (if (and (eq (cnsc-ready-code? a) 1)
                 (and (eq (cnsc-ready-code? b) 1)
                      (not (str_eq a b)))) 1 0))

    (defn cnsc-self-corpus-ready? ()
        (if (and (eq (cnsc-all-sources-ready?) 1)
                 (ge (cnsc-ready-count) 2)) 1 0))

    (defn cnsc-parallel-en-pairs ()
        (mul (cnsc-total-keypaths) (sub (cnsc-ready-count) 1)))

    0)
