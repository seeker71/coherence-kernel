; bidirectional-locale-roundtrip.fk -- A<->B guide for voice/text/meaning learning.
;
; Transcript and translation side channels are teachers, not answer leaks. A
; direction receipt records text, audio, and locale-neutral Form meaning before
; and after a loop. Trust grows when A->B and B->A both improve, plus mono-locale
; voice/text loops. If one side leads, the guide asks for the return path before
; native authority expands.
;
; A direction row:
;   src-locale dst-locale src-text dst-text src-meaning dst-meaning
;   native-before native-after oracle-score audio-ok text-ok fail timeout undo
;
; Meaning equality is represented by matching Form-native meaning ids. The real
; NL<->Form parser can later supply richer recipe/data nodes without changing
; the learning gate.

(do
    (defn blr-dir (src dst src-text dst-text src-meaning dst-meaning
                   native-before native-after oracle-score audio-ok text-ok
                   fail timeout undo)
        (list "bidirectional-locale-direction"
              src dst src-text dst-text src-meaning dst-meaning
              native-before native-after oracle-score audio-ok text-ok
              fail timeout undo))

    (defn blr-kind          (r) (nth r 0))
    (defn blr-src           (r) (nth r 1))
    (defn blr-dst           (r) (nth r 2))
    (defn blr-src-text      (r) (nth r 3))
    (defn blr-dst-text      (r) (nth r 4))
    (defn blr-src-meaning   (r) (nth r 5))
    (defn blr-dst-meaning   (r) (nth r 6))
    (defn blr-before        (r) (nth r 7))
    (defn blr-after         (r) (nth r 8))
    (defn blr-oracle        (r) (nth r 9))
    (defn blr-audio-ok      (r) (nth r 10))
    (defn blr-text-ok       (r) (nth r 11))
    (defn blr-fail          (r) (nth r 12))
    (defn blr-timeout       (r) (nth r 13))
    (defn blr-undo          (r) (nth r 14))

    (defn blr-control-clean? (r)
        (if (eq (add (add (blr-fail r) (blr-timeout r)) (blr-undo r)) 0) 1 0))
    (defn blr-cross? (r)
        (if (str_eq (blr-src r) (blr-dst r)) 0 1))
    (defn blr-mono? (r)
        (if (str_eq (blr-src r) (blr-dst r)) 1 0))
    (defn blr-meaning-ok? (r)
        (if (eq (blr-src-meaning r) (blr-dst-meaning r)) 1 0))
    (defn blr-improved? (r)
        (if (lt (abs (sub (blr-oracle r) (blr-after r)))
                (abs (sub (blr-oracle r) (blr-before r)))) 1 0))
    (defn blr-success? (r)
        (if (and (eq (blr-control-clean? r) 1)
                 (and (eq (blr-audio-ok r) 1)
                      (and (eq (blr-text-ok r) 1)
                           (and (eq (blr-meaning-ok? r) 1)
                                (eq (blr-improved? r) 1))))) 1 0))

    (defn blr-direction-match? (r src dst)
        (if (and (str_eq (blr-src r) src) (str_eq (blr-dst r) dst)) 1 0))
    (defn blr-find (rows src dst)
        (if (eq (len rows) 0)
            (blr-dir "" "" "" "" 0 1 0 0 1 0 0 1 0 0)
            (if (eq (blr-direction-match? (head rows) src dst) 1)
                (head rows)
                (blr-find (tail rows) src dst))))

    (defn blr-has-success? (rows src dst)
        (blr-success? (blr-find rows src dst)))
    (defn blr-cross-pair-success? (rows a b)
        (if (and (eq (blr-has-success? rows a b) 1)
                 (eq (blr-has-success? rows b a) 1)) 1 0))
    (defn blr-mono-pair-success? (rows a b)
        (if (and (eq (blr-has-success? rows a a) 1)
                 (eq (blr-has-success? rows b b) 1)) 1 0))
    (defn blr-balanced? (rows a b)
        (if (and (eq (blr-cross-pair-success? rows a b) 1)
                 (eq (blr-mono-pair-success? rows a b) 1)) 1 0))

    (defn blr-needs-return-path? (rows a b)
        (if (and (eq (blr-has-success? rows a b) 1)
                 (eq (blr-has-success? rows b a) 0)) 1 0))

    (defn blr-route (rows a b)
        (if (eq (blr-balanced? rows a b) 1)
            "native"
            "oracle-guide"))

    (defn blr-receipt (rows a b)
        (list "bidirectional-locale-roundtrip"
              a b
              (blr-has-success? rows a b)
              (blr-has-success? rows b a)
              (blr-has-success? rows a a)
              (blr-has-success? rows b b)
              (blr-needs-return-path? rows a b)
              (blr-route rows a b)))

    (defn blr-rec-kind    (r) (nth r 0))
    (defn blr-rec-a       (r) (nth r 1))
    (defn blr-rec-b       (r) (nth r 2))
    (defn blr-rec-ab      (r) (nth r 3))
    (defn blr-rec-ba      (r) (nth r 4))
    (defn blr-rec-aa      (r) (nth r 5))
    (defn blr-rec-bb      (r) (nth r 6))
    (defn blr-rec-return-needed (r) (nth r 7))
    (defn blr-rec-route   (r) (nth r 8))

    0)
