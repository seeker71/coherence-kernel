; source-window-audio2audio-authority.fk -- source ASR window feeds acoustic audio2audio.
;
; The source side now has a multilocale segmented source-ASR window. The target
; side already has a metal-witnessed decoded-token audio2audio acoustic route.
; This cell composes those two witnessed summaries into one authority row:
; source speech -> native source tokens -> neutral Form -> target acoustic
; frames. It is still not live microphone streaming and not neural speech.
;
; witness sources:
;   learn/multilocale-segmented-source-window.fk
;   learn/tests/multilocale-segmented-source-window-band.fk
;   learn/metal-audio2audio-acoustic-authority.fk
;   learn/tests/metal-audio2audio-acoustic-authority-band.fk

(do
    (defn swa2a-bit (cond) (if cond 1 0))

    (defn swa2a-source-ready? (samples pairs oracle before after rate ready-pairs
                                      before-native after-native native-form oracle-metal neural-metal min-pairs floor)
        (if (eq
                (add
                    (add
                        (add (swa2a-bit (ge samples 6))
                             (swa2a-bit (ge pairs min-pairs)))
                        (add (swa2a-bit (ge oracle samples))
                             (swa2a-bit (eq before 0))))
                    (add
                        (add (swa2a-bit (ge after samples))
                             (swa2a-bit (ge rate floor)))
                        (add
                            (add (swa2a-bit (ge ready-pairs min-pairs))
                                 (swa2a-bit (eq before-native 0)))
                            (add
                                (add (swa2a-bit (eq after-native 1))
                                     (swa2a-bit (eq native-form 1)))
                                (add (swa2a-bit (eq oracle-metal 1))
                                     (swa2a-bit (eq neural-metal 0)))))))
                12) 1 0))

    (defn swa2a-target-ready? (acoustic-rows acoustic-pairs acoustic-pass acoustic-ready-pairs
                                      live-observed live-ready live-target route-metal authority
                                      native-form oracle-metal neural-pending min-acoustic-pairs min-live)
        (if (eq
                (add
                    (add
                        (add (swa2a-bit (ge acoustic-rows 10))
                             (swa2a-bit (ge acoustic-pairs min-acoustic-pairs)))
                        (add (swa2a-bit (ge acoustic-pass acoustic-rows))
                             (swa2a-bit (ge acoustic-ready-pairs min-acoustic-pairs))))
                    (add
                        (add (swa2a-bit (ge live-observed min-live))
                             (swa2a-bit (ge live-ready live-target)))
                        (add
                            (add (swa2a-bit (eq route-metal 1))
                                 (swa2a-bit (eq authority 1)))
                            (add
                                (add (swa2a-bit (eq native-form 1))
                                     (swa2a-bit (eq oracle-metal 1)))
                                (swa2a-bit (eq neural-pending 1))))))
                11) 1 0))

    (defn swa2a-route (source-ready target-ready)
        (if (and (eq source-ready 1) (eq target-ready 1))
            "native-source-window-audio2audio-acoustic"
            (if (eq source-ready 1)
                "source-native-target-guide"
                "oracle-guide")))

    (defn swa2a-receipt (source-samples source-pairs source-oracle source-before source-after
                              source-rate source-ready-pairs source-before-native source-after-native
                              source-native-form source-oracle-metal source-neural-metal
                              acoustic-rows acoustic-pairs acoustic-pass acoustic-ready-pairs
                              live-observed live-ready live-target route-metal authority
                              target-native-form target-oracle-metal target-neural-pending
                              oracle device)
        (do
            (let source-ready
                (swa2a-source-ready?
                    source-samples source-pairs source-oracle source-before source-after
                    source-rate source-ready-pairs source-before-native source-after-native
                    source-native-form source-oracle-metal source-neural-metal 3 80))
            (let target-ready
                (swa2a-target-ready?
                    acoustic-rows acoustic-pairs acoustic-pass acoustic-ready-pairs
                    live-observed live-ready live-target route-metal authority
                    target-native-form target-oracle-metal target-neural-pending 5 7))
            (list "source-window-audio2audio-authority"
                  source-ready
                  target-ready
                  (swa2a-route source-ready target-ready)
                  source-samples
                  source-pairs
                  source-after
                  source-rate
                  source-ready-pairs
                  acoustic-rows
                  acoustic-pairs
                  acoustic-pass
                  acoustic-ready-pairs
                  live-observed
                  live-ready
                  live-target
                  oracle
                  device
                  1
                  1
                  0
                  "multilocale-segmented-source-window"
                  "metal-audio2audio-acoustic-authority")))

    (defn swa2a-live-receipt ()
        (swa2a-receipt
            6 3 6 0 6 100 3 0 1 1 1 0
            10 5 10 5 7 7 7 1 1 1 1 1
            "whisper.cpp-large-v3-turbo-metal"
            "macos-arm64-m4-max"))

    (defn swa2a-rec-kind (r) (nth r 0))
    (defn swa2a-rec-source-ready (r) (nth r 1))
    (defn swa2a-rec-target-ready (r) (nth r 2))
    (defn swa2a-rec-route (r) (nth r 3))
    (defn swa2a-rec-native-form (r) (nth r 18))
    (defn swa2a-rec-oracle-metal (r) (nth r 19))
    (defn swa2a-rec-neural-metal (r) (nth r 20))

    0)
