; speech-form-pair-window-0007.fk -- execute the next selected Form pair window.
;
; The previous next-action receipt selected en<->es. This cell runs that pair
; as a closed-set Form-native NL/audio learning window over the Sanskrit
; baseline meaning row. It expands observed Form pair windows; it does not train
; or promote a neural model.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk

(do
    (defn sfw7-kind () "speech-form-pair-window-0007")
    (defn sfw7-a () "en")
    (defn sfw7-b () "es")
    (defn sfw7-meaning () 303)
    (defn sfw7-floor () 50)
    (defn sfw7-max-wer () 25)
    (defn sfw7-meta () (mlap-meta 93 94 18 64))
    (defn sfw7-feat () (list 2300 23 2 2))
    (defn sfw7-tokens (locale) (slb-tokens (slb-line-by-meaning (sfw7-meaning)) locale))

    (defn sfw7-nl (src dst)
        (mlap-nl-sample (sfw7-meaning) src dst
                        (sfw7-tokens src)
                        (sfw7-tokens dst)
                        (sfw7-meaning)
                        0 0 0))

    (defn sfw7-audio (src dst)
        (mlap-audio-sample (sfw7-meaning) src dst
                           (sfw7-tokens dst)
                           (sfw7-tokens dst)
                           (sfw7-feat)
                           (sfw7-meta)
                           0 0 0))

    (defn sfw7-nl-lanes ()
        (list
            (sfw7-nl (sfw7-a) (sfw7-b))
            (sfw7-nl (sfw7-b) (sfw7-a))
            (sfw7-nl (sfw7-a) (sfw7-a))
            (sfw7-nl (sfw7-b) (sfw7-b))))

    (defn sfw7-audio-lanes ()
        (list
            (sfw7-audio (sfw7-a) (sfw7-b))
            (sfw7-audio (sfw7-b) (sfw7-a))
            (sfw7-audio (sfw7-a) (sfw7-a))
            (sfw7-audio (sfw7-b) (sfw7-b))))

    (defn sfw7-route-code (nl-rate audio-rate)
        (if (and (ge nl-rate (sfw7-floor)) (ge audio-rate (sfw7-floor))) 1 0))

    (defn sfw7-receipt ()
        (do
            (let nl (sfw7-nl-lanes))
            (let audio (sfw7-audio-lanes))
            (let before-rows (empty))
            (let before-audio (empty))
            (let after-rows (mlap-nl-trained-rows nl before-rows))
            (let after-audio (mlap-audio-trained-candidates audio before-audio (sfw7-max-wer)))
            (let before-nl (mlap-nl-rate nl before-rows (sfw7-max-wer)))
            (let after-nl (mlap-nl-rate nl after-rows (sfw7-max-wer)))
            (let before-audio-rate (mlap-audio-rate audio before-audio (sfw7-max-wer)))
            (let after-audio-rate (mlap-audio-rate audio after-audio (sfw7-max-wer)))
            (let before-route (sfw7-route-code before-nl before-audio-rate))
            (let after-route (sfw7-route-code after-nl after-audio-rate))
            (list (sfw7-kind)
                  (sfw7-a)
                  (sfw7-b)
                  (sfw7-meaning)
                  (len nl)
                  (len audio)
                  before-nl
                  after-nl
                  before-audio-rate
                  after-audio-rate
                  before-route
                  after-route
                  (if (and (eq before-route 0) (eq after-route 1)) 1 0)
                  1
                  1
                  0
                  1
                  0
                  0
                  "form-native-pair-window-not-neural-training")))

    (defn sfw7-rec-kind         (r) (nth r 0))
    (defn sfw7-rec-a            (r) (nth r 1))
    (defn sfw7-rec-b            (r) (nth r 2))
    (defn sfw7-rec-meaning      (r) (nth r 3))
    (defn sfw7-rec-nl-lanes     (r) (nth r 4))
    (defn sfw7-rec-audio-lanes  (r) (nth r 5))
    (defn sfw7-rec-before-nl    (r) (nth r 6))
    (defn sfw7-rec-after-nl     (r) (nth r 7))
    (defn sfw7-rec-before-audio (r) (nth r 8))
    (defn sfw7-rec-after-audio  (r) (nth r 9))
    (defn sfw7-rec-before-route (r) (nth r 10))
    (defn sfw7-rec-after-route  (r) (nth r 11))
    (defn sfw7-rec-shifted      (r) (nth r 12))
    (defn sfw7-rec-oracle       (r) (nth r 13))
    (defn sfw7-rec-native-form  (r) (nth r 14))
    (defn sfw7-rec-neural       (r) (nth r 15))
    (defn sfw7-rec-control      (r) (nth r 16))
    (defn sfw7-rec-diffusion    (r) (nth r 17))
    (defn sfw7-rec-trained-neural (r) (nth r 18))
    (defn sfw7-rec-status       (r) (nth r 19))

    0)
