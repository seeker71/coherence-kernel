; speech-corpus-capture-batch-0002.fk -- second live self-corpus audio batch.
;
; This batch renders twenty-four consentful Coherence Network self-corpus text
; rows with local macOS voices, normalizes them to wav, transcribes them with
; local whisper.cpp on Metal, and records oracle WER plus wav bytes. These are
; captured corpus rows, not trained rows and not native ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/coherence-network-self-corpus.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-acquisition-window.fk

(do
    (defn sccb2-kind () "speech-corpus-capture-batch-0002")
    (defn sccb2-out-dir () (str_concat (temp_dir) "/speech-corpus-capture-batch-0002"))

    (defn sccb2-row (id locale key text voice whisper-lang)
        (list "speech-corpus-capture-row" id locale key text voice whisper-lang))
    (defn sccb2-row-id      (r) (nth r 1))
    (defn sccb2-row-locale  (r) (nth r 2))
    (defn sccb2-row-key     (r) (nth r 3))
    (defn sccb2-row-text    (r) (nth r 4))
    (defn sccb2-row-voice   (r) (nth r 5))
    (defn sccb2-row-lang    (r) (nth r 6))

    (defn sccb2-rows ()
        (list
            (sccb2-row 1 "en" "common.close" "Close" "Flo (English (US))" "en")
            (sccb2-row 2 "en" "common.cancel" "Cancel" "Flo (English (US))" "en")
            (sccb2-row 3 "en" "common.submit" "Submit" "Flo (English (US))" "en")
            (sccb2-row 4 "en" "nav.search" "Search" "Flo (English (US))" "en")
            (sccb2-row 5 "de" "common.close" "Schließen" "Flo (German (Germany))" "de")
            (sccb2-row 6 "de" "common.yes" "Ja" "Flo (German (Germany))" "de")
            (sccb2-row 7 "de" "common.no" "Nein" "Flo (German (Germany))" "de")
            (sccb2-row 8 "de" "nav.search" "Suche" "Flo (German (Germany))" "de")
            (sccb2-row 9 "es" "common.save" "Guardar" "Flo (Spanish (Spain))" "es")
            (sccb2-row 10 "es" "common.yes" "Sí" "Flo (Spanish (Spain))" "es")
            (sccb2-row 11 "es" "common.no" "No" "Flo (Spanish (Spain))" "es")
            (sccb2-row 12 "es" "hatiSuci.status.open" "Abierto" "Flo (Spanish (Spain))" "es")
            (sccb2-row 13 "fr" "common.yes" "Oui" "Amélie" "fr")
            (sccb2-row 14 "fr" "common.no" "Non" "Amélie" "fr")
            (sccb2-row 15 "fr" "nav.ideas" "Idées" "Amélie" "fr")
            (sccb2-row 16 "fr" "nav.assets" "Ressources" "Amélie" "fr")
            (sccb2-row 17 "id" "common.close" "Tutup" "Damayanti" "id")
            (sccb2-row 18 "id" "common.cancel" "Batal" "Damayanti" "id")
            (sccb2-row 19 "id" "common.save" "Simpan" "Damayanti" "id")
            (sccb2-row 20 "id" "common.submit" "Kirim" "Damayanti" "id")
            (sccb2-row 21 "pt-br" "common.back" "Voltar" "Flo (Portuguese (Brazil))" "pt")
            (sccb2-row 22 "pt-br" "common.no" "Não" "Flo (Portuguese (Brazil))" "pt")
            (sccb2-row 23 "pt-br" "nav.vision" "Visão" "Flo (Portuguese (Brazil))" "pt")
            (sccb2-row 24 "pt-br" "hatiSuci.act.complete" "Feito" "Flo (Portuguese (Brazil))" "pt")))

    (defn sccb2-path-stem (row)
        (mstal-cat4 (sccb2-out-dir) "/row-" (mstal-int-str (sccb2-row-id row)) ""))
    (defn sccb2-aiff-path (row) (str_concat (sccb2-path-stem row) ".aiff"))
    (defn sccb2-wav-path (row) (str_concat (sccb2-path-stem row) ".wav"))

    (defn sccb2-say-command (row)
        (str_concat
            (str_concat "say -v " (mstal-q (sccb2-row-voice row)))
            (str_concat
                (str_concat " -o " (mstal-q (sccb2-aiff-path row)))
                (str_concat " " (mstal-q (sccb2-row-text row))))))

    (defn sccb2-ffmpeg-command (row)
        (str_concat
            (str_concat "ffmpeg -hide_banner -loglevel error -y -i " (mstal-q (sccb2-aiff-path row)))
            (str_concat " -ar 16000 -ac 1 -c:a pcm_s16le " (mstal-q (sccb2-wav-path row)))))

    (defn sccb2-whisper-command (row)
        (str_concat
            (str_concat "whisper-cli -m " (mstal-q (mstal-model)))
            (str_concat
                (str_concat " -f " (mstal-q (sccb2-wav-path row)))
                (str_concat " -l " (str_concat (sccb2-row-lang row) " -nt -np")))))

    (defn sccb2-render-row (row)
        (do
            (let _mk (fs_mkdir (sccb2-out-dir)))
            (let _say (host-exec (sccb2-say-command row) ""))
            (let _ff (host-exec (sccb2-ffmpeg-command row) ""))
            (sccb2-wav-path row)))

    (defn sccb2-capture-row (row)
        (do
            (let wav (sccb2-render-row row))
            (let transcript (host-exec (sccb2-whisper-command row) ""))
            (let wer (sw-wer (sw-tokens transcript) (sw-tokens (sccb2-row-text row))))
            (list "speech-corpus-capture-receipt-row"
                  (sccb2-row-id row)
                  (sccb2-row-locale row)
                  (sccb2-row-key row)
                  (sccb2-row-text row)
                  transcript
                  wer
                  (if (le wer 25) 1 0)
                  (mstal-audio-hash wav)
                  (len (mstal-env wav))
                  (file_size wav))))

    (defn sccb2-rec-row-id       (r) (nth r 1))
    (defn sccb2-rec-row-locale   (r) (nth r 2))
    (defn sccb2-rec-row-key      (r) (nth r 3))
    (defn sccb2-rec-row-text     (r) (nth r 4))
    (defn sccb2-rec-row-oracle   (r) (nth r 5))
    (defn sccb2-rec-row-wer      (r) (nth r 6))
    (defn sccb2-rec-row-ok       (r) (nth r 7))
    (defn sccb2-rec-row-hash     (r) (nth r 8))
    (defn sccb2-rec-row-windows  (r) (nth r 9))
    (defn sccb2-rec-row-bytes    (r) (nth r 10))

    (defn sccb2-capture-loop (rows)
        (if (eq (len rows) 0) (empty)
            (cons (sccb2-capture-row (head rows))
                  (sccb2-capture-loop (tail rows)))))

    (defn sccb2-count-ok (rows)
        (if (eq (len rows) 0) 0
            (add (sccb2-rec-row-ok (head rows)) (sccb2-count-ok (tail rows)))))

    (defn sccb2-count-hash (rows)
        (if (eq (len rows) 0) 0
            (add (if (gt (sccb2-rec-row-hash (head rows)) 0) 1 0)
                 (sccb2-count-hash (tail rows)))))

    (defn sccb2-max-wer (rows)
        (if (eq (len rows) 0) 0
            (do
                (let rest (sccb2-max-wer (tail rows)))
                (if (gt (sccb2-rec-row-wer (head rows)) rest)
                    (sccb2-rec-row-wer (head rows))
                    rest))))

    (defn sccb2-total-bytes (rows)
        (if (eq (len rows) 0) 0
            (add (sccb2-rec-row-bytes (head rows))
                 (sccb2-total-bytes (tail rows)))))

    (defn sccb2-receipt-from (rows)
        (list (sccb2-kind)
              rows
              (len rows)
              (sccb2-count-ok rows)
              (sccb2-count-hash rows)
              (sccb2-max-wer rows)
              (sccb2-total-bytes rows)
              "captured-corpus-audio-not-training-sufficient"
              1
              0
              0))

    (defn sccb2-run-receipt ()
        (if (eq (mstal-ready?) 1)
            (sccb2-receipt-from (sccb2-capture-loop (sccb2-rows)))
            (list (sccb2-kind) (empty) 0 0 0 100 0 "missing-host-tools" 1 0 0)))

    (defn sccb2-rec-kind        (r) (nth r 0))
    (defn sccb2-rec-rows        (r) (nth r 1))
    (defn sccb2-rec-count       (r) (nth r 2))
    (defn sccb2-rec-ok          (r) (nth r 3))
    (defn sccb2-rec-hash-count  (r) (nth r 4))
    (defn sccb2-rec-max-wer     (r) (nth r 5))
    (defn sccb2-rec-bytes       (r) (nth r 6))
    (defn sccb2-rec-status      (r) (nth r 7))
    (defn sccb2-rec-native-form (r) (nth r 8))
    (defn sccb2-rec-neural      (r) (nth r 9))
    (defn sccb2-rec-trained     (r) (nth r 10))

    (defn sccb2-run-verdict ()
        (do
            (let r (sccb2-run-receipt))
            (add
                (add
                    (add (if (str_eq (sccb2-rec-kind r) (sccb2-kind)) 1 0)
                         (if (eq (sccb2-rec-count r) 24) 2 0))
                    (add (if (eq (sccb2-rec-ok r) 24) 4 0)
                         (if (eq (sccb2-rec-hash-count r) 24) 8 0)))
                (add
                    (add (if (le (sccb2-rec-max-wer r) 25) 16 0)
                         (if (ge (sccb2-rec-bytes r) 500000) 32 0))
                    (add
                        (add (if (str_eq (sccb2-rec-status r)
                                         "captured-corpus-audio-not-training-sufficient") 64 0)
                             (if (eq (sccb2-rec-native-form r) 1) 128 0))
                        (add
                            (add (if (eq (sccb2-rec-neural r) 0) 256 0)
                                 (if (eq (cnsc-self-corpus-ready?) 1) 512 0))
                            (add
                                (add (if (eq (scaw-plan-meets-wav-floor?) 1) 1024 0)
                                     (if (eq (slds-sufficient (slds-current)) 0) 2048 0))
                                (if (eq (sccb2-rec-trained r) 0) 4096 0))))))))

    0)
