; speech-native-neural-pair-window-0013.fk -- thirteenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; ar<->sa. It connects the Arabic baseline to the Sanskrit source baseline as
; a native neural micro-pair, increasing trained neural pair coverage from
; twelve to thirteen without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw13-kind () "speech-native-neural-pair-window-0013")
    (defn snpw13-a () "ar")
    (defn snpw13-b () "sa")
    (defn snpw13-meaning () 301)
    (defn snpw13-floor () 50)
    (defn snpw13-max-wer () 25)
    (defn snpw13-meta () (mlap-meta 99 98 16 77))
    (defn snpw13-feat () (list 3600 36 2 2))
    (defn snpw13-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw13-meaning)) locale))

    (defn snpw13-nl (src dst)
        (mlap-nl-sample (snpw13-meaning) src dst
                         (snpw13-tokens src)
                         (snpw13-tokens dst)
                         (snpw13-meaning)
                         0 0 0))

    (defn snpw13-audio (src dst)
        (mlap-audio-sample (snpw13-meaning) src dst
                            (snpw13-tokens dst)
                            (snpw13-tokens dst)
                            (snpw13-feat)
                            (snpw13-meta)
                            0 0 0))

    (defn snpw13-nl-lanes ()
        (list
            (snpw13-nl (snpw13-a) (snpw13-b))
            (snpw13-nl (snpw13-b) (snpw13-a))
            (snpw13-nl (snpw13-a) (snpw13-a))
            (snpw13-nl (snpw13-b) (snpw13-b))))

    (defn snpw13-audio-lanes ()
        (list
            (snpw13-audio (snpw13-a) (snpw13-b))
            (snpw13-audio (snpw13-b) (snpw13-a))
            (snpw13-audio (snpw13-a) (snpw13-a))
            (snpw13-audio (snpw13-b) (snpw13-b))))

    (defn snpw13-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw13-receipt ()
        (do
            (let nl (snpw13-nl-lanes))
            (let audio (snpw13-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw13-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw13-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw13-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw13-neural-rate nl-rate audio-rate boot))
            (list (snpw13-kind)
                  (snpw13-a)
                  (snpw13-b)
                  (snpw13-meaning)
                  1
                  2
                  13
                  26
                  13
                  13
                  before
                  after
                  (if (and (lt before (snpw13-floor)) (ge after (snpw13-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0013-trained-not-open-authority")))

    (defn snpw13-rec-kind            (r) (nth r 0))
    (defn snpw13-rec-a               (r) (nth r 1))
    (defn snpw13-rec-b               (r) (nth r 2))
    (defn snpw13-rec-meaning         (r) (nth r 3))
    (defn snpw13-rec-pair-increment  (r) (nth r 4))
    (defn snpw13-rec-directed-increment (r) (nth r 5))
    (defn snpw13-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw13-rec-cumulative-directed (r) (nth r 7))
    (defn snpw13-rec-epochs          (r) (nth r 8))
    (defn snpw13-rec-params          (r) (nth r 9))
    (defn snpw13-rec-before-rate     (r) (nth r 10))
    (defn snpw13-rec-after-rate      (r) (nth r 11))
    (defn snpw13-rec-shifted         (r) (nth r 12))
    (defn snpw13-rec-form-nl         (r) (nth r 13))
    (defn snpw13-rec-form-audio      (r) (nth r 14))
    (defn snpw13-rec-before-loss     (r) (nth r 15))
    (defn snpw13-rec-after-loss      (r) (nth r 16))
    (defn snpw13-rec-oracle          (r) (nth r 17))
    (defn snpw13-rec-native-form     (r) (nth r 18))
    (defn snpw13-rec-neural          (r) (nth r 19))
    (defn snpw13-rec-open-authority  (r) (nth r 20))
    (defn snpw13-rec-status          (r) (nth r 21))

    0)
