; speech-corpus-crossvoice-capture-batch-0004.fk -- two-voice corpus acquisition shard.
;
; This batch renders five consentful Coherence Network self-corpus keys across
; the five locales that have two local macOS voices on this host. It records
; local Whisper/Metal oracle agreement and wav bytes as screened acquisition
; evidence. Only oracle-clean rows are admitted; misses remain useful as
; controls. These rows reduce the corpus gap; they are not model promotion.
;
; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk learn/coherence-network-self-corpus.fk learn/speech-model-metrics-report.fk learn/speech-learning-data-sufficiency.fk learn/speech-corpus-acquisition-window.fk

(do
    (defn sccb4-kind () "speech-corpus-crossvoice-capture-batch-0004")
    (defn sccb4-out-dir () (str_concat (temp_dir) "/speech-corpus-crossvoice-capture-batch-0004"))

    (defn sccb4-row (id locale key text voice whisper-lang)
        (list "speech-corpus-crossvoice-capture-row" id locale key text voice whisper-lang))
    (defn sccb4-row-id      (r) (nth r 1))
    (defn sccb4-row-locale  (r) (nth r 2))
    (defn sccb4-row-key     (r) (nth r 3))
    (defn sccb4-row-text    (r) (nth r 4))
    (defn sccb4-row-voice   (r) (nth r 5))
    (defn sccb4-row-lang    (r) (nth r 6))

    (defn sccb4-rows ()
        (list
            (sccb4-row 1 "en" "hatiSuci.reg.enter" "Enter the house" "Flo (English (US))" "en")
            (sccb4-row 2 "en" "hatiSuci.reg.enter" "Enter the house" "Eddy (English (US))" "en")
            (sccb4-row 3 "en" "hatiSuci.invite.heading" "Invite someone" "Flo (English (US))" "en")
            (sccb4-row 4 "en" "hatiSuci.invite.heading" "Invite someone" "Eddy (English (US))" "en")
            (sccb4-row 5 "en" "hatiSuci.add.detailPlaceholder" "What do you need?" "Flo (English (US))" "en")
            (sccb4-row 6 "en" "hatiSuci.add.detailPlaceholder" "What do you need?" "Eddy (English (US))" "en")
            (sccb4-row 7 "en" "hatiSuci.add.button" "Send to the board" "Flo (English (US))" "en")
            (sccb4-row 8 "en" "hatiSuci.add.button" "Send to the board" "Eddy (English (US))" "en")
            (sccb4-row 9 "en" "hatiSuci.market.heading" "From the market" "Flo (English (US))" "en")
            (sccb4-row 10 "en" "hatiSuci.market.heading" "From the market" "Eddy (English (US))" "en")
            (sccb4-row 11 "de" "hatiSuci.reg.enter" "Ins Haus eintreten" "Flo (German (Germany))" "de")
            (sccb4-row 12 "de" "hatiSuci.reg.enter" "Ins Haus eintreten" "Eddy (German (Germany))" "de")
            (sccb4-row 13 "de" "hatiSuci.invite.heading" "Jemanden einladen" "Flo (German (Germany))" "de")
            (sccb4-row 14 "de" "hatiSuci.invite.heading" "Jemanden einladen" "Eddy (German (Germany))" "de")
            (sccb4-row 15 "de" "hatiSuci.add.detailPlaceholder" "Was brauchst du?" "Flo (German (Germany))" "de")
            (sccb4-row 16 "de" "hatiSuci.add.detailPlaceholder" "Was brauchst du?" "Eddy (German (Germany))" "de")
            (sccb4-row 17 "de" "hatiSuci.add.button" "An die Tafel senden" "Flo (German (Germany))" "de")
            (sccb4-row 18 "de" "hatiSuci.add.button" "An die Tafel senden" "Eddy (German (Germany))" "de")
            (sccb4-row 19 "de" "hatiSuci.market.heading" "Vom Markt" "Flo (German (Germany))" "de")
            (sccb4-row 20 "de" "hatiSuci.market.heading" "Vom Markt" "Eddy (German (Germany))" "de")
            (sccb4-row 21 "es" "hatiSuci.reg.enter" "Entrar en la casa" "Flo (Spanish (Spain))" "es")
            (sccb4-row 22 "es" "hatiSuci.reg.enter" "Entrar en la casa" "Eddy (Spanish (Spain))" "es")
            (sccb4-row 23 "es" "hatiSuci.invite.heading" "Invitar a alguien" "Flo (Spanish (Spain))" "es")
            (sccb4-row 24 "es" "hatiSuci.invite.heading" "Invitar a alguien" "Eddy (Spanish (Spain))" "es")
            (sccb4-row 25 "es" "hatiSuci.add.detailPlaceholder" "¿Qué necesitas?" "Flo (Spanish (Spain))" "es")
            (sccb4-row 26 "es" "hatiSuci.add.detailPlaceholder" "¿Qué necesitas?" "Eddy (Spanish (Spain))" "es")
            (sccb4-row 27 "es" "hatiSuci.add.button" "Enviar al tablón" "Flo (Spanish (Spain))" "es")
            (sccb4-row 28 "es" "hatiSuci.add.button" "Enviar al tablón" "Eddy (Spanish (Spain))" "es")
            (sccb4-row 29 "es" "hatiSuci.market.heading" "Del mercado" "Flo (Spanish (Spain))" "es")
            (sccb4-row 30 "es" "hatiSuci.market.heading" "Del mercado" "Eddy (Spanish (Spain))" "es")
            (sccb4-row 31 "fr" "hatiSuci.reg.enter" "Entrer dans la maison" "Flo (French (France))" "fr")
            (sccb4-row 32 "fr" "hatiSuci.reg.enter" "Entrer dans la maison" "Eddy (French (France))" "fr")
            (sccb4-row 33 "fr" "hatiSuci.invite.heading" "Inviter quelqu'un" "Flo (French (France))" "fr")
            (sccb4-row 34 "fr" "hatiSuci.invite.heading" "Inviter quelqu'un" "Eddy (French (France))" "fr")
            (sccb4-row 35 "fr" "hatiSuci.add.detailPlaceholder" "De quoi avez-vous besoin ?" "Flo (French (France))" "fr")
            (sccb4-row 36 "fr" "hatiSuci.add.detailPlaceholder" "De quoi avez-vous besoin ?" "Eddy (French (France))" "fr")
            (sccb4-row 37 "fr" "hatiSuci.add.button" "Envoyer au tableau" "Flo (French (France))" "fr")
            (sccb4-row 38 "fr" "hatiSuci.add.button" "Envoyer au tableau" "Eddy (French (France))" "fr")
            (sccb4-row 39 "fr" "hatiSuci.market.heading" "Du marché" "Flo (French (France))" "fr")
            (sccb4-row 40 "fr" "hatiSuci.market.heading" "Du marché" "Eddy (French (France))" "fr")
            (sccb4-row 41 "pt-br" "hatiSuci.reg.enter" "Entrar na casa" "Flo (Portuguese (Brazil))" "pt")
            (sccb4-row 42 "pt-br" "hatiSuci.reg.enter" "Entrar na casa" "Eddy (Portuguese (Brazil))" "pt")
            (sccb4-row 43 "pt-br" "hatiSuci.invite.heading" "Convidar alguém" "Flo (Portuguese (Brazil))" "pt")
            (sccb4-row 44 "pt-br" "hatiSuci.invite.heading" "Convidar alguém" "Eddy (Portuguese (Brazil))" "pt")
            (sccb4-row 45 "pt-br" "hatiSuci.add.detailPlaceholder" "O que você precisa?" "Flo (Portuguese (Brazil))" "pt")
            (sccb4-row 46 "pt-br" "hatiSuci.add.detailPlaceholder" "O que você precisa?" "Eddy (Portuguese (Brazil))" "pt")
            (sccb4-row 47 "pt-br" "hatiSuci.add.button" "Enviar ao quadro" "Flo (Portuguese (Brazil))" "pt")
            (sccb4-row 48 "pt-br" "hatiSuci.add.button" "Enviar ao quadro" "Eddy (Portuguese (Brazil))" "pt")
            (sccb4-row 49 "pt-br" "hatiSuci.market.heading" "Do mercado" "Flo (Portuguese (Brazil))" "pt")
            (sccb4-row 50 "pt-br" "hatiSuci.market.heading" "Do mercado" "Eddy (Portuguese (Brazil))" "pt")))

    (defn sccb4-path-stem (row)
        (mstal-cat4 (sccb4-out-dir) "/row-" (mstal-int-str (sccb4-row-id row)) ""))
    (defn sccb4-aiff-path (row) (str_concat (sccb4-path-stem row) ".aiff"))
    (defn sccb4-wav-path (row) (str_concat (sccb4-path-stem row) ".wav"))

    (defn sccb4-say-command (row)
        (str_concat
            (str_concat "say -v " (mstal-q (sccb4-row-voice row)))
            (str_concat
                (str_concat " -o " (mstal-q (sccb4-aiff-path row)))
                (str_concat " " (mstal-q (sccb4-row-text row))))))

    (defn sccb4-ffmpeg-command (row)
        (str_concat
            (str_concat "ffmpeg -hide_banner -loglevel error -y -i " (mstal-q (sccb4-aiff-path row)))
            (str_concat " -ar 16000 -ac 1 -c:a pcm_s16le " (mstal-q (sccb4-wav-path row)))))

    (defn sccb4-whisper-command (row)
        (str_concat
            (str_concat "whisper-cli -m " (mstal-q (mstal-model)))
            (str_concat
                (str_concat " -f " (mstal-q (sccb4-wav-path row)))
                (str_concat " -l " (str_concat (sccb4-row-lang row) " -nt -np")))))

    (defn sccb4-render-row (row)
        (do
            (let _mk (fs_mkdir (sccb4-out-dir)))
            (let _say (host-exec (sccb4-say-command row) ""))
            (let _ff (host-exec (sccb4-ffmpeg-command row) ""))
            (sccb4-wav-path row)))

    (defn sccb4-capture-row (row)
        (do
            (let wav (sccb4-render-row row))
            (let transcript (host-exec (sccb4-whisper-command row) ""))
            (let wer (sw-wer (sw-tokens transcript) (sw-tokens (sccb4-row-text row))))
            (list "speech-corpus-crossvoice-capture-receipt-row"
                  (sccb4-row-id row)
                  (sccb4-row-locale row)
                  (sccb4-row-key row)
                  (sccb4-row-text row)
                  (sccb4-row-voice row)
                  transcript
                  wer
                  (if (le wer 25) 1 0)
                  (mstal-audio-hash wav)
                  (len (mstal-env wav))
                  (file_size wav))))

    (defn sccb4-rec-row-wer      (r) (nth r 7))
    (defn sccb4-rec-row-ok       (r) (nth r 8))
    (defn sccb4-rec-row-hash     (r) (nth r 9))
    (defn sccb4-rec-row-bytes    (r) (nth r 11))

    (defn sccb4-capture-loop (rows)
        (if (eq (len rows) 0) (empty)
            (cons (sccb4-capture-row (head rows))
                  (sccb4-capture-loop (tail rows)))))

    (defn sccb4-count-ok (rows)
        (if (eq (len rows) 0) 0
            (add (sccb4-rec-row-ok (head rows)) (sccb4-count-ok (tail rows)))))

    (defn sccb4-count-hash (rows)
        (if (eq (len rows) 0) 0
            (add (if (gt (sccb4-rec-row-hash (head rows)) 0) 1 0)
                 (sccb4-count-hash (tail rows)))))

    (defn sccb4-max-wer (rows)
        (if (eq (len rows) 0) 0
            (do
                (let rest (sccb4-max-wer (tail rows)))
                (if (gt (sccb4-rec-row-wer (head rows)) rest)
                    (sccb4-rec-row-wer (head rows))
                    rest))))

    (defn sccb4-total-bytes (rows)
        (if (eq (len rows) 0) 0
            (add (sccb4-rec-row-bytes (head rows))
                 (sccb4-total-bytes (tail rows)))))

    (defn sccb4-locale-count () 5)
    (defn sccb4-voices-per-locale () 2)
    (defn sccb4-key-count () 5)

    (defn sccb4-shard-en ()
        (list (nth (sccb4-rows) 0) (nth (sccb4-rows) 1) (nth (sccb4-rows) 2) (nth (sccb4-rows) 3)
              (nth (sccb4-rows) 4) (nth (sccb4-rows) 5) (nth (sccb4-rows) 6) (nth (sccb4-rows) 7)
              (nth (sccb4-rows) 8) (nth (sccb4-rows) 9)))
    (defn sccb4-shard-de ()
        (list (nth (sccb4-rows) 10) (nth (sccb4-rows) 11) (nth (sccb4-rows) 12) (nth (sccb4-rows) 13)
              (nth (sccb4-rows) 14) (nth (sccb4-rows) 15) (nth (sccb4-rows) 16) (nth (sccb4-rows) 17)
              (nth (sccb4-rows) 18) (nth (sccb4-rows) 19)))
    (defn sccb4-shard-es ()
        (list (nth (sccb4-rows) 20) (nth (sccb4-rows) 21) (nth (sccb4-rows) 22) (nth (sccb4-rows) 23)
              (nth (sccb4-rows) 24) (nth (sccb4-rows) 25) (nth (sccb4-rows) 26) (nth (sccb4-rows) 27)
              (nth (sccb4-rows) 28) (nth (sccb4-rows) 29)))
    (defn sccb4-shard-fr ()
        (list (nth (sccb4-rows) 30) (nth (sccb4-rows) 31) (nth (sccb4-rows) 32) (nth (sccb4-rows) 33)
              (nth (sccb4-rows) 34) (nth (sccb4-rows) 35) (nth (sccb4-rows) 36) (nth (sccb4-rows) 37)
              (nth (sccb4-rows) 38) (nth (sccb4-rows) 39)))
    (defn sccb4-shard-pt ()
        (list (nth (sccb4-rows) 40) (nth (sccb4-rows) 41) (nth (sccb4-rows) 42) (nth (sccb4-rows) 43)
              (nth (sccb4-rows) 44) (nth (sccb4-rows) 45) (nth (sccb4-rows) 46) (nth (sccb4-rows) 47)
              (nth (sccb4-rows) 48) (nth (sccb4-rows) 49)))

    (defn sccb4-shard-rows (locale)
        (if (str_eq locale "en") (sccb4-shard-en)
            (if (str_eq locale "de") (sccb4-shard-de)
                (if (str_eq locale "es") (sccb4-shard-es)
                    (if (str_eq locale "fr") (sccb4-shard-fr)
                        (if (str_eq locale "pt-br") (sccb4-shard-pt)
                            (empty)))))))

    (defn sccb4-receipt-from (rows)
        (list (sccb4-kind)
              rows
              (len rows)
              (sccb4-count-ok rows)
              (sccb4-count-hash rows)
              (sccb4-max-wer rows)
              (sccb4-total-bytes rows)
              (sccb4-locale-count)
              (sccb4-voices-per-locale)
              (sccb4-key-count)
              "screened-crossvoice-corpus-audio-not-training-sufficient"
              1
              0
              0))

    (defn sccb4-run-receipt ()
        (if (eq (mstal-ready?) 1)
            (sccb4-receipt-from (sccb4-capture-loop (sccb4-rows)))
            (list (sccb4-kind) (empty) 0 0 0 100 0 5 2 5 "missing-host-tools" 1 0 0)))

    (defn sccb4-run-shard-receipt (locale)
        (if (eq (mstal-ready?) 1)
            (sccb4-receipt-from (sccb4-capture-loop (sccb4-shard-rows locale)))
            (list (sccb4-kind) (empty) 0 0 0 100 0 5 2 5 "missing-host-tools" 1 0 0)))

    (defn sccb4-rec-kind        (r) (nth r 0))
    (defn sccb4-rec-rows        (r) (nth r 1))
    (defn sccb4-rec-count       (r) (nth r 2))
    (defn sccb4-rec-ok          (r) (nth r 3))
    (defn sccb4-rec-hash-count  (r) (nth r 4))
    (defn sccb4-rec-max-wer     (r) (nth r 5))
    (defn sccb4-rec-bytes       (r) (nth r 6))
    (defn sccb4-rec-locales     (r) (nth r 7))
    (defn sccb4-rec-voices      (r) (nth r 8))
    (defn sccb4-rec-keys        (r) (nth r 9))
    (defn sccb4-rec-status      (r) (nth r 10))
    (defn sccb4-rec-native-form (r) (nth r 11))
    (defn sccb4-rec-neural      (r) (nth r 12))
    (defn sccb4-rec-trained     (r) (nth r 13))

    0)
