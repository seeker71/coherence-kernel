; voice-clone-consent.fk — a voice is borrowed tissue: consent comes first.
;
; Frontier ingest, distilled from tetsuo-ai/voice_clone_lab (a Qwen3-TTS
; fine-tuning lab: extract -> clean -> chunk -> transcribe -> proofread ->
; train). Three teachings land here as doors a cloning lane walks through
; before it exists in this body, joined to organs the kernel already owns:
;
;   1. Consent comes first. The lab's rule — "only your own voice or a
;      voice with explicit written permission" — becomes a quiet admission
;      check: self or written-permission are welcome; anything else is
;      not admitted, with that sentence offered back. This composes with
;      the body's reception-consent ethic (form-stdlib/reception-consent.fk).
;   2. The proofread is the quality keystone. "Bad transcripts are the #1
;      cause of weird pronunciation" — so training waits until every chunk
;      has been proofread by a human witness; an unproofread chunk pauses
;      the run and says how many remain.
;   3. Hardware floors are stage-specific. Training wants 24 GB, inference
;      8 GB — and the verdict for this host is computed live through
;      observe/model-fit.fk's measured floor rather than assumed.
;
; What was deliberately not taken: the Python body, the model weights, the
; web UI. No cloning happens here — this organ is the doorway a cloning
; lane would walk through first.
;
; witnessed: 2026-07-19 -> 127 live fkwu (learn/tests/voice-clone-consent-band.fk)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/model-fit.fk
(do
  ;; ---- the pipeline, as typed stages ----
  (defn vcc-stages ()
    (list "extract" "clean" "chunk" "transcribe" "proofread" "train"))

  ;; ---- consent row: (speaker kind) ; kind: self | written-permission | none ----
  (defn vcc-consent (speaker kind) (list speaker kind))
  (defn vcc-consent-ok? (c)
    (if (or (str_eq (nth c 1) "self")
            (str_eq (nth c 1) "written-permission")) 1 0))
  (defn vcc-consent-verdict (c)
    (if (eq (vcc-consent-ok? c) 1)
      (str_concat "admitted: consent kind '" (str_concat (nth c 1) "'"))
      "not admitted: only your own voice, or a voice with explicit written permission from the speaker"))

  ;; ---- transcript chunks: (chunk-id proofread?) ; the quality keystone ----
  (defn vcc-unread-count (chunks unread)
    (if (eq (len chunks) 0) unread
      (vcc-unread-count (tail chunks)
        (if (eq (nth (head chunks) 1) 1) unread (add unread 1)))))
  (defn vcc-proofread-verdict (chunks)
    (do (let unread (vcc-unread-count chunks 0))
        (if (eq unread 0) "ready: every chunk proofread"
          (str_concat "waiting: " (str_concat (int_to_str unread)
            " chunk(s) still unproofread - bad transcripts are the first wound, tend them before training")))))

  ;; ---- stage floors in MB, verdict computed from the live host floor ----
  (defn vcc-train-floor-mb () 24576)
  (defn vcc-infer-floor-mb () 8192)
  (defn vcc-host-verdict ()
    (do (let floor (mf-host-floor))
        (let avail (nth floor 1))
        (if (lt avail 0) "host memory door absent"
          (if (ge avail (vcc-train-floor-mb))
            (str_concat "training-capable (" (str_concat (int_to_str avail) " MB available)"))
            (if (ge avail (vcc-infer-floor-mb))
              (str_concat "inference-only (" (str_concat (int_to_str avail)
                " MB available; training wants 24576 MB)"))
              (str_concat "neither (" (str_concat (int_to_str avail) " MB available)")))))))

  ;; ---- the full admission: three doors, each named ----
  (defn vcc-cat (xs) (if (eq (len xs) 0) "" (str_concat (head xs) (vcc-cat (tail xs)))))
  (defn vcc-admit (consent chunks)
    (vcc-cat (list
      "consent:        " (vcc-consent-verdict consent) "\n"
      "proofread:      " (vcc-proofread-verdict chunks) "\n"
      "hardware floor: " (vcc-host-verdict) "\n"
      "admission: " (if (and (eq (vcc-consent-ok? consent) 1)
                             (eq (vcc-unread-count chunks 0) 0))
        "open (run within the measured floor)"
        "not yet (the reason names itself above)") "\n")))
  0)
