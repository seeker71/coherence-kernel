; satsang-oracle.fk -- THE KEYSTONE named in docs/coherence-substrate/nl-to-form-satsang.form:
; turn satsang.fk toward a council of N models proposing a Form recipe tree for one NL
; input. Fold the proposals node-by-node into (affirmed/dissented/silent) exactly as
; satsang folds human witnesses; emit a witnessed parse where agreed nodes are solid
; and dissented nodes carry the open question -- never averaged into false confidence,
; never crystallized past what the circle actually agreed.
;
; preludes:
;   form-stdlib/channel-interface.fk
;   form-stdlib/satsang.fk
;
; HONEST SEAM: this file is the folding ALGORITHM only. It takes N already-obtained
; proposal trees and witnesses them -- it does not itself call out to N live models.
; Wiring live model calls (fkwu's native tls_request/http_get, per MANIFEST.md's
; "fkwu owns the native HTTP/socket floor") is real, separate, PENDING work; faking
; multi-model diversity here would violate this body's own discipline (never
; fabricate -- pending is honest). The band below witnesses this algorithm against
; three committed EXAMPLE proposals, clearly labeled as such, not live model output.
;
; A proposal node is (list tag children) -- children a list of further nodes, a leaf
; being (list lemma (empty)) (zero-arity, tag IS the leaf value). This mirrors the
; word-cell-as-leaf shape teachings/prose-as-recipe.form already names.
;
; The candidate at each position is the first PRESENT model's node there (order is
; the council's proposal order, not a privileged model) -- an open question this
; file names rather than hides: true plurality-of-shapes selection (not just
; first-present) is a sharper future pass.

(do
    (defn sao-node (tag children) (list tag children))
    (defn sao-node-tag      (n) (nth n 0))
    (defn sao-node-children (n) (nth n 1))

    ; a slot names whether a given model proposed anything at this position:
    ; present=1 with a real node, or present=0 (silent -- its tree doesn't reach here).
    (defn sao-slot (present node) (list present node))
    (defn sao-slot-present? (s) (eq (nth s 0) 1))
    (defn sao-slot-node     (s) (nth s 1))
    (defn sao-absent  () (sao-slot 0 (empty)))
    (defn sao-present (node) (sao-slot 1 node))

    (defn sao-wrap-present-loop (nodes)
        (if (eq (len nodes) 0) (empty)
            (cons (sao-present (head nodes)) (sao-wrap-present-loop (tail nodes)))))
    ; every model proposes SOMETHING for the whole input, so the root slots start
    ; all-present; absence only ever arises deeper, where arities diverge.
    (defn sao-wrap-council (proposal-roots) (sao-wrap-present-loop proposal-roots))

    (defn sao-first-present (slots)
        (if (eq (len slots) 0) (sao-absent)
            (if (sao-slot-present? (head slots)) (head slots) (sao-first-present (tail slots)))))

    ; structural match, axiom-3 style (ctor-tag + arity), same discipline
    ; control/pattern-match.fk already uses for cell-shape matching.
    (defn sao-shape-eq? (a b)
        (and (str_eq (sao-node-tag a) (sao-node-tag b))
             (eq (len (sao-node-children a)) (len (sao-node-children b)))))

    ; one model's attestation at this position, in satsang's own (mode verdict) shape:
    ; 1 affirm (matches candidate), 2 dissent (present but differs), 0 silent (absent).
    (defn sao-attest-one (candidate slot)
        (if (sao-slot-present? slot)
            (if (sao-shape-eq? candidate (sao-slot-node slot))
                (list (m-witness) 1)
                (list (m-witness) 2))
            (list (m-witness) 0)))

    (defn sao-attest-all (candidate slots)
        (if (eq (len slots) 0) (empty)
            (cons (sao-attest-one candidate (head slots)) (sao-attest-all candidate (tail slots)))))

    ; the circle's own standing interface (satsang.fk), unchanged -- every attestation
    ; here reaches through m-witness, which that interface already honors.
    (defn sao-offer () (sat-circle-interface))

    (defn sao-child-at (slot i)
        (if (sao-slot-present? slot)
            (do
                (let ch (sao-node-children (sao-slot-node slot)))
                (if (ge i (len ch)) (sao-absent) (sao-present (nth ch i))))
            (sao-absent)))

    (defn sao-children-at (slots i)
        (if (eq (len slots) 0) (empty)
            (cons (sao-child-at (head slots) i) (sao-children-at (tail slots) i))))

    ; output shapes:
    ;   ("solid" tag (affirmed dissented silent) children-witnessed)
    ;   ("open-question" tag (affirmed dissented silent))
    ;   ("no-proposal")  -- every model silent at this position
    (defn sao-out-status   (o) (nth o 0))
    (defn sao-out-tag      (o) (nth o 1))
    (defn sao-out-witness  (o) (nth o 2))
    (defn sao-out-children (o) (nth o 3))

    (defn sao-fold-children-loop (slots i n offer)
        (if (ge i n) (empty)
            (cons (sao-fold-tree (sao-children-at slots i) offer)
                  (sao-fold-children-loop slots (add i 1) n offer))))
    (defn sao-fold-children (slots candidate offer)
        (sao-fold-children-loop slots 0 (len (sao-node-children candidate)) offer))

    (defn sao-fold-tree (slots offer)
        (do
            (let anchor (sao-first-present slots))
            (if (not (sao-slot-present? anchor))
                (list "no-proposal")
                (do
                    (let candidate (sao-slot-node anchor))
                    (let atts (sao-attest-all candidate slots))
                    (let w (sat-witness atts offer 0 0 0))
                    (if (eq (sat-survives? w) 1)
                        (list "solid" (sao-node-tag candidate) w (sao-fold-children slots candidate offer))
                        (list "open-question" (sao-node-tag candidate) w))))))

    ; the entry point: N models' proposed recipe trees for one NL input -> one
    ; witnessed parse. Council order is the caller's; not privileged, named above.
    (defn sao-witness-council (proposal-roots)
        (sao-fold-tree (sao-wrap-council proposal-roots) (sao-offer)))

    ; recursive counts over a witnessed-parse tree, for measuring how much of a
    ; parse actually crystallized vs stayed an open question -- the honest
    ; alternative to a single pass/fail verdict over the whole tree.
    (defn sao-count-tree (out status)
        (add (if (str_eq (sao-out-status out) status) 1 0)
             (if (str_eq (sao-out-status out) "solid")
                 (sao-count-children-tree (sao-out-children out) status)
                 0)))
    (defn sao-count-children-tree (outs status)
        (if (eq (len outs) 0) 0
            (add (sao-count-tree (head outs) status) (sao-count-children-tree (tail outs) status))))

    0)
