; metal-live-pair-anchors.fk -- observed live Metal pair anchor set.
;
; The multiseed sweep has five locale windows. The live Metal evidence now has
; six reciprocal audio anchors: en<->de, en<->es, en<->id, en<->fr, en<->it,
; and en<->zh. This cell counts the live anchors and only routes full-metal-native
; when the target count is observed.
;
; preludes:
;   learn/metal-observed-sweep-bridge.fk

(do
    (defn mlpa-en-de ()
        (mosb-anchor "en-de" 12 10 0 83 66 100 1 1 1 0))
    (defn mlpa-en-es ()
        (mosb-anchor "en-es" 12 12 0 100 100 100 1 1 1 0))
    (defn mlpa-en-id ()
        (mosb-anchor "en-id" 12 12 0 100 100 100 1 1 1 0))
    (defn mlpa-en-fr ()
        (mosb-anchor "en-fr" 12 10 0 83 100 66 1 1 1 0))
    (defn mlpa-en-it ()
        (mosb-anchor "en-it" 12 12 0 100 100 100 1 1 1 0))
    (defn mlpa-en-zh ()
        (mosb-anchor "en-zh" 12 10 0 83 66 100 1 1 1 0))

    (defn mlpa-ready (floor)
        (add (add (mosb-anchor-ready? (mlpa-en-de) floor)
                  (mosb-anchor-ready? (mlpa-en-es) floor))
             (add (add (mosb-anchor-ready? (mlpa-en-id) floor)
                       (mosb-anchor-ready? (mlpa-en-fr) floor))
                  (add (mosb-anchor-ready? (mlpa-en-it) floor)
                       (mosb-anchor-ready? (mlpa-en-zh) floor)))))

    (defn mlpa-route (ready observed target)
        (if (ge ready target) "full-metal-native"
            (if (ge observed 1) "metal-anchored-native-guide" "oracle-guide")))

    (defn mlpa-receipt (floor target)
        (do
            (let de (mlpa-en-de))
            (let es (mlpa-en-es))
            (let id (mlpa-en-id))
            (let fr (mlpa-en-fr))
            (let it (mlpa-en-it))
            (let zh (mlpa-en-zh))
            (let observed 6)
            (let ready (mlpa-ready floor))
            (list "metal-live-pair-anchors"
                  target
                  observed
                  ready
                  (mosb-next-live-needed observed target)
                  (mlpa-route ready observed target)
                  (if (ge ready target) 1 0)
                  (mosb-anchor-ready? de floor)
                  (mosb-anchor-ready? es floor)
                  (nth de 5)
                  (nth es 5)
                  (nth de 6)
                  (nth de 7)
                  (nth es 6)
                  (nth es 7)
                  (add (add (add (nth de 8) (nth es 8)) (nth id 8))
                       (add (add (nth fr 8) (nth it 8)) (nth zh 8)))
                  (add (add (add (nth de 3) (nth es 3)) (nth id 3))
                       (add (add (nth fr 3) (nth it 3)) (nth zh 3)))
                  (add (add (add (nth de 2) (nth es 2)) (nth id 2))
                       (add (add (nth fr 2) (nth it 2)) (nth zh 2)))
                  (add (add (add (nth de 9) (nth es 9)) (nth id 9))
                       (add (add (nth fr 9) (nth it 9)) (nth zh 9)))
                  (add (add (add (nth de 10) (nth es 10)) (nth id 10))
                       (add (add (nth fr 10) (nth it 10)) (nth zh 10)))
                  (add (add (add (if (eq (nth de 11) 0) 1 0)
                                 (if (eq (nth es 11) 0) 1 0))
                            (if (eq (nth id 11) 0) 1 0))
                       (add (add (if (eq (nth fr 11) 0) 1 0)
                                 (if (eq (nth it 11) 0) 1 0))
                            (if (eq (nth zh 11) 0) 1 0)))
                  floor
                  (mosb-anchor-ready? id floor)
                  (nth id 5)
                  (nth id 6)
                  (nth id 7)
                  (mosb-anchor-ready? fr floor)
                  (nth fr 5)
                  (nth fr 6)
                  (nth fr 7)
                  (mosb-anchor-ready? it floor)
                  (nth it 5)
                  (nth it 6)
                  (nth it 7)
                  (mosb-anchor-ready? zh floor)
                  (nth zh 5)
                  (nth zh 6)
                  (nth zh 7))))

    0)
