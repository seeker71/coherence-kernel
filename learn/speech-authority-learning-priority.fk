; speech-authority-learning-priority.fk -- choose authority learning over pair drift.
;
; Pair windows grow neural coverage, but the full speech goal is open ASR/TTS
; authority. This cell makes the priority executable: when measured open ASR or
; Sema voice gaps remain at 100, the next oracle-to-native trial outranks
; another pair-window increment while the pair scheduler remains available as
; the background coverage lane.
;
; preludes: learn/speech-neural-pair-coverage.fk learn/speech-pair-training-next-action.fk learn/speech-open-asr-tts-target-model.fk learn/speech-oracle-native-backlog.fk learn/speech-next-trial-scheduler.fk

(do
    (defn salp-kind () "speech-authority-learning-priority")
    (defn salp-force-authority? (open-gap voice-gap)
        (if (or (ge open-gap 100) (ge voice-gap 100)) 1 0))
    (defn salp-choice (force next-trial pair-action)
        (if (eq force 1) (snts-action next-trial) (sptn-action-id pair-action)))
    (defn salp-target (force next-trial pair-action)
        (if (eq force 1) (snts-target next-trial) (sptn-action-route pair-action)))
    (defn salp-route (force next-trial pair-action)
        (if (eq force 1) (snts-route next-trial) (sptn-action-route pair-action)))

    (defn salp-report ()
        (do
            (let coverage (snpc-report))
            (let pair-report (sptn-report))
            (let pair-action (sptn-rec-action pair-report))
            (let target (soatm-report))
            (let trials (snts-report))
            (let next-trial (nth trials 2))
            (let open-gap (soatm-rec-open-asr-gap target))
            (let voice-gap (soatm-rec-voice-gap target))
            (let force (salp-force-authority? open-gap voice-gap))
            (list (salp-kind)
                  (snpc-rec-neural-pairs coverage)
                  (snpc-rec-neural-directed coverage)
                  (snpc-rec-neural-params coverage)
                  (sptn-action-id pair-action)
                  (sptn-action-a pair-action)
                  (sptn-action-b pair-action)
                  open-gap
                  voice-gap
                  (soatm-rec-voice-native-pass target)
                  (soatm-rec-voice-native-total target)
                  (soatm-rec-voice-oracle-pass target)
                  (soatm-rec-voice-oracle-total target)
                  (snts-id next-trial)
                  (snts-gap next-trial)
                  (snts-action next-trial)
                  (snts-target next-trial)
                  (snts-promote next-trial)
                  (snts-control next-trial)
                  force
                  (salp-choice force next-trial pair-action)
                  (salp-target force next-trial pair-action)
                  (salp-route force next-trial pair-action)
                  "authority-gap-outranks-pair-window-until-open-receipts-pass"
                  1
                  0)))

    (defn salp-rec-kind             (r) (nth r 0))
    (defn salp-rec-neural-pairs     (r) (nth r 1))
    (defn salp-rec-neural-directed  (r) (nth r 2))
    (defn salp-rec-neural-params    (r) (nth r 3))
    (defn salp-rec-pair-id          (r) (nth r 4))
    (defn salp-rec-pair-a           (r) (nth r 5))
    (defn salp-rec-pair-b           (r) (nth r 6))
    (defn salp-rec-open-gap         (r) (nth r 7))
    (defn salp-rec-voice-gap        (r) (nth r 8))
    (defn salp-rec-voice-native-ok  (r) (nth r 9))
    (defn salp-rec-voice-native-total (r) (nth r 10))
    (defn salp-rec-voice-oracle-ok  (r) (nth r 11))
    (defn salp-rec-voice-oracle-total (r) (nth r 12))
    (defn salp-rec-trial-id         (r) (nth r 13))
    (defn salp-rec-trial-gap        (r) (nth r 14))
    (defn salp-rec-trial-action     (r) (nth r 15))
    (defn salp-rec-trial-target     (r) (nth r 16))
    (defn salp-rec-promote          (r) (nth r 17))
    (defn salp-rec-control          (r) (nth r 18))
    (defn salp-rec-force-authority  (r) (nth r 19))
    (defn salp-rec-choice           (r) (nth r 20))
    (defn salp-rec-target           (r) (nth r 21))
    (defn salp-rec-route            (r) (nth r 22))
    (defn salp-rec-status           (r) (nth r 23))
    (defn salp-rec-native-form      (r) (nth r 24))
    (defn salp-rec-open-authority   (r) (nth r 25))

    0)
