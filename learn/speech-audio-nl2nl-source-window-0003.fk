; speech-audio-nl2nl-source-window-0003.fk -- fi/ja audio to neutral to audio.
;
; A third observed source-window bridge adds Finnish and Japanese loopback rows
; from speech-open-asr-trial-window-0010. Source audio is heard by the local
; Metal oracle, native Form maps the transcript to a locale-neutral presence
; meaning, then target text/audio is checked by the same local oracle. Host TTS
; and Whisper remain carriers/oracles; native ownership is the neutral route and
; target selection.
;
; preludes:
;   observe/stt-wer.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk

(do
    (defn sanw3-kind () "speech-audio-nl2nl-source-window-0003")
    (defn sanw3-meaning () 602)
    (defn sanw3-max-wer () 25)

    (defn sanw3-row (id src dst src-truth src-heard dst-target dst-heard
                        src-hash dst-hash src-bytes dst-bytes)
        (list "speech-audio-nl2nl-source-window-row"
              id src dst src-truth src-heard dst-target dst-heard
              src-hash dst-hash src-bytes dst-bytes))

    (defn sanw3-row-src       (r) (nth r 2))
    (defn sanw3-row-dst       (r) (nth r 3))
    (defn sanw3-row-src-truth (r) (nth r 4))
    (defn sanw3-row-src-heard (r) (nth r 5))
    (defn sanw3-row-dst-text  (r) (nth r 6))
    (defn sanw3-row-dst-heard (r) (nth r 7))
    (defn sanw3-row-src-bytes (r) (nth r 10))
    (defn sanw3-row-dst-bytes (r) (nth r 11))

    (defn sanw3-rows ()
        (list
            (sanw3-row 9703 "fi" "ja"
                       "minä olen" "Minä olen." "私はいます" "私はいます。"
                       2803940054 704718359 30744 52762)
            (sanw3-row 9704 "ja" "fi"
                       "私はいます" "私はいます。" "minä olen" "Minä olen."
                       704718359 2803940054 52762 30744)))

    (defn sanw3-src-ok? (r)
        (sw-accept? (sw-tokens (sanw3-row-src-heard r))
                    (sw-tokens (sanw3-row-src-truth r))
                    (sanw3-max-wer)))
    (defn sanw3-dst-ok? (r)
        (sw-accept? (sw-tokens (sanw3-row-dst-heard r))
                    (sw-tokens (sanw3-row-dst-text r))
                    (sanw3-max-wer)))

    (defn sanw3-native-meaning (r)
        (if (str_eq (sanw3-row-src r) "fi")
            (if (eq (sanw3-src-ok? r) 1) (sanw3-meaning) 0)
            (if (str_eq (sanw3-row-src r) "ja")
                (if (eq (sanw3-src-ok? r) 1) (sanw3-meaning) 0)
                0)))

    (defn sanw3-target-text (meaning dst)
        (if (eq meaning (sanw3-meaning))
            (if (str_eq dst "fi") "minä olen"
                (if (str_eq dst "ja") "私はいます" ""))
            ""))

    (defn sanw3-native-ok? (r)
        (if (and (eq (sanw3-native-meaning r) (sanw3-meaning))
                 (and (str_eq (sanw3-target-text (sanw3-native-meaning r) (sanw3-row-dst r))
                              (sanw3-row-dst-text r))
                      (eq (sanw3-dst-ok? r) 1))) 1 0))

    (defn sanw3-row-bytes (r) (add (sanw3-row-src-bytes r) (sanw3-row-dst-bytes r)))

    (defn sanw3-count-src (rows)
        (if (eq (len rows) 0) 0
            (add (sanw3-src-ok? (head rows)) (sanw3-count-src (tail rows)))))
    (defn sanw3-count-dst (rows)
        (if (eq (len rows) 0) 0
            (add (sanw3-dst-ok? (head rows)) (sanw3-count-dst (tail rows)))))
    (defn sanw3-count-native (rows)
        (if (eq (len rows) 0) 0
            (add (sanw3-native-ok? (head rows)) (sanw3-count-native (tail rows)))))
    (defn sanw3-total-bytes (rows)
        (if (eq (len rows) 0) 0
            (add (sanw3-row-bytes (head rows)) (sanw3-total-bytes (tail rows)))))

    (defn sanw3-receipt ()
        (do
            (let rows (sanw3-rows))
            (list (sanw3-kind)
                  rows
                  (len rows)
                  (sanw3-count-src rows)
                  (sanw3-count-dst rows)
                  (sanw3-count-native rows)
                  (sanw3-total-bytes rows)
                  (sanw3-meaning)
                  "fi<->ja"
                  "whisper.cpp-large-v3-turbo-metal"
                  "macos-arm64-m4-max"
                  "oracle-guided-source-window-audio-nl2nl-audio-bridge-not-native-vocoder"
                  1
                  1
                  0
                  0)))

    (defn sanw3-rec-kind      (r) (nth r 0))
    (defn sanw3-rec-count     (r) (nth r 2))
    (defn sanw3-rec-src-ok    (r) (nth r 3))
    (defn sanw3-rec-dst-ok    (r) (nth r 4))
    (defn sanw3-rec-native-ok (r) (nth r 5))
    (defn sanw3-rec-bytes     (r) (nth r 6))
    (defn sanw3-rec-meaning   (r) (nth r 7))
    (defn sanw3-rec-pair      (r) (nth r 8))
    (defn sanw3-rec-status    (r) (nth r 11))
    (defn sanw3-rec-native    (r) (nth r 12))
    (defn sanw3-rec-oracle    (r) (nth r 13))
    (defn sanw3-rec-vocoder   (r) (nth r 14))
    (defn sanw3-rec-neural    (r) (nth r 15))

    0)
