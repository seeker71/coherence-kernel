; sema-voice-trial-window-0004.fk -- fourth scoped Sema voice challenger window.
;
; This adds a real local loopback observation to the scoped TCAV voice floor:
; macOS say rendered "I am here.", ffmpeg normalized it to 16 kHz mono wav, and
; local whisper.cpp large-v3-turbo transcribed it exactly. The scoped candidate
; moves the training denominator; global live Sema authority remains oracle-held.
;
; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/sema-voice-trial-window.fk
;   learn/sema-voice-trial-window-0002.fk
;   learn/sema-voice-trial-window-0003.fk

(do
    (defn svtw4-candidate ()
        (svtw-voice-candidate
            "tcav-local-loopback-presence-v4-window"
            "text-conditioned-acoustic-vocoder"
            "I am here."
            "I am here."
            3566916401
            92
            96
            0
            104
            165
            82
            64
            18
            1 1 0 0 0))

    (defn svtw4-receipt ()
        (do
            (let previous (svtw3-receipt))
            (let c (svtw4-candidate))
            (let count 4)
            (let oracle-ok (add (svtw-rec-oracle-ok previous) (svtw-oracle-ok? c 25)))
            (let native-ok (add (svtw-rec-native-ok previous) (svtw-native-ok? c 25 80 90)))
            (list "sema-voice-trial-window-receipt-0004"
                  "tcav-four-window-cumulative"
                  (svtw-cand-recipe c)
                  (svtw-cand-wer c)
                  oracle-ok
                  native-ok
                  "native-sema-voice-trial-window"
                  "whisper.cpp-large-v3-turbo-metal"
                  "macos-arm64-m4-max"
                  (svtw-cand-audio-hash c)
                  (svtw-cand-f0 c)
                  (svtw-cand-warmth c)
                  (svtw-cand-cadence c)
                  (svtw-cand-breath c)
                  "choice-cut-fail-undo-timeout-clean"
                  1
                  0
                  count
                  (svtw2-rate oracle-ok count)
                  (svtw2-rate native-ok count)
                  (svtw-cand-id c)
                  (svtw-cand-truth c)
                  20396
                  "macos-say-samantha-loopback"))

    (defn svtw4-rec-wav-bytes (r) (nth r 22))
    (defn svtw4-rec-carrier   (r) (nth r 23))

    (defn svtw4-report ()
        (do
            (let trial (svtw-queued-trial))
            (let receipt (svtw4-receipt))
            (list "sema-voice-trial-window-0004"
                  trial
                  receipt
                  (snts-oracle-rate trial)
                  (snts-native-rate trial)
                  100
                  (svtw-rec-oracle-ok receipt)
                  (svtw-rec-native-ok receipt)
                  (svtw-rec-wer receipt)
                  "cut-tcav-challenger-for-trial-window"
                  (snts-model-context)
                  "trial-window-native-not-global-live-voice"
                  1
                  0
                  (svtw2-rec-count receipt)
                  (svtw2-rec-oracle-rate receipt)
                  (svtw2-rec-native-rate receipt)
                  (svtw4-rec-wav-bytes receipt)
                  (svtw4-rec-carrier receipt))))

    0)
