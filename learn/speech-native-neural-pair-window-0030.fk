; speech-native-neural-pair-window-0030.fk -- thirtieth native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; zh<->id. A fresh Mac Metal local-oracle probe checks the same baseline
; meaning, then the Form-native NL/audio micro-pair shifts from oracle-held to
; native within this closed pair window. This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw30-kind () "speech-native-neural-pair-window-0030")
    (defn snpw30-a () "zh")
    (defn snpw30-b () "id")
    (defn snpw30-meaning () 303)
    (defn snpw30-floor () 50)
    (defn snpw30-max-wer () 25)
    (defn snpw30-meta () (mlap-meta 96 97 11 80))
    (defn snpw30-feat () (list 3040 32 2 2))
    (defn snpw30-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw30-meaning)) locale))

    (defn snpw30-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0030-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw30-oracle-locale (r) (nth r 1))
    (defn snpw30-oracle-voice  (r) (nth r 2))
    (defn snpw30-oracle-transcript (r) (nth r 3))
    (defn snpw30-oracle-wer    (r) (nth r 4))
    (defn snpw30-oracle-bytes  (r) (nth r 5))
    (defn snpw30-oracle-cksum  (r) (nth r 6))
    (defn snpw30-oracle-name   (r) (nth r 7))
    (defn snpw30-oracle-device (r) (nth r 8))

    (defn snpw30-oracle-rows ()
        (list
            (snpw30-oracle-row "zh" "Tingting" "我在。" 0 15064 3568659029)
            (snpw30-oracle-row "id" "Damayanti" "Aku ada." 0 23712 1805192547)))

    (defn snpw30-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw30-oracle-wer (head rows)) (snpw30-max-wer)) 1 0)
                 (snpw30-oracle-ok-loop (tail rows)))))
    (defn snpw30-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw30-oracle-bytes (head rows))
                 (snpw30-oracle-byte-total-loop (tail rows)))))

    (defn snpw30-nl (src dst)
        (mlap-nl-sample (snpw30-meaning) src dst
                         (snpw30-tokens src)
                         (snpw30-tokens dst)
                         (snpw30-meaning)
                         0 0 0))

    (defn snpw30-audio (src dst)
        (mlap-audio-sample (snpw30-meaning) src dst
                            (snpw30-tokens dst)
                            (snpw30-tokens dst)
                            (snpw30-feat)
                            (snpw30-meta)
                            0 0 0))

    (defn snpw30-nl-lanes ()
        (list
            (snpw30-nl (snpw30-a) (snpw30-b))
            (snpw30-nl (snpw30-b) (snpw30-a))
            (snpw30-nl (snpw30-a) (snpw30-a))
            (snpw30-nl (snpw30-b) (snpw30-b))))

    (defn snpw30-audio-lanes ()
        (list
            (snpw30-audio (snpw30-a) (snpw30-b))
            (snpw30-audio (snpw30-b) (snpw30-a))
            (snpw30-audio (snpw30-a) (snpw30-a))
            (snpw30-audio (snpw30-b) (snpw30-b))))

    (defn snpw30-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw30-receipt ()
        (do
            (let nl (snpw30-nl-lanes))
            (let audio (snpw30-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw30-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw30-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw30-max-wer)))
            (let oracle-rows (snpw30-oracle-rows))
            (let oracle-ok (snpw30-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw30-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw30-kind)
                  (snpw30-a)
                  (snpw30-b)
                  (snpw30-meaning)
                  1
                  2
                  30
                  60
                  30
                  30
                  before
                  after
                  (if (and (lt before (snpw30-floor)) (ge after (snpw30-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw30-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0030-trained-not-open-authority")))

    (defn snpw30-rec-kind            (r) (nth r 0))
    (defn snpw30-rec-a               (r) (nth r 1))
    (defn snpw30-rec-b               (r) (nth r 2))
    (defn snpw30-rec-meaning         (r) (nth r 3))
    (defn snpw30-rec-pair-increment  (r) (nth r 4))
    (defn snpw30-rec-directed-increment (r) (nth r 5))
    (defn snpw30-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw30-rec-cumulative-directed (r) (nth r 7))
    (defn snpw30-rec-epochs          (r) (nth r 8))
    (defn snpw30-rec-params          (r) (nth r 9))
    (defn snpw30-rec-before-rate     (r) (nth r 10))
    (defn snpw30-rec-after-rate      (r) (nth r 11))
    (defn snpw30-rec-shifted         (r) (nth r 12))
    (defn snpw30-rec-form-nl         (r) (nth r 13))
    (defn snpw30-rec-form-audio      (r) (nth r 14))
    (defn snpw30-rec-before-loss     (r) (nth r 15))
    (defn snpw30-rec-after-loss      (r) (nth r 16))
    (defn snpw30-rec-oracle-ok       (r) (nth r 17))
    (defn snpw30-rec-oracle-total    (r) (nth r 18))
    (defn snpw30-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw30-rec-oracle          (r) (nth r 20))
    (defn snpw30-rec-native-form     (r) (nth r 21))
    (defn snpw30-rec-neural          (r) (nth r 22))
    (defn snpw30-rec-open-authority  (r) (nth r 23))
    (defn snpw30-rec-status          (r) (nth r 24))

    0)
