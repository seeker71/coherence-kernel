; sema-voice-teacher-oracle-intake.fk -- passing local teacher audio for Sema voice.
;
; The native formant carrier is still WER 100. This intake preserves the other
; side of today's real metal observation: a local macOS teacher voice rendered
; the Sema phrase, Whisper on Apple Metal heard it exactly, and Form can admit
; that as oracle-positive training evidence while native Sema authority remains
; held at 0/1.
;
; preludes:
;   observe/stt-wer.fk
;   presence/formant-vocoder.fk
;   learn/sema-voice-sample-loop.fk
;   learn/sema-voice-local-oracle-receipt.fk
;   presence/macos-sema-voice-teacher-carrier.fk
;   learn/speech-live-receipt-intake.fk

(do
    (defn svtoi-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn svtoi-live-hash () 497318870)
    (defn svtoi-live-id () 983002)
    (defn svtoi-native-wer () 100)
    (defn svtoi-oracle-confidence () 94)
    (defn svtoi-latency-ms () 120)

    (defn svtoi-rough-profile ()
        (svsl-profile "rough"
                      145 620 1250 2850 130
                      55 82 48 42 44 2))
    (defn svtoi-incumbent ()
        (svsl-sample (svtoi-rough-profile) 56 70 22 160 1 981001 0 0 0))

    (defn svtoi-live-teacher-row ()
        (mstc-row-from (svtoi-live-id)
                       "Flo (English (US))"
                       (svtoi-live-hash)
                       (mstc-text)))

    (defn svtoi-local-oracle-receipt ()
        (do
            (let row (svtoi-live-teacher-row))
            (svlor-receipt (svtoi-incumbent) (mstc-row-svlor row) (svsl-target) (mstc-max-wer) 20)))

    (defn svtoi-speech-row ()
        (slri-row "sema-live-voice"
                  (svtoi-live-id)
                  (mstc-device)
                  "whisper.cpp-large-v3-turbo-metal"
                  (svtoi-live-hash)
                  16000
                  1
                  (mstc-text)
                  0
                  (svtoi-native-wer)
                  (svtoi-oracle-confidence)
                  (svtoi-latency-ms)
                  1
                  1
                  0
                  0
                  0))

    (defn svtoi-report ()
        (do
            (let teacher (svtoi-live-teacher-row))
            (let receipt (svtoi-local-oracle-receipt))
            (let speech (svtoi-speech-row))
            (list "sema-voice-teacher-oracle-intake"
                  teacher
                  receipt
                  speech
                  1
                  1
                  (svtoi-rate 1 1)
                  0
                  1
                  (svtoi-rate 0 1)
                  (mstc-row-wer teacher)
                  (slri-native-success? speech 25 80 2000)
                  "oracle-teacher-positive-native-held"
                  "host-teacher-training-evidence-not-native-sema-authority"
                  "macos-arm64-m4-max"
                  "whisper.cpp-large-v3-turbo-metal"
                  1
                  0)))

    (defn svtoi-rec-kind          (r) (nth r 0))
    (defn svtoi-rec-teacher       (r) (nth r 1))
    (defn svtoi-rec-oracle-receipt (r) (nth r 2))
    (defn svtoi-rec-speech-row    (r) (nth r 3))
    (defn svtoi-rec-oracle-ok     (r) (nth r 4))
    (defn svtoi-rec-oracle-total  (r) (nth r 5))
    (defn svtoi-rec-oracle-rate   (r) (nth r 6))
    (defn svtoi-rec-native-ok     (r) (nth r 7))
    (defn svtoi-rec-native-total  (r) (nth r 8))
    (defn svtoi-rec-native-rate   (r) (nth r 9))
    (defn svtoi-rec-wer           (r) (nth r 10))
    (defn svtoi-rec-native-success (r) (nth r 11))
    (defn svtoi-rec-route         (r) (nth r 12))
    (defn svtoi-rec-boundary      (r) (nth r 13))
    (defn svtoi-rec-device        (r) (nth r 14))
    (defn svtoi-rec-oracle        (r) (nth r 15))
    (defn svtoi-rec-native-form   (r) (nth r 16))
    (defn svtoi-rec-neural-ready  (r) (nth r 17))

    0)
