; speech-corpus-acquisition-window.fk -- plan enough consentful audio rows.
;
; The current live speech learner is below the data-sufficient floor. This cell
; turns the ready Coherence Network self-corpus into an acquisition window large
; enough to approach the first corpus-scale wav/locale floor before any future
; training claim can move.
; It does not pretend planned wavs are trained. Captured rows are only admitted
; when live batch receipts exist, and the window remains under the full floor.
;
; preludes:
;   learn/coherence-network-self-corpus.fk
;   learn/speech-model-metrics-report.fk
;   learn/speech-learning-data-sufficiency.fk

(do
    (defn scaw-kind () "speech-corpus-acquisition-window")
    (defn scaw-window-keypaths () 2000)
    (defn scaw-voices-per-locale () 1)
    (defn scaw-crossvoice-locales () 5)
    (defn scaw-crossvoice-voices-per-locale () 2)
    (defn scaw-heldout-ratio-denom () 10)
    (defn scaw-captured-rows () 119)

    (defn scaw-ready-locales ()
        (cnsc-ready-count))

    (defn scaw-planned-wavs ()
        (mul (scaw-window-keypaths)
             (mul (scaw-ready-locales) (scaw-voices-per-locale))))

    (defn scaw-planned-heldout ()
        (div (scaw-planned-wavs) (scaw-heldout-ratio-denom)))

    (defn scaw-planned-crossvoice-wavs ()
        (mul (scaw-window-keypaths)
             (mul (scaw-crossvoice-locales) (scaw-crossvoice-voices-per-locale))))

    (defn scaw-planned-crossvoice-heldout ()
        (div (scaw-planned-crossvoice-wavs) (scaw-heldout-ratio-denom)))

    (defn scaw-plan-meets-wav-floor? ()
        (if (ge (scaw-planned-wavs)
                (slds-required-wavs (slds-current))) 1 0))

    (defn scaw-plan-meets-locale-floor? ()
        (if (ge (scaw-ready-locales)
                (slds-required-locales (slds-current))) 1 0))

    (defn scaw-plan-meets-heldout-floor? ()
        (if (ge (scaw-planned-heldout)
                (slds-required-heldout (slds-current))) 1 0))

    (defn scaw-selected-locales ()
        (list "en" "de" "es" "fr" "id" "pt-br"))

    (defn scaw-macos-voice (locale)
        (if (str_eq locale "en") "Flo (English (US))"
            (if (str_eq locale "de") "Flo (German (Germany))"
                (if (str_eq locale "es") "Flo (Spanish (Spain))"
                    (if (str_eq locale "fr") "Flo (French (France))"
                        (if (str_eq locale "id") "Damayanti"
                            (if (str_eq locale "pt-br") "Flo (Portuguese (Brazil))"
                                "missing")))))))

    (defn scaw-voice-ready? (locale)
        (if (str_eq (scaw-macos-voice locale) "missing") 0 1))

    (defn scaw-all-voices-ready-loop (locales)
        (if (eq (len locales) 0) 1
            (if (eq (scaw-voice-ready? (head locales)) 1)
                (scaw-all-voices-ready-loop (tail locales))
                0)))

    (defn scaw-all-voices-ready? ()
        (scaw-all-voices-ready-loop (scaw-selected-locales)))

    (defn scaw-row-budget ()
        (list "speech-corpus-row-budget"
              (scaw-window-keypaths)
              (scaw-ready-locales)
              (scaw-voices-per-locale)
              (scaw-planned-wavs)
              (scaw-planned-heldout)
              (cnsc-total-keypaths)
              (cnsc-parallel-en-pairs)
              (scaw-crossvoice-locales)
              (scaw-crossvoice-voices-per-locale)
              (scaw-planned-crossvoice-wavs)
              (scaw-planned-crossvoice-heldout)))

    (defn scaw-receipt ()
        (list (scaw-kind)
              (scaw-row-budget)
              (scaw-plan-meets-wav-floor?)
              (scaw-plan-meets-locale-floor?)
              (scaw-plan-meets-heldout-floor?)
              (scaw-all-voices-ready?)
              (scaw-captured-rows)
              "corpus-scale-window-open-training-intake-started"
              1
              0))

    (defn scaw-rec-kind          (r) (nth r 0))
    (defn scaw-rec-budget        (r) (nth r 1))
    (defn scaw-rec-wav-floor     (r) (nth r 2))
    (defn scaw-rec-locale-floor  (r) (nth r 3))
    (defn scaw-rec-heldout-floor (r) (nth r 4))
    (defn scaw-rec-voices-ready  (r) (nth r 5))
    (defn scaw-rec-captured      (r) (nth r 6))
    (defn scaw-rec-status        (r) (nth r 7))
    (defn scaw-rec-native-form   (r) (nth r 8))
    (defn scaw-rec-neural        (r) (nth r 9))

    (defn scaw-budget-keypaths       (b) (nth b 1))
    (defn scaw-budget-locales        (b) (nth b 2))
    (defn scaw-budget-voices         (b) (nth b 3))
    (defn scaw-budget-wavs           (b) (nth b 4))
    (defn scaw-budget-heldout        (b) (nth b 5))
    (defn scaw-budget-corpus-keys    (b) (nth b 6))
    (defn scaw-budget-parallel-pairs (b) (nth b 7))
    (defn scaw-budget-crossvoice-locales (b) (nth b 8))
    (defn scaw-budget-crossvoice-voices  (b) (nth b 9))
    (defn scaw-budget-crossvoice-wavs    (b) (nth b 10))
    (defn scaw-budget-crossvoice-heldout (b) (nth b 11))

    0)
