; speech-native-neural-pair-window-0039.fk -- thirty-ninth native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; it<->pt-br. Fresh Mac Metal local-oracle probes check the Italian and
; Portuguese-Brazil renderings for the same neutral meaning, then the
; Form-native NL/audio micro-pair shifts from oracle-held to native within this
; closed pair window. This is not open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw39-kind () "speech-native-neural-pair-window-0039")
    (defn snpw39-a () "it")
    (defn snpw39-b () "pt-br")
    (defn snpw39-meaning () 303)
    (defn snpw39-floor () 50)
    (defn snpw39-max-wer () 25)
    (defn snpw39-meta () (mlap-meta 96 96 12 79))
    (defn snpw39-feat () (list 3044 39 2 2))
    (defn snpw39-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw39-meaning)) locale))

    (defn snpw39-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0039-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw39-oracle-locale (r) (nth r 1))
    (defn snpw39-oracle-voice  (r) (nth r 2))
    (defn snpw39-oracle-transcript (r) (nth r 3))
    (defn snpw39-oracle-wer    (r) (nth r 4))
    (defn snpw39-oracle-bytes  (r) (nth r 5))
    (defn snpw39-oracle-cksum  (r) (nth r 6))
    (defn snpw39-oracle-name   (r) (nth r 7))
    (defn snpw39-oracle-device (r) (nth r 8))

    (defn snpw39-oracle-rows ()
        (list
            (snpw39-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)
            (snpw39-oracle-row "pt-br" "Flo (Portuguese (Brazil))" "Eu sou." 0 31774 1996659987)))

    (defn snpw39-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw39-oracle-wer (head rows)) (snpw39-max-wer)) 1 0)
                 (snpw39-oracle-ok-loop (tail rows)))))
    (defn snpw39-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw39-oracle-bytes (head rows))
                 (snpw39-oracle-byte-total-loop (tail rows)))))

    (defn snpw39-nl (src dst)
        (mlap-nl-sample (snpw39-meaning) src dst
                         (snpw39-tokens src)
                         (snpw39-tokens dst)
                         (snpw39-meaning)
                         0 0 0))

    (defn snpw39-audio (src dst)
        (mlap-audio-sample (snpw39-meaning) src dst
                            (snpw39-tokens dst)
                            (snpw39-tokens dst)
                            (snpw39-feat)
                            (snpw39-meta)
                            0 0 0))

    (defn snpw39-nl-lanes ()
        (list
            (snpw39-nl (snpw39-a) (snpw39-b))
            (snpw39-nl (snpw39-b) (snpw39-a))
            (snpw39-nl (snpw39-a) (snpw39-a))
            (snpw39-nl (snpw39-b) (snpw39-b))))

    (defn snpw39-audio-lanes ()
        (list
            (snpw39-audio (snpw39-a) (snpw39-b))
            (snpw39-audio (snpw39-b) (snpw39-a))
            (snpw39-audio (snpw39-a) (snpw39-a))
            (snpw39-audio (snpw39-b) (snpw39-b))))

    (defn snpw39-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw39-receipt ()
        (do
            (let nl (snpw39-nl-lanes))
            (let audio (snpw39-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw39-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw39-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw39-max-wer)))
            (let oracle-rows (snpw39-oracle-rows))
            (let oracle-ok (snpw39-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw39-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw39-kind)
                  (snpw39-a)
                  (snpw39-b)
                  (snpw39-meaning)
                  1
                  2
                  39
                  78
                  39
                  39
                  before
                  after
                  (if (and (lt before (snpw39-floor)) (ge after (snpw39-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw39-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0039-trained-not-open-authority")))

    (defn snpw39-rec-kind            (r) (nth r 0))
    (defn snpw39-rec-a               (r) (nth r 1))
    (defn snpw39-rec-b               (r) (nth r 2))
    (defn snpw39-rec-meaning         (r) (nth r 3))
    (defn snpw39-rec-pair-increment  (r) (nth r 4))
    (defn snpw39-rec-directed-increment (r) (nth r 5))
    (defn snpw39-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw39-rec-cumulative-directed (r) (nth r 7))
    (defn snpw39-rec-epochs          (r) (nth r 8))
    (defn snpw39-rec-params          (r) (nth r 9))
    (defn snpw39-rec-before-rate     (r) (nth r 10))
    (defn snpw39-rec-after-rate      (r) (nth r 11))
    (defn snpw39-rec-shifted         (r) (nth r 12))
    (defn snpw39-rec-form-nl         (r) (nth r 13))
    (defn snpw39-rec-form-audio      (r) (nth r 14))
    (defn snpw39-rec-before-loss     (r) (nth r 15))
    (defn snpw39-rec-after-loss      (r) (nth r 16))
    (defn snpw39-rec-oracle-ok       (r) (nth r 17))
    (defn snpw39-rec-oracle-total    (r) (nth r 18))
    (defn snpw39-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw39-rec-oracle          (r) (nth r 20))
    (defn snpw39-rec-native-form     (r) (nth r 21))
    (defn snpw39-rec-neural          (r) (nth r 22))
    (defn snpw39-rec-open-authority  (r) (nth r 23))
    (defn snpw39-rec-status          (r) (nth r 24))

    0)
