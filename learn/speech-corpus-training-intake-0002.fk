; speech-corpus-training-intake-0002.fk -- second captured batch enters training.
;
; Batch 0002 has twenty-four consentful, local-oracle accepted, WER-0 rows
; across the same six ready locales. This cell admits those rows on top of
; intake 0001, moving the native prototype-training floor from 6 to 30 rows
; without claiming data sufficiency or global ASR/TTS authority.
;
; preludes: learn/speech-corpus-training-intake-0001.fk

(do
    (defn scti2-row (id locale key text oracle-ok wer hash-present consent clean)
        (list "speech-corpus-training-intake-row"
              id locale key text oracle-ok wer hash-present consent clean))

    (defn scti2-row-id      (r) (nth r 1))
    (defn scti2-row-locale  (r) (nth r 2))
    (defn scti2-row-key     (r) (nth r 3))
    (defn scti2-row-text    (r) (nth r 4))
    (defn scti2-row-oracle  (r) (nth r 5))
    (defn scti2-row-wer     (r) (nth r 6))
    (defn scti2-row-hash    (r) (nth r 7))
    (defn scti2-row-consent (r) (nth r 8))
    (defn scti2-row-clean   (r) (nth r 9))

    (defn scti2-batch-rows ()
        (list
            (scti2-row 7 "en" "common.close" "Close" 1 0 1 1 1)
            (scti2-row 8 "en" "common.cancel" "Cancel" 1 0 1 1 1)
            (scti2-row 9 "en" "common.submit" "Submit" 1 0 1 1 1)
            (scti2-row 10 "en" "nav.search" "Search" 1 0 1 1 1)
            (scti2-row 11 "de" "common.close" "Schließen" 1 0 1 1 1)
            (scti2-row 12 "de" "common.yes" "Ja" 1 0 1 1 1)
            (scti2-row 13 "de" "common.no" "Nein" 1 0 1 1 1)
            (scti2-row 14 "de" "nav.search" "Suche" 1 0 1 1 1)
            (scti2-row 15 "es" "common.save" "Guardar" 1 0 1 1 1)
            (scti2-row 16 "es" "common.yes" "Sí" 1 0 1 1 1)
            (scti2-row 17 "es" "common.no" "No" 1 0 1 1 1)
            (scti2-row 18 "es" "hatiSuci.status.open" "Abierto" 1 0 1 1 1)
            (scti2-row 19 "fr" "common.yes" "Oui" 1 0 1 1 1)
            (scti2-row 20 "fr" "common.no" "Non" 1 0 1 1 1)
            (scti2-row 21 "fr" "nav.ideas" "Idées" 1 0 1 1 1)
            (scti2-row 22 "fr" "nav.assets" "Ressources" 1 0 1 1 1)
            (scti2-row 23 "id" "common.close" "Tutup" 1 0 1 1 1)
            (scti2-row 24 "id" "common.cancel" "Batal" 1 0 1 1 1)
            (scti2-row 25 "id" "common.save" "Simpan" 1 0 1 1 1)
            (scti2-row 26 "id" "common.submit" "Kirim" 1 0 1 1 1)
            (scti2-row 27 "pt-br" "common.back" "Voltar" 1 0 1 1 1)
            (scti2-row 28 "pt-br" "common.no" "Não" 1 0 1 1 1)
            (scti2-row 29 "pt-br" "nav.vision" "Visão" 1 0 1 1 1)
            (scti2-row 30 "pt-br" "hatiSuci.act.complete" "Feito" 1 0 1 1 1)))

    (defn scti2-admit? (row max-wer)
        (if (and (eq (scti2-row-oracle row) 1)
                 (and (le (scti2-row-wer row) max-wer)
                      (and (eq (scti2-row-hash row) 1)
                           (and (eq (scti2-row-consent row) 1)
                                (eq (scti2-row-clean row) 1))))) 1 0))

    (defn scti2-count-admitted (rows max-wer)
        (if (eq (len rows) 0) 0
            (add (scti2-admit? (head rows) max-wer)
                 (scti2-count-admitted (tail rows) max-wer))))

    (defn scti2-count-oracle (rows)
        (if (eq (len rows) 0) 0
            (add (scti2-row-oracle (head rows)) (scti2-count-oracle (tail rows)))))

    (defn scti2-count-hash (rows)
        (if (eq (len rows) 0) 0
            (add (scti2-row-hash (head rows)) (scti2-count-hash (tail rows)))))

    (defn scti2-max-wer (rows)
        (if (eq (len rows) 0) 0
            (do
                (let rest (scti2-max-wer (tail rows)))
                (if (gt (scti2-row-wer (head rows)) rest) (scti2-row-wer (head rows)) rest))))

    (defn scti2-locale-seen? (rows locale)
        (if (eq (len rows) 0) 0
            (if (str_eq (scti2-row-locale (head rows)) locale)
                1
                (scti2-locale-seen? (tail rows) locale))))

    (defn scti2-locale-count (rows)
        (add
            (add
                (add (scti2-locale-seen? rows "en")
                     (scti2-locale-seen? rows "de"))
                (add (scti2-locale-seen? rows "es")
                     (scti2-locale-seen? rows "fr")))
            (add (scti2-locale-seen? rows "id")
                 (scti2-locale-seen? rows "pt-br"))))

    (defn scti2-report ()
        (do
            (let previous (scti-report))
            (let rows (scti2-batch-rows))
            (let admitted (scti2-count-admitted rows 25))
            (let total (add (scti-rec-admitted previous) admitted))
            (list "speech-corpus-training-intake-0002"
                  rows
                  (len rows)
                  (scti2-count-oracle rows)
                  admitted
                  (scti-rate admitted (len rows))
                  total
                  (scti-rate total (add (scti-rec-count previous) (len rows)))
                  (scti2-locale-count rows)
                  (scti2-count-hash rows)
                  (scti2-max-wer rows)
                  580710
                  (add (scti-rec-bytes previous) 580710)
                  12000
                  0
                  "native-prototype-training-intake"
                  "captured-corpus-training-intake-expanded-not-data-sufficient"
                  1
                  0
                  0)))

    (defn scti2-rec-kind         (r) (nth r 0))
    (defn scti2-rec-rows         (r) (nth r 1))
    (defn scti2-rec-count        (r) (nth r 2))
    (defn scti2-rec-oracle-ok    (r) (nth r 3))
    (defn scti2-rec-admitted     (r) (nth r 4))
    (defn scti2-rec-rate         (r) (nth r 5))
    (defn scti2-rec-total        (r) (nth r 6))
    (defn scti2-rec-total-rate   (r) (nth r 7))
    (defn scti2-rec-locales      (r) (nth r 8))
    (defn scti2-rec-hash-count   (r) (nth r 9))
    (defn scti2-rec-max-wer      (r) (nth r 10))
    (defn scti2-rec-bytes        (r) (nth r 11))
    (defn scti2-rec-total-bytes  (r) (nth r 12))
    (defn scti2-rec-floor        (r) (nth r 13))
    (defn scti2-rec-sufficient   (r) (nth r 14))
    (defn scti2-rec-route        (r) (nth r 15))
    (defn scti2-rec-status       (r) (nth r 16))
    (defn scti2-rec-native-form  (r) (nth r 17))
    (defn scti2-rec-neural       (r) (nth r 18))
    (defn scti2-rec-authority    (r) (nth r 19))

    0)
