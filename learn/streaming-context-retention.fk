; streaming-context-retention.fk — bounded memory for a long-lived stream.
;
; Named while ingesting LingBot-Map (Chen et al., arXiv:2604.14141). Its
; Geometric Context Transformer does not keep every past frame equally alive:
; it separates anchor context, a pose-reference window, and trajectory memory.
; This cell distils only that transferable retention shape. An observation is
; retained when it is the anchor, lies inside the recent window, or has been
; selected into sparse trajectory memory. Old, unselected intermediates leave.
;
; Honest floor: this is a memory-policy law, not 3D reconstruction, attention,
; SLAM, pose estimation, or a learned model. `age`, `window`, `anchor`, and
; `trajectory` are integer/boolean senses supplied by a caller. What the band
; proves is the bounded selective-retention invariant.
;
; Self-contained over core. Four-way by
; learn/tests/streaming-context-retention-band.fk.
; witnessed: 2026-07-18 -> band 127 four-way (fkwu/Go/Rust/TS)
;
; preludes: form/form-stdlib/core.fk

(do
    ; observation = (age anchor trajectory)
    (defn scr-age (o) (nth o 0))
    (defn scr-anchor? (o) (nth o 1))
    (defn scr-trajectory? (o) (nth o 2))

    (defn scr-recent? (o window)
        (if (le (scr-age o) window) 1 0))

    (defn scr-retained? (o window)
        (if (eq (scr-anchor? o) 1) 1
            (if (eq (scr-recent? o window) 1) 1
                (if (eq (scr-trajectory? o) 1) 1 0))))

    ; 1 anchor / 2 local window / 4 trajectory / 0 released intermediate.
    ; Anchor wins because it is the coordinate ground even when old.
    (defn scr-context-class (o window)
        (if (eq (scr-anchor? o) 1) 1
            (if (eq (scr-recent? o window) 1) 2
                (if (eq (scr-trajectory? o) 1) 4 0))))

    (defn scrk (ok bit) (if ok bit 0))
    (defn streaming-context-retention-check ()
        (add (add (add (add
            (scrk (eq (scr-context-class (list 10000 1 0) 128) 1) 1)
            (scrk (eq (scr-context-class (list 8 0 0) 128) 2) 10))
            (scrk (eq (scr-context-class (list 10000 0 1) 128) 4) 100))
            (scrk (eq (scr-retained? (list 10000 0 0) 128) 0) 1000))
            (scrk (eq (scr-retained? (list 10000 0 1) 128) 1) 10000)))
)
