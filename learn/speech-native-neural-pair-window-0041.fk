; speech-native-neural-pair-window-0041.fk -- forty-first native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; ar<->it. Fresh Mac Metal local-oracle probes check the Arabic and Italian
; renderings for the same neutral meaning, then the Form-native NL/audio
; micro-pair shifts from oracle-held to native within this closed pair window.
; This is not open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw41-kind () "speech-native-neural-pair-window-0041")
    (defn snpw41-a () "ar")
    (defn snpw41-b () "it")
    (defn snpw41-meaning () 303)
    (defn snpw41-floor () 50)
    (defn snpw41-max-wer () 25)
    (defn snpw41-meta () (mlap-meta 96 96 14 80))
    (defn snpw41-feat () (list 3046 41 2 2))
    (defn snpw41-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw41-meaning)) locale))

    (defn snpw41-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0041-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw41-oracle-locale (r) (nth r 1))
    (defn snpw41-oracle-voice  (r) (nth r 2))
    (defn snpw41-oracle-transcript (r) (nth r 3))
    (defn snpw41-oracle-wer    (r) (nth r 4))
    (defn snpw41-oracle-bytes  (r) (nth r 5))
    (defn snpw41-oracle-cksum  (r) (nth r 6))
    (defn snpw41-oracle-name   (r) (nth r 7))
    (defn snpw41-oracle-device (r) (nth r 8))

    (defn snpw41-oracle-rows ()
        (list
            (snpw41-oracle-row "ar" "Majed" "أنا." 0 10906 3840888175)
            (snpw41-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw41-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw41-oracle-wer (head rows)) (snpw41-max-wer)) 1 0)
                 (snpw41-oracle-ok-loop (tail rows)))))
    (defn snpw41-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw41-oracle-bytes (head rows))
                 (snpw41-oracle-byte-total-loop (tail rows)))))

    (defn snpw41-nl (src dst)
        (mlap-nl-sample (snpw41-meaning) src dst
                         (snpw41-tokens src)
                         (snpw41-tokens dst)
                         (snpw41-meaning)
                         0 0 0))

    (defn snpw41-audio (src dst)
        (mlap-audio-sample (snpw41-meaning) src dst
                            (snpw41-tokens dst)
                            (snpw41-tokens dst)
                            (snpw41-feat)
                            (snpw41-meta)
                            0 0 0))

    (defn snpw41-nl-lanes ()
        (list
            (snpw41-nl (snpw41-a) (snpw41-b))
            (snpw41-nl (snpw41-b) (snpw41-a))
            (snpw41-nl (snpw41-a) (snpw41-a))
            (snpw41-nl (snpw41-b) (snpw41-b))))

    (defn snpw41-audio-lanes ()
        (list
            (snpw41-audio (snpw41-a) (snpw41-b))
            (snpw41-audio (snpw41-b) (snpw41-a))
            (snpw41-audio (snpw41-a) (snpw41-a))
            (snpw41-audio (snpw41-b) (snpw41-b))))

    (defn snpw41-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw41-receipt ()
        (do
            (let nl (snpw41-nl-lanes))
            (let audio (snpw41-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw41-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw41-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw41-max-wer)))
            (let oracle-rows (snpw41-oracle-rows))
            (let oracle-ok (snpw41-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw41-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw41-kind)
                  (snpw41-a)
                  (snpw41-b)
                  (snpw41-meaning)
                  1
                  2
                  41
                  82
                  41
                  41
                  before
                  after
                  (if (and (lt before (snpw41-floor)) (ge after (snpw41-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw41-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0041-trained-not-open-authority")))

    (defn snpw41-rec-kind            (r) (nth r 0))
    (defn snpw41-rec-a               (r) (nth r 1))
    (defn snpw41-rec-b               (r) (nth r 2))
    (defn snpw41-rec-meaning         (r) (nth r 3))
    (defn snpw41-rec-pair-increment  (r) (nth r 4))
    (defn snpw41-rec-directed-increment (r) (nth r 5))
    (defn snpw41-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw41-rec-cumulative-directed (r) (nth r 7))
    (defn snpw41-rec-epochs          (r) (nth r 8))
    (defn snpw41-rec-params          (r) (nth r 9))
    (defn snpw41-rec-before-rate     (r) (nth r 10))
    (defn snpw41-rec-after-rate      (r) (nth r 11))
    (defn snpw41-rec-shifted         (r) (nth r 12))
    (defn snpw41-rec-form-nl         (r) (nth r 13))
    (defn snpw41-rec-form-audio      (r) (nth r 14))
    (defn snpw41-rec-before-loss     (r) (nth r 15))
    (defn snpw41-rec-after-loss      (r) (nth r 16))
    (defn snpw41-rec-oracle-ok       (r) (nth r 17))
    (defn snpw41-rec-oracle-total    (r) (nth r 18))
    (defn snpw41-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw41-rec-oracle          (r) (nth r 20))
    (defn snpw41-rec-native-form     (r) (nth r 21))
    (defn snpw41-rec-neural          (r) (nth r 22))
    (defn snpw41-rec-open-authority  (r) (nth r 23))
    (defn snpw41-rec-status          (r) (nth r 24))

    0)
