; locale-affinity-graph.fk — the body's locales as a graph whose edges tell
; human movement through time, place, and shared tongues.
;
; Asked 2026-07-02 ~01:47: "how do the different grammar rules compare —
; probably interesting to look at changes in a graph; we can probably trace
; human movement through time, location, shared tongues." The features were
; already data: coherence-network-self-corpus.fk carries, per locale, its
; family (blood), script (ink), morphological typology (grammar's shape),
; and region (ground). This cell composes those rows UNCHANGED into a
; weighted affinity: two locales share family 8, script 4, typology 2,
; region 1 — an injective 0..15 fold per edge, heaviest for kinship, lighter
; for contact.
;
; The graph the numbers draw IS migration history, readable edge by edge:
;   es-fr / es-pt-br / fr-pt-br at 14 — the Romance triangle, Rome's
;     descendants closer to each other than to their ancestor;
;   la-es at 12 < es-fr at 14 — the ancestor sits FARTHER than the siblings
;     stand to each other: time drifted the typology (fusional-classical vs
;     fusional-stress) — the signature of centuries, visible as arithmetic;
;   en-de at 13 — Germanic kin, full ink and ground, but the typology bit is
;     DARK: English went analytic after its contact centuries (Norse, then
;     1066) — a crossed isogloss recorded as one missing bit;
;   pt-br: romance family on south-american ground — the Atlantic crossing
;     carried the tongue but not the region bit;
;   id / nv at 4 to Europe's locales — script-only edges: ink travels by
;     ship and mission where blood does not;
;   zh, ar at 0 to everything here — isolates in this feature space:
;     different cradles, no shared bit (their bridges in this body are the
;     AUDIO pair windows, not the feature graph);
;   nv-chr at 1 — neighbors by land, strangers by tongue: shared ground,
;     nothing else — the oldest kind of adjacency.
;
; Honest floor: four features per locale is typology, not philology — this
; graph reads the self-corpus's own metadata, not measured grammar-rule
; overlap from the BMF field-domain grammars; wiring THOSE rules in (rule
; sets compared rule by rule) is the named next deepening. And nv/chr sit in
; the graph but remain consent-pending in the corpus — present, not spent.
;
; preludes: form-stdlib/core.fk learn/coherence-network-self-corpus.fk

(do
    (defn lag-find (rows code)
        (if (eq (len rows) 0) 0
            (if (str_eq (cnsc-loc-code (head rows)) code)
                (head rows)
                (lag-find (tail rows) code))))
    (defn lag-loc (code) (lag-find (cnsc-locales) code))

    (defn lag-sh (x y w) (if (str_eq x y) w 0))
    (defn lag-aff (ca cb)
        (do (let a (lag-loc ca))
            (let b (lag-loc cb))
            (add (lag-sh (cnsc-loc-family a) (cnsc-loc-family b) 8)
            (add (lag-sh (cnsc-loc-script a) (cnsc-loc-script b) 4)
            (add (lag-sh (cnsc-loc-typology a) (cnsc-loc-typology b) 2)
                 (lag-sh (cnsc-loc-region a) (cnsc-loc-region b) 1))))))

    (defn lag-codes ()
        (list "en" "de" "es" "fr" "id" "pt-br" "zh" "ar" "la" "nv" "chr"))

    ; the strongest edge a locale has to any OTHER locale
    (defn lag-max-to-loop (code codes)
        (if (eq (len codes) 0) 0
            (do (let rest (lag-max-to-loop code (tail codes)))
                (let cur (if (str_eq (head codes) code) 0
                             (lag-aff code (head codes))))
                (if (gt cur rest) cur rest))))
    (defn lag-max-to (code) (lag-max-to-loop code (lag-codes)))

    ; isolates: locales whose strongest edge is 0 — different cradles
    (defn lag-isolates-loop (codes)
        (if (eq (len codes) 0) 0
            (add (if (eq (lag-max-to (head codes)) 0) 1 0)
                 (lag-isolates-loop (tail codes)))))
    (defn lag-isolates () (lag-isolates-loop (lag-codes)))

    ; the graph's heaviest edge overall
    (defn lag-max-pair-loop (codes)
        (if (eq (len codes) 0) 0
            (do (let rest (lag-max-pair-loop (tail codes)))
                (let cur (lag-max-to (head codes)))
                (if (gt cur rest) cur rest))))
    (defn lag-max-pair () (lag-max-pair-loop (lag-codes)))

    ; folded scalar witness: locales*10^4 + heaviest-edge*10^2 + isolates
    ; (injective while heaviest <= 99 and isolates <= 99). Today:
    ; 11*10000 + 14*100 + 2 = 111402.
    (defn lag-field-code ()
        (add (mul (len (lag-codes)) 10000)
        (add (mul (lag-max-pair) 100)
             (lag-isolates))))
    0)
