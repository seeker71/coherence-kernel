; champion-challenger.fk — the model-promotion north star: a Form-native CHALLENGER runs beside a
; trusted 3rd-party CHAMPION (ground truth) and TAKES OVER only when it has PROVEN it reaches or
; exceeds the champion over a window. "Sample the 3rd-party models until the Form-native arms reach
; or exceed them" — made executable.
;
; self-grounding-classifier.fk promotes OUR perception by counting agreement with a trusted route;
; classifier-eval.fk gates PASS on a proven count. This composes that same proven-count spine but
; asks a distinct question: not "is our reading correct" but "WHICH MODEL is the authority right now",
; decided by proven head-to-head competition. The champion is the incumbent 3rd-party model; the
; challenger is the Form-native arm. Authority flips to the challenger only on earned competition,
; never on asserted accuracy — value-execution.fk's credit gate turned onto model promotion.
;
; TWO readings of the same competition, by what the per-sample coin measures:
;   CLASSIFICATION (cc-*): the coin is correct/incorrect (0/1); the competition is exact INTEGER
;     counts — no ratio, identical on every kernel. A trial = (list champion-correct challenger-correct).
;   VALUE / RL (cc-val-*): the coin is the policy's achieved VALUE (a real float); the competition
;     sums value and compares with real float ordering (ge/gt). A trial = (list champion-value
;     challenger-value). Float comparison crosses four-way (tests/float-compare-band.fk → 4095), so
;     this is as deterministic as the integer reading. diffusion-q-cc.fk uses it for the QAM loop.
;
; Proven by: tests/champion-challenger-band.fk (classification) + tests/diffusion-q-cc-band.fk
; (value-native), both four-way at validate.sh, incl. fkwu.

(do
    (defn cc-champ  (t) (nth t 0))   ; 1 if the 3rd-party champion was correct on this sample
    (defn cc-chall  (t) (nth t 1))   ; 1 if the Form-native challenger was correct on this sample

    ; --- score each model over the window: count correct (recursion is the loop; no subtraction) ---
    (defn cc-champ-score (h)
        (if (eq (len h) 0) 0
            (add (cc-champ (head h)) (cc-champ-score (tail h)))))
    (defn cc-chall-score (h)
        (if (eq (len h) 0) 0
            (add (cc-chall (head h)) (cc-chall-score (tail h)))))

    ; --- REACHES: the challenger is within `margin` of the champion (or over it). margin is slack
    ;     allowed below the champion; margin=0 means the challenger must equal-or-exceed. No sub:
    ;     instead of (chall >= champ - margin) we add the slack to the challenger's side. ---
    (defn cc-reaches? (h margin)
        (if (ge (add (cc-chall-score h) margin) (cc-champ-score h)) 1 0))

    ; --- EXCEEDS: the challenger STRICTLY beats the champion over the window. ---
    (defn cc-exceeds? (h)
        (if (gt (cc-chall-score h) (cc-champ-score h)) 1 0))

    ; --- PROMOTE: flip authority to the challenger only when the window is long enough to trust
    ;     (>= min-samples) AND the challenger has reached the champion within margin. Proven
    ;     competition, never asserted — the long-window floor is the same shape as classifier-eval's
    ;     min-correct gate. ---
    (defn cc-promote? (h min-samples margin)
        (if (and (ge (len h) min-samples) (eq (cc-reaches? h margin) 1)) 1 0))

    ; --- AUTHORITY: which model the body routes on right now. "challenger" once promoted — the
    ;     Form-native arm wins and the 3rd-party champion can retire; "champion" until the
    ;     competition is proven. ---
    (defn cc-authority (h min-samples margin)
        (if (eq (cc-promote? h min-samples margin) 1) "challenger" "champion"))

    ; --- VALUE-NATIVE reading: for RL/value competition the per-sample coin is the policy's
    ;     achieved VALUE (a real float), not a binary correct/incorrect. A value trial is
    ;     (list champion-value challenger-value); authority flips when the challenger's TOTAL value
    ;     reaches the champion's over a trusted window. Float comparison crosses four-way
    ;     (tests/float-compare-band.fk → 4095) — the integer-count reading above is for
    ;     classification; this one is for value. margin is a real-valued slack. ---
    (defn cc-val-champ-score (h)
        (if (eq (len h) 0) 0.0 (add (cc-champ (head h)) (cc-val-champ-score (tail h)))))
    (defn cc-val-chall-score (h)
        (if (eq (len h) 0) 0.0 (add (cc-chall (head h)) (cc-val-chall-score (tail h)))))
    (defn cc-val-reaches? (h margin)
        (if (ge (add (cc-val-chall-score h) margin) (cc-val-champ-score h)) 1 0))
    (defn cc-val-exceeds? (h)
        (if (gt (cc-val-chall-score h) (cc-val-champ-score h)) 1 0))
    (defn cc-val-promote? (h min-samples margin)
        (if (and (ge (len h) min-samples) (eq (cc-val-reaches? h margin) 1)) 1 0))
    (defn cc-val-authority (h min-samples margin)
        (if (eq (cc-val-promote? h min-samples margin) 1) "challenger" "champion"))

    0)
