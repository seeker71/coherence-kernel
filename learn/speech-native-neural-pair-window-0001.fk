; speech-native-neural-pair-window-0001.fk -- first non-zero neural pair window.
;
; This promotes one reciprocal Form-native pair window through the enabled
; native neural micro-kernel. It makes trained pair coverage non-zero without
; claiming open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-form-pair-window-0008.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw1-kind () "speech-native-neural-pair-window-0001")
    (defn snpw1-a () "en")
    (defn snpw1-b () "fr")
    (defn snpw1-floor () 50)

    (defn snpw1-neural-rate (form boot)
        (if (and (eq (sfw8-rec-after-nl form) 100)
                 (and (eq (sfw8-rec-after-audio form) 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw1-receipt ()
        (do
            (let form (sfw8-receipt))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw1-neural-rate form boot))
            (list (snpw1-kind)
                  (snpw1-a)
                  (snpw1-b)
                  1
                  2
                  (snnb-rec-epochs boot)
                  (snnb-rec-param-count boot)
                  before
                  after
                  (if (and (lt before (snpw1-floor)) (ge after (snpw1-floor))) 1 0)
                  (sfw8-rec-after-nl form)
                  (sfw8-rec-after-audio form)
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-trained-not-open-authority")))

    (defn snpw1-rec-kind          (r) (nth r 0))
    (defn snpw1-rec-a             (r) (nth r 1))
    (defn snpw1-rec-b             (r) (nth r 2))
    (defn snpw1-rec-pairs         (r) (nth r 3))
    (defn snpw1-rec-directed      (r) (nth r 4))
    (defn snpw1-rec-epochs        (r) (nth r 5))
    (defn snpw1-rec-params        (r) (nth r 6))
    (defn snpw1-rec-before-rate   (r) (nth r 7))
    (defn snpw1-rec-after-rate    (r) (nth r 8))
    (defn snpw1-rec-shifted       (r) (nth r 9))
    (defn snpw1-rec-form-nl       (r) (nth r 10))
    (defn snpw1-rec-form-audio    (r) (nth r 11))
    (defn snpw1-rec-before-loss   (r) (nth r 12))
    (defn snpw1-rec-after-loss    (r) (nth r 13))
    (defn snpw1-rec-oracle        (r) (nth r 14))
    (defn snpw1-rec-native-form   (r) (nth r 15))
    (defn snpw1-rec-neural        (r) (nth r 16))
    (defn snpw1-rec-open-authority (r) (nth r 17))
    (defn snpw1-rec-status        (r) (nth r 18))

    0)
