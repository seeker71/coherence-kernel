; speech-open-asr-trial-window-0009.fk -- ninth scoped open-ASR source window.
;
; This authority-lane increment adds a real local Mac loopback pair for fr+pt-br:
; macOS say -> ffmpeg -> whisper.cpp on Apple Metal. Whisper is run with an
; explicit language for each endpoint so the local oracle evidence is
; language-aware. This moves scoped open-ASR evidence only; global live open
; dictation remains oracle-held.
;
; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/speech-open-asr-trial-window.fk
;   learn/speech-open-asr-trial-window-0002.fk
;   learn/speech-open-asr-trial-window-0003.fk
;   learn/speech-open-asr-trial-window-0004.fk
;   learn/speech-open-asr-trial-window-0005.fk
;   learn/speech-open-asr-trial-window-0006.fk
;   learn/speech-open-asr-trial-window-0007.fk
;   learn/speech-open-asr-trial-window-0008.fk

(do
    (defn soat9-sample (id locale voice truth heard oracle-ok native-ok audio-hash bytes latency consent fail timeout undo)
        (list "speech-open-asr-trial-sample-0009"
              id locale voice truth heard oracle-ok native-ok audio-hash bytes latency consent fail timeout undo))
    (defn soat9-sample-oracle (s) (nth s 6))
    (defn soat9-sample-native (s) (nth s 7))
    (defn soat9-sample-bytes  (s) (nth s 9))
    (defn soat9-sample-clean? (s)
        (if (and (eq (nth s 11) 1)
                 (eq (add (add (nth s 12) (nth s 13)) (nth s 14)) 0)) 1 0))

    (defn soat9-samples ()
        (list
            (soat9-sample 9417 "fr" "Thomas"
                          "je suis" "Je suis" 1 1 3224208913 17908 41 1 0 0 0)
            (soat9-sample 9418 "pt-br" "Luciana"
                          "eu sou" "Eu sou." 1 1 2995895654 19708 43 1 0 0 0)))

    (defn soat9-count-oracle (samples)
        (if (eq (len samples) 0) 0
            (add
                (if (eq (soat9-sample-clean? (head samples)) 1)
                    (soat9-sample-oracle (head samples))
                    0)
                (soat9-count-oracle (tail samples)))))

    (defn soat9-count-native (samples)
        (if (eq (len samples) 0) 0
            (add
                (if (eq (soat9-sample-clean? (head samples)) 1)
                    (soat9-sample-native (head samples))
                    0)
                (soat9-count-native (tail samples)))))

    (defn soat9-count-bytes (samples)
        (if (eq (len samples) 0) 0
            (add
                (if (eq (soat9-sample-clean? (head samples)) 1)
                    (soat9-sample-bytes (head samples))
                    0)
                (soat9-count-bytes (tail samples)))))

    (defn soat9-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn soat9-segmented-receipt ()
        (do
            (let previous (soat8-segmented-receipt))
            (let samples (soat9-samples))
            (let count (add (soat-receipt-count previous) (len samples)))
            (let oracle-ok (add (soat-receipt-oracle-ok previous) (soat9-count-oracle samples)))
            (let native-ok (add (soat-receipt-native-ok previous) (soat9-count-native samples)))
            (list "speech-open-asr-segmented-trial-receipt-0009"
                  "macos-arm64-m4-max"
                  "whisper.cpp-large-v3-turbo-metal"
                  "multi"
                  "multi"
                  count
                  oracle-ok
                  native-ok
                  (soat9-rate native-ok count)
                  50
                  "native"
                  303
                  "aham-asmi"
                  (list "je" "suis" "eu" "sou")
                  1
                  0
                  (soat9-count-bytes samples)
                  "fr+pt-br-metal-loopback")))

    (defn soat9-report ()
        (do
            (let trial (soat-next-trial))
            (let receipt (soat9-segmented-receipt))
            (list "speech-open-asr-trial-window-0009"
                  trial
                  receipt
                  (snts-oracle-rate trial)
                  (snts-native-rate trial)
                  (soat-receipt-oracle-ok receipt)
                  (soat-receipt-native-ok receipt)
                  (soat-receipt-native-rate receipt)
                  (soat-promote-action receipt)
                  "choice-cut-fail-undo-timeout-clean"
                  (snts-model-context)
                  "trial-window-native-not-global-authority"
                  (nth receipt 16)
                  (nth receipt 17)
                  1
                  0)))

    0)
