; speech-current-status-ledger.fk -- current speech model status, without mixing scopes.
;
; The older metrics report records global live rows. The newer ASR and Sema
; voice trial windows prove scoped native movement. This ledger composes both:
; global authority remains oracle-held where it is still failing, while scoped
; trial windows can record native cuts.
;
; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/sema-voice-trial-window.fk
;   learn/sema-voice-trial-window-0002.fk

(do
    (defn smcl-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn smcl-size ()
        (list "speech-current-model-size"
              30     ; admitted native neural weight parameters
              4      ; selected arms: ASR, TTS, NL2NL, audio2audio
              38     ; major Form components plus scoped trial windows and nonzero voice floor
              6      ; native Sema voice organs/components
              8      ; scoped native trial windows
              0))    ; C seed growth

    (defn smcl-composition ()
        (list "speech-current-composition"
              "prototype-asr"
              "native-segmented-acoustic-learning"
              "sema-voice-sample-loop"
              "text-conditioned-acoustic-vocoder"
              "closed-set-locale-form"
              "native-source-window-audio2audio-acoustic"
              "speech-native-neural-pair-window-0022"
              "speech-native-neural-pair-window-0023"
              "speech-native-neural-pair-window-0024"
              "speech-native-neural-pair-window-0025"
              "speech-native-neural-pair-window-0026"
              "speech-native-neural-pair-window-0027"
              "speech-native-neural-pair-window-0028"
              "speech-native-neural-pair-window-0029"
              "speech-native-neural-pair-window-0030"
              "speech-open-asr-trial-window-0005"
              "speech-open-asr-trial-window-0006"
              "speech-audio-nl2nl-source-window-0002"
              "sanskrit-locale-baseline"
              "local-oracle-guided-ab-trials"))

    (defn smcl-open-live-row ()
        (list "live-open-dictation" 4 4 100 0 4 0 100 "oracle-guide"))

    (defn smcl-voice-live-row ()
        (list "sema-live-voice" 1 1 100 0 1 0 100 "oracle-guide"))

    (defn smcl-global-live ()
        (do
            (list "speech-global-live-authority"
                  (smcl-open-live-row)
                  (smcl-voice-live-row)
                  5 5 100
                  0 5 0
                  "oracle-held")))

    (defn smcl-open-trial ()
        (list "speech-current-open-asr-trial"
              12
              12
              12
              12
              100
              "native"
              "trial-window-native-not-global-authority"))

    (defn smcl-voice-trial ()
        (do
            (let r (svtw2-report))
            (let receipt (nth r 2))
            (list "speech-current-sema-voice-trial"
                  (svtw-rec-oracle-ok receipt)
                  (svtw2-rec-count receipt)
                  (svtw-rec-native-ok receipt)
                  (svtw2-rec-count receipt)
                  (svtw-rec-wer receipt)
                  (svtw-rec-route receipt)
                  (nth r 11)
                  (svtw-rec-f0 receipt)
                  (svtw-rec-warmth receipt)
                  (svtw-rec-cadence receipt)
                  (svtw-rec-breath receipt))))

    (defn smcl-scoped-trials ()
        (list "speech-scoped-trial-windows"
              (smcl-open-trial)
              (smcl-voice-trial)
              14 14 100
              14 14 100
              "trial-window-native-not-global-authority"))

    (defn smcl-voice-quality ()
        (list "speech-current-voice-quality"
              165 82 64 76 18
              165 82 64 18
              "target-and-scoped-tcav-window-aligned"))

    (defn smcl-report ()
        (list "speech-current-status-ledger"
              (smcl-size)
              (smcl-composition)
              (smcl-global-live)
              (smcl-scoped-trials)
              (smcl-voice-quality)
              "global-live-authority-still-oracle-held"
              "scoped-trials-cut-native-challengers"
              1
              1))

    0)
