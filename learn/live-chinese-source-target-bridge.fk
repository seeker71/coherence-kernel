; live-chinese-source-target-bridge.fk -- live Chinese ASR to target acoustic frames.
;
; This is the compact source-to-target bridge that fits the direct-source lane:
; a real local Chinese teacher wav is rendered and transcribed on Metal by
; macos-chinese-teacher-acoustic-learning; the native decoded source is checked
; against the local oracle; the Sanskrit baseline supplies target-locale tokens;
; and this cell emits a small Form-native target acoustic frame row.
;
; Boundary: the target frame emitter is a compact deterministic micro-kernel,
; not the full TCAV stack and not a neural vocoder. It moves live source audio
; into locale-neutral meaning and target acoustic data without claiming global
; ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/sanskrit-locale-baseline.fk learn/macos-sema-teacher-acoustic-learning.fk learn/macos-chinese-teacher-acoustic-learning.fk

(do
    (defn lzst-kind () "live-chinese-source-target-bridge")
    (defn lzst-src () "zh")
    (defn lzst-dst () "en")
    (defn lzst-meaning () 303)
    (defn lzst-max-wer () 25)

    (defn lzst-target-tokens (dst)
        (slb-tokens (slb-line-by-meaning (lzst-meaning)) dst))

    (defn lzst-token-code (tok)
        (if (str_eq tok "i") 1
            (if (str_eq tok "am") 2
                (if (str_eq tok "ich") 3
                    (if (str_eq tok "bin") 4
                        (if (str_eq tok "yo") 5
                            (if (str_eq tok "soy") 6
                                (if (str_eq tok "我") 7
                                    (if (str_eq tok "在") 8 99))))))))

    (defn lzst-acoustic-frame (tok idx)
        (list "live-target-acoustic-frame"
              tok
              (lzst-token-code tok)
              (add 4 idx)
              (add 160 (mul idx 3))
              (add 80 (mul (lzst-token-code tok) 2))))

    (defn lzst-frame-loop (tokens idx)
        (if (eq (len tokens) 0) (empty)
            (cons (lzst-acoustic-frame (head tokens) idx)
                  (lzst-frame-loop (tail tokens) (add idx 1)))))

    (defn lzst-target-frames (dst)
        (lzst-frame-loop (lzst-target-tokens dst) 1))

    (defn lzst-frame-energy (frames)
        (if (eq (len frames) 0) 0
            (add (nth (head frames) 5) (lzst-frame-energy (tail frames)))))

    (defn lzst-source-ok? (r)
        (if (and (eq (mztal-rec-ok r) 1)
                 (and (eq (mztal-rec-wer r) 0)
                      (eq (sw-accept?
                            (sw-tokens (mztal-rec-native r))
                            (sw-tokens (mztal-text))
                            (lzst-max-wer)) 1))) 1 0))

    (defn lzst-receipt-from (r dst)
        (do
            (let target (lzst-target-tokens dst))
            (let frames (lzst-target-frames dst))
            (list (lzst-kind)
                  (mztal-rec-locale r)
                  dst
                  (mztal-rec-meaning r)
                  (mztal-rec-hash r)
                  (mztal-rec-native r)
                  (lzst-source-ok? r)
                  (len target)
                  (len frames)
                  (lzst-frame-energy frames)
                  (if (and (eq (lzst-source-ok? r) 1)
                           (and (gt (len frames) 0)
                                (eq (slb-pair-ready? (mztal-rec-locale r) dst) 1)))
                      "native-source-target-acoustic"
                      "oracle-guide")
                  (mztal-rec-confidence r)
                  1
                  0)))

    (defn lzst-rec-kind        (r) (nth r 0))
    (defn lzst-rec-src         (r) (nth r 1))
    (defn lzst-rec-dst         (r) (nth r 2))
    (defn lzst-rec-meaning     (r) (nth r 3))
    (defn lzst-rec-hash        (r) (nth r 4))
    (defn lzst-rec-native      (r) (nth r 5))
    (defn lzst-rec-source-ok   (r) (nth r 6))
    (defn lzst-rec-target-toks (r) (nth r 7))
    (defn lzst-rec-frames      (r) (nth r 8))
    (defn lzst-rec-energy      (r) (nth r 9))
    (defn lzst-rec-route       (r) (nth r 10))
    (defn lzst-rec-confidence  (r) (nth r 11))
    (defn lzst-rec-native-form (r) (nth r 12))
    (defn lzst-rec-neural      (r) (nth r 13))

    (defn lzst-run-receipt ()
        (lzst-receipt-from (mztal-run-receipt) (lzst-dst)))

    (defn lzst-run-verdict ()
        (do
            (let r (lzst-run-receipt))
            (add
                (add
                    (add (if (str_eq (lzst-rec-kind r) (lzst-kind)) 1 0)
                         (if (str_eq (lzst-rec-src r) "zh") 2 0))
                    (add (if (str_eq (lzst-rec-dst r) "en") 4 0)
                         (if (eq (lzst-rec-meaning r) 303) 8 0)))
                (add
                    (add (if (gt (lzst-rec-hash r) 0) 16 0)
                         (if (eq (lzst-rec-source-ok r) 1) 32 0))
                    (add
                        (add (if (eq (lzst-rec-target-toks r) 2) 64 0)
                             (if (eq (lzst-rec-frames r) 2) 128 0))
                        (add
                            (add (if (gt (lzst-rec-energy r) 0) 256 0)
                                 (if (str_eq (lzst-rec-route r) "native-source-target-acoustic") 512 0))
                            (add
                                (add (if (ge (lzst-rec-confidence r) 80) 1024 0)
                                     (if (eq (lzst-rec-native-form r) 1) 2048 0))
                                (if (eq (lzst-rec-neural r) 0) 4096 0))))))))

    0)
