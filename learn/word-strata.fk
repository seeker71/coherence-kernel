; word-strata.fk — the function-word strata as data: the first buildable
; consequence of deixis-as-content-addressing (Urs, 2026-07-02 ~02:08:
; "I, you, we, he, it being placeholders map to memory and node-ids").
;
; Three strata, three fates in any NL cell:
;   DEICTIC     — referential surface forms (i, you, it, here, now...).
;                 These are HOLES: they resolve to nodes (speaker, addressee,
;                 salient referent) rather than carrying lexical content.
;                 Until the live resolver stands (relationship-store binding,
;                 named future work), they match each other by TYPE at weight
;                 1 — "i" meets "i am" through shared reference, which is why
;                 meaning 303 ("i am"), expressed ENTIRELY in this stratum,
;                 stays locatable. Naive stopword-stripping would blind the
;                 body to pure being.
;   GRAMMATICAL — pure structure (articles, copulas, auxiliaries, adpositions,
;                 conjunctions). Carry no referent. Score ZERO in locate and
;                 are stripped from embeddings: the paraphrase band's measured
;                 "for" collision (301 mistaken for 304 over an incidental
;                 shared adposition) is exactly this stratum polluting lexical
;                 statistics. Negation (not/no/never) is deliberately NOT
;                 here — polarity flips meaning and stays content.
;   CONTENT     — everything else, weight 2. Quantifiers (all, every) stay
;                 content: they are load-bearing in the baseline meanings.
;
; Honest floor: these lists are English-only seed data — the de/es/fr/...
; strata are named next rows, one small consented movement per locale; and
; deictic TYPE-match is a stand-in for real node resolution, not the thing
; itself.
;
; preludes: form-stdlib/core.fk

(do
    (defn ws-member (ws w)
        (if (eq (len ws) 0) 0
            (if (str_eq (head ws) w) 1 (ws-member (tail ws) w))))

    (defn ws-deictic ()
        (list "i" "me" "my" "mine" "you" "your" "yours" "we" "us" "our"
              "he" "him" "his" "she" "her" "hers" "it" "its"
              "they" "them" "their" "this" "that" "these" "those"
              "here" "there" "now" "then" "who" "whom" "whose"))

    (defn ws-grammatical ()
        (list "the" "a" "an" "is" "am" "are" "was" "were" "be" "being" "been"
              "do" "does" "did" "let" "may" "will" "shall" "would" "should"
              "can" "could" "must" "of" "for" "to" "in" "on" "at" "by"
              "with" "from" "into" "and" "or" "but" "so" "as" "if" "than"))

    (defn ws-deictic? (w) (ws-member (ws-deictic) w))
    (defn ws-grammatical? (w) (ws-member (ws-grammatical) w))
    (defn ws-content? (w)
        (if (eq (ws-deictic? w) 1) 0
            (if (eq (ws-grammatical? w) 1) 0 1)))

    ; token weight for locate scoring: content 2, deictic 1, grammatical 0
    (defn ws-weight (w)
        (if (eq (ws-content? w) 1) 2
            (if (eq (ws-deictic? w) 1) 1 0)))

    ; strip the grammatical stratum (for embeddings: structure leaves the
    ; statistics; reference and content stay)
    (defn ws-strip-grammatical (tokens)
        (if (eq (len tokens) 0) (empty)
            (if (eq (ws-grammatical? (head tokens)) 1)
                (ws-strip-grammatical (tail tokens))
                (cons (head tokens) (ws-strip-grammatical (tail tokens))))))
    0)
