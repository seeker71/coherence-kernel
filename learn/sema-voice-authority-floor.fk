; sema-voice-authority-floor.fk -- keep Sema voice from collapsing to 0/0.
;
; The live Sema voice authority row now has a witnessed local-oracle pass from
; a host teacher sample, while native stays 0/1, WER 100. The scoped TCAV trial window has a passing
; local-oracle/native candidate. This cell keeps both facts visible so the
; training floor is nonzero while global live authority remains unpromoted.
;
; preludes:
;   learn/speech-oracle-native-backlog.fk
;   learn/speech-next-trial-scheduler.fk
;   learn/sema-voice-trial-window.fk
;   learn/sema-voice-trial-window-0002.fk

(do
    (defn svaf-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn svaf-row (kind source oracle-ok oracle-total native-ok native-total wer route scope)
        (list kind source
              oracle-ok oracle-total (svaf-rate oracle-ok oracle-total)
              native-ok native-total (svaf-rate native-ok native-total)
              wer route scope))

    (defn svaf-row-kind          (r) (nth r 0))
    (defn svaf-row-source        (r) (nth r 1))
    (defn svaf-row-oracle-ok     (r) (nth r 2))
    (defn svaf-row-oracle-total  (r) (nth r 3))
    (defn svaf-row-oracle-rate   (r) (nth r 4))
    (defn svaf-row-native-ok     (r) (nth r 5))
    (defn svaf-row-native-total  (r) (nth r 6))
    (defn svaf-row-native-rate   (r) (nth r 7))
    (defn svaf-row-wer           (r) (nth r 8))
    (defn svaf-row-route         (r) (nth r 9))
    (defn svaf-row-scope         (r) (nth r 10))

    (defn svaf-live-row ()
        (do
            (let live (nth (sonb-gaps) 1))
            (svaf-row "sema-voice-live-authority-row"
                      (sonb-gap-name live)
                      (sonb-gap-oracle-ok live) (sonb-gap-oracle-total live)
                      (sonb-gap-native-ok live) (sonb-gap-native-total live)
                      (sonb-gap-native-wer live)
                      (sonb-gap-route live)
                      "global-live-authority-not-promoted")))

    (defn svaf-trial-row ()
        (do
            (let receipt (svtw2-receipt))
            (svaf-row "sema-voice-scoped-training-row"
                      (svtw-rec-id receipt)
                      (svtw-rec-oracle-ok receipt) (svtw2-rec-count receipt)
                      (svtw-rec-native-ok receipt) (svtw2-rec-count receipt)
                      (svtw-rec-wer receipt)
                      (svtw-rec-route receipt)
                      "scoped-training-floor-not-global-authority")))

    (defn svaf-combined-row (live trial)
        (svaf-row "sema-voice-nonzero-training-floor"
                  "live-plus-scoped-trial"
                  (add (svaf-row-oracle-ok live) (svaf-row-oracle-ok trial))
                  (add (svaf-row-oracle-total live) (svaf-row-oracle-total trial))
                  (add (svaf-row-native-ok live) (svaf-row-native-ok trial))
                  (add (svaf-row-native-total live) (svaf-row-native-total trial))
                  (svaf-row-wer live)
                  "oracle-guide"
                  "nonzero-floor-live-authority-still-held"))

    (defn svaf-zero-denominator? (row)
        (if (or (eq (svaf-row-oracle-total row) 0)
                (eq (svaf-row-native-total row) 0)) 1 0))

    (defn svaf-live-promoted? (live)
        (if (and (eq (svaf-row-oracle-ok live) (svaf-row-oracle-total live))
                 (and (eq (svaf-row-native-ok live) (svaf-row-native-total live))
                      (str_eq (svaf-row-route live) "native-sema-voice"))) 1 0))

    (defn svaf-action (live combined)
        (if (eq (svaf-zero-denominator? combined) 1)
            "block-zero-denominator-voice-gate"
            (if (eq (svaf-live-promoted? live) 1)
                "promote-native-sema-voice"
                "render-next-live-sema-sample-and-oracle")))

    (defn svaf-status (live combined)
        (if (eq (svaf-zero-denominator? combined) 1)
            "invalid-voice-floor-zero-denominator"
            (if (eq (svaf-live-promoted? live) 1)
                "native-sema-voice-authority-ready"
                "nonzero-training-floor-live-authority-still-held")))

    (defn svaf-report ()
        (do
            (let live (svaf-live-row))
            (let trial (svaf-trial-row))
            (let combined (svaf-combined-row live trial))
            (list "sema-voice-authority-floor"
                  live
                  trial
                  combined
                  (svaf-action live combined)
                  (svaf-status live combined)
                  "tcav-two-window-cumulative"
                  "whisper.cpp-large-v3-turbo-metal"
                  "macos-arm64-m4-max"
                  1
                  0)))

    (defn svaf-rec-kind          (r) (nth r 0))
    (defn svaf-rec-live          (r) (nth r 1))
    (defn svaf-rec-trial         (r) (nth r 2))
    (defn svaf-rec-combined      (r) (nth r 3))
    (defn svaf-rec-action        (r) (nth r 4))
    (defn svaf-rec-status        (r) (nth r 5))
    (defn svaf-rec-candidate     (r) (nth r 6))
    (defn svaf-rec-oracle        (r) (nth r 7))
    (defn svaf-rec-device        (r) (nth r 8))
    (defn svaf-rec-native-form   (r) (nth r 9))
    (defn svaf-rec-neural-ready  (r) (nth r 10))

    0)
