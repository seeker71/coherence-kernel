; speech-native-neural-pair-window-0017.fk -- seventeenth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; de<->fr. It connects the German baseline to the French baseline as a native
; neural micro-pair, increasing trained neural pair coverage from sixteen to
; seventeen without claiming full open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw17-kind () "speech-native-neural-pair-window-0017")
    (defn snpw17-a () "de")
    (defn snpw17-b () "fr")
    (defn snpw17-meaning () 301)
    (defn snpw17-floor () 50)
    (defn snpw17-max-wer () 25)
    (defn snpw17-meta () (mlap-meta 95 94 16 81))
    (defn snpw17-feat () (list 4000 40 2 2))
    (defn snpw17-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw17-meaning)) locale))

    (defn snpw17-nl (src dst)
        (mlap-nl-sample (snpw17-meaning) src dst
                         (snpw17-tokens src)
                         (snpw17-tokens dst)
                         (snpw17-meaning)
                         0 0 0))

    (defn snpw17-audio (src dst)
        (mlap-audio-sample (snpw17-meaning) src dst
                            (snpw17-tokens dst)
                            (snpw17-tokens dst)
                            (snpw17-feat)
                            (snpw17-meta)
                            0 0 0))

    (defn snpw17-nl-lanes ()
        (list
            (snpw17-nl (snpw17-a) (snpw17-b))
            (snpw17-nl (snpw17-b) (snpw17-a))
            (snpw17-nl (snpw17-a) (snpw17-a))
            (snpw17-nl (snpw17-b) (snpw17-b))))

    (defn snpw17-audio-lanes ()
        (list
            (snpw17-audio (snpw17-a) (snpw17-b))
            (snpw17-audio (snpw17-b) (snpw17-a))
            (snpw17-audio (snpw17-a) (snpw17-a))
            (snpw17-audio (snpw17-b) (snpw17-b))))

    (defn snpw17-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw17-receipt ()
        (do
            (let nl (snpw17-nl-lanes))
            (let audio (snpw17-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw17-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw17-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw17-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw17-neural-rate nl-rate audio-rate boot))
            (list (snpw17-kind)
                  (snpw17-a)
                  (snpw17-b)
                  (snpw17-meaning)
                  1
                  2
                  17
                  34
                  17
                  17
                  before
                  after
                  (if (and (lt before (snpw17-floor)) (ge after (snpw17-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0017-trained-not-open-authority")))

    (defn snpw17-rec-kind            (r) (nth r 0))
    (defn snpw17-rec-a               (r) (nth r 1))
    (defn snpw17-rec-b               (r) (nth r 2))
    (defn snpw17-rec-meaning         (r) (nth r 3))
    (defn snpw17-rec-pair-increment  (r) (nth r 4))
    (defn snpw17-rec-directed-increment (r) (nth r 5))
    (defn snpw17-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw17-rec-cumulative-directed (r) (nth r 7))
    (defn snpw17-rec-epochs          (r) (nth r 8))
    (defn snpw17-rec-params          (r) (nth r 9))
    (defn snpw17-rec-before-rate     (r) (nth r 10))
    (defn snpw17-rec-after-rate      (r) (nth r 11))
    (defn snpw17-rec-shifted         (r) (nth r 12))
    (defn snpw17-rec-form-nl         (r) (nth r 13))
    (defn snpw17-rec-form-audio      (r) (nth r 14))
    (defn snpw17-rec-before-loss     (r) (nth r 15))
    (defn snpw17-rec-after-loss      (r) (nth r 16))
    (defn snpw17-rec-oracle          (r) (nth r 17))
    (defn snpw17-rec-native-form     (r) (nth r 18))
    (defn snpw17-rec-neural          (r) (nth r 19))
    (defn snpw17-rec-open-authority  (r) (nth r 20))
    (defn snpw17-rec-status          (r) (nth r 21))

    0)
