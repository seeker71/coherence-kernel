; macos-chinese-teacher-acoustic-learning.fk -- Chinese teacher wav trains native ASR.
;
; This brings home the short Chinese baseline line that passed the local oracle:
; "我在" (meaning 303). Longer Chinese baseline phrases remain oracle misses and
; should feed the next A/B learner; this cell admits only the witnessed pass.
;
; The path is executable: macOS `say` renders Eddy Chinese, ffmpeg normalizes the
; wav, local whisper.cpp on Metal transcribes it, and Form reads the wav
; envelope, trains Chinese token prototypes, and decodes the learned frames.
;
; Boundary: scoped supervised prototype learning. This is not a neural acoustic
; encoder and not native Sema TTS authority.
;
; preludes: observe/stt-wer.fk observe/wav-sense.fk learn/macos-sema-teacher-acoustic-learning.fk

(do
    (defn mztal-kind () "macos-chinese-teacher-acoustic-learning")
    (defn mztal-meaning () 303)
    (defn mztal-locale () "zh")
    (defn mztal-voice () "Eddy (Chinese (China mainland))")
    (defn mztal-text () "我在")
    (defn mztal-tokens () (sw-tokens (mztal-text)))
    (defn mztal-out-dir () (str_concat (temp_dir) "/sema-chinese-teacher-acoustic-learning"))

    (defn mztal-aiff-path (id)
        (mstal-cat4 (mztal-out-dir) "/chinese-" (mstal-int-str id) ".aiff"))
    (defn mztal-wav-path (id)
        (mstal-cat4 (mztal-out-dir) "/chinese-" (mstal-int-str id) ".wav"))
    (defn mztal-say-command (voice aiff text)
        (str_concat
            (str_concat "say -v " (mstal-q voice))
            (str_concat
                (str_concat " -o " (mstal-q aiff))
                (str_concat " " (mstal-q text)))))
    (defn mztal-ffmpeg-command (aiff wav)
        (str_concat
            (str_concat "ffmpeg -hide_banner -loglevel error -y -i " (mstal-q aiff))
            (str_concat " -ar 16000 -ac 1 -c:a pcm_s16le " (mstal-q wav))))
    (defn mztal-whisper-command (wav)
        (str_concat
            (str_concat "whisper-cli -m " (mstal-q (mstal-model)))
            (str_concat
                (str_concat " -f " (mstal-q wav))
                (str_concat " -l zh -nt -np"))))

    (defn mztal-render (id)
        (do
            (let _mk (fs_mkdir (mztal-out-dir)))
            (let _say (host-exec (mztal-say-command (mztal-voice) (mztal-aiff-path id) (mztal-text)) ""))
            (let _ff (host-exec (mztal-ffmpeg-command (mztal-aiff-path id) (mztal-wav-path id)) ""))
            (mztal-wav-path id)))
    (defn mztal-transcript (wav)
        (host-exec (mztal-whisper-command wav) ""))
    (defn mztal-ready? ()
        (mstal-ready?))

    (defn mztal-trained (features)
        (mstal-train-loop (mztal-tokens) features (mstal-base-prototypes)))

    (defn mztal-receipt-from (wav transcript)
        (do
            (let env (mstal-env wav))
            (let features (mstal-token-features wav))
            (let trained (mztal-trained features))
            (let frames (mstal-frames (mstal-frame-features features) trained 2 80))
            (let native (mstal-decoded-text frames))
            (list (mztal-kind)
                  (mztal-locale)
                  (mztal-meaning)
                  (mstal-audio-hash wav)
                  (len env)
                  (len features)
                  (len trained)
                  transcript
                  native
                  (if (and (sw-accept? (sw-tokens transcript) (mztal-tokens) (mstal-max-wer))
                           (sw-accept? (sw-tokens native) (mztal-tokens) (mstal-max-wer))) 1 0)
                  (sw-wer (sw-tokens native) (mztal-tokens))
                  (mstal-min-conf frames)
                  (mstal-device)
                  (mstal-oracle)
                  1
                  0)))

    (defn mztal-rec-kind        (r) (nth r 0))
    (defn mztal-rec-locale      (r) (nth r 1))
    (defn mztal-rec-meaning     (r) (nth r 2))
    (defn mztal-rec-hash        (r) (nth r 3))
    (defn mztal-rec-env-count   (r) (nth r 4))
    (defn mztal-rec-features    (r) (nth r 5))
    (defn mztal-rec-prototypes  (r) (nth r 6))
    (defn mztal-rec-oracle      (r) (nth r 7))
    (defn mztal-rec-native      (r) (nth r 8))
    (defn mztal-rec-ok          (r) (nth r 9))
    (defn mztal-rec-wer         (r) (nth r 10))
    (defn mztal-rec-confidence  (r) (nth r 11))
    (defn mztal-rec-device      (r) (nth r 12))
    (defn mztal-rec-oracle-name (r) (nth r 13))
    (defn mztal-rec-native-form (r) (nth r 14))
    (defn mztal-rec-neural      (r) (nth r 15))

    (defn mztal-run-receipt ()
        (if (eq (mztal-ready?) 1)
            (do
                (let wav (mztal-render 984601))
                (let transcript (mztal-transcript wav))
                (mztal-receipt-from wav transcript))
            (list (mztal-kind) (mztal-locale) (mztal-meaning) 0 0 0 0 "" "" 0 100 0
                  (mstal-device) (mstal-oracle) 1 0)))

    (defn mztal-run-wer ()
        (mztal-rec-wer (mztal-run-receipt)))

    (defn mztal-run-verdict ()
        (do
            (let r (mztal-run-receipt))
            (add
                (add
                    (add (if (str_eq (mztal-rec-kind r) (mztal-kind)) 1 0)
                         (if (str_eq (mztal-rec-locale r) "zh") 2 0))
                    (add (if (eq (mztal-rec-meaning r) 303) 4 0)
                         (if (gt (mztal-rec-hash r) 0) 8 0)))
                (add
                    (add (if (eq (mztal-rec-env-count r) 8) 16 0)
                         (if (eq (mztal-rec-features r) 3) 32 0))
                    (add
                        (add (if (gt (mztal-rec-prototypes r) 2) 64 0)
                             (if (eq (sw-wer (sw-tokens (mztal-rec-oracle r)) (mztal-tokens)) 0) 128 0))
                        (add
                            (add (if (eq (sw-wer (sw-tokens (mztal-rec-native r)) (mztal-tokens)) 0) 256 0)
                                 (if (eq (mztal-rec-ok r) 1) 512 0))
                            (add
                                (add (if (eq (mztal-rec-wer r) 0) 1024 0)
                                     (if (ge (mztal-rec-confidence r) 80) 2048 0))
                                (add (if (eq (mztal-rec-native-form r) 1) 4096 0)
                                     (if (eq (mztal-rec-neural r) 0) 8192 0)))))))))

    0)
