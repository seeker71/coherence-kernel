; speech-native-neural-pair-window-0040.fk -- fortieth native neural pair window.
;
; This trains the next reciprocal pair selected by the background pair lane:
; zh<->it. Fresh Mac Metal local-oracle probes check the Chinese and Italian
; renderings for the same neutral meaning, then the Form-native NL/audio
; micro-pair shifts from oracle-held to native within this closed pair window.
; This is not open ASR/TTS authority.
;
; preludes: observe/stt-wer.fk observe/asr-prompt-id.fk learn/sanskrit-locale-baseline.fk learn/multilocale-nl-audio-pipeline.fk learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw40-kind () "speech-native-neural-pair-window-0040")
    (defn snpw40-a () "zh")
    (defn snpw40-b () "it")
    (defn snpw40-meaning () 303)
    (defn snpw40-floor () 50)
    (defn snpw40-max-wer () 25)
    (defn snpw40-meta () (mlap-meta 96 96 13 80))
    (defn snpw40-feat () (list 3045 40 2 2))
    (defn snpw40-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw40-meaning)) locale))

    (defn snpw40-oracle-row (locale voice transcript wer wav-bytes cksum)
        (list "speech-native-neural-pair-0040-local-oracle"
              locale voice transcript wer wav-bytes cksum
              "whisper.cpp-large-v3-turbo-metal"
              "macos-arm64-m4-max"))
    (defn snpw40-oracle-locale (r) (nth r 1))
    (defn snpw40-oracle-voice  (r) (nth r 2))
    (defn snpw40-oracle-transcript (r) (nth r 3))
    (defn snpw40-oracle-wer    (r) (nth r 4))
    (defn snpw40-oracle-bytes  (r) (nth r 5))
    (defn snpw40-oracle-cksum  (r) (nth r 6))
    (defn snpw40-oracle-name   (r) (nth r 7))
    (defn snpw40-oracle-device (r) (nth r 8))

    (defn snpw40-oracle-rows ()
        (list
            (snpw40-oracle-row "zh" "Tingting" "我在" 0 15064 3568659029)
            (snpw40-oracle-row "it" "Alice" "Io sono" 0 16706 3343634846)))

    (defn snpw40-oracle-ok-loop (rows)
        (if (eq (len rows) 0) 0
            (add (if (le (snpw40-oracle-wer (head rows)) (snpw40-max-wer)) 1 0)
                 (snpw40-oracle-ok-loop (tail rows)))))
    (defn snpw40-oracle-byte-total-loop (rows)
        (if (eq (len rows) 0) 0
            (add (snpw40-oracle-bytes (head rows))
                 (snpw40-oracle-byte-total-loop (tail rows)))))

    (defn snpw40-nl (src dst)
        (mlap-nl-sample (snpw40-meaning) src dst
                         (snpw40-tokens src)
                         (snpw40-tokens dst)
                         (snpw40-meaning)
                         0 0 0))

    (defn snpw40-audio (src dst)
        (mlap-audio-sample (snpw40-meaning) src dst
                            (snpw40-tokens dst)
                            (snpw40-tokens dst)
                            (snpw40-feat)
                            (snpw40-meta)
                            0 0 0))

    (defn snpw40-nl-lanes ()
        (list
            (snpw40-nl (snpw40-a) (snpw40-b))
            (snpw40-nl (snpw40-b) (snpw40-a))
            (snpw40-nl (snpw40-a) (snpw40-a))
            (snpw40-nl (snpw40-b) (snpw40-b))))

    (defn snpw40-audio-lanes ()
        (list
            (snpw40-audio (snpw40-a) (snpw40-b))
            (snpw40-audio (snpw40-b) (snpw40-a))
            (snpw40-audio (snpw40-a) (snpw40-a))
            (snpw40-audio (snpw40-b) (snpw40-b))))

    (defn snpw40-neural-rate (nl-rate audio-rate oracle-ok boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq oracle-ok 2)
                           (and (eq (snnb-rec-after-loss boot) 0)
                                (eq (snnb-rec-bootstrap-ready boot) 1))))) 100 0))

    (defn snpw40-receipt ()
        (do
            (let nl (snpw40-nl-lanes))
            (let audio (snpw40-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw40-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw40-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw40-max-wer)))
            (let oracle-rows (snpw40-oracle-rows))
            (let oracle-ok (snpw40-oracle-ok-loop oracle-rows))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw40-neural-rate nl-rate audio-rate oracle-ok boot))
            (list (snpw40-kind)
                  (snpw40-a)
                  (snpw40-b)
                  (snpw40-meaning)
                  1
                  2
                  40
                  80
                  40
                  40
                  before
                  after
                  (if (and (lt before (snpw40-floor)) (ge after (snpw40-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  oracle-ok
                  (len oracle-rows)
                  (snpw40-oracle-byte-total-loop oracle-rows)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0040-trained-not-open-authority")))

    (defn snpw40-rec-kind            (r) (nth r 0))
    (defn snpw40-rec-a               (r) (nth r 1))
    (defn snpw40-rec-b               (r) (nth r 2))
    (defn snpw40-rec-meaning         (r) (nth r 3))
    (defn snpw40-rec-pair-increment  (r) (nth r 4))
    (defn snpw40-rec-directed-increment (r) (nth r 5))
    (defn snpw40-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw40-rec-cumulative-directed (r) (nth r 7))
    (defn snpw40-rec-epochs          (r) (nth r 8))
    (defn snpw40-rec-params          (r) (nth r 9))
    (defn snpw40-rec-before-rate     (r) (nth r 10))
    (defn snpw40-rec-after-rate      (r) (nth r 11))
    (defn snpw40-rec-shifted         (r) (nth r 12))
    (defn snpw40-rec-form-nl         (r) (nth r 13))
    (defn snpw40-rec-form-audio      (r) (nth r 14))
    (defn snpw40-rec-before-loss     (r) (nth r 15))
    (defn snpw40-rec-after-loss      (r) (nth r 16))
    (defn snpw40-rec-oracle-ok       (r) (nth r 17))
    (defn snpw40-rec-oracle-total    (r) (nth r 18))
    (defn snpw40-rec-oracle-bytes    (r) (nth r 19))
    (defn snpw40-rec-oracle          (r) (nth r 20))
    (defn snpw40-rec-native-form     (r) (nth r 21))
    (defn snpw40-rec-neural          (r) (nth r 22))
    (defn snpw40-rec-open-authority  (r) (nth r 23))
    (defn snpw40-rec-status          (r) (nth r 24))

    0)
