; speech-locale-coverage-matrix.fk -- per-locale speech coverage report.
;
; The aggregate speech reports say what shifted overall. This matrix names the
; locale/pair coverage: baseline readiness, live Metal anchors, seeded closed
; loops, and open/live voice gaps.

(do
    (defn slcm-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn slcm-locale (code baseline self-corpus live-anchor consent ready native-rate oracle-rate status)
        (list "speech-locale-coverage"
              code baseline self-corpus live-anchor consent ready native-rate oracle-rate status))
    (defn slcm-code        (r) (nth r 1))
    (defn slcm-baseline    (r) (nth r 2))
    (defn slcm-self-corpus (r) (nth r 3))
    (defn slcm-live-anchor (r) (nth r 4))
    (defn slcm-consent     (r) (nth r 5))
    (defn slcm-ready       (r) (nth r 6))
    (defn slcm-native-rate (r) (nth r 7))
    (defn slcm-oracle-rate (r) (nth r 8))
    (defn slcm-status      (r) (nth r 9))

    (defn slcm-locales ()
        (list
            (slcm-locale "en" 1 1 1 1 1 100 100 "live-anchor")
            (slcm-locale "de" 1 1 1 1 1 100 100 "live-anchor")
            (slcm-locale "es" 1 1 1 1 1 100 100 "live-anchor")
            (slcm-locale "fr" 1 1 1 1 1 100 100 "live-anchor")
            (slcm-locale "id" 1 1 1 1 1 100 100 "live-anchor")
            (slcm-locale "it" 0 0 1 1 1 100 100 "live-anchor-carrier-only")
            (slcm-locale "zh" 1 0 1 1 1 83 83 "unicode-live-anchor")
            (slcm-locale "ar" 1 0 1 1 1 100 100 "unicode-live-anchor")
            (slcm-locale "sa" 1 0 0 1 1 100 100 "seeded-baseline")
            (slcm-locale "la" 1 0 0 1 1 100 100 "seeded-baseline")
            (slcm-locale "pt-br" 1 1 0 1 1 100 100 "seeded-baseline")
            (slcm-locale "nv" 0 0 0 0 0 0 0 "consent-pending")
            (slcm-locale "chr" 0 0 0 0 0 0 0 "consent-pending")))

    (defn slcm-pair (a b kind native-ok total oracle-ok route)
        (list "speech-locale-pair-coverage"
              a b kind native-ok total (slcm-rate native-ok total)
              oracle-ok (slcm-rate oracle-ok total) route))
    (defn slcm-pair-a           (p) (nth p 1))
    (defn slcm-pair-b           (p) (nth p 2))
    (defn slcm-pair-kind        (p) (nth p 3))
    (defn slcm-pair-native-ok   (p) (nth p 4))
    (defn slcm-pair-total       (p) (nth p 5))
    (defn slcm-pair-native-rate (p) (nth p 6))
    (defn slcm-pair-oracle-ok   (p) (nth p 7))
    (defn slcm-pair-oracle-rate (p) (nth p 8))
    (defn slcm-pair-route       (p) (nth p 9))

    (defn slcm-pairs ()
        (list
            (slcm-pair "en" "de" "live-metal-anchor" 1 1 1 "native")
            (slcm-pair "en" "es" "live-metal-anchor" 1 1 1 "native")
            (slcm-pair "en" "id" "live-metal-anchor" 1 1 1 "native")
            (slcm-pair "en" "fr" "live-metal-anchor" 1 1 1 "native")
            (slcm-pair "en" "it" "live-metal-anchor" 1 1 1 "native")
            (slcm-pair "en" "zh" "unicode-live-anchor" 10 12 10 "native")
            (slcm-pair "en" "ar" "unicode-live-anchor" 12 12 12 "native")
            (slcm-pair "zh" "ar" "seeded-multiseed" 4 4 4 "native")
            (slcm-pair "sa" "la" "seeded-multiseed" 4 4 4 "native")
            (slcm-pair "fr" "id" "seeded-multiseed" 4 4 4 "native")
            (slcm-pair "open" "dictation" "live-open-asr" 0 4 4 "oracle-guide")
            (slcm-pair "sema" "voice" "live-voice" 0 1 0 "oracle-guide")))

    (defn slcm-count-ready (rows)
        (if (eq (len rows) 0) 0
            (add (slcm-ready (head rows)) (slcm-count-ready (tail rows)))))
    (defn slcm-count-live (rows)
        (if (eq (len rows) 0) 0
            (add (slcm-live-anchor (head rows)) (slcm-count-live (tail rows)))))
    (defn slcm-count-consent-pending (rows)
        (if (eq (len rows) 0) 0
            (add (if (eq (slcm-consent (head rows)) 0) 1 0)
                 (slcm-count-consent-pending (tail rows)))))
    (defn slcm-pair-native-count (pairs)
        (if (eq (len pairs) 0) 0
            (add (if (str_eq (slcm-pair-route (head pairs)) "native") 1 0)
                 (slcm-pair-native-count (tail pairs)))))
    (defn slcm-pair-held-count (pairs)
        (if (eq (len pairs) 0) 0
            (add (if (str_eq (slcm-pair-route (head pairs)) "oracle-guide") 1 0)
                 (slcm-pair-held-count (tail pairs)))))

    (defn slcm-report ()
        (do
            (let locales (slcm-locales))
            (let pairs (slcm-pairs))
            (list "speech-locale-coverage-matrix"
                  locales
                  pairs
                  (len locales)
                  (slcm-count-ready locales)
                  (slcm-count-live locales)
                  (slcm-count-consent-pending locales)
                  (len pairs)
                  (slcm-pair-native-count pairs)
                  (slcm-pair-held-count pairs)
                  1
                  0)))

    0)
