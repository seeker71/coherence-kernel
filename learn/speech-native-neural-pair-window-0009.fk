; speech-native-neural-pair-window-0009.fk -- ninth native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; en<->sa. It uses the same Form-native NL/audio baseline and enabled neural
; micro-kernel path, increasing trained neural pair coverage from eight to nine
; without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw9-kind () "speech-native-neural-pair-window-0009")
    (defn snpw9-a () "en")
    (defn snpw9-b () "sa")
    (defn snpw9-meaning () 301)
    (defn snpw9-floor () 50)
    (defn snpw9-max-wer () 25)
    (defn snpw9-meta () (mlap-meta 99 98 14 73))
    (defn snpw9-feat () (list 3200 32 2 2))
    (defn snpw9-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw9-meaning)) locale))

    (defn snpw9-nl (src dst)
        (mlap-nl-sample (snpw9-meaning) src dst
                        (snpw9-tokens src)
                        (snpw9-tokens dst)
                        (snpw9-meaning)
                        0 0 0))

    (defn snpw9-audio (src dst)
        (mlap-audio-sample (snpw9-meaning) src dst
                           (snpw9-tokens dst)
                           (snpw9-tokens dst)
                           (snpw9-feat)
                           (snpw9-meta)
                           0 0 0))

    (defn snpw9-nl-lanes ()
        (list
            (snpw9-nl (snpw9-a) (snpw9-b))
            (snpw9-nl (snpw9-b) (snpw9-a))
            (snpw9-nl (snpw9-a) (snpw9-a))
            (snpw9-nl (snpw9-b) (snpw9-b))))

    (defn snpw9-audio-lanes ()
        (list
            (snpw9-audio (snpw9-a) (snpw9-b))
            (snpw9-audio (snpw9-b) (snpw9-a))
            (snpw9-audio (snpw9-a) (snpw9-a))
            (snpw9-audio (snpw9-b) (snpw9-b))))

    (defn snpw9-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw9-receipt ()
        (do
            (let nl (snpw9-nl-lanes))
            (let audio (snpw9-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw9-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw9-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw9-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw9-neural-rate nl-rate audio-rate boot))
            (list (snpw9-kind)
                  (snpw9-a)
                  (snpw9-b)
                  (snpw9-meaning)
                  1
                  2
                  9
                  18
                  9
                  9
                  before
                  after
                  (if (and (lt before (snpw9-floor)) (ge after (snpw9-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0009-trained-not-open-authority")))

    (defn snpw9-rec-kind            (r) (nth r 0))
    (defn snpw9-rec-a               (r) (nth r 1))
    (defn snpw9-rec-b               (r) (nth r 2))
    (defn snpw9-rec-meaning         (r) (nth r 3))
    (defn snpw9-rec-pair-increment  (r) (nth r 4))
    (defn snpw9-rec-directed-increment (r) (nth r 5))
    (defn snpw9-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw9-rec-cumulative-directed (r) (nth r 7))
    (defn snpw9-rec-epochs          (r) (nth r 8))
    (defn snpw9-rec-params          (r) (nth r 9))
    (defn snpw9-rec-before-rate     (r) (nth r 10))
    (defn snpw9-rec-after-rate      (r) (nth r 11))
    (defn snpw9-rec-shifted         (r) (nth r 12))
    (defn snpw9-rec-form-nl         (r) (nth r 13))
    (defn snpw9-rec-form-audio      (r) (nth r 14))
    (defn snpw9-rec-before-loss     (r) (nth r 15))
    (defn snpw9-rec-after-loss      (r) (nth r 16))
    (defn snpw9-rec-oracle          (r) (nth r 17))
    (defn snpw9-rec-native-form     (r) (nth r 18))
    (defn snpw9-rec-neural          (r) (nth r 19))
    (defn snpw9-rec-open-authority  (r) (nth r 20))
    (defn snpw9-rec-status          (r) (nth r 21))

    0)
