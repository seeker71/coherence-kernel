; speech-oracle-native-backlog.fk -- oracle-held speech gaps.
;
; The aggregate reports show current rates. This cell names the remaining
; oracle-held backlog directly, so "native neural parameters = 0" cannot be
; confused with "no native speech structure exists."

(do
    (defn sonb-rate (ok total)
        (if (eq total 0) 0 (div (mul ok 100) total)))

    (defn sonb-gap (name oracle-ok oracle-total native-ok native-total oracle-wer native-wer priority next target route)
        (list "speech-oracle-native-gap"
              name
              oracle-ok oracle-total (sonb-rate oracle-ok oracle-total)
              native-ok native-total (sonb-rate native-ok native-total)
              oracle-wer native-wer priority next target route))
    (defn sonb-gap-name        (g) (nth g 1))
    (defn sonb-gap-oracle-ok   (g) (nth g 2))
    (defn sonb-gap-oracle-total (g) (nth g 3))
    (defn sonb-gap-oracle-rate (g) (nth g 4))
    (defn sonb-gap-native-ok   (g) (nth g 5))
    (defn sonb-gap-native-total (g) (nth g 6))
    (defn sonb-gap-native-rate (g) (nth g 7))
    (defn sonb-gap-oracle-wer  (g) (nth g 8))
    (defn sonb-gap-native-wer  (g) (nth g 9))
    (defn sonb-gap-priority    (g) (nth g 10))
    (defn sonb-gap-next        (g) (nth g 11))
    (defn sonb-gap-target      (g) (nth g 12))
    (defn sonb-gap-route       (g) (nth g 13))

    (defn sonb-gaps ()
        (list
            (sonb-gap "live-open-dictation"
                      4 4
                      0 4
                      0 100
                      1
                      "train-live-segmented-open-asr-source"
                      "native-segmented-acoustic-learning"
                      "oracle-guide")
            (sonb-gap "sema-live-voice"
                      0 1
                      0 1
                      100 100
                      2
                      "render-and-oracle-next"
                      "text-conditioned-acoustic-vocoder-candidate-search"
                      "oracle-guide")))

    (defn sonb-count-route (rows route)
        (if (eq (len rows) 0) 0
            (add (if (str_eq (sonb-gap-route (head rows)) route) 1 0)
                 (sonb-count-route (tail rows) route))))

    (defn sonb-neural-backlog ()
        (list "speech-neural-weight-backlog"
              0
              2
              "native-open-asr-weight-recipe"
              "native-acoustic-vocoder-weight-recipe"
              "admit-only-consented-local-recipe-data"))

    (defn sonb-body-state ()
        (list "speech-native-body-state"
              6
              4
              14
              0
              1
              "native-form-body-present-neural-weights-not-admitted"))

    (defn sonb-report ()
        (do
            (let gaps (sonb-gaps))
            (list "speech-oracle-native-backlog"
                  gaps
                  (sonb-neural-backlog)
                  (sonb-body-state)
                  (len gaps)
                  (sonb-count-route gaps "oracle-guide")
                  "local-oracle-teaches-until-native-receipts-win"
                  1
                  0)))

    0)
