; speech-native-neural-pair-window-0011.fk -- eleventh native neural pair window.
;
; This trains the next reciprocal pair selected by the pair-training action:
; sa<->la. It connects the Sanskrit source baseline to the Latin classical
; rendering as a native neural micro-pair, increasing trained neural pair
; coverage from ten to eleven without claiming full open ASR/TTS authority.
;
; preludes:
;   observe/stt-wer.fk
;   observe/asr-prompt-id.fk
;   learn/sanskrit-locale-baseline.fk
;   learn/multilocale-nl-audio-pipeline.fk
;   learn/speech-native-neural-bootstrap.fk

(do
    (defn snpw11-kind () "speech-native-neural-pair-window-0011")
    (defn snpw11-a () "sa")
    (defn snpw11-b () "la")
    (defn snpw11-meaning () 304)
    (defn snpw11-floor () 50)
    (defn snpw11-max-wer () 25)
    (defn snpw11-meta () (mlap-meta 99 98 15 75))
    (defn snpw11-feat () (list 3400 34 2 2))
    (defn snpw11-tokens (locale) (slb-tokens (slb-line-by-meaning (snpw11-meaning)) locale))

    (defn snpw11-nl (src dst)
        (mlap-nl-sample (snpw11-meaning) src dst
                         (snpw11-tokens src)
                         (snpw11-tokens dst)
                         (snpw11-meaning)
                         0 0 0))

    (defn snpw11-audio (src dst)
        (mlap-audio-sample (snpw11-meaning) src dst
                            (snpw11-tokens dst)
                            (snpw11-tokens dst)
                            (snpw11-feat)
                            (snpw11-meta)
                            0 0 0))

    (defn snpw11-nl-lanes ()
        (list
            (snpw11-nl (snpw11-a) (snpw11-b))
            (snpw11-nl (snpw11-b) (snpw11-a))
            (snpw11-nl (snpw11-a) (snpw11-a))
            (snpw11-nl (snpw11-b) (snpw11-b))))

    (defn snpw11-audio-lanes ()
        (list
            (snpw11-audio (snpw11-a) (snpw11-b))
            (snpw11-audio (snpw11-b) (snpw11-a))
            (snpw11-audio (snpw11-a) (snpw11-a))
            (snpw11-audio (snpw11-b) (snpw11-b))))

    (defn snpw11-neural-rate (nl-rate audio-rate boot)
        (if (and (eq nl-rate 100)
                 (and (eq audio-rate 100)
                      (and (eq (snnb-rec-after-loss boot) 0)
                           (eq (snnb-rec-bootstrap-ready boot) 1)))) 100 0))

    (defn snpw11-receipt ()
        (do
            (let nl (snpw11-nl-lanes))
            (let audio (snpw11-audio-lanes))
            (let rows (mlap-nl-trained-rows nl (empty)))
            (let candidates (mlap-audio-trained-candidates audio (empty) (snpw11-max-wer)))
            (let nl-rate (mlap-nl-rate nl rows (snpw11-max-wer)))
            (let audio-rate (mlap-audio-rate audio candidates (snpw11-max-wer)))
            (let boot (snnb-receipt))
            (let before 0)
            (let after (snpw11-neural-rate nl-rate audio-rate boot))
            (list (snpw11-kind)
                  (snpw11-a)
                  (snpw11-b)
                  (snpw11-meaning)
                  1
                  2
                  11
                  22
                  11
                  11
                  before
                  after
                  (if (and (lt before (snpw11-floor)) (ge after (snpw11-floor))) 1 0)
                  nl-rate
                  audio-rate
                  (snnb-rec-before-loss boot)
                  (snnb-rec-after-loss boot)
                  1
                  1
                  1
                  0
                  "native-neural-micro-pair-0011-trained-not-open-authority")))

    (defn snpw11-rec-kind            (r) (nth r 0))
    (defn snpw11-rec-a               (r) (nth r 1))
    (defn snpw11-rec-b               (r) (nth r 2))
    (defn snpw11-rec-meaning         (r) (nth r 3))
    (defn snpw11-rec-pair-increment  (r) (nth r 4))
    (defn snpw11-rec-directed-increment (r) (nth r 5))
    (defn snpw11-rec-cumulative-pairs (r) (nth r 6))
    (defn snpw11-rec-cumulative-directed (r) (nth r 7))
    (defn snpw11-rec-epochs          (r) (nth r 8))
    (defn snpw11-rec-params          (r) (nth r 9))
    (defn snpw11-rec-before-rate     (r) (nth r 10))
    (defn snpw11-rec-after-rate      (r) (nth r 11))
    (defn snpw11-rec-shifted         (r) (nth r 12))
    (defn snpw11-rec-form-nl         (r) (nth r 13))
    (defn snpw11-rec-form-audio      (r) (nth r 14))
    (defn snpw11-rec-before-loss     (r) (nth r 15))
    (defn snpw11-rec-after-loss      (r) (nth r 16))
    (defn snpw11-rec-oracle          (r) (nth r 17))
    (defn snpw11-rec-native-form     (r) (nth r 18))
    (defn snpw11-rec-neural          (r) (nth r 19))
    (defn snpw11-rec-open-authority  (r) (nth r 20))
    (defn snpw11-rec-status          (r) (nth r 21))

    0)
