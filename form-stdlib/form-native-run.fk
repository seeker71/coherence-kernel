; form-native-run.fk — the form-cli agent runner as a PURE FORM recipe.
;
; preludes: form-stdlib/core.fk
;
; This is the runner the kernel runs — NOT hand-written emitted C. It composes the
; kernel's own primitives: host-io builtins (host-exec / host-read / host-write, the
; host-kernel.form driver layer) for the oracle call and tools, and the string
; builtins (str_find / substring / str_len) to parse the oracle's Hermes tool-call.
; The loop is Form recursion. No C, no Python — the body is Form, the kernel is the
; native runtime. Supersedes the emitted-C runner (form-cli-run.fk fcrun-emit).
;
; The oracle is a host command (ollama run qwen2.5:72b — local, sovereign; or
; claude -p). Tools: bash / read_file / write_file / search, each a tool-channel
; host:exec / host:file family. The reply is parsed tolerantly (tagged or bare JSON).
;
; Witness: scripts/form_native_run.sh (the kernel runs this recipe end to end).

; ── Hermes tool-call field extractor: "key":"value" -> value ("" if missing) ──
(defn fnr-jf (json key)
    (do
        (let patt (str_concat "\"" (str_concat key "\"")))
        (let ki (str_find json patt 0))
        (if (lt ki 0)
            ""
            (do
                (let colon (str_find json ":" (add ki (str_len patt))))
                (let q1 (str_find json "\"" (add colon 1)))
                (let q2 (str_find json "\"" (add q1 1)))
                (if (lt q2 0) "" (substring json (add q1 1) q2))))))

; ── the system prompt (Hermes tool protocol) ──
(defn fnr-sys ()
    "You are form-cli, a coding agent. Tools (reply with ONE line of JSON to use one): {\"name\":\"bash\",\"arguments\":{\"cmd\":\"...\"}} | {\"name\":\"read_file\",\"arguments\":{\"path\":\"...\"}} | {\"name\":\"write_file\",\"arguments\":{\"path\":\"...\",\"content\":\"...\"}} | {\"name\":\"edit\",\"arguments\":{\"path\":\"...\",\"find\":\"...\",\"replace\":\"...\"}} | {\"name\":\"search\",\"arguments\":{\"pattern\":\"...\"}} | {\"name\":\"glob\",\"arguments\":{\"pattern\":\"*.fk\"}}. After each tool you receive an OBSERVATION. When the task is done, reply with your final answer as plain text (no JSON).\n\n")

; ── call the oracle: pipe the prompt to its stdin, AGENT-CLI-ONLY ──
; The prompt goes to the oracle's stdin in memory (host-exec's 2nd arg) — no temp
; file, no writable /tmp, so this runs unchanged on Android too. The oracle runs with
; ANTHROPIC_API_KEY stripped (env -u): the remote is an agent CLI on its flat-rate
; subscription login, NEVER a metered API key — a stray key in the environment can't
; silently bill per-token. (env -u UNSETS it; ANTHROPIC_API_KEY= would leave an empty
; key that still wins precedence and fails auth.) Same law as ask+'s fcap-escalate.
(defn fnr-oracle (oracle prompt)
    (host-exec (str_concat "env -u ANTHROPIC_API_KEY " (str_concat oracle " 2>/dev/null")) prompt))

; ── structured edit: replace the FIRST occurrence of `find` with `repl` in s (pure Form, four-way) ──
(defn fnr-replace (s find repl)
    (do
        (let i (str_find s find 0))
        (if (lt i 0) s
            (str_concat (substring s 0 i)
                (str_concat repl (substring s (add i (str_len find)) (str_len s)))))))

; ── execute a parsed tool-call (tc is the reply text carrying the JSON) ──
(defn fnr-exec (name tc)
    (if (str_eq name "bash")
        (host-exec (fnr-jf tc "cmd"))
        (if (str_eq name "read_file")
            (host-read (fnr-jf tc "path"))
            (if (str_eq name "write_file")
                (do (host-write (fnr-jf tc "path") (fnr-jf tc "content"))
                    (str_concat "wrote " (fnr-jf tc "path")))
                (if (str_eq name "search")
                    (host-exec (str_concat "grep -rn -- '" (str_concat (fnr-jf tc "pattern") "' . 2>/dev/null | head -40")))
                    (if (str_eq name "edit")
                        (do (host-write (fnr-jf tc "path")
                                (fnr-replace (host-read (fnr-jf tc "path")) (fnr-jf tc "find") (fnr-jf tc "replace")))
                            (str_concat "edited " (fnr-jf tc "path")))
                        (if (str_eq name "glob")
                            (host-exec (str_concat "find . -name '" (str_concat (fnr-jf tc "pattern") "' 2>/dev/null | head -40")))
                            "(unknown tool)")))))))

; ── is this reply a tool-call? (carries both "name" and "arguments") ──
(defn fnr-toolcall? (reply)
    (if (and (ge (str_find reply "\"name\"" 0) 0) (ge (str_find reply "\"arguments\"" 0) 0)) 1 0))

; ── the loop: recurse over (transcript, step) until a final answer or max. The
;    `guide` is the runner's self-guidance — the corpus-trained tool predictor's
;    likely-tools hint for this task (form-cli-predict.fk, computed by the
;    carrier), prepended to the system prompt so the local model stops omitting
;    tools it learned to need (e.g. Bash). Empty guide = the unguided runner. ──
(defn fnr-step (oracle guide transcript step max)
    (if (ge step max)
        (str_concat "(reached max-steps)\n" transcript)
        (do
            (let prompt (str_concat (fnr-sys) (str_concat guide (str_concat transcript "\nYour reply:"))))
            (let reply (fnr-oracle oracle prompt))
            (if (eq (fnr-toolcall? reply) 0)
                reply
                (do
                    (let nm (fnr-jf reply "name"))
                    (let obs (fnr-exec nm reply))
                    (fnr-step oracle guide
                        (str_concat transcript
                            (str_concat "\nACTION " (str_concat (int_to_str step)
                                (str_concat ": " (str_concat reply (str_concat "\nOBSERVATION: " obs))))))
                        (add step 1) max))))))

; ── the entry: run a task. returns the final answer (or the capped transcript). ──
(defn fnr-run (task oracle max)
    (fnr-step oracle "" (str_concat "TASK: " task) 1 max))
; ── self-guided entry: the runner runs with the predictor's likely-tools hint. ──
(defn fnr-run-guided (task oracle max guide)
    (fnr-step oracle guide (str_concat "TASK: " task) 1 max))

; ── FRONTIER-IN-THE-LOOP: a step's reply is usable if it is a tool-call OR a substantive final
;    answer; a garbled/empty local reply (the weak-model failure we saw) is not. ──
(defn fnr-usable? (reply)
    (if (eq (fnr-toolcall? reply) 1) 1 (if (gt (str_len reply) 40) 1 0)))

; tiered step: try the LOCAL oracle; if its reply is not usable, escalate THIS step to the REMOTE
; (frontier) oracle — local-first quality, frontier when local can't, learning toward sovereignty.
(defn fnr-step-tiered (local remote guide transcript step max)
    (if (ge step max)
        (str_concat "(reached max-steps)\n" transcript)
        (do
            (let prompt (str_concat (fnr-sys) (str_concat guide (str_concat transcript "\nYour reply:"))))
            (let lr (fnr-oracle local prompt))
            (let reply (if (eq (fnr-usable? lr) 1) lr (fnr-oracle remote prompt)))
            (if (eq (fnr-toolcall? reply) 0)
                reply
                (do
                    (let nm (fnr-jf reply "name"))
                    (let obs (fnr-exec nm reply))
                    (fnr-step-tiered local remote guide
                        (str_concat transcript
                            (str_concat "\nACTION " (str_concat (int_to_str step)
                                (str_concat ": " (str_concat reply (str_concat "\nOBSERVATION: " obs))))))
                        (add step 1) max))))))

; ── SESSION MEMORY (logs now, substrate later): read recent session context, persist this run. ──
(defn fnr-recent ()
    (host-exec "tail -c 1500 $HOME/.coherence-network/form-cli-sessions.log 2>/dev/null"))
(defn fnr-persist (transcript)
    ; pipe the transcript to the appending shell via stdin (host-exec's 2nd arg) —
    ; no /tmp hop, so this persists on Android too, where /tmp does not exist.
    (host-exec "cat >> $HOME/.coherence-network/form-cli-sessions.log; printf '\\n=== /turn ===\\n' >> $HOME/.coherence-network/form-cli-sessions.log" transcript))

; tiered entry WITH memory: prepend recent session context, run local-first+escalating, persist the run
; (the persisted transcript is both cross-turn memory AND a training corpus of real agent work).
(defn fnr-run-tiered (task local remote max)
    (do
        (let mem (fnr-recent))
        (let guide (if (gt (str_len mem) 0) (str_concat "RECENT SESSION (memory):\n" (str_concat mem "\n\n")) ""))
        (let result (fnr-step-tiered local remote guide (str_concat "TASK: " task) 1 max))
        (do (fnr-persist result) result)))
