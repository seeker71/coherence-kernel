; hati-os-targets.fk - host OS target and distribution catalog for Hati-OS.
;
; The fourth kernel has one Form surface and many host implementations. This
; catalog keeps target triples, per-OS resource implementations, and public
; binary download coordinates visible to cells and recipes.

(do
    (defn hos-target (name os arch binary-format package-format launcher clang-triple assembly-surface form-native-object form-native-executable jit-oracle jit-runtime jit-model)
        (list name os arch binary-format package-format launcher clang-triple assembly-surface form-native-object form-native-executable jit-oracle jit-runtime jit-model))
    (defn hos-target-name (target) (nth target 0))
    (defn hos-target-os (target) (nth target 1))
    (defn hos-target-arch (target) (nth target 2))
    (defn hos-target-binary-format (target) (nth target 3))
    (defn hos-target-package-format (target) (nth target 4))
    (defn hos-target-launcher (target) (nth target 5))
    (defn hos-target-clang-triple (target) (nth target 6))
    (defn hos-target-assembly-surface (target) (nth target 7))
    (defn hos-target-form-native-object (target) (nth target 8))
    (defn hos-target-form-native-executable (target) (nth target 9))
    (defn hos-target-jit-oracle (target) (nth target 10))
    (defn hos-target-jit-runtime (target) (nth target 11))
    (defn hos-target-jit-model (target) (nth target 12))
    (defn hos-empty-target () (hos-target "" "" "" "" "" "" "" "" "" "" "" "" ""))

    (defn hos-targets ()
        (list
            (hos-target "macos-arm64" "macos" "arm64" "mach-o" "tar.zst" "hati-os" "arm64-apple-macosx" "mach-o-relocatable+arm64-asm" "form-macho" "form-macho+ld" "clang" "form-native-arm64-assembler" "clang-oracle-sampled-form-native-recipe")
            (hos-target "android-arm64" "android" "arm64" "elf" "tar.zst" "hati-os" "aarch64-linux-android" "elf-relocatable+aarch64-asm" "form-elf" "form-elf-exec" "clang" "form-native-arm64-assembler" "clang-oracle-sampled-form-native-recipe")
            (hos-target "windows-arm64" "windows" "arm64" "pe-coff" "zip" "hati-os.exe" "aarch64-pc-windows-msvc" "pe-coff+arm64-asm" "form-pe-coff-arm64" "form-pe-arm64-exec-pending" "clang" "form-native-arm64-assembler" "clang-oracle-sampled-form-native-recipe")
            (hos-target "windows-amd64" "windows" "amd64" "pe-coff" "zip" "hati-os.exe" "x86_64-pc-windows-msvc" "pe-coff+x64-asm" "form-pe-coff" "form-pe-coff+dll-bootstrap-exe" "optional-clang-llvm-build-witness" "fkwu-self-jit-no-runtime-toolchain" "form-authored-fkc-nat-expr-hot-flip")
            (hos-target "windows-x86_64" "windows" "x86_64" "pe-coff" "zip" "hati-os.exe" "x86_64-pc-windows-msvc" "pe-coff+x64-asm" "form-pe-coff" "form-pe-coff+dll-bootstrap-exe" "optional-clang-llvm-build-witness" "fkwu-self-jit-no-runtime-toolchain" "form-authored-fkc-nat-expr-hot-flip")))

    (defn hos-impl (target protocol capability implementation floor north-star)
        (list target protocol capability implementation floor north-star))
    (defn hos-impl-target (impl) (nth impl 0))
    (defn hos-impl-protocol (impl) (nth impl 1))
    (defn hos-impl-capability (impl) (nth impl 2))
    (defn hos-impl-implementation (impl) (nth impl 3))
    (defn hos-impl-floor (impl) (nth impl 4))
    (defn hos-impl-north-star (impl) (nth impl 5))
    (defn hos-empty-impl () (hos-impl "" "" "" "" "" ""))

    (defn hos-implementations ()
        (list
            (hos-impl "macos-arm64" "host:process" "cap.host.process" "libproc+sysctl+proc_pidinfo" "ps/top carrier receipt" "typed direct process snapshot")
            (hos-impl "macos-arm64" "host:usage" "cap.host.usage" "host_statistics64+task_info+getifaddrs+IOKit" "vm_stat/iostat carrier receipt" "typed direct utilization sample")
            (hos-impl "macos-arm64" "audio:pcm16" "cap.audio.sample" "CoreAudio+AVFoundation" "say/rec carrier receipt" "native PCM stream")
            (hos-impl "macos-arm64" "video:rgba-time" "cap.video.frame" "ScreenCaptureKit+AVFoundation" "screencapture/ffmpeg carrier receipt" "native frame stream")
            (hos-impl "macos-arm64" "sensor:signal" "cap.sensor.read" "CoreMotion+CoreLocation-when-present" "inventory receipt" "typed sensor stream")
            (hos-impl "macos-arm64" "gpu:compute" "cap.compute.gpu" "Metal+IOReport+powermetrics" "GPU catalog row and dashboard unavailable/sample gap" "native Metal dispatch and pressure receipt")
            (hos-impl "macos-arm64" "dsp:signal" "cap.compute.dsp" "Accelerate+AudioToolbox" "CPU/Accelerate signal-kernel floor" "hardware DSP/ANE signal receipt when exposed")
            (hos-impl "macos-arm64" "mlx:array" "cap.compute.mlx" "MLX+Metal" "MLX capability catalog row" "native MLX array execution receipt")
            (hos-impl "macos-arm64" "host:file" "cap.host.file" "posix-open+read+write+stat" "read_file/write_file host-io receipt" "typed byte-range file stream")
            (hos-impl "macos-arm64" "http:request" "cap.network.http" "NSURLSession+socket_connect" "http-client socket floor receipt" "native HTTP over socket host-io")
            (hos-impl "android-arm64" "host:process" "cap.host.process" "procfs+ActivityManager-permission-gated" "toybox ps carrier receipt" "typed app-visible process snapshot")
            (hos-impl "android-arm64" "host:usage" "cap.host.usage" "procfs+BatteryManager+Debug+SensorManager" "dumpsys/top carrier receipt" "typed utilization and pressure sample")
            (hos-impl "android-arm64" "audio:pcm16" "cap.audio.sample" "AAudio+AudioRecord+AudioTrack" "intent/media carrier receipt" "native PCM stream")
            (hos-impl "android-arm64" "video:rgba-time" "cap.video.frame" "Camera2+MediaProjection-permission-gated" "camera/screenshot carrier receipt" "native camera and screen frame stream")
            (hos-impl "android-arm64" "sensor:signal" "cap.sensor.read" "SensorManager+LocationManager+GNSS-permission-gated" "inventory receipt" "typed sensor and GPS stream")
            (hos-impl "android-arm64" "gpu:compute" "cap.compute.gpu" "Vulkan+OpenGL-ES+GPU-counter-when-available" "GPU catalog row and dashboard unavailable/sample gap" "native GPU dispatch and pressure receipt")
            (hos-impl "android-arm64" "dsp:signal" "cap.compute.dsp" "NNAPI+vendor-DSP-delegates" "NNAPI/DSP capability catalog row" "native DSP/NPU signal receipt")
            (hos-impl "android-arm64" "mlx:array" "cap.compute.mlx" "unsupported-on-android" "explicit unsupported row" "route to Android GPU/NNAPI equivalent without pretending MLX exists")
            (hos-impl "android-arm64" "host:file" "cap.host.file" "java.io+ContentResolver+SAF" "read_file/write_file host-io receipt" "typed app-sandbox file stream")
            (hos-impl "android-arm64" "http:request" "cap.network.http" "HttpURLConnection+socket_connect" "http-client socket floor receipt" "native HTTP over socket host-io")
            (hos-impl "windows-arm64" "host:process" "cap.host.process" "PowerShell+CIM+Get-Process" "Windows-on-ARM process carrier receipt pending" "typed direct process snapshot")
            (hos-impl "windows-arm64" "host:usage" "cap.host.usage" "CIM+PerformanceCounter+DirectML" "Windows-on-ARM utilization carrier receipt pending" "typed utilization and accelerator pressure sample")
            (hos-impl "windows-arm64" "audio:pcm16" "cap.audio.sample" "WASAPI+MediaFoundation" "device inventory carrier receipt pending" "native PCM stream")
            (hos-impl "windows-arm64" "video:rgba-time" "cap.video.frame" "Windows.Graphics.Capture+MediaFoundation" "screen/camera inventory carrier receipt pending" "native camera and screen frame stream")
            (hos-impl "windows-arm64" "sensor:signal" "cap.sensor.read" "Windows.Devices.Sensors+Location-when-present" "inventory receipt pending" "typed sensor and location stream")
            (hos-impl "windows-arm64" "gpu:compute" "cap.compute.gpu" "DirectML+D3D12+Vulkan" "Windows-on-ARM accelerator capability catalog row" "native DirectML/D3D12/Vulkan dispatch and pressure receipt")
            (hos-impl "windows-arm64" "dsp:signal" "cap.compute.dsp" "DirectML+WASAPI-DSP-when-exposed" "DirectML/DSP capability catalog row" "native Windows ML/DSP signal receipt")
            (hos-impl "windows-arm64" "mlx:array" "cap.compute.mlx" "unsupported-on-windows" "explicit unsupported row; DirectML equivalent available" "route to Windows DirectML/Vulkan without pretending MLX exists")
            (hos-impl "windows-arm64" "host:file" "cap.host.file" "CreateFile+ReadFile+WriteFile" "read_file/write_file host-io receipt pending" "typed byte-range file stream")
            (hos-impl "windows-arm64" "http:request" "cap.network.http" "WinHTTP+socket_connect" "http-client socket floor receipt pending" "native HTTP over socket host-io")
            (hos-impl "windows-amd64" "host:process" "cap.host.process" "PowerShell+CIM+Get-Process" "Get-Process/CIM carrier receipt" "typed direct process snapshot")
            (hos-impl "windows-amd64" "host:usage" "cap.host.usage" "CIM+PerformanceCounter+nvidia-smi" "Windows 11 + RTX 4070 CUDA driver receipt" "typed utilization and GPU pressure sample")
            (hos-impl "windows-amd64" "audio:pcm16" "cap.audio.sample" "WASAPI+MediaFoundation" "device inventory carrier receipt" "native PCM stream")
            (hos-impl "windows-amd64" "video:rgba-time" "cap.video.frame" "Windows.Graphics.Capture+MediaFoundation" "screen/camera inventory carrier receipt" "native camera and screen frame stream")
            (hos-impl "windows-amd64" "sensor:signal" "cap.sensor.read" "Windows.Devices.Sensors+Location-when-present" "inventory receipt" "typed sensor and location stream")
            (hos-impl "windows-amd64" "gpu:compute" "cap.compute.gpu" "NVIDIA-CUDA-driver+DirectML+Vulkan" "RTX 4070 nvidia-smi CUDA 13.1 driver receipt" "native CUDA/DirectML/Vulkan dispatch and pressure receipt")
            (hos-impl "windows-amd64" "dsp:signal" "cap.compute.dsp" "DirectML+WASAPI-DSP-when-exposed" "DirectML/DSP capability catalog row" "native Windows ML/DSP signal receipt")
            (hos-impl "windows-amd64" "mlx:array" "cap.compute.mlx" "unsupported-on-windows" "explicit unsupported row; CUDA/DirectML equivalent available" "route to Windows CUDA/DirectML/Vulkan without pretending MLX exists")
            (hos-impl "windows-x86_64" "host:process" "cap.host.process" "PowerShell+CIM+Get-Process" "Get-Process/CIM carrier receipt" "typed direct process snapshot")
            (hos-impl "windows-x86_64" "host:usage" "cap.host.usage" "CIM+PerformanceCounter+nvidia-smi" "Windows 11 + RTX 4070 CUDA driver receipt" "typed utilization and GPU pressure sample")
            (hos-impl "windows-x86_64" "audio:pcm16" "cap.audio.sample" "WASAPI+MediaFoundation" "device inventory carrier receipt" "native PCM stream")
            (hos-impl "windows-x86_64" "video:rgba-time" "cap.video.frame" "Windows.Graphics.Capture+MediaFoundation" "screen/camera inventory carrier receipt" "native camera and screen frame stream")
            (hos-impl "windows-x86_64" "sensor:signal" "cap.sensor.read" "Windows.Devices.Sensors+Location-when-present" "inventory receipt" "typed sensor and location stream")
            (hos-impl "windows-x86_64" "gpu:compute" "cap.compute.gpu" "NVIDIA-CUDA-driver+DirectML+Vulkan" "RTX 4070 nvidia-smi CUDA 13.1 driver receipt" "native CUDA/DirectML/Vulkan dispatch and pressure receipt")
            (hos-impl "windows-x86_64" "dsp:signal" "cap.compute.dsp" "DirectML+WASAPI-DSP-when-exposed" "DirectML/DSP capability catalog row" "native Windows ML/DSP signal receipt")
            (hos-impl "windows-x86_64" "mlx:array" "cap.compute.mlx" "unsupported-on-windows" "explicit unsupported row; CUDA/DirectML equivalent available" "route to Windows CUDA/DirectML/Vulkan without pretending MLX exists")))

    (defn hos-artifact (target kind url format checksum status)
        (list target kind url format checksum status))
    (defn hos-artifact-target (artifact) (nth artifact 0))
    (defn hos-artifact-kind (artifact) (nth artifact 1))
    (defn hos-artifact-url (artifact) (nth artifact 2))
    (defn hos-artifact-format (artifact) (nth artifact 3))
    (defn hos-artifact-checksum (artifact) (nth artifact 4))
    (defn hos-artifact-status (artifact) (nth artifact 5))
    (defn hos-empty-artifact () (hos-artifact "" "" "" "" "" ""))

    (defn hos-artifacts ()
        (list
            (hos-artifact "macos-arm64" "native-binary" "https://hati.earth/downloads/hati-os/macos/arm64/hati-os-macos-arm64.tar.zst" "tar.zst" "sha256" "public-asset-door")
            (hos-artifact "android-arm64" "native-kernel-package" "https://hati.earth/downloads/hati-os/android/arm64/hati-os-android-arm64.tar.zst" "tar.zst" "sha256" "public-asset-door")
            (hos-artifact "windows-arm64" "native-kernel-package" "https://hati.earth/downloads/hati-os/windows/arm64/hati-os-windows-arm64.zip" "zip" "sha256" "target-floor-door")
            (hos-artifact "windows-amd64" "native-kernel-package" "https://hati.earth/downloads/hati-os/windows/amd64/hati-os-windows-amd64.zip" "zip" "sha256" "target-floor-door")
            (hos-artifact "windows-x86_64" "native-kernel-package" "https://hati.earth/downloads/hati-os/windows/x86_64/hati-os-windows-x86_64.zip" "zip" "sha256" "target-floor-door")))

    (defn hos-find-target (name rows)
        (if (eq (len rows) 0) (hos-empty-target)
            (if (str_eq (hos-target-name (head rows)) name)
                (head rows)
                (hos-find-target name (tail rows)))))
    (defn hos-target-by-name (name) (hos-find-target name (hos-targets)))

    (defn hos-find-impl (target protocol rows)
        (if (eq (len rows) 0) (hos-empty-impl)
            (if (str_eq (hos-impl-target (head rows)) target)
                (if (str_eq (hos-impl-protocol (head rows)) protocol)
                    (head rows)
                    (hos-find-impl target protocol (tail rows)))
                (hos-find-impl target protocol (tail rows)))))
    (defn hos-impl-for (target protocol) (hos-find-impl target protocol (hos-implementations)))

    (defn hos-find-artifact (target rows)
        (if (eq (len rows) 0) (hos-empty-artifact)
            (if (str_eq (hos-artifact-target (head rows)) target)
                (head rows)
                (hos-find-artifact target (tail rows)))))
    (defn hos-artifact-for (target) (hos-find-artifact target (hos-artifacts)))
    (defn hos-download-url (target) (hos-artifact-url (hos-artifact-for target)))

    0)
