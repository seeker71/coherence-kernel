  "casts_note": "Intrinsic casting rows — spec specs/form-intrinsic-casting.md. Each category is one primitive cast pair; `from`/`to` name the TYPE-* typed-token rows; `reverse` names the inverse row when the round-trip law R(C(x)) node_eq x holds for every valid x; `lossy` true means information can drop; `total` false means the cast can fail and a failed cast realizes to nothing (core-axioms third state), never 0 and never a thrown error. Dialect implicit-coercion rows live with each dialect under `coercions`; lifters consult them and emit explicit CAST nodes — kernels never coerce.",
  "casts": {
    "category_type": 98,
    "name_prefix": "CAST",
    "categories": [
      {"name": "TYPE-BOOL",    "inst": 1, "note": "typed-token cell: the bool view over a 0/1 int cell"},
      {"name": "TYPE-INT",     "inst": 2, "note": "typed-token cell: int"},
      {"name": "TYPE-FLOAT",   "inst": 3, "note": "typed-token cell: float64"},
      {"name": "TYPE-STRING",  "inst": 4, "note": "typed-token cell: string"},
      {"name": "TYPE-NOTHING", "inst": 5, "note": "typed-token cell: the third state"},
      {"name": "BOOL-INT",     "inst": 10, "from": "TYPE-BOOL",   "to": "TYPE-INT",    "lossy": false, "reverse": "INT-BOOL",   "total": true,  "note": "0/1 identity — bool IS a Blueprint view over an int cell"},
      {"name": "INT-BOOL",     "inst": 11, "from": "TYPE-INT",    "to": "TYPE-BOOL",   "lossy": true,  "reverse": null,         "total": true,  "note": "truthiness: 0 -> false, anything else -> true"},
      {"name": "INT-FLOAT",    "inst": 12, "from": "TYPE-INT",    "to": "TYPE-FLOAT",  "lossy": false, "reverse": "FLOAT-INT",  "total": true},
      {"name": "FLOAT-INT",    "inst": 13, "from": "TYPE-FLOAT",  "to": "TYPE-INT",    "lossy": true,  "reverse": null,         "total": true,  "note": "trunc toward zero"},
      {"name": "INT-STRING",   "inst": 14, "from": "TYPE-INT",    "to": "TYPE-STRING", "lossy": false, "reverse": "STRING-INT", "total": true},
      {"name": "STRING-INT",   "inst": 15, "from": "TYPE-STRING", "to": "TYPE-INT",    "lossy": true,  "reverse": null,         "total": false, "note": "Form-validated decimal parse; nothing on non-numeric"},
      {"name": "FLOAT-STRING", "inst": 16, "from": "TYPE-FLOAT",  "to": "TYPE-STRING", "lossy": true,  "reverse": null,         "total": true,  "note": "canonical Form-side formatter — 6 fractional digits, trailing zeros stripped, at least one kept"},
      {"name": "STRING-FLOAT", "inst": 17, "from": "TYPE-STRING", "to": "TYPE-FLOAT",  "lossy": true,  "reverse": null,         "total": false, "note": "pure-Form decimal parse over the str_to_int leaf (no exponent form yet); nothing on non-numeric"},
      {"name": "BOOL-STRING",  "inst": 18, "from": "TYPE-BOOL",   "to": "TYPE-STRING", "lossy": false, "reverse": "STRING-BOOL","total": true,  "note": "canonical true/false — dialect display forms are lift-time coercion data"},
      {"name": "STRING-BOOL",  "inst": 19, "from": "TYPE-STRING", "to": "TYPE-BOOL",   "lossy": false, "reverse": "BOOL-STRING","total": false, "note": "parse true/false; nothing otherwise"},
      {"name": "STRING-BOOL-TRUTHY", "inst": 20, "from": "TYPE-STRING", "to": "TYPE-BOOL", "lossy": true, "reverse": null,      "total": true,  "note": "dialect truthiness: empty -> false, anything else -> true"}
    ]
  },
