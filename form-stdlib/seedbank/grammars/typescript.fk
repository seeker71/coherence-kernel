; grammars/typescript.fk — TypeScript parser (file-header subset)
;
; Compost target: form/form-kernel-ts/src/lang-typescript.ts
; (1887 lines of TypeScript bootstrap).
;
; Subset supported (the patterns most common at the top of .ts/.tsx
; files in this repo's web/ and form/form-kernel-ts/ trees):
;   - import { A, B } from 'module';
;   - import X from 'module';
;   - import * as X from 'module';
;   - export const NAME = ...;
;   - export function NAME(...) { ... }
;   - export class NAME { ... }
;   - const/let/var NAME = ...;
;   - function NAME(...) { ... }
;   - class NAME { ... }
;   - // line comments and /* block comments */
;
; Skipped (subsequent breaths): full expression grammar, body parsing,
; type annotations, generics, decorators, JSX (.tsx), async/await,
; destructuring patterns.

(do

    ;; --- shared line helpers --------------------------------------

    (defn substr (s a b)
        (if (ge a b) ""
            (str_concat (char_at s a) (substr s (add a 1) b))))

    (defn lines-from-source (s)
        (lines-loop s 0 0 1 (empty)))

    (defn lines-loop (s i start line acc)
        (if (eq i (str_len s))
            (if (gt i start)
                (reverse-acc (cons (list (substr s start i) line) acc))
                (reverse-acc acc))
            (if (eq (ord (char_at s i)) 10)
                (lines-loop s (add i 1) (add i 1) (add line 1)
                            (cons (list (substr s start i) line) acc))
                (lines-loop s (add i 1) start line acc))))

    (defn reverse-acc (xs) (foldl rev-step (empty) xs))
    (defn rev-step (acc x) (cons x acc))

    (defn line-text (ln) (head ln))
    (defn line-num  (ln) (head (tail ln)))

    (defn is-ws-cp (cp)
        (or (eq cp 32) (or (eq cp 9) (or (eq cp 10) (eq cp 13)))))

    (defn trim-leading-ws (s)
        (if (eq (str_len s) 0) s
            (if (is-ws-cp (ord (char_at s 0)))
                (trim-leading-ws (substr s 1 (str_len s)))
                s)))

    (defn trim-trailing-ws (s)
        (if (eq (str_len s) 0) s
            (if (is-ws-cp (ord (char_at s (sub (str_len s) 1))))
                (trim-trailing-ws (substr s 0 (sub (str_len s) 1)))
                s)))

    (defn trim (s) (trim-leading-ws (trim-trailing-ws s)))

    (defn is-blank? (text) (eq (str_len (trim text)) 0))

    (defn is-line-comment? (text)
        (do
            (let trimmed (trim-leading-ws text))
            (and (ge (str_len trimmed) 2)
                 (and (eq (ord (char_at trimmed 0)) 47)
                      (eq (ord (char_at trimmed 1)) 47)))))

    (defn starts-with? (text prefix)
        (if (lt (str_len text) (str_len prefix)) false
            (str_eq (substr text 0 (str_len prefix)) prefix)))

    (defn starts-with-keyword? (text kw)
        (and (starts-with? text kw)
             (and (gt (str_len text) (str_len kw))
                  (is-ws-cp (ord (char_at text (str_len kw)))))))

    (defn find-from (s needle start)
        (find-loop s needle start))

    (defn find-loop (s needle i)
        (if (gt (add i (str_len needle)) (str_len s)) (sub 0 1)
            (if (str_eq (substr s i (add i (str_len needle))) needle) i
                (find-loop s needle (add i 1)))))

    ;; --- statement dispatch --------------------------------------

    (defn parse-import (text line-no source-path)
        ;; Extract module name from quotes; the rest goes as the "names" string.
        (do
            (let quote-pos (find-quote text 0))
            (let after (add quote-pos 1))
            (let end (find-quote text after))
            (let module (if (and (ge quote-pos 0) (ge end 0))
                            (substr text after end)
                            ""))
            (let names-part (trim (substr text 6 (if (ge quote-pos 0) quote-pos (str_len text)))))
            (intern_node_at TS-IMPORT
                            (list (intern_trivial_string names-part)
                                  (intern_trivial_string module))
                            source-path line-no 1)))

    (defn find-quote (s i)
        ;; Find first single or double quote.
        (if (eq i (str_len s)) (sub 0 1)
            (do
                (let cp (ord (char_at s i)))
                (if (or (eq cp 34) (eq cp 39)) i
                    (find-quote s (add i 1))))))

    (defn parse-function-decl (text line-no source-path)
        (do
            (let after (trim (substr text 8 (str_len text))))   ; strip "function"
            (let open-paren (find-from after "(" 0))
            (let close-paren (find-from after ")" 0))
            (if (or (lt open-paren 0) (lt close-paren 0))
                (intern_node_at TS-FUNCTION-DECL
                                (list (intern_trivial_string after)
                                      (intern_trivial_string ""))
                                source-path line-no 1)
                (intern_node_at TS-FUNCTION-DECL
                                (list (intern_trivial_string (trim (substr after 0 open-paren)))
                                      (intern_trivial_string (trim (substr after (add open-paren 1) close-paren))))
                                source-path line-no 1))))

    (defn parse-class-decl (text line-no source-path)
        (do
            (let after (trim (substr text 5 (str_len text))))   ; strip "class"
            ;; Name ends at first non-ident or `{` or space.
            (let space-pos (find-from after " " 0))
            (let brace-pos (find-from after "{" 0))
            (let end (pick-min space-pos brace-pos (str_len after)))
            (intern_node_at TS-CLASS-DECL
                            (list (intern_trivial_string (trim (substr after 0 end))))
                            source-path line-no 1)))

    (defn pick-min (a b fallback)
        (if (lt a 0)
            (if (lt b 0) fallback b)
            (if (lt b 0) a
                (if (lt a b) a b))))

    (defn parse-decl (text line-no source-path kind kind-len)
        ;; kind is "const"|"let"|"var"; kind-len is its length.
        (do
            (let after (trim (substr text kind-len (str_len text))))
            (let eq-pos (find-from after "=" 0))
            (if (lt eq-pos 0)
                (intern_node_at TS-CONST-DECL
                                (list (intern_trivial_string kind)
                                      (intern_trivial_string after)
                                      (intern_trivial_string ""))
                                source-path line-no 1)
                (intern_node_at TS-CONST-DECL
                                (list (intern_trivial_string kind)
                                      (intern_trivial_string (trim (substr after 0 eq-pos)))
                                      (intern_trivial_string (trim (substr after (add eq-pos 1) (str_len after)))))
                                source-path line-no 1))))

    (defn parse-export (text line-no source-path)
        (do
            (let after (trim (substr text 6 (str_len text))))   ; strip "export"
            (intern_node_at TS-EXPORT
                            (list (parse-statement-text after line-no source-path))
                            source-path line-no 1)))

    (defn parse-statement-text (text line-no source-path)
        (if (starts-with-keyword? text "function")
            (parse-function-decl text line-no source-path)
            (if (starts-with-keyword? text "class")
                (parse-class-decl text line-no source-path)
                (if (starts-with-keyword? text "const")
                    (parse-decl text line-no source-path "const" 5)
                    (if (starts-with-keyword? text "let")
                        (parse-decl text line-no source-path "let" 3)
                        (if (starts-with-keyword? text "var")
                            (parse-decl text line-no source-path "var" 3)
                            (intern_trivial_string text)))))))

    (defn ts-parse-block (ln source-path)
        (do
            (let text (line-text ln))
            (let line-no (line-num ln))
            (let trimmed (trim-leading-ws text))
            (if (starts-with-keyword? trimmed "import")
                (parse-import trimmed line-no source-path)
                (if (starts-with-keyword? trimmed "export")
                    (parse-export trimmed line-no source-path)
                    (parse-statement-text trimmed line-no source-path)))))

    (defn ts-ts-parse-blocks (lines source-path acc)
        (if (nil? lines) (reverse-acc acc)
            (do
                (let ln (head lines))
                (let text (line-text ln))
                (if (or (is-blank? text) (is-line-comment? text))
                    (ts-ts-parse-blocks (tail lines) source-path acc)
                    (ts-ts-parse-blocks (tail lines) source-path
                                  (cons (ts-parse-block ln source-path) acc))))))

    (defn parse-typescript (source-path text)
        (do
            (let lines (lines-from-source text))
            (let blocks (ts-ts-parse-blocks lines source-path (empty)))
            (intern_node_at TS-MODULE blocks source-path 1 1)))
)
