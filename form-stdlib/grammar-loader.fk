; grammar-loader.fk -- ontology-free named registry over BMF grammars.
;
; The BMF engine (bmf-grammar.fk) already makes a GRAMMAR pure data and parses a
; source string with g-parse. This adds the missing top: a named REGISTRY so a
; caller selects a grammar by name ("shell", "arith", "bash", ...) and parses any
; source through it.
;
;   register a grammar (data)  ──▶  gl-register
;   parse any source           ──▶  gl-parse / gl-parse-with  ──▶  Form AST node
;
; Grammars are values, so the registry is an immutable alist; registering returns
; a NEW registry (newest shadows older). "Support any grammar" = gl-register;
; "support any source" = the src string. The AST a grammar produces can be lowered
; to a recipe/blueprint/cell downstream. This layer's only job is source text ->
; AST through a named grammar value.
;
; No ontology loader, no line grammar, no tokenizer: those are higher
; integration/domain layers. The direct layer gate is the slim BMF stack.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    ;; Layer language manifest -- this layer's observable abstraction.
    (defn gl-layer-feature (name status) (list "grammar-loader-layer-feature" name status))
    (defn gl-layer-feature-name (f) (nth f 1))
    (defn gl-layer-feature-status (f) (nth f 2))
    (defn grammar-loader-language-manifest ()
        (list
            (gl-layer-feature "named-registry" 1)
            (gl-layer-feature "immutable-register" 1)
            (gl-layer-feature "shadowing" 1)
            (gl-layer-feature "parse-with" 1)
            (gl-layer-feature "parse-by-name" 1)
            (gl-layer-feature "ontology-free" 1)
            (gl-layer-feature "no-line-grammar" 1)))
    (defn grammar-loader-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (gl-layer-feature-name (head fs)) name)
                     (eq (gl-layer-feature-status (head fs)) 1))
                1
                (grammar-loader-manifest-has? name (tail fs)))))

    ;; a registry is an alist of (name grammar); newest first.
    (defn gl-empty () (empty))
    (defn gl-entry (name g) (list name g))
    (defn gl-ent-name (e) (head e))
    (defn gl-ent-grammar (e) (head (tail e)))

    ;; register returns a NEW registry with (name -> g) in front (shadows older).
    (defn gl-register (reg name g) (cons (gl-entry name g) reg))

    ;; the grammar registered under name, or (empty) when absent.
    (defn gl-find (reg name)
        (if (nil? reg) (empty)
            (if (str_eq (gl-ent-name (head reg)) name) (gl-ent-grammar (head reg))
                (gl-find (tail reg) name))))

    (defn gl-has? (reg name)
        (if (nil? reg) false
            (if (str_eq (gl-ent-name (head reg)) name) true
                (gl-has? (tail reg) name))))

    (defn gl-count (reg) (len reg))

    (defn gl-names (reg)
        (if (nil? reg) (empty)
            (cons (gl-ent-name (head reg)) (gl-names (tail reg)))))

    ;; parse SRC with an explicit grammar value — the any-grammar/any-source door.
    (defn gl-parse-with (g src) (g-parse g src))

    ;; parse SRC with the grammar registered under NAME.
    (defn gl-parse (reg name src)
        (do (let g (gl-find reg name))
            (if (nil? g) (intern_trivial_string "NO-SUCH-GRAMMAR")
                (g-parse g src))))

    ;; did a parse succeed? g-parse / gl-parse return a string-leaf sentinel on
    ;; failure ("PARSE-FAIL" / "NO-SUCH-GRAMMAR"); every real AST is a node.
    (defn gl-ok? (node)
        (not (or (node_eq node (intern_trivial_string "PARSE-FAIL"))
                 (node_eq node (intern_trivial_string "NO-SUCH-GRAMMAR")))))
)
