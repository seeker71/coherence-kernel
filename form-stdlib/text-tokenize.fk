; text-tokenize.fk — split text into lowercased ascii-letter words, in pure Form.
;
; preludes: form-stdlib/core.fk
;
; Ported home from the origin (2026-07-02) to heal cognition/rag-embed.fk's
; re-vec, which called tk-words for the life of this checkout while the organ
; that defines it had never come across — every embedding silently summed to
; zero (receipts/2026-07-01-nl-meaning-net.md named the wound;
; learn/resident-conatus.fk probes it live). One lift applied at the door:
; the origin held TK-LOWERS as a top-level `let`, which is invisible inside
; `defn` bodies on `fkwu --src` (root cause #1,
; receipts/2026-07-01-json-fk-src-scoping-fix.md) — here it is the proven
; zero-arg-defn shape, called as (TK-LOWERS).
;
; The shell `tr A-Z a-z | grep -oE '[a-z]{4,}'` was a transformation, so it is
; Form. A char is a letter when ord(c) is A-Z (65-90) or a-z (97-122); an
; uppercase letter lowercases through an ord-indexed 26-char table (no chr op
; needed). The scan accumulates the current word as a string and flushes it,
; space-joined, when a non-letter (or the end) breaks it — words shorter than
; minlen are dropped. Result is a single space-joined string (no cons needed);
; a caller splits on spaces. The scanner uses one-byte substring + ord so the
; fkwu byte-return edge of `char_at` cannot change the text shape.
;
; NAMED BOUNDARY (sibling review, grok, 2026-07-02, confirmed live): this is
; ASCII-parochial by construction. Every multibyte UTF-8 char is a hard
; delimiter, so CJK text tokenizes to NOTHING (re-vec still zero-vectors it)
; and accented words shatter into fragments ("résumé" -> "r sum") that hash
; as plausible-looking tokens. learn/resident-conatus.fk carries this as the
; self-clearing ask rcn-ask-re-vec-utf8 until a byte-honest tokenizer lands.

(do
    (defn TK-LOWERS () (list "a" "b" "c" "d" "e" "f" "g" "h" "i" "j" "k" "l" "m"
                             "n" "o" "p" "q" "r" "s" "t" "u" "v" "w" "x" "y" "z"))

    ; lowercase one char: uppercase A-Z -> a-z (ord-indexed), others unchanged.
    (defn tk-low (c)
        (do (let o (ord c))
            (if (if (ge o 65) (le o 90) 0) (nth (TK-LOWERS) (sub o 65)) c)))

    ; is a char an ascii letter? (A-Z or a-z)
    (defn tk-alpha? (c)
        (do (let o (ord c))
            (if (if (ge o 65) (le o 90) 0) 1
                (if (if (ge o 97) (le o 122) 0) 1 0))))

    ; flush the current word to the space-joined accumulator when it is long enough.
    (defn tk-flush (out cur minlen)
        (if (ge (str_len cur) minlen)
            (if (str_eq out "") cur (str_concat out (str_concat " " cur)))
            out))

    ; scan the text char by char, lowercasing letters into `cur`, flushing on breaks.
    (defn tk-scan (text i n cur out minlen)
        (if (ge i n)
            (tk-flush out cur minlen)
            (do
                (let c (substring text i (add i 1)))
                (if (eq (tk-alpha? c) 1)
                    (tk-scan text (add i 1) n (str_concat cur (tk-low c)) out minlen)
                    (tk-scan text (add i 1) n "" (tk-flush out cur minlen) minlen)))))

    ; the entry: text -> space-joined lowercased letter-words of length >= minlen.
    (defn tk-words (text minlen)
        (tk-scan text 0 (str_len text) "" "" minlen))
    0)
