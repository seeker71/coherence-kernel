; lang-common.fk — the statement + expression rules shared by every imperative
; language grammar (BML, Go, Java, …). Each language provides its own `method`,
; `param`, and `ifs` (where surfaces genuinely differ) and appends these.
;
; This is the core-abstraction-first payoff: the languages diverge only at the
; few rules where their surface actually differs; everything from `stmt` down to
; `atom` is one shared bag of rules emitting the universal vocabulary.
;
; A grammar's `stmt` references `ifs` by name — each language supplies its own
; `ifs`, resolved within that grammar — so the shared `stmt` works unchanged.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    (defn common-rules () (list

        (rule3 "stmt"
            (p-cap "v" (list "alt" (p-ref "ret") (p-ref "ifs") (p-ref "lets") (p-ref "exprs")))
            (t-splice "v"))

        (rule3 "ret"
            (list "seq" (p-lit "return") (p-cap "e" (p-ref "expr")) (p-lit ";"))
            (t-emit "UE-JUMP-RETURN" (list (t-splice "e"))))

        (rule3 "lets"
            (list "seq" (p-cap "n" (p-run "alpha")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";"))
            (t-emit "let" (list (t-splice "n") (t-splice "e"))))

        (rule3 "exprs"
            (list "seq" (p-cap "e" (p-ref "expr")) (p-lit ";"))
            (t-splice "e"))

        (rule3 "expr"
            (p-cap "v" (list "alt" (p-ref "addx") (p-ref "subx") (p-ref "term")))
            (t-splice "v"))
        (rule3 "addx"
            (list "seq" (p-cap "l" (p-ref "term")) (p-lit "+") (p-cap "r" (p-ref "expr")))
            (t-emit "add" (list (t-splice "l") (t-splice "r"))))
        (rule3 "subx"
            (list "seq" (p-cap "l" (p-ref "term")) (p-lit "-") (p-cap "r" (p-ref "expr")))
            (t-emit "sub" (list (t-splice "l") (t-splice "r"))))

        (rule3 "term"
            (p-cap "v" (list "alt" (p-ref "mulx") (p-ref "divx") (p-ref "factor")))
            (t-splice "v"))
        (rule3 "mulx"
            (list "seq" (p-cap "l" (p-ref "factor")) (p-lit "*") (p-cap "r" (p-ref "term")))
            (t-emit "mul" (list (t-splice "l") (t-splice "r"))))
        (rule3 "divx"
            (list "seq" (p-cap "l" (p-ref "factor")) (p-lit "/") (p-cap "r" (p-ref "term")))
            (t-emit "div" (list (t-splice "l") (t-splice "r"))))

        (rule3 "factor"
            (list "alt"
                (list "seq" (p-lit "(") (p-cap "v" (p-ref "expr")) (p-lit ")"))
                (p-cap "v" (p-ref "call"))
                (p-cap "v" (p-ref "atom")))
            (t-splice "v"))

        (rule3 "call"
            (list "seq" (p-cap "n" (p-run "alpha")) (p-lit "(")
                  (p-cap "args" (p-sep (p-ref "expr") (p-lit ","))) (p-lit ")"))
            (t-emit "fncall" (list (t-splice "n") (t-splices "args"))))

        (rule3 "atom"
            (p-cap "v" (p-run "alnum"))
            (t-splice "v"))))
)
