; runtime-program-image-fkb-walker-trace.fk -- structured program-image walker trace adapter.
;
; Layer 9h3 binds structured supplied walker/resource facts to the same
; request-ready 9e envelope and admitted 8h6 program-image admission that 9h1
; already consumes. A valid trace lowers to the existing 9h1 supplied-run row
; and then delegates to 9h1. Invalid trace facts stay structured and loud.
;
; This is not a program-image walker or loader. It does not open artifacts,
; decode bytes, run an image, consume executor capability readiness, call
; native code, install a selector, or grow the C seed.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/runtime-artifact-attempt-receipt.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-fkb-byte-container.fk
;           form-stdlib/program-image-fkb-byte-file-witness.fk
;           form-stdlib/program-image-fkb-byte-decode.fk
;           form-stdlib/runtime-program-image-fkb-attempt.fk

(do
    (defn rpiwt-version () "runtime-program-image-fkb-walker-trace-v1")

    (defn rpiwt-feature (name status) (list "runtime-program-image-fkb-walker-trace-feature" name status))
    (defn rpiwt-feature-name (f) (nth f 1))
    (defn rpiwt-feature-status (f) (nth f 2))
    (defn runtime-program-image-fkb-walker-trace-manifest ()
        (list
            (rpiwt-feature "walker-trace-adapter-not-loader" 1)
            (rpiwt-feature "structured-resource-facts" 1)
            (rpiwt-feature "trace-identity-bound-to-envelope-and-admission" 1)
            (rpiwt-feature "function-root-entry-only" 1)
            (rpiwt-feature "entry-root-validated" 1)
            (rpiwt-feature "resource-counters-sane" 1)
            (rpiwt-feature "ok-requires-completed-output" 1)
            (rpiwt-feature "hard-statuses-preserved" 1)
            (rpiwt-feature "soft-and-unknown-statuses-preserved" 1)
            (rpiwt-feature "lowers-to-9h1-supplied-run" 1)
            (rpiwt-feature "9h1-bridge-visible" 1)
            (rpiwt-feature "no-executor-capability-consumption" 1)
            (rpiwt-feature "no-artifact-io" 1)
            (rpiwt-feature "no-program-image-walk" 1)
            (rpiwt-feature "no-native-call" 1)
            (rpiwt-feature "no-selector-install" 1)
            (rpiwt-feature "no-c-seed-growth" 1)
            (rpiwt-feature "future-real-9h-walker-still-pending" 1)))
    (defn runtime-program-image-fkb-walker-trace-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rpiwt-feature-name (head fs)) name)
                     (eq (rpiwt-feature-status (head fs)) 1))
                1
                (runtime-program-image-fkb-walker-trace-manifest-has? name (tail fs)))))

    (defn rpiwt-status-trace-ready () "trace-ready")
    (defn rpiwt-status-investigate () "investigate")
    (defn rpiwt-status-refused () "refused")

    (defn rpiwt-reason-trace-lowered () "trace-lowered")
    (defn rpiwt-reason-malformed-envelope () "malformed-envelope")
    (defn rpiwt-reason-non-program-image-envelope () "non-program-image-envelope")
    (defn rpiwt-reason-malformed-admission () "malformed-admission")
    (defn rpiwt-reason-non-admitted-admission () "non-admitted-admission")
    (defn rpiwt-reason-admission-decode-not-decoded () "admission-decode-not-decoded")
    (defn rpiwt-reason-admission-invalid-pif () "admission-invalid-pif")
    (defn rpiwt-reason-admission-decode-pif-mismatch () "admission-decode-pif-mismatch")
    (defn rpiwt-reason-artifact-identity-mismatch () "artifact-identity-mismatch")
    (defn rpiwt-reason-malformed-trace () "malformed-trace")
    (defn rpiwt-reason-trace-identity-mismatch () "trace-identity-mismatch")
    (defn rpiwt-reason-invalid-entry-kind () "invalid-entry-kind")
    (defn rpiwt-reason-negative-entry-index () "negative-entry-index")
    (defn rpiwt-reason-entry-index-out-of-range () "entry-index-out-of-range")
    (defn rpiwt-reason-root-node-out-of-range () "root-node-out-of-range")
    (defn rpiwt-reason-root-node-mismatch () "root-node-mismatch")
    (defn rpiwt-reason-negative-step-budget () "negative-step-budget")
    (defn rpiwt-reason-negative-steps-used () "negative-steps-used")
    (defn rpiwt-reason-steps-used-exceeds-budget () "steps-used-exceeds-budget")
    (defn rpiwt-reason-negative-output () "negative-output")
    (defn rpiwt-reason-empty-ok-output () "empty-ok-output")
    (defn rpiwt-reason-ok-stop-reason-mismatch () "ok-stop-reason-mismatch")
    (defn rpiwt-reason-status-stop-reason-mismatch () "status-stop-reason-mismatch")
    (defn rpiwt-reason-empty-unknown-stop-reason () "empty-unknown-stop-reason")
    (defn rpiwt-reason-manifest ()
        (list
            (rpiwt-reason-trace-lowered)
            (rpiwt-reason-malformed-envelope)
            (rpiwt-reason-non-program-image-envelope)
            (rpiwt-reason-malformed-admission)
            (rpiwt-reason-non-admitted-admission)
            (rpiwt-reason-admission-decode-not-decoded)
            (rpiwt-reason-admission-invalid-pif)
            (rpiwt-reason-admission-decode-pif-mismatch)
            (rpiwt-reason-artifact-identity-mismatch)
            (rpiwt-reason-malformed-trace)
            (rpiwt-reason-trace-identity-mismatch)
            (rpiwt-reason-invalid-entry-kind)
            (rpiwt-reason-negative-entry-index)
            (rpiwt-reason-entry-index-out-of-range)
            (rpiwt-reason-root-node-out-of-range)
            (rpiwt-reason-root-node-mismatch)
            (rpiwt-reason-negative-step-budget)
            (rpiwt-reason-negative-steps-used)
            (rpiwt-reason-steps-used-exceeds-budget)
            (rpiwt-reason-negative-output)
            (rpiwt-reason-empty-ok-output)
            (rpiwt-reason-ok-stop-reason-mismatch)
            (rpiwt-reason-status-stop-reason-mismatch)
            (rpiwt-reason-empty-unknown-stop-reason)))

    (defn rpiwt-entry-kind-function-root () "function-root")
    (defn rpiwt-stop-completed () "completed")
    (defn rpiwt-stop-oom-killed () "oom-killed")
    (defn rpiwt-stop-killed () "killed")
    (defn rpiwt-stop-stalled () "stalled")
    (defn rpiwt-stop-timeout () "timeout")
    (defn rpiwt-stop-wrong-value () "wrong-value")
    (defn rpiwt-stop-loader-missing () "loader-missing")
    (defn rpiwt-stop-error () "error")
    (defn rpiwt-stop-unknown () "unknown")
    (defn rpiwt-marker () "program-image-fkb-walker-trace")

    ; trace = ("runtime-program-image-fkb-walker-trace" artifact-path
    ;          source-hash content-hash entry-kind entry-index root-node
    ;          step-budget steps-used output-count first-value exit-code
    ;          status stop-reason detail)
    (defn rpiwt-trace (artifact-path source-hash content-hash entry-kind entry-index root-node step-budget steps-used output-count first-value exit-code status stop-reason detail)
        (list "runtime-program-image-fkb-walker-trace"
              artifact-path source-hash content-hash entry-kind entry-index
              root-node step-budget steps-used output-count first-value
              exit-code status stop-reason detail))
    (defn rpiwt-trace? (t)
        (if (eq (len t) 15)
            (str_eq (nth t 0) "runtime-program-image-fkb-walker-trace")
            0))
    (defn rpiwt-trace-artifact-path (t) (nth t 1))
    (defn rpiwt-trace-source-hash (t) (nth t 2))
    (defn rpiwt-trace-content-hash (t) (nth t 3))
    (defn rpiwt-trace-entry-kind (t) (nth t 4))
    (defn rpiwt-trace-entry-index (t) (nth t 5))
    (defn rpiwt-trace-root-node (t) (nth t 6))
    (defn rpiwt-trace-step-budget (t) (nth t 7))
    (defn rpiwt-trace-steps-used (t) (nth t 8))
    (defn rpiwt-trace-output-count (t) (nth t 9))
    (defn rpiwt-trace-first-value (t) (nth t 10))
    (defn rpiwt-trace-exit-code (t) (nth t 11))
    (defn rpiwt-trace-status (t) (nth t 12))
    (defn rpiwt-trace-stop-reason (t) (nth t 13))
    (defn rpiwt-trace-detail (t) (nth t 14))

    (defn rpiwt-no-run () (list "runtime-program-image-fkb-walker-trace-no-run"))
    (defn rpiwt-no-run? (r)
        (if (eq (len r) 1)
            (str_eq (nth r 0) "runtime-program-image-fkb-walker-trace-no-run")
            0))
    (defn rpiwt-no-9h1-bridge () (list "runtime-program-image-fkb-walker-trace-no-9h1-bridge"))
    (defn rpiwt-no-9h1-bridge? (b)
        (if (eq (len b) 1)
            (str_eq (nth b 0) "runtime-program-image-fkb-walker-trace-no-9h1-bridge")
            0))

    ; bridge = ("runtime-program-image-fkb-walker-trace-bridge"
    ;           envelope admission trace run 9h1-bridge status reason)
    (defn rpiwt-bridge-receipt (envelope admission trace run bridge status reason)
        (list "runtime-program-image-fkb-walker-trace-bridge"
              envelope admission trace run bridge status reason))
    (defn rpiwt-bridge? (b)
        (if (eq (len b) 8)
            (str_eq (nth b 0) "runtime-program-image-fkb-walker-trace-bridge")
            0))
    (defn rpiwt-bridge-envelope (b) (nth b 1))
    (defn rpiwt-bridge-admission (b) (nth b 2))
    (defn rpiwt-bridge-trace (b) (nth b 3))
    (defn rpiwt-bridge-run (b) (nth b 4))
    (defn rpiwt-bridge-9h1 (b) (nth b 5))
    (defn rpiwt-bridge-status (b) (nth b 6))
    (defn rpiwt-bridge-reason (b) (nth b 7))

    (defn rpiwt-investigate (envelope admission trace run bridge reason)
        (rpiwt-bridge-receipt envelope admission trace run bridge
                              (rpiwt-status-investigate) reason))
    (defn rpiwt-refused (envelope admission trace run bridge reason)
        (rpiwt-bridge-receipt envelope admission trace run bridge
                              (rpiwt-status-refused) reason))
    (defn rpiwt-terminal-from-9h1 (envelope admission trace run bridge reason)
        (if (str_eq (rpifa-bridge-status bridge) (rpifa-status-refused))
            (rpiwt-refused envelope admission trace run bridge reason)
            (rpiwt-investigate envelope admission trace run bridge reason)))
    (defn rpiwt-ready (envelope admission trace run bridge)
        (rpiwt-bridge-receipt envelope admission trace run bridge
                              (rpiwt-status-trace-ready)
                              (rpiwt-reason-trace-lowered)))

    (defn rpiwt-run-detail (trace)
        (str_concat (rpiwt-marker)
            (str_concat " stop="
            (str_concat (rpiwt-trace-stop-reason trace)
            (str_concat " detail=" (rpiwt-trace-detail trace))))))
    (defn rpiwt-run-from-trace (trace)
        (rpifa-supplied-run (rpiwt-trace-artifact-path trace)
                            (rpiwt-trace-first-value trace)
                            (rpiwt-trace-output-count trace)
                            (rpiwt-trace-exit-code trace)
                            (rpiwt-trace-status trace)
                            (rpiwt-run-detail trace)))

    (defn rpiwt-trace-identity-matches? (envelope pif trace)
        (and (str_eq (rpiwt-trace-artifact-path trace) (rale-envelope-artifact-path envelope))
        (and (str_eq (rpiwt-trace-artifact-path trace) (pif-envelope-artifact-path pif))
        (and (str_eq (rpiwt-trace-source-hash trace) (rale-envelope-source-hash envelope))
        (and (str_eq (rpiwt-trace-source-hash trace) (pif-envelope-source-hash pif))
        (and (str_eq (rpiwt-trace-content-hash trace) (rale-envelope-content-hash envelope))
             (str_eq (rpiwt-trace-content-hash trace) (pif-envelope-content-hash pif))))))))

    (defn rpiwt-entry-index-valid? (pif trace)
        (do
            (let table (pif-envelope-table pif))
            (and (ge (rpiwt-trace-entry-index trace) 0)
                 (lt (rpiwt-trace-entry-index trace) (pif-table-nf table)))))
    (defn rpiwt-root-node-in-range? (pif trace)
        (do
            (let table (pif-envelope-table pif))
            (and (ge (rpiwt-trace-root-node trace) 0)
                 (lt (rpiwt-trace-root-node trace) (pif-table-nr table)))))
    (defn rpiwt-root-node-matches? (pif trace)
        (do
            (let table (pif-envelope-table pif))
            (eq (rpiwt-trace-root-node trace)
                (nth (pif-table-fn-roots table) (rpiwt-trace-entry-index trace)))))
    (defn rpiwt-entry-reason (pif trace)
        (if (not (str_eq (rpiwt-trace-entry-kind trace) (rpiwt-entry-kind-function-root)))
            (rpiwt-reason-invalid-entry-kind)
            (if (lt (rpiwt-trace-entry-index trace) 0)
                (rpiwt-reason-negative-entry-index)
                (if (not (rpiwt-entry-index-valid? pif trace))
                    (rpiwt-reason-entry-index-out-of-range)
                    (if (not (rpiwt-root-node-in-range? pif trace))
                        (rpiwt-reason-root-node-out-of-range)
                        (if (not (rpiwt-root-node-matches? pif trace))
                            (rpiwt-reason-root-node-mismatch)
                            (rpiwt-reason-trace-lowered)))))))
    (defn rpiwt-entry-valid? (pif trace)
        (str_eq (rpiwt-entry-reason pif trace) (rpiwt-reason-trace-lowered)))

    (defn rpiwt-resource-reason (trace)
        (if (lt (rpiwt-trace-step-budget trace) 0)
            (rpiwt-reason-negative-step-budget)
            (if (lt (rpiwt-trace-steps-used trace) 0)
                (rpiwt-reason-negative-steps-used)
                (if (gt (rpiwt-trace-steps-used trace) (rpiwt-trace-step-budget trace))
                    (rpiwt-reason-steps-used-exceeds-budget)
                    (if (lt (rpiwt-trace-output-count trace) 0)
                        (rpiwt-reason-negative-output)
                        (if (and (str_eq (rpiwt-trace-status trace) (rao-obs-ok))
                                 (eq (rpiwt-trace-output-count trace) 0))
                            (rpiwt-reason-empty-ok-output)
                            (rpiwt-reason-trace-lowered)))))))
    (defn rpiwt-resource-valid? (trace)
        (str_eq (rpiwt-resource-reason trace) (rpiwt-reason-trace-lowered)))

    (defn rpiwt-known-status? (status)
        (if (str_eq status (rao-obs-ok))
            1
            (if (eq (rao-hard-status? status) 1)
                1
                (if (eq (rao-soft-status? status) 1) 1 0))))
    (defn rpiwt-known-status-stop-matches? (status stop)
        (if (str_eq status (rao-obs-ok))
            (str_eq stop (rpiwt-stop-completed))
            (if (str_eq status (rao-obs-oom-killed))
                (str_eq stop (rpiwt-stop-oom-killed))
                (if (str_eq status (rao-obs-killed))
                    (str_eq stop (rpiwt-stop-killed))
                    (if (str_eq status (rao-obs-stalled))
                        (str_eq stop (rpiwt-stop-stalled))
                        (if (str_eq status (rao-obs-timeout))
                            (str_eq stop (rpiwt-stop-timeout))
                            (if (str_eq status (rao-obs-wrong-value))
                                (str_eq stop (rpiwt-stop-wrong-value))
                                (if (str_eq status (rao-obs-loader-missing))
                                    (str_eq stop (rpiwt-stop-loader-missing))
                                    (if (str_eq status (rao-obs-error))
                                        (str_eq stop (rpiwt-stop-error))
                                        0)))))))))
    (defn rpiwt-status-reason (trace)
        (do
            (let status (rpiwt-trace-status trace))
            (let stop (rpiwt-trace-stop-reason trace))
            (if (eq (rpiwt-known-status? status) 1)
                (if (eq (rpiwt-known-status-stop-matches? status stop) 1)
                    (rpiwt-reason-trace-lowered)
                    (if (str_eq status (rao-obs-ok))
                        (rpiwt-reason-ok-stop-reason-mismatch)
                        (rpiwt-reason-status-stop-reason-mismatch)))
                (if (gt (str_len stop) 0)
                    (rpiwt-reason-trace-lowered)
                    (rpiwt-reason-empty-unknown-stop-reason)))))
    (defn rpiwt-status-valid? (trace)
        (str_eq (rpiwt-status-reason trace) (rpiwt-reason-trace-lowered)))

    (defn rpiwt-terminal-envelope (envelope admission trace run reason)
        (do
            (let bridge (rpifa-bridge-from-run envelope admission run))
            (rpiwt-terminal-from-9h1 envelope admission trace run bridge reason)))
    (defn rpiwt-terminal-admission (envelope admission trace run reason)
        (do
            (let bridge (rpifa-bridge-from-run envelope admission run))
            (rpiwt-terminal-from-9h1 envelope admission trace run bridge reason)))

    (defn rpiwt-bridge-after-admission (envelope admission trace run)
        (do
            (let pif (pifbd-admission-pif admission))
            (if (not (rpifa-pif-matches-envelope? envelope pif))
                (rpiwt-terminal-admission envelope admission trace run (rpiwt-reason-artifact-identity-mismatch))
                (if (not (rpiwt-trace-identity-matches? envelope pif trace))
                    (rpiwt-investigate envelope admission trace run (rpiwt-no-9h1-bridge)
                                       (rpiwt-reason-trace-identity-mismatch))
                    (if (not (rpiwt-entry-valid? pif trace))
                        (rpiwt-refused envelope admission trace run (rpiwt-no-9h1-bridge)
                                       (rpiwt-entry-reason pif trace))
                        (if (not (rpiwt-resource-valid? trace))
                            (rpiwt-refused envelope admission trace run (rpiwt-no-9h1-bridge)
                                           (rpiwt-resource-reason trace))
                            (if (not (rpiwt-status-valid? trace))
                                (rpiwt-refused envelope admission trace run (rpiwt-no-9h1-bridge)
                                               (rpiwt-status-reason trace))
                                (do
                                    (let bridge (rpifa-bridge-from-run envelope admission run))
                                    (if (str_eq (rpifa-bridge-status bridge) (rpifa-status-attempt-ready))
                                        (rpiwt-ready envelope admission trace run bridge)
                                        (rpiwt-terminal-from-9h1 envelope admission trace run bridge
                                                                 (rpifa-bridge-reason bridge)))))))))))

    (defn rpiwt-bridge-from-trace (envelope admission trace)
        (if (not (rpiwt-trace? trace))
            (rpiwt-refused envelope admission trace (rpiwt-no-run) (rpiwt-no-9h1-bridge)
                           (rpiwt-reason-malformed-trace))
            (do
                (let run (rpiwt-run-from-trace trace))
                (if (not (rale-envelope? envelope))
                    (rpiwt-terminal-envelope envelope admission trace run (rpiwt-reason-malformed-envelope))
                    (if (not (rpifa-program-image-envelope? envelope))
                        (rpiwt-terminal-envelope envelope admission trace run (rpiwt-reason-non-program-image-envelope))
                        (if (not (pifbd-admission? admission))
                            (rpiwt-terminal-admission envelope admission trace run (rpiwt-reason-malformed-admission))
                            (if (not (rpifa-admission-status-admitted? admission))
                                (rpiwt-terminal-admission envelope admission trace run (rpiwt-reason-non-admitted-admission))
                                (if (not (rpifa-admission-decode-decoded? admission))
                                    (rpiwt-terminal-admission envelope admission trace run (rpiwt-reason-admission-decode-not-decoded))
                                    (if (not (rpifa-admission-pif-valid? admission))
                                        (rpiwt-terminal-admission envelope admission trace run (rpiwt-reason-admission-invalid-pif))
                                        (if (not (rpifa-admission-decode-matches-pif? admission))
                                            (rpiwt-terminal-admission envelope admission trace run (rpiwt-reason-admission-decode-pif-mismatch))
                                            (rpiwt-bridge-after-admission envelope admission trace run)))))))))))
)
