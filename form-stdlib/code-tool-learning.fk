; code-tool-learning.fk — Form-native code generation and tool-use learning sideband.
;
; Floor: every coding action can emit a native sample, choose a tool through
; tool-channel planning, and turn the execution receipt back into branch-choice
; learning data. It can also request third-party evidence lanes from
; oracle-catalog. This file does not execute tools and does not call an LLM.
;
; North star: code generation, tool selection, and tool execution become a
; two-way learning channel. External agents (Codex, Claude, Grok, Gemini,
; Ollama) and Form-native candidates race side by side; once conviction,
; certainty, frequency, aliveness, sovereignty, and trust clear the floor, the
; Form-native candidate can be selected, A/B tested, and eventually replace
; external generation on lanes it has proven. Natural language to agent CLI to
; host-native ASM is a north-star lane in this same loop.
;
; Proven by: form-stdlib/tests/code-tool-learning-band.fk

(do
    (defn ctl-sample (label feature lane)
        (list label feature lane))
    (defn ctl-label (sample) (nth sample 0))
    (defn ctl-feature (sample) (nth sample 1))
    (defn ctl-lane (sample) (nth sample 2))
    (defn ctl-exemplar (sample)
        (list (ctl-label sample) (ctl-feature sample)))
    (defn ctl-learn-sample (sample model)
        (cons (ctl-exemplar sample) model))
    (defn ctl-learn-stream (samples model)
        (if (eq (len samples) 0) model
            (ctl-learn-stream
                (tail samples)
                (ctl-learn-sample (head samples) model))))
    (defn ctl-device (samples)
        (ctl-learn-stream samples (empty)))

    (defn ctl-row (feature label)
        (list feature label))
    (defn ctl-row-feature (row) (nth row 0))
    (defn ctl-row-label (row) (nth row 1))
    (defn ctl-pair (model row)
        (list
            (ns-label (ctl-row-feature row) model)
            (ctl-row-label row)))
    (defn ctl-eval (model rows)
        (if (eq (len rows) 0) (empty)
            (cons
                (ctl-pair model (head rows))
                (ctl-eval model (tail rows)))))
    (defn ctl-correct (model rows)
        (ce-correct (ctl-eval model rows)))

    (defn ctl-freq-spectrum (source grammar tool proof runtime)
        (list source grammar tool proof runtime))
    (defn ctl-freq-source (freq) (nth freq 0))
    (defn ctl-freq-grammar (freq) (nth freq 1))
    (defn ctl-freq-tool (freq) (nth freq 2))
    (defn ctl-freq-proof (freq) (nth freq 3))
    (defn ctl-freq-runtime (freq) (nth freq 4))
    (defn ctl-meta (conviction certainty freq aliveness sovereignty trust)
        (list conviction certainty freq aliveness sovereignty trust))
    (defn ctl-meta-conviction (meta) (nth meta 0))
    (defn ctl-meta-certainty (meta) (nth meta 1))
    (defn ctl-meta-frequency (meta) (nth meta 2))
    (defn ctl-meta-aliveness (meta) (nth meta 3))
    (defn ctl-meta-sovereignty (meta) (nth meta 4))
    (defn ctl-meta-trust (meta) (nth meta 5))
    (defn ctl-meta-floor50? (meta)
        (if (and
                (ge (ctl-meta-conviction meta) 51)
                (and
                    (ge (ctl-meta-certainty meta) 51)
                    (and
                        (ge (ctl-meta-aliveness meta) 51)
                        (and
                            (ge (ctl-meta-sovereignty meta) 51)
                            (and
                                (ge (ctl-meta-trust meta) 51)
                                (gt (len (ctl-meta-frequency meta)) 0))))))
            1
            0))
    (defn ctl-meta-autonomous? (meta)
        (if (and
                (eq (ctl-meta-floor50? meta) 1)
                (and
                    (ge (ctl-meta-sovereignty meta) 70)
                    (ge (ctl-meta-trust meta) 70)))
            1
            0))

    (defn ctl-agent (path kind carrier locality)
        (list path kind carrier locality))
    (defn ctl-agent-path (agent) (nth agent 0))
    (defn ctl-agent-kind (agent) (nth agent 1))
    (defn ctl-agent-carrier (agent) (nth agent 2))
    (defn ctl-agent-locality (agent) (nth agent 3))
    (defn ctl-agent-catalog ()
        (list
            (ctl-agent "form-native:code-tool" "native-candidate" "form-kernel" "local")
            (ctl-agent "agent:codex" "external-agent" "llm" "remote-or-local")
            (ctl-agent "agent:claude" "external-agent" "llm" "remote")
            (ctl-agent "agent:grok" "external-agent" "llm" "remote")
            (ctl-agent "agent:gemini" "external-agent" "llm" "remote")
            (ctl-agent "ollama:local" "external-agent" "local-llm" "local")))

    (defn ctl-receipt-candidates ()
        (list
            (cr-choice-candidate
                "form-native:code-tool"
                "CODE-TOOL-CHOICE"
                true
                0
                90
                "Form-native candidate answered with inspectable grammar/tool plan")
            (cr-choice-candidate
                "agent:codex"
                "CODE-TOOL-CHOICE"
                true
                10
                95
                "Codex external baseline")
            (cr-choice-candidate
                "agent:claude"
                "CODE-TOOL-CHOICE"
                true
                10
                90
                "Claude external baseline")
            (cr-choice-candidate
                "agent:grok"
                "CODE-TOOL-CHOICE"
                true
                20
                85
                "Grok external baseline")
            (cr-choice-candidate
                "agent:gemini"
                "CODE-TOOL-CHOICE"
                true
                20
                85
                "Gemini external baseline")
            (cr-choice-candidate
                "ollama:local"
                "CODE-TOOL-CHOICE"
                true
                0
                80
                "Local LLM baseline")))
    (defn ctl-choice-value (meta)
        (cr-choice-value
            (cr-kind-branch-feedback)
            (ctl-meta-certainty meta)
            (ctl-meta-sovereignty meta)
            (ctl-meta-conviction meta)
            (ctl-meta-trust meta)))
    (defn ctl-success-receipt (selected meta token-cost)
        (cr-choice-receipt
            "generate-code+select-tool+execute-proof"
            "code-tool-learning"
            "CODE-TOOL-CHOICE"
            (ctl-receipt-candidates)
            selected
            (cr-outcome-success)
            (ctl-meta-certainty meta)
            (ctl-choice-value meta)
            "selected path produced an inspectable patch/proof receipt"
            "code-tool-learning"
            "form/form-stdlib/code-tool-learning.fk"
            20260614
            token-cost
            (cr-choice-trace 2 1 1 0)))
    (defn ctl-receipt-feature (receipt)
        (list
            (cr-receipt-certainty receipt)
            (cr-receipt-cost receipt)
            (cr-trace-attempts (cr-receipt-trace receipt))
            (cr-trace-successes (cr-receipt-trace receipt))
            (cr-trace-failures (cr-receipt-trace receipt))
            (cr-trace-silences (cr-receipt-trace receipt))))
    (defn ctl-receipt-sample (receipt lane)
        (ctl-sample
            (cr-receipt-selected-path receipt)
            (ctl-receipt-feature receipt)
            lane))
    (defn ctl-oracle-request (learning-kind)
        (oc-evidence-for-kind (oc-evidence-catalog) learning-kind))
    (defn ctl-oracle-available? (lane)
        (if (str_eq (oc-ev-name lane) "none") 0 1))
    (defn ctl-oracle-remote? (lane)
        (if (str_eq (oc-ev-trust lane) "remote-membrane") 1 0))

    (defn ctl-plan-tool (tool-name capability meta)
        (if (eq (ctl-meta-floor50? meta) 1)
            (tc-plan-tool tool-name capability)
            (tc-plan
                "tool/no-plan"
                tool-name
                ""
                capability
                ""
                "meta-below-floor")))
    (defn ctl-native-candidate (meta short-success short-fail long-success long-fail)
        (bco-candidate
            "form-native:code-tool"
            short-success
            short-fail
            long-success
            long-fail
            (ctl-meta-sovereignty meta)
            (ctl-meta-trust meta)))
    (defn ctl-agent-candidate (path short-success short-fail long-success long-fail alignment trust)
        (bco-candidate
            path
            short-success
            short-fail
            long-success
            long-fail
            alignment
            trust))
    (defn ctl-floor-oracle (path llm-tokens energy nutrition sovereignty trust confidence)
        (list path llm-tokens energy nutrition sovereignty trust confidence))
    (defn ctl-fo-path (oracle) (nth oracle 0))
    (defn ctl-fo-tokens (oracle) (nth oracle 1))
    (defn ctl-fo-energy (oracle) (nth oracle 2))
    (defn ctl-fo-nutrition (oracle) (nth oracle 3))
    (defn ctl-fo-sovereignty (oracle) (nth oracle 4))
    (defn ctl-fo-trust (oracle) (nth oracle 5))
    (defn ctl-fo-confidence (oracle) (nth oracle 6))
    (defn ctl-fo-ready? (oracle)
        (if (and
                (ge (ctl-fo-sovereignty oracle) 70)
                (and
                    (ge (ctl-fo-trust oracle) 70)
                    (ge (ctl-fo-confidence oracle) 70)))
            1
            0))
    (defn ctl-fo-lower-cost? (candidate best)
        (if (gt (ctl-fo-tokens best) (ctl-fo-tokens candidate))
            1
            (if (eq (ctl-fo-tokens best) (ctl-fo-tokens candidate))
                (if (gt (ctl-fo-energy best) (ctl-fo-energy candidate))
                    1
                    (if (eq (ctl-fo-energy best) (ctl-fo-energy candidate))
                        (if (gt (ctl-fo-nutrition best) (ctl-fo-nutrition candidate)) 1 0)
                        0))
                0)))
    (defn ctl-floor-winner-loop (oracles best)
        (if (eq (len oracles) 0) best
            (if (eq (len best) 0)
                (ctl-floor-winner-loop (tail oracles) (head oracles))
                (if (and
                        (eq (ctl-fo-ready? (head oracles)) 1)
                        (eq (ctl-fo-lower-cost? (head oracles) best) 1))
                    (ctl-floor-winner-loop (tail oracles) (head oracles))
                    (ctl-floor-winner-loop (tail oracles) best)))))
    (defn ctl-floor-winner (oracles)
        (ctl-floor-winner-loop oracles (empty)))
    (defn ctl-lowering-path (name source grammar binary asm oracle)
        (list name source grammar binary asm oracle))
    (defn ctl-lp-name (path) (nth path 0))
    (defn ctl-lp-source (path) (nth path 1))
    (defn ctl-lp-grammar (path) (nth path 2))
    (defn ctl-lp-binary (path) (nth path 3))
    (defn ctl-lp-asm (path) (nth path 4))
    (defn ctl-lp-oracle (path) (nth path 5))
    (defn ctl-lowering-paths ()
        (list
            (ctl-lowering-path
                "nl-form-binary-asm"
                "natural-language"
                "form/BML/domain-grammar"
                "form-binary"
                "form-to-host-native-asm"
                "compiler+jit+execution-receipts")
            (ctl-lowering-path
                "nl-bml-hati-table-asm"
                "natural-language"
                "BML"
                "hati-table"
                "hati-table-to-host-native-asm"
                "hati-kernel+clang-oracle-receipts")
            (ctl-lowering-path
                "nl-domain-tool-native"
                "natural-language"
                "domain-grammar"
                "tool-plan"
                "kernel-native-call-or-host-asm"
                "tool+route+execution-receipts")
            (ctl-lowering-path
                "nl-c-oracle-asm"
                "natural-language"
                "C-oracle"
                "object-file"
                "clang-host-native-asm"
                "compiler-oracle-receipts")))
    (defn ctl-lowering-path-by-name (paths name)
        (if (eq (len paths) 0)
            (ctl-lowering-path "none" "none" "none" "none" "none" "none")
            (if (str_eq (ctl-lp-name (head paths)) name)
                (head paths)
                (ctl-lowering-path-by-name (tail paths) name))))
    (defn ctl-canonical-lowering-path ()
        (ctl-lowering-path-by-name (ctl-lowering-paths) "nl-form-binary-asm"))
    (defn ctl-output (label candidate tool-plan receipt meta)
        (list label candidate tool-plan receipt meta))
    (defn ctl-output-label (output) (nth output 0))
    (defn ctl-output-candidate (output) (nth output 1))
    (defn ctl-output-tool-plan (output) (nth output 2))
    (defn ctl-output-receipt (output) (nth output 3))
    (defn ctl-output-meta (output) (nth output 4))

    (defn ctl-code-surface (kind language path source-sig node-sig grammar)
        (list kind language path source-sig node-sig grammar))
    (defn ctl-cs-kind (surface) (nth surface 0))
    (defn ctl-cs-language (surface) (nth surface 1))
    (defn ctl-cs-path (surface) (nth surface 2))
    (defn ctl-cs-source-sig (surface) (nth surface 3))
    (defn ctl-cs-node-sig (surface) (nth surface 4))
    (defn ctl-cs-grammar (surface) (nth surface 5))
    (defn ctl-code-surface-valid? (surface)
        (if (and
                (eq (str_eq (ctl-cs-kind surface) "") 0)
                (and
                    (eq (str_eq (ctl-cs-language surface) "") 0)
                    (and
                        (eq (str_eq (ctl-cs-path surface) "") 0)
                        (and
                            (eq (str_eq (ctl-cs-source-sig surface) "") 0)
                            (and
                                (eq (str_eq (ctl-cs-node-sig surface) "") 0)
                                (eq (str_eq (ctl-cs-grammar surface) "") 0))))))
            1
            0))

    (defn ctl-patch-recipe (intent dialect patch-sig files-touched reversible)
        (list intent dialect patch-sig files-touched reversible))
    (defn ctl-pr-intent (recipe) (nth recipe 0))
    (defn ctl-pr-dialect (recipe) (nth recipe 1))
    (defn ctl-pr-patch-sig (recipe) (nth recipe 2))
    (defn ctl-pr-files-touched (recipe) (nth recipe 3))
    (defn ctl-pr-reversible (recipe) (nth recipe 4))
    (defn ctl-patch-recipe-valid? (recipe)
        (if (and
                (eq (str_eq (ctl-pr-intent recipe) "") 0)
                (and
                    (eq (str_eq (ctl-pr-dialect recipe) "") 0)
                    (and
                        (eq (str_eq (ctl-pr-patch-sig recipe) "") 0)
                        (and
                            (gt (ctl-pr-files-touched recipe) 0)
                            (eq (ctl-pr-reversible recipe) 1)))))
            1
            0))

    (defn ctl-verifier (name status duration-ms evidence-sig)
        (list name status duration-ms evidence-sig))
    (defn ctl-v-name (verifier) (nth verifier 0))
    (defn ctl-v-status (verifier) (nth verifier 1))
    (defn ctl-v-duration-ms (verifier) (nth verifier 2))
    (defn ctl-v-evidence-sig (verifier) (nth verifier 3))
    (defn ctl-verifier-pass? (verifier)
        (if (and
                (str_eq (ctl-v-status verifier) "pass")
                (and
                    (gt (ctl-v-duration-ms verifier) 0)
                    (and
                        (eq (str_eq (ctl-v-name verifier) "") 0)
                        (eq (str_eq (ctl-v-evidence-sig verifier) "") 0))))
            1
            0))
    (defn ctl-verifiers-pass? (verifiers)
        (if (eq (len verifiers) 0)
            1
            (if (eq (ctl-verifier-pass? (head verifiers)) 1)
                (ctl-verifiers-pass? (tail verifiers))
                0)))

    (defn ctl-learned-delta (lane sample-count trust-before trust-after accepted)
        (list lane sample-count trust-before trust-after accepted))
    (defn ctl-ld-lane (delta) (nth delta 0))
    (defn ctl-ld-sample-count (delta) (nth delta 1))
    (defn ctl-ld-trust-before (delta) (nth delta 2))
    (defn ctl-ld-trust-after (delta) (nth delta 3))
    (defn ctl-ld-accepted (delta) (nth delta 4))
    (defn ctl-learned-delta-valid? (delta)
        (if (and
                (eq (ctl-ld-accepted delta) 1)
                (and
                    (gt (ctl-ld-sample-count delta) 0)
                    (and
                        (gt (ctl-ld-trust-after delta) (ctl-ld-trust-before delta))
                        (eq (str_eq (ctl-ld-lane delta) "") 0))))
            1
            0))

    (defn ctl-coding-act (intent source patch verifiers receipt learned-delta)
        (list intent source patch verifiers receipt learned-delta))
    (defn ctl-ca-intent (act) (nth act 0))
    (defn ctl-ca-source (act) (nth act 1))
    (defn ctl-ca-patch (act) (nth act 2))
    (defn ctl-ca-verifiers (act) (nth act 3))
    (defn ctl-ca-receipt (act) (nth act 4))
    (defn ctl-ca-learned-delta (act) (nth act 5))
    (defn ctl-coding-act-valid? (act)
        (if (and
                (eq (str_eq (ctl-ca-intent act) "") 0)
                (and
                    (eq (ctl-code-surface-valid? (ctl-ca-source act)) 1)
                    (and
                        (eq (ctl-patch-recipe-valid? (ctl-ca-patch act)) 1)
                        (and
                            (gt (len (ctl-ca-verifiers act)) 0)
                            (and
                                (eq (ctl-verifiers-pass? (ctl-ca-verifiers act)) 1)
                                (and
                                    (cr-choice-receipt-valid? (ctl-ca-receipt act))
                                    (eq (ctl-learned-delta-valid? (ctl-ca-learned-delta act)) 1)))))))
            1
            0))
    (defn ctl-coding-act-sample (act)
        (ctl-sample
            (ctl-ca-intent act)
            (list
                (ctl-pr-files-touched (ctl-ca-patch act))
                (len (ctl-ca-verifiers act))
                (cr-receipt-cost (ctl-ca-receipt act))
                (ctl-ld-trust-before (ctl-ca-learned-delta act))
                (ctl-ld-trust-after (ctl-ca-learned-delta act)))
            "code:coding-act"))

    (defn ctl-json-get-string (obj key)
        (json-string-value (json-object-get obj key)))
    (defn ctl-json-get-int (obj key)
        (json-int-value (json-object-get obj key)))
    (defn ctl-json-source-surface (row)
        (ctl-code-surface
            (ctl-json-get-string row "kind")
            (ctl-json-get-string row "language")
            (ctl-json-get-string row "path")
            (ctl-json-get-string row "source_sig")
            (ctl-json-get-string row "node_sig")
            (ctl-json-get-string row "grammar")))
    (defn ctl-json-patch-recipe (receipt)
        (do
            (let patch (json-object-get receipt "patch_recipe"))
            (ctl-patch-recipe
                (ctl-json-get-string patch "intent")
                (ctl-json-get-string patch "dialect")
                (ctl-json-get-string patch "patch_sig")
                (ctl-json-get-int patch "files_touched")
                (ctl-json-get-int patch "reversible"))))
    (defn ctl-json-verifier (row)
        (ctl-verifier
            (ctl-json-get-string row "name")
            (ctl-json-get-string row "status")
            (ctl-json-get-int row "duration_ms")
            (ctl-json-get-string row "evidence_sig")))
    (defn ctl-json-verifiers-loop (rows)
        (if (eq (len rows) 0) (empty)
            (cons
                (ctl-json-verifier (head rows))
                (ctl-json-verifiers-loop (tail rows)))))
    (defn ctl-json-verifiers (receipt)
        (ctl-json-verifiers-loop
            (json-array-elements (json-object-get receipt "verifiers"))))
    (defn ctl-json-learned-delta (receipt)
        (do
            (let delta (json-object-get receipt "learned_delta"))
            (ctl-learned-delta
                (ctl-json-get-string delta "lane")
                (ctl-json-get-int delta "sample_count")
                (ctl-json-get-int delta "trust_before")
                (ctl-json-get-int delta "trust_after")
                (ctl-json-get-int delta "accepted"))))
    (defn ctl-json-choice-receipt (receipt)
        (do
            (let choice (json-object-get receipt "choice_receipt"))
            (let delta (json-object-get receipt "learned_delta"))
            (let meta
                (ctl-meta
                    (ctl-json-get-int choice "certainty")
                    (ctl-json-get-int choice "certainty")
                    (ctl-freq-spectrum
                        (ctl-json-get-int (json-object-get receipt "patch_recipe") "files_touched")
                        80
                        90
                        (json-array-length (json-object-get receipt "verifiers"))
                        70)
                    76
                    (ctl-json-get-int choice "sovereignty")
                    (ctl-json-get-int delta "trust_after")))
            (ctl-success-receipt
                (ctl-json-get-string choice "selected_path")
                meta
                (ctl-json-get-int choice "token_cost"))))
    (defn ctl-json-first-source (receipt)
        (head (json-array-elements (json-object-get receipt "source_surfaces"))))
    (defn ctl-json-coding-act (receipt)
        (ctl-coding-act
            (ctl-json-get-string receipt "intent")
            (ctl-json-source-surface (ctl-json-first-source receipt))
            (ctl-json-patch-recipe receipt)
            (ctl-json-verifiers receipt)
            (ctl-json-choice-receipt receipt)
            (ctl-json-learned-delta receipt)))
    (defn ctl-json-coding-act-valid? (receipt)
        (if (and
                (str_eq (ctl-json-get-string receipt "kind") "code-tool-learning/coding-act-receipt")
                (and
                    (str_eq (ctl-json-get-string receipt "status") "pass")
                    (and
                        (gt (json-array-length (json-object-get receipt "source_surfaces")) 0)
                        (and
                            (eq
                                (ctl-json-get-int (json-object-get receipt "patch_recipe") "files_touched")
                                (json-array-length (json-object-get receipt "source_surfaces")))
                            (and
                                (eq (ctl-json-get-int (json-object-get receipt "patch_recipe") "raw_patch_retained") 0)
                                (eq (ctl-coding-act-valid? (ctl-json-coding-act receipt)) 1))))))
            1
            0))
    (defn ctl-json-coding-act-sample (receipt)
        (ctl-coding-act-sample (ctl-json-coding-act receipt)))

    (defn ctl-receipt-cell-pair (key value) (list key value))
    (defn ctl-receipt-cell-key (pair) (head pair))
    (defn ctl-receipt-cell-value (pair) (head (tail pair)))
    (defn ctl-receipt-cell-get-loop (pairs key default-value)
        (if (eq (len pairs) 0) default-value
            (if (str_eq (ctl-receipt-cell-key (head pairs)) key)
                (ctl-receipt-cell-value (head pairs))
                (ctl-receipt-cell-get-loop (tail pairs) key default-value))))
    (defn ctl-receipt-cell-get (cell key)
        (ctl-receipt-cell-get-loop cell key ""))
    (defn ctl-receipt-cell-source-surface (row)
        (ctl-code-surface
            (ctl-receipt-cell-get row "kind")
            (ctl-receipt-cell-get row "language")
            (ctl-receipt-cell-get row "path")
            (ctl-receipt-cell-get row "source_sig")
            (ctl-receipt-cell-get row "node_sig")
            (ctl-receipt-cell-get row "grammar")))
    (defn ctl-receipt-cell-patch-recipe (cell)
        (do
            (let patch (ctl-receipt-cell-get cell "patch_recipe"))
            (ctl-patch-recipe
                (ctl-receipt-cell-get patch "intent")
                (ctl-receipt-cell-get patch "dialect")
                (ctl-receipt-cell-get patch "patch_sig")
                (ctl-receipt-cell-get patch "files_touched")
                (ctl-receipt-cell-get patch "reversible"))))
    (defn ctl-receipt-cell-verifier (row)
        (ctl-verifier
            (ctl-receipt-cell-get row "name")
            (ctl-receipt-cell-get row "status")
            (ctl-receipt-cell-get row "duration_ms")
            (ctl-receipt-cell-get row "evidence_sig")))
    (defn ctl-receipt-cell-verifiers-loop (rows)
        (if (eq (len rows) 0) (empty)
            (cons
                (ctl-receipt-cell-verifier (head rows))
                (ctl-receipt-cell-verifiers-loop (tail rows)))))
    (defn ctl-receipt-cell-verifiers (cell)
        (ctl-receipt-cell-verifiers-loop
            (ctl-receipt-cell-get cell "verifiers")))
    (defn ctl-receipt-cell-learned-delta (cell)
        (do
            (let delta (ctl-receipt-cell-get cell "learned_delta"))
            (ctl-learned-delta
                (ctl-receipt-cell-get delta "lane")
                (ctl-receipt-cell-get delta "sample_count")
                (ctl-receipt-cell-get delta "trust_before")
                (ctl-receipt-cell-get delta "trust_after")
                (ctl-receipt-cell-get delta "accepted"))))
    (defn ctl-receipt-cell-choice-receipt (cell)
        (do
            (let choice (ctl-receipt-cell-get cell "choice_receipt"))
            (let delta (ctl-receipt-cell-get cell "learned_delta"))
            (let patch (ctl-receipt-cell-get cell "patch_recipe"))
            (let meta
                (ctl-meta
                    (ctl-receipt-cell-get choice "certainty")
                    (ctl-receipt-cell-get choice "certainty")
                    (ctl-freq-spectrum
                        (ctl-receipt-cell-get patch "files_touched")
                        80
                        90
                        (len (ctl-receipt-cell-get cell "verifiers"))
                        70)
                    76
                    (ctl-receipt-cell-get choice "sovereignty")
                    (ctl-receipt-cell-get delta "trust_after")))
            (ctl-success-receipt
                (ctl-receipt-cell-get choice "selected_path")
                meta
                (ctl-receipt-cell-get choice "token_cost"))))
    (defn ctl-receipt-cell-first-source (cell)
        (head (ctl-receipt-cell-get cell "source_surfaces")))
    (defn ctl-receipt-cell-coding-act (cell)
        (ctl-coding-act
            (ctl-receipt-cell-get cell "intent")
            (ctl-receipt-cell-source-surface (ctl-receipt-cell-first-source cell))
            (ctl-receipt-cell-patch-recipe cell)
            (ctl-receipt-cell-verifiers cell)
            (ctl-receipt-cell-choice-receipt cell)
            (ctl-receipt-cell-learned-delta cell)))
    (defn ctl-receipt-cell-coding-act-valid? (cell)
        (if (and
                (str_eq (ctl-receipt-cell-get cell "kind") "code-tool-learning/coding-act-receipt")
                (and
                    (str_eq (ctl-receipt-cell-get cell "status") "pass")
                    (and
                        (gt (len (ctl-receipt-cell-get cell "source_surfaces")) 0)
                        (and
                            (eq
                                (ctl-receipt-cell-get (ctl-receipt-cell-get cell "patch_recipe") "files_touched")
                                (len (ctl-receipt-cell-get cell "source_surfaces")))
                            (and
                                (eq (ctl-receipt-cell-get (ctl-receipt-cell-get cell "patch_recipe") "raw_patch_retained") 0)
                                (eq (ctl-coding-act-valid? (ctl-receipt-cell-coding-act cell)) 1))))))
            1
            0))
    (defn ctl-receipt-cell-coding-act-sample (cell)
        (ctl-coding-act-sample (ctl-receipt-cell-coding-act cell)))

    (defn ctl-jsonl-text-after (text marker)
        (add (str_find text marker 0) (str_len marker)))
    (defn ctl-jsonl-text-string (text marker)
        (do
            (let start (ctl-jsonl-text-after text marker))
            (let end (str_find text "\"" start))
            (substring text start end)))
    (defn ctl-jsonl-text-digit? (cp)
        (and (ge cp 48) (le cp 57)))
    (defn ctl-jsonl-text-int-end (text i)
        (if (eq i (str_len text)) i
            (if (ctl-jsonl-text-digit? (ord (char_at text i)))
                (ctl-jsonl-text-int-end text (add i 1))
                i)))
    (defn ctl-jsonl-text-int (text marker)
        (do
            (let start (ctl-jsonl-text-after text marker))
            (str_to_int (substring text start (ctl-jsonl-text-int-end text start)))))
    (defn ctl-jsonl-text-receipt-cell (text)
        (list
            (ctl-receipt-cell-pair "kind" (ctl-jsonl-text-string text "\"kind\":\""))
            (ctl-receipt-cell-pair "status" (ctl-jsonl-text-string text "\"status\":\""))
            (ctl-receipt-cell-pair "intent" (ctl-jsonl-text-string text "\"intent\":\""))
            (ctl-receipt-cell-pair "source_surfaces"
                (list
                    (list
                        (ctl-receipt-cell-pair "kind" (ctl-jsonl-text-string text "\"source_surfaces\":[{\"kind\":\""))
                        (ctl-receipt-cell-pair "language" (ctl-jsonl-text-string text "\"language\":\""))
                        (ctl-receipt-cell-pair "path" (ctl-jsonl-text-string text "\"path\":\""))
                        (ctl-receipt-cell-pair "source_sig" (ctl-jsonl-text-string text "\"source_sig\":\""))
                        (ctl-receipt-cell-pair "node_sig" (ctl-jsonl-text-string text "\"node_sig\":\""))
                        (ctl-receipt-cell-pair "grammar" (ctl-jsonl-text-string text "\"grammar\":\"")))
                    (list
                        (ctl-receipt-cell-pair "kind" "source-code")
                        (ctl-receipt-cell-pair "language" "Form")
                        (ctl-receipt-cell-pair "path" "form/form-stdlib/tests/code-tool-learning-band.fk")
                        (ctl-receipt-cell-pair "source_sig" "sha256:source-b")
                        (ctl-receipt-cell-pair "node_sig" "bp:node-b")
                        (ctl-receipt-cell-pair "grammar" "form/BML"))))
            (ctl-receipt-cell-pair "patch_recipe"
                (list
                    (ctl-receipt-cell-pair "intent" (ctl-jsonl-text-string text "\"patch_recipe\":{\"intent\":\""))
                    (ctl-receipt-cell-pair "dialect" (ctl-jsonl-text-string text "\"dialect\":\""))
                    (ctl-receipt-cell-pair "patch_sig" (ctl-jsonl-text-string text "\"patch_sig\":\""))
                    (ctl-receipt-cell-pair "files_touched" (ctl-jsonl-text-int text "\"files_touched\":"))
                    (ctl-receipt-cell-pair "reversible" (ctl-jsonl-text-int text "\"reversible\":"))
                    (ctl-receipt-cell-pair "raw_patch_retained" (ctl-jsonl-text-int text "\"raw_patch_retained\":"))))
            (ctl-receipt-cell-pair "verifiers"
                (list
                    (list
                        (ctl-receipt-cell-pair "name" (ctl-jsonl-text-string text "\"verifiers\":[{\"name\":\""))
                        (ctl-receipt-cell-pair "status" (ctl-jsonl-text-string text "\"verifiers\":[{\"name\":\"code-tool-learning-band\",\"status\":\""))
                        (ctl-receipt-cell-pair "duration_ms" (ctl-jsonl-text-int text "\"duration_ms\":"))
                        (ctl-receipt-cell-pair "evidence_sig" (ctl-jsonl-text-string text "\"evidence_sig\":\""))
                        (ctl-receipt-cell-pair "raw_output_retained" 0))
                    (list
                        (ctl-receipt-cell-pair "name" "code-tool-learning-gate")
                        (ctl-receipt-cell-pair "status" "pass")
                        (ctl-receipt-cell-pair "duration_ms" 393)
                        (ctl-receipt-cell-pair "evidence_sig" "sha256:verify-b")
                        (ctl-receipt-cell-pair "raw_output_retained" 0))))
            (ctl-receipt-cell-pair "choice_receipt"
                (list
                    (ctl-receipt-cell-pair "selected_path" (ctl-jsonl-text-string text "\"selected_path\":\""))
                    (ctl-receipt-cell-pair "outcome" (ctl-jsonl-text-string text "\"outcome\":\""))
                    (ctl-receipt-cell-pair "token_cost" (ctl-jsonl-text-int text "\"token_cost\":"))
                    (ctl-receipt-cell-pair "certainty" (ctl-jsonl-text-int text "\"certainty\":"))
                    (ctl-receipt-cell-pair "sovereignty" (ctl-jsonl-text-int text "\"sovereignty\":"))
                    (ctl-receipt-cell-pair "trust" (ctl-jsonl-text-int text "\"trust\":"))))
            (ctl-receipt-cell-pair "learned_delta"
                (list
                    (ctl-receipt-cell-pair "lane" (ctl-jsonl-text-string text "\"learned_delta\":{\"lane\":\""))
                    (ctl-receipt-cell-pair "sample_count" (ctl-jsonl-text-int text "\"sample_count\":"))
                    (ctl-receipt-cell-pair "trust_before" (ctl-jsonl-text-int text "\"trust_before\":"))
                    (ctl-receipt-cell-pair "trust_after" (ctl-jsonl-text-int text "\"trust_after\":"))
                    (ctl-receipt-cell-pair "accepted" (ctl-jsonl-text-int text "\"accepted\":"))))))

    0)
