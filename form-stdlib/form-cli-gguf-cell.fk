        (do
            (let out0 (fc-kv-line "full_width_model_logit_generation_verified" (fc-gg-bool ok)))
            (let out1 (str_concat out0 (fc-kv-line "full_width_logit_generation_source" "fkwu-read_file_slice-real-gguf-token-embedding-q6k-dot4")))
            (let out2 (str_concat out1 (fc-kv-line "full_width_logit_generation_scope" "full-vocabulary-real-gguf-token-embedding-projection")))
