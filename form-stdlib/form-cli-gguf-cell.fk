            (let out27 (str_concat out26 (fc-kv-line "full_width_token_text_expected_sha256" token-sha)))
            (let out28 (str_concat out27 (fc-kv-line "decoded_token_text" token-text)))
            (let out29 (str_concat out28 (fc-kv-line "full_width_logits_generated_in_form" "true")))
            (let out30 (str_concat out29 (fc-kv-line "full_width_model_logits" "true")))
            (let out31 (str_concat out30 (fc-kv-line "full_vocabulary_logits" "true")))
            (let out32 (str_concat out31 (fc-kv-line "full_model_logits" "false")))
            (let out33 (str_concat out32 (fc-kv-line "full_llama_hidden_state_logits" "false")))
            (let out34 (str_concat out33 (fc-kv-line "full_width_logit_accelerator_buffers" "false")))
            (str_concat out34
                (if (eq ok 1)
                    "PASS fkwu-form-cli-gguf-fullwidth-logits"
                    "FAIL fkwu-form-cli-gguf-fullwidth-logits"))))

    (defn fc-gguf-fullwidth-logits-cell (arg)
        (if (str_eq arg "")
            "usage: gguf-fullwidth-logits-cell <manifest-path>"
            (do
                (let manifest (fc-gg-strip-eol (read_file arg)))
                (let parts (split-on manifest " "))
                (let kind (fc-part parts 0 ""))
                (let expected-sha (fc-part parts 1 ""))
                (let gguf-path (fc-part parts 2 ""))
                (let file-size-str (fc-part parts 3 "0"))
                (let token-count-str (fc-part parts 4 "0"))
                (let selected-id-str (fc-part parts 5 "0"))
                (let selected-logit-str (fc-part parts 6 "0"))
                (let token-index-str (fc-part parts 7 "0"))
                (let token-entry-start-str (fc-part parts 8 "0"))
                (let token-len-str (fc-part parts 9 "0"))
                (let token-sha (fc-part parts 10 ""))
                (let tensor-name (fc-part parts 11 ""))
                (let tensor-index-str (fc-part parts 12 "0"))
                (let tensor-type-str (fc-part parts 13 "0"))
                (let tensor-start-str (fc-part parts 14 "0"))
                (let row-stride-str (fc-part parts 15 "0"))
                (let block-len-str (fc-part parts 16 "0"))
                (let projection-name (fc-part parts 17 ""))
                (let file-size (str_to_int file-size-str))
                (let token-count (str_to_int token-count-str))
                (let selected-token-id (str_to_int selected-id-str))
                (let expected-selected-logit (str_to_int selected-logit-str))
                (let token-index (str_to_int token-index-str))
                (let token-entry-start (str_to_int token-entry-start-str))
                (let token-len (str_to_int token-len-str))
                (let tensor-index (str_to_int tensor-index-str))
                (let tensor-type (str_to_int tensor-type-str))
                (let tensor-start (str_to_int tensor-start-str))
                (let row-stride (str_to_int row-stride-str))
                (let block-len (str_to_int block-len-str))
                (if (or (or (str_eq kind "") (str_eq expected-sha ""))
                        (or (str_eq gguf-path "") (or (str_eq token-sha "") (or (str_eq tensor-name "") (str_eq projection-name "")))))
                    "FAIL gguf-fullwidth-logits manifest expected: gguf-fullwidth-logits-cell-v1 <sha256> <gguf-path> <file-size> <token-count> <selected-token-id> <selected-logit-micro> <token-array-index> <token-entry-start> <token-len> <token-sha256> <tensor-name> <tensor-index> <tensor-type> <tensor-start> <row-stride> <block-len> <projection-name>"
                    (if (str_eq kind "gguf-fullwidth-logits-cell-v1")
                        (do
                            (let actual-file-size (file_size gguf-path))
                            (let canonical (fc-gg-fw-canonical gguf-path file-size-str token-count-str selected-id-str selected-logit-str token-index-str token-entry-start-str token-len-str token-sha tensor-name tensor-index-str tensor-type-str tensor-start-str row-stride-str block-len-str projection-name))
                            (let actual-sha (fc-gg-cell-digest canonical))
                            (let token-text-start (add token-entry-start 8))
                            (let token-end (add token-text-start token-len))
                            (let source-end (add tensor-start (add (mul (sub token-count 1) row-stride) block-len)))
                            (let prelim-ok
                                (if (and (str_eq expected-sha actual-sha)
                                    (and (eq actual-file-size file-size)
                                    (and (gt token-count 0)
                                    (and (ge selected-token-id 0)
                                    (and (lt selected-token-id token-count)
                                    (and (eq selected-token-id token-index)
                                    (and (ge token-entry-start 0)
                                    (and (gt token-len 0)
                                    (and (ge file-size token-end)
                                    (and (eq tensor-type 14)
                                    (and (ge tensor-start 0)
                                    (and (ge row-stride block-len)
                                    (and (eq block-len 210)
                                         (ge file-size source-end)))))))))))))) 1 0))
                            (if (eq prelim-ok 0)
                                (fc-gguf-fullwidth-logits-report 0 expected-sha actual-sha gguf-path file-size actual-file-size token-count selected-token-id expected-selected-logit 0 token-index token-entry-start token-text-start token-len 0 0 token-sha "" tensor-name tensor-index tensor-type tensor-start row-stride block-len source-end 0 "")
                                (do
                                    (let len-raw (read_file_slice gguf-path token-entry-start 8))
                                    (let token-raw (read_file_slice gguf-path token-text-start token-len))
                                    (let len-bytes (fc-gg-string-bytes len-raw))
                                    (let declared-token-len (fc-gg-u64 len-bytes 0))
                                    (let actual-token-len (str_len token-raw))
                                    (let actual-token-sha (fc-gg-cell-digest token-raw))
                                    (let argmax-token-id (fc-gg-fw-best-id gguf-path tensor-start row-stride block-len token-count))
                                    (let selected-logit (fc-gg-fw-source-logit gguf-path tensor-start row-stride block-len selected-token-id))
                                    (let ok (if (and (eq declared-token-len token-len)
                                                (and (eq actual-token-len token-len)
                                                (and (str_eq actual-token-sha token-sha)
                                                (and (eq argmax-token-id selected-token-id)
                                                     (eq selected-logit expected-selected-logit))))) 1 0))
                                    (fc-gguf-fullwidth-logits-report ok expected-sha actual-sha gguf-path file-size actual-file-size token-count selected-token-id expected-selected-logit selected-logit token-index token-entry-start token-text-start token-len declared-token-len actual-token-len token-sha actual-token-sha tensor-name tensor-index tensor-type tensor-start row-stride block-len source-end argmax-token-id token-raw))))
                        (str_concat "FAIL gguf-fullwidth-logits manifest kind=" kind))))))

    (defn fc-gguf-tensor-slice-math (arg)
        (if (str_eq arg "")
            "usage: gguf-tensor-slice-math <manifest-path>"
            (do
                (let manifest (fc-gg-strip-eol (read_file arg)))
                (let parts (split-on manifest " "))
                (let kind (fc-part parts 0 ""))
                (let expected-sha (fc-part parts 1 ""))
                (let gguf-path (fc-part parts 2 ""))
                (let tensor-name (fc-part parts 3 ""))
                (let tensor-index (fc-part-int parts 4 0))
                (let tensor-type (fc-part-int parts 5 0))
                (let dim0 (fc-part-int parts 6 0))
                (let absolute-start (fc-part-int parts 7 0))
                (let slice-len (fc-part-int parts 8 0))
                (let file-size (fc-part-int parts 9 0))
                (let exp-q0 (fc-part-int parts 10 0))
                (let exp-q31 (fc-part-int parts 11 0))
                (let exp-q255 (fc-part-int parts 12 0))
                (let exp-dot1 (fc-part-int parts 13 0))
                (let exp-dot4 (fc-part-int parts 14 0))
                (if (or (or (str_eq kind "") (str_eq expected-sha ""))
                        (or (str_eq gguf-path "") (str_eq tensor-name "")))
                    "FAIL gguf-tensor-slice manifest expected: gguf-tensor-slice-math-v1 <slice-sha256> <gguf-path> <tensor-name> <tensor-index> <tensor-type> <dim0> <absolute-start> <slice-len> <file-size> <q0-micro> <q31-micro> <q255-micro> <dot1-micro> <dot4-micro>"
                    (if (str_eq kind "gguf-tensor-slice-math-v1")
                        (do
                            (let actual-file-size (file_size gguf-path))
                            (let slice-raw (read_file_slice gguf-path absolute-start slice-len))
                            (let actual-len (str_len slice-raw))
                            (let actual-sha (fc-gg-cell-digest slice-raw))
                            (if (or (not (str_eq expected-sha actual-sha))
                                    (or (not (eq actual-len slice-len))
                                    (or (not (eq actual-file-size file-size))
                                    (or (not (eq tensor-type 14))
                                        (lt actual-len 210)))))
                                (fc-gguf-tensor-slice-fail expected-sha actual-sha gguf-path tensor-name tensor-index tensor-type dim0 absolute-start slice-len file-size actual-file-size actual-len)
                                (do
                                    (let bytes (fc-gg-string-bytes slice-raw))
                                    (let full (wl-load-q6k bytes 0))
                                    (let q0 (fc-gg-micro (wl-q6k-at bytes 0 0)))
                                    (let q31 (fc-gg-micro (wl-q6k-at bytes 0 31)))
                                    (let q255 (fc-gg-micro (wl-q6k-at bytes 0 255)))
                                    (let dot1 (fc-gg-micro (wl-q6k-at bytes 0 0)))
                                    (let dot4 (fc-gg-micro (fc-gg-q6k-dot4 bytes)))
                                    (let full-len (len full))
                                    (let math-ok (if (and (eq q0 exp-q0)
                                                    (and (eq q31 exp-q31)
                                                    (and (eq q255 exp-q255)
                                                    (and (eq dot1 exp-dot1)
                                                    (and (eq dot4 exp-dot4)
                                                         (eq full-len 256)))))) 1 0))
                                    (fc-gguf-tensor-slice-report math-ok expected-sha actual-sha gguf-path tensor-name tensor-index tensor-type dim0 absolute-start slice-len file-size actual-file-size actual-len q0 q31 q255 dot1 dot4 full-len exp-q0 exp-q31 exp-q255 exp-dot1 exp-dot4))))
                        (str_concat "FAIL gguf-tensor-slice manifest kind=" kind))))))
    0)
