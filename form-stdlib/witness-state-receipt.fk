; witness-state-receipt.fk - Form-native live witness counter receipt rows.
;
; Floor: live Mac witness /state counters are represented as summary-only Form
; rows that can be validated and turned into android-mesh-learning active sample
; rows without extending the Python receipt helper.
;
; North star: the witness exports these rows directly into the substrate/native
; recipe ledger, so speech, vision, multimodal, GPU, and model learners consume
; live counters as first-class receipts instead of ad hoc JSON/JQ evidence.
;
; Proven by: form-stdlib/tests/witness-state-receipt-band.fk

(do
    (defn wsr-floor ()
        (list
            "live witness state counters have a Form-native receipt row"
            "mic camera and gpu counters lower into summary-only active sample rows"
            "the exporter source is Form-native; Python remains only a compatibility helper"
            "heldout learner rows score native challengers against explicit oracle teachers"
            "oracle teacher labels must be backed by native witness export receipts, not fixtures"
            "live oracle processes emit source-backed label rows across increasing witness export cycles"))
    (defn wsr-north-star ()
        (list
            "Mac witness writes native receipt cells continuously"
            "Android and Mac active counters feed heldout speech vision multimodal and gpu learners"
            "raw audio frames and buffers stay outside durable receipt storage"))

    (defn wsr-state (source present frames mic-rms-ppm camera-luma-ppm camera-samples gpu-samples gpu-latency-us sample-count active-organs privacy)
        (list source present frames mic-rms-ppm camera-luma-ppm camera-samples gpu-samples gpu-latency-us sample-count active-organs privacy))
    (defn wsr-source (state) (nth state 0))
    (defn wsr-present? (state) (nth state 1))
    (defn wsr-frames (state) (nth state 2))
    (defn wsr-mic-rms-ppm (state) (nth state 3))
    (defn wsr-camera-luma-ppm (state) (nth state 4))
    (defn wsr-camera-samples (state) (nth state 5))
    (defn wsr-gpu-samples (state) (nth state 6))
    (defn wsr-gpu-latency-us (state) (nth state 7))
    (defn wsr-sample-count (state) (nth state 8))
    (defn wsr-active-organs (state) (nth state 9))
    (defn wsr-privacy (state) (nth state 10))

    (defn wsr-live? (state)
        (if (and
                (eq (wsr-present? state) 1)
                (gt (wsr-frames state) 0))
            1
            0))
    (defn wsr-summary-only? (state)
        (if (and
                (not (str_eq (wsr-privacy state) ""))
                (not (str_eq (wsr-privacy state) "raw-media")))
            1
            0))
    (defn wsr-export-native? (state)
        (if (and
                (str_eq (wsr-source state) "form-native-witness-state")
                (not (str_eq (wsr-source state) "python-helper")))
            1
            0))

    (defn wsr-has-organ? (organs name)
        (if (eq (len organs) 0) 0
            (if (str_eq (head organs) name)
                1
                (wsr-has-organ? (tail organs) name))))
    (defn wsr-mic-active? (state)
        (if (and
                (gt (wsr-mic-rms-ppm state) 0)
                (eq (wsr-has-organ? (wsr-active-organs state) "mic") 1))
            1
            0))
    (defn wsr-camera-active? (state)
        (if (and
                (gt (wsr-camera-luma-ppm state) 0)
                (and
                    (gt (wsr-camera-samples state) 0)
                    (eq (wsr-has-organ? (wsr-active-organs state) "camera") 1)))
            1
            0))
    (defn wsr-gpu-active? (state)
        (if (and
                (gt (wsr-gpu-samples state) 0)
                (and
                    (gt (wsr-gpu-latency-us state) 0)
                    (eq (wsr-has-organ? (wsr-active-organs state) "gpu") 1)))
            1
            0))

    (defn wsr-active-samples (state)
        (list
            (aml-mic-rms-sample (wsr-frames state) (wsr-mic-rms-ppm state))
            (aml-camera-luma-sample (wsr-camera-samples state) (wsr-camera-luma-ppm state))
            (aml-gpu-readback-sample (wsr-gpu-samples state) (wsr-gpu-latency-us state))))
    (defn wsr-active-media-floor? (state)
        (if (and
                (eq (wsr-live? state) 1)
                (and
                    (eq (wsr-summary-only? state) 1)
                    (and
                        (eq (wsr-mic-active? state) 1)
                        (and
                            (eq (wsr-camera-active? state) 1)
                            (eq (wsr-gpu-active? state) 1)))))
            1
            0))
    (defn wsr-count-floor? (state min-frames min-camera min-gpu min-total)
        (if (and
                (ge (wsr-frames state) min-frames)
                (and
                    (ge (wsr-camera-samples state) min-camera)
                    (and
                        (ge (wsr-gpu-samples state) min-gpu)
                        (ge (wsr-sample-count state) min-total))))
            1
            0))
    (defn wsr-routes-native-first? (state)
        (if (and
                (str_eq (aml-active-route-choice "speech-transcribe" (wsr-active-samples state) 12 30 78) "native-first")
                (and
                    (str_eq (aml-active-route-choice "vision-describe" (wsr-active-samples state) 30 55 80) "native-first")
                    (str_eq (aml-active-route-choice "multimodal-align" (wsr-active-samples state) 30 70 80) "native-first")))
            1
            0))
    (defn wsr-heldout-retirement-ready? (history min-samples margin)
        (aml-retire? history min-samples margin))
    (defn wsr-learning-ready? (state)
        (if (and
                (eq (wsr-active-media-floor? state) 1)
                (and
                    (eq (wsr-export-native? state) 1)
                    (eq (wsr-routes-native-first? state) 1)))
            1
            0))

    (defn wsr-heldout-row (feature lane count metric native-score oracle-score champion-correct challenger-correct privacy)
        (list feature lane count metric native-score oracle-score champion-correct challenger-correct privacy))
    (defn wsr-heldout-feature (row) (nth row 0))
    (defn wsr-heldout-lane (row) (nth row 1))
    (defn wsr-heldout-count (row) (nth row 2))
    (defn wsr-heldout-metric (row) (nth row 3))
    (defn wsr-heldout-native-score (row) (nth row 4))
    (defn wsr-heldout-oracle-score (row) (nth row 5))
    (defn wsr-heldout-champion-correct (row) (nth row 6))
    (defn wsr-heldout-challenger-correct (row) (nth row 7))
    (defn wsr-heldout-privacy (row) (nth row 8))

    (defn wsr-heldout-from-state (feature state native-score oracle-score champion-correct challenger-correct)
        (if (str_eq feature "speech-transcribe")
            (wsr-heldout-row feature "mic" (wsr-frames state) (wsr-mic-rms-ppm state) native-score oracle-score champion-correct challenger-correct (wsr-privacy state))
            (if (str_eq feature "vision-describe")
                (wsr-heldout-row feature "camera" (wsr-camera-samples state) (wsr-camera-luma-ppm state) native-score oracle-score champion-correct challenger-correct (wsr-privacy state))
                (if (str_eq feature "multimodal-align")
                    (wsr-heldout-row feature "mic+camera+gpu" (wsr-sample-count state) (wsr-sample-count state) native-score oracle-score champion-correct challenger-correct (wsr-privacy state))
                    (wsr-heldout-row feature "gpu" (wsr-gpu-samples state) (wsr-gpu-latency-us state) native-score oracle-score champion-correct challenger-correct (wsr-privacy state))))))
    (defn wsr-heldout-valid? (row)
        (if (and
                (gt (wsr-heldout-count row) 0)
                (and
                    (gt (wsr-heldout-metric row) 0)
                    (and
                        (gt (wsr-heldout-native-score row) 0)
                        (and
                            (gt (wsr-heldout-oracle-score row) 0)
                            (not (str_eq (wsr-heldout-privacy row) "raw-media"))))))
            1
            0))
    (defn wsr-heldout-trial (row)
        (list (wsr-heldout-champion-correct row) (wsr-heldout-challenger-correct row)))
    (defn wsr-heldout-history (rows)
        (if (eq (len rows) 0)
            (empty)
            (cons (wsr-heldout-trial (head rows)) (wsr-heldout-history (tail rows)))))
    (defn wsr-heldout-valid-count (rows)
        (if (eq (len rows) 0) 0
            (add
                (wsr-heldout-valid? (head rows))
                (wsr-heldout-valid-count (tail rows)))))
    (defn wsr-heldout-all-valid? (rows)
        (if (eq (len rows) 0) 1
            (if (eq (wsr-heldout-valid? (head rows)) 1)
                (wsr-heldout-all-valid? (tail rows))
                0)))
    (defn wsr-heldout-learning-floor? (state rows)
        (if (and
                (eq (wsr-learning-ready? state) 1)
                (and
                    (eq (wsr-heldout-all-valid? rows) 1)
                    (ge (wsr-heldout-valid-count rows) 3)))
            1
            0))
    (defn wsr-heldout-retire? (rows min-samples margin)
        (wsr-heldout-retirement-ready? (wsr-heldout-history rows) min-samples margin))
    (defn wsr-heldout-authority (rows min-samples margin)
        (aml-authority (wsr-heldout-history rows) min-samples margin))
    (defn wsr-heldout-native-wins? (rows min-samples margin)
        (if (and
                (eq (wsr-heldout-retire? rows min-samples margin) 1)
                (str_eq (wsr-heldout-authority rows min-samples margin) "native"))
            1
            0))

    (defn wsr-export-row (source transport seq frames sample-count checksum privacy)
        (list source transport seq frames sample-count checksum privacy))
    (defn wsr-export-source (row) (nth row 0))
    (defn wsr-export-transport (row) (nth row 1))
    (defn wsr-export-seq (row) (nth row 2))
    (defn wsr-export-frames (row) (nth row 3))
    (defn wsr-export-sample-count (row) (nth row 4))
    (defn wsr-export-checksum (row) (nth row 5))
    (defn wsr-export-privacy (row) (nth row 6))
    (defn wsr-export-valid? (row)
        (if (and
                (str_eq (wsr-export-source row) "native-witness-export")
                (and
                    (not (str_eq (wsr-export-transport row) ""))
                    (and
                        (gt (wsr-export-seq row) 0)
                        (and
                            (gt (wsr-export-frames row) 0)
                            (and
                                (gt (wsr-export-sample-count row) 0)
                                (and
                                    (not (str_eq (wsr-export-checksum row) ""))
                                    (not (str_eq (wsr-export-privacy row) "raw-media"))))))))
            1
            0))

    (defn wsr-oracle-label (feature provider protocol label confidence export-seq sample-ref privacy)
        (list feature provider protocol label confidence export-seq sample-ref privacy))
    (defn wsr-oracle-feature (label) (nth label 0))
    (defn wsr-oracle-provider (label) (nth label 1))
    (defn wsr-oracle-protocol (label) (nth label 2))
    (defn wsr-oracle-label-value (label) (nth label 3))
    (defn wsr-oracle-confidence (label) (nth label 4))
    (defn wsr-oracle-export-seq (label) (nth label 5))
    (defn wsr-oracle-sample-ref (label) (nth label 6))
    (defn wsr-oracle-privacy (label) (nth label 7))
    (defn wsr-oracle-label-valid? (label export)
        (if (and
                (eq (wsr-export-valid? export) 1)
                (and
                    (not (str_eq (wsr-oracle-provider label) "fixture"))
                    (and
                        (not (str_eq (wsr-oracle-protocol label) ""))
                        (and
                            (not (str_eq (wsr-oracle-label-value label) ""))
                            (and
                                (ge (wsr-oracle-confidence label) 70)
                                (and
                                    (eq (wsr-oracle-export-seq label) (wsr-export-seq export))
                                    (and
                                        (not (str_eq (wsr-oracle-sample-ref label) ""))
                                        (not (str_eq (wsr-oracle-privacy label) "raw-media")))))))))
            1
            0))
    (defn wsr-heldout-from-oracle-label (label state native-score challenger-correct)
        (wsr-heldout-from-state
            (wsr-oracle-feature label)
            state
            native-score
            (wsr-oracle-confidence label)
            1
            challenger-correct))
    (defn wsr-oracle-heldout-valid? (row label export)
        (if (and
                (eq (wsr-heldout-valid? row) 1)
                (and
                    (eq (wsr-oracle-label-valid? label export) 1)
                    (str_eq (wsr-heldout-feature row) (wsr-oracle-feature label))))
            1
            0))
    (defn wsr-oracle-label-count (labels export)
        (if (eq (len labels) 0) 0
            (add
                (wsr-oracle-label-valid? (head labels) export)
                (wsr-oracle-label-count (tail labels) export))))
    (defn wsr-oracle-labels-all-valid? (labels export)
        (if (eq (len labels) 0) 1
            (if (eq (wsr-oracle-label-valid? (head labels) export) 1)
                (wsr-oracle-labels-all-valid? (tail labels) export)
                0)))
    (defn wsr-source-backed-learning-floor? (state export labels rows)
        (if (and
                (eq (wsr-learning-ready? state) 1)
                (and
                    (eq (wsr-export-valid? export) 1)
                    (and
                        (eq (wsr-oracle-labels-all-valid? labels export) 1)
                        (and
                            (ge (wsr-oracle-label-count labels export) 4)
                            (eq (wsr-heldout-learning-floor? state rows) 1)))))
            1
            0))
    (defn wsr-source-backed-native-wins? (state export labels rows min-samples margin)
        (if (and
                (eq (wsr-source-backed-learning-floor? state export labels rows) 1)
                (eq (wsr-heldout-native-wins? rows min-samples margin) 1))
            1
            0))

    (defn wsr-oracle-process (feature provider protocol status confidence-floor privacy)
        (list feature provider protocol status confidence-floor privacy))
    (defn wsr-process-feature (row) (nth row 0))
    (defn wsr-process-provider (row) (nth row 1))
    (defn wsr-process-protocol (row) (nth row 2))
    (defn wsr-process-status (row) (nth row 3))
    (defn wsr-process-confidence-floor (row) (nth row 4))
    (defn wsr-process-privacy (row) (nth row 5))
    (defn wsr-oracle-process-valid? (row)
        (if (and
                (not (str_eq (wsr-process-feature row) ""))
                (and
                    (not (str_eq (wsr-process-provider row) "fixture"))
                    (and
                        (not (str_eq (wsr-process-protocol row) ""))
                        (and
                            (str_eq (wsr-process-status row) "running")
                            (and
                                (ge (wsr-process-confidence-floor row) 70)
                                (not (str_eq (wsr-process-privacy row) "raw-media")))))))
            1
            0))
    (defn wsr-process-covers-label? (process label export)
        (if (and
                (eq (wsr-oracle-process-valid? process) 1)
                (and
                    (eq (wsr-oracle-label-valid? label export) 1)
                    (and
                        (str_eq (wsr-process-feature process) (wsr-oracle-feature label))
                        (and
                            (str_eq (wsr-process-provider process) (wsr-oracle-provider label))
                            (and
                                (str_eq (wsr-process-protocol process) (wsr-oracle-protocol label))
                                (ge (wsr-oracle-confidence label) (wsr-process-confidence-floor process)))))))
            1
            0))
    (defn wsr-label-has-process? (label export processes)
        (if (eq (len processes) 0) 0
            (if (eq (wsr-process-covers-label? (head processes) label export) 1)
                1
                (wsr-label-has-process? label export (tail processes)))))
    (defn wsr-labels-covered? (labels export processes)
        (if (eq (len labels) 0) 1
            (if (eq (wsr-label-has-process? (head labels) export processes) 1)
                (wsr-labels-covered? (tail labels) export processes)
                0)))
    (defn wsr-process-valid-count (processes)
        (if (eq (len processes) 0) 0
            (add
                (wsr-oracle-process-valid? (head processes))
                (wsr-process-valid-count (tail processes)))))

    (defn wsr-emission-cycle (sequence export labels processes rows privacy)
        (list sequence export labels processes rows privacy))
    (defn wsr-emission-seq (cycle) (nth cycle 0))
    (defn wsr-emission-export (cycle) (nth cycle 1))
    (defn wsr-emission-labels (cycle) (nth cycle 2))
    (defn wsr-emission-processes (cycle) (nth cycle 3))
    (defn wsr-emission-rows (cycle) (nth cycle 4))
    (defn wsr-emission-privacy (cycle) (nth cycle 5))
    (defn wsr-emission-cycle-valid? (state cycle)
        (if (and
                (eq (wsr-emission-seq cycle) (wsr-export-seq (wsr-emission-export cycle)))
                (and
                    (not (str_eq (wsr-emission-privacy cycle) "raw-media"))
                    (and
                        (eq (wsr-source-backed-learning-floor?
                                state
                                (wsr-emission-export cycle)
                                (wsr-emission-labels cycle)
                                (wsr-emission-rows cycle)) 1)
                        (and
                            (eq (wsr-labels-covered?
                                    (wsr-emission-labels cycle)
                                    (wsr-emission-export cycle)
                                    (wsr-emission-processes cycle)) 1)
                            (ge (wsr-process-valid-count (wsr-emission-processes cycle)) 4)))))
            1
            0))
    (defn wsr-emission-next? (previous next)
        (if (and
                (gt (wsr-emission-seq next) (wsr-emission-seq previous))
                (and
                    (ge
                        (wsr-export-frames (wsr-emission-export next))
                        (wsr-export-frames (wsr-emission-export previous)))
                    (ge
                        (wsr-export-sample-count (wsr-emission-export next))
                        (wsr-export-sample-count (wsr-emission-export previous)))))
            1
            0))
    (defn wsr-emission-cycles-all-valid? (state cycles)
        (if (eq (len cycles) 0) 1
            (if (eq (wsr-emission-cycle-valid? state (head cycles)) 1)
                (wsr-emission-cycles-all-valid? state (tail cycles))
                0)))
    (defn wsr-emission-cycles-increasing? (cycles)
        (if (eq (len cycles) 0) 1
            (if (eq (len (tail cycles)) 0) 1
                (if (eq (wsr-emission-next? (head cycles) (head (tail cycles))) 1)
                    (wsr-emission-cycles-increasing? (tail cycles))
                    0))))
    (defn wsr-continuous-emission-floor? (state cycles)
        (if (and
                (ge (len cycles) 2)
                (and
                    (eq (wsr-emission-cycles-all-valid? state cycles) 1)
                    (eq (wsr-emission-cycles-increasing? cycles) 1)))
            1
            0))
    (defn wsr-emission-record-status (state cycles)
        (if (eq (wsr-continuous-emission-floor? state cycles) 1)
            "pass"
            "blocked"))
    (defn wsr-emission-record-pass? (state cycles)
        (str_eq (wsr-emission-record-status state cycles) "pass"))

    0)
