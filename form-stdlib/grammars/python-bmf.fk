; grammars/python-bmf.fk - Python grammar as native BMF object rules
;
; The Python path below matches BMF source objects directly. There is no
; host parser, no lexical layer, and no TypeScript lowering in this file:
; a sensing layer supplies BMF stack objects, rules consume those objects,
; and completed matches emit reversible Form objects.
;
; Per-dialect PY-BMF-* category constants are declared as data in
; form-stdlib/form-ontology.json; scripts/gen_bp_table.py bakes them into
; the kernel-native bp table, and form-ontology-loader.fk materializes the
; Form-side bindings. This file references them as free identifiers; load
; form-ontology-loader.fk as a prelude before this file.

(do
    ;; --- source-object helpers ---------------------------------------

    (defn py-keyword (value) (bmf-atom "py-keyword" value))
    (defn py-name (value) (bmf-atom "py-name" value))
    (defn py-op (value) (bmf-atom "py-op" value))
    (defn py-int (value) (bmf-atom "py-int" value))
    (defn py-float (value) (bmf-atom "py-float" value))
    (defn py-string (value) (bmf-atom "py-string" value))
    (defn py-bytes (value) (bmf-atom "py-bytes" value))
    (defn py-fstring (value) (bmf-atom "py-fstring" value))
    (defn py-tstring (value) (bmf-atom "py-tstring" value))
    (defn py-layout (value) (bmf-atom "py-layout" value))

    ;; Python source sensing is dialect data, not a host tokenizer. The
    ;; generic Form source scanner reads characters, attaches cursor ranges,
    ;; and emits these BMF source objects for the Python rules below.
    (let python-source-keywords
        (list "import" "from" "as" "def" "return" "class" "pass" "if"
              "else" "elif" "while" "for" "in" "with" "async" "await"
              "try" "except" "finally" "raise" "True" "False" "None"
              "not" "and" "or" "yield" "global" "nonlocal" "del"
              "assert" "match" "case" "lambda" "is" "type"))

    (let python-source-ops
        (list "**=" "//=" ">>=" "<<=" ":=" "==" "!=" "<=" ">=" "->"
              "@="
              "+=" "-=" "*=" "/=" "%=" "&=" "|=" "^=" "**" "//" "<<"
              ">>" "..." "(" ")" "[" "]" "{" "}" "," ":" "." ";" "@"
              "=" "+" "-" "*" "/" "%" "&" "|" "^" "~" "<" ">" "!"))

    (defn python-source-dialect (_unused)
        (fsc-source-dialect python-source-keywords
                            "py-keyword"
                            "py-name"
                            "py-int"
                            "py-string"
                            "py-op"
                            "py-eof"
                            python-source-ops))

    (defn python-source-quote? (ch)
        (or (str_eq ch "\"") (str_eq ch "'")))

    (defn python-source-string-prefix? (ch)
        (or (str_eq ch "r")
        (or (str_eq ch "R")
        (or (str_eq ch "b")
        (or (str_eq ch "B")
        (or (str_eq ch "f")
        (or (str_eq ch "F")
        (or (str_eq ch "t")
        (or (str_eq ch "T")
        (or (str_eq ch "u")
            (str_eq ch "U")))))))))))

    (defn python-source-prefix-has? (prefix low up)
        (or (fsc-contains? prefix low)
            (fsc-contains? prefix up)))

    (defn python-source-prefix-string-kind (prefix)
        (if (python-source-prefix-has? prefix "f" "F") "py-fstring"
        (if (python-source-prefix-has? prefix "t" "T") "py-tstring"
        (if (python-source-prefix-has? prefix "b" "B") "py-bytes"
            "py-string"))))

    (defn python-source-skip-comment (cursor)
        (if (fsc-source-cursor-end? cursor) cursor
            (if (str_eq (fsc-source-cursor-char cursor) "\n")
                (fsc-source-cursor-advance cursor)
                (python-source-skip-comment (fsc-source-cursor-advance cursor)))))

    (defn python-source-scan-skip (cursor)
        (if (fsc-source-cursor-end? cursor) cursor
            (if (fsc-space? (fsc-source-cursor-char cursor))
                (python-source-scan-skip (fsc-source-cursor-advance cursor))
            (if (str_eq (fsc-source-cursor-char cursor) "#")
                (python-source-scan-skip (python-source-skip-comment cursor))
                cursor))))

    ;; Slice the source text between two cursor offsets. Both cursors must
    ;; share the same underlying source. Used by scanners that track start
    ;; and end positions and extract the token text once via substring —
    ;; O(N) instead of O(N²) per-byte str_concat accumulation.
    (defn python-source-cursor-slice (start-cursor end-cursor)
        (if (fsc-source-cursor-file? start-cursor)
            (read_file_slice (fsc-source-cursor-source start-cursor)
                             (fsc-source-cursor-offset start-cursor)
                             (sub (fsc-source-cursor-offset end-cursor)
                                  (fsc-source-cursor-offset start-cursor)))
            (substring (fsc-source-cursor-source start-cursor)
                       (fsc-source-cursor-offset start-cursor)
                       (fsc-source-cursor-offset end-cursor))))

    ;; Track start/end positions through the loop; extract the token text
    ;; once at termination. The returned (list value cursor) shape is
    ;; preserved so callers don't change. Backslash escapes still consume
    ;; two characters in source — the slice carries both verbatim, which
    ;; matches the prior accumulator's behaviour (it appended the char
    ;; after the backslash, never the backslash itself; the prior shape
    ;; was lossy on backslashes and the slice preserves them as written).
    (defn python-source-scan-string-loop (start-cursor cursor quote)
        (if (fsc-source-cursor-end? cursor)
            (list (python-source-cursor-slice start-cursor cursor) cursor)
            (if (str_eq (fsc-source-cursor-char cursor) "\\")
                (python-source-scan-string-loop
                    start-cursor
                    (fsc-source-cursor-advance (fsc-source-cursor-advance cursor))
                    quote)
            (if (str_eq (fsc-source-cursor-char cursor) quote)
                (list (python-source-cursor-slice start-cursor cursor)
                      (fsc-source-cursor-advance cursor))
                (python-source-scan-string-loop
                    start-cursor
                    (fsc-source-cursor-advance cursor)
                    quote)))))

    (defn python-source-scan-triple-string-loop (start-cursor cursor quote)
        (if (fsc-source-cursor-end? cursor)
            (list (python-source-cursor-slice start-cursor cursor) cursor)
            (if (and (fsc-source-cursor-prefix? cursor quote)
                     (and (fsc-source-cursor-prefix? (fsc-source-cursor-advance cursor) quote)
                          (fsc-source-cursor-prefix? (fsc-source-cursor-advance (fsc-source-cursor-advance cursor)) quote)))
                (list (python-source-cursor-slice start-cursor cursor)
                      (fsc-source-advance-n cursor 3))
                (python-source-scan-triple-string-loop
                    start-cursor
                    (fsc-source-cursor-advance cursor)
                    quote))))

    (defn python-source-scan-string-at (start quote string-kind)
        (do
            (let open-quote (fsc-source-cursor-char start))
            (if (and (fsc-source-cursor-prefix? start open-quote)
                     (and (fsc-source-cursor-prefix? (fsc-source-cursor-advance start) open-quote)
                          (fsc-source-cursor-prefix? (fsc-source-cursor-advance (fsc-source-cursor-advance start)) open-quote)))
                (do
                    (let body-start (fsc-source-advance-n start 3))
                    (let read (python-source-scan-triple-string-loop body-start body-start open-quote))
                    (fsc-scan-result (fsc-source-object string-kind (nth read 0) start (nth read 1)) (nth read 1)))
                (do
                    (let body-start (fsc-source-cursor-advance start))
                    (if (str_eq (fsc-source-cursor-char body-start) open-quote)
                        (fsc-scan-result
                            (fsc-source-object string-kind "" start (fsc-source-cursor-advance body-start))
                            (fsc-source-cursor-advance body-start))
                        (do
                            (let read (python-source-scan-string-loop body-start body-start open-quote))
                            (fsc-scan-result (fsc-source-object string-kind (nth read 0) start (nth read 1)) (nth read 1))))))))

    (defn python-source-prefixed-string-prefix-len (cursor)
        (do
            (let ch (fsc-source-cursor-char cursor))
            (let next (fsc-source-cursor-char (fsc-source-cursor-advance cursor)))
            (let after-next (fsc-source-cursor-char (fsc-source-advance-n cursor 2)))
            (if (and (python-source-string-prefix? ch)
                     (and (python-source-string-prefix? next)
                          (python-source-quote? after-next)))
                2
                (if (and (python-source-string-prefix? ch)
                         (python-source-quote? next))
                    1
                    0))))

    (defn python-source-scan-prefixed-string (start prefix-len)
        (do
            (let quote-start (fsc-source-advance-n start prefix-len))
            (let prefix (python-source-cursor-slice start quote-start))
            (python-source-scan-string-at quote-start
                                          (fsc-source-cursor-char quote-start)
                                          (python-source-prefix-string-kind prefix))))

    (defn python-source-prefixed-string-start? (cursor)
        (gt (python-source-prefixed-string-prefix-len cursor) 0))

    (defn python-source-int-char? (ch)
        (or (fsc-digit? ch) (str_eq ch "_")))

    (defn python-source-scan-int-loop (start-cursor cursor)
        (if (fsc-source-cursor-end? cursor)
            (list (python-source-cursor-slice start-cursor cursor) cursor)
            (do
                (let ch (fsc-source-cursor-char cursor))
                (if (python-source-int-char? ch)
                    (python-source-scan-int-loop
                        start-cursor
                        (fsc-source-cursor-advance cursor))
                    (list (python-source-cursor-slice start-cursor cursor) cursor)))))

    ;; A float literal is an integer digit-run, a single ".", and a
    ;; fractional digit-run (e.g. 0.5, 2.25, 1.0). The scanner reads the
    ;; whole-number part first; if the very next char is "." AND the char
    ;; after it is a digit, it is a float — consume the "." and the
    ;; fractional digits and emit a "py-float" source object carrying the
    ;; full "N.M" slice. Otherwise (no dot, or a dot not followed by a
    ;; digit — attribute access "obj.field", or the "2." of "2.method()")
    ;; the token stays "py-int" and the "." is left for the op scanner so
    ;; the existing ATTR / method-call shapes are untouched. Exponents
    ;; (1e9) and leading-dot floats (.5) are a later breath — every demo
    ;; today uses the N.M shape.
    (defn python-source-scan-int (start)
        (do
            (let read (python-source-scan-int-loop start start))
            (let after-int (nth read 1))
            (if (and (not (fsc-source-cursor-end? after-int))
                     (str_eq (fsc-source-cursor-char after-int) "."))
                (do
                    (let after-dot (fsc-source-cursor-advance after-int))
                    (if (and (not (fsc-source-cursor-end? after-dot))
                             (fsc-digit? (fsc-source-cursor-char after-dot)))
                        (do
                            (let frac (python-source-scan-int-loop after-dot after-dot))
                            (let end (nth frac 1))
                            (fsc-scan-result
                                (fsc-source-object "py-float"
                                    (python-source-cursor-slice start end) start end)
                                end))
                        (fsc-scan-result
                            (fsc-source-object "py-int" (nth read 0) start after-int)
                            after-int)))
                (fsc-scan-result
                    (fsc-source-object "py-int" (nth read 0) start after-int)
                    after-int))))

    (defn python-source-scan-next (cursor)
        (do
            (let start (python-source-scan-skip cursor))
            (let ch (fsc-source-cursor-char start))
            (let prefix-len (python-source-prefixed-string-prefix-len start))
            (if (fsc-source-cursor-end? start)
                (fsc-scan-result (fsc-source-object "py-eof" "" start start) start)
            (if (gt prefix-len 0)
                (python-source-scan-prefixed-string start prefix-len)
            (if (python-source-quote? ch)
                (python-source-scan-string-at start ch "py-string")
            (if (fsc-digit? ch)
                (python-source-scan-int start)
            (if (fsc-source-name-start-char? ch)
                (fsc-source-scan-name start python-source-keywords "py-keyword" "py-name")
                (fsc-source-scan-op start "py-op" python-source-ops))))))))

    (defn python-source-scan-text-loop (cursor acc)
        (do
            (let result (python-source-scan-next cursor))
            (let object (fsc-scan-result-object result))
            (if (str_eq (bmf-object-kind object) "py-eof")
                (reverse-list acc)
                (python-source-scan-text-loop
                    (fsc-scan-result-cursor result)
                    (cons object acc)))))

    (defn python-source-scan-text (source)
        (python-source-scan-text-loop (fsc-source-cursor source 0 1 0)
                                      (empty)))

    (defn python-source-scan-file (path)
        (python-source-scan-text-loop
            (fsc-file-source-cursor path 0 1 0 (file_size path))
            (empty)))

    ;; Python layout is part of the language grammar. The scanner reads source
    ;; objects first, then derives NEWLINE/INDENT/DEDENT/ENDMARKER objects from
    ;; source coordinates so CPython-shaped rules can refer to layout explicitly.

    (defn py-newline () (py-layout "NEWLINE"))
    (defn py-indent () (py-layout "INDENT"))
    (defn py-dedent () (py-layout "DEDENT"))
    (defn py-endmarker () (py-layout "ENDMARKER"))

    (defn python-layout-dedents (from-indent to-indent acc)
        (if (le from-indent to-indent) acc
            (python-layout-dedents (sub from-indent 4)
                                   to-indent
                                   (cons (py-dedent) acc))))

    (defn python-layout-shift (prev-indent next-indent acc)
        (if (gt next-indent prev-indent)
            (cons (py-indent) acc)
        (if (lt next-indent prev-indent)
            (python-layout-dedents prev-indent next-indent acc)
            acc)))

    (defn python-source-layout-loop
        (objects prev-line prev-indent current-line-start? acc)
        (if (nil? objects)
            (reverse-list
                (cons (py-endmarker)
                      (python-layout-dedents prev-indent 0 acc)))
            (do
                (let object (head objects))
                (let line (python-source-object-line object))
                (let col (python-source-object-col object))
                (let new-line? (gt line prev-line))
                (let with-newline
                    (if new-line?
                        (cons (py-newline) acc)
                        acc))
                (let with-layout
                    (if new-line?
                        (python-layout-shift prev-indent col with-newline)
                        with-newline))
                (python-source-layout-loop
                    (tail objects)
                    line
                    (if new-line? col prev-indent)
                    false
                    (cons object with-layout)))))

    (defn python-source-layout-objects (objects)
        (python-source-layout-loop objects 1 0 true (empty)))

    (defn python-source-scan-text-with-layout (source)
        (python-source-layout-objects (python-source-scan-text source)))

    (defn python-source-scan-file-with-layout (path)
        (python-source-layout-objects (python-source-scan-file path)))

    ;; --- generic Python module parse objects --------------------------
    ;;
    ;; This is the first whole-file parser entry above source sensing. It keeps
    ;; source objects intact, groups them into logical statements using source
    ;; coordinates and bracket depth, and emits Form-native BMF objects that can
    ;; be queried or reversed without the sample-module rule.

    (defn python-source-object-span (object)
        (head (bmf-object-source-span object)))

    (defn python-source-object-line (object)
        (fsc-repo-text-line-number (python-source-object-span object)))

    (defn python-source-object-col (object)
        (fsc-repo-text-line-start-col (python-source-object-span object)))

    (defn python-source-open-group? (object)
        (and (str_eq (bmf-object-kind object) "py-op")
             (or (str_eq (bmf-object-value object) "(")
             (or (str_eq (bmf-object-value object) "[")
                 (str_eq (bmf-object-value object) "{")))))

    (defn python-source-close-group? (object)
        (and (str_eq (bmf-object-kind object) "py-op")
             (or (str_eq (bmf-object-value object) ")")
             (or (str_eq (bmf-object-value object) "]")
                 (str_eq (bmf-object-value object) "}")))))

    (defn python-source-depth-after (depth object)
        (if (python-source-open-group? object) (add depth 1)
        (if (python-source-close-group? object)
            (if (gt depth 0) (sub depth 1) 0)
            depth)))

    (defn python-statement-kind-from-first (object)
        (if (str_eq (bmf-object-kind object) "py-keyword")
            (bmf-object-value object)
        (if (and (str_eq (bmf-object-kind object) "py-op")
                 (str_eq (bmf-object-value object) "@"))
            "decorator"
            "expr")))

    (defn python-statement-kind (objects)
        (if (nil? objects) "empty"
            (python-statement-kind-from-first (head objects))))

    (defn python-statement-indent (objects)
        (if (nil? objects) 0
            (python-source-object-col (head objects))))

    (defn python-parse-statement (objects)
        (bmf-object "py-statement"
                    (list (python-statement-kind objects)
                          (python-statement-indent objects)
                          (python-statement-cpython-rule-from-tokens objects)
                          (len objects))
                    (bmf-collection objects)
                    bmf-identity-inverse))

    (defn python-statement-kind-value (statement)
        (nth (bmf-object-value statement) 0))

    (defn python-statement-indent-value (statement)
        (nth (bmf-object-value statement) 1))

    (defn python-statement-tokens (statement)
        (bmf-collection-items (bmf-object-source statement)))

    (defn python-token-value? (object value)
        (str_eq (bmf-object-value object) value))

    (defn python-statement-token-value? (tokens index value)
        (and (gt (len tokens) index)
             (python-token-value? (nth tokens index) value)))

    (defn python-statement-cpython-rule-from-tokens (tokens)
        (if (nil? tokens) "empty"
        (if (python-statement-token-value? tokens 0 "from") "import_stmt"
        (if (python-statement-token-value? tokens 0 "import") "import_stmt"
        (if (python-statement-token-value? tokens 0 "return") "return_stmt"
        (if (python-statement-token-value? tokens 0 "raise") "raise_stmt"
        (if (python-statement-token-value? tokens 0 "pass") "pass_stmt"
        (if (python-statement-token-value? tokens 0 "del") "del_stmt"
        (if (python-statement-token-value? tokens 0 "yield") "yield_stmt"
        (if (python-statement-token-value? tokens 0 "assert") "assert_stmt"
        (if (python-statement-token-value? tokens 0 "break") "break_stmt"
        (if (python-statement-token-value? tokens 0 "continue") "continue_stmt"
        (if (python-statement-token-value? tokens 0 "global") "global_stmt"
        (if (python-statement-token-value? tokens 0 "nonlocal") "nonlocal_stmt"
        (if (python-statement-token-value? tokens 0 "class") "class_def"
        (if (python-statement-token-value? tokens 0 "def") "function_def"
        (if (and (python-statement-token-value? tokens 0 "async")
                 (python-statement-token-value? tokens 1 "def")) "function_def"
        (if (python-statement-token-value? tokens 0 "if") "if_stmt"
        (if (python-statement-token-value? tokens 0 "while") "while_stmt"
        (if (or (python-statement-token-value? tokens 0 "for")
                (and (python-statement-token-value? tokens 0 "async")
                     (python-statement-token-value? tokens 1 "for"))) "for_stmt"
        (if (or (python-statement-token-value? tokens 0 "with")
                (and (python-statement-token-value? tokens 0 "async")
                     (python-statement-token-value? tokens 1 "with"))) "with_stmt"
        (if (python-statement-token-value? tokens 0 "try") "try_stmt"
        (if (python-statement-token-value? tokens 0 "match") "match_stmt"
        (if (python-statement-token-value? tokens 0 "type") "type_alias"
        (if (python-statement-token-value? tokens 1 "=") "assignment"
        (if (python-statement-token-value? tokens 1 ":=") "assignment_expression"
            "star_expressions"))))))))))))))))))))))))))

    (defn python-statement-cpython-rule (statement)
        (nth (bmf-object-value statement) 2))

    (defn python-statement-token-count (statement)
        (nth (bmf-object-value statement) 3))

    (defn python-parse-module-object (statements source-objects)
        (bmf-object "py-module"
                    (bmf-collection statements)
                    (bmf-empty 0)
                    bmf-identity-inverse))

    (defn python-module-statements (module)
        (bmf-collection-items (bmf-object-value module)))

    (defn python-module-source-objects-loop (statements acc)
        (if (nil? statements) (reverse-list acc)
            (python-module-source-objects-loop
                (tail statements)
                (append (reverse-list (python-statement-tokens (head statements)))
                        acc))))

    (defn python-module-source-objects (module)
        (python-module-source-objects-loop
            (python-module-statements module)
            (empty)))

    (defn python-statement-tree (statement children)
        (bmf-object "py-statement-tree"
                    (list (python-statement-kind-value statement)
                          (python-statement-indent-value statement)
                          (python-statement-cpython-rule statement)
                          (python-statement-token-count statement)
                          (bmf-collection children))
                    (bmf-object-source statement)
                    bmf-identity-inverse))

    (defn python-statement-tree-kind (tree)
        (nth (bmf-object-value tree) 0))

    (defn python-statement-tree-indent (tree)
        (nth (bmf-object-value tree) 1))

    (defn python-statement-tree-tokens (tree)
        (bmf-collection-items (bmf-object-source tree)))

    (defn python-statement-tree-children (tree)
        (bmf-collection-items (nth (bmf-object-value tree) 4)))

    (defn python-statement-tree-cpython-rule (tree)
        (nth (bmf-object-value tree) 2))

    (defn python-statement-tree-token-count (tree)
        (nth (bmf-object-value tree) 3))

    (defn python-parse-block-result (trees rest)
        (list "python-parse-block-result" trees rest))

    (defn python-parse-block-result-trees (result) (nth result 1))
    (defn python-parse-block-result-rest (result) (nth result 2))

    (defn python-parse-statement-trees-loop (statements indent acc)
        (if (nil? statements)
            (python-parse-block-result (reverse-list acc) (empty))
            (do
                (let statement (head statements))
                (let statement-indent (python-statement-indent-value statement))
                (if (lt statement-indent indent)
                    (python-parse-block-result (reverse-list acc) statements)
                (if (gt statement-indent indent)
                    (python-parse-block-result (reverse-list acc) statements)
                    (do
                        (let rest (tail statements))
                        (let child-result
                            (if (and (not (nil? rest))
                                     (gt (python-statement-indent-value (head rest))
                                         statement-indent))
                                (python-parse-statement-trees-loop
                                    rest
                                    (python-statement-indent-value (head rest))
                                    (empty))
                                (python-parse-block-result (empty) rest)))
                        (let tree
                            (python-statement-tree
                                statement
                                (python-parse-block-result-trees child-result)))
                        (python-parse-statement-trees-loop
                            (python-parse-block-result-rest child-result)
                            indent
                            (cons tree acc))))))))

    (defn python-parse-statement-trees (statements)
        (python-parse-block-result-trees
            (python-parse-statement-trees-loop statements 0 (empty))))

    (defn python-parse-module-tree-object (module)
        (bmf-object "py-module-tree"
                    (bmf-collection
                        (python-parse-statement-trees
                            (python-module-statements module)))
                    (bmf-object-source module)
                    bmf-identity-inverse))

    (defn python-module-tree-statements (module-tree)
        (bmf-collection-items (bmf-object-value module-tree)))

    (defn python-parse-module-tree-file (path)
        (python-parse-module-tree-object (python-parse-module-file path)))

    (defn python-parse-module-finish (current statements source-objects)
        (python-parse-module-object
            (reverse-list
                (if (nil? current)
                    statements
                    (cons (python-parse-statement (reverse-list current))
                          statements)))
            source-objects))

    (defn python-parse-module-loop
        (remaining current current-line depth statements source-objects)
        (if (nil? remaining)
            (python-parse-module-finish current statements source-objects)
            (do
                (let object (head remaining))
                (let line (python-source-object-line object))
                (let next-depth (python-source-depth-after depth object))
                (if (nil? current)
                    (python-parse-module-loop
                        (tail remaining)
                        (list object)
                        line
                        next-depth
                        statements
                        source-objects)
                    (if (and (gt line current-line) (eq depth 0))
                        (python-parse-module-loop
                            (tail remaining)
                            (list object)
                            line
                            next-depth
                            (cons (python-parse-statement (reverse-list current))
                                  statements)
                            source-objects)
                        (python-parse-module-loop
                            (tail remaining)
                            (cons object current)
                            line
                            next-depth
                            statements
                            source-objects))))))

    (defn python-parse-module-objects (source-objects)
        (python-parse-module-loop source-objects
                                  (empty)
                                  0
                                  0
                                  (empty)
                                  source-objects))

    (defn python-parse-module-text (source)
        (python-parse-module-objects (python-source-scan-text source)))

    (defn python-parse-module-file (path)
        (python-parse-module-objects (python-source-scan-file path)))

    (defn kw (value) (object-lit "py-keyword" value))
    (defn op (value) (object-lit "py-op" value))
    (defn name (capture-name) (list "capture" capture-name (object-lit "py-name" "")))
    (defn int-lit (capture-name) (list "capture" capture-name (object-lit "py-int" "")))
    (defn float-lit (capture-name) (list "capture" capture-name (object-lit "py-float" "")))
    (defn string-lit (capture-name) (list "capture" capture-name (object-lit "py-string" "")))
    (defn bytes-lit (capture-name) (list "capture" capture-name (object-lit "py-bytes" "")))
    (defn fstring-lit (capture-name) (list "capture" capture-name (object-lit "py-fstring" "")))
    (defn tstring-lit (capture-name) (list "capture" capture-name (object-lit "py-tstring" "")))

    ;; Generic source-section aliases. The source compiler names helpers
    ;; from the section dialect (`python-kw`, `python-name`, ...), while the
    ;; older hand-authored Python rules keep their shorter local names.
    (defn python-kw (value) (kw value))
    (defn python-op (value) (op value))
    (defn python-name (capture-name) (name capture-name))
    (defn python-int-lit (capture-name) (int-lit capture-name))
    (defn python-float-lit (capture-name) (float-lit capture-name))
    (defn python-string-lit (capture-name) (string-lit capture-name))
    (defn python-bytes-lit (capture-name) (bytes-lit capture-name))
    (defn python-fstring-lit (capture-name) (fstring-lit capture-name))
    (defn python-tstring-lit (capture-name) (tstring-lit capture-name))

    ;; --- capture helpers ---------------------------------------------

    (defn pybmf-value (objects capture-name)
        (bmf-collection-value objects capture-name))

    (defn pybmf-trivial-string (objects capture-name)
        (intern_trivial_string (pybmf-value objects capture-name)))

    (defn pybmf-trivial-int (objects capture-name)
        (intern_trivial_int (str_to_int (pybmf-value objects capture-name))))

    (defn pybmf-empty-string (_objects)
        (intern_trivial_string ""))

    (defn pybmf-node-kids (object)
        (node_children (bmf-object-value object)))

    ;; --- emitters -----------------------------------------------------

    (defn pybmf-emit-import (objects)
        (intern_node PY-BMF-IMPORT
                     (list (pybmf-trivial-string objects "module")
                           (pybmf-trivial-string objects "alias"))))

    (defn pybmf-emit-import-bare (objects)
        (intern_node PY-BMF-IMPORT
                     (list (pybmf-trivial-string objects "module")
                           (pybmf-empty-string objects))))

    (defn pybmf-source-import-as (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-keyword "import")
                  (py-name (node_value (nth kids 0)))
                  (py-keyword "as")
                  (py-name (node_value (nth kids 1))))))

    (defn pybmf-emit-from-import (objects)
        (intern_node PY-BMF-FROM-IMPORT
                     (list (pybmf-trivial-string objects "module")
