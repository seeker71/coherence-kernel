            (let typed-kids (node_children (nth default-kids 0)))
            (list (py-keyword "def")
                  (py-name (node_value (nth kids 0)))
                  (py-op "(")
                  (py-name (node_value (nth typed-kids 0)))
                  (py-op ":")
                  (py-name (node_value (nth typed-kids 1)))
                  (py-op "=")
                  (py-int (int_to_str (node_value (nth default-kids 1))))
                  (py-op ")")
                  (py-op ":"))))

    (defn pybmf-emit-def-return-annotation (objects)
        (intern_node PY-BMF-RET-ANN
                     (list (pybmf-trivial-string objects "name")
                           (pybmf-trivial-string objects "type"))))

    ;; --- additional type-annotation rules ----------------------------

    (defn pybmf-emit-var-annotated (objects)
        (intern_node PY-BMF-ANNOTATED
                     (list (pybmf-trivial-string objects "target")
                           (pybmf-trivial-string objects "type"))))

    (defn pybmf-source-var-annotated (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ":")
                  (py-name (node_value (nth kids 1))))))

    (defn pybmf-source-var-annotated-int (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ":")
                  (py-name (node_value (nth kids 1)))
                  (py-op "=")
                  (py-int (int_to_str (node_value (nth kids 2)))))))

    (defn pybmf-emit-var-annotated-name (objects)
        (intern_node PY-BMF-ANNOTATED
                     (list (pybmf-trivial-string objects "target")
                           (pybmf-trivial-string objects "type")
                           (pybmf-trivial-string objects "value"))))

    (defn pybmf-source-var-annotated-name (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ":")
                  (py-name (node_value (nth kids 1)))
                  (py-op "=")
                  (py-name (node_value (nth kids 2))))))

    (defn pybmf-emit-return-ann-suffix (objects)
        (intern_node PY-BMF-RET-ANN
                     (list (pybmf-trivial-string objects "type"))))

    (defn pybmf-source-return-ann-suffix (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-op "->")
                  (py-name (node_value (nth kids 0))))))

    (defn pybmf-emit-def-typed-ret (objects)
        (intern_node PY-BMF-DEF
                     (list (pybmf-trivial-string objects "name")
                           (intern_node PY-BMF-RET-ANN
                                        (list (pybmf-trivial-string objects "ret"))))))

    (defn pybmf-source-def-typed-ret (object)
        (do
            (let kids (pybmf-node-kids object))
            (let ret-kids (node_children (nth kids 1)))
            (list (py-keyword "def")
                  (py-name (node_value (nth kids 0)))
                  (py-op "(")
                  (py-op ")")
                  (py-op "->")
                  (py-name (node_value (nth ret-kids 0)))
                  (py-op ":")
                  (py-keyword "pass"))))

    (defn pybmf-emit-def-typed-param-ret (objects)
        (intern_node PY-BMF-DEF
                     (list (pybmf-trivial-string objects "name")
                           (intern_node PY-BMF-TYPED-PARAM
                                        (list (pybmf-trivial-string objects "p")
                                              (pybmf-trivial-string objects "t")))
                           (intern_node PY-BMF-RET-ANN
                                        (list (pybmf-trivial-string objects "ret"))))))

    (defn pybmf-source-def-typed-param-ret (object)
        (do
            (let kids (pybmf-node-kids object))
            (let param-kids (node_children (nth kids 1)))
            (let ret-kids (node_children (nth kids 2)))
            (list (py-keyword "def")
                  (py-name (node_value (nth kids 0)))
                  (py-op "(")
                  (py-name (node_value (nth param-kids 0)))
                  (py-op ":")
                  (py-name (node_value (nth param-kids 1)))
                  (py-op ")")
                  (py-op "->")
                  (py-name (node_value (nth ret-kids 0)))
                  (py-op ":")
                  (py-keyword "pass"))))

    (defn pybmf-emit-walrus-ident (objects)
        (intern_node PY-BMF-WALRUS
                     (list (pybmf-trivial-string objects "target")
                           (pybmf-trivial-string objects "value"))))

    (defn pybmf-source-walrus-ident (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ":=")
                  (py-name (node_value (nth kids 1))))))

    (defn pybmf-emit-if-walrus-pass (objects)
        (intern_node PY-BMF-IF
                     (list (intern_node PY-BMF-WALRUS
                                        (list (pybmf-trivial-string objects "target")
                                              (pybmf-trivial-string objects "value")))
                           (intern_node PY-BMF-PASS (empty)))))

    (defn pybmf-source-if-walrus-pass (object)
        (do
            (let kids (pybmf-node-kids object))
            (let walrus-kids (node_children (nth kids 0)))
            (list (py-keyword "if")
                  (py-name (node_value (nth walrus-kids 0)))
                  (py-op ":=")
                  (py-name (node_value (nth walrus-kids 1)))
                  (py-op ":")
                  (py-keyword "pass"))))

    (defn pybmf-emit-float (objects)
        (intern_node PY-BMF-FLOAT
                     (list (pybmf-trivial-string objects "value"))))

    (defn pybmf-emit-bytes (objects)
        (intern_node PY-BMF-BYTES
                     (list (pybmf-trivial-string objects "value"))))

    (defn pybmf-source-bytes (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-bytes (node_value (nth kids 0))))))

    (defn pybmf-emit-ellipsis (_objects)
        (intern_node PY-BMF-ELLIPSIS (empty)))

    (defn pybmf-source-ellipsis (_object)
        (list (py-op "...")))

    (defn pybmf-emit-fstring (objects)
        (intern_node PY-BMF-FSTRING
                     (list (pybmf-trivial-string objects "value"))))

    (defn pybmf-source-fstring (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-fstring (node_value (nth kids 0))))))

    (defn pybmf-emit-fstring-format (objects)
        (intern_node PY-BMF-FSTRING
                     (list (pybmf-trivial-string objects "prefix")
                           (pybmf-trivial-string objects "value"))))

    (defn pybmf-source-fstring-format (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-fstring (node_value (nth kids 0)))
                  (py-op "{")
                  (py-name (node_value (nth kids 1)))
                  (py-op "}"))))

    (defn pybmf-emit-fstring-double-format (objects)
        (intern_node PY-BMF-FSTRING
                     (list (pybmf-trivial-string objects "prefix")
                           (pybmf-trivial-string objects "a")
                           (pybmf-trivial-string objects "b"))))

    (defn pybmf-source-fstring-double-format (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-fstring (node_value (nth kids 0)))
                  (py-op "{")
                  (py-name (node_value (nth kids 1)))
                  (py-op "}")
                  (py-op "{")
                  (py-name (node_value (nth kids 2)))
                  (py-op "}"))))

    (defn pybmf-emit-fstring-spec (objects)
        (intern_node PY-BMF-FSTRING
                     (list (pybmf-trivial-string objects "prefix")
                           (pybmf-trivial-string objects "value")
                           (pybmf-trivial-string objects "spec"))))

    (defn pybmf-source-fstring-spec (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-fstring (node_value (nth kids 0)))
                  (py-op "{")
                  (py-name (node_value (nth kids 1)))
                  (py-op ":")
                  (py-name (node_value (nth kids 2)))
                  (py-op "}"))))

    (defn pybmf-emit-ifexp (objects)
        (intern_node PY-BMF-IFEXP
                     (list (pybmf-trivial-string objects "body")
                           (pybmf-trivial-string objects "test")
                           (pybmf-trivial-string objects "orelse"))))

    (defn pybmf-emit-attr-assign-int (objects)
        (intern_node PY-BMF-ATTR-ASSIGN
                     (list (pybmf-trivial-string objects "object")
                           (pybmf-trivial-string objects "field")
                           (pybmf-trivial-int objects "value"))))

    (defn pybmf-emit-subscript-assign-int (objects)
        (intern_node PY-BMF-SUB-ASSIGN
                     (list (pybmf-trivial-string objects "object")
                           (pybmf-trivial-int objects "index")
                           (pybmf-trivial-int objects "value"))))

    (defn pybmf-emit-unpack2-ident (objects)
        (intern_node PY-BMF-UNPACK
                     (list (pybmf-trivial-string objects "a")
                           (pybmf-trivial-string objects "b")
                           (pybmf-trivial-string objects "value"))))

    ;; --- attribute chain and assignment, method calls ---------------

    (defn pybmf-emit-attr-chain (objects)
        (intern_node PY-BMF-ATTR
                     (list (intern_node PY-BMF-ATTR
                                        (list (pybmf-trivial-string objects "object")
                                              (pybmf-trivial-string objects "field1")))
                           (pybmf-trivial-string objects "field2"))))

    (defn pybmf-source-attr-chain (object)
        (do
            (let kids (pybmf-node-kids object))
            (let inner-kids (node_children (nth kids 0)))
            (list (py-name (node_value (nth inner-kids 0)))
                  (py-op ".")
                  (py-name (node_value (nth inner-kids 1)))
                  (py-op ".")
                  (py-name (node_value (nth kids 1))))))

    (defn pybmf-emit-attr-assign-name (objects)
        (intern_node PY-BMF-ATTR-ASSIGN
                     (list (pybmf-trivial-string objects "object")
                           (pybmf-trivial-string objects "field")
                           (pybmf-trivial-string objects "value"))))

    (defn pybmf-source-attr-assign-name (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ".")
                  (py-name (node_value (nth kids 1)))
                  (py-op "=")
                  (py-name (node_value (nth kids 2))))))

    (defn pybmf-emit-attr-assign-call0 (objects)
        (intern_node PY-BMF-ATTR-ASSIGN
                     (list (pybmf-trivial-string objects "object")
                           (pybmf-trivial-string objects "field")
                           (intern_node PY-BMF-CALL
                                        (list (pybmf-trivial-string objects "call"))))))

    (defn pybmf-source-attr-assign-call0 (object)
        (do
            (let kids (pybmf-node-kids object))
            (let call-kids (node_children (nth kids 2)))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ".")
                  (py-name (node_value (nth kids 1)))
                  (py-op "=")
                  (py-name (node_value (nth call-kids 0)))
                  (py-op "(")
                  (py-op ")"))))

    (defn pybmf-emit-method-call1 (objects)
        (intern_node PY-BMF-METHOD-CALL
                     (list (pybmf-trivial-string objects "object")
                           (pybmf-trivial-string objects "method")
                           (pybmf-trivial-string objects "arg"))))

    (defn pybmf-source-method-call1 (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ".")
                  (py-name (node_value (nth kids 1)))
                  (py-op "(")
                  (py-name (node_value (nth kids 2)))
                  (py-op ")"))))

    (defn pybmf-emit-method-call2 (objects)
        (intern_node PY-BMF-METHOD-CALL
                     (list (pybmf-trivial-string objects "object")
                           (pybmf-trivial-string objects "method")
                           (pybmf-trivial-string objects "a")
                           (pybmf-trivial-string objects "b"))))

    (defn pybmf-source-method-call2 (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-name (node_value (nth kids 0)))
                  (py-op ".")
                  (py-name (node_value (nth kids 1)))
                  (py-op "(")
                  (py-name (node_value (nth kids 2)))
                  (py-op ",")
                  (py-name (node_value (nth kids 3)))
                  (py-op ")"))))

    (defn pybmf-emit-chained-method-call (objects)
        (intern_node PY-BMF-METHOD-CALL
                     (list (intern_node PY-BMF-METHOD-CALL
                                        (list (pybmf-trivial-string objects "object")
                                              (pybmf-trivial-string objects "m1")))
                           (pybmf-trivial-string objects "m2"))))

    (defn pybmf-source-chained-method-call (object)
        (do
            (let kids (pybmf-node-kids object))
            (let inner-kids (node_children (nth kids 0)))
            (list (py-name (node_value (nth inner-kids 0)))
                  (py-op ".")
                  (py-name (node_value (nth inner-kids 1)))
                  (py-op "(")
                  (py-op ")")
                  (py-op ".")
                  (py-name (node_value (nth kids 1)))
                  (py-op "(")
                  (py-op ")"))))

    (let python-bmf-native-section
        (list
            (bmf-native "pybmf-emit-import" pybmf-emit-import PY-BMF-IMPORT)
            (bmf-native "pybmf-emit-from-import" pybmf-emit-from-import PY-BMF-FROM-IMPORT)
            (bmf-native "pybmf-emit-def" pybmf-emit-def PY-BMF-DEF)
            (bmf-native "pybmf-emit-class" pybmf-emit-class PY-BMF-CLASS)
            (bmf-native "pybmf-emit-assign-int" pybmf-emit-assign-int PY-BMF-ASSIGN)
            (bmf-native "pybmf-emit-assign-ident" pybmf-emit-assign-ident PY-BMF-ASSIGN)
            (bmf-native "pybmf-emit-return-int" pybmf-emit-return-int PY-BMF-RETURN)
            (bmf-native "pybmf-emit-return-ident" pybmf-emit-return-ident PY-BMF-RETURN)
            (bmf-native "pybmf-emit-raise" pybmf-emit-raise PY-BMF-RAISE)
            (bmf-native "pybmf-emit-if" pybmf-emit-if PY-BMF-IF)
            (bmf-native "pybmf-emit-for" pybmf-emit-for PY-BMF-FOR)
            (bmf-native "pybmf-emit-call0" pybmf-emit-call0 PY-BMF-CALL)
            (bmf-native "pybmf-emit-binop-sub" pybmf-emit-binop-sub PY-BMF-BINOP)
            (bmf-native "pybmf-emit-compare-eq" pybmf-emit-compare-eq PY-BMF-COMPARE)
            (bmf-native "pybmf-emit-await" pybmf-emit-await PY-BMF-AWAIT)
            (bmf-native "pybmf-emit-yield-from" pybmf-emit-yield-from PY-BMF-YIELD-FROM)
            (bmf-native "pybmf-emit-fstring" pybmf-emit-fstring PY-BMF-FSTRING)
            (bmf-native "pybmf-emit-ifexp" pybmf-emit-ifexp PY-BMF-IFEXP)
            (bmf-native "pybmf-emit-set-comp" pybmf-emit-set-comp PY-BMF-SETCOMP)
            (bmf-native "pybmf-emit-match-as" pybmf-emit-match-as PY-BMF-MATCH-AS)))

    ;; --- BMF object patterns -----------------------------------------

    section [python.bmf] {
    import-as ::= "import" $module:name "as" $alias:name => pybmf-emit-import <= pybmf-source-import-as;
    import ::= "import" $module:name => pybmf-emit-import-bare;
    import-many2 ::= "import" $a:name "," $b:name => pybmf-emit-import-many2 <= pybmf-source-import-many2;
    import-many3 ::= "import" $a:name "," $b:name "," $c:name => pybmf-emit-import-many3 <= pybmf-source-import-many3;
    import-alias-many2 ::= "import" $a:name "as" $alias_a:name "," $b:name "as" $alias_b:name => pybmf-emit-import-alias-many2 <= pybmf-source-import-alias-many2;
    from-import ::= "from" $module:name "import" $name:name => pybmf-emit-from-import <= pybmf-source-from-import;
    from-import-as ::= "from" $module:name "import" $name:name "as" $alias:name => pybmf-emit-from-import-as <= pybmf-source-from-import-as;
    from-import-many2 ::= "from" $module:name "import" $a:name "," $b:name => pybmf-emit-from-import-many2 <= pybmf-source-from-import-many2;
    from-import-many3 ::= "from" $module:name "import" $a:name "," $b:name "," $c:name => pybmf-emit-from-import-many3 <= pybmf-source-from-import-many3;
    from-import-alias-many2 ::= "from" $module:name "import" $a:name "as" $alias_a:name "," $b:name "as" $alias_b:name => pybmf-emit-from-import-alias-many2 <= pybmf-source-from-import-alias-many2;
    from-import-paren-many2 ::= "from" $module:name "import" "(" $a:name "," $b:name ")" => pybmf-emit-from-import-paren-many2 <= pybmf-source-from-import-paren-many2;
    from-import-star ::= "from" $module:name "import" "*" => pybmf-emit-from-import-star <= pybmf-source-from-import-star;
    decorator ::= "@" $name:name => pybmf-emit-decorator <= pybmf-source-decorator;
    decorator-call1 ::= "@" $name:name "(" $arg:name ")" => pybmf-emit-decorator-call1 <= pybmf-source-decorator-call1;
    decorator-dotted ::= "@" $name:name "." $attr:name => pybmf-emit-decorator-dotted <= pybmf-source-decorator-dotted;
    decorator-call0 ::= "@" $name:name "(" ")" => pybmf-emit-decorator-call0 <= pybmf-source-decorator-call0;
    decorator-call2 ::= "@" $name:name "(" $arg1:name "," $arg2:name ")" => pybmf-emit-decorator-call2 <= pybmf-source-decorator-call2;
    decorator-dotted-call0 ::= "@" $name:name "." $attr:name "(" ")" => pybmf-emit-decorator-dotted-call0 <= pybmf-source-decorator-dotted-call0;
    decorator-dotted-call1 ::= "@" $name:name "." $attr:name "(" $arg:name ")" => pybmf-emit-decorator-dotted-call1 <= pybmf-source-decorator-dotted-call1;
    decorated-def ::= "@" $decorator:name "def" $name:name "(" ")" ":" => pybmf-emit-decorated-def <= pybmf-source-decorated-def;
    def ::= "def" $name:name "(" ")" ":" => pybmf-emit-def <= pybmf-source-def;
    def2 ::= "def" $name:name "(" $a:name "," $b:name ")" ":" => pybmf-emit-def2 <= pybmf-source-def2;
    class ::= "class" $name:name ":" "pass" => pybmf-emit-class <= pybmf-source-class;
    assign-int ::= $target:name "=" $value:int => pybmf-emit-assign-int <= pybmf-source-assign-int;
    assign-ident ::= $target:name "=" $value:name => pybmf-emit-assign-ident <= pybmf-source-assign-ident;
    assign-string ::= $target:name "=" $value:string => pybmf-emit-assign-string <= pybmf-source-assign-string;
    return-int ::= "return" $value:int => pybmf-emit-return-int <= pybmf-source-return-int;
    return-ident ::= "return" $value:name => pybmf-emit-return-ident <= pybmf-source-return-ident;
    return-string ::= "return" $value:string => pybmf-emit-return-string <= pybmf-source-return-string;
    return-plus-ident ::= "return" $left:name "+" $right:name => pybmf-emit-return-plus-ident <= pybmf-source-return-plus-ident;
    raise ::= "raise" $value:name => pybmf-emit-raise <= pybmf-source-raise;
    raise-from ::= "raise" $error:name "from" $cause:name => pybmf-emit-raise-from <= pybmf-source-raise-from;
    pass ::= "pass" => pybmf-emit-pass;
    break ::= "break" => pybmf-emit-break;
    continue ::= "continue" => pybmf-emit-continue;
    global ::= "global" $name:name => pybmf-emit-global;
    nonlocal ::= "nonlocal" $name:name => pybmf-emit-nonlocal;
    del ::= "del" $name:name => pybmf-emit-del;
    assert-ident ::= "assert" $value:name => pybmf-emit-assert;
    if-header ::= "if" $cond:name ":" "pass" => pybmf-emit-if <= pybmf-source-if-pass;
    ifexp-ident ::= $body:name "if" $test:name "else" $orelse:name => pybmf-emit-ifexp;
    if-else-pass ::= "if" $cond:name ":" "pass" "else" ":" "pass" => pybmf-emit-if-else-pass <= pybmf-source-if-else-pass;
    elif-pass ::= "if" $cond:name ":" "pass" "elif" $elif_cond:name ":" "pass" => pybmf-emit-elif-pass <= pybmf-source-elif-pass;
    if-elif-else-pass ::= "if" $cond:name ":" "pass" "elif" $elif_cond:name ":" "pass" "else" ":" "pass" => pybmf-emit-if-elif-else-pass <= pybmf-source-if-elif-else-pass;
    while-header ::= "while" $cond:name ":" "pass" => pybmf-emit-while <= pybmf-source-while-pass;
    for-header ::= "for" $target:name "in" $iter:name ":" "pass" => pybmf-emit-for <= pybmf-source-for-pass;
    with-pass ::= "with" $ctx:name ":" "pass" => pybmf-emit-with-pass <= pybmf-source-with-pass;
    with-as-pass ::= "with" $ctx:name "as" $alias:name ":" "pass" => pybmf-emit-with-as-pass <= pybmf-source-with-as-pass;
    async-for-pass ::= "async" "for" $target:name "in" $iter:name ":" "pass" => pybmf-emit-async-for-pass;
    async-with-pass ::= "async" "with" $ctx:name ":" "pass" => pybmf-emit-async-with-pass <= pybmf-source-async-with-pass;
    async-with-as-pass ::= "async" "with" $ctx:name "as" $alias:name ":" "pass" => pybmf-emit-async-with-as-pass <= pybmf-source-async-with-as-pass;
    try-except-pass ::= "try" ":" "pass" "except" $error:name ":" "pass" => pybmf-emit-try-except-pass <= pybmf-source-try-except-pass;
    except-as-pass ::= "except" $error:name "as" $alias:name ":" "pass" => pybmf-emit-except-as-pass <= pybmf-source-except-as-pass;
    try-finally-pass ::= "try" ":" "pass" "finally" ":" "pass" => pybmf-emit-try-finally-pass <= pybmf-source-try-finally-pass;
    try-except-else-finally-pass ::= "try" ":" "pass" "except" $error:name ":" "pass" "else" ":" "pass" "finally" ":" "pass" => pybmf-emit-try-except-else-finally-pass <= pybmf-source-try-except-else-finally-pass;
    try-except-stmt ::= "try" ":" $body:name "except" $err:name ":" $handler:name => pybmf-emit-try-except-stmt <= pybmf-source-try-except-stmt;
    try-except-as-stmt ::= "try" ":" $body:name "except" $err:name "as" $alias:name ":" $handler:name => pybmf-emit-try-except-as-stmt <= pybmf-source-try-except-as-stmt;
    try-finally-stmt ::= "try" ":" $body:name "finally" ":" $cleanup:name => pybmf-emit-try-finally-stmt <= pybmf-source-try-finally-stmt;
    try-except-finally-stmt ::= "try" ":" $body:name "except" $err:name ":" $handler:name "finally" ":" $cleanup:name => pybmf-emit-try-except-finally-stmt <= pybmf-source-try-except-finally-stmt;
    raise-call0 ::= "raise" $error:name "(" ")" => pybmf-emit-raise-call0 <= pybmf-source-raise-call0;
    raise-call1 ::= "raise" $error:name "(" $arg:name ")" => pybmf-emit-raise-call1 <= pybmf-source-raise-call1;
    raise-call-string ::= "raise" $error:name "(" $arg:string ")" => pybmf-emit-raise-call-string <= pybmf-source-raise-call-string;
    async-def ::= "async" "def" $name:name "(" ")" ":" => pybmf-emit-async-def;
    call0 ::= $callee:name "(" ")" => pybmf-emit-call0 <= pybmf-source-call0;
    call1-ident ::= $callee:name "(" $arg:name ")" => pybmf-emit-call1-ident <= pybmf-source-call1-ident;
    kwarg ::= $key:name "=" $value:name => pybmf-emit-kwarg <= pybmf-source-kwarg;
    star-arg ::= "*" $value:name => pybmf-emit-star-arg <= pybmf-source-star-arg;
    star-star-arg ::= "**" $value:name => pybmf-emit-star-star-arg <= pybmf-source-star-arg;
    call-kwarg1 ::= $callee:name "(" $key:name "=" $value:name ")" => pybmf-emit-call-kwarg1 <= pybmf-source-call-kwarg1;
    call-star1 ::= $callee:name "(" "*" $value:name ")" => pybmf-emit-call-star1 <= pybmf-source-call-star1;
    call-star-star1 ::= $callee:name "(" "**" $value:name ")" => pybmf-emit-call-star-star1 <= pybmf-source-call-star1;
    assign-call2-ident ::= $target:name "=" $callee:name "(" $a:name "," $b:name ")" => pybmf-emit-assign-call2-ident;
    attr ::= $object:name "." $field:name => pybmf-emit-attr <= pybmf-source-attr;
    attr-chain ::= $object:name "." $field1:name "." $field2:name => pybmf-emit-attr-chain <= pybmf-source-attr-chain;
    method-call0 ::= $object:name "." $method:name "(" ")" => pybmf-emit-method-call0 <= pybmf-source-method-call0;
    method-call1 ::= $object:name "." $method:name "(" $arg:name ")" => pybmf-emit-method-call1 <= pybmf-source-method-call1;
    method-call2 ::= $object:name "." $method:name "(" $a:name "," $b:name ")" => pybmf-emit-method-call2 <= pybmf-source-method-call2;
    chained-method-call ::= $object:name "." $m1:name "(" ")" "." $m2:name "(" ")" => pybmf-emit-chained-method-call <= pybmf-source-chained-method-call;
    subscript-ident-int ::= $object:name "[" $index:int "]" => pybmf-emit-subscript-ident-int <= pybmf-source-subscript-ident-int;
    slice-int-int ::= $object:name "[" $start:int ":" $end:int "]" => pybmf-emit-slice-int-int;
    slice-name-name ::= $object:name "[" $start:name ":" $end:name "]" => pybmf-emit-slice-name-name <= pybmf-source-slice-name-name;
    slice-name-omit ::= $object:name "[" $start:name ":" "]" => pybmf-emit-slice-name-omit <= pybmf-source-slice-name-omit;
    slice-omit-name ::= $object:name "[" ":" $end:name "]" => pybmf-emit-slice-omit-name <= pybmf-source-slice-omit-name;
    slice-omit-omit ::= $object:name "[" ":" "]" => pybmf-emit-slice-omit-omit <= pybmf-source-slice-omit-omit;
    slice-step-int ::= $object:name "[" ":" ":" $step:int "]" => pybmf-emit-slice-step-int <= pybmf-source-slice-step-int;
    list3-int ::= "[" $a:int "," $b:int "," $c:int "]" => pybmf-emit-list3-int;
    tuple2-ident ::= "(" $a:name "," $b:name ")" => pybmf-emit-tuple2-ident;
    set2-int ::= "{" $a:int "," $b:int "}" => pybmf-emit-set2-int;
    dict1-ident-int ::= "{" $key:name ":" $value:int "}" => pybmf-emit-dict1-ident-int;
    list-comp ::= "[" $expr:name "for" $target:name "in" $iter:name "]" => pybmf-emit-list-comp <= pybmf-source-list-comp;
    dict-comp ::= "{" $key:name ":" $value:name "for" $target:name "in" $iter:name "}" => pybmf-emit-dict-comp <= pybmf-source-dict-comp;
    gen-exp ::= "(" $expr:name "for" $target:name "in" $iter:name ")" => pybmf-emit-gen-exp;
    set-comp ::= "{" $expr:name "for" $target:name "in" $iter:name "}" => pybmf-emit-set-comp <= pybmf-source-set-comp;
    annotated-assign-int ::= $target:name ":" $type:name "=" $value:int => pybmf-emit-annotated-assign-int <= pybmf-source-var-annotated-int;
    var-annotated ::= $target:name ":" $type:name => pybmf-emit-var-annotated <= pybmf-source-var-annotated;
    var-annotated-name ::= $target:name ":" $type:name "=" $value:name => pybmf-emit-var-annotated-name <= pybmf-source-var-annotated-name;
    list-comp-simple ::= "[" $expr:name "for" $var:name "in" $iter:name "]" => pybmf-emit-list-comp-simple <= pybmf-source-list-comp-simple;
    list-comp-if ::= "[" $expr:name "for" $var:name "in" $iter:name "if" $cond:name "]" => pybmf-emit-list-comp-if <= pybmf-source-list-comp-if;
    set-comp-simple ::= "{" $expr:name "for" $var:name "in" $iter:name "}" => pybmf-emit-set-comp-simple <= pybmf-source-set-comp-simple;
    dict-comp-simple ::= "{" $key:name ":" $value:name "for" $var:name "in" $iter:name "}" => pybmf-emit-dict-comp-simple <= pybmf-source-dict-comp-simple;
    genexp-simple ::= "(" $expr:name "for" $var:name "in" $iter:name ")" => pybmf-emit-genexp-simple <= pybmf-source-genexp-simple;
    genexp-if ::= "(" $expr:name "for" $var:name "in" $iter:name "if" $cond:name ")" => pybmf-emit-genexp-if <= pybmf-source-genexp-if;
    typed-param ::= $name:name ":" $type:name => pybmf-emit-typed-param <= pybmf-source-typed-param;
    default-param-int ::= $name:name "=" $value:int => pybmf-emit-default-param-int <= pybmf-source-default-param-int;
    default-param-string ::= $name:name "=" $value:string => pybmf-emit-default-param-string <= pybmf-source-default-param-string;
    typed-default-param-int ::= $name:name ":" $type:name "=" $value:int => pybmf-emit-typed-default-param-int <= pybmf-source-typed-default-param-int;
    typed-default-param-string ::= $name:name ":" $type:name "=" $value:string => pybmf-emit-typed-default-param-string <= pybmf-source-typed-default-param-string;
    def1-typed-default-int ::= "def" $name:name "(" $arg:name ":" $type:name "=" $value:int ")" ":" => pybmf-emit-def1-typed-default-int <= pybmf-source-def1-typed-default-int;
    def-return-annotation ::= "def" $name:name "(" ")" "->" $type:name ":" => pybmf-emit-def-return-annotation;
    return-ann ::= "->" $type:name => pybmf-emit-return-ann-suffix <= pybmf-source-return-ann-suffix;
    def-typed-ret ::= "def" $name:name "(" ")" "->" $ret:name ":" "pass" => pybmf-emit-def-typed-ret <= pybmf-source-def-typed-ret;
    def-typed-param-ret ::= "def" $name:name "(" $p:name ":" $t:name ")" "->" $ret:name ":" "pass" => pybmf-emit-def-typed-param-ret <= pybmf-source-def-typed-param-ret;
    plus-assign-int ::= $target:name "+=" $value:int => pybmf-emit-aug-assign-int;
    attr-assign-int ::= $object:name "." $field:name "=" $value:int => pybmf-emit-attr-assign-int;
    attr-assign-name ::= $object:name "." $field:name "=" $value:name => pybmf-emit-attr-assign-name <= pybmf-source-attr-assign-name;
    attr-assign-call0 ::= $object:name "." $field:name "=" $call:name "(" ")" => pybmf-emit-attr-assign-call0 <= pybmf-source-attr-assign-call0;
    subscript-assign-int ::= $object:name "[" $index:int "]" "=" $value:int => pybmf-emit-subscript-assign-int;
    unpack2-ident ::= $a:name "," $b:name "=" $value:name => pybmf-emit-unpack2-ident;
    walrus-ident ::= $target:name ":=" $value:name => pybmf-emit-walrus-ident <= pybmf-source-walrus-ident;
    if-walrus-pass ::= "if" $target:name ":=" $value:name ":" "pass" => pybmf-emit-if-walrus-pass <= pybmf-source-if-walrus-pass;
    class-base ::= "class" $name:name "(" $base:name ")" ":" "pass" => pybmf-emit-class-base <= pybmf-source-class-base;
    class-no-base ::= "class" $name:name "(" ")" ":" "pass" => pybmf-emit-class-no-base <= pybmf-source-class-no-base;
    class-base2 ::= "class" $name:name "(" $base_a:name "," $base_b:name ")" ":" "pass" => pybmf-emit-class-base2 <= pybmf-source-class-base2;
    class-base3 ::= "class" $name:name "(" $base_a:name "," $base_b:name "," $base_c:name ")" ":" "pass" => pybmf-emit-class-base3 <= pybmf-source-class-base3;
    class-kwbase-metaclass ::= "class" $name:name "(" $meta_key:name "=" $meta_value:name ")" ":" "pass" => pybmf-emit-class-kwbase-metaclass <= pybmf-source-class-kwbase-metaclass;
    decorated-class-base ::= "@" $decorator:name "class" $name:name "(" $base:name ")" ":" "pass" => pybmf-emit-decorated-class-base <= pybmf-source-decorated-class-base;
    bool-true ::= "True" => pybmf-emit-bool-true;
    bool-false ::= "False" => pybmf-emit-bool-false;
    none ::= "None" => pybmf-emit-none;
    not-ident ::= "not" $value:name => pybmf-emit-unary-not <= pybmf-source-unary-not;
    neg-int ::= "-" $value:int => pybmf-emit-unary-neg-int;
    pos-int ::= "+" $value:int => pybmf-emit-unary-plus-int;
    invert-ident ::= "~" $value:name => pybmf-emit-unary-invert;
    compare-eq-ident ::= $left:name "==" $right:name => pybmf-emit-compare-eq <= pybmf-source-compare-op;
    compare-lt-ident ::= $left:name "<" $right:name => pybmf-emit-compare-lt <= pybmf-source-compare-op;
    compare-ne-ident ::= $left:name "!=" $right:name => pybmf-emit-compare-ne <= pybmf-source-compare-op;
    compare-gt-ident ::= $left:name ">" $right:name => pybmf-emit-compare-gt <= pybmf-source-compare-op;
    compare-gte-ident ::= $left:name ">=" $right:name => pybmf-emit-compare-gte <= pybmf-source-compare-op;
    compare-lte-ident ::= $left:name "<=" $right:name => pybmf-emit-compare-lte <= pybmf-source-compare-op;
    compare-in-ident ::= $left:name "in" $right:name => pybmf-emit-compare-in <= pybmf-source-compare-word;
    compare-not-in-ident ::= $left:name "not" "in" $right:name => pybmf-emit-compare-not-in <= pybmf-source-compare-not-in;
    compare-is-ident ::= $left:name "is" $right:name => pybmf-emit-compare-is <= pybmf-source-compare-word;
    compare-is-not-ident ::= $left:name "is" "not" $right:name => pybmf-emit-compare-is-not <= pybmf-source-compare-is-not;
    compare-chain-lt-lte ::= $left:name "<" $middle:name "<=" $right:name => pybmf-emit-compare-chain-lt-lte <= pybmf-source-compare-chain;
    binop-sub-ident ::= $left:name "-" $right:name => pybmf-emit-binop-sub <= pybmf-source-binop-ident;
    binop-mul-ident ::= $left:name "*" $right:name => pybmf-emit-binop-mul <= pybmf-source-binop-ident;
    binop-div-ident ::= $left:name "/" $right:name => pybmf-emit-binop-div <= pybmf-source-binop-ident;
    binop-mod-ident ::= $left:name "%" $right:name => pybmf-emit-binop-mod <= pybmf-source-binop-ident;
    binop-pow-ident ::= $left:name "**" $right:name => pybmf-emit-binop-pow <= pybmf-source-binop-ident;
    binop-floor-div-ident ::= $left:name "//" $right:name => pybmf-emit-binop-floor-div <= pybmf-source-binop-ident;
    binop-bit-or-ident ::= $left:name "|" $right:name => pybmf-emit-binop-bit-or <= pybmf-source-binop-ident;
    binop-bit-and-ident ::= $left:name "&" $right:name => pybmf-emit-binop-bit-and <= pybmf-source-binop-ident;
    binop-bit-xor-ident ::= $left:name "^" $right:name => pybmf-emit-binop-bit-xor <= pybmf-source-binop-ident;
    binop-lshift-ident ::= $left:name "<<" $right:name => pybmf-emit-binop-lshift <= pybmf-source-binop-ident;
    binop-rshift-ident ::= $left:name ">>" $right:name => pybmf-emit-binop-rshift <= pybmf-source-binop-ident;
    bool-and-ident ::= $left:name "and" $right:name => pybmf-emit-bool-and;
    bool-or-ident ::= $left:name "or" $right:name => pybmf-emit-bool-or;
    lambda1-ident ::= "lambda" $arg:name ":" $value:name => pybmf-emit-lambda1-ident <= pybmf-source-lambda1-ident;
    await-ident ::= "await" $value:name => pybmf-emit-await <= pybmf-source-await;
    yield-ident ::= "yield" $value:name => pybmf-emit-yield <= pybmf-source-yield;
    yield-from-ident ::= "yield" "from" $value:name => pybmf-emit-yield-from;
    match-header ::= "match" $subject:name ":" => pybmf-emit-match-header <= pybmf-source-match-header;
    case-pass ::= "case" $pattern:name ":" "pass" => pybmf-emit-case-pass <= pybmf-source-case-pass;
    case-guard-pass ::= "case" $pattern:name "if" $guard:name ":" "pass" => pybmf-emit-case-guard-pass <= pybmf-source-case-guard-pass;
    match-as ::= $name:name "as" $alias:name => pybmf-emit-match-as <= pybmf-source-match-as;
    float ::= $value:float => pybmf-emit-float;
    bytes ::= $value:bytes => pybmf-emit-bytes <= pybmf-source-bytes;
    fstring ::= $value:fstring => pybmf-emit-fstring <= pybmf-source-fstring;
    fstring-format ::= $prefix:fstring "{" $value:name "}" => pybmf-emit-fstring-format <= pybmf-source-fstring-format;
    fstring-double-format ::= $prefix:fstring "{" $a:name "}" "{" $b:name "}" => pybmf-emit-fstring-double-format <= pybmf-source-fstring-double-format;
    fstring-spec ::= $prefix:fstring "{" $value:name ":" $spec:name "}" => pybmf-emit-fstring-spec <= pybmf-source-fstring-spec;
    ellipsis ::= "..." => pybmf-emit-ellipsis <= pybmf-source-ellipsis;
    sample-module ::= "import" $import_a:name "import" $import_b:name "from" $from_mod:name "import" $from_name:name $const_name:name "=" $const_value:int "def" $add_name:name "(" $add_a:name "," $add_b:name ")" ":" "return" $ret_left:name "+" $ret_right:name "def" $main_name:name "(" ")" ":" $x_name:name "=" $x_value:int $y_name:name "=" $y_value:int $z_name:name "=" $z_call:name "(" $z_arg_a:name "," $z_arg_b:name ")" $print_call:name "(" $print_arg:name ")" => pybmf-emit-sample-module;
    int ::= $value:int => pybmf-emit-int;
    string ::= $value:string => pybmf-emit-string;
    ident ::= $value:name => pybmf-emit-ident;
    }

    ;; --- rule lookup and object-stream entry -------------------------

    (defn python-bmf-rule-name (r) (head r))

    (defn python-bmf-find-rule (rule-name rules)
        (if (nil? rules) (empty)
            (if (str_eq (python-bmf-rule-name (head rules)) rule-name)
                (head rules)
                (python-bmf-find-rule rule-name (tail rules)))))

    (defn apply-python-bmf-rule (rule-name object-stream)
        (do
            (let rule (python-bmf-find-rule rule-name python-bmf-rules))
            (apply-object-rule rule object-stream)))

    ;; --- native source sections -------------------------------------

    (let python-bmf-section python-bmf-second)

    (let python-recipe-section
        (form-rule-recipe-section "python"
            (list
                (compiler-rule "python" "import" "Python import source objects" pybmf-emit-import)
                (compiler-rule "python" "def" "Python function source objects" pybmf-emit-def)
                (compiler-rule "python" "class" "Python class source objects" pybmf-emit-class)
                (compiler-rule "python" "assign" "Python assignment source objects" pybmf-emit-assign-ident)
                (compiler-rule "python" "return" "Python return source objects" pybmf-emit-return-ident)
                (compiler-rule "python" "match" "Python match source objects" pybmf-emit-match-header)
                (compiler-rule "python" "fstring" "Python f-string source objects" pybmf-emit-fstring))))

    (let python-form-source
        (form-source "python" (list python-bmf-section python-recipe-section)))

    (let python-bmf-dialect
        (bmf-dialect "python"
                     (form-section-object python-bmf-section)
                     python-bmf-native-section
                     python-bmf-rules))

    0)
