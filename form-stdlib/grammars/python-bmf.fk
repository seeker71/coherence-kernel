    ;; --- try/except/finally with real (non-pass) bodies --------------
    ;; Body and handler/cleanup stand in as single-name references so the
    ;; grammar can match real exception-handling code. Each rule is fully
    ;; reversible — emit interns the children as substrate-trivial strings,
    ;; source projects them back to the positional token stream.

    (defn pybmf-emit-try-except-stmt (objects)
        (intern_node PY-BMF-TRY
                     (list (intern_trivial_string "except-stmt")
                           (pybmf-trivial-string objects "body")
                           (pybmf-trivial-string objects "err")
                           (pybmf-trivial-string objects "handler"))))

    (defn pybmf-source-try-except-stmt (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-keyword "try")
                  (py-op ":")
                  (py-name (node_value (nth kids 1)))
                  (py-keyword "except")
                  (py-name (node_value (nth kids 2)))
                  (py-op ":")
                  (py-name (node_value (nth kids 3))))))

    (defn pybmf-emit-try-except-as-stmt (objects)
        (intern_node PY-BMF-TRY
                     (list (intern_trivial_string "except-as-stmt")
                           (pybmf-trivial-string objects "body")
                           (pybmf-trivial-string objects "err")
                           (pybmf-trivial-string objects "alias")
                           (pybmf-trivial-string objects "handler"))))

    (defn pybmf-source-try-except-as-stmt (object)
        (do
            (let kids (pybmf-node-kids object))
            (list (py-keyword "try")
                  (py-op ":")
                  (py-name (node_value (nth kids 1)))
                  (py-keyword "except")
                  (py-name (node_value (nth kids 2)))
                  (py-keyword "as")
                  (py-name (node_value (nth kids 3)))
                  (py-op ":")
                  (py-name (node_value (nth kids 4))))))

    (defn pybmf-emit-try-finally-stmt (objects)
        (intern_node PY-BMF-TRY
                     (list (intern_trivial_string "finally-stmt")
                           (pybmf-trivial-string objects "body")
                           (pybmf-trivial-string objects "cleanup"))))

