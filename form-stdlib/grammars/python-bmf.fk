    ;; --- comprehension expansions: simple + filtered ----------------
    ;; The four containers (list/set/dict/genexp) share a common shape:
    ;; expression-recipe + iteration-var + iterable-recipe (+ optional
    ;; condition-recipe). The PY-BMF-COMP category carries list/dict/set
    ;; flavor as a leading trivial-string discriminator; PY-BMF-GENEXP is
    ;; its own category. Filtered variants append a fourth (or fifth, for
    ;; dict) child holding the predicate name.

    (defn pybmf-emit-list-comp-simple (objects)
        (intern_node PY-BMF-COMP
                     (list (intern_trivial_string "list")
                           (pybmf-trivial-string objects "expr")
                           (pybmf-trivial-string objects "var")
                           (pybmf-trivial-string objects "iter"))))

