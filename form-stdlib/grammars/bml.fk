    (defn bml-body-source-if-local-null-return-false-at? (values)
        (if (gt (len values) 5)
            (if (str_eq (head values) "if")
                (if (str_eq (nth values 1) "(")
                    (if (str_eq (nth values 3) "==")
                        (if (str_eq (nth values 4) "null")
                            (str_eq (nth values 5) ")")
