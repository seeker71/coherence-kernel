    (defn bml-body-source-bmf-compile-shape? (body-component)
        (and (bml-body-source-contains? body-component "ParseStream")
             (and (bml-body-source-contains? body-component "m_hSyntaxes")
             (and (bml-body-source-contains? body-component "GetFileExtension")
                  (bml-body-source-contains? body-component "Invoke")))))

    (defn bml-body-source-exec-bmf-compile (body-component self env)
        (do
            (bml-body-source-exec-parse-stream-assignment body-component env)
            (let syntax
                (bml-body-source-exec-syntax-lookup-assignment
                    body-component
                    self
                    env))
            (if (record? syntax)
                (do
                    (bml-body-source-exec-receiver-call3-assignment
                        body-component
                        self
                        env)
                    (record_get env "bResult"))
                false)))

    (defn bml-body-source-exec-sequence-loop (values previous self env)
        (if (nil? values) self
            (if (bml-body-source-if-not-instanceof-return-false-at? values)
                (if (bml-body-source-if-not-instanceof-condition? values self env)
                    false
                    (bml-body-source-exec-sequence-loop
                        (drop 10 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-typed-cast-assignment-at? values)
                (do
                    (bml-body-source-exec-typed-cast-assignment-at values self env)
                    (bml-body-source-exec-sequence-loop
                        (drop 8 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-if-member-neq-return-false-at? values)
                (if (bml-body-source-if-member-neq-condition? values self env)
                    false
                    (bml-body-source-exec-sequence-loop
                        (drop 11 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-if-chain-member-neq-return-false-at? values)
                (if (bml-body-source-if-chain-member-neq-condition? values self env)
                    false
                    (bml-body-source-exec-sequence-loop
                        (drop 15 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-return-member-add-at? values)
                (bml-body-source-eval-return-member-add-at values self env)
            (if (bml-body-source-return-member-eq-at? values)
                (bml-body-source-eval-return-member-eq-at values self env)
            (if (bml-body-source-constructor-assignment-at? values)
                (do
                    (record_set
                        self
                        (head values)
                        (bml-body-source-construct0 (nth values 2)))
                    (bml-body-source-exec-sequence-loop
                        (drop 6 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-assignment-at? values)
                (do
                    (record_set
                        self
                        (head values)
                        (record_get env (nth values 2)))
                    (bml-body-source-exec-sequence-loop
                        (drop 4 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-receiver-call1-nested-implicit-at? values)
                (do
                    (bml-body-source-exec-receiver-call1-nested-implicit-at values self env)
                    (bml-body-source-exec-sequence-loop
                        (drop 10 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-receiver-call1-at? values)
                (do
                    (bml-body-source-exec-receiver-call1-at values self env)
                    (bml-body-source-exec-sequence-loop
                        (drop 7 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-receiver-call0-at? values)
                (do
                    (method_invoke
                        (bml-body-source-object-value self env (head values))
                        (nth values 2))
                    (bml-body-source-exec-sequence-loop
                        (drop 6 values)
                        ";"
                        self
                        env))
            (if (bml-body-source-implicit-call1-at? values)
                (if (str_eq previous ".")
                    (bml-body-source-exec-sequence-loop
                        (tail values)
                        (head values)
                        self
                        env)
                    (do
                        (method_invoke
                            self
                            (head values)
                            (bml-body-source-arg-value env (nth values 2)))
                        (bml-body-source-exec-sequence-loop
                            (drop 5 values)
                            ";"
                            self
                            env)))
                (bml-body-source-exec-sequence-loop
                    (tail values)
                    (head values)
                    self
                    env)))))))))))))))

    (defn bml-body-source-exec (body-component self env)
        (if (bml-body-source-bmf-compile-shape? body-component)
            (bml-body-source-exec-bmf-compile body-component self env)
            (bml-body-source-exec-sequence-loop
                (bml-body-source-values body-component)
                ""
                self
                env)))

    (defn bml-constructor-env-blueprint (_x)
        (make_nodeid 1 2 99 9202))

    (defn bml-body-source-self-call? (body-component)
        (do
            (let values (bml-body-source-values body-component))
            (if (gt (len values) 1)
                (if (str_eq (head values) "self")
                    (str_eq (nth values 1) "(")
                    false)
                false)))

    (defn bml-body-source-self-args-append-current (current acc)
        (if (str_eq current "") acc
            (cons current acc)))

    (defn bml-body-source-self-args-loop (values depth current acc)
        (if (nil? values)
            (reverse-list
                (bml-body-source-self-args-append-current current acc))
            (do
                (let value (head values))
                (if (eq depth 0)
                    (if (str_eq value ")")
                        (reverse-list
                            (bml-body-source-self-args-append-current
                                current
                                acc))
                    (if (str_eq value ",")
                        (bml-body-source-self-args-loop
                            (tail values)
                            0
                            ""
                            (bml-body-source-self-args-append-current
                                current
                                acc))
                    (if (str_eq value "(")
                        (bml-body-source-self-args-loop
                            (tail values)
                            1
                            current
                            acc)
                    (if (str_eq value "<")
                        (bml-body-source-self-args-loop
                            (tail values)
                            1
                            current
                            acc)
                        (bml-body-source-self-args-loop
                            (tail values)
                            0
                            (if (str_eq current "") value current)
                            acc)))))
                    (if (str_eq value ")")
                        (bml-body-source-self-args-loop
                            (tail values)
                            (sub depth 1)
                            current
                            acc)
                    (if (str_eq value ">")
                        (bml-body-source-self-args-loop
                            (tail values)
                            (sub depth 1)
                            current
                            acc)
                    (if (str_eq value "(")
                        (bml-body-source-self-args-loop
                            (tail values)
                            (add depth 1)
                            current
                            acc)
                    (if (str_eq value "<")
                        (bml-body-source-self-args-loop
                            (tail values)
                            (add depth 1)
                            current
                            acc)
                        (bml-body-source-self-args-loop
                            (tail values)
                            depth
                            current
                            acc)))))))))

    (defn bml-body-source-self-args (body-component)
        (if (bml-body-source-self-call? body-component)
            (bml-body-source-self-args-loop
                (drop 2 (bml-body-source-values body-component))
                0
                ""
                (empty))
            (empty)))

    (defn bml-find-constructor-by-param-count (constructors param-count)
        (if (nil? constructors) (empty)
            (if (eq (len (bml-constructor-parameters (head constructors))) param-count)
                (head constructors)
                (bml-find-constructor-by-param-count
                    (tail constructors)
                    param-count))))

    (defn bml-body-source-arg-value (env arg-name)
        (if (str_eq arg-name "null") (empty)
            (if (str_eq arg-name "Array") (empty)
                (record_get env arg-name))))

    (defn bml-constructor-bind-args-loop (parameters arg-names source-env target-env)
        (if (nil? parameters) target-env
            (do
                (record_set
                    target-env
                    (bml-parameter-name (head parameters))
                    (bml-body-source-arg-value source-env (head arg-names)))
                (bml-constructor-bind-args-loop
                    (tail parameters)
                    (tail arg-names)
                    source-env
                    target-env))))

    (defn bml-constructor-bind-args (constructor arg-names source-env)
        (bml-constructor-bind-args-loop
            (bml-constructor-parameters constructor)
            arg-names
            source-env
            (record_new (bml-constructor-env-blueprint 0))))

    (defn bml-exec-constructor (constructors constructor self env)
        (do
            (let body (bml-constructor-body constructor))
            (if (gt (bml-body-source-assignment-count body) 0)
                (bml-body-source-exec-assignments body self env)
            (if (bml-body-source-self-call? body)
                (do
                    (let arg-names (bml-body-source-self-args body))
                    (let target
                        (bml-find-constructor-by-param-count
                            constructors
                            (len arg-names)))
                    (let target-env
                        (bml-constructor-bind-args target arg-names env))
                    (bml-exec-constructor constructors target self target-env))
                self))))

    (defn bml-template-parameters (template-component)
        (nth (comp-bml-fields template-component) 0))

    (defn bml-template-kind (template-component)
        (nth (comp-bml-fields template-component) 1))

    (defn bml-template-body (template-component)
        (nth (comp-bml-fields template-component) 2))

    (defn bml-template-valid-kind? (template-component)
        (if (str_eq (bml-template-kind template-component) "class") true
            (str_eq (bml-template-kind template-component) "interface")))

    (defn bml-hati-template-metadata (template-component)
        (list
            "bml-hati-template-metadata"
            (bml-template-kind template-component)
            (bml-template-parameters template-component)
            (bml-template-body template-component)
            (bml-template-valid-kind? template-component)))

    (defn bml-hati-template-metadata-kind (metadata)
        (nth metadata 1))

    (defn bml-hati-template-metadata-parameters (metadata)
        (nth metadata 2))

    (defn bml-hati-template-metadata-param-count (metadata)
        (len (bml-hati-template-metadata-parameters metadata)))

    (defn bml-hati-template-metadata-body (metadata)
        (nth metadata 3))

    (defn bml-hati-template-metadata-supported? (metadata)
        (nth metadata 4))

    (defn bml-class-abstract? (class-component)
        (bml-properties-has? (bml-class-properties class-component) "abstract"))

    (defn bml-class-final? (class-component)
        (bml-properties-has? (bml-class-properties class-component) "final"))

    (defn bml-method-abstract? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "abstract"))

    (defn bml-method-final? (method-component)
        (bml-properties-has? (bml-method-properties method-component) "final"))

    (defn bml-method-default? (method-component)
