    (defn bml-body-source-arg-value-runtime (self env arg-name)
        (if (str_eq arg-name "self") self
            (if (str_eq arg-name "null") (empty)
            (if (str_eq arg-name "false") false
            (if (str_eq arg-name "true") true
            (if (str_eq arg-name "0") 0
                (bml-body-source-object-value self env arg-name)))))))

    (defn bml-body-source-receiver-call3-assignment-at? (values)
        (if (gt (len values) 13)
            (if (str_eq (nth values 2) "=")
                (if (str_eq (nth values 4) ".")
                    (if (str_eq (nth values 6) "(")
                        (if (str_eq (nth values 8) ",")
                            (if (str_eq (nth values 10) ",")
                                (if (str_eq (nth values 12) ")")
                                    (str_eq (nth values 13) ";")
                                    false)
                                false)
                            false)
                        false)
                    false)
                false)
            false))

    (defn bml-body-source-receiver-call3-assignment-count-loop (values count)
