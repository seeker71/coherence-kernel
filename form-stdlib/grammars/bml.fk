    (defn bml-token-cursor-with-rest (tokens index rest)
        (list "bml-token-cursor" tokens index rest))

    (defn bml-token-cursor (tokens index)
        (bml-token-cursor-with-rest tokens index (drop index tokens)))

    (defn bml-token-cursor? (cursor)
        (if (nil? cursor) false
            (str_eq (head cursor) "bml-token-cursor")))

    (defn bml-token-cursor-tokens (cursor)
        (nth cursor 1))

    (defn bml-token-cursor-index (cursor)
        (nth cursor 2))

    (defn bml-token-cursor-rest (cursor)
        (if (gt (len cursor) 3)
            (nth cursor 3)
            (drop (bml-token-cursor-index cursor)
                  (bml-token-cursor-tokens cursor))))

    (defn bml-token-cursor-end? (cursor)
        (nil? (bml-token-cursor-rest cursor)))

    (defn bml-token-cursor-current (cursor)
        (head (bml-token-cursor-rest cursor)))

    (defn bml-token-cursor-advance (cursor)
        (bml-token-cursor-with-rest
            (bml-token-cursor-tokens cursor)
            (add (bml-token-cursor-index cursor) 1)
            (tail (bml-token-cursor-rest cursor))))

    (defn bml-token-span (start length token-values)
        (list "bml-token-span" start length token-values))

    (defn bml-token-span? (span)
        (if (nil? span) false
            (str_eq (head span) "bml-token-span")))

    (defn bml-token-span-start (span)
        (nth span 1))

    (defn bml-token-span-length (span)
        (nth span 2))

    (defn bml-token-span-values (span)
        (nth span 3))

    (defn bml-body-source-with-span (token-values token-span)
        (comp-bml-component "BodySource" (list token-values token-span)))

    (defn bml-body-source (token-values)
        (bml-body-source-with-span
            token-values
            (bml-token-span 0 (len token-values) token-values)))

    (defn bml-body-source-values (body-component)
        (head (comp-bml-fields body-component)))

    (defn bml-body-source-span (body-component)
        (if (gt (len (comp-bml-fields body-component)) 1)
            (nth (comp-bml-fields body-component) 1)
            (bml-token-span
                0
                (len (bml-body-source-values body-component))
                (bml-body-source-values body-component))))

    (defn bml-string-list-contains? (items value)
        (if (nil? items) false
            (if (str_eq (head items) value) true
                (bml-string-list-contains? (tail items) value))))

    (defn bml-body-source-contains? (body-component value)
        (bml-string-list-contains?
            (bml-body-source-values body-component)
            value))

    (defn bml-bmf-as-string-special-escape (next)
        (if (str_eq next (byte_to_str 92)) next
        (if (str_eq next (byte_to_str 39)) next
        (if (str_eq next (byte_to_str 34)) next
        (if (str_eq next "n") (byte_to_str 10)
        (if (str_eq next "t") (byte_to_str 9)
        (if (str_eq next "r") ""
            (empty))))))))

    (defn bml-bmf-as-string-known-escape? (next)
        (or (str_eq next (byte_to_str 92))
        (or (str_eq next (byte_to_str 39))
        (or (str_eq next (byte_to_str 34))
        (or (str_eq next "n")
        (or (str_eq next "t")
            (str_eq next "r")))))))

    (defn bml-bmf-as-string-loop (str-value i acc)
        (if (ge i (str_len str-value)) acc
            (do
                (let ch (char_at str-value i))
                (if (and (str_eq ch (byte_to_str 92))
                         (lt (add i 1) (str_len str-value)))
                    (do
                        (let next (char_at str-value (add i 1)))
                        (let escaped (bml-bmf-as-string-special-escape next))
                        (if (bml-bmf-as-string-known-escape? next)
                            (bml-bmf-as-string-loop
                                str-value
                                (add i 2)
                                (str_concat acc escaped))
                            (bml-bmf-as-string-loop
                                str-value
                                (add i 1)
                                (str_concat acc ch))))
                    (bml-bmf-as-string-loop
                        str-value
                        (add i 1)
                        (str_concat acc ch))))))

    (defn bml-bmf-as-string (str-value)
        (bml-bmf-as-string-loop str-value 0 ""))

    (defn bml-bmf-as-bml-string-escape (ch)
        (if (str_eq ch (byte_to_str 92))
            (str_concat (byte_to_str 92) (byte_to_str 92))
        (if (str_eq ch (byte_to_str 34))
            (str_concat (byte_to_str 92) (byte_to_str 34))
        (if (str_eq ch (byte_to_str 10))
            (str_concat (byte_to_str 92) "n")
        (if (str_eq ch (byte_to_str 13))
            (str_concat (byte_to_str 92) "r")
        (if (str_eq ch (byte_to_str 9))
            (str_concat (byte_to_str 92) "t")
        (if (eq (ord ch) 0)
            (str_concat (byte_to_str 92) "0")
            ch)))))))

    (defn bml-bmf-as-bml-string-loop (str-value i acc)
        (if (ge i (str_len str-value)) acc
            (bml-bmf-as-bml-string-loop
                str-value
                (add i 1)
                (str_concat
                    acc
                    (bml-bmf-as-bml-string-escape
                        (char_at str-value i))))))

    (defn bml-bmf-as-bml-string (str-value)
        (if (nil? str-value) ""
            (bml-bmf-as-bml-string-loop str-value 0 "")))

    (defn bml-body-source-as-string-shape? (body-component)
        (and (bml-body-source-contains? body-component "StringBuffer")
             (and (bml-body-source-contains? body-component "switch")
                  (bml-body-source-contains? body-component "strValue"))))

    (defn bml-body-source-as-bml-string-shape? (body-component)
        (and (bml-body-source-contains? body-component "StringBuffer")
             (and (bml-body-source-contains? body-component "select")
                  (bml-body-source-contains? body-component "strValue"))))

    (defn bml-body-source-exec-as-string (body-component env)
        (if (bml-body-source-as-string-shape? body-component)
            (bml-bmf-as-string (record_get env "strValue"))
            ""))

    (defn bml-body-source-exec-as-bml-string (body-component env)
        (if (bml-body-source-as-bml-string-shape? body-component)
            (bml-bmf-as-bml-string (record_get env "strValue"))
            ""))

    (defn bml-body-source-assignment-at? (values)
        (if (gt (len values) 3)
            (if (str_eq (nth values 1) "=")
                (str_eq (nth values 3) ";")
                false)
            false))

    (defn bml-body-source-assignment-count-loop (values count)
        (if (nil? values) count
            (if (bml-body-source-assignment-at? values)
                (bml-body-source-assignment-count-loop
                    (drop 4 values)
                    (add count 1))
                (bml-body-source-assignment-count-loop
                    (tail values)
                    count))))

    (defn bml-body-source-assignment-count (body-component)
        (bml-body-source-assignment-count-loop
            (bml-body-source-values body-component)
            0))

    (defn bml-body-source-exec-assignments-loop (values self env)
        (if (nil? values) self
            (if (bml-body-source-assignment-at? values)
                (do
                    (record_set
                        self
                        (head values)
                        (record_get env (nth values 2)))
                    (bml-body-source-exec-assignments-loop
                        (drop 4 values)
                        self
                        env))
                (bml-body-source-exec-assignments-loop
                    (tail values)
                    self
                    env))))

    (defn bml-body-source-exec-assignments (body-component self env)
        (bml-body-source-exec-assignments-loop
            (bml-body-source-values body-component)
            self
            env))

