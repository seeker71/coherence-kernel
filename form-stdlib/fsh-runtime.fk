; fsh-runtime.fk — staged-input helpers for the native Form shell.
; preludes: form-stdlib/core.fk
(do
    (defn fsh-read (i acc)
        (do (let b (input_byte i))
            (if (eq b 0) acc
                (fsh-read (add i 1) (str_concat acc (byte_to_str b))))))
    (defn fsh-script () (fsh-read 0 ""))
    0)
