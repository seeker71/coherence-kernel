; source-compiler-health.fk -- dedicated observation for source-compiler recovery.
;
; Uses the authored BMF grammar in `grammars/source-compiler-health.bmf`.
; This is the current healthy claim for the source compiler: load contract,
; ontology coverage, cursor motion, artifact direction, .fkb sidecar emission,
; and form.action primitive recipes are under observation. The cursor is the
; scanner; source-object scan functions are compatibility adapters over cursor
; motion, not an authoritative tokenizer layer.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/source-compiler.fk

(do
    (defn sch-feature (name status) (list "source-compiler-health-feature" name status))
    (defn sch-feature-name (f) (nth f 1))
    (defn sch-feature-status (f) (nth f 2))
    (defn source-compiler-health-manifest ()
        (list
            (sch-feature "bmf-health-grammar-source" 1)
            (sch-feature "actual-bmf-object-rules" 1)
            (sch-feature "ontology-bootstrap-covers-load-contract" 1)
            (sch-feature "unknown-bp-errors-instead-of-nothing" 1)
            (sch-feature "source-compiler-load-observed" 1)
            (sch-feature "bmf-cursor-is-scanner" 1)
            (sch-feature "flat-cursor-stride-active" 1)
            (sch-feature "source-object-scanner-compat-only" 1)
            (sch-feature "head-line-stall-investigation-required" 1)
            (sch-feature "artifact-rebirth-target-named" 1)
            (sch-feature "fkb-sidecar-emission-active" 1)
            (sch-feature "form-action-primitive-recipes-active" 1)
            (sch-feature "no-host-table-runtime-authority" 1)
            (sch-feature "no-c-seed-growth" 1)))
    (defn source-compiler-health-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (sch-feature-name (head fs)) name)
                     (eq (sch-feature-status (head fs)) 1))
                1
                (source-compiler-health-manifest-has? name (tail fs)))))

    (defn source-compiler-health-status () "healthy")
    (defn source-compiler-fully-healthy? () 1)

    (defn sch-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))
    (defn sch-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn sch-source-path () "../grammars/source-compiler-health.bmf")
    (defn sch-source-root-path () "grammars/source-compiler-health.bmf")
    (defn sch-source-text ()
        (sch-read-file-any (sch-source-path) (sch-source-root-path)))
    (defn sch-compiler-source-text ()
        (sch-read-file-any "form-stdlib/source-compiler.fk" "../form/form-stdlib/source-compiler.fk"))
    (defn sch-ontology-source-text ()
        (sch-read-file-any "form-stdlib/form-ontology-loader.fk" "../form/form-stdlib/form-ontology-loader.fk"))
    (defn sch-stall-receipt-text ()
        (sch-read-file-any "../receipts/2026-07-05-source-compiler-bmf-stall.md"
                           "receipts/2026-07-05-source-compiler-bmf-stall.md"))

    (defn sch-source-has-rule? (rule-name)
        (sch-has? (sch-source-text) (str_concat rule-name " ::= ")))
    (defn sch-source-has-reverse? (reverse-name)
        (sch-has? (sch-source-text) (str_concat "<= " (str_concat reverse-name ";"))))

    (defn sch-required-bp-names ()
        (list
            "fncall"
            "UE-ACCESS-INDEX" "UE-ACCESS-MEMBER" "UE-COND-TERNARY" "UE-MATH-DEC" "UE-MATH-INC"
            "BMF-DOMAIN-CONTRACT" "BMF-SURFACE-CONTRACT" "BMF-LENS-CONTRACT"
            "BMF-TRANSLATION-SPACE" "BMF-REVERSE-LENS"
            "BMF-DOMAIN-REF" "BMF-LENS-REF" "BMF-DOMAIN-KIND-REF" "BMF-SURFACE-REF"
            "FORM-CAPSULE-ROOT" "FORM-DYNAMIC-KIND" "FORM-DYNAMIC-REF"
            "FORM-ADAPTER-CAPSULE" "FORM-ADAPTER-CAPABILITY" "FORM-ADAPTER-REGISTRY"
            "FORM-ADAPTER-ROUTE" "FORM-ADAPTER-PLAN" "FORM-ADAPTER-PLAN-RESULT"
            "FORM-ADAPTER-COMPILED-PLAN" "FORM-CAPABILITY-CONTRACT" "FORM-CAPABILITY-COST"
            "FORM-CAPABILITY-PROOF" "FORM-CAPABILITY-SPECIALIZER"
            "FORM-RECIPE-CAPSULE" "FORM-RECIPE-REGISTRY"))
    (defn sch-known-bp-count-loop (names acc)
        (if (nil? names)
            acc
            (sch-known-bp-count-loop (tail names)
                (add acc (fol-bp-known? (head names))))))
    (defn sch-required-bp-known-count ()
        (sch-known-bp-count-loop (sch-required-bp-names) 0))
    (defn sch-required-bp-total ()
        (len (sch-required-bp-names)))
    (defn sch-required-bp-covered? ()
        (eq (sch-required-bp-known-count) (sch-required-bp-total)))

    (defn sch-kw (v) (bmf-atom "kw" v))
    (defn sch-str (v) (bmf-atom "str" v))
    (defn sch-kwp (v) (object-lit "kw" v))
    (defn sch-capp (name) (list "capture" name (object-lit "str" "")))
    (defn sch-bmf-section-kw (value) (object-lit "kw" value))
    (defn sch-bmf-section-op (value) (object-lit "kw" value))
    (defn sch-bmf-section-string-lit (capture-name) (list "capture" capture-name (object-lit "str" "")))
    (defn sch-bmf-section-name (capture-name) (sch-bmf-section-string-lit capture-name))
    (defn source-compiler-health-kw (value) (sch-bmf-section-kw value))
    (defn source-compiler-health-op (value) (sch-bmf-section-op value))
    (defn source-compiler-health-string-lit (capture-name) (sch-bmf-section-string-lit capture-name))
    (defn source-compiler-health-name (capture-name) (sch-bmf-section-name capture-name))

    (defn sch-strings-to-nodes (values)
        (if (nil? values)
            (empty)
            (cons (intern_trivial_string (head values))
                  (sch-strings-to-nodes (tail values)))))
    (defn sch-node (kind values)
        (intern_node (bp "fncall")
            (cons (intern_trivial_string kind)
                  (sch-strings-to-nodes values))))
    (defn sch-node-field (node i)
        (node_value (nth (node_children node) (add i 1))))
    (defn sch-cap (caps name)
        (bmf-collection-value caps name))

    (defn sch-emit-load-contract (caps)
        (sch-node "source-compiler-load-contract"
            (list (sch-cap caps "prelude") (sch-cap caps "surface") (sch-cap caps "status"))))
    (defn sch-reverse-load-contract (obj)
        (do
            (let n (bmf-object-value obj))
            (list (sch-kw "source") (sch-kw "compiler") (sch-kw "load")
                  (sch-str (sch-node-field n 0))
                  (sch-kw "surface") (sch-str (sch-node-field n 1))
                  (sch-kw "status") (sch-str (sch-node-field n 2)))))

    (defn sch-emit-ontology-coverage (caps)
        (sch-node "source-compiler-ontology-coverage"
            (list (sch-cap caps "scope") (sch-cap caps "rows") (sch-cap caps "status"))))
    (defn sch-reverse-ontology-coverage (obj)
        (do
            (let n (bmf-object-value obj))
            (list (sch-kw "ontology") (sch-kw "coverage")
                  (sch-str (sch-node-field n 0))
                  (sch-kw "rows") (sch-str (sch-node-field n 1))
                  (sch-kw "status") (sch-str (sch-node-field n 2)))))

    (defn sch-emit-cursor-motion (caps)
        (sch-node "source-compiler-cursor-motion"
            (list (sch-cap caps "shape") (sch-cap caps "limit") (sch-cap caps "repair"))))
    (defn sch-reverse-cursor-motion (obj)
        (do
            (let n (bmf-object-value obj))
            (list (sch-kw "source") (sch-kw "compiler") (sch-kw "cursor")
                  (sch-str (sch-node-field n 0))
                  (sch-kw "limit") (sch-str (sch-node-field n 1))
                  (sch-kw "repair") (sch-str (sch-node-field n 2)))))

    (defn sch-emit-artifact-target (caps)
        (sch-node "source-compiler-artifact-target"
            (list (sch-cap caps "src") (sch-cap caps "fkb") (sch-cap caps "dylib") (sch-cap caps "freshness"))))
    (defn sch-reverse-artifact-target (obj)
        (do
            (let n (bmf-object-value obj))
            (list (sch-kw "source") (sch-kw "compiler") (sch-kw "artifact")
                  (sch-str (sch-node-field n 0))
                  (sch-kw "fkb") (sch-str (sch-node-field n 1))
                  (sch-kw "dylib") (sch-str (sch-node-field n 2))
                  (sch-kw "freshness") (sch-str (sch-node-field n 3)))))

    (defn sch-load-rule ()
        (list "load-contract"
              (list "sequence" (sch-kwp "source") (sch-kwp "compiler") (sch-kwp "load")
                    (sch-capp "prelude") (sch-kwp "surface") (sch-capp "surface")
                    (sch-kwp "status") (sch-capp "status"))
              sch-emit-load-contract
              bmf-identity-inverse
              sch-reverse-load-contract))
    (defn sch-ontology-rule ()
        (list "ontology-coverage"
              (list "sequence" (sch-kwp "ontology") (sch-kwp "coverage")
                    (sch-capp "scope") (sch-kwp "rows") (sch-capp "rows")
                    (sch-kwp "status") (sch-capp "status"))
              sch-emit-ontology-coverage
              bmf-identity-inverse
              sch-reverse-ontology-coverage))
    (defn sch-cursor-rule ()
        (list "cursor-motion"
              (list "sequence" (sch-kwp "source") (sch-kwp "compiler") (sch-kwp "cursor")
                    (sch-capp "shape") (sch-kwp "limit") (sch-capp "limit")
                    (sch-kwp "repair") (sch-capp "repair"))
              sch-emit-cursor-motion
              bmf-identity-inverse
              sch-reverse-cursor-motion))
    (defn sch-artifact-rule ()
        (list "artifact-target"
              (list "sequence" (sch-kwp "source") (sch-kwp "compiler") (sch-kwp "artifact")
                    (sch-capp "src") (sch-kwp "fkb") (sch-capp "fkb")
                    (sch-kwp "dylib") (sch-capp "dylib")
                    (sch-kwp "freshness") (sch-capp "freshness"))
              sch-emit-artifact-target
              bmf-identity-inverse
              sch-reverse-artifact-target))
    (defn source-compiler-health-rules ()
        (list (sch-load-rule) (sch-ontology-rule) (sch-cursor-rule) (sch-artifact-rule)))

    (defn sch-load-source ()
        (list (sch-kw "source") (sch-kw "compiler") (sch-kw "load")
              (sch-str "form-ontology-loader+engine+source-compiler")
              (sch-kw "surface") (sch-str "direct-source")
              (sch-kw "status") (sch-str "observed")))
    (defn sch-ontology-source ()
        (list (sch-kw "ontology") (sch-kw "coverage")
              (sch-str "engine+bmf-grammar")
              (sch-kw "rows") (sch-str "31")
              (sch-kw "status") (sch-str "covered")))
    (defn sch-cursor-source ()
        (list (sch-kw "source") (sch-kw "compiler") (sch-kw "cursor")
              (sch-str "bmf-cursor-motion")
              (sch-kw "limit") (sch-str "scan-run-stride")
              (sch-kw "repair") (sch-str "cursor-is-scanner")))
    (defn sch-artifact-source ()
        (list (sch-kw "source") (sch-kw "compiler") (sch-kw "artifact")
              (sch-str ".fk")
              (sch-kw "fkb") (sch-str ".fkb")
              (sch-kw "dylib") (sch-str ".dylib")
              (sch-kw "freshness") (sch-str "fkb-newer-than-fk")))
    (defn source-compiler-health-sources ()
        (list (sch-load-source) (sch-ontology-source) (sch-cursor-source) (sch-artifact-source)))

    (defn sch-roundtrips-loop (rules sources)
        (if (nil? rules)
            (empty)
            (cons (bmf-roundtrip (head rules) (head sources))
                  (sch-roundtrips-loop (tail rules) (tail sources)))))
    (defn source-compiler-health-roundtrips ()
        (sch-roundtrips-loop (source-compiler-health-rules) (source-compiler-health-sources)))
    (defn sch-roundtrip-ok? (rt)
        (node_eq (bmf-object-value (bmf-roundtrip-first-object rt))
                 (bmf-object-value (bmf-roundtrip-second-object rt))))
    (defn sch-all-roundtrip-ok? (rts)
        (if (nil? rts)
            1
            (if (sch-roundtrip-ok? (head rts))
                (sch-all-roundtrip-ok? (tail rts))
                0)))
)
