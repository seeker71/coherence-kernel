; model-vitality.fk - body-readable model data and vitality rows.
;
; Floor: planning and receipt rows only. Model architecture, tensors, deltas,
; optimizer state, eval receipts, lineage, and vitality are explicit Form data;
; local files, GPU buffers, MLX arrays, and emitted binaries are cache/projection
; carriers and cannot be named as source of truth here.
;
; North star: every model cell can express its resonance, vitality, sovereignty,
; and trust through content-addressed substrate rows. Large tensors are chunk
; cells with merkle roots; mesh peers share slices by merkle; the body reads a
; model-vitality row and focuses attention on the next needed teaching step.
; Focused proof and fast release are vitality signals, not afterthoughts.
;
; Real chunk storage floor: when loaded with cell-log-store.fk and sha256.fk,
; this file can store a tensor chunk payload in the segmented file carrier,
; reopen it, read the bytes back, and verify the content digest. GPU/MLX/Metal
; carrier rows are cache/projection receipts: a carrier must return bytes whose
; re-hash matches the source chunk digest before the body treats it as faithful.
;
; Physical carrier floor: CPU, generic GPU via Metal, Metal, and MLX may now be
; proven by local native witnesses that materialize bytes into carrier memory,
; dematerialize them back, and re-hash the returned bytes. If another host lacks
; one carrier, that absence is a named implementation gap rather than hidden as
; model truth.
;
; Production ingestion floor: deployed pulse and runtime/front-door readings can
; be represented as explicit production vitality rows and routed through the
; same live model-vitality store read. Shell probes may capture public slices,
; but the body-readable grammar, validity gates, and focus route live here.
;
; Native HTTP capture floor: all kernels expose http_get as a non-shell native
; external HTTP carrier returning a Form dict. The emitted fourth arm carries
; plaintext http:// through DNS/TCP/socket/read/write and verified https://
; through runtime-loaded OpenSSL/BoringSSL-compatible TLS. This file lifts that
; dict into model-vitality rows. The fourth arm now also captures response
; header rows and can read them through native _get, so production HTTPS
; authority receipts are carried by the native body. Explicit request-header
; rows now forward through all kernels, including fkwu. The emitted fourth arm
; now measures elapsed request duration inside the native carrier. Next floor:
; larger bodies and streaming/backpressure rows.

(do
    (defn mv-kind-model-architecture () "model/architecture")
    (defn mv-kind-tensor-chunk () "model/tensor-chunk")
    (defn mv-kind-delta-slice () "model/delta-slice")
    (defn mv-kind-optimizer-state () "model/optimizer-state")
    (defn mv-kind-eval-receipt () "model/eval-receipt")
    (defn mv-kind-vitality () "model/vitality")
    (defn mv-kind-lineage () "model/lineage")
    (defn mv-kind-chunk-storage () "model/chunk-storage")
    (defn mv-kind-carrier-projection () "model/carrier-projection")
    (defn mv-kind-vitality-route () "model/vitality-route")
    (defn mv-kind-ingest-source () "model/ingest-source")
    (defn mv-kind-ingest-chunk () "model/ingest-chunk")
    (defn mv-kind-chunk-set-root () "model/chunk-set-root")
    (defn mv-kind-live-vitality-row () "model/live-vitality-row")
    (defn mv-kind-production-vitality-ingest () "model/production-vitality-ingest")
    (defn mv-kind-native-http-capture () "model/native-http-capture")

    (defn mv-floor () (list
        "floor"
        "explicit-model-data-rows"
        "chunk-cells-with-merkle"
        "eval-receipts"
        "body-readable-vitality"
        "carrier-cache-not-truth"
        "smallest-focused-proof"))

    (defn mv-north-star () (list
        "north-star"
        "architecture-weights-deltas-optimizer-evals-lineage-are-cells"
        "resonance-vitality-sovereignty-trust-guide-focus"
        "mesh-shares-content-addressed-slices"
        "gpu-mlx-metal-are-materialized-carriers"
        "promotion-is-earned-by-receipts"
        "fast-release-cadence-is-vitality"))

    (defn mv-score-valid? (score) (and (ge score 0) (le score 100)))
    (defn mv-nonempty? (value) (gt (str_len value) 0))
    (defn mv-row? (value tag arity)
        (if (eq (len value) arity) (str_eq (nth value 0) tag) false))

    (defn mv-cell-ref (kind id merkle local-node floor north)
        (list "model-cell-ref" kind id merkle local-node floor north))
    (defn mv-cell-ref? (value) (mv-row? value "model-cell-ref" 7))
    (defn mv-cell-kind (ref) (nth ref 1))
    (defn mv-cell-id (ref) (nth ref 2))
    (defn mv-cell-merkle (ref) (nth ref 3))
    (defn mv-cell-local-node (ref) (nth ref 4))
    (defn mv-cell-floor (ref) (nth ref 5))
    (defn mv-cell-north-star (ref) (nth ref 6))
    (defn mv-cell-ref-text-valid? (ref)
        (and (mv-nonempty? (mv-cell-kind ref))
        (and (mv-nonempty? (mv-cell-id ref))
        (and (mv-nonempty? (mv-cell-merkle ref))
             (mv-nonempty? (mv-cell-local-node ref))))))
    (defn mv-cell-ref-guidance-valid? (ref)
        (and (gt (len (mv-cell-floor ref)) 0)
             (gt (len (mv-cell-north-star ref)) 0)))
    (defn mv-cell-ref-valid? (ref)
        (if (mv-cell-ref? ref)
            (and (mv-cell-ref-text-valid? ref)
                 (mv-cell-ref-guidance-valid? ref))
            false))

    (defn mv-tensor-chunk
        (tensor-id chunk-index shape strides format provenance merkle elements bytes cache-source)
        (list
            "model-tensor-chunk"
            tensor-id
            chunk-index
            shape
            strides
            format
            provenance
            merkle
            elements
            bytes
            cache-source))
    (defn mv-tensor-chunk? (chunk) (mv-row? chunk "model-tensor-chunk" 11))
    (defn mv-chunk-tensor-id (chunk) (nth chunk 1))
    (defn mv-chunk-index (chunk) (nth chunk 2))
    (defn mv-chunk-shape (chunk) (nth chunk 3))
    (defn mv-chunk-strides (chunk) (nth chunk 4))
    (defn mv-chunk-format (chunk) (nth chunk 5))
    (defn mv-chunk-provenance (chunk) (nth chunk 6))
    (defn mv-chunk-merkle (chunk) (nth chunk 7))
    (defn mv-chunk-elements (chunk) (nth chunk 8))
    (defn mv-chunk-bytes (chunk) (nth chunk 9))
    (defn mv-chunk-cache-source (chunk) (nth chunk 10))
    (defn mv-cache-is-source? (chunk) (eq (mv-chunk-cache-source chunk) 1))
    (defn mv-tensor-chunk-text-valid? (chunk)
        (and (mv-nonempty? (mv-chunk-tensor-id chunk))
        (and (mv-nonempty? (mv-chunk-format chunk))
        (and (mv-nonempty? (mv-chunk-provenance chunk))
             (mv-nonempty? (mv-chunk-merkle chunk))))))
    (defn mv-tensor-chunk-shape-valid? (chunk)
        (and (ge (mv-chunk-index chunk) 0)
        (and (gt (len (mv-chunk-shape chunk)) 0)
        (and (gt (len (mv-chunk-strides chunk)) 0)
        (and (gt (mv-chunk-elements chunk) 0)
             (gt (mv-chunk-bytes chunk) 0))))))
    (defn mv-tensor-chunk-valid? (chunk)
        (if (mv-tensor-chunk? chunk)
            (and (mv-tensor-chunk-text-valid? chunk)
            (and (mv-tensor-chunk-shape-valid? chunk)
                 (not (mv-cache-is-source? chunk))))
            false))

    (defn mv-eval-receipt
        (model-id dataset-merkle accuracy confidence trust resonance vitality sovereignty energy latency memory coverage freshness mergeability readiness samples eval-merkle)
        (list
            "model-eval-receipt"
            model-id
            dataset-merkle
            accuracy
            confidence
            trust
            resonance
            vitality
            sovereignty
            energy
            latency
            memory
            coverage
            freshness
            mergeability
            readiness
            samples
            eval-merkle))
    (defn mv-eval-receipt? (receipt) (mv-row? receipt "model-eval-receipt" 18))
    (defn mv-eval-model-id (r) (nth r 1))
    (defn mv-eval-dataset (r) (nth r 2))
    (defn mv-eval-accuracy (r) (nth r 3))
    (defn mv-eval-confidence (r) (nth r 4))
    (defn mv-eval-trust (r) (nth r 5))
    (defn mv-eval-resonance (r) (nth r 6))
    (defn mv-eval-vitality (r) (nth r 7))
    (defn mv-eval-sovereignty (r) (nth r 8))
    (defn mv-eval-energy (r) (nth r 9))
    (defn mv-eval-latency (r) (nth r 10))
    (defn mv-eval-memory (r) (nth r 11))
    (defn mv-eval-coverage (r) (nth r 12))
    (defn mv-eval-freshness (r) (nth r 13))
    (defn mv-eval-mergeability (r) (nth r 14))
    (defn mv-eval-readiness (r) (nth r 15))
    (defn mv-eval-samples (r) (nth r 16))
    (defn mv-eval-merkle (r) (nth r 17))

    (defn mv-scores-valid? (scores)
        (if (eq (len scores) 0)
            true
            (and (mv-score-valid? (head scores))
                 (mv-scores-valid? (tail scores)))))

    (defn mv-eval-signals-valid? (r)
        (mv-scores-valid? (list
            (mv-eval-accuracy r)
            (mv-eval-confidence r)
            (mv-eval-trust r)
            (mv-eval-resonance r)
            (mv-eval-vitality r)
            (mv-eval-sovereignty r)
            (mv-eval-energy r)
            (mv-eval-latency r)
            (mv-eval-memory r)
            (mv-eval-coverage r)
            (mv-eval-freshness r)
            (mv-eval-mergeability r)
            (mv-eval-readiness r))))

    (defn mv-eval-receipt-valid? (r)
        (if (mv-eval-receipt? r)
            (and
                (mv-nonempty? (mv-eval-model-id r))
                (and
                    (mv-nonempty? (mv-eval-dataset r))
                    (and
                        (mv-nonempty? (mv-eval-merkle r))
                        (and
                            (gt (mv-eval-samples r) 0)
                            (mv-eval-signals-valid? r)))))
            false))

    (defn mv-quality-score (r)
        (div
            (add
                (mv-eval-accuracy r)
                (add
                    (mv-eval-confidence r)
                    (add
                        (mv-eval-trust r)
                        (add
                            (mv-eval-resonance r)
                            (add
                                (mv-eval-vitality r)
                                (add
                                    (mv-eval-sovereignty r)
                                    (add
                                        (mv-eval-coverage r)
                                        (add
                                            (mv-eval-freshness r)
                                            (add
                                                (mv-eval-mergeability r)
                                                (mv-eval-readiness r))))))))))
            10))

    (defn mv-pressure-score (r)
        (div (add (mv-eval-energy r) (add (mv-eval-latency r) (mv-eval-memory r))) 3))

    (defn mv-vitality-score (r)
        (sub (mv-quality-score r) (div (mv-pressure-score r) 2)))

    (defn mv-focus (r)
        (if (lt (mv-eval-trust r) 70)
            "teach-trust"
            (if (lt (mv-eval-sovereignty r) 70)
                "restore-sovereignty"
                (if (lt (mv-eval-resonance r) 70)
                    "seek-resonance"
                    (if (lt (mv-eval-vitality r) 70)
                        "restore-vitality"
                        (if (lt (mv-eval-coverage r) 70)
                            "learn-more-samples"
                            (if (lt (mv-eval-mergeability r) 70)
                                "repair-mergeability"
                                (if (gt (mv-pressure-score r) 70)
                                    "compress-or-route"
                                    (if (ge (mv-eval-readiness r) 80)
                                        "serve-and-watch"
                                        "keep-learning")))))))))

    (defn mv-vitality-receipt (r)
        (list
            "model-vitality-receipt"
            (mv-eval-model-id r)
            (mv-eval-merkle r)
            (mv-quality-score r)
            (mv-pressure-score r)
            (mv-vitality-score r)
            (mv-focus r)
            (list
                "resonance" (mv-eval-resonance r)
                "vitality" (mv-eval-vitality r)
                "sovereignty" (mv-eval-sovereignty r)
                "trust" (mv-eval-trust r))
            (mv-floor)
            (mv-north-star)))
    (defn mv-vitality-receipt? (v) (mv-row? v "model-vitality-receipt" 10))
    (defn mv-vitality-model-id (v) (nth v 1))
    (defn mv-vitality-eval-merkle (v) (nth v 2))
    (defn mv-vitality-quality (v) (nth v 3))
    (defn mv-vitality-pressure (v) (nth v 4))
    (defn mv-vitality-score-value (v) (nth v 5))
    (defn mv-vitality-focus (v) (nth v 6))
    (defn mv-vitality-lenses (v) (nth v 7))
    (defn mv-vitality-valid? (v)
        (if (mv-vitality-receipt? v)
            (and (mv-nonempty? (mv-vitality-model-id v))
            (and (mv-nonempty? (mv-vitality-eval-merkle v))
            (and (mv-score-valid? (mv-vitality-quality v))
            (and (ge (mv-vitality-pressure v) 0)
            (and (mv-nonempty? (mv-vitality-focus v))
                 (gt (len (mv-vitality-lenses v)) 0))))))
            false))

    (defn mv-lineage (architecture weights deltas optimizer evals vitality ancestors)
        (list "model-lineage" architecture weights deltas optimizer evals vitality ancestors))
    (defn mv-lineage? (value) (mv-row? value "model-lineage" 8))
    (defn mv-lineage-architecture (l) (nth l 1))
    (defn mv-lineage-weights (l) (nth l 2))
    (defn mv-lineage-deltas (l) (nth l 3))
    (defn mv-lineage-optimizer (l) (nth l 4))
    (defn mv-lineage-evals (l) (nth l 5))
    (defn mv-lineage-vitality (l) (nth l 6))
    (defn mv-lineage-ancestors (l) (nth l 7))
    (defn mv-lineage-valid? (l)
        (if (mv-lineage? l)
            (and (mv-cell-ref-valid? (mv-lineage-architecture l))
            (and (gt (len (mv-lineage-weights l)) 0)
            (and (gt (len (mv-lineage-deltas l)) 0)
            (and (mv-cell-ref-valid? (mv-lineage-optimizer l))
            (and (gt (len (mv-lineage-evals l)) 0)
            (and (mv-vitality-valid? (mv-lineage-vitality l))
                 (gt (len (mv-lineage-ancestors l)) 0)))))))
            false))

    (defn mv-body-read (v)
        (list
            "body-read-model-vitality"
            (mv-vitality-model-id v)
            (mv-vitality-focus v)
            (mv-vitality-score-value v)
            (mv-vitality-lenses v)
            (mv-vitality-eval-merkle v)))
    (defn mv-body-read? (value) (mv-row? value "body-read-model-vitality" 6))
    (defn mv-body-read-focus (value) (nth value 2))
    (defn mv-body-read-score (value) (nth value 3))
    (defn mv-body-read-valid? (value)
        (if (mv-body-read? value)
            (and
                (mv-nonempty? (nth value 1))
                (and
                    (mv-nonempty? (mv-body-read-focus value))
                    (ge (mv-body-read-score value) 0)))
            false))

    ;; ---- real chunk storage receipts -------------------------------------
    ;; These functions intentionally depend on sha256.fk + cell-log-store.fk
    ;; when called. model-vitality-band stays pure/four-way; the real storage
    ;; band loads those carrier files and proves physical file-backed storage.
    (defn mv-bytes-eq? (a b)
        (if (eq (len a) 0)
            (if (eq (len b) 0) 1 0)
            (if (eq (len b) 0) 0
                (if (eq (head a) (head b))
                    (mv-bytes-eq? (tail a) (tail b))
                    0))))

    (defn mv-payload-digest (payload)
        (sha256 (cls-str-bytes payload)))

    (defn mv-chunk-storage-key (chunk)
        (str_concat "model-chunk:" (mv-chunk-merkle chunk)))

    (defn mv-store-chunk (store chunk payload)
        (do
            (let key (mv-chunk-storage-key chunk))
            (let digest (mv-payload-digest payload))
            (let next-store (cls-put store key payload))
            (list
                "model-chunk-store-receipt"
                next-store
                key
                (mv-chunk-merkle chunk)
                digest
                (str_len payload)
                "stored")))
    (defn mv-store-chunk-receipt? (value) (mv-row? value "model-chunk-store-receipt" 7))
    (defn mv-store-chunk-store (r) (nth r 1))
    (defn mv-store-chunk-key (r) (nth r 2))
    (defn mv-store-chunk-merkle (r) (nth r 3))
    (defn mv-store-chunk-digest (r) (nth r 4))
    (defn mv-store-chunk-bytes (r) (nth r 5))
    (defn mv-store-chunk-status (r) (nth r 6))
    (defn mv-store-chunk-valid? (r)
        (if (mv-store-chunk-receipt? r)
            (and (mv-nonempty? (mv-store-chunk-key r))
            (and (mv-nonempty? (mv-store-chunk-merkle r))
            (and (gt (len (mv-store-chunk-digest r)) 0)
            (and (gt (mv-store-chunk-bytes r) 0)
                 (str_eq (mv-store-chunk-status r) "stored")))))
            false))

    (defn mv-read-stored-chunk (store receipt)
        (do
            (let got (cls-get store (mv-store-chunk-key receipt)))
            (let found (cls-found? got))
            (let payload (if (eq found 1) (cls-value got) ""))
            (let digest (if (eq found 1) (mv-payload-digest payload) (list)))
            (list
                "model-chunk-read-receipt"
                (mv-store-chunk-key receipt)
                found
                digest
                (str_len payload)
                (mv-store-chunk-digest receipt))))
    (defn mv-read-stored-chunk? (value) (mv-row? value "model-chunk-read-receipt" 6))
    (defn mv-read-chunk-key (r) (nth r 1))
    (defn mv-read-chunk-found (r) (nth r 2))
    (defn mv-read-chunk-digest (r) (nth r 3))
    (defn mv-read-chunk-bytes (r) (nth r 4))
    (defn mv-read-chunk-expected-digest (r) (nth r 5))
    (defn mv-read-stored-chunk-valid? (r)
        (if (mv-read-stored-chunk? r)
            (and (eq (mv-read-chunk-found r) 1)
            (and (gt (mv-read-chunk-bytes r) 0)
                 (eq (mv-bytes-eq? (mv-read-chunk-digest r) (mv-read-chunk-expected-digest r)) 1)))
            false))

    ;; ---- carrier projection re-hash receipts -----------------------------
    (defn mv-carrier-known? (carrier)
        (if (str_eq carrier "cpu:buffer") 1
            (if (str_eq carrier "gpu:buffer") 1
                (if (str_eq carrier "mlx:array") 1
                    (if (str_eq carrier "metal:buffer") 1 0)))))

    (defn mv-carrier-projection-rehash (carrier codec chunk source-digest returned-payload)
        (do
            (let returned-digest (mv-payload-digest returned-payload))
            (list
                "model-carrier-projection-rehash"
                carrier
                codec
                (mv-chunk-merkle chunk)
                source-digest
                returned-digest
                (str_len returned-payload)
                (if (eq (mv-bytes-eq? source-digest returned-digest) 1)
                    "rehash-ok"
                    "rehash-mismatch"))))
    (defn mv-carrier-projection-rehash? (value)
        (mv-row? value "model-carrier-projection-rehash" 8))
    (defn mv-carrier-projection-carrier (r) (nth r 1))
    (defn mv-carrier-projection-codec (r) (nth r 2))
    (defn mv-carrier-projection-merkle (r) (nth r 3))
    (defn mv-carrier-projection-source-digest (r) (nth r 4))
    (defn mv-carrier-projection-returned-digest (r) (nth r 5))
    (defn mv-carrier-projection-bytes (r) (nth r 6))
    (defn mv-carrier-projection-status (r) (nth r 7))
    (defn mv-carrier-projection-valid? (r)
        (if (mv-carrier-projection-rehash? r)
            (and (eq (mv-carrier-known? (mv-carrier-projection-carrier r)) 1)
            (and (mv-nonempty? (mv-carrier-projection-codec r))
            (and (mv-nonempty? (mv-carrier-projection-merkle r))
            (and (gt (mv-carrier-projection-bytes r) 0)
            (and (str_eq (mv-carrier-projection-status r) "rehash-ok")
                 (eq (mv-bytes-eq?
                        (mv-carrier-projection-source-digest r)
                        (mv-carrier-projection-returned-digest r)) 1))))))
            false))

    ;; ---- multi-chunk safetensors / MLX ingest rows ----------------------
    (defn mv-ingest-source (source-kind source-id path format header-digest total-bytes tensor-count floor north)
        (list
            "model-ingest-source"
            source-kind
            source-id
            path
            format
            header-digest
            total-bytes
            tensor-count
            floor
            north))
    (defn mv-ingest-source? (value) (mv-row? value "model-ingest-source" 10))
    (defn mv-ingest-source-kind (s) (nth s 1))
    (defn mv-ingest-source-id (s) (nth s 2))
    (defn mv-ingest-source-path (s) (nth s 3))
    (defn mv-ingest-source-format (s) (nth s 4))
    (defn mv-ingest-source-header-digest (s) (nth s 5))
    (defn mv-ingest-source-total-bytes (s) (nth s 6))
    (defn mv-ingest-source-tensor-count (s) (nth s 7))
    (defn mv-ingest-source-floor (s) (nth s 8))
    (defn mv-ingest-source-north (s) (nth s 9))
    (defn mv-ingest-source-valid? (s)
        (if (mv-ingest-source? s)
            (and (mv-nonempty? (mv-ingest-source-kind s))
            (and (mv-nonempty? (mv-ingest-source-id s))
            (and (mv-nonempty? (mv-ingest-source-path s))
            (and (mv-nonempty? (mv-ingest-source-format s))
            (and (gt (len (mv-ingest-source-header-digest s)) 0)
            (and (gt (mv-ingest-source-total-bytes s) 0)
            (and (gt (mv-ingest-source-tensor-count s) 0)
            (and (gt (len (mv-ingest-source-floor s)) 0)
                 (gt (len (mv-ingest-source-north s)) 0)))))))))
            false))

    (defn mv-ingest-chunk-spec
        (tensor-id chunk-index offset length shape strides format provenance expected-digest)
        (list
            "model-ingest-chunk-spec"
            tensor-id
            chunk-index
            offset
            length
            shape
            strides
            format
            provenance
            expected-digest))
    (defn mv-ingest-chunk-spec? (value) (mv-row? value "model-ingest-chunk-spec" 10))
    (defn mv-ingest-chunk-tensor-id (c) (nth c 1))
    (defn mv-ingest-chunk-index (c) (nth c 2))
    (defn mv-ingest-chunk-offset (c) (nth c 3))
    (defn mv-ingest-chunk-length (c) (nth c 4))
    (defn mv-ingest-chunk-shape (c) (nth c 5))
    (defn mv-ingest-chunk-strides (c) (nth c 6))
    (defn mv-ingest-chunk-format (c) (nth c 7))
    (defn mv-ingest-chunk-provenance (c) (nth c 8))
    (defn mv-ingest-chunk-expected-digest (c) (nth c 9))
    (defn mv-ingest-chunk-spec-valid? (c)
        (if (mv-ingest-chunk-spec? c)
            (and (mv-nonempty? (mv-ingest-chunk-tensor-id c))
            (and (ge (mv-ingest-chunk-index c) 0)
            (and (ge (mv-ingest-chunk-offset c) 0)
            (and (gt (mv-ingest-chunk-length c) 0)
            (and (gt (len (mv-ingest-chunk-shape c)) 0)
            (and (gt (len (mv-ingest-chunk-strides c)) 0)
            (and (mv-nonempty? (mv-ingest-chunk-format c))
            (and (mv-nonempty? (mv-ingest-chunk-provenance c))
                 (gt (len (mv-ingest-chunk-expected-digest c)) 0)))))))))
            false))

    (defn mv-ingest-chunk-read (source spec)
        (do
            (let payload (read_file_slice
                (mv-ingest-source-path source)
                (mv-ingest-chunk-offset spec)
                (mv-ingest-chunk-length spec)))
            (let digest (mv-payload-digest payload))
            (let chunk (mv-tensor-chunk
                (mv-ingest-chunk-tensor-id spec)
                (mv-ingest-chunk-index spec)
                (mv-ingest-chunk-shape spec)
                (mv-ingest-chunk-strides spec)
                (mv-ingest-chunk-format spec)
                (mv-ingest-chunk-provenance spec)
                (str_concat "sha256:"
                    (str_concat (mv-ingest-source-id source)
                    (str_concat ":chunk-" (cls-int-str (mv-ingest-chunk-index spec)))))
                1
                (mv-ingest-chunk-length spec)
                0))
            (list
                "model-ingest-chunk-read"
                (mv-ingest-source-id source)
                chunk
                (mv-ingest-chunk-offset spec)
                (mv-ingest-chunk-length spec)
                digest
                (mv-ingest-chunk-expected-digest spec)
                payload
                (if (eq (mv-bytes-eq? digest (mv-ingest-chunk-expected-digest spec)) 1)
                    "chunk-digest-ok"
                    "chunk-digest-mismatch"))))
    (defn mv-ingest-chunk-read? (value) (mv-row? value "model-ingest-chunk-read" 9))
    (defn mv-ingest-read-source-id (r) (nth r 1))
    (defn mv-ingest-read-chunk (r) (nth r 2))
    (defn mv-ingest-read-offset (r) (nth r 3))
    (defn mv-ingest-read-length (r) (nth r 4))
    (defn mv-ingest-read-digest (r) (nth r 5))
    (defn mv-ingest-read-expected-digest (r) (nth r 6))
    (defn mv-ingest-read-payload (r) (nth r 7))
    (defn mv-ingest-read-status (r) (nth r 8))
    (defn mv-ingest-chunk-read-valid? (r)
        (if (mv-ingest-chunk-read? r)
            (and (mv-nonempty? (mv-ingest-read-source-id r))
            (and (mv-tensor-chunk-valid? (mv-ingest-read-chunk r))
            (and (gt (mv-ingest-read-length r) 0)
            (and (eq (str_len (mv-ingest-read-payload r)) (mv-ingest-read-length r))
            (and (str_eq (mv-ingest-read-status r) "chunk-digest-ok")
                 (eq (mv-bytes-eq? (mv-ingest-read-digest r) (mv-ingest-read-expected-digest r)) 1))))))
            false))

    (defn mv-store-ingest-chunk (store read)
        (mv-store-chunk store (mv-ingest-read-chunk read) (mv-ingest-read-payload read)))

    (defn mv-chunk-set-root (source reads root-digest total-bytes)
        (list
            "model-chunk-set-root"
            (mv-ingest-source-id source)
            (len reads)
            total-bytes
            root-digest
            reads))
    (defn mv-chunk-set-root? (value) (mv-row? value "model-chunk-set-root" 6))
    (defn mv-chunk-set-source-id (r) (nth r 1))
    (defn mv-chunk-set-count (r) (nth r 2))
    (defn mv-chunk-set-total-bytes (r) (nth r 3))
    (defn mv-chunk-set-root-digest (r) (nth r 4))
    (defn mv-chunk-set-reads (r) (nth r 5))
    (defn mv-chunk-set-root-valid? (r)
        (if (mv-chunk-set-root? r)
            (and (mv-nonempty? (mv-chunk-set-source-id r))
            (and (gt (mv-chunk-set-count r) 1)
            (and (gt (mv-chunk-set-total-bytes r) 0)
            (and (gt (len (mv-chunk-set-root-digest r)) 0)
                 (eq (len (mv-chunk-set-reads r)) (mv-chunk-set-count r))))))
            false))

    ;; ---- physical carrier materialize/dematerialize receipts -------------
    (defn mv-physical-carrier-rehash
        (carrier host device codec chunk source-digest materialized-bytes returned-payload witness)
        (do
            (let returned-digest (mv-payload-digest returned-payload))
            (list
                "model-physical-carrier-rehash"
                carrier
                host
                device
                codec
                (mv-chunk-merkle chunk)
                source-digest
                returned-digest
                materialized-bytes
                (str_len returned-payload)
                witness
                (if (eq (mv-bytes-eq? source-digest returned-digest) 1)
                    "physical-rehash-ok"
                    "physical-rehash-mismatch"))))
    (defn mv-physical-carrier-rehash? (value)
        (mv-row? value "model-physical-carrier-rehash" 12))
    (defn mv-physical-carrier-name (r) (nth r 1))
    (defn mv-physical-carrier-host (r) (nth r 2))
    (defn mv-physical-carrier-device (r) (nth r 3))
    (defn mv-physical-carrier-codec (r) (nth r 4))
    (defn mv-physical-carrier-source-digest (r) (nth r 6))
    (defn mv-physical-carrier-returned-digest (r) (nth r 7))
    (defn mv-physical-carrier-materialized-bytes (r) (nth r 8))
    (defn mv-physical-carrier-returned-bytes (r) (nth r 9))
    (defn mv-physical-carrier-witness (r) (nth r 10))
    (defn mv-physical-carrier-status (r) (nth r 11))
    (defn mv-physical-carrier-valid? (r)
        (if (mv-physical-carrier-rehash? r)
            (and (eq (mv-carrier-known? (mv-physical-carrier-name r)) 1)
            (and (mv-nonempty? (mv-physical-carrier-host r))
            (and (mv-nonempty? (mv-physical-carrier-device r))
            (and (mv-nonempty? (mv-physical-carrier-codec r))
            (and (gt (mv-physical-carrier-materialized-bytes r) 0)
            (and (eq (mv-physical-carrier-materialized-bytes r) (mv-physical-carrier-returned-bytes r))
            (and (mv-nonempty? (mv-physical-carrier-witness r))
            (and (str_eq (mv-physical-carrier-status r) "physical-rehash-ok")
                 (eq (mv-bytes-eq?
                        (mv-physical-carrier-source-digest r)
                        (mv-physical-carrier-returned-digest r)) 1)))))))))
            false))

    (defn mv-physical-carrier-gap (carrier host wanted available evidence next-step)
        (list
            "model-physical-carrier-gap"
            carrier
            host
            wanted
            available
            evidence
            next-step))
    (defn mv-physical-carrier-gap? (value)
        (mv-row? value "model-physical-carrier-gap" 7))
    (defn mv-physical-carrier-gap-carrier (g) (nth g 1))
    (defn mv-physical-carrier-gap-host (g) (nth g 2))
    (defn mv-physical-carrier-gap-wanted (g) (nth g 3))
    (defn mv-physical-carrier-gap-available (g) (nth g 4))
    (defn mv-physical-carrier-gap-evidence (g) (nth g 5))
    (defn mv-physical-carrier-gap-next-step (g) (nth g 6))
    (defn mv-physical-carrier-gap-valid? (g)
        (if (mv-physical-carrier-gap? g)
            (and (eq (mv-carrier-known? (mv-physical-carrier-gap-carrier g)) 1)
            (and (mv-nonempty? (mv-physical-carrier-gap-host g))
            (and (mv-nonempty? (mv-physical-carrier-gap-wanted g))
            (and (mv-nonempty? (mv-physical-carrier-gap-available g))
            (and (mv-nonempty? (mv-physical-carrier-gap-evidence g))
                 (mv-nonempty? (mv-physical-carrier-gap-next-step g)))))))
            false))

    ;; ---- live model-vitality rows from the store -------------------------
    (defn mv-live-vitality-key (body-read)
        (str_concat "model-vitality:" (nth body-read 1)))
    (defn mv-live-vitality-text (body-read)
        (str_concat (nth body-read 1)
            (str_concat "|"
            (str_concat (mv-body-read-focus body-read)
            (str_concat "|"
            (str_concat (mv-body-read-eval-merkle body-read) "|row"))))))
    (defn mv-body-read-eval-merkle (body-read) (nth body-read 5))
    (defn mv-store-live-vitality-row (store body-read)
        (do
            (let key (mv-live-vitality-key body-read))
            (let text (mv-live-vitality-text body-read))
            (let digest (mv-payload-digest text))
            (let next-store (cls-put store key text))
            (list
                "model-live-vitality-store-row"
                next-store
                key
                body-read
                digest
                (str_len text)
                "stored")))
    (defn mv-live-vitality-store-row? (value)
        (mv-row? value "model-live-vitality-store-row" 7))
    (defn mv-live-row-store (r) (nth r 1))
    (defn mv-live-row-key (r) (nth r 2))
    (defn mv-live-row-body-read (r) (nth r 3))
    (defn mv-live-row-digest (r) (nth r 4))
    (defn mv-live-row-bytes (r) (nth r 5))
    (defn mv-live-row-status (r) (nth r 6))
    (defn mv-live-row-valid? (r)
        (if (mv-live-vitality-store-row? r)
            (and (mv-nonempty? (mv-live-row-key r))
            (and (mv-body-read-valid? (mv-live-row-body-read r))
            (and (gt (len (mv-live-row-digest r)) 0)
            (and (gt (mv-live-row-bytes r) 0)
                 (str_eq (mv-live-row-status r) "stored")))))
            false))

    (defn mv-read-live-vitality-route (store row wellness-state pulse-state release-state)
        (do
            (let got (cls-get store (mv-live-row-key row)))
            (let found (cls-found? got))
            (let payload (if (eq found 1) (cls-value got) ""))
            (let digest (if (eq found 1) (mv-payload-digest payload) (list)))
            (let route (mv-vitality-route (mv-live-row-body-read row) wellness-state pulse-state release-state))
            (list
                "model-live-vitality-route-read"
                (mv-live-row-key row)
                found
                digest
                (mv-live-row-digest row)
                route
                (if (eq (mv-bytes-eq? digest (mv-live-row-digest row)) 1)
                    "live-row-digest-ok"
                    "live-row-digest-mismatch"))))
    (defn mv-live-vitality-route-read? (value)
        (mv-row? value "model-live-vitality-route-read" 7))
    (defn mv-live-route-found (r) (nth r 2))
    (defn mv-live-route-digest (r) (nth r 3))
    (defn mv-live-route-expected-digest (r) (nth r 4))
    (defn mv-live-route-route (r) (nth r 5))
    (defn mv-live-route-status (r) (nth r 6))
    (defn mv-live-vitality-route-read-valid? (r)
        (if (mv-live-vitality-route-read? r)
            (and (eq (mv-live-route-found r) 1)
            (and (str_eq (mv-live-route-status r) "live-row-digest-ok")
            (and (mv-vitality-route-valid? (mv-live-route-route r))
                 (eq (mv-bytes-eq? (mv-live-route-digest r) (mv-live-route-expected-digest r)) 1))))
            false))

    ;; ---- production pulse/runtime ingestion rows -------------------------
    (defn mv-production-pulse-sample
        (source url observed-at overall silences latency-ms sample-bytes floor north)
        (list
            "model-production-pulse-sample"
            source
            url
            observed-at
            overall
            silences
            latency-ms
            sample-bytes
            floor
            north))
    (defn mv-production-pulse-sample? (value)
        (mv-row? value "model-production-pulse-sample" 10))
    (defn mv-production-pulse-source (p) (nth p 1))
    (defn mv-production-pulse-url (p) (nth p 2))
    (defn mv-production-pulse-observed-at (p) (nth p 3))
    (defn mv-production-pulse-overall (p) (nth p 4))
    (defn mv-production-pulse-silences (p) (nth p 5))
    (defn mv-production-pulse-latency-ms (p) (nth p 6))
    (defn mv-production-pulse-bytes (p) (nth p 7))
    (defn mv-production-pulse-floor (p) (nth p 8))
    (defn mv-production-pulse-north (p) (nth p 9))
    (defn mv-production-pulse-valid? (p)
        (if (mv-production-pulse-sample? p)
            (and (mv-nonempty? (mv-production-pulse-source p))
            (and (mv-nonempty? (mv-production-pulse-url p))
            (and (mv-nonempty? (mv-production-pulse-observed-at p))
            (and (mv-nonempty? (mv-production-pulse-overall p))
            (and (ge (mv-production-pulse-silences p) 0)
            (and (ge (mv-production-pulse-latency-ms p) 0)
            (and (gt (mv-production-pulse-bytes p) 0)
            (and (gt (len (mv-production-pulse-floor p)) 0)
                 (gt (len (mv-production-pulse-north p)) 0)))))))))
            false))

    (defn mv-production-runtime-telemetry
        (url status handler router python-authority latency-ms body-bytes floor north)
        (list
            "model-production-runtime-telemetry"
            url
            status
            handler
            router
            python-authority
            latency-ms
            body-bytes
            floor
            north))
    (defn mv-production-runtime-telemetry? (value)
        (mv-row? value "model-production-runtime-telemetry" 10))
    (defn mv-production-runtime-url (r) (nth r 1))
    (defn mv-production-runtime-status (r) (nth r 2))
    (defn mv-production-runtime-handler (r) (nth r 3))
    (defn mv-production-runtime-router (r) (nth r 4))
    (defn mv-production-runtime-python-authority (r) (nth r 5))
    (defn mv-production-runtime-latency-ms (r) (nth r 6))
    (defn mv-production-runtime-body-bytes (r) (nth r 7))
    (defn mv-production-runtime-floor (r) (nth r 8))
    (defn mv-production-runtime-north (r) (nth r 9))
    (defn mv-production-runtime-valid? (r)
        (if (mv-production-runtime-telemetry? r)
            (and (mv-nonempty? (mv-production-runtime-url r))
            (and (eq (mv-production-runtime-status r) 200)
            (and (mv-nonempty? (mv-production-runtime-handler r))
            (and (str_eq (mv-production-runtime-router r) "native-kernel")
            (and (str_eq (mv-production-runtime-python-authority r) "false")
            (and (ge (mv-production-runtime-latency-ms r) 0)
            (and (gt (mv-production-runtime-body-bytes r) 0)
            (and (gt (len (mv-production-runtime-floor r)) 0)
                 (gt (len (mv-production-runtime-north r)) 0)))))))))
            false))

    (defn mv-production-wellness-state (pulse)
        (if (str_eq (mv-production-pulse-overall pulse) "deploy-lag")
            "deploy-lag"
            (if (str_eq (mv-production-pulse-overall pulse) "strained")
                "strained"
                "clear")))

    (defn mv-production-pulse-state (pulse)
        (if (gt (mv-production-pulse-silences pulse) 0)
            "silent"
            (if (str_eq (mv-production-pulse-overall pulse) "silent")
                "silent"
                "breathing")))

    (defn mv-production-release-state (runtime)
        (if (gt (mv-production-runtime-latency-ms runtime) 1000)
            "slow"
            "fast"))

    (defn mv-production-vitality-route (store row pulse runtime)
        (do
            (let live-read (mv-read-live-vitality-route
                store
                row
                (mv-production-wellness-state pulse)
                (mv-production-pulse-state pulse)
                (mv-production-release-state runtime)))
            (list
                "model-production-vitality-route"
                (mv-live-row-key row)
                pulse
                runtime
                live-read
                (if (and (mv-production-pulse-valid? pulse)
                    (and (mv-production-runtime-valid? runtime)
                         (mv-live-vitality-route-read-valid? live-read)))
                    "production-route-ok"
                    "production-route-gap"))))
    (defn mv-production-vitality-route? (value)
        (mv-row? value "model-production-vitality-route" 6))
    (defn mv-production-vitality-route-key (r) (nth r 1))
    (defn mv-production-vitality-route-pulse (r) (nth r 2))
    (defn mv-production-vitality-route-runtime (r) (nth r 3))
    (defn mv-production-vitality-route-live-read (r) (nth r 4))
    (defn mv-production-vitality-route-status (r) (nth r 5))
    (defn mv-production-vitality-route-valid? (r)
        (if (mv-production-vitality-route? r)
            (and (mv-nonempty? (mv-production-vitality-route-key r))
            (and (mv-production-pulse-valid? (mv-production-vitality-route-pulse r))
            (and (mv-production-runtime-valid? (mv-production-vitality-route-runtime r))
            (and (mv-live-vitality-route-read-valid? (mv-production-vitality-route-live-read r))
                 (str_eq (mv-production-vitality-route-status r) "production-route-ok")))))
            false))

    ;; ---- kernel-native external HTTP capture -----------------------------
    ;; These helpers expect the dict returned by the kernel native:
    ;; http_get(url, headers, timeout_ms) -> __dict__ with status_code, body,
    ;; error, duration_ms, and headers. The semantic row lives here; host scripts
    ;; may only orchestrate kernel execution.
    (defn mv-http-response-status (response) (_get response "status_code"))
    (defn mv-http-response-body (response) (_get response "body"))
    (defn mv-http-response-error (response) (_get response "error"))
    (defn mv-http-response-duration-ms (response) (_get response "duration_ms"))
    (defn mv-http-response-headers (response) (_get response "headers"))
    (defn mv-http-header (name value) (list 43001 name value))
    (defn mv-http-header? (header)
        (if (eq (len header) 3) (eq (nth header 0) 43001) false))
    (defn mv-http-header-name (header) (nth header 1))
    (defn mv-http-header-value (header) (nth header 2))
    (defn mv-ascii-lower-code (cp)
        (if (and (ge cp 65) (le cp 90)) (add cp 32) cp))
    (defn mv-str-lower-loop (s i out)
        (if (ge i (str_len s))
            out
            (mv-str-lower-loop
                s
                (add i 1)
                (str_concat out (byte_to_str (mv-ascii-lower-code (ord (char_at s i))))))))
    (defn mv-str-lower (s) (mv-str-lower-loop s 0 ""))
    (defn mv-str-eq-ci? (a b) (str_eq (mv-str-lower a) (mv-str-lower b)))
    (defn mv-http-header-value-or (headers name default-value)
        (if (eq (len headers) 0)
            default-value
            (if (mv-str-eq-ci? (mv-http-header-name (head headers)) name)
                (mv-http-header-value (head headers))
                (mv-http-header-value-or (tail headers) name default-value))))

    (defn mv-native-http-capture (url response floor north)
        (list
            "model-native-http-capture"
            url
            (mv-http-response-status response)
            (mv-http-response-duration-ms response)
            (str_len (mv-http-response-body response))
            (mv-http-response-error response)
            (mv-http-response-headers response)
            "kernel-native-http-get"
            floor
            north))
    (defn mv-native-http-capture? (value)
        (mv-row? value "model-native-http-capture" 10))
    (defn mv-native-http-capture-url (c) (nth c 1))
    (defn mv-native-http-capture-status (c) (nth c 2))
    (defn mv-native-http-capture-duration-ms (c) (nth c 3))
    (defn mv-native-http-capture-body-bytes (c) (nth c 4))
    (defn mv-native-http-capture-error (c) (nth c 5))
    (defn mv-native-http-capture-headers (c) (nth c 6))
    (defn mv-native-http-capture-authority (c) (nth c 7))
    (defn mv-native-http-capture-floor (c) (nth c 8))
    (defn mv-native-http-capture-north (c) (nth c 9))
    (defn mv-native-http-capture-valid? (c)
        (if (mv-native-http-capture? c)
            (and (mv-nonempty? (mv-native-http-capture-url c))
            (and (eq (mv-native-http-capture-status c) 200)
            (and (ge (mv-native-http-capture-duration-ms c) 0)
            (and (gt (mv-native-http-capture-body-bytes c) 0)
            (and (str_eq (mv-native-http-capture-error c) "")
            (and (str_eq (mv-native-http-capture-authority c) "kernel-native-http-get")
            (and (gt (len (mv-native-http-capture-floor c)) 0)
                 (gt (len (mv-native-http-capture-north c)) 0))))))))
            false))

    ;; Requires json.fk when called; JSON body parsing stays in Form instead of
    ;; relying on sibling-specific convenience natives.
    (defn mv-native-http-pulse-sample (source url response floor north)
        (do
            (let body (mv-http-response-body response))
            (let root (parse-json url body))
            (mv-production-pulse-sample
                source
                url
                (json-string-value (json-object-get root "as_of"))
                (json-string-value (json-object-get root "overall"))
                (json-int-value (json-object-get root "silences"))
                (mv-http-response-duration-ms response)
                (str_len body)
                floor
                north)))

    ;; Response headers use the same tag-43001 kh-header row shape already used
    ;; by the native front door, read locally here to avoid making capture proof
    ;; depend on the BML source compiler.
    (defn mv-native-http-runtime-telemetry (url response floor north)
        (do
            (let headers (mv-http-response-headers response))
            (mv-production-runtime-telemetry
                url
                (mv-http-response-status response)
                (mv-http-header-value-or headers "x-form-handler" "")
                (mv-http-header-value-or headers "x-form-router" "")
                (mv-http-header-value-or headers "x-form-python-authority" "")
                (mv-http-response-duration-ms response)
                (str_len (mv-http-response-body response))
                floor
                north)))

    ;; ---- wellness/pulse routing over model vitality ----------------------
    (defn mv-vitality-route-focus (body-read wellness-state pulse-state release-state)
        (if (str_eq (mv-body-read-focus body-read) "teach-trust")
            "teach-trust"
            (if (str_eq (mv-body-read-focus body-read) "restore-sovereignty")
                "restore-sovereignty"
                (if (str_eq wellness-state "deploy-lag")
                    "release-health"
                    (if (str_eq pulse-state "silent")
                        "restore-pulse"
                        (if (str_eq release-state "slow")
                            "focus-proof"
                            (mv-body-read-focus body-read)))))))

    (defn mv-vitality-route (body-read wellness-state pulse-state release-state)
        (list
            "model-vitality-route"
            (nth body-read 1)
            (mv-body-read-focus body-read)
            wellness-state
            pulse-state
            release-state
            (mv-vitality-route-focus body-read wellness-state pulse-state release-state)
            (mv-body-read-score body-read)))
    (defn mv-vitality-route? (value) (mv-row? value "model-vitality-route" 8))
    (defn mv-vitality-route-model (r) (nth r 1))
    (defn mv-vitality-route-source-focus (r) (nth r 2))
    (defn mv-vitality-route-wellness (r) (nth r 3))
    (defn mv-vitality-route-pulse (r) (nth r 4))
    (defn mv-vitality-route-release (r) (nth r 5))
    (defn mv-vitality-route-focus-result (r) (nth r 6))
    (defn mv-vitality-route-score (r) (nth r 7))
    (defn mv-vitality-route-valid? (r)
        (if (mv-vitality-route? r)
            (and (mv-nonempty? (mv-vitality-route-model r))
            (and (mv-nonempty? (mv-vitality-route-source-focus r))
            (and (mv-nonempty? (mv-vitality-route-wellness r))
            (and (mv-nonempty? (mv-vitality-route-pulse r))
            (and (mv-nonempty? (mv-vitality-route-release r))
            (and (mv-nonempty? (mv-vitality-route-focus-result r))
                 (ge (mv-vitality-route-score r) 0)))))))
            false))
)
