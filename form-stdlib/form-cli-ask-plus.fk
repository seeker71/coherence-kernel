; form-cli-ask-plus.fk — compatibility name for the canonical staged ask trace.
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/str-byte-at.fk
; preludes: form-stdlib/sha256.fk form-stdlib/hmac-sha256.fk form-stdlib/hex.fk
; preludes: form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
; preludes: form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-ask.fk
; preludes: form-stdlib/form-cli-router.fk form-stdlib/form-cli-judge.fk
; preludes: form-stdlib/form-cli-sufficiency.fk form-stdlib/form-freq-check.fk
; preludes: form-stdlib/trust-row.fk form-stdlib/form-cli-ask-gate.fk
; preludes: form-stdlib/form-cli-staged-trace.fk form-stdlib/form-cli-request.fk
;
; The former `ask+` carrier independently re-ran retrieval, copied one verdict
; into several trust fields, and could invoke a remote model before the kernel
; had authored an honest result row. That duplicate path is gone. The live CLI
; stages one question, selects one hit, validates one structured receipt, and
; returns one kernel-authored trust row plus the exact selected payload.
;
; Consumers perform any rented escalation only after reading `decision:escalate`;
; they never rewrite native trust fields. `fca-ask-plus-traced-at` is the pure
; compatibility seam for tests. `fca-ask-plus-traced` is the live staged-query
; seam and reads the protected key plus actual native wall clock.

(do
    (defn fca-ask-plus-traced-at (hit receipt query key-hex now)
        (fcast-trace-hit-at hit receipt (fcast-query-key query) key-hex now))

    (defn fca-ask-plus-traced (receipt)
        (do
            (let query (read_file (ra-staged-query)))
            (let hit (ra-grounded-hit-at (ra-default-index) query))
            (let key-hex (fcr-strip-eol (read_file (fcr-key-path))))
            (fca-ask-plus-traced-at
                hit receipt query key-hex (fcr-now-seconds))))

    0)
