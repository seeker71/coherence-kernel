; sense-self.fk — the body reads its OWN sovereignty and vitality as living vectors, from real counts.
;
; preludes: form-stdlib/living-vector.fk
;
; living-vector.fk gives the algebra (reading / binding / dominance / lift / gap) over per-mille axes.
; This block is the bridge from the body's RAW SELF-COUNTS to those vectors: each axis is a SHARE —
; numerator per denominator, in per-mille — so "6 of 10 queries answered from the body" becomes a
; cognitive-sovereignty of 600. The COMPUTATION is the body (pure, four-way, native); the GATHERING of
; the counts is a thin carrier (git/manifest/test reads), never the body — "the carrier is a thin door,
; not a script." Feed it real counts and lv-binding names the one axis whose tending restores the most
; coherence this breath; feed it nothing on an axis (denominator 0) and the share is honest 0, not a lie.
;
; The two self-readings (axis order is living-vector's contract):
;   sovereignty = [ cognitive , proof , infrastructure , generative ] from
;     (body-answered / queries), (proven bands / total bands), (owned runs / total runs),
;     (native-generated / total generated)  — the last is ~0 today, the floor the vector must surface.
;   vitality    = [ circulation , feedback , edges , proof-freshness ] from
;     (read cells / cells), (updated cells / cells), (connected cells / cells), (fresh tests / tests).
;
; Kin: living-vector.fk (the algebra), sovereignty-receipt.fk + sense-liveness.fk (per-response and
; per-sense scalars these aggregate), wellness_check.py (the carrier that could feed this for a gradient
; readout). Proven by: form-stdlib/tests/sense-self-band.fk

(do
    ; --- one axis from a count: per-mille share, with honest-0 on no-data (never divide by zero). ---
    (defn ss-share (num denom) (if (eq denom 0) 0 (div (mul num 1000) denom)))

    ; --- the sovereignty self-reading from eight raw counts (four numerator/denominator pairs). ---
    (defn ss-sovereignty (body-ans queries proven total-bands owned-runs total-runs nat-gen total-gen)
        (list (ss-share body-ans queries)
              (ss-share proven total-bands)
              (ss-share owned-runs total-runs)
              (ss-share nat-gen total-gen)))

    ; --- the vitality self-reading from eight raw counts. ---
    (defn ss-vitality (read cells updated upd-total connected conn-total fresh tests)
        (list (ss-share read cells)
              (ss-share updated upd-total)
              (ss-share connected conn-total)
              (ss-share fresh tests)))

    0)
