; kernel-http.fk - BML-authored HTTP/router value surface.
;
; preludes: form-stdlib/core.fk
;
; This surface is value-shaped: requests, responses, routes, pressure rows,
; and route candidates are plain Form/BML data with real validation and
; scoring recipes. Kernel adapters can carry these values without owning the
; routing decision.

section [form.bml] {
    let kh_tag_header = 43001;
    let kh_tag_request = 43002;
    let kh_tag_response = 43003;
    let kh_tag_route = 43004;
    let kh_tag_pressure_row = 43005;
    let kh_tag_route_candidate = 43006;
    let kh_tag_route_data_ref = 43007;
    let kh_tag_field = 43008;
    let kh_tag_route_decision = 43009;
    let kh_tag_route_choice = 43010;
    let kh_tag_route_decision_signature = 43011;
    let kh_tag_route_choice_signature = 43012;
    let kh_tag_channel_policy = 43013;
    let kh_tag_method_bridge = 43014;

    def kh-bool-score(ok, score) = if ok then score else 0;
    def kh-tagged?(value, tag, arity) = if eq(len(value), arity) then eq(nth(value, 0), tag) else false;
    def kh-nonempty-string?(value) = gt(str_len(value), 0);
    def kh-path-valid?(path) = if gt(str_len(path), 0) then str_eq(char_at(path, 0), "/") else false;
    def kh-prefix?(text, prefix) = if gt(str_len(prefix), str_len(text)) then false else str_eq(substring(text, 0, str_len(prefix)), prefix);

    // HTTP header names are ASCII case-insensitive. Keep the normalization here
    // in Form so route-required headers, response finalization, and handler
    // helpers all see the same protocol truth without host-side special casing.
    def kh-ascii-lower-char(c) {
        let cp = ord(c);
        if and(ge(cp, 65), le(cp, 90)) then char_at("abcdefghijklmnopqrstuvwxyz", sub(cp, 65)) else c;
    }
    def kh-ascii-lower-loop(text, i) = if ge(i, str_len(text)) then "" else str_concat(kh-ascii-lower-char(char_at(text, i)), kh-ascii-lower-loop(text, add(i, 1)));
    def kh-ascii-lower(text) = kh-ascii-lower-loop(text, 0);
    def kh-str-eq-ci?(left, right) = str_eq(kh-ascii-lower(left), kh-ascii-lower(right));

    def kh-list-string-present?(values, value) = if nil?(values) then false else if str_eq(head(values), value) then true else kh-list-string-present?(tail(values), value);
    def kh-join-strings(values, separator) = if nil?(values) then "" else if nil?(tail(values)) then head(values) else str_concat(head(values), str_concat(separator, kh-join-strings(tail(values), separator)));

    def kh-method-bridge(route_method, request_method, pressure) = list(kh_tag_method_bridge, route_method, request_method, pressure);
    def kh-method-bridge?(bridge) = kh-tagged?(bridge, kh_tag_method_bridge, 4);
    def kh-method-bridge-route-method(bridge) = nth(bridge, 1);
    def kh-method-bridge-request-method(bridge) = nth(bridge, 2);
    def kh-method-bridge-pressure(bridge) = nth(bridge, 3);
    def kh-method-bridge-valid?(bridge) = if kh-method-bridge?(bridge) then and(kh-nonempty-string?(kh-method-bridge-route-method(bridge)), and(kh-nonempty-string?(kh-method-bridge-request-method(bridge)), ge(kh-method-bridge-pressure(bridge), 0))) else false;
    def kh-method-bridges-valid?(bridges) = if nil?(bridges) then true else if kh-method-bridge-valid?(head(bridges)) then kh-method-bridges-valid?(tail(bridges)) else false;

    // Channel policy is the Form-visible protocol invitation and pressure map.
    // HTTP is one carrier/protocol value here, not a special host-owned branch.
    def kh-channel-policy(carrier, protocol, allowed_methods, method_bridges, no_body_methods, allow_methods, cache_policy, compression_policy, stream_policy, identity_policy, authorization_policy) {
        list(kh_tag_channel_policy, carrier, protocol, allowed_methods, method_bridges, no_body_methods, allow_methods, cache_policy, compression_policy, stream_policy, identity_policy, authorization_policy);
    }
    def kh-channel-policy?(policy) = kh-tagged?(policy, kh_tag_channel_policy, 12);
    def kh-channel-policy-carrier(policy) = nth(policy, 1);
    def kh-channel-policy-protocol(policy) = nth(policy, 2);
    def kh-channel-policy-allowed-methods(policy) = nth(policy, 3);
    def kh-channel-policy-method-bridges(policy) = nth(policy, 4);
    def kh-channel-policy-no-body-methods(policy) = nth(policy, 5);
    def kh-channel-policy-allow-methods(policy) = nth(policy, 6);
    def kh-channel-policy-cache-policy(policy) = nth(policy, 7);
    def kh-channel-policy-compression-policy(policy) = nth(policy, 8);
    def kh-channel-policy-stream-policy(policy) = nth(policy, 9);
    def kh-channel-policy-identity-policy(policy) = nth(policy, 10);
    def kh-channel-policy-authorization-policy(policy) = nth(policy, 11);
    def kh-channel-policy-valid?(policy) {
        if kh-channel-policy?(policy) then and(kh-nonempty-string?(kh-channel-policy-carrier(policy)), and(kh-nonempty-string?(kh-channel-policy-protocol(policy)), kh-method-bridges-valid?(kh-channel-policy-method-bridges(policy)))) else false;
    }

    def kh-default-allowed-methods() = list("GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS");
    def kh-default-channel-policy() {
        kh-channel-policy(
            "tcp",
            "http/1.1",
            kh-default-allowed-methods(),
            list(kh-method-bridge("GET", "HEAD", 20)),
            list("HEAD"),
            kh-default-allowed-methods(),
            "cache-policy-observe",
            "compression-policy-observe",
            "stream-policy-buffered",
            "identity-policy-claim",
            "authorization-policy-capability"
        );
    }
    def kh-method-known-with-policy?(policy, method) = kh-list-string-present?(kh-channel-policy-allowed-methods(policy), method);
    def kh-method-known?(method) = kh-method-known-with-policy?(kh-default-channel-policy(), method);
    def kh-route-method-valid-with-policy?(policy, method) = or(kh-method-known-with-policy?(policy, method), str_eq(method, "ANY"));
    def kh-route-method-valid?(method) = kh-route-method-valid-with-policy?(kh-default-channel-policy(), method);
    def kh-policy-method-bridge-pressure-or(policy, route_method, request_method, fallback) {
        kh-method-bridge-pressure-or(kh-channel-policy-method-bridges(policy), route_method, request_method, fallback);
    }
    def kh-method-bridge-pressure-or(bridges, route_method, request_method, fallback) {
        if nil?(bridges) then fallback else if and(kh-method-bridge?(head(bridges)), and(str_eq(kh-method-bridge-route-method(head(bridges)), route_method), str_eq(kh-method-bridge-request-method(head(bridges)), request_method))) then kh-method-bridge-pressure(head(bridges)) else kh-method-bridge-pressure-or(tail(bridges), route_method, request_method, fallback);
    }
    def kh-policy-no-body-method?(policy, method) = kh-list-string-present?(kh-channel-policy-no-body-methods(policy), method);
    def kh-policy-allow-header-value(policy) = kh-join-strings(kh-channel-policy-allow-methods(policy), ", ");

    def kh-header(name, value) = list(kh_tag_header, name, value);
    def kh-header?(header) = kh-tagged?(header, kh_tag_header, 3);
    def kh-header-name(header) = nth(header, 1);
    def kh-header-value(header) = nth(header, 2);
    def kh-headers-valid?(headers) = if nil?(headers) then true else if kh-header?(head(headers)) then kh-headers-valid?(tail(headers)) else false;
    def kh-header-present?(headers, name) = if nil?(headers) then false else if kh-str-eq-ci?(kh-header-name(head(headers)), name) then true else kh-header-present?(tail(headers), name);
    def kh-header-value-or(headers, name, default_value) = if nil?(headers) then default_value else if kh-str-eq-ci?(kh-header-name(head(headers)), name) then kh-header-value(head(headers)) else kh-header-value-or(tail(headers), name, default_value);
    def kh-header-observation(headers, name) = if str_eq(name, "") then "not-required" else if kh-header-present?(headers, name) then "present" else "missing";

    def kh-field(name, value) = list(kh_tag_field, name, value);
    def kh-field?(field) = kh-tagged?(field, kh_tag_field, 3);
    def kh-field-name(field) = nth(field, 1);
    def kh-field-value(field) = nth(field, 2);
    def kh-fields-valid?(fields) = if nil?(fields) then true else if kh-field?(head(fields)) then kh-fields-valid?(tail(fields)) else false;
    def kh-field-present?(fields, name) = if nil?(fields) then false else if str_eq(kh-field-name(head(fields)), name) then true else kh-field-present?(tail(fields), name);
    def kh-field-value-or(fields, name, default_value) = if nil?(fields) then default_value else if str_eq(kh-field-name(head(fields)), name) then kh-field-value(head(fields)) else kh-field-value-or(tail(fields), name, default_value);
    def kh-field-int-or(fields, name, default_value) {
        let raw = kh-field-value-or(fields, name, "");
        if str_eq(raw, "") then default_value else str_to_int(raw);
    }
    def kh-field-bool-or(fields, name, default_value) {
        let raw = kh-field-value-or(fields, name, "");
        if str_eq(raw, "") then default_value else or(str_eq(raw, "true"), str_eq(raw, "1"));
    }

    def kh-request(method, path, headers, query, body) = list(kh_tag_request, method, path, headers, query, body);
    def kh-request?(request) = kh-tagged?(request, kh_tag_request, 6);
    def kh-request-method(request) = nth(request, 1);
    def kh-request-path(request) = nth(request, 2);
    def kh-request-headers(request) = nth(request, 3);
    def kh-request-query(request) = nth(request, 4);
    def kh-request-body(request) = nth(request, 5);
    def kh-request-valid-with-policy?(policy, request) = if kh-request?(request) then and(kh-method-known-with-policy?(policy, kh-request-method(request)), and(kh-path-valid?(kh-request-path(request)), and(kh-headers-valid?(kh-request-headers(request)), kh-fields-valid?(kh-request-query(request))))) else false;
    def kh-request-valid?(request) = kh-request-valid-with-policy?(kh-default-channel-policy(), request);
    def kh-query-value-or(request, name, default_value) = kh-field-value-or(kh-request-query(request), name, default_value);
    def kh-query-int-or(request, name, default_value) = kh-field-int-or(kh-request-query(request), name, default_value);
    def kh-query-bool-or(request, name, default_value) = kh-field-bool-or(kh-request-query(request), name, default_value);

    def kh-response(status, headers, body) = list(kh_tag_response, status, headers, body);
    def kh-response?(response) = kh-tagged?(response, kh_tag_response, 4);
    def kh-response-status(response) = nth(response, 1);
    def kh-response-headers(response) = nth(response, 2);
    def kh-response-body(response) = nth(response, 3);
    def kh-response-valid?(response) = if kh-response?(response) then and(ge(kh-response-status(response), 100), and(le(kh-response-status(response), 599), kh-headers-valid?(kh-response-headers(response)))) else false;

    def kh-route(name, method, pattern, priority, handler, required_header, pressure_budget) = list(kh_tag_route, name, method, pattern, priority, handler, required_header, pressure_budget);
    def kh-route?(route) = kh-tagged?(route, kh_tag_route, 8);
    def kh-route-name(route) = nth(route, 1);
    def kh-route-method(route) = nth(route, 2);
    def kh-route-pattern(route) = nth(route, 3);
    def kh-route-priority(route) = nth(route, 4);
    def kh-route-handler(route) = nth(route, 5);
    def kh-route-required-header(route) = nth(route, 6);
    def kh-route-pressure-budget(route) = nth(route, 7);
    def kh-route-valid-with-policy?(policy, route) = if kh-route?(route) then and(kh-route-method-valid-with-policy?(policy, kh-route-method(route)), and(kh-path-valid?(kh-route-pattern(route)), and(ge(kh-route-priority(route), 0), and(kh-nonempty-string?(kh-route-handler(route)), ge(kh-route-pressure-budget(route), 0))))) else false;
    def kh-route-valid?(route) = kh-route-valid-with-policy?(kh-default-channel-policy(), route);

    def kh-route-data-ref(route_id, handler) = list(kh_tag_route_data_ref, route_id, handler);
    def kh-route-data-ref?(ref) = kh-tagged?(ref, kh_tag_route_data_ref, 3);
    def kh-route-data-ref-id(ref) = nth(ref, 1);
    def kh-route-data-ref-handler(ref) = nth(ref, 2);
    def kh-route-data-ref-valid?(ref) = if kh-route-data-ref?(ref) then kh-nonempty-string?(kh-route-data-ref-id(ref)) else false;

    def kh-pattern-wildcard?(pattern) = if gt(str_len(pattern), 0) then str_eq(char_at(pattern, sub(str_len(pattern), 1)), "*") else false;
    def kh-pattern-prefix(pattern) = if kh-pattern-wildcard?(pattern) then substring(pattern, 0, sub(str_len(pattern), 1)) else pattern;
    def kh-head-through-get?(route, request) = and(str_eq(kh-route-method(route), "GET"), str_eq(kh-request-method(request), "HEAD"));
    def kh-head-through-get-with-policy?(policy, route, request) = lt(kh-policy-method-bridge-pressure-or(policy, kh-route-method(route), kh-request-method(request), 400), 400);
    def kh-method-pressure-with-policy(policy, route, request) {
        let bridge_pressure = kh-policy-method-bridge-pressure-or(policy, kh-route-method(route), kh-request-method(request), 400);
        if str_eq(kh-route-method(route), kh-request-method(request)) then 0 else if lt(bridge_pressure, 400) then bridge_pressure else if str_eq(kh-route-method(route), "ANY") then 40 else 400;
    }
    def kh-method-pressure(route, request) = kh-method-pressure-with-policy(kh-default-channel-policy(), route, request);
    def kh-path-pressure(route, request) = if str_eq(kh-route-pattern(route), kh-request-path(request)) then 0 else if and(kh-pattern-wildcard?(kh-route-pattern(route)), kh-prefix?(kh-request-path(request), kh-pattern-prefix(kh-route-pattern(route)))) then 25 else 500;
    def kh-header-pressure(route, request) = if str_eq(kh-route-required-header(route), "") then 0 else if kh-header-present?(kh-request-headers(request), kh-route-required-header(route)) then 0 else 120;
    def kh-budget-pressure(total, budget) = if le(total, budget) then 0 else sub(total, budget);

    def kh-pressure-row(axis, observed, expected, pressure) = list(kh_tag_pressure_row, axis, observed, expected, pressure);
    def kh-pressure-row?(row) = kh-tagged?(row, kh_tag_pressure_row, 5);
    def kh-pressure-row-axis(row) = nth(row, 1);
    def kh-pressure-row-observed(row) = nth(row, 2);
    def kh-pressure-row-expected(row) = nth(row, 3);
    def kh-pressure-row-pressure(row) = nth(row, 4);
    def kh-pressure-matrix-total(matrix) = if nil?(matrix) then 0 else add(kh-pressure-row-pressure(head(matrix)), kh-pressure-matrix-total(tail(matrix)));

    def kh-candidate-pressure-matrix-with-policy(policy, route, request) {
        let method_pressure = kh-method-pressure-with-policy(policy, route, request);
        let path_pressure = kh-path-pressure(route, request);
        let header_pressure = kh-header-pressure(route, request);
        let base_pressure = sum(list(method_pressure, path_pressure, header_pressure));
        let budget_pressure = kh-budget-pressure(base_pressure, kh-route-pressure-budget(route));
        list(
            kh-pressure-row("method", kh-request-method(request), kh-route-method(route), method_pressure),
            kh-pressure-row("path", kh-request-path(request), kh-route-pattern(route), path_pressure),
            kh-pressure-row("header", kh-header-observation(kh-request-headers(request), kh-route-required-header(route)), kh-route-required-header(route), header_pressure),
            kh-pressure-row("budget", base_pressure, kh-route-pressure-budget(route), budget_pressure)
        );
    }
    def kh-candidate-pressure-matrix(route, request) = kh-candidate-pressure-matrix-with-policy(kh-default-channel-policy(), route, request);

    def kh-candidate-score-from(route, pressure) = sub(add(1000, mul(kh-route-priority(route), 10)), pressure);
    def kh-route-candidate-with-policy(policy, route, request) {
        let matrix = kh-candidate-pressure-matrix-with-policy(policy, route, request);
        let pressure = kh-pressure-matrix-total(matrix);
        list(kh_tag_route_candidate, route, request, matrix, pressure, kh-candidate-score-from(route, pressure));
    }
    def kh-route-candidate(route, request) = kh-route-candidate-with-policy(kh-default-channel-policy(), route, request);
    def kh-route-candidate?(candidate) = kh-tagged?(candidate, kh_tag_route_candidate, 6);
    def kh-route-candidate-route(candidate) = nth(candidate, 1);
    def kh-route-candidate-request(candidate) = nth(candidate, 2);
    def kh-route-candidate-matrix(candidate) = nth(candidate, 3);
    def kh-route-candidate-pressure(candidate) = nth(candidate, 4);
    def kh-route-candidate-score(candidate) = nth(candidate, 5);
    def kh-route-candidate-valid?(candidate) = if kh-route-candidate?(candidate) then and(kh-route-valid?(kh-route-candidate-route(candidate)), and(kh-request-valid?(kh-route-candidate-request(candidate)), and(eq(kh-route-candidate-pressure(candidate), kh-pressure-matrix-total(kh-route-candidate-matrix(candidate))), eq(kh-route-candidate-score(candidate), kh-candidate-score-from(kh-route-candidate-route(candidate), kh-route-candidate-pressure(candidate)))))) else false;

    def kh-route-candidate-eligible?(candidate) = if kh-route-candidate?(candidate) then le(kh-route-candidate-pressure(candidate), kh-route-pressure-budget(kh-route-candidate-route(candidate))) else false;
    def kh-route-candidates-with-policy(policy, routes, request) = if nil?(routes) then empty else cons(kh-route-candidate-with-policy(policy, head(routes), request), kh-route-candidates-with-policy(policy, tail(routes), request));
    def kh-route-candidates(routes, request) = kh-route-candidates-with-policy(kh-default-channel-policy(), routes, request);
    def kh-keep-eligible-candidate(candidate, rest) = if kh-route-candidate-eligible?(candidate) then cons(candidate, rest) else rest;
    def kh-eligible-candidates(candidates) = if nil?(candidates) then empty else kh-keep-eligible-candidate(head(candidates), kh-eligible-candidates(tail(candidates)));
    def kh-route-eligible-candidates-with-policy(policy, routes, request) = kh-eligible-candidates(kh-route-candidates-with-policy(policy, routes, request));
    def kh-route-eligible-candidates(routes, request) = kh-route-eligible-candidates-with-policy(kh-default-channel-policy(), routes, request);
    def kh-route-same?(left, right) = if kh-route?(left) then if kh-route?(right) then and(str_eq(kh-route-name(left), kh-route-name(right)), and(str_eq(kh-route-method(left), kh-route-method(right)), and(str_eq(kh-route-pattern(left), kh-route-pattern(right)), and(eq(kh-route-priority(left), kh-route-priority(right)), and(str_eq(kh-route-handler(left), kh-route-handler(right)), and(str_eq(kh-route-required-header(left), kh-route-required-header(right)), eq(kh-route-pressure-budget(left), kh-route-pressure-budget(right)))))))) else false else false;
    def kh-route-candidate-same?(left, right) = if kh-route-candidate?(left) then if kh-route-candidate?(right) then and(kh-route-same?(kh-route-candidate-route(left), kh-route-candidate-route(right)), and(eq(kh-route-candidate-pressure(left), kh-route-candidate-pressure(right)), eq(kh-route-candidate-score(left), kh-route-candidate-score(right)))) else false else false;
    def kh-better-candidate(left, right) = if gt(kh-route-candidate-score(left), kh-route-candidate-score(right)) then left else if eq(kh-route-candidate-score(left), kh-route-candidate-score(right)) then if ge(kh-route-priority(kh-route-candidate-route(left)), kh-route-priority(kh-route-candidate-route(right))) then left else right else right;
    def kh-select-route-candidate-loop(candidates, best) = if nil?(candidates) then best else kh-select-route-candidate-loop(tail(candidates), kh-better-candidate(best, head(candidates)));
    def kh-select-route-candidate(candidates) = if nil?(candidates) then empty else kh-select-route-candidate-loop(tail(candidates), head(candidates));
    def kh-route-decision(candidate, eligible, selected) = list(kh_tag_route_decision, candidate, eligible, selected);
    def kh-route-decision?(decision) = kh-tagged?(decision, kh_tag_route_decision, 4);
    def kh-route-decision-candidate(decision) = nth(decision, 1);
    def kh-route-decision-eligible?(decision) = nth(decision, 2);
    def kh-route-decision-selected?(decision) = nth(decision, 3);
    def kh-route-decision-valid?(decision) = if kh-route-decision?(decision) then kh-route-candidate-valid?(kh-route-decision-candidate(decision)) else false;
    def kh-route-decisions(candidates, selected) = if nil?(candidates) then empty else cons(kh-route-decision(head(candidates), kh-route-candidate-eligible?(head(candidates)), kh-route-candidate-same?(head(candidates), selected)), kh-route-decisions(tail(candidates), selected));
    def kh-route-decisions-valid?(decisions) = if nil?(decisions) then true else if kh-route-decision-valid?(head(decisions)) then kh-route-decisions-valid?(tail(decisions)) else false;

    // Fixed, data-oblivious buckets for route-choice attention. This borrows the
    // TurboQuant teaching: compression remains content-addressable only when the
    // quantizer is universal, not trained from the current route corpus.
    def kh-pressure-bucket(pressure) = if eq(pressure, 0) then 0 else if le(pressure, 25) then 1 else if le(pressure, 120) then 2 else if le(pressure, 400) then 3 else if le(pressure, 500) then 4 else 5;
    def kh-score-bucket(score) = if lt(score, 0) then 0 else if lt(score, 500) then 1 else if lt(score, 900) then 2 else if lt(score, 1000) then 3 else if lt(score, 1100) then 4 else 5;
    def kh-pressure-code(row) = list(kh-pressure-row-axis(row), kh-pressure-bucket(kh-pressure-row-pressure(row)));
    def kh-pressure-codes(matrix) = if nil?(matrix) then empty else cons(kh-pressure-code(head(matrix)), kh-pressure-codes(tail(matrix)));
    def kh-route-decision-signature(decision) {
        let candidate = kh-route-decision-candidate(decision);
        let route = kh-route-candidate-route(candidate);
        list(
            kh_tag_route_decision_signature,
            kh-route-name(route),
            kh-route-handler(route),
            kh-pressure-codes(kh-route-candidate-matrix(candidate)),
            kh-pressure-bucket(kh-route-candidate-pressure(candidate)),
            kh-score-bucket(kh-route-candidate-score(candidate)),
            kh-route-decision-eligible?(decision),
            kh-route-decision-selected?(decision)
        );
    }
    def kh-route-decision-signature?(signature) = kh-tagged?(signature, kh_tag_route_decision_signature, 8);
    def kh-route-decision-signature-codes(signature) = nth(signature, 3);
    def kh-route-decision-signature-pressure-bucket(signature) = nth(signature, 4);
    def kh-route-decision-signature-score-bucket(signature) = nth(signature, 5);
    def kh-route-decision-signature-eligible?(signature) = nth(signature, 6);
    def kh-route-decision-signature-selected?(signature) = nth(signature, 7);
    def kh-route-decision-signatures(decisions) = if nil?(decisions) then empty else cons(kh-route-decision-signature(head(decisions)), kh-route-decision-signatures(tail(decisions)));

    def kh-route-choice(request, candidates, decisions, selected) = list(kh_tag_route_choice, request, candidates, decisions, selected);
    def kh-route-choice?(choice) = kh-tagged?(choice, kh_tag_route_choice, 5);
    def kh-route-choice-request(choice) = nth(choice, 1);
    def kh-route-choice-candidates(choice) = nth(choice, 2);
    def kh-route-choice-decisions(choice) = nth(choice, 3);
    def kh-route-choice-selected(choice) = nth(choice, 4);
    def kh-route-choice-valid?(choice) = if kh-route-choice?(choice) then and(kh-request-valid?(kh-route-choice-request(choice)), and(eq(len(kh-route-choice-candidates(choice)), len(kh-route-choice-decisions(choice))), kh-route-decisions-valid?(kh-route-choice-decisions(choice)))) else false;
    def kh-route-choice-signature(choice) = list(kh_tag_route_choice_signature, kh-request-method(kh-route-choice-request(choice)), kh-request-path(kh-route-choice-request(choice)), kh-route-decision-signatures(kh-route-choice-decisions(choice)));
    def kh-route-choice-signature?(signature) = kh-tagged?(signature, kh_tag_route_choice_signature, 4);
    def kh-route-choice-signature-decision-signatures(signature) = nth(signature, 3);
    def kh-route-choice-for-request-with-policy(policy, routes, request) {
        let candidates = kh-route-candidates-with-policy(policy, routes, request);
        let selected = kh-select-route-candidate(kh-eligible-candidates(candidates));
        kh-route-choice(request, candidates, kh-route-decisions(candidates, selected), selected);
    }
    def kh-route-choice-for-request(routes, request) = kh-route-choice-for-request-with-policy(kh-default-channel-policy(), routes, request);
    def kh-select-route-candidate-for-request-with-policy(policy, routes, request) = kh-route-choice-selected(kh-route-choice-for-request-with-policy(policy, routes, request));
    def kh-select-route-candidate-for-request(routes, request) = kh-route-choice-selected(kh-route-choice-for-request(routes, request));
    def kh-select-route-score(routes, request) {
        let selected = kh-select-route-candidate-for-request(routes, request);
        if nil?(selected) then 0 else kh-route-candidate-score(selected);
    }

    0;
}
