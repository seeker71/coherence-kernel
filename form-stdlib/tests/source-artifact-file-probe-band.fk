    (defn safpb-bit-source-happy ()
        (do
            (let sp (safpb-source-probe))
            (let obs (safp-source-probe-observation sp))
            (let v (safp-source-probe-vouch sp))
            (safpb-score
                (and (str_eq (safp-source-probe-status sp) (sai-status-match))
                (and (str_eq (sap-observation-source-hash obs) (safpb-source-hash))
                (and (eq (sap-observation-size obs) 3)
                (and (eq (sai-vouch-observed-size v) 3)
                     (str_eq (sai-vouch-evidence-kind v) (fbd-evidence-kind))))))
                4)))
