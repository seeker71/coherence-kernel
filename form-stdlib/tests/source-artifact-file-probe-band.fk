                (and (sce-emitted? e)
                     (str_eq (sce-emission-reason e) (sce-reason-compile-emission-ready)))
                536870912)))
    (defn safpb-bit-version ()
        (safpb-score (str_eq (safp-version) "source-artifact-file-probe-v1") 1073741824))

    (defn source-artifact-file-probe-band ()
        (do
            (let _setup (safpb-setup))
            (let score (sum (list
                (safpb-bit-manifest-1)
                (safpb-bit-manifest-2)
                (safpb-bit-source-happy)
                (safpb-bit-fkb-happy)
                (safpb-bit-plan-run-fkb)
                (safpb-bit-missing-fkb-plan)
                (safpb-bit-missing-source-scp)
                (safpb-bit-source-mismatch)
                (safpb-bit-fkb-mismatch)
                (safpb-bit-too-large)
                (safpb-bit-malformed-expected)
                (safpb-bit-seal-visible)
                (safpb-bit-native-helper)
                (safpb-bit-missing-native)
                (safpb-bit-stat-drift)
                (safpb-bit-no-supplied-hash-leak)
                (safpb-bit-carrier-accessors)
                (safpb-bit-default-cap-helper)
                (safpb-bit-absent-shape)
                (safpb-bit-bad-cap-not-drift)
                (safpb-bit-missing-tbl-visible)
                (safpb-bit-persistence-ready)
                (safpb-bit-persistence-bad-fkb)
                (safpb-bit-source-absent-shape)
                (safpb-bit-native-policy-fields)
                (safpb-bit-static-boundary)
                (safpb-bit-mirror)
                (safpb-bit-no-route-or-persistence)
                (safpb-bit-descriptor-fields)
                (safpb-bit-emission-current)
                (safpb-bit-version))))
            (let _cleanup (safpb-cleanup))
            score))

    (source-artifact-file-probe-band))
