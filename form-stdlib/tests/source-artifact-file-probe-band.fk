                (and (str_eq (safp-artifact-probe-status fkb-probe) (sai-status-unobserved))
                (and (str_eq (safp-probe-bundle-status probe) (sai-status-unobserved))
                (and (str_eq (rap-plan-primary plan) (rap-act-compile-source))
