; source-artifact-file-probe-band.fk -- file-backed probe bundle witness.
;
; preludes: form-stdlib/core.fk form-stdlib/form-fs.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/file-byte-digest.fk form-stdlib/source-artifact-file-probe.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-tbl-emit.fk form-stdlib/source-compiler-emission.fk form-stdlib/source-compiler-persistence.fk
;
; Expected: 2147483647

(do
    (defn safpb-score (ok bit) (if ok bit 0))
    (defn safpb-manifest-has (name)
        (source-artifact-file-probe-manifest-has? name (source-artifact-file-probe-manifest)))
    (defn safpb-has? (text needle)
        (ge (str_find text needle 0) 0))

    (defn safpb-root ()
        (fs-path-join (fs-temp-dir) "source-artifact-file-probe-band"))
    (defn safpb-path (name)
        (fs-path-join (safpb-root) name))
    (defn safpb-source-path () (safpb-path "source.fk"))
    (defn safpb-fkb-path () (safpb-path "source.fkb"))
    (defn safpb-dylib-path () (safpb-path "source.dylib"))
    (defn safpb-large-path () (safpb-path "large.fkb"))
    (defn safpb-missing-source-path () (safpb-path "missing-source.fk"))
    (defn safpb-missing-fkb-path () (safpb-path "missing.fkb"))

    (defn safpb-repeat-byte-loop (b n acc)
        (if (le n 0)
            acc
            (safpb-repeat-byte-loop b (sub n 1) (cons b acc))))
    (defn safpb-repeat-byte (b n)
        (safpb-repeat-byte-loop b n (list)))
    (defn safpb-source-bytes () (list 97 98 99))
    (defn safpb-fkb-bytes () (list 102 107 98))
    (defn safpb-dylib-bytes () (list 100 121 110))
    (defn safpb-large-bytes () (safpb-repeat-byte 65 129))
    (defn safpb-hash (bytes) (sai-sha256-hex bytes))
    (defn safpb-source-hash () (safpb-hash (safpb-source-bytes)))
    (defn safpb-fkb-hash () (safpb-hash (safpb-fkb-bytes)))
    (defn safpb-dylib-hash () (safpb-hash (safpb-dylib-bytes)))
    (defn safpb-wrong-hash () (safpb-hash (list)))

    (defn safpb-write-bytes (path bytes)
        (do
            (let _rm (fs-remove-file path))
            (if (eq (len bytes) 0)
                (fs-write-text path "")
                (fs-append-bytes path bytes))))
    (defn safpb-setup ()
        (do
            (let root (safpb-root))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let _src (safpb-write-bytes (safpb-source-path) (safpb-source-bytes)))
            (let _fkb (safpb-write-bytes (safpb-fkb-path) (safpb-fkb-bytes)))
            (let _dylib (safpb-write-bytes (safpb-dylib-path) (safpb-dylib-bytes)))
            (let _large (safpb-write-bytes (safpb-large-path) (safpb-large-bytes)))
            0))
    (defn safpb-cleanup ()
        (do
            (let _src (fs-remove-file (safpb-source-path)))
            (let _fkb (fs-remove-file (safpb-fkb-path)))
            (let _dylib (fs-remove-file (safpb-dylib-path)))
            (let _large (fs-remove-file (safpb-large-path)))
            (fs-remove-tree (safpb-root))))

    (defn safpb-max () 128)
    (defn safpb-source-probe ()
        (safp-source-file-probe (safpb-source-path) (safpb-source-hash) (safpb-max)))
    (defn safpb-fkb-probe ()
        (safp-program-image-fkb-file-probe (safpb-fkb-path)
                                           (safp-source-probe-vouch (safpb-source-probe))
                                           (safpb-fkb-hash)
                                           1
                                           1
                                           (safpb-max)))
    (defn safpb-good-probe ()
        (safp-source-fkb-probe (safpb-source-path) (safpb-fkb-path)
                               (safpb-source-hash) (safpb-fkb-hash) 1 1 (safpb-max)))
    (defn safpb-bad-source-probe ()
        (safp-source-fkb-probe (safpb-source-path) (safpb-fkb-path)
                               (safpb-wrong-hash) (safpb-fkb-hash) 1 1 (safpb-max)))
    (defn safpb-bad-fkb-probe ()
        (safp-source-fkb-probe (safpb-source-path) (safpb-fkb-path)
                               (safpb-source-hash) (safpb-wrong-hash) 1 1 (safpb-max)))
    (defn safpb-missing-fkb-probe ()
        (safp-source-fkb-probe (safpb-source-path) (safpb-missing-fkb-path)
                               (safpb-source-hash) (safpb-fkb-hash) 1 1 (safpb-max)))
    (defn safpb-good-bundle ()
        (safp-probe-bundle-sap (safpb-good-probe)))
    (defn safpb-bad-source-bundle ()
        (safp-probe-bundle-sap (safpb-bad-source-probe)))
    (defn safpb-bad-fkb-bundle ()
        (safp-probe-bundle-sap (safpb-bad-fkb-probe)))
    (defn safpb-missing-source-bundle ()
        (safp-source-fkb-bundle (safpb-missing-source-path) (safpb-fkb-path)
                                (safpb-source-hash) (safpb-fkb-hash) 1 1 (safpb-max)))
    (defn safpb-missing-fkb-bundle ()
        (safp-probe-bundle-sap (safpb-missing-fkb-probe)))
    (defn safpb-seal-bundle ()
        (safp-source-fkb-bundle (safpb-source-path) (safpb-fkb-path)
                                (safpb-source-hash) (safpb-fkb-hash) 0 1 (safpb-max)))
    (defn safpb-no-tbl-bundle ()
        (safp-source-fkb-bundle (safpb-source-path) (safpb-fkb-path)
                                (safpb-source-hash) (safpb-fkb-hash) 1 0 (safpb-max)))

    (defn safpb-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn safpb-source-descriptor ()
        (sad-source (safpb-source-path)
                    (safpb-source-hash)
                    (fs-stat-mtime (safpb-source-path))))
    (defn safpb-pif ()
        (pif-envelope (safpb-source-path)
                      (safpb-source-hash)
                      (fs-stat-mtime (safpb-source-path))
                      (safpb-fkb-path)
                      (safpb-fkb-hash)
                      (fs-stat-mtime (safpb-fkb-path))
                      1
                      (safpb-table)))
    (defn safpb-text ()
        (pite-table-text-from-envelope (safpb-pif)))
    (defn safpb-compile-envelope ()
        (rale-envelope-from-selection
            (safpb-source-descriptor)
            (sad-no-artifact)
            (sad-no-artifact)
            (ras-selection-from-plan
                (rap-plan-from-descriptors
                    (safpb-source-descriptor)
                    (sad-no-artifact)
                    (sad-no-artifact)))))
    (defn safpb-emission ()
        (sce-emission-from-compile (safpb-compile-envelope)
                                   (sac-compile-output 0 0)
                                   (safpb-pif)
                                   (safpb-text)
                                   (sce-no-dylib)))

    (defn safpb-bit-manifest-1 ()
        (safpb-score
            (and (eq (safpb-manifest-has "file-backed-sap-bundle") 1)
            (and (eq (safpb-manifest-has "uses-file-byte-digest") 1)
            (and (eq (safpb-manifest-has "direct-stat-fields-only") 1)
            (and (eq (safpb-manifest-has "no-supplied-hash-in-stat-pass") 1)
            (and (eq (safpb-manifest-has "stat-vouch-size-cross-check") 1)
            (and (eq (safpb-manifest-has "stat-drift-degrades-hash") 1)
            (and (eq (safpb-manifest-has "vouch-status-observable") 1)
                 (eq (safpb-manifest-has "source-hash-from-vouch-only") 1))))))))
            1))
    (defn safpb-bit-manifest-2 ()
        (safpb-score
            (and (eq (safpb-manifest-has "content-hash-from-vouch-only") 1)
            (and (eq (safpb-manifest-has "missing-artifact-stays-absent") 1)
            (and (eq (safpb-manifest-has "cap-bound-by-file-byte-digest") 1)
            (and (eq (safpb-manifest-has "seal-proof-callable-supplied") 1)
            (and (eq (safpb-manifest-has "no-seal-proof-verification") 1)
            (and (eq (safpb-manifest-has "no-whole-file-text-materialization") 1)
            (and (eq (safpb-manifest-has "no-form-binary-io") 1)
            (and (eq (safpb-manifest-has "no-disk-write") 1)
            (and (eq (safpb-manifest-has "no-artifact-load-walk-call") 1)
            (and (eq (safpb-manifest-has "no-runtime-selector") 1)
            (and (eq (safpb-manifest-has "no-route-derivation") 1)
            (and (eq (safpb-manifest-has "no-compiler-emission-import") 1)
            (and (eq (safpb-manifest-has "no-persistence-attestation") 1)
