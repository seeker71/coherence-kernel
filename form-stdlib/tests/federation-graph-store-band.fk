; federation-graph-store-band.fk — native identity + durable traversal proof.
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-ontology-loader.fk form-stdlib/offer-ack-core.fk form-stdlib/federation-graph-offer.fk form-stdlib/cell-log-store.fk form-stdlib/storage-port.fk form-stdlib/storage-port-file.fk form-stdlib/federation-graph-store.fk
;
; 11111112 = seven semantic bits (1111111), durable reopen (10000000),
; and carrier agreement (1).
(do
    (defn fgsb-run (carrier config)
        (do
            (let s0 (storage-open carrier config))
            (let a (fgs-offer carrier s0 "mac" "android" "text" "hello" "{}" "2026-07-22T00:00:00Z"))
            (let s1 (fgs-result-store a))
            (let duplicate (fgs-offer carrier s1 "mac" "android" "text" "hello" "{}" "2026-07-22T00:00:00Z"))
            (let s2 (fgs-result-store duplicate))
            (let b (fgs-offer carrier s2 "windows" "" "status" "alive" "{}" "2026-07-22T00:00:01Z"))
            (let s3 (fgs-result-store b))
            (list s3
              (sum (list
                (if (eq (fgs-ack-node? a) 1) 1 0)
                (if (str_eq (fgs-result-id a) (fgs-result-id duplicate)) 10 0)
                (if (eq (fgs-count carrier s3) 2) 100 0)
                (if (eq (storage-found? (fgs-get carrier s3 (fgs-result-id a))) 1) 1000 0)
                (if (eq (len (fgs-incoming carrier s3 "android")) 1) 10000 0)
                (if (eq (len (fgs-outgoing carrier s3 "mac")) 1) 100000 0)
                (if (eq (len (fgs-broadcasts carrier s3)) 1) 1000000 0))))))
    (let mem (fgsb-run (carrier-memory) ""))
    (let dir (str_concat (temp_dir) "/federation-graph-store-band.d"))
    (fs_rmdir dir)
    (let file (fgsb-run (carrier-file) dir))
    (let reopened (storage-open (carrier-file) dir))
    (let durable (if (and (eq (fgs-count (carrier-file) reopened) 2)
                          (eq (len (fgs-incoming (carrier-file) reopened "android")) 1))
                     10000000 0))
    (let agree (if (eq (nth mem 1) (nth file 1)) 1 0))
    (fs_rmdir dir)
    (sum (list (nth file 1) durable agree)))
