; string-byte-fold-band.fk — raw UTF-8/NUL parity for the materialized and
; streaming native byte doors plus the linear universal-table text carrier.
; Input/table length never becomes Form recursion or a live N-cell byte list.

(do
    (defn sbf-sum (acc byte) (add acc byte))
    (defn sbf-count (acc byte) (add acc 1))

    (let sample (str_concat "A" (str_concat (byte_to_str 0) "λ🙂")))
    (let bytes (string_bytes sample))

    (let c0 (if (eq (len bytes) 8) 1 0))
    (let c1 (if (and (eq (nth bytes 0) 65)
                     (and (eq (nth bytes 1) 0)
                       (and (eq (nth bytes 2) 206)
                         (and (eq (nth bytes 3) 187)
                           (and (eq (nth bytes 4) 240)
                             (and (eq (nth bytes 5) 159)
                               (and (eq (nth bytes 6) 153)
                                    (eq (nth bytes 7) 130)))))))) 2 0))
    (let c2 (if (eq (string_byte_fold sample 0 sbf-sum) 1140) 4 0))
    (let c3 (if (eq (string_byte_fold "Form" 0 sbf-sum) 404) 8 0))
    (let c4 (if (eq (string_byte_fold sample 0 sbf-count) 8) 16 0))
    (let c5 (if (str_eq
                    (form_table_text
                        (list 8 3)
                        (list (list 4 5 6 7) (list 1 2 3 4)))
                    "2 3 8 2 1 2 3 4 4 5 6 7") 32 0))

    (sum (list c0 c1 c2 c3 c4 c5)))
