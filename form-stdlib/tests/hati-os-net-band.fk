; preludes: form-stdlib/core.fk form-stdlib/minimal-surface.fk form-stdlib/hati-os-kernel.fk form-stdlib/hati-os-kernel-emit.fk
;
; hati-os-net-band — n1/n2 proven three-way: the NET organ (a server-variant
; main owning socket/bind/listen/accept/fork through quoteless externs), live
; request staging into fk_src, and the responder builder (fkresp folds a
; string into a PUTC-chain program).
; The dup2(fd,1) move makes the PROGRAM's PUTC bytes the response body. The
; live serving — a real binary answering curl with 200 + JSON, sub-ms — is
; the audit's half; here the kernels prove the server emission agrees.
;
; Verdict 63 when the net surface holds:
;   1   fkresp folds bytes to PUTC rows — "hi" gives LIT 104, PUTC, LIT 105,
;       PUTC chained by ADD-sequencing over a LIT 0 base
;   2   the server emission carries the net organ externs — socket(2,1,0),
;       fork(), accept(sfd ... — found by str_find
;   4   the server emission stages the accepted request into fk_src
;       (read(cfd, fk_src...), fk_src[got]=0), making dynamic response
;       selection possible on the live request bytes
;   8   the server emission stays deterministic for the same responder
;       (same fns -> same text)
;   16  a different responder string gives a different emission (the body the
;       net main serves is the program, parameterized)
;   32  the universal server emission loads a table file once and stages each
;       accepted request into fk_src before walking fn 0
(do
    (let resp (fkresp "hi"))
    (let c0 (if (str_eq (fkc-rows-text (fkc-flatten resp)) "{1,104,0,0},{9,0,0,0},{1,105,0,0},{9,2,0,0},{1,0,0,0},{3,3,4,0},{3,1,5,0},") 1 0))

    (let srv (fkc-emit-server (list resp)))
    (let c1 (if (ge (str_find srv "socket(2, 1, 0)" 0) 0)
                (if (ge (str_find srv "fork()" 0) 0)
                    (if (ge (str_find srv "accept(sfd" 0) 0) 2 0) 0) 0))

    (let c2 (if (ge (str_find srv "read((int)cfd, fk_src, 262143)" 0) 0)
                (if (ge (str_find srv "fk_src[got] = 0;" 0) 0) 4 0) 0))

    (let c3 (if (str_eq srv (fkc-emit-server (list resp))) 8 0))

    (let c4 (if (str_eq srv (fkc-emit-server (list (fkresp "yo")))) 0 16))

    (let srvu (fkc-emit-server-universal))
    (let c5 (if (ge (str_find srvu "open(argv[1], 0)" 0) 0)
                (if (ge (str_find srvu "read((int)cfd, fk_src, 262143)" 0) 0) 32 0) 0))

    (sum (list c0 c1 c2 c3 c4 c5)))
