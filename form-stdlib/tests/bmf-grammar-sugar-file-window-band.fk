; bmf-grammar-sugar-file-window-band.fk -- literal sugar over cursor-file windows.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk
;
; Expected: 7

(do
  (defn s (ok bit) (if ok bit 0))
  (defn kid (n i) (nth (node_children n) i))
  (defn cat? (n name) (node_eq (node_category n) (bmf-bp name)))
  (let root (fs-path-join (fs-temp-dir) "bgs-fw-band"))
  (let path (fs-path-join root "x.bmf"))
  (let _a (fs-remove-file path))
  (let _b (fs-remove-tree root))
  (let _c (fs-mkdir root))
  (let _d (fs-write-text path "\"fw\" 42"))
  (let g (grammar "p" (list
    (rule3 "p" (list "seq" (p-cap "a" (p-str)) (p-cap "b" (p-num)))
      (t-emit "do" (list (t-splice "a") (t-splice-int "b")))))))
  (let r (g-match-full-rule g "p" (cursor-file-window path 3)))
  (let n (if (rok? r) (rok-node r) (intern_trivial_string "missing")))
  (let score (sum (list
    (s (rok? r) 1)
    (s (cat? n "do") 2)
    (s (and (str_eq (node_value (kid n 0)) "fw") (eq (node_value (kid n 1)) 42)) 4))))
  (let _e (fs-remove-file path))
  (let _f (fs-remove-tree root))
  score)
