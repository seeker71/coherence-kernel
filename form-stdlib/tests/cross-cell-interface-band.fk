; cross-cell-interface-band.fk — the cross-cell interface domain grammar: five
; interfaces as data rows, one engine routes any request and folds only the
; MERGING ones (share/learn/build) into the commons; the transient ones
; (sense/ask) read without keeping. A sixth interface would be a new ROW, not a
; recipe. Establishes the lift four-way.
;
; preludes: form-stdlib/core.fk form-stdlib/channel-interface.fk form-stdlib/world-build.fk form-stdlib/cross-cell-interface.fk

(do
    (let accepting (list (m-witness) (m-ask-how) (m-offer) (m-reflect) (m-invite)))

    ; one request per interface + a bare one (-> ask, ground) + a duplicate share
    (let reqs (list
        "sense gpu"        ; transient -> does NOT grow the commons
        "ask how-decode"   ; transient
        "share r-add"      ; merges -> grows
        "learn ex-1"       ; merges -> grows
        "build world-1"    ; merges -> grows
        "hello there"      ; -> ask (ground), transient
        "share r-add"))    ; duplicate merge -> content-addressed dedup
    (let commons (cci-route-stream (world-empty) accepting reqs))

    ; only share/learn/build fold in; share r-add deduped -> {r-add, ex-1, world-1} = 3
    (let n (world-size commons))
    ; the engine reads the registry: verb -> interface (ask is the ground default)
    (let i-sense (if (str_eq (cci-interface "sense gpu") "sense") 1 0))
    (let i-build (if (str_eq (cci-interface "build world-1") "build") 1 0))
    (let i-ask   (if (str_eq (cci-interface "hello there") "ask") 1 0))
    ; the registry holds five interfaces, all as data
    (let regn (len (cci-registry)))
    ; 3 + 1*10 + 1*100 + 1*1000 + 5*10000 = 51113
    (add n (add (mul i-sense 10) (add (mul i-build 100) (add (mul i-ask 1000) (mul regn 10000))))))
