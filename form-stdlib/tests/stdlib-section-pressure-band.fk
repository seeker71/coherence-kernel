; stdlib-section-pressure-band.fk -- low-level Form pressure is observable.
;
; preludes: form-stdlib/core.fk form-stdlib/engine.fk form-stdlib/stdlib-section-pressure.fk
;
; Expected: 65535

(do
    (defn sgpb-score (ok bit) (if ok bit 0))
    (defn sgpb-manifest-has (name)
        (stdlib-section-pressure-manifest-has?
            name
            (stdlib-section-pressure-manifest)))
    (defn sgpb-rows () (sgp-observed-rows))
    (defn sgpb-core-row () (nth (sgpb-rows) 0))
    (defn sgpb-bmf-section-row () (nth (sgpb-rows) 3))
    (defn sgpb-uplift-row () (nth (sgpb-rows) 4))
    (defn sgpb-first-rt () (sgp-roundtrip-row (sgpb-core-row)))

    (defn stdlib-section-pressure-band ()
        (add
            (sgpb-score (eq (sgpb-manifest-has "real-file-read") 1) 1)
        (add
            (sgpb-score (eq (sgpb-manifest-has "low-level-defn-count") 1) 2)
        (add
            (sgpb-score (sgp-source-has-pressure-section?) 4)
        (add
            (sgpb-score (and (sgp-source-has-pressure-rule?)
                             (sgp-source-has-pressure-reverse?)) 8)
        (add
            (sgpb-score (eq (len (sgpb-rows)) 5) 16)
        (add
            (sgpb-score (gt (sgp-total-defn (sgpb-rows)) 0) 32)
        (add
            (sgpb-score (gt (sgp-total-let (sgpb-rows)) 0) 64)
        (add
            (sgpb-score (gt (sgp-total-bmf-sections (sgpb-rows)) 0) 128)
        (add
            (sgpb-score (eq (sgp-all-rows-have-next? (sgpb-rows)) 1) 256)
        (add
            (sgpb-score (gt (sgp-row-defn-count (sgpb-core-row)) 0) 512)
        (add
            (sgpb-score (gt (sgp-row-bmf-count (sgpb-bmf-section-row)) 0) 1024)
        (add
            (sgpb-score (gt (sgp-row-defn-count (sgpb-uplift-row)) 0) 2048)
        (add
            (sgpb-score (eq (sgp-all-roundtrips-ok? (sgpb-rows)) 1) 4096)
        (add
            (sgpb-score (eq (len (bmf-roundtrip-source (sgpb-first-rt))) 19) 8192)
        (add
            (sgpb-score (sgp-has? (sgp-source-text) "\"defn\"") 16384)
            (sgpb-score (gt (sgp-pressure-total (sgpb-rows))
                            (sgp-total-defn (sgpb-rows))) 32768)))))))))))))))))

    (stdlib-section-pressure-band))
