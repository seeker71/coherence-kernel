; program-image-tbl-emit-band.fk -- witness .tbl text emission from 8h envelope.
;
; preludes: form-stdlib/core.fk form-stdlib/form-fs.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-tbl-emit.fk
;
; Expected: 2147483647

(do
    (defn piteb-score (ok bit) (if ok bit 0))
    (defn piteb-manifest-has (name)
        (program-image-tbl-emit-manifest-has? name (program-image-tbl-emit-manifest)))
    (defn piteb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn piteb-read-text-any (primary fallback)
        (if (ge (fs-stat-size primary) 0)
            (fs-read-text primary)
            (fs-read-text fallback)))

    (defn piteb-path () "/tmp/program-image-tbl-emit.tbl")
    (defn piteb-invalid-path () "/tmp/program-image-tbl-emit-invalid.tbl")

    (defn piteb-table-42 ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn piteb-table-negative ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 -7 0 0))
                         0
                         (empty)))
    (defn piteb-table-string ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 7 0 0))
                         1
                         (list (list 65 66))))
    (defn piteb-bad-node-arity ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (list 1 42 0))
                         0
                         (empty)))
    (defn piteb-bad-count ()
        (pif-table-image 2
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn piteb-bad-root-kind ()
        (pif-table-image 1
                         (list "root")
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn piteb-bad-node-cell-kind ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 "bad" 0 0))
                         0
                         (empty)))
    (defn piteb-envelope-42 ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (piteb-table-42)))
    (defn piteb-envelope-seal-bad ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      0
                      (piteb-table-42)))
    (defn piteb-envelope-bad-table ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (piteb-bad-node-arity)))

    (defn piteb-golden-42 () "1 0 1 1 42 0 0 0\n")
    (defn piteb-golden-negative () "1 0 1 1 -7 0 0 0\n")
    (defn piteb-golden-string () "1 0 1 1 7 0 0 1 2 65 66\n")

    (defn piteb-bit-manifest-1 ()
        (sum (list
            (piteb-score (eq (piteb-manifest-has "valid-envelope-to-tbl-text") 1) 1)
            (piteb-score (eq (piteb-manifest-has "executor-order-nf-fns-nr-nodes-ns-strings") 1) 2)
            (piteb-score (eq (piteb-manifest-has "single-space-between-integers") 1) 4)
            (piteb-score (eq (piteb-manifest-has "one-trailing-newline") 1) 8)
            (piteb-score (eq (piteb-manifest-has "exact-golden-text") 1) 16)
            (piteb-score (eq (piteb-manifest-has "negative-integer-rendering") 1) 32)
            (piteb-score (eq (piteb-manifest-has "string-byte-row-rendering") 1) 64)
            (piteb-score
                (and (eq (piteb-manifest-has "invalid-envelope-empty-text") 1)
                     (eq (piteb-manifest-has "numeric-stream-integers-required") 1))
                128))))
    (defn piteb-bit-manifest-2 ()
        (sum (list
            (piteb-score (eq (piteb-manifest-has "invalid-write-nondestructive") 1) 256)
            (piteb-score (eq (piteb-manifest-has "write-text-only") 1) 512)
            (piteb-score (eq (piteb-manifest-has "write-return-observed") 1) 1024)
            (piteb-score (eq (piteb-manifest-has "no-binary-artifact-io") 1) 2048)
            (piteb-score (eq (piteb-manifest-has "no-program-image-load") 1) 4096)
            (piteb-score (eq (piteb-manifest-has "no-native-call") 1) 8192)
            (piteb-score (eq (piteb-manifest-has "no-selector-install") 1) 16384)
            (piteb-score (eq (piteb-manifest-has "no-c-seed-growth") 1) 32768)
            (piteb-score (eq (piteb-manifest-has "future-9h-consumes-table-text-or-live-binary-io") 1) 65536))))

    (defn piteb-bit-golden-42 ()
        (piteb-score
            (str_eq (pite-table-text-from-envelope (piteb-envelope-42))
                    (piteb-golden-42))
            131072))
    (defn piteb-bit-table-direct ()
        (piteb-score
            (str_eq (pite-table-text (piteb-table-42))
                    (piteb-golden-42))
            262144))
    (defn piteb-bit-negative ()
        (piteb-score
            (str_eq (pite-table-text (piteb-table-negative))
                    (piteb-golden-negative))
            524288))
    (defn piteb-bit-string-row ()
        (piteb-score
            (str_eq (pite-table-text (piteb-table-string))
                    (piteb-golden-string))
            1048576))
    (defn piteb-bit-invalid-table-empty ()
        (piteb-score
            (and (str_eq (pite-table-text (piteb-bad-node-arity)) "")
            (and (str_eq (pite-table-text (piteb-bad-count)) "")
            (and (str_eq (pite-table-text (piteb-bad-root-kind)) "")
                 (str_eq (pite-table-text (piteb-bad-node-cell-kind)) ""))))
            2097152))
    (defn piteb-bit-invalid-envelope-empty ()
        (piteb-score
            (and (str_eq (pite-table-text-from-envelope (piteb-envelope-seal-bad)) "")
                 (str_eq (pite-table-text-from-envelope (piteb-envelope-bad-table)) ""))
            4194304))
    (defn piteb-bit-exact-order-pinned ()
        (do
            (let stream (pif-table-numeric-stream (piteb-table-string)))
            (piteb-score
                (and (eq (len stream) 11)
                (and (eq (nth stream 0) 1)
                (and (eq (nth stream 1) 0)
                (and (eq (nth stream 2) 1)
                (and (eq (nth stream 3) 1)
                (and (eq (nth stream 4) 7)
                (and (eq (nth stream 7) 1)
                (and (eq (nth stream 8) 2)
                (and (eq (nth stream 9) 65)
                     (eq (nth stream 10) 66))))))))))
                8388608)))
    (defn piteb-bit-write-valid ()
        (do
            (let _rm (fs-remove-file (piteb-path)))
            (let wrote (pite-write-table-text (piteb-path) (piteb-envelope-42)))
            (piteb-score
                (and (eq wrote 1)
                (and (str_eq (fs-read-text (piteb-path)) (piteb-golden-42))
                     (eq (fs-stat-size (piteb-path)) (str_len (piteb-golden-42)))))
                16777216)))
    (defn piteb-bit-write-invalid-nondestructive ()
        (do
            (let _rm (fs-remove-file (piteb-invalid-path)))
            (let wrote-missing (pite-write-table-text (piteb-invalid-path) (piteb-envelope-bad-table)))
            (let absent-ok
                (and (eq wrote-missing 0)
                     (eq (fs-stat-size (piteb-invalid-path)) -1)))
            (let sentinel "stale-table-sentinel\n")
            (let _seed (fs-write-text (piteb-invalid-path) sentinel))
            (let wrote-existing (pite-write-table-text (piteb-invalid-path) (piteb-envelope-bad-table)))
            (piteb-score
                (and absent-ok
                (and (eq wrote-existing 0)
                (and (str_eq (fs-read-text (piteb-invalid-path)) sentinel)
                     (eq (fs-stat-size (piteb-invalid-path)) (str_len sentinel)))))
                33554432)))
    (defn piteb-bit-descriptor-still-routes ()
        (piteb-score
            (eq (pif-route-from-envelope (piteb-envelope-42)) (sac-run-fkb))
            67108864))
    (defn piteb-bit-shape-rejects ()
        (piteb-score
            (and (not (pif-table-valid? (piteb-bad-node-arity)))
                 (not (pif-table-valid? (piteb-bad-count))))
            134217728))
    (defn piteb-bit-static-module-guide ()
        (do
            (let text (piteb-read-text-any "form/form-stdlib/program-image-tbl-emit.fk"
                                           "../form/form-stdlib/program-image-tbl-emit.fk"))
            (piteb-score
                (and (not (piteb-has? text "write_form_binary"))
                (and (not (piteb-has? text "read_form_binary"))
                (and (not (piteb-has? text "recipe_to_bytes"))
                (and (not (piteb-has? text "bytes_to_recipe"))
                (and (not (piteb-has? text "dlopen"))
                     (not (piteb-has? text "fk_run")))))) )
                268435456)))
    (defn piteb-bit-mirror ()
        (do
            (let text (piteb-read-text-any "form/form-stdlib/program-image-tbl-emit.fk"
                                           "../form/form-stdlib/program-image-tbl-emit.fk"))
            (let grammar (piteb-read-text-any "grammars/program-image-tbl-emit.fk"
                                              "../grammars/program-image-tbl-emit.fk"))
            (piteb-score
                (str_eq text grammar)
                536870912)))
    (defn piteb-bit-version ()
        (piteb-score (str_eq (pite-version) "program-image-tbl-emit-v1") 1073741824))

    (defn program-image-tbl-emit-band ()
        (sum (list
            (piteb-bit-manifest-1)
            (piteb-bit-manifest-2)
            (piteb-bit-golden-42)
            (piteb-bit-table-direct)
            (piteb-bit-negative)
            (piteb-bit-string-row)
            (piteb-bit-invalid-table-empty)
            (piteb-bit-invalid-envelope-empty)
            (piteb-bit-exact-order-pinned)
            (piteb-bit-write-valid)
            (piteb-bit-write-invalid-nondestructive)
            (piteb-bit-descriptor-still-routes)
            (piteb-bit-shape-rejects)
            (piteb-bit-static-module-guide)
            (piteb-bit-mirror)
            (piteb-bit-version))))

    (program-image-tbl-emit-band))
