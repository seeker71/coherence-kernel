; json-band.fk — proof json.fk works on `fkwu --src`, at last.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk
;
; json.fk was broken on bare `fkwu --src` from the start — root-caused this
; walk to genuinely be root cause #2 from receipts/2026-07-01-json-fk-src-
; scoping-fix.md (forward references between top-level `defn`s never
; resolve), applying MORE PERVASIVELY than first understood: `json-next-
; token` itself forward-referenced its own scan-string/scan-number/scan-
; literal helpers, and the parser/emitter were each a genuine mutual-
; recursion cycle (five and four functions respectively). What that
; receipt named "root cause #3" (self-recursion in one `if`-branch
; corrupting sibling branches) turned out NOT to be a fourth interpreter
; bug — see receipts/2026-07-01-json-fk-actually-fixed.md for the full,
; corrected account of how that got misdiagnosed.
;
; Fixed by: reordering the tokenizer bottom-up (every function defined
; after everything it calls — a pure DAG, no cycles there), and collapsing
; the parser (json-parse-value/array/array-elements/object/object-pairs)
; and the emitter (json-emit/pair-list/array-items/pair-node) into ONE
; self-recursive function each, keyed on a `mode` argument — the exact
; shape cell-serialize.fk and wire-xml.fk already proved correct.
;
; Covers: numbers (the original failing case), nested objects, nested
; arrays, null, strings, floats, and the parse-json/json-object-get public
; entry points external callers (routers/mesh-sensings-route.fk) actually
; use. Does NOT cover true/false round-tripping distinctly — a real,
; separate, pre-existing native-level gap (`intern_trivial_bool true` and
; `...false` construct the SAME node, confirmed directly), named in
; json-emit-leaf's own comment, not silently assumed fixed by this stone.
;
; Verdict 255 when every assertion holds.

(do
    (defn jsb-score (ok bit) (if ok bit 0))
    (defn json-band ()
        (do
    (let n (json-pair-r (json-parse-value "1" 0 "test")))
    (let c0 (jsb-score (eq (node_value n) 1) 1))                              ; the original failing case
    (let obj (json-pair-r (json-parse-value "{\"a\":1,\"b\":[2,3]}" 0 "test")))
    (let c1 (jsb-score (str_eq (json-emit obj) "{\"a\":1,\"b\":[2,3]}") 2))
    (let c2 (jsb-score (eq (node_value (json-object-get obj "a")) 1) 4))
    (let nested (json-pair-r (json-parse-value "{\"x\":{\"y\":5}}" 0 "test")))
    (let c3 (jsb-score (str_eq (json-emit nested) "{\"x\":{\"y\":5}}") 8))
    (let nul (json-pair-r (json-parse-value "null" 0 "test")))
    (let c4 (jsb-score (str_eq (json-emit nul) "null") 16))
    (let arr (json-pair-r (json-parse-value "[1,2,3]" 0 "test")))
    (let c5 (jsb-score (str_eq (json-emit arr) "[1,2,3]") 32))
    (let deep (parse-json "test" "{\"deep\":{\"nested\":[1,2,3]}}"))
    (let c6 (jsb-score (str_eq (json-emit deep) "{\"deep\":{\"nested\":[1,2,3]}}") 64))
    (let s (json-pair-r (json-parse-value "\"hello\"" 0 "test")))
    (let f (json-pair-r (json-parse-value "3.5" 0 "test")))
    (let c7 (jsb-score (and (str_eq (json-emit s) "\"hello\"") (str_eq (json-emit f) "3.5")) 128))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (json-band))
