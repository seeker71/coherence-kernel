; native-edit-band.fk — four-way proof of native-edit's STRING layer (index,
; count, replace-first, replace-all, GREP) on synthetic strings. No host I/O, so
; the walkers (Go/Rust/TS) run it identically to fkwu. The file layer (ne-edit-
; unique / ne-edit-all / ne-grep-file) is fkwu-carrier and proven live by receipt.
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/native-edit.fk
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/line-grammar.fk form/form-stdlib/native-edit.fk \
;          form/form-stdlib/tests/native-edit-band.fk > /tmp/ne.fk
;      ./fkwu --src /tmp/ne.fk    ; -> 255
;
; Verdict 255 when every assertion holds (incl. the grep bit).
(do
    (defn neb-score (ok bit) (if ok bit 0))
    (defn native-edit-band ()
        (do
            ; the ONE substring engine (find-from, shared with sh-bi-grep): found
            ; mid-string, found-after-`from`, and not-found
            (let c0 (neb-score (eq (find-from "hello world" "world" 0) 6) 1))
            (let c1 (neb-score (eq (find-from "abcabc" "abc" 1) 3) 2))
            (let c2 (neb-score (eq (find-from "abc" "xyz" 0) -1) 4))
            ; count: non-overlapping
            (let c3 (neb-score (eq (ne-count "abababab" "ab") 4) 8))
            ; replace-first vs replace-all
            (let c4 (neb-score (str_eq (ne-replace-first "a.b.c.d" "." "-") "a-b.c.d") 16))
            (let c5 (neb-score (str_eq (ne-replace-all "a.b.c.d" "." "-") "a-b-c-d") 32))
            ; replace-all where `new` contains `old` must NOT loop (rescans only the tail)
            (let c6 (neb-score (str_eq (ne-replace-all "xx" "x" "yy") "yyyy") 64))
            ; grep: line-oriented match count -- "a cat" and "cat cat" match, "a dog" does not
            (let c7 (neb-score (eq (ne-grep-count "cat"
                        (str_concat "a cat" (str_concat (byte_to_str 10)
                            (str_concat "a dog" (str_concat (byte_to_str 10) "cat cat"))))) 2) 128))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))
    (native-edit-band))
