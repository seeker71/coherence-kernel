; preludes: form-stdlib/core.fk form-stdlib/offer-ack-core.fk form-stdlib/federation-graph-offer.fk
(do
    (let m1 (fgo-message "m1" "mac" "android" "command" "e30="))
    (let m1-again (fgo-message "m1" "mac" "android" "command" "e30="))
    (let m2 (fgo-message "m2" "mac" "android" "command" "e30="))
    (let ack (fgo-offer "m1" "mac" "android" "command" "e30="))
    (add (if (node_eq m1 m1-again) 1 0)
         (add (if (not (node_eq m1 m2)) 10 0)
              (add (if (eq (oac-kind ack) (oac-tag-node)) 100 0)
                   (if (node_eq (oac-payload ack) (fgo-edge "mac" "android" m1)) 1000 0)))))
)
