; preludes: form-stdlib/core.fk form-stdlib/somatic-coherence-loop.fk
;
; somatic-coherence-loop-band -- executable consentful coherence loop.
;
; Verdict 255:
;   1   ungrounded routes to ground
;   2   unattuned routes to attune
;   4   no consent routes to ask-consent
;   8   no small move routes to move-small
;   16  no integration routes to integrate
;   32  no witness routes to witness
;   64  complete state returns complete
;   128 no depth without consent, even if integration is present

(do
    (defn scl-band-score (cond bit) (if cond bit 0))
    (defn somatic-coherence-loop-band ()
        (do
            (let no-ground (scl-receipt 0 1 1 1 1 1))
            (let no-attune (scl-receipt 1 0 1 1 1 1))
            (let no-consent (scl-receipt 1 1 0 1 1 1))
            (let no-move (scl-receipt 1 1 1 0 1 1))
            (let no-integrate (scl-receipt 1 1 1 1 0 1))
            (let no-witness (scl-receipt 1 1 1 1 1 0))
            (let complete (scl-receipt 1 1 1 1 1 1))
            (add
                (add
                    (add (scl-band-score (str_eq (scl-rec-next no-ground) "ground") 1)
                         (scl-band-score (str_eq (scl-rec-next no-attune) "attune") 2))
                    (add (scl-band-score (str_eq (scl-rec-next no-consent) "ask-consent") 4)
                         (scl-band-score (str_eq (scl-rec-next no-move) "move-small") 8)))
                (add
                    (add (scl-band-score (str_eq (scl-rec-next no-integrate) "integrate") 16)
                         (scl-band-score (str_eq (scl-rec-next no-witness) "witness") 32))
                    (add (scl-band-score (str_eq (scl-rec-next complete) "complete") 64)
                         (scl-band-score (eq (scl-may-deepen? 1 1 0 1) 0) 128))))))
    (somatic-coherence-loop-band))
