; tests/http-server-band.fk — sibling-witness band for http-server.fk.
; preludes: form-stdlib/kernel-http.fk form-stdlib/http-parse.fk form-stdlib/http-request.fk form-stdlib/http-render.fk form-stdlib/http-server.fk
;
; The Server. Proves the full dispatch — a raw HTTP/1.1 request string flows
; parse -> Router -> handler -> render -> wire — across every shape: two matched
; routes (one whose handler reads the request and declares its own content-type),
; an unmatched path (404 naming what missed), a matched route whose handler is
; unregistered (500, the wiring gap made visible), HEAD through GET with no body,
; case-insensitive required headers, and a generic OPTIONS invitation. The whole
; flow walks one value vocabulary — no substrate-node detour anywhere on the path.
;
; The handlers, routes, and registry are DEMO data this band supplies; the
; Server names none of them — it is one generic flow over data. Emits a bit-sum
; (1023 when all pass). Identical across Go/Rust/TS + the emitted fkwu arm proves
; the dispatch — including the first-class handler call — is correct and
; four-way-portable.

;; demo handlers : handler(kh-request) -> kh-response. A handler reads the
;; request through the Request class and returns a Response; it never sees
;; routing. demo-echo reads the path and declares application/json.
(defn demo-health (request) (kh-response 200 (list) "ok"))
(defn demo-echo (request)
    (kh-response 200
        (list (kh-header "Content-Type" "application/json"))
        (str_concat "{\"path\":\"" (str_concat (kh-request-path request) "\"}"))))

;; demo routes (DATA) + registry (name -> handler closure). "ghost" names a
;; handler the registry does NOT hold — the wiring gap CHECK 5 exercises.
(let demo-routes
    (list (kh-route "health" "GET" "/health" 0 "health" "" 100)
          (kh-route "echo"   "GET" "/echo"   0 "echo"   "" 100)
          (kh-route "ghost"  "GET" "/ghost"  0 "ghost-handler" "" 100)
          (kh-route "blocked" "GET" "/blocked" 99 "health" "X-Missing" 0)))
(let demo-registry
    (list (list "health" demo-health)
          (list "echo"   demo-echo)))

;; CHECK 1 (bit 1) — GET /health dispatches to demo-health: a 200 whose body is
;; "ok" and whose content-type is the text/plain default (the handler set none).
(let r-health (kh-serve demo-routes demo-registry "GET /health HTTP/1.1\r\nHost: x\r\n\r\n"))
(let ok-health
    (if (str_eq r-health "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 2\r\nX-Form-Router: native-kernel\r\n\r\nok")
        1 0))

;; CHECK 2 (bit 2) — GET /echo dispatches to demo-echo, which READS the request
;; path and declares application/json. Body {"path":"/echo"} is 16 bytes; the
;; handler's content-type is preserved, the framing headers added.
(let r-echo (kh-serve demo-routes demo-registry "GET /echo HTTP/1.1\r\nHost: x\r\n\r\n"))
(let ok-echo
    (if (str_eq r-echo "HTTP/1.1 200 OK\r\nContent-Length: 16\r\nX-Form-Router: native-kernel\r\nContent-Type: application/json\r\n\r\n{\"path\":\"/echo\"}")
        2 0))

;; CHECK 3 (bit 4) — an unmatched path yields the Server's 404.
(let r-404 (kh-serve demo-routes demo-registry "GET /nope HTTP/1.1\r\nHost: x\r\n\r\n"))
(let ok-404 (if (ge (str_find r-404 "HTTP/1.1 404 Not Found\r\n" 0) 0) 4 0))

;; CHECK 4 (bit 8) — the 404 body names the path that missed.
(let ok-404-body (if (ge (str_find r-404 "no route for /nope" 0) 0) 8 0))

;; CHECK 5 (bit 16) — GET /ghost MATCHES a route, but "ghost-handler" is not in
;; the registry: the Server answers 500, the wiring gap made visible rather than
;; crashing or silently 404-ing.
(let r-ghost (kh-serve demo-routes demo-registry "GET /ghost HTTP/1.1\r\nHost: x\r\n\r\n"))
(let ok-ghost (if (ge (str_find r-ghost "HTTP/1.1 500 Internal Server Error\r\n" 0) 0) 16 0))

;; CHECK 6 (bit 32) — GET /blocked has an exact high-priority route, but that
;; route requires a missing header and has no pressure budget. Eligibility is a
;; Form-native choice point, so the Server does NOT dispatch the route's handler;
;; it returns the honest route miss.
(let r-blocked (kh-serve demo-routes demo-registry "GET /blocked HTTP/1.1\r\nHost: x\r\n\r\n"))
(let ok-blocked (if (ge (str_find r-blocked "HTTP/1.1 404 Not Found\r\n" 0) 0) 32 0))

;; CHECK 7 (bit 64) — HEAD /health can use the GET route, but the server sends
;; no response body. This welcomes health probes/caches without duplicating every
;; GET handler as a HEAD handler.
(let r-head (kh-serve demo-routes demo-registry "HEAD /health HTTP/1.1\r\nHost: x\r\n\r\n"))
(let ok-head (if (str_eq r-head "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 0\r\nX-Form-Router: native-kernel\r\n\r\n") 64 0))

;; CHECK 8 (bit 128) — a lowercased required header still satisfies the route,
;; matching HTTP's case-insensitive header-name rule.
(let r-blocked-present (kh-serve demo-routes demo-registry "GET /blocked HTTP/1.1\r\nHost: x\r\nx-missing: yes\r\n\r\n"))
(let ok-blocked-present (if (ge (str_find r-blocked-present "HTTP/1.1 200 OK\r\n" 0) 0) 128 0))

;; CHECK 9 (bit 256) — unmatched OPTIONS gets a native no-body invitation with
;; an Allow header instead of looking like an ordinary route miss.
(let r-options (kh-serve demo-routes demo-registry "OPTIONS /nope HTTP/1.1\r\nHost: x\r\nOrigin: https://coherencycoin.com\r\n\r\n"))
(let ok-options (if (and (ge (str_find r-options "HTTP/1.1 204 No Content\r\n" 0) 0) (ge (str_find r-options "Allow: GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS\r\n" 0) 0)) 256 0))

;; CHECK 10 (bit 512) — the protocol invitation is policy data, not a server
;; constant. A custom channel policy emits its own Allow surface.
(let custom-policy
    (kh-channel-policy "tcp" "http/1.1"
        (list "GET" "HEAD" "OPTIONS")
        (list (kh-method-bridge "GET" "HEAD" 12))
        (list "HEAD")
        (list "GET" "HEAD" "OPTIONS")
        "cache-policy-observe"
        "compression-policy-observe"
        "stream-policy-buffered"
        "identity-policy-claim"
        "authorization-policy-capability"))
(let r-options-custom (kh-serve-with-policy demo-routes demo-registry "OPTIONS /nope HTTP/1.1\r\nHost: x\r\n\r\n" custom-policy))
(let ok-options-custom (if (and (ge (str_find r-options-custom "HTTP/1.1 204 No Content\r\n" 0) 0) (ge (str_find r-options-custom "Allow: GET, HEAD, OPTIONS\r\n" 0) 0)) 512 0))

;; verdict — sum of the bit-weighted checks; 1023 when all pass.
(add ok-health
(add ok-echo
(add ok-404
(add ok-404-body
(add ok-ghost
(add ok-blocked
(add ok-head
(add ok-blocked-present
(add ok-options
     ok-options-custom)))))))))
