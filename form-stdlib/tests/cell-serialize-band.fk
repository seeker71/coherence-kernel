; cell-serialize-band.fk — proof of the values+types+identity JSON round-trip.
;
; preludes: form-stdlib/core.fk form-stdlib/wire-registry.fk form-stdlib/cell-serialize.fk
;
; The actual north star: a nested cell built via intern_node/bp survives a
; full trip through JSON TEXT and back to the exact same NodeID — not just
; equal-looking values, real content-addressed identity (axiom-3), verified
; via `eq`, not `str_eq` on some rendering of it. Also covers the two gaps
; named (and now closed) in receipts/2026-07-01-wire-serialization-lane-
; generic-dialects.md: `null` is a real, distinct, identity-preserving
; value (wire-registry.fk's WIRE-NULL), not int 0; and a string carrying
; every character JSON requires escaping (quote, backslash, newline) round-
; trips exactly, not just characters that happened not to need it.
;
; Verdict 1023 when every assertion holds.

(do
    (defn csb-score (ok bit) (if ok bit 0))
    (defn cell-serialize-band ()
        (do
    (let registry (list (wr-entry "OUTER" (bp "OUTER")) (wr-entry "INNER" (bp "INNER"))))
    (let inner (intern_node (bp "INNER") (list (intern_trivial_int 1) (intern_trivial_int 2))))
    (let original (intern_node (bp "OUTER") (list inner (intern_trivial_int 3))))
    (let text (cell-to-json original registry))
    (let reconstructed (json-to-cell text registry))
    (let c0 (csb-score (eq original reconstructed) 1))                      ; THE north-star check
    (let c1 (csb-score (str_eq text "{\"bp\":\"OUTER\",\"c\":[{\"bp\":\"INNER\",\"c\":[1,2]},3]}") 2))
    (let c2 (csb-score (eq (node_category reconstructed) (bp "OUTER")) 4))
    (let c3 (csb-score (eq (nth (node_children reconstructed) 1) (intern_trivial_int 3)) 8))
    (let c4 (csb-score (eq (node_category (head (node_children reconstructed))) (bp "INNER")) 16))
    (let c5 (csb-score (str_eq (cser-emit-leaf (intern_trivial_string "hi")) "\"hi\"") 32))
    (let nul (wr-make-null))
    (let nul-text (cell-to-json nul registry))
    (let nul-back (json-to-cell nul-text registry))
    (let c6 (csb-score (str_eq nul-text "null") 64))
    (let c7 (csb-score (eq nul nul-back) 128))
    (let esc-str (intern_trivial_string "he said \"hi\"\nline2\\end"))
    (let esc-text (cell-to-json esc-str registry))
    (let esc-back (json-to-cell esc-text registry))
    (let c8 (csb-score (eq esc-str esc-back) 256))
    (let composite-with-null (intern_node (bp "OUTER") (list nul esc-str)))
    (let cwn-text (cell-to-json composite-with-null registry))
    (let cwn-back (json-to-cell cwn-text registry))
    (let c9 (csb-score (eq composite-with-null cwn-back) 512))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9)))))))))
    )
    )
    (cell-serialize-band))
