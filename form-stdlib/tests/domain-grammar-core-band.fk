; domain-grammar-core-band.fk -- multi-domain grammar shell.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/domain-grammar-core.fk
;
; Expected: 268435455

(do
    (defn dgcoreb-score (ok bit) (if ok bit 0))
    (defn dgcoreb-manifest-has (name)
        (domain-grammar-core-manifest-has? name (domain-grammar-core-manifest)))
    (defn dgcoreb-reg () (dgcore-domain-registry))
    (defn dgcoreb-catalog () (dgcore-domain-catalog))
    (defn dgcoreb-prog () (dgcore-parse (dgcoreb-reg) "programming" "return 13"))
    (defn dgcoreb-nl () (dgcore-parse (dgcoreb-reg) "natural-language" "fact sun warm"))
    (defn dgcoreb-dna () (dgcore-parse (dgcoreb-reg) "dna" "gene ATG"))
    (defn dgcoreb-missing () (dgcore-parse (dgcoreb-reg) "chemistry" "atom H"))
    (defn dgcoreb-bad-prog () (dgcore-parse (dgcoreb-reg) "programming" "return x"))
    (defn dgcoreb-trailing () (dgcore-parse (dgcoreb-reg) "dna" "gene ATG trailing"))
    (defn dgcoreb-shadow () (dgcore-parse (dgcore-shadow-registry) "programming" "yield 7"))
    (defn dgcoreb-domain (name) (dgcore-find-domain (dgcoreb-catalog) name))

    (defn domain-grammar-core-band ()
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "domain-descriptor") 1) 1)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "multi-domain-registry") 1) 2)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "grammar-as-data") 1) 4)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "one-cursor") 1) 8)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "no-line-grammar") 1) 16)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "no-tokenizer") 1) 32)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "ontology-free") 1) 64)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "metadata-only-lanes") 1) 128)
        (add
            (dgcoreb-score (eq (dgcoreb-manifest-has "multi-domain-witness") 1) 256)
        (add
            (dgcoreb-score (eq (gl-count (dgcoreb-reg)) 3) 512)
        (add
            (dgcoreb-score (gl-has? (dgcoreb-reg) "programming") 1024)
        (add
            (dgcoreb-score (gl-has? (dgcoreb-reg) "natural-language") 2048)
        (add
            (dgcoreb-score (gl-has? (dgcoreb-reg) "dna") 4096)
        (add
            (dgcoreb-score
                (and (dgcore-ok? (dgcoreb-prog))
                     (str_eq (dgcore-node-tag (dgcoreb-prog)) "__prog_return__"))
                8192)
        (add
            (dgcoreb-score (str_eq (dgcore-node-slot (dgcoreb-prog) 1) "13") 16384)
        (add
            (dgcoreb-score
                (and (dgcore-ok? (dgcoreb-nl))
                     (str_eq (dgcore-node-tag (dgcoreb-nl)) "__nl_fact__"))
                32768)
        (add
            (dgcoreb-score
                (and (str_eq (dgcore-node-slot (dgcoreb-nl) 1) "sun")
                     (str_eq (dgcore-node-slot (dgcoreb-nl) 2) "warm"))
                65536)
        (add
            (dgcoreb-score
                (and (dgcore-ok? (dgcoreb-dna))
                     (str_eq (dgcore-node-tag (dgcoreb-dna)) "__dna_gene__"))
                131072)
        (add
            (dgcoreb-score (str_eq (dgcore-node-slot (dgcoreb-dna) 1) "ATG") 262144)
        (add
            (dgcoreb-score (not (gl-ok? (dgcoreb-missing))) 524288)
        (add
            (dgcoreb-score (not (gl-ok? (dgcoreb-bad-prog))) 1048576)
        (add
            (dgcoreb-score (not (gl-ok? (dgcoreb-trailing))) 2097152)
        (add
            (dgcoreb-score
                (and (not (str_eq (g-start (dgcore-domain-grammar (dgcoreb-domain "programming")))
                                  (g-start (dgcore-domain-grammar (dgcoreb-domain "natural-language")))))
                     (not (str_eq (g-start (dgcore-domain-grammar (dgcoreb-domain "natural-language")))
                                  (g-start (dgcore-domain-grammar (dgcoreb-domain "dna"))))))
                4194304)
        (add
            (dgcoreb-score
                (and (not (str_eq (dgcore-node-tag (dgcoreb-prog)) (dgcore-node-tag (dgcoreb-nl))))
                     (not (str_eq (dgcore-node-tag (dgcoreb-nl)) (dgcore-node-tag (dgcoreb-dna)))))
                8388608)
        (add
            (dgcoreb-score
                (and (not (str_eq (dgcore-domain-family (dgcoreb-domain "programming"))
                                  (dgcore-domain-family (dgcoreb-domain "natural-language"))))
                     (not (str_eq (dgcore-domain-family (dgcoreb-domain "natural-language"))
                                  (dgcore-domain-family (dgcoreb-domain "dna")))))
                16777216)
        (add
            (dgcoreb-score
                (not (str_eq (dgcore-domain-evidence-lane (dgcoreb-domain "programming"))
                             (dgcore-domain-evidence-lane (dgcoreb-domain "dna"))))
                33554432)
        (add
            (dgcoreb-score
                (not (str_eq (dgcore-domain-residue-policy (dgcoreb-domain "natural-language"))
                             (dgcore-domain-residue-policy (dgcoreb-domain "dna"))))
                67108864)
            (dgcoreb-score
                (and (dgcore-ok? (dgcoreb-shadow))
                     (str_eq (dgcore-node-tag (dgcoreb-shadow)) "__prog_yield__"))
                134217728)))))))))))))))))))))))))))))

    (domain-grammar-core-band))
