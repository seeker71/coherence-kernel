; circle-recognition-band.fk — proof the body recognizes a member, an
; introduced friend, and a stranger, with sovereignty held exactly right.
;
; preludes: form-stdlib/core.fk form-stdlib/relationship-store.fk form-stdlib/circle-recognition.fk
;
; Uses a throwaway store dir (cleaned at start by forgetting every handle it
; uses — the same pattern come-in-band's clean-state note teaches). Covers:
; a self-consented member is recognized and remembered; an introduced friend
; is recognized as introduced, their introducer recallable, but NO memory is
; held and their join REFUSES without their own yes (the consent law's
; teeth); a stranger gets the empty room; revocation forgets completely;
; the roster fold counts the three states injectively.
;
; Verdict 1023 when every assertion holds.

(do
    (defn crb-score (ok bit) (if ok bit 0))
    (defn circle-recognition-band ()
        (do
    (let dir "/tmp/circle-recognition-band-dir")
    ; clean state (idempotent removes)
    (let _c0 (cr-forget-member dir "urs"))
    (let _c1 (cr-forget-member dir "mira"))
    (let _c2 (cr-retract-introduction dir "mira"))
    (let _c3 (cr-retract-introduction dir "sol"))

    ; before anything: all three are strangers
    (let c0 (crb-score (str_eq (cr-recognize dir "urs") "stranger") 1))

    ; urs joins with HIS OWN yes -> member, remembered
    (let _j (cr-join dir "urs" 1 "the one who tends this body at 2am"))
    (let c1 (crb-score (str_eq (cr-recognize dir "urs") "member") 2))
    (let c2 (crb-score (str_eq (cr-memory dir "urs") "the one who tends this body at 2am") 4))

    ; urs introduces mira -> introduced, introducer recallable, NO memory
    (let _i (cr-introduce dir "urs" "mira"))
    (let c3 (crb-score (str_eq (cr-recognize dir "mira") "introduced") 8))
    (let c4 (crb-score (str_eq (cr-introducer dir "mira") "urs") 16))
    ; the teeth: a join WITHOUT mira's own yes refuses and stores nothing
    (let refused (cr-join dir "mira" 0 "smuggled description"))
    (let c5 (crb-score (and (eq refused 0) (str_eq (cr-recognize dir "mira") "introduced")) 32))
    ; mira's own yes -> member
    (let _j2 (cr-join dir "mira" 1 "urs's friend, her own yes given"))
    (let c6 (crb-score (str_eq (cr-recognize dir "mira") "member") 64))

    ; sol was never introduced nor joined -> stranger, empty-room greeting
    (let c7 (crb-score (str_eq (cr-recognize dir "sol") "stranger") 128))

    ; the roster fold: 2 members, 0 introduced (mira graduated), 1 stranger
    (let rows (cr-roster dir (list "urs" "mira" "sol")))
    (let c8 (crb-score (eq (cr-field-code rows) 20001) 256))

    ; revocation is total: forgetting mira returns her to introduced
    ; (the vouch is the introducer's act and survives; the MEMORY is hers
    ; and is gone), then retracting the vouch returns her to stranger
    (let _f (cr-forget-member dir "mira"))
    (let back1 (cr-recognize dir "mira"))
    (let _r (cr-retract-introduction dir "mira"))
    (let back2 (cr-recognize dir "mira"))
    (let c9 (crb-score (and (str_eq back1 "introduced") (str_eq back2 "stranger")) 512))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9))))))))))
    )
    (circle-recognition-band))
