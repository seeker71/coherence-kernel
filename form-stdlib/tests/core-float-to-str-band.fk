; core-float-to-str-band.fk — proof of Form-native float_to_str, and the
; json.fk regression it fixes.
;
; preludes: form-stdlib/core.fk
;
; Scoped honestly (see the comment on float_to_str in core.fk): 6 fractional
; digits, trailing zeros trimmed, decimal notation only — not a full
; arbitrary-precision/scientific-notation %.15g replacement. Covers the
; rounding-carry edge case a naive split-then-round-the-fraction
; implementation gets wrong (2.9999999 must become "3", not garbage from an
; overflowed fractional digit string) — verified directly, not assumed,
; after an earlier version of this file produced exactly that garbage.
;
; Verdict 127 when every assertion holds.

(do
    (defn cfs-score (ok bit) (if ok bit 0))
    (defn core-float-to-str-band ()
        (do
    (let c0 (cfs-score (str_eq (float_to_str 3.14) "3.14") 1))
    (let c1 (cfs-score (str_eq (float_to_str -2.5) "-2.5") 2))
    (let c2 (cfs-score (str_eq (float_to_str 100.0) "100") 4))
    (let c3 (cfs-score (str_eq (float_to_str 0.001) "0.001") 8))
    (let c4 (cfs-score (str_eq (float_to_str 2.9999999) "3") 16))    ; the carry case
    (let c5 (cfs-score (str_eq (float_to_str 0.9999999) "1") 32))   ; carry crossing 0 -> 1
    (add c0 (add c1 (add c2 (add c3 (add c4 c5))))))
    )
    (core-float-to-str-band))
