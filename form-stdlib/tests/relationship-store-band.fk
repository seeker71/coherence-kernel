; relationship-store-band.fk — proof of the file-backed relationship store.
;
; preludes: form-stdlib/relationship-store.fk
;
; Asserts real persistence, verified within one process AND (per the receipt)
; independently confirmed to survive across separate `fkwu --src` invocations:
; remember writes a real file, known?/recall read it back exactly, an
; unremembered handle reads back unknown, and forget removes it.
;
; Verdict 31 when every assertion holds on fkwu. NOTE: not four-way — the
; minimal walkers (Go/Rust/TS) do not implement fs_mkdir/fs_exists/
; file_append_bytes/read_file/str_byte_at's host effects; witnessed on fkwu
; directly only (a real filesystem effect is not in their pure-recipe surface
; by design — see walkers/README.md).

(do
    (defn rsb-score (ok bit) (if ok bit 0))
    (defn relationship-store-band (dir)
        (do
    (let c0 (rsb-score (eq (rs-known? dir "ghost") 0) 1))
    (rs-remember dir "urs" "warm, technical+precise")
    (let c1 (rsb-score (eq (rs-known? dir "urs") 1) 2))
    (let c2 (rsb-score (str_eq (rs-recall dir "urs") "warm, technical+precise") 4))
    (let c3 (rsb-score (eq (rs-known? dir "ghost") 0) 8))
    (rs-forget dir "urs")
    (let c4 (rsb-score (eq (rs-known? dir "urs") 0) 16))
    (add c0 (add c1 (add c2 (add c3 c4)))))
    )
    (relationship-store-band "/tmp/relationship-store-band-dir"))
