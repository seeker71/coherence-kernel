; source-compiler-multi-dialect-band.fk - one source carries several DSL sections
;
; Updated for the Recipe-emit path (a12b8f71, 7abdf048): each section
; lowers to a sibling .fkb plus a one-line walk_recipe_here driver.
; The old assertions looked for inlined-text markers ("python-bmf-rules",
; "go-emit-var-int", etc.) — those bindings now live inside the .fkb
; sidecars. The new assertions verify that the source-compiler emitted
; one driver line per section and wrote the corresponding sidecar to
; disk with non-zero size.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/bml.fk form-stdlib/source-compiler.fk

(do
    (let source
        (str_concat
        (str_concat "section " "[python.bmf] {
  assign-int ::= $name:name \"=\" $value:int => pybmf-emit-assign-int <= pybmf-source-assign-int;
}
")
        (str_concat
        (str_concat "section " "[go.bmf] {
  var-int ::= \"var\" $name:name \"=\" $value:int => go-emit-var-int <= go-source-var-int;
}
")
        (str_concat
        (str_concat "section " "[form.bml] {
  let score = add(40, 2)
  score
}
")
        (str_concat "section " "[natural.bmf] {
  fact-is ::= $subject:name \"is\" $value:int \".\" => natural-emit-fact-int <= natural-source-fact-is;
  fact-id-adalah ::= $subject:name \"adalah\" $value:int \".\" => natural-emit-fact-int <= natural-source-fact-id-adalah;
}
")))))

    (let out-path (str_concat (temp_dir) "/form-test-multi-dialect"))
    (let compiled (form-source-compile-text source out-path))

    (sum
        (list
            (if (fsc-contains? compiled "walk_recipe_here") 10 0)
            (if (fsc-contains? compiled ".python.bmf.fkb") 20 0)
            (if (fsc-contains? compiled ".go.bmf.fkb") 30 0)
            (if (fsc-contains? compiled ".form.bml.fkb") 40 0)
            (if (fsc-contains? compiled ".natural.bmf.fkb") 50 0)
            (if (gt (file_size (str_concat out-path ".python.bmf.fkb")) 0) 60 0)
            (if (gt (file_size (str_concat out-path ".go.bmf.fkb")) 0) 70 0)
            (if (gt (file_size (str_concat out-path ".form.bml.fkb")) 0) 80 0)
            (if (gt (file_size (str_concat out-path ".natural.bmf.fkb")) 0) 90 0))))
