; typed-literal-carrier-band.fk -- Layer 8h2 typed literal NodeID wrapper witness.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/typed-literal-carrier.fk
;
; Expected: 8388607

(do
    (defn tlitb-score (ok bit) (if ok bit 0))
    (defn tlitb-manifest-has (name)
        (typed-literal-carrier-manifest-has? name (typed-literal-carrier-manifest)))
    (defn tlitb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn tlitb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn tlitb-int7 ()
        (do
            (let loaded-string (tlit-string "7"))
            (tlit-int 7)))
    (defn tlitb-wide-int () (tlit-int 2147483648))
    (defn tlitb-string () (tlit-string "seven"))
    (defn tlitb-nested ()
        (tlit-list
            (list
                (tlitb-int7)
                (tlitb-string)
                (tlit-list (list (tlit-int 8))))))
    (defn tlitb-wrong-category ()
        (intern_node (tlit-string-bp) (list (intern_trivial_int 7))))
    (defn tlitb-wrong-arity ()
        (intern_node (tlit-int-bp)
            (list (intern_trivial_int 7) (intern_trivial_int 8))))
    (defn tlitb-wrong-child-type ()
        (intern_node (tlit-int-bp) (list (intern_trivial_string "7"))))
    (defn tlitb-invalid-list-child ()
        (tlit-list (list (intern_trivial_int 7))))

    (defn tlitb-bit-manifest ()
        (tlitb-score
            (and (eq (tlitb-manifest-has "typed-int-wrapper") 1)
            (and (eq (tlitb-manifest-has "typed-string-wrapper") 1)
            (and (eq (tlitb-manifest-has "typed-list-wrapper") 1)
            (and (eq (tlitb-manifest-has "registered-blueprint-categories") 1)
            (and (eq (tlitb-manifest-has "trivial-child-node-types") 1)
            (and (eq (tlitb-manifest-has "recursive-list-validation") 1)
            (and (eq (tlitb-manifest-has "sibling-exact-node-id-guard") 1)
            (and (eq (tlitb-manifest-has "direct-fkwu-category-shape-fallback") 1)
            (and (eq (tlitb-manifest-has "direct-fkwu-raw-negative-nodeid-alias-floor") 1)
            (and (eq (tlitb-manifest-has "wide-int-child-type-admitted") 1)
            (and (eq (tlitb-manifest-has "total-sentinel-accessors") 1)
            (and (eq (tlitb-manifest-has "does-not-change-pirc-admission") 1)
            (and (eq (tlitb-manifest-has "no-parser") 1)
            (and (eq (tlitb-manifest-has "no-form-binary-io") 1)
            (and (eq (tlitb-manifest-has "no-runtime-load-call") 1)
                 (eq (tlitb-manifest-has "no-c-seed-growth") 1))))))))))))))))
            1))
    (defn tlitb-bit-registered-bp ()
        (tlitb-score
            (and (node_eq (tlit-int-bp) (make_nodeid 8 45 6 50))
            (and (node_eq (tlit-string-bp) (make_nodeid 8 45 6 51))
                 (node_eq (tlit-list-bp) (make_nodeid 8 45 6 52))))
            2))
    (defn tlitb-bit-exact-kind-floor ()
        (tlitb-score (tlit-exact-kind-floor?) 4))
    (defn tlitb-bit-int-small ()
        (do
            (let n (tlitb-int7))
            (let child (head (node_children n)))
            (tlitb-score
                (and (tlit-int? n)
                (and (tlit? n)
                (and (node_eq (node_category n) (tlit-int-bp))
                (and (eq (len (node_children n)) 1)
                (and (eq (node_type child) 1)
                     (eq (tlit-int-value n) 7))))))
                8)))
    (defn tlitb-bit-int-wide ()
        (do
            (let n (tlitb-wide-int))
            (tlitb-score
                (and (tlit-int? n)
                     (tlit-int-child-type? (head (node_children n))))
                16)))
    (defn tlitb-bit-string ()
        (do
            (let s (tlitb-string))
            (let child (head (node_children s)))
            (tlitb-score
                (and (tlit-string? s)
                (and (tlit? s)
                (and (node_eq (node_category s) (tlit-string-bp))
                (and (eq (len (node_children s)) 1)
                (and (eq (node_type child) 2)
                     (str_eq (tlit-string-value s) "seven"))))))
                32)))
    (defn tlitb-bit-list ()
        (do
            (let xs (tlit-list (list (tlit-int 1) (tlit-string "a"))))
            (tlitb-score
                (and (tlit-list? xs)
                (and (tlit? xs)
                     (eq (len (tlit-list-items xs)) 2)))
                64)))
    (defn tlitb-bit-nested ()
        (do
            (let xs (tlitb-nested))
            (let items (tlit-list-items xs))
            (let inner (nth items 2))
            (tlitb-score
                (and (tlit-list? xs)
                (and (eq (tlit-int-value (nth items 0)) 7)
                (and (str_eq (tlit-string-value (nth items 1)) "seven")
                (and (tlit-list? inner)
                     (eq (tlit-int-value (head (tlit-list-items inner))) 8)))))
                128)))
    (defn tlitb-bit-accessors ()
        (do
            (let xs (tlitb-nested))
            (tlitb-score
                (and (eq (tlit-int-value (head (tlit-list-items xs))) 7)
                (and (str_eq (tlit-string-value (nth (tlit-list-items xs) 1)) "seven")
                     (eq (len (tlit-list-items xs)) 3)))
                256)))
    (defn tlitb-bit-wrong-category ()
        (tlitb-score
            (and (not (tlit-int? (tlitb-wrong-category)))
            (and (not (tlit-string? (tlitb-wrong-category)))
                 (not (tlit? (tlitb-wrong-category)))))
            512))
    (defn tlitb-bit-wrong-arity ()
        (tlitb-score
            (and (not (tlit-int? (tlitb-wrong-arity)))
                 (not (tlit? (tlitb-wrong-arity))))
            1024))
    (defn tlitb-bit-wrong-child-type ()
        (tlitb-score
            (and (not (tlit-int? (tlitb-wrong-child-type)))
                 (not (tlit? (tlitb-wrong-child-type))))
            2048))
    (defn tlitb-bit-invalid-list-child ()
        (tlitb-score
            (and (not (tlit-list? (tlitb-invalid-list-child)))
                 (not (tlit? (tlitb-invalid-list-child))))
            4096))
    (defn tlitb-bit-raw-values-reject-in-exact-siblings ()
        (tlitb-score
            (and (not (tlit? 7))
            (and (not (tlit? -7))
            (and (not (tlit? "7"))
                 (not (tlit? (list 1 2))))))
            8192))
    (defn tlitb-bit-total-sentinel-accessors ()
        (tlitb-score
            (and (eq (tlit-int-value (tlitb-wrong-child-type)) 0)
            (and (str_eq (tlit-string-value (tlitb-wrong-category)) "")
                 (eq (len (tlit-list-items (tlitb-wrong-category))) 0)))
            16384))
    (defn tlitb-bit-version ()
        (tlitb-score (str_eq (tlit-version) "typed-literal-carrier-v1") 32768))
    (defn tlitb-bit-child-type-helper ()
        (tlitb-score
            (and (tlit-int-child-type? (intern_trivial_int 7))
            (and (tlit-int-child-type? (intern_trivial_int 2147483648))
            (and (tlit-string-child-type? (intern_trivial_string "x"))
            (and (not (tlit-int-child-type? (intern_trivial_string "x")))
            (and (not (tlit-int-child-type? 7))
                 (not (tlit-string-child-type? "x")))))))
            65536))
    (defn tlitb-bit-stable-after-string-literals ()
        (do
            (let s1 (tlit-string "loaded-before"))
            (let s2 (tlit-string "7"))
            (let n (tlit-int 7))
            (tlitb-score
                (and (tlit-string? s1)
                (and (tlit-string? s2)
                (and (tlit-int? n)
                     (eq (tlit-int-value n) 7))))
                131072)))
    (defn tlitb-bit-invalid-list-items-empty ()
        (tlitb-score (eq (len (tlit-list-items (tlitb-invalid-list-child))) 0) 262144))
    (defn tlitb-bit-static-and-mirror ()
        (do
            (let text (tlitb-read-file-any "form/form-stdlib/typed-literal-carrier.fk"
                                           "../form/form-stdlib/typed-literal-carrier.fk"))
            (let grammar (tlitb-read-file-any "grammars/typed-literal-carrier.fk"
                                              "../grammars/typed-literal-carrier.fk"))
            (let registry (tlitb-read-file-any "form/form-stdlib/blueprint-registry.json"
                                               "../form/form-stdlib/blueprint-registry.json"))
            (tlitb-score
                (and (str_eq text grammar)
                (and (tlitb-has? registry "TYPED-LITERAL-INT")
                (and (tlitb-has? registry "TYPED-LITERAL-STRING")
                (and (tlitb-has? registry "TYPED-LITERAL-LIST")
                (and (not (tlitb-has? text "pirc-carrier-from-envelope"))
                (and (not (tlitb-has? text "write_form_binary"))
                (and (not (tlitb-has? text "read_form_binary"))
                (and (not (tlitb-has? text "g-match-rule"))
                (and (not (tlitb-has? text "cursor-str"))
                (and (not (tlitb-has? text "walk_recipe"))
                (and (not (tlitb-has? text "fk_run"))
                (and (not (tlitb-has? text "dlopen"))
                     (not (tlitb-has? text "dlsym"))))))))))))))
                524288)))
    (defn tlitb-bit-nodeid-guard ()
        (tlitb-score
            (and (tlit-nodeid-carrierable? (tlitb-int7))
            (and (not (tlit-nodeid-carrierable? 7))
            (and (not (tlit-nodeid-carrierable? "7"))
                 (not (tlit-nodeid-carrierable? (list 1 2))))))
            1048576))
    (defn tlitb-bit-floor-named ()
        (tlitb-score
            (and (eq (tlitb-manifest-has "direct-fkwu-raw-negative-nodeid-alias-floor") 1)
                 (eq (tlitb-manifest-has "does-not-change-pirc-admission") 1))
            2097152))
    (defn tlitb-bit-no-parser-io-runtime ()
        (tlitb-score
            (and (eq (tlitb-manifest-has "no-parser") 1)
            (and (eq (tlitb-manifest-has "no-form-binary-io") 1)
            (and (eq (tlitb-manifest-has "no-runtime-load-call") 1)
                 (eq (tlitb-manifest-has "no-c-seed-growth") 1))))
            4194304))

    (defn typed-literal-carrier-band ()
        (sum (list
            (tlitb-bit-manifest)
            (tlitb-bit-registered-bp)
            (tlitb-bit-exact-kind-floor)
            (tlitb-bit-int-small)
            (tlitb-bit-int-wide)
            (tlitb-bit-string)
            (tlitb-bit-list)
            (tlitb-bit-nested)
            (tlitb-bit-accessors)
            (tlitb-bit-wrong-category)
            (tlitb-bit-wrong-arity)
            (tlitb-bit-wrong-child-type)
            (tlitb-bit-invalid-list-child)
            (tlitb-bit-raw-values-reject-in-exact-siblings)
            (tlitb-bit-total-sentinel-accessors)
            (tlitb-bit-version)
            (tlitb-bit-child-type-helper)
            (tlitb-bit-stable-after-string-literals)
            (tlitb-bit-invalid-list-items-empty)
            (tlitb-bit-static-and-mirror)
            (tlitb-bit-nodeid-guard)
            (tlitb-bit-floor-named)
            (tlitb-bit-no-parser-io-runtime))))

    (typed-literal-carrier-band))
