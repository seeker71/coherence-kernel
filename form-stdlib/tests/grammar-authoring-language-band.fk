; grammar-authoring-language-band.fk -- author one domain grammar without Form cells.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/domain-grammar-core.fk form-stdlib/grammar-authoring-language.fk
;
; Expected: 134217727

(do
    (defn galb-score (ok bit) (if ok bit 0))
    (defn galb-manifest-has (name)
        (grammar-authoring-language-manifest-has? name (grammar-authoring-language-manifest)))
    (defn galb-source ()
        "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { return value digit -> prog-return }")
    (defn galb-loose-source ()
        "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe {   return   value   digit   ->   prog-return   }")
    (defn galb-decl () (gal-parse (galb-source)))
    (defn galb-lower () (gal-lower-domain (galb-decl)))
    (defn galb-reg () (gal-register-lowered (galb-decl)))
    (defn galb-authored-result () (dgcore-parse (galb-reg) "programming" "return 13"))
    (defn galb-hand-reg () (gl-register (gl-empty) "programming" (dgcore-programming-grammar)))
    (defn galb-hand-result () (dgcore-parse (galb-hand-reg) "programming" "return 13"))
    (defn galb-authored-bad () (dgcore-parse (galb-reg) "programming" "return x"))
    (defn galb-hand-bad () (dgcore-parse (galb-hand-reg) "programming" "return x"))
    (defn galb-trailing-decl () (gal-parse (str_concat (galb-source) " trailing")))
    (defn galb-malformed-decl ()
        (gal-parse "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { return value digit prog-return }"))

    (defn grammar-authoring-language-band ()
        (add
            (galb-score (eq (galb-manifest-has "scannerless") 1) 1)
        (add
            (galb-score (eq (galb-manifest-has "bmf-cursor-grammar") 1) 2)
        (add
            (galb-score (eq (galb-manifest-has "no-line-grammar") 1) 4)
        (add
            (galb-score (eq (galb-manifest-has "not-s-expression-surface") 1) 8)
        (add
            (galb-score (eq (galb-manifest-has "not-form-cell-authoring") 1) 16)
        (add
            (galb-score (eq (galb-manifest-has "single-domain-decl") 1) 32)
        (add
            (galb-score (eq (galb-manifest-has "single-rule-body") 1) 64)
        (add
            (galb-score (eq (galb-manifest-has "metadata-only-lanes") 1) 128)
        (add
            (galb-score (eq (galb-manifest-has "grammar-value-lowering") 1) 256)
        (add
            (galb-score (gal-ok? (galb-decl)) 512)
        (add
            (galb-score (str_eq (gal-domain-name (galb-decl)) "programming") 1024)
        (add
            (galb-score (str_eq (gal-family (galb-decl)) "programming-language") 2048)
        (add
            (galb-score (str_eq (gal-semantic-lane (galb-decl)) "semantic-stdlib") 4096)
        (add
            (galb-score (str_eq (gal-evidence-lane (galb-decl)) "compiler-proof") 8192)
        (add
            (galb-score (str_eq (gal-residue-policy (galb-decl)) "syntax-semantic-residue") 16384)
        (add
            (galb-score (str_eq (gal-lower-target (galb-decl)) "form-recipe") 32768)
        (add
            (galb-score
                (and (str_eq (gal-rule-literal (galb-decl)) "return")
                     (and (str_eq (gal-rule-capture (galb-decl)) "value")
                          (and (str_eq (gal-rule-class (galb-decl)) "digit")
                               (str_eq (gal-emit-slug (galb-decl)) "prog-return"))))
                65536)
        (add
            (galb-score (str_eq (dgcore-domain-kind (galb-lower)) "domain-grammar") 131072)
        (add
            (galb-score (str_eq (g-start (dgcore-domain-grammar (galb-lower))) "return") 262144)
        (add
            (galb-score
                (and (dgcore-ok? (galb-authored-result))
                     (str_eq (dgcore-node-tag (galb-authored-result)) "__prog_return__"))
                524288)
        (add
            (galb-score (str_eq (dgcore-node-slot (galb-authored-result) 1) "13") 1048576)
        (add
            (galb-score
                (and (str_eq (g-start (dgcore-domain-grammar (galb-lower))) (g-start (dgcore-programming-grammar)))
                     (and (str_eq (dgcore-node-tag (galb-authored-result)) (dgcore-node-tag (galb-hand-result)))
                          (and (str_eq (dgcore-node-slot (galb-authored-result) 1) (dgcore-node-slot (galb-hand-result) 1))
                               (and (not (dgcore-ok? (galb-authored-bad)))
                                    (not (dgcore-ok? (galb-hand-bad)))))))
                2097152)
        (add
            (galb-score (not (gal-ok? (galb-trailing-decl))) 4194304)
        (add
            (galb-score (not (gal-ok? (galb-malformed-decl))) 8388608)
        (add
            (galb-score
                (and (eq (gl-count (galb-reg)) 1)
                     (gl-has? (galb-reg) "programming"))
                16777216)
        (add
            (galb-score (gal-ok? (gal-parse (galb-loose-source))) 33554432)
            (galb-score
                (and (str_eq (dgcore-domain-semantic-lane (galb-lower)) (gal-semantic-lane (galb-decl)))
                     (and (str_eq (dgcore-domain-evidence-lane (galb-lower)) (gal-evidence-lane (galb-decl)))
                          (and (str_eq (dgcore-domain-residue-policy (galb-lower)) (gal-residue-policy (galb-decl)))
                               (str_eq (dgcore-domain-lower-target (galb-lower)) (gal-lower-target (galb-decl))))))
                67108864))))))))))))))))))))))))))))

    (grammar-authoring-language-band))
