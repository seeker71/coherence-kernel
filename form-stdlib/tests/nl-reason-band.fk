; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/string-case.fk form-stdlib/nl-lexicon-data.fk form-stdlib/nl-translate.fk form-stdlib/forward-chaining.fk form-stdlib/derivation.fk form-stdlib/nl-reason.fk
;
; Reason about natural language, end to end — the keystone, pinned. A real English sentence is parsed
; by the real translator, reasoned over by the real reasoning blocks, and the conclusion decoded back
; to English with its proof. The inference is true in this body's own ontology:
;
;   FACT (English): "the body is cell"          -> property(body, cell),  attribute atom = 4 (cell)
;   RULE:            a cell is a recipe          -> cell(4) -> recipe(5)
;   DERIVE:          "the body is recipe"        -> entailed, proof depth 2 (recipe <- cell)
;
; Nothing is hand-fed: the subject and attribute are READ from the parse, the conclusion is DERIVED,
; and the answer sentence is DECODED. Verdict 255 when every step lands.
(do
    (let fact (norm-en (g-parse (nl-en) "the body is cell")))   ; REAL parse: surface -> pivot node
    (let subj (nlr-subj-sym fact))                              ; "n3" (body), read from the parse
    (let fact-atom (nlr-attr-atom fact))                        ; 4 (cell), read from the parse
    (let RECIPE 5)                                              ; the conclusion proposition (recipe)
    (let facts (list fact-atom))                                ; what the sentence asserts
    (let rules (list (list (list fact-atom) RECIPE)))           ; the rule: cell -> recipe
    (let proof (pf-derive RECIPE facts rules))                  ; REAL reasoning: derive + prove
    (let answer (nlr-answer subj RECIPE))                       ; REAL decode: conclusion -> English

    (let c0 (if (str_eq subj "n3") 1 0))                        ; subject parsed = body
    (let c1 (if (eq fact-atom 4) 2 0))                          ; attribute parsed = cell (atom 4)
    (let c2 (if (eq (fwd-entails? facts rules RECIPE) 1) 4 0))  ; "the body is recipe" is ENTAILED
    (let c3 (if (eq (pf-status proof) 2) 8 0))                  ; ...by a RULE (derived, not given)
    (let c4 (if (eq (pf-depth proof) 2) 16 0))                  ; proof runs 2 deep: recipe <- cell
    (let c5 (if (eq (pf-goal proof) RECIPE) 32 0))              ; the proof concludes recipe
    (let c6 (if (str_eq answer "the body is recipe") 64 0))     ; THE NL ANSWER, decoded from the proof
    (let c7 (if (str_eq (nlt-c->en (nlr-atom->sym fact-atom)) "cell") 128 0)) ; round-trip sanity: atom->cell

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
