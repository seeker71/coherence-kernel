; reception-consent-band.fk — proof of the reception-consent policy.
;
; preludes: form-stdlib/reception-consent.fk
;
; Asserts the universal rule: exposure-bearing consents (findable, email,
; recorded-relation, enrolled, relationship-memory/"remember me") rest CLOSED
; in every facet, including the contributor door; share-name rests OPEN only
; at the web-begin facet — everywhere else, and every other consent, rests
; CLOSED (opt-in). "Being remembered" is never a silent default.
;
; Verdict 255 when every assertion holds across sibling kernels and fkwu.

(do
    (defn rc-band-score (ok bit) (if ok bit 0))
    (defn reception-consent-band ()
        (do
    (let c0 (rc-band-score (eq (rc-resting (f-web-begin) (c-share-name)) (rc-open)) 1))
    (let c1 (rc-band-score (eq (rc-resting (f-web-begin) (c-findable)) (rc-closed)) 2))
    (let c2 (rc-band-score (eq (rc-resting (f-body-arrival) (c-relationship-mem)) (rc-closed)) 4))
    (let c3 (rc-band-score (eq (rc-resting (f-agent) (c-recorded-relation)) (rc-closed)) 8))
    (let c4 (rc-band-score (eq (rc-resting (f-channel) (c-enrolled)) (rc-closed)) 16))
    (let c5 (rc-band-score (eq (rc-resting (f-web-interest) (c-share-location)) (rc-closed)) 32))
    (let c6 (rc-band-score (eq (rc-exposure? (c-share-name)) false) 64))
    (let c7 (rc-band-score (eq (rc-exposure? (c-relationship-mem)) true) 128))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))
    (reception-consent-band))
