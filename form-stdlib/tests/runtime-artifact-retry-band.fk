; runtime-artifact-retry-band.fk -- Layer 9d fallback re-selection witness.
;
; Expected: 2147483647
;
; This band proves retry/re-selection rows over 9c outcome rows only. It does
; not load or walk `.fkb`, load or call `.dylib`, execute native bytes, generate
; observations, run fallbacks, loop retries, decide admission, or grow the C
; seed.
;
; preludes: form/form-stdlib/core.fk
;           form/form-stdlib/source-artifact-cache.fk
;           form/form-stdlib/source-artifact-descriptor.fk
;           form/form-stdlib/runtime-artifact-plan.fk
;           form/form-stdlib/runtime-artifact-selector.fk
;           form/form-stdlib/runtime-artifact-outcome.fk
;           form/form-stdlib/runtime-artifact-retry.fk

(do
    (defn rarb-score (ok bit) (if ok bit 0))
    (defn rarb-manifest-has (name)
        (runtime-artifact-retry-manifest-has? name (runtime-artifact-retry-manifest)))

    (defn rarb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn rarb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn rarb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn rarb-native-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (rarb-source) (rarb-fkb-fresh) (rarb-dylib-fresh))))
    (defn rarb-fkb-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (rarb-source) (rarb-fkb-fresh) (sad-no-artifact))))
    (defn rarb-compile-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (rarb-source) (sad-no-artifact) (sad-no-artifact))))
    (defn rarb-outcome (selection status)
        (rao-outcome-from-selection-observation selection
            (rao-run-observation (ras-selection-selected selection) status "detail" 7)))
    (defn rarb-native-soft-outcome ()
        (rarb-outcome (rarb-native-selection) (rao-obs-loader-missing)))
    (defn rarb-fkb-soft-outcome ()
        (rarb-outcome (rarb-fkb-selection) (rao-obs-error)))
    (defn rarb-compile-soft-outcome ()
        (rarb-outcome (rarb-compile-selection) (rao-obs-error)))
    (defn rarb-native-ok-outcome ()
        (rarb-outcome (rarb-native-selection) (rao-obs-ok)))
    (defn rarb-native-pending-outcome ()
        (rao-outcome-from-selection (rarb-native-selection)))
    (defn rarb-native-hard-outcome (status)
        (rarb-outcome (rarb-native-selection) status))
    (defn rarb-status? (r status) (str_eq (rar-retry-status r) status))
    (defn rarb-reason? (r reason) (str_eq (rar-retry-reason r) reason))
    (defn rarb-next-selected? (r action)
        (str_eq (ras-selection-selected (rar-retry-next-selection r)) action))
    (defn rarb-next-route? (r route)
        (eq (ras-selection-route (rar-retry-next-selection r)) route))
    (defn rarb-next-fallback? (r action)
        (str_eq (ras-selection-fallback (rar-retry-next-selection r)) action))
    (defn rarb-next-reason? (r reason)
        (str_eq (ras-selection-reason (rar-retry-next-selection r)) reason))
    (defn rarb-no-next? (r)
        (rar-no-selection? (rar-retry-next-selection r)))

    (defn rarb-bit-manifest-1 ()
        (sum (list
            (rarb-score (eq (rarb-manifest-has "retry-face-not-execution") 1) 1)
            (rarb-score (eq (rarb-manifest-has "consumes-rao-outcome-only") 1) 2)
            (rarb-score (eq (rarb-manifest-has "total-retry-row") 1) 4)
            (rarb-score (eq (rarb-manifest-has "fallback-available-only-retries") 1) 8)
            (rarb-score (eq (rarb-manifest-has "hard-outcomes-do-not-retry") 1) 16)
            (rarb-score (eq (rarb-manifest-has "synthetic-fallback-selection-not-from-plan") 1) 32)
            (rarb-score (eq (rarb-manifest-has "known-pairing-table-only") 1) 64)
            (rarb-score (eq (rarb-manifest-has "retry-row-carries-source-outcome") 1) 128))))

    (defn rarb-bit-manifest-2 ()
        (sum (list
            (rarb-score (eq (rarb-manifest-has "no-descriptor-consumption") 1) 256)
            (rarb-score (eq (rarb-manifest-has "no-rap-plan-consumption") 1) 512)
            (rarb-score (eq (rarb-manifest-has "no-observation-generation") 1) 1024)
            (rarb-score (eq (rarb-manifest-has "no-runtime-load-walk-call-exec") 1) 2048)
            (rarb-score (eq (rarb-manifest-has "no-fallback-execution-or-retry-loop") 1) 4096)
            (rarb-score (eq (rarb-manifest-has "no-admission-policy") 1) 8192)
            (rarb-score (eq (rarb-manifest-has "no-seal-proof-callable-reverify") 1) 16384)
            (rarb-score (eq (rarb-manifest-has "no-c-seed-growth-or-selector-install") 1) 32768))))

    (defn rarb-bit-complete-terminal ()
        (do
            (let r (rar-retry-from-outcome (rarb-native-ok-outcome)))
            (rarb-score
                (and (rarb-status? r (rar-status-terminal-complete))
                     (and (rarb-reason? r (rar-reason-terminal-complete))
                          (rarb-no-next? r)))
                65536)))

    (defn rarb-bit-pending-waits ()
        (do
            (let r (rar-retry-from-outcome (rarb-native-pending-outcome)))
            (rarb-score
                (and (rarb-status? r (rar-status-waiting-observation))
                     (and (rarb-reason? r (rar-reason-waiting-observation))
                          (rarb-no-next? r)))
                131072)))

    (defn rarb-bit-terminal-propagates ()
        (do
            (let i (rar-retry-from-outcome (rao-outcome-from-selection (ras-selection (sad-route-invalid) (rap-act-investigate) (rap-act-none) (ras-status-investigate) 0 0 (ras-reason-upstream-investigate)))))
            (let f (rar-retry-from-outcome (rao-outcome-from-selection (ras-selection (sad-route-invalid) (rap-act-none) (rap-act-none) (ras-status-refused) 0 0 (ras-reason-malformed-plan)))))
            (rarb-score
                (and (rarb-status? i (rar-status-terminal-investigate))
                     (and (rarb-status? f (rar-status-terminal-refused))
                          (and (rarb-no-next? i) (rarb-no-next? f))))
                262144)))

    (defn rarb-hard-no-retry? ()
        (do
            (let a (rar-retry-from-outcome (rarb-native-hard-outcome (rao-obs-oom-killed))))
            (let b (rar-retry-from-outcome (rarb-native-hard-outcome (rao-obs-killed))))
            (let c (rar-retry-from-outcome (rarb-native-hard-outcome (rao-obs-stalled))))
            (let d (rar-retry-from-outcome (rarb-native-hard-outcome (rao-obs-timeout))))
            (let e (rar-retry-from-outcome (rarb-native-hard-outcome (rao-obs-wrong-value))))
            (and (rarb-status? a (rar-status-terminal-investigate))
                 (and (rarb-status? b (rar-status-terminal-investigate))
                      (and (rarb-status? c (rar-status-terminal-investigate))
                           (and (rarb-status? d (rar-status-terminal-investigate))
                                (and (rarb-status? e (rar-status-terminal-investigate))
                                     (and (rarb-no-next? a) (rarb-no-next? e)))))))))
    (defn rarb-bit-hard-outcomes-do-not-retry ()
        (rarb-score (rarb-hard-no-retry?) 524288))

    (defn rarb-bit-native-soft-retry ()
        (do
            (let r (rar-retry-from-outcome (rarb-native-soft-outcome)))
            (let n (rar-retry-next-selection r))
            (rarb-score
                (and (rarb-status? r (rar-status-retry-ready))
                     (and (rarb-reason? r (rar-reason-fallback-reselected-program-image))
                          (and (rarb-next-route? r (sac-run-fkb))
                               (and (rarb-next-selected? r (rap-act-run-program-image))
                                    (and (rarb-next-fallback? r (rap-act-compile-source))
                                         (and (eq (ras-selection-skip-parse n) 1)
                                              (and (eq (ras-selection-skip-recompute n) 0)
                                                   (rarb-next-reason? r (ras-reason-selected-program-image)))))))))
                1048576)))

    (defn rarb-bit-fkb-soft-retry ()
        (do
            (let r (rar-retry-from-outcome (rarb-fkb-soft-outcome)))
            (let n (rar-retry-next-selection r))
            (rarb-score
                (and (rarb-status? r (rar-status-retry-ready))
                     (and (rarb-reason? r (rar-reason-fallback-reselected-compile-source))
                          (and (rarb-next-route? r (sac-run-source-compile))
                               (and (rarb-next-selected? r (rap-act-compile-source))
                                    (and (rarb-next-fallback? r (rap-act-none))
                                         (and (eq (ras-selection-skip-parse n) 0)
                                              (and (eq (ras-selection-skip-recompute n) 0)
                                                   (rarb-next-reason? r (ras-reason-selected-compile-source)))))))))
                2097152)))

    (defn rarb-bit-fallback-available-not-execution ()
        (do
            (let r (rar-retry-from-outcome (rarb-native-soft-outcome)))
            (let n (rar-retry-next-selection r))
            (rarb-score
                (and (rarb-status? r (rar-status-retry-ready))
                     (and (ras-selection? n)
                          (and (str_eq (ras-selection-status n) (ras-status-selected))
                               (not (str_eq (rar-retry-status r) (rao-status-complete))))))
                4194304)))

    (defn rarb-bit-malformed-outcome-refused ()
        (do
            (let a (rar-retry-from-outcome (list "runtime-artifact-outcome" 1)))
            (let b (rar-retry-from-outcome 3))
            (rarb-score
                (and (rarb-status? a (rar-status-refused))
                     (and (rarb-reason? a (rar-reason-malformed-outcome))
                          (and (rarb-status? b (rar-status-refused))
                               (rarb-reason? b (rar-reason-malformed-outcome)))))
                8388608)))

    (defn rarb-bit-unknown-status-investigates ()
        (do
            (let o (rao-outcome 7 (rap-act-run-native) (rap-act-run-program-image) (ras-status-selected) "surprise" (rao-obs-error) (ras-reason-selected-native) "surprise" "detail" 7))
            (let r (rar-retry-from-outcome o))
            (rarb-score
                (and (rarb-status? r (rar-status-investigate))
                     (and (rarb-reason? r (rar-reason-unknown-outcome-status))
                          (rarb-no-next? r)))
                16777216)))

    (defn rarb-bit-corrupt-fallback-available-investigates ()
        (do
            (let h (rao-outcome 7 (rap-act-run-native) (rap-act-run-program-image) (ras-status-selected) (rao-status-fallback-available) (rao-obs-oom-killed) (ras-reason-selected-native) (rao-reason-soft-failure-fallback-available) "detail" 7))
            (let m (rao-outcome 7 (rap-act-run-native) (rap-act-none) (ras-status-selected) (rao-status-fallback-available) (rao-obs-error) (ras-reason-selected-native) (rao-reason-soft-failure-fallback-available) "detail" 7))
            (let t (rao-outcome 7 (rap-act-run-native) (rap-act-run-program-image) (ras-status-investigate) (rao-status-fallback-available) (rao-obs-error) (ras-reason-upstream-investigate) (rao-reason-soft-failure-fallback-available) "detail" 7))
            (let rh (rar-retry-from-outcome h))
            (let rm (rar-retry-from-outcome m))
            (let rt (rar-retry-from-outcome t))
            (rarb-score
                (and (rarb-status? rh (rar-status-investigate))
                     (and (rarb-reason? rh (rar-reason-hard-outcome-no-retry))
                          (and (rarb-status? rm (rar-status-refused))
                               (and (rarb-status? rt (rar-status-investigate))
                                    (rarb-no-next? rh)))))
                33554432)))

    (defn rarb-bit-unknown-pairing-investigates ()
        (do
            (let o (rao-outcome 7 (rap-act-run-native) (rap-act-compile-source) (ras-status-selected) (rao-status-fallback-available) (rao-obs-error) (ras-reason-selected-native) (rao-reason-soft-failure-fallback-available) "detail" 7))
            (let e (rao-outcome 8 (rap-act-compile-source) (rap-act-run-program-image) (ras-status-selected) (rao-status-fallback-available) (rao-obs-error) (ras-reason-selected-compile-source) (rao-reason-soft-failure-fallback-available) "detail" 7))
            (let r (rar-retry-from-outcome o))
            (let q (rar-retry-from-outcome e))
            (rarb-score
                (and (rarb-status? r (rar-status-investigate))
                     (and (rarb-reason? r (rar-reason-unknown-fallback-pairing))
                          (and (rarb-no-next? r)
                               (and (rarb-status? q (rar-status-investigate))
                                    (and (rarb-reason? q (rar-reason-unknown-fallback-pairing))
                                         (rarb-no-next? q))))))
                67108864)))

    (defn rarb-same-program-image-selection? (a b)
        (and (eq (ras-selection-route a) (ras-selection-route b))
             (and (str_eq (ras-selection-selected a) (ras-selection-selected b))
                  (and (str_eq (ras-selection-fallback a) (ras-selection-fallback b))
                       (and (str_eq (ras-selection-status a) (ras-selection-status b))
                            (and (eq (ras-selection-skip-parse a) (ras-selection-skip-parse b))
                                 (and (eq (ras-selection-skip-recompute a) (ras-selection-skip-recompute b))
                                      (str_eq (ras-selection-reason a) (ras-selection-reason b)))))))))
    (defn rarb-bit-golden-parity ()
        (do
            (let retry-fkb (rar-retry-next-selection (rar-retry-from-outcome (rarb-native-soft-outcome))))
            (let retry-compile (rar-retry-next-selection (rar-retry-from-outcome (rarb-fkb-soft-outcome))))
            (let ref-fkb (rarb-fkb-selection))
            (let ref-compile (rarb-compile-selection))
            (rarb-score
                (and (rarb-same-program-image-selection? retry-fkb ref-fkb)
                     (rarb-same-program-image-selection? retry-compile ref-compile))
                134217728)))

    (defn rarb-bit-idempotent ()
        (do
            (let o (rarb-native-soft-outcome))
            (let a (rar-retry-from-outcome o))
            (let b (rar-retry-from-outcome o))
            (rarb-score
                (and (str_eq (rar-retry-status a) (rar-retry-status b))
                     (and (str_eq (rar-retry-reason a) (rar-retry-reason b))
                          (rarb-same-program-image-selection? (rar-retry-next-selection a) (rar-retry-next-selection b))))
                268435456)))

    (defn rarb-bit-hand-built-outcome ()
        (do
            (let o (rao-outcome 7 (rap-act-run-native) (rap-act-run-program-image) (ras-status-selected) (rao-status-fallback-available) (rao-obs-error) (ras-reason-selected-native) (rao-reason-soft-failure-fallback-available) "detail" 7))
            (let r (rar-retry-from-outcome o))
            (rarb-score
                (and (rarb-status? r (rar-status-retry-ready))
                     (and (eq (rar-retry-prior-route r) 7)
                          (rarb-next-route? r (sac-run-fkb))))
                536870912)))

    (defn rarb-bit-row-shape-provenance ()
        (do
            (let r (rar-retry-from-outcome (rarb-native-soft-outcome)))
            (rarb-score
                (and (rar-retry? r)
                     (and (eq (len r) 10)
                          (and (rao-outcome? (rar-retry-source-outcome r))
                               (and (str_eq (rar-retry-prior-status r) (rao-status-fallback-available))
                                    (str_eq (rar-retry-prior-reason r) (rao-reason-soft-failure-fallback-available))))))
                1073741824)))

    (defn runtime-artifact-retry-band ()
        (sum (list
            (rarb-bit-manifest-1)
            (rarb-bit-manifest-2)
            (rarb-bit-complete-terminal)
            (rarb-bit-pending-waits)
            (rarb-bit-terminal-propagates)
            (rarb-bit-hard-outcomes-do-not-retry)
            (rarb-bit-native-soft-retry)
            (rarb-bit-fkb-soft-retry)
            (rarb-bit-fallback-available-not-execution)
            (rarb-bit-malformed-outcome-refused)
            (rarb-bit-unknown-status-investigates)
            (rarb-bit-corrupt-fallback-available-investigates)
            (rarb-bit-unknown-pairing-investigates)
            (rarb-bit-golden-parity)
            (rarb-bit-idempotent)
            (rarb-bit-hand-built-outcome)
            (rarb-bit-row-shape-provenance))))

    (runtime-artifact-retry-band))
