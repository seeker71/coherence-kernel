; tests/field-model-form-runtime-intervene-band.fk - focused BML FMF intervention proof.
;
; preludes: form-stdlib/core.fk form-stdlib/field-model-form-runtime.fk

(do
    (let field (fmfrt-lift-sequence "ATG"))
    (let observer (fmfrt-observer "bml-intervene-proof" "all-compatible"))
    (let changed (fmfrt-intervene field observer (list (fmfrt-delta "set-site" 1 "symbol" "C"))))
    (if (str_eq (fmfrt-project-sequence (fmfrt-result-field changed)) "ACG") 1 0))
