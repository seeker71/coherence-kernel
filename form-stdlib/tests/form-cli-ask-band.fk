; preludes: form-stdlib/core.fk form-stdlib/form-cli-router.fk form-stdlib/form-cli-judge.fk form-stdlib/form-cli-sufficiency.fk form-stdlib/form-freq-check.fk form-stdlib/trust-row.fk form-stdlib/form-cli-ask-gate.fk
;
; form-cli-ask-band — the ask verb's posterior gate plus independent structured
; trust result, four-way. It pins that path, grounding, frequency, and sufficiency
; are separately measured: a rented answer may be sufficient; a native answer may
; fail live grounding; unknown frequency stays unknown; only four exact yes readings
; become OBSERVED.
;
; Verdict 262143 when every claim lands:
;   1     strong posterior signals accept
;   2     weak content escalates with the content reason
;   4     empty answer retries while a retry remains
;   8     exhausted empty answer escalates with empty reason
;   16    low confidence escalates with confidence reason
;   32    explicit native terminal -> path native
;   64    explicit rented terminal -> path rented
;   128   borderline quality accepts
;   256   empty answer is unusable
;   512   local miss marker is unusable
;   1024  real text is usable
;   2048  no measured content remains 0 even for non-empty text
;   4096  grounding requires all four resolver/binding facts
;   8192  a missing persistence or answer binding blocks grounding
;   16384 full independent result is OBSERVED
;   32768 unknown frequency remains unknown and blocks observed
;   65536 rented path stays rented while sufficiency remains independently yes
;   131072 exact structured row is emitted by the kernel
(do
    (let strong (fca-ask-signals 1 1 80 60 60 1))
    (let weak (fca-ask-signals 1 1 40 60 60 1))
    (let retry-empty (fca-ask-signals 0 1 0 60 60 1))
    (let spent-empty (fca-ask-signals 0 1 0 60 60 0))
    (let low-confidence (fca-ask-signals 1 1 80 10 60 1))
    (let border (fca-ask-signals 1 1 60 60 60 1))
    (let good-ground (fca-grounding 1 1 1 1))
    (let no-live-ground (fca-grounding 1 1 0 1))
    (let no-bound-ground (fca-grounding 1 1 1 0))
    (let clear (fc-certified-form-reading 1 1))
    (let full (fca-ask-result 1 good-ground clear strong))
    (let unknown (fca-ask-result 1 good-ground (fc-unmeasured-reading) strong))
    (let rented (fca-ask-result 0 good-ground clear strong))

    (let c0  (if (eq (fca-ask-verdict strong) 0) 1 0))
    (let c1  (if (and (eq (fca-ask-verdict weak) 2) (eq (fca-ask-reason weak) 3)) 2 0))
    (let c2  (if (eq (fca-ask-verdict retry-empty) 1) 4 0))
    (let c3  (if (and (eq (fca-ask-verdict spent-empty) 2) (eq (fca-ask-reason spent-empty) 1)) 8 0))
    (let c4  (if (and (eq (fca-ask-verdict low-confidence) 2) (eq (fca-ask-reason low-confidence) 4)) 16 0))
    (let c5  (if (eq (fca-ask-path 1) 1) 32 0))
    (let c6  (if (eq (fca-ask-path 0) 0) 64 0))
    (let c7  (if (eq (fca-ask-verdict border) 0) 128 0))
    (let c8  (if (eq (fca-usable? "") 0) 256 0))
    (let c9  (if (eq (fca-usable? "[ask: local fkwu RAG index has no grounded hit]") 0) 512 0))
    (let c10 (if (eq (fca-usable? "Four.") 1) 1024 0))
    (let c11 (if (and (eq (fca-content-intrinsic "Four.") 0)
                       (eq (fca-content-intrinsic "") 0)) 2048 0))
    (let c12 (if (eq (fca-grounded? good-ground) 1) 4096 0))
    (let c13 (if (and (eq (fca-grounded? no-live-ground) 0)
                       (eq (fca-grounded? no-bound-ground) 0)) 8192 0))
    (let c14 (if (and (eq (fca-result-observed full) 1)
                       (eq (fca-result-grounded full) 1)) 16384 0))
    (let c15 (if (and (eq (fca-result-frequency unknown) 2)
                       (eq (fca-result-observed unknown) 0)) 32768 0))
    (let c16 (if (and (eq (fca-result-path rented) 0)
                       (and (eq (fca-result-sufficient rented) 1)
                            (eq (fca-result-observed rented) 0))) 65536 0))
    (let c17 (if (str_eq (fca-ask-trace-row full)
                  "trust  path:native  grounded:yes  freq:yes  freq-source:certified-form  suffic:yes  observed:yes  -> OBSERVED  decision:accept  reason:ok") 131072 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
        (add c8 (add c9 (add c10 (add c11 (add c12 (add c13 (add c14
        (add c15 (add c16 c17))))))))))))))))))
