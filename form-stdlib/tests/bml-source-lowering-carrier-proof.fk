; tests/bml-source-lowering-carrier-proof.fk
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proof-only bridge: high-level BML source owns the compiler/source-lowering
; architecture. This Form test only shows that parsed BML declarations can be
; carried as compiler-object sections until the BML compiler can bootstrap them.

(do
    (defn score-bool (actual)
        (if actual 1 0))

    (defn score-int (actual expected)
        (if (eq actual expected) 1 0))

    (defn score-gt (actual expected)
        (if (gt actual expected) 1 0))

    (defn score-str (actual expected)
        (if (nil? actual)
            0
            (if (str_eq actual expected) 1 0)))

    (defn template-body-node (template-component)
        (head (bml-template-body template-component)))

    (defn template-body-name (template-component)
        (do
            (let node (template-body-node template-component))
            (if (bml-component-kind? node "Class")
                (bml-class-name node)
                (if (bml-component-kind? node "Interface")
                    (bml-interface-name node)
                    ""))))

    (defn find-template-body (templates name)
        (if (nil? templates)
            (empty)
            (if (str_eq (template-body-name (head templates)) name)
                (head templates)
                (find-template-body (tail templates) name))))

    (defn template-class (templates name)
        (do
            (let template-component (find-template-body templates name))
            (if (nil? template-component)
                (empty)
                (template-body-node template-component))))

    (defn template-kind-score (templates name expected-kind)
        (do
            (let template-component (find-template-body templates name))
            (if (nil? template-component)
                0
                (score-str
                    (bml-template-kind template-component)
                    expected-kind))))

    (defn template-param-count-score (templates name expected-count)
        (do
            (let template-component (find-template-body templates name))
            (if (nil? template-component)
                0
                (score-int
                    (len (bml-template-parameters template-component))
                    expected-count))))

    (defn class-field-type-score (class-component field-name expected-type)
        (if (nil? class-component)
            0
            (do
                (let field
                    (bml-find-field
                        (bml-class-own-fields class-component)
                        field-name))
                (if (nil? field)
                    0
                    (score-str
                        (bml-field-type field)
                        expected-type)))))

    (defn class-method-return-score (class-component method-name expected-return)
        (if (nil? class-component)
            0
            (do
                (let method-component
                    (bml-find-method
                        (bml-class-own-methods class-component)
                        method-name))
                (if (nil? method-component)
                    0
                    (score-str
                        (bml-method-return method-component)
                        expected-return)))))

    (defn class-base-score (class-component expected-base)
        (if (nil? class-component)
            0
            (score-str
                (bml-class-structural-base-name class-component)
                expected-base)))

    (defn class-const-value-score (class-component const-name expected-value)
        (if (nil? class-component)
            0
            (do
                (let const-component
                    (bml-find-const
                        (bml-class-own-constants class-component)
                        const-name))
                (if (nil? const-component)
                    0
                    (score-str
                        (bml-const-value const-component)
                        expected-value)))))

    (defn section-name-score (section expected-name)
        (if (nil? section)
            0
            (score-str
                (compiler-section-name section)
                expected-name)))

    (defn section-item-count-score (section expected-count)
        (if (nil? section)
            0
            (score-int
                (len (compiler-section-items section))
                expected-count)))

    (defn first-section-item (section)
        (if (nil? section)
            (empty)
            (if (nil? (compiler-section-items section))
                (empty)
                (head (compiler-section-items section)))))

    (defn first-section-item-kind-score (section expected-kind)
        (do
            (let item (first-section-item section))
            (if (nil? item)
                0
                (score-str
                    (compiler-object-kind item)
                    expected-kind))))

    (defn first-section-item-source-kind-score (section expected-kind)
        (do
            (let item (first-section-item section))
            (if (nil? item)
                0
                (score-str
                    (comp-bml-kind (compiler-object-source item))
                    expected-kind))))

    (defn declaration-node-name (node)
        (if (bml-component-kind? node "Class")
            (bml-class-name node)
            (if (bml-component-kind? node "Interface")
                (bml-interface-name node)
                (if (bml-component-kind? node "Template")
                    (template-body-name node)
                    (if (nil? (comp-bml-fields node))
                        ""
                        (head (comp-bml-fields node)))))))

    (defn declaration-carrier (node)
        (compiler-object
            "bml-source-declaration"
            (list
                (comp-bml-kind node)
                (declaration-node-name node))
            node
            compiler-identity-inverse))

    (defn lower-declarations-loop (nodes acc)
        (if (nil? nodes)
            (reverse-list acc)
            (lower-declarations-loop
                (tail nodes)
                (cons
                    (declaration-carrier (head nodes))
                    acc))))

    (defn lower-declarations (nodes)
        (lower-declarations-loop
            nodes
            (empty)))

    (defn lower-template-declarations-loop (nodes acc)
        (if (nil? nodes)
            (reverse-list acc)
            (do
                (let node (head nodes))
                (lower-template-declarations-loop
                    (tail nodes)
                    (if (template-declaration? node)
                        (cons (declaration-carrier node) acc)
                        acc)))))

    (defn lower-template-declarations (nodes)
        (lower-template-declarations-loop
            nodes
            (empty)))

    (defn template-declaration? (node)
        (bml-component-kind? node "Template"))

    (defn language-class-name? (name)
        (if (str_eq name "BMLLanguage")
            true
            (if (str_eq name "CSharpLanguage")
                true
                (if (str_eq name "JavaLanguage")
                    true
                    (if (str_eq name "TypeScriptLanguage")
                        true
                        (if (str_eq name "GoLanguage")
                            true
                            (str_eq name "RustLanguage")))))))

    (defn language-port-declaration? (node)
        (if (bml-component-kind? node "Class")
            (language-class-name? (bml-class-name node))
            false))

    (defn lower-language-port-declarations-loop (nodes acc)
        (if (nil? nodes)
            (reverse-list acc)
            (do
                (let node (head nodes))
                (lower-language-port-declarations-loop
                    (tail nodes)
                    (if (language-port-declaration? node)
                        (cons (declaration-carrier node) acc)
                        acc)))))

    (defn lower-language-port-declarations (nodes)
        (lower-language-port-declarations-loop
            nodes
            (empty)))

    (defn bootstrap-boundary-declaration? (node)
        (if (bml-component-kind? node "Class")
            (str_eq
                (bml-class-name node)
                "SelfHostingPlan")
            false))

    (defn lower-bootstrap-boundary-declarations-loop (nodes acc)
        (if (nil? nodes)
            (reverse-list acc)
            (do
                (let node (head nodes))
                (lower-bootstrap-boundary-declarations-loop
                    (tail nodes)
                    (if (bootstrap-boundary-declaration? node)
                        (cons (declaration-carrier node) acc)
                        acc)))))

    (defn lower-bootstrap-boundary-declarations (nodes)
        (lower-bootstrap-boundary-declarations-loop
            nodes
            (empty)))

    (defn bml-source-lowered-unit (nodes)
        (compiler-unit
            "bml"
            "BML.compiler"
            (list
                (compiler-section
                    "bml"
                    "declarations"
                    (lower-declarations nodes))
                (compiler-section
                    "bml"
                    "templates"
                    (lower-template-declarations nodes))
                (compiler-section
                    "bml"
                    "language-ports"
                    (lower-language-port-declarations nodes))
                (compiler-section
                    "bml"
                    "bootstrap-boundary"
                    (lower-bootstrap-boundary-declarations nodes)))))

    (defn find-compiler-section (sections name)
        (if (nil? sections)
            (empty)
            (if (str_eq
                    (compiler-section-name (head sections))
                    name)
                (head sections)
                (find-compiler-section
                    (tail sections)
                    name))))

    (let path "form-stdlib/bml/bmf-bml-compiler-picture.bml")
    (let parsed (bml-source-file-parse-declarations path))
    (let nodes (bml-source-exec-parse-nodes parsed))
    (let model (bml-source-declaration-model parsed))
    (let templates (bml-components-of-kind nodes "Template"))

    (let carrier-interface
        (bml-model-find-interface
            model
            "CompilerCarrier"))
    (let source-lowerer
        (find-template-body
            templates
            "SourceLowerer"))
    (let declaration-lowering-stage
        (template-class
            templates
            "BMLDeclarationLoweringStage"))
    (let source-lowering-flow
        (template-class
            templates
            "BMLSourceLoweringFlow"))
    (let compiler-unit-model
        (template-class
            templates
            "CompilerUnitModel"))
    (let compiler-section-model
        (template-class
            templates
            "CompilerSectionModel"))
    (let self-hosting-plan
        (bml-model-find-class
            model
            "SelfHostingPlan"))
    (let modern
        (bml-model-find-class
            model
            "ModernBMLCompiler"))

    (let unit (bml-source-lowered-unit nodes))
    (let sections (compiler-unit-sections unit))
    (let declaration-section
        (find-compiler-section
            sections
            "declarations"))
    (let template-section
        (find-compiler-section
            sections
            "templates"))
    (let language-section
        (find-compiler-section
            sections
            "language-ports"))
    (let bootstrap-section
        (find-compiler-section
            sections
            "bootstrap-boundary"))

    (sum
        (list
            (score-bool (bml-source-exec-parse-ok? parsed))
            (score-int (len (bml-source-exec-parse-rest parsed)) 0)
            (score-str (compiler-object-kind unit) "compiler-unit")
            (score-str (compiler-unit-language unit) "bml")
            (score-str (compiler-unit-name unit) "BML.compiler")
            (score-int (len sections) 4)
            (section-name-score declaration-section "declarations")
            (section-name-score template-section "templates")
            (section-name-score language-section "language-ports")
            (section-name-score bootstrap-section "bootstrap-boundary")
            (section-item-count-score declaration-section (len nodes))
            (section-item-count-score template-section (len templates))
            (section-item-count-score language-section 6)
            (section-item-count-score bootstrap-section 1)
            (first-section-item-kind-score
                declaration-section
                "bml-source-declaration")
            (first-section-item-source-kind-score
                declaration-section
                "Package")
            (score-bool (not (nil? carrier-interface)))
            (template-kind-score templates "SourceLowerer" "interface")
            (template-param-count-score templates "SourceLowerer" 3)
            (template-kind-score templates "CompilerDeclaration" "class")
            (template-kind-score templates "CompilerSectionModel" "class")
            (template-kind-score templates "CompilerUnitModel" "class")
            (template-kind-score templates "BMLDeclarationLoweringStage" "class")
            (template-param-count-score templates "BMLDeclarationLoweringStage" 2)
            (template-kind-score templates "BMLSourceLoweringFlow" "class")
            (template-param-count-score templates "BMLSourceLoweringFlow" 3)
            (class-base-score
                declaration-lowering-stage
                "CompilerStage<TDeclaration,TCarrier>")
            (class-field-type-score
                source-lowering-flow
                "m_hDeclarationStage"
                "BMLDeclarationLoweringStage<TDeclaration,TCarrier>")
            (class-field-type-score
                source-lowering-flow
                "m_hBootstrapBoundary"
                "CompilerSectionModel<TCarrier>")
            (class-method-return-score
                source-lowering-flow
                "LowerSource"
                "CompilerUnitModel<Object>")
            (class-base-score
                compiler-unit-model
                "CompilerCarrier")
            (class-base-score
                compiler-section-model
                "CompilerCarrier")
            (score-bool (not (nil? self-hosting-plan)))
            (class-const-value-score
                self-hosting-plan
                "OwnerLanguage"
                "BML")
            (class-const-value-score
                self-hosting-plan
                "FormRole"
                "minimum bootstrap and proof carrier")
            (class-const-value-score
                self-hosting-plan
                "ReleaseRule"
                "release non-bootstrap s-expression compiler logic")
            (class-method-return-score
                self-hosting-plan
                "RetiresNonBootstrapSExpressions"
                "bool")
            (class-field-type-score
                modern
                "m_hSourceLowering"
                "BMLCompilerSourceLoweringFlow")
            (class-field-type-score
                modern
                "m_hSelfHosting"
                "SelfHostingPlan")
            (class-method-return-score
                modern
                "CompileCompilerSource"
                "CompilerUnitModel<Object>")
            (class-method-return-score
                modern
                "OwnsCompilerArchitecture"
                "bool"))))
