; tests/bml-thesis-rule-operator-member-compare-proof.fk
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves the first member comparison in original container-Rule.bml:
; if ( m_strName != hOther.Name ) return false;

(do
    (defn bool-score (b bit)
        (if b bit 0))

    (defn int-score (actual expected bit)
        (if (eq actual expected) bit 0))

    (defn str-score (actual expected bit)
        (if (str_eq actual expected) bit 0))

    (let path "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/container-Rule.bml")
    (let parsed (bml-source-file-parse-declarations path))
    (let model (bml-source-declaration-model parsed))
    (let rule-class (bml-model-find-class model "Rule"))
    (let operator-method
        (bml-find-method
            (bml-class-own-methods rule-class)
            "operator=="))
    (let operator-body (bml-method-body operator-method))

    (let MemberRuleBP (make_nodeid 1 2 99 9290))
    (let MemberCallEnvBP (bml-constructor-env-blueprint 0))
    (let rule-instance (record_new MemberRuleBP "bmlClass" "Rule" "m_strName" "left"))
    (let other-rule (record_new MemberRuleBP "bmlClass" "Rule" "Name" "right"))
    (let direct-env (record_new MemberCallEnvBP "hObj" other-rule "hOther" other-rule))
    (let direct-result
        (bml-body-source-exec-if-member-neq-return-false
            operator-body
            rule-instance
            direct-env))

    (let sequence-env (record_new MemberCallEnvBP "hObj" other-rule))
    (let sequence-result
        (bml-body-source-exec
            operator-body
            rule-instance
            sequence-env))

    (defn rule-eq-dispatch (self hObj)
        (bml-body-source-exec
            operator-body
            self
            (record_new MemberCallEnvBP "hObj" hObj)))

    (method_define MemberRuleBP "operator==" rule-eq-dispatch)
    (let method-result (method_invoke rule-instance "operator==" other-rule))

    (sum
        (list
            (bool-score (bml-source-exec-parse-ok? parsed) 1)
            (str-score (bml-method-name operator-method) "operator==" 2)
            (bool-score (bml-body-source-contains? operator-body "m_strName") 4)
            (bool-score (bml-body-source-contains? operator-body "Name") 8)
            (bool-score
                (gt (bml-body-source-if-member-neq-return-false-count operator-body) 0)
                16)
            (bool-score (not direct-result) 32)
            (bool-score (record_has sequence-env "hOther") 64)
            (bool-score (not sequence-result) 128)
            (bool-score (not method-result) 256)
            (str-score (record_get (record_get sequence-env "hOther") "Name") "right" 512)
            (str-score (record_get rule-instance "m_strName") "left" 1024)
            (bool-score (bml-body-source-instanceof? other-rule "Rule") 2048))))
