; tests/intrinsic-cast-band.fk — the value-walk lane of intrinsic casting.
;
; Every primitive cast pair realizes; round-trip laws hold for declared
; reversible pairs; a failed cast realizes to nothing (never 0, never a
; throw) and nothing propagates through cast chains; cast recipes
; content-address (same shape -> same NodeID); and a lifted TS mixed
; string+int expression walks through an explicit CAST node to the
; coerced string — the kernel never coerces.
;
; Aggregate: group A (value casts) weight 1, group B (laws + row data)
; weight 100, group C (nothing) weight 10000, group D (recipe layer +
; lifted TS) weight 1000000. Expected: 15 + 900 + 70000 + 7000000 = 7070915.
;
; Fourth arm: 3-kernel only — groups A and B cross (the value-walk casts and
;           the inst-row laws ride int/string/bool ops the fourth arm carries),
;           but groups C and D rest on op families fkwu does not carry:
;           - group C (nothing): the host-null value ABI. The real kernels
;             carry a VNull value — `(node_value (make_nodeid 1 1 4 0))` — and a
;             typed `value_kind` ("int"/"string"/"null"/...). fkwu has no
;             host-null in its value ABI; the shim carries null STRUCTURALLY as
;             the reserved VALUE-NONE node and approximates value_kind as
;             null-vs-value (fourth-shim.fk), which the band's host-null nothing
;             does not equal — so every ic-nothing? reads "value" and group C
;             answers 0.
;           - group D (recipe layer + lifted TS): the lifted-TS path
;             ts-bmf-run-expr-text / ts-lift-expr-text source-compiles and
;             evaluates a TypeScript expression through the source-compiler +
;             grammar layers, which the fourth arm does not yet walk; only the
;             cast-node content-addressing (d1) crosses.
;           fkwu answers 2000915 (= 15 + 900 + 0 + 2000000) where the three
;           walkers answer 7070915 — unsupported op families, named here, not a
;           divergence. It crosses when the host-null/value_kind value-ABI and
;           the lifted-TS source-compile-eval carriers
;           (docs/coherence-substrate/fourth-arm-substrate-carriers.form) join
;           the fourth arm.
;
; spec: specs/form-intrinsic-casting.md
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/typescript-bmf.fk form-stdlib/intrinsic-cast.fk form-stdlib/typescript-bmf-eval.fk form-stdlib/typescript-bmf-lift.fk

(do
    ;; --- group A: value-level casts (weight 1) ------------------------
    (let a1  (if (eq (ic-bool-int 1) 1) 1 0))
    (let a2  (if (eq (ic-bool-int 0) 0) 1 0))
    (let a3  (if (eq (ic-int-bool 5) 1) 1 0))
    (let a4  (if (eq (ic-int-bool 0) 0) 1 0))
    (let a5  (if (eq (ic-int-float 5) 5.0) 1 0))
    (let a6  (if (eq (ic-float-int 3.7) 3) 1 0))
    (let a7  (if (str_eq (ic-int-string 42) "42") 1 0))
    (let a8  (if (str_eq (ic-int-string (sub 0 7)) "-7") 1 0))
    (let a9  (if (eq (ic-string-int "42") 42) 1 0))
    (let a10 (if (eq (ic-string-int "-7") (sub 0 7)) 1 0))
    (let a11 (if (str_eq (ic-float-string 2.5) "2.5") 1 0))
    (let a12 (if (str_eq (ic-float-string (sub 0.0 0.25)) "-0.25") 1 0))
    (let a13 (if (str_eq (ic-float-string 5.0) "5.0") 1 0))
    (let a14 (if (eq (ic-string-float "2.5") 2.5) 1 0))
    (let a15 (if (eq (ic-string-float "-0.25") (sub 0.0 0.25)) 1 0))
    (let group-a
        (add a1 (add a2 (add a3 (add a4 (add a5 (add a6 (add a7 (add a8
        (add a9 (add a10 (add a11 (add a12 (add a13 (add a14 a15)))))))))))))))

    ;; --- group B: laws + row data (weight 100) -------------------------
    (let b1 (if (and (str_eq (ic-bool-string 1) "true")
                     (str_eq (ic-bool-string 0) "false")) 1 0))
    (let b2 (if (and (eq (ic-string-bool "true") 1)
                     (eq (ic-string-bool "false") 0)) 1 0))
    (let b3 (if (and (eq (ic-string-bool-truthy "") 0)
                     (eq (ic-string-bool-truthy "x") 1)) 1 0))
    (let b4 (if (eq (ic-string-int (ic-int-string 123)) 123) 1 0))
    (let b5 (if (eq (ic-int-bool (ic-bool-int 1)) 1) 1 0))
    (let b6 (if (eq (ic-float-int (ic-int-float 7)) 7) 1 0))
    (let b7 (if (and (eq (ic-reverse-inst 14) 15)
                     (and (eq (ic-reverse-inst 10) 11)
                          (and (eq (ic-reverse-inst 19) 18)
                               (and (eq (ic-reverse-inst 13) 0)
                                    (eq (ic-reverse-inst 16) 0))))) 1 0))
    (let b8 (if (and (eq (ic-lossy-inst? 13) 1) (eq (ic-lossy-inst? 14) 0)) 1 0))
    (let b9 (if (and (eq (ic-total-inst? 15) 0) (eq (ic-total-inst? 14) 1)) 1 0))
    (let group-b
        (add b1 (add b2 (add b3 (add b4 (add b5 (add b6 (add b7 (add b8 b9)))))))))

    ;; --- group C: nothing on failure (weight 10000) --------------------
    (let c1 (if (eq (ic-nothing? (ic-string-int "abc")) 1) 1 0))
    (let c2 (if (eq (ic-nothing? (ic-string-int "")) 1) 1 0))
    (let c3 (if (eq (ic-nothing? (ic-string-int "12x")) 1) 1 0))
    (let c4 (if (eq (ic-nothing? (ic-string-float "abc")) 1) 1 0))
    (let c5 (if (eq (ic-nothing? (ic-string-float "1.2.3")) 1) 1 0))
    (let c6 (if (eq (ic-nothing? (ic-string-bool "yes")) 1) 1 0))
    (let c7 (if (eq (ic-nothing?
                        (ic-eval-tree
                            (ic-cast-node CAST-FLOAT-INT
                                (ic-cast-node CAST-STRING-FLOAT
                                    (intern_trivial_string "abc"))))) 1) 1 0))
    (let group-c
        (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))

    ;; --- group D: recipe layer + lifted TS (weight 1000000) ------------
    (let leaf42 (intern_trivial_int 42))
    (let d1 (if (node_eq (ic-cast-node CAST-INT-STRING leaf42)
                         (ic-cast-node CAST-INT-STRING leaf42)) 1 0))
    (let d2 (if (str_eq (ic-eval-tree (ic-cast-node CAST-INT-STRING leaf42)) "42") 1 0))
    (let d3 (if (eq (ic-eval-tree
                        (ic-cast-node CAST-STRING-INT
                            (ic-cast-node CAST-INT-STRING leaf42))) 42) 1 0))
    (let d4 (if (str_eq (ts-bmf-run-expr-text "\"n=\" + 5") "n=5") 1 0))
    (let lifted (ts-lift-expr-text "\"n=\" + 5"))
    (let d5 (if (and (node_eq (node_category lifted) TS-BMF-EVAL-CONCAT)
                     (node_eq (node_category (nth (node_children lifted) 1))
                              CAST-INT-STRING)) 1 0))
    (let d6 (if (str_eq (ts-bmf-run-expr-text "5 + \"n=\"") "5n=") 1 0))
    (let d7 (if (eq (ts-bmf-run-expr-text "2 + 3 * 4") 14) 1 0))
    (let group-d
        (add d1 (add d2 (add d3 (add d4 (add d5 (add d6 d7)))))))

    (add group-a
         (add (mul group-b 100)
              (add (mul group-c 10000)
                   (mul group-d 1000000)))))
