; literals-band.fk — character-literal matching over the cursor. No lexer.
;
; str/char/num are matching rules — siblings of lit/cls/run — that read characters
; straight off the cursor and emit a Form leaf. One scannerless pass: cursor + BMF
; grammar rules + Form objects, nothing held between them, no token stream, no
; tokenize phase. Comment-skip is the cursor's trivia-skip.
;
; Three synthetic checks (char, float, comment-skip), then the headline: parse the
; ACTUAL thesis BML file from disk — the cursor reads it, grammar rules match (the
; leading //// comment block + //--- Constants --- skipped), Form objects hold the
; result; the real string literal `"BMF.library.BMF"` falls out. Real source, end to end.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    (defn L (s) (intern_trivial_string s))
    (defn lt2 (n v) (intern_node (bp "let") (list n v)))

    ;; a tiny field grammar to exercise the literal matchers:  type name = value ;
    (let lexg (grammar "field" (list
        (rule3 "field"
            (list "seq" (p-run "alpha") (p-cap "name" (p-run "alpha")) (p-lit "=") (p-cap "v" (p-ref "val")) (p-lit ";"))
            (t-emit "let" (list (t-splice "name") (t-splice "v"))))
        (rule3 "val"
            (p-cap "v" (list "alt" (p-str) (p-char) (p-num) (p-run "alnum")))
            (t-splice "v")))))

    ;; char literal:  char c = 'q' ;
    (let s-chr (if (node_eq (g-parse lexg "char c = 'q' ;") (lt2 (L "c") (L "q"))) 100 0))
    ;; float number:  float pi = 3.14 ;
    (let s-num (if (node_eq (g-parse lexg "float pi = 3.14 ;") (lt2 (L "pi") (L "3.14"))) 100 0))
    ;; comment skip (block + line) around a real-shaped field:
    (let s-cmt (if (node_eq (g-parse lexg "/* size */ int n = 42 ; // trailing") (lt2 (L "n") (L "42"))) 100 0))

    ;; ── REAL SOURCE: the actual thesis BML file ───────────────────────────
    ;; rh walks: [leading //// comment block skipped] package BMF ;
    ;;   import BMF.primitive.* ;   class BMF [ public ] : Application {
    ;;   [//--- Constants --- skipped]  const String DefaultBMFSyntax = "..." ;
    ;; and extracts the real string literal.
    (let rhg (grammar "rh" (list
        (rule3 "rh"
            (list "seq"
                (p-lit "package") (p-run "alpha") (p-lit ";")
                (p-lit "import") (p-sep (list "alt" (p-run "alpha") (p-lit "*")) (p-lit ".")) (p-lit ";")
                (p-lit "class") (p-run "alpha") (p-lit "[") (p-run "alpha") (p-lit "]")
                (p-lit ":") (p-run "alpha") (p-lit "{")
                (p-lit "const") (p-run "alpha") (p-run "alpha") (p-lit "=") (p-cap "v" (p-str)) (p-lit ";"))
            (t-splice "v")))))
    (let rh-res (g-match-rule rhg (g-start rhg)
        (cursor-file "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/BMF-grammar.bml")))
    (let real (if (rok? rh-res) (rok-node rh-res) (L "PARSE-FAIL")))
    (let s-real (if (node_eq real (L "BMF.library.BMF")) 100 0))

    ; Expected total: 400  (char, float, comments, + real thesis-file string literal)
    (add s-chr (add s-num (add s-cmt s-real))))
