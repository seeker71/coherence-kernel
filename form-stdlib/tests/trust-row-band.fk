; preludes: form-stdlib/trust-row.fk
;
; The trust-row renderer, pinned. Proves the observed? verdict, ternary frequency,
; exact-positive scoring (unknown cannot manufacture a 4), source attribution, and
; full rendered rows. Verdict 2047 when every claim lands.
(do
    (let c0 (if (eq     (tr-observed? 1 1 1 1) 1)                                                    1   0))
    (let c1 (if (str_eq (tr-verdict 1 1 1 1) "OBSERVED")                                            2   0))
    (let c2 (if (str_eq (tr-verdict 0 0 0 0) "rented")                                              4   0))
    (let c3 (if (str_eq (tr-verdict 1 0 1 0) "native-partial")                                      8   0))
    (let c4 (if (str_eq (tr-path-name 1) "native")                                                 16   0))
    (let c5 (if (str_eq (tr-path-name 0) "rented")                                                 32   0))
    (let c6 (if (eq     (tr-score 1 1 2 0) 2)                                                      64   0))
    (let c7 (if (str_eq (tr-row 0 0 0 0)
                        "trust  path:rented  grounded:no  freq:no  suffic:no  -> rented")         128   0))
    (let c8 (if (str_eq (tr-mark 2) "unknown")                                                     256   0))
    ; Old raw-sum logic saw 0+1+2+1=4 and falsely returned observed.
    (let c9 (if (eq (tr-observed? 0 1 2 1) 0)                                                      512   0))
    (let c10 (if (str_eq (tr-row-with-source 1 1 2 "unmeasured" 1)
                         "trust  path:native  grounded:yes  freq:unknown  freq-source:unmeasured  suffic:yes  observed:no  -> native-partial") 1024 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 c10)))))))))))
