; preludes:
;   form/form-stdlib/hati-os-targets.fk
;   form/form-stdlib/host-os-membrane.fk
;
; host-os-membrane-band -- supported platform membrane and C-seed shrink law.
;
; Verdict 8191:
;   1    macOS target exists in the platform catalog
;   2    macOS is supported by the membrane
;   4    Windows amd64 is supported by the membrane
;   8    Android arm64 is supported by the membrane
;   16   Windows arm64 is named but not falsely marked observed-on-metal
;   32   macOS direct-source row is ready
;   64   Android has metal runtime and fresh direct-source receipt
;   128  unknown targets are rejected
;   256  speech loopback is a known host door
;   512  speech loopback body law is Form-native
;   1024 speech loopback stays local-only
;   2048 all metal-observed rows carry a seed-shrink next step
;   4096 no platform falsely claims a concrete speech carrier yet

(do
    (defn hom-band-score (cond bit) (if cond bit 0))

    (defn host-os-membrane-band ()
        (do
            (let mac (hom-platform-for "macos-arm64"))
            (let win (hom-platform-for "windows-amd64"))
            (let win-arm (hom-platform-for "windows-arm64"))
            (let android (hom-platform-for "android-arm64"))
            (let speech (hom-door-for "speech:loopback"))
            (let native-stage (hom-seed-stage-for "native-walker"))
            (let c0 (hom-band-score (eq (hom-catalog-known? "macos-arm64") 1) 1))
            (let c1 (hom-band-score (and (eq (hom-supported? "macos-arm64") 1)
                                         (str_eq (hom-target mac) "macos-arm64")) 2))
            (let c2 (hom-band-score (and (eq (hom-supported? "windows-amd64") 1)
                                         (str_eq (hom-os win) "windows")) 4))
            (let c3 (hom-band-score (and (eq (hom-supported? "android-arm64") 1)
                                         (str_eq (hom-os android) "android")) 8))
            (let c4 (hom-band-score (and (eq (hom-supported? "windows-arm64") 1)
                                         (eq (hom-metal win-arm) 0)) 16))
            (let c5 (hom-band-score (eq (hom-direct-src mac) 1) 32))
            (let c6 (hom-band-score (and (eq (hom-metal android) 1)
                                         (eq (hom-direct-src android) 1)) 64))
            (let c7 (hom-band-score (eq (hom-supported? "linux-amiga") 0) 128))
            (let c8 (hom-band-score (eq (hom-door-known? "speech:loopback") 1) 256))
            (let c9 (hom-band-score (eq (hom-door-body-owned? "speech:loopback") 1) 512))
            (let c10 (hom-band-score (eq (hom-door-local speech) 1) 1024))
            (let c11 (hom-band-score (eq (hom-all-metal-has-shrink? (hom-platforms)) 1) 2048))
            (let c12 (hom-band-score (and (eq (hom-all-speech-carriers-pending? (hom-platforms)) 1)
                                          (eq (hom-seed-c native-stage) 0)) 4096))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    c12))))

    (host-os-membrane-band))
