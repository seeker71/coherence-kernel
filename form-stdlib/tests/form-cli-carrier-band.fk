; form-cli-carrier-band.fk — baked identity plus a real full-nonce native challenge.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk
; preludes: form-stdlib/hex.fk form-stdlib/form-cli-carrier.fk
;
; Verdict 255 proves identity shape, a cross-implementation known answer, strict
; nonce admission, determinism, and sensitivity at both ends of the nonce.

(do
    (let nonce "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f")
    (let first-mut "100102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f")
    (let last-mut "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1e")
    (let known "1cb41be978d307c11bf41602cd11bdac834046103d6fc89a6f69cd0c6c4efb21")
    (let challenge (fcc-carrier-challenge nonce))
    (let c0 (if (str_eq (fcc-schema) "form-cli-carrier-v2") 1 0))
    (let c1 (if (str_eq (fcc-source-stamp) "FORM_CLI_SOURCE_SHA256_PLACEHOLDER") 2 0))
    (let c2 (if (str_eq (fcc-challenge-digest nonce) known) 4 0))
    (let c3 (if (not (lt (str_find challenge nonce 0) 0)) 8 0))
    (let c4 (if (str_eq (fcc-carrier-challenge "abcd")
                       "carrier-challenge:error:invalid-nonce") 16 0))
    (let c5 (if (str_eq (fcc-carrier-challenge
                         "FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF")
                       "carrier-challenge:error:invalid-nonce") 32 0))
    (let c6 (if (and (not (str_eq (fcc-challenge-digest nonce)
                                   (fcc-challenge-digest first-mut)))
                     (not (str_eq (fcc-challenge-digest nonce)
                                   (fcc-challenge-digest last-mut)))) 64 0))
    (let c7 (if (str_eq challenge (fcc-carrier-challenge nonce)) 128 0))
    (sum (list c0 c1 c2 c3 c4 c5 c6 c7)))
