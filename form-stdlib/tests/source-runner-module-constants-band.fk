; source-runner-module-constants-band.fk -- top-level let constants in direct source.
;
; This pins the temporary C-seed source-runner behavior that keeps checkout
; witnessing honest until source parsing and constants move into Form artifacts.
;
; Expected: 127

(let X 40)
(let top-before (add X 1))
(defn shadow () (do (let X 5) (add X 2)))
(let X 100)
(let top-after (add X 1))
(defn read-new () (add X 2))

(do
    (let b1 (if (eq top-before 41) 1 0))
    (let b2 (if (eq (read-new) 102) 2 0))
    (let b3 (if (eq (shadow) 7) 4 0))
    (let b4 (if (eq (add X 0) 100) 8 0))
    (let b5 (if (eq top-after 101) 16 0))
    (let b6 (if (eq top-before 41) 32 0))
    (let b7 (if (eq (do (let X 6) (add X 3)) 9) 64 0))
    (add b1 (add b2 (add b3 (add b4 (add b5 (add b6 b7)))))))
