; tests/bml-hati-native-class-field-proof.fk
;
; preludes: form-stdlib/core.fk form-stdlib/minimal-surface.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/hati-os-kernel.fk form-stdlib/hati-os-kernel-emit.fk form-stdlib/grammars/bml.fk
;
; Proves the next BML-native floor step after packed multi-arg calls:
; a class-shaped BML source row carries a declared field and a method whose
; method scope reads record-backed self.field through Hati, while a setter
; method mutates the same record-backed field before returning it.

(do
    (defn score-bool (actual)
        (if actual 1 0))

    (defn score-int (actual expected)
        (if (eq actual expected) 1 0))

    (defn score-str (actual expected)
        (if (nil? actual)
            0
            (if (str_eq actual expected) 1 0)))

    (defn str-contains? (haystack needle)
        (ge (str_find haystack needle 0) 0))

    (let class-source
        "class Rule[public]: Object { section[public] { int value; int Read() { return this.value + 5; } } }\n")
    (let class-step
        (bml-source-parse-balanced-class-shell
            (bml-source-scan-text class-source)))
    (let class-component (bml-source-parse-step-node class-step))
    (let class-field (bml-find-field (bml-class-own-fields class-component) "value"))
    (let class-method-component (bml-find-method (bml-class-own-methods class-component) "Read"))

    (let read-source
        "int Read() { return this.value + 5; }\n")
    (let read-parsed
        (bml-source-parse-executable-stream
            (bml-source-scan-text read-source)))
    (let read-method (head (bml-source-exec-parse-nodes read-parsed)))
    (let class-node
        (bml-ast-class
            "Rule"
            "Object"
            (bml-ast-block
                (list
                    (bml-ast-section
                        (bml-ast-name "public")
                        (bml-ast-block
                            (list
                                (bml-ast-field "int" "value")
                                read-method)))))))
    (let class-self (record_new (make_nodeid 1 9 2026 613) "value" 37))
    (let class-image (bml-hati-compile-image class-node))
    (let class-table (bml-hati-table-file class-image))

    (let setter-source
        "int Set() { this.value = 33; return this.value; }\n")
    (let setter-parsed
        (bml-source-parse-executable-stream
            (bml-source-scan-text setter-source)))
    (let setter-node (head (bml-source-exec-parse-nodes setter-parsed)))
    (let setter-self (record_new (make_nodeid 1 9 2026 614) "value" 7))
    (let setter-image (bml-hati-compile-image setter-node))
    (let setter-table (bml-hati-table-file setter-image))
    (let setter-value (bml-hati-run-value-with-arg setter-node setter-self))

    (sum
        (list
            (score-bool (bml-source-parse-step-ok? class-step))
            (score-str (bml-class-name class-component) "Rule")
            (score-str (bml-field-name class-field) "value")
            (score-str (bml-method-name class-method-component) "Read")
            (score-bool (bml-source-exec-parse-ok? read-parsed))
            (score-str (head (bml-source-exec-parse-rules read-parsed)) "method-return-this-field-add-int")
            (score-bool (node_eq (node_category class-node) BML-AST-CLASS))
            (score-str (bml-method-node-name read-method) "Read")
            (score-bool (bml-hati-image-supported? class-image))
            (score-int (len (bml-hati-image-fns class-image)) 1)
            (score-int (bml-hati-run-value-with-arg class-node class-self) 42)
            (score-bool (str-contains? class-table "97"))
            (score-bool (not (str-contains? class-table "BML-HATI-UNSUPPORTED")))
            (score-bool (bml-source-exec-parse-ok? setter-parsed))
            (score-str (head (bml-source-exec-parse-rules setter-parsed)) "method-set-this-field-return")
            (score-bool (bml-hati-image-supported? setter-image))
            (score-int setter-value 33)
            (score-int (record_get setter-self "value") 33)
            (score-bool (str-contains? setter-table "98"))
            (score-bool (str-contains? setter-table "97"))
            (score-bool (not (str-contains? setter-table "BML-HATI-UNSUPPORTED"))))))
