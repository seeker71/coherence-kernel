; stdlib-knowledge-hierarchy-band.fk -- semantic cluster index witness.
;
; preludes: form-stdlib/core.fk form-stdlib/stdlib-knowledge-hierarchy.fk
;
; Expected: 16383

(do
    (defn skhb-score (ok bit) (if ok bit 0))
    (defn skhb-inv () (skh-inventory))
    (defn skhb-grammar-cluster ()
        (skh-find-cluster "grammar-compiler-language" (skh-clusters)))
    (defn skhb-unclassified-cluster ()
        (skh-find-cluster "unclassified" (skh-clusters)))
    (defn skhb-freshness-grammar ()
        (skh-find-missing-grammar "stdlib-freshness-header" (skh-missing-grammars)))
    (defn skhb-cluster-index-grammar ()
        (skh-find-missing-grammar "stdlib-cluster-index-language" (skh-missing-grammars)))
    (defn skhb-pressure-grammar ()
        (skh-find-missing-grammar "section-grammar-pressure-language" (skh-missing-grammars)))

    (defn stdlib-knowledge-hierarchy-band ()
        (sum
            (list
                (skhb-score (str_eq (skh-version) "stdlib-knowledge-hierarchy-v1") 1)
                (skhb-score (eq (skh-inventory-total (skhb-inv)) 2276) 2)
                (skhb-score (eq (skh-inventory-root (skhb-inv)) 847) 4)
                (skhb-score (eq (skh-inventory-tests (skhb-inv)) 1258) 8)
                (skhb-score (eq (len (skh-clusters)) 13) 16)
                (skhb-score (eq (skh-root-count-sum) 847) 32)
                (skhb-score (eq (skh-cluster-root-count (skhb-grammar-cluster)) 44) 64)
                (skhb-score (str_eq (skh-cluster-missing-grammar (skhb-grammar-cluster)) "cluster-index-and-section-lift-language") 128)
                (skhb-score (gt (skh-cluster-root-count (skhb-unclassified-cluster)) 0) 256)
                (skhb-score (eq (len (skh-section-classes)) 11) 512)
                (skhb-score (str_eq (skh-missing-grammar-status (skhb-freshness-grammar)) "built-v1") 1024)
                (skhb-score (str_eq (skh-missing-grammar-status (skhb-cluster-index-grammar)) "bmf-source-v1") 2048)
                (skhb-score (and (eq (skh-no-uplift-before-index?) 1)
                                 (str_eq (skh-bmf-missing-grammar-source-path)
                                         "grammars/stdlib-uplift-missing-grammars.bmf")) 4096)
                (skhb-score (and (str_eq (skh-missing-grammar-status (skhb-pressure-grammar))
                                          "bmf-source-and-use-v1")
                                 (str_eq (skh-section-pressure-source-path)
                                         "grammars/stdlib-section-pressure.bmf")) 8192))))

    (stdlib-knowledge-hierarchy-band))
