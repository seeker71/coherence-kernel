; tests/bml-concrete-source-lowerer-execution-proof.fk
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves the concrete BML source lowerer is not only a parsed shape. Focused
; BML BodySource patterns execute its parsed method bodies through method
; dispatch: source declarations, parser adapter, declaration stage, typed
; carriers, and language/bootstrap classifiers.

(do
    (defn score-bool (actual)
        (if actual 1 0))

    (defn score-int (actual expected)
        (if (eq actual expected) 1 0))

    (defn score-str (actual expected)
        (if (nil? actual)
            0
            (if (str_eq actual expected) 1 0)))

    (defn score-record-field-str (rec slot expected)
        (if (record_has rec slot)
            (score-str (record_get rec slot) expected)
            0))

    (defn template-body-node (template-component)
        (head (bml-template-body template-component)))

    (defn template-body-name (template-component)
        (do
            (let node (template-body-node template-component))
            (if (bml-component-kind? node "Class")
                (bml-class-name node)
                (if (bml-component-kind? node "Interface")
                    (bml-interface-name node)
                    ""))))

    (defn find-template-body (templates name)
        (if (nil? templates)
            (empty)
            (if (str_eq (template-body-name (head templates)) name)
                (head templates)
                (find-template-body (tail templates) name))))

    (defn template-class (templates name)
        (do
            (let template-component (find-template-body templates name))
            (if (nil? template-component)
                (empty)
                (template-body-node template-component))))

    (let path "form-stdlib/bml/bmf-bml-compiler-picture.bml")
    (let parsed (bml-source-file-parse-declarations path))
    (let nodes (bml-source-exec-parse-nodes parsed))
    (let model (bml-source-declaration-model parsed))
    (let templates (bml-components-of-kind nodes "Template"))

    (let compiler-declaration
        (template-class
            templates
            "CompilerDeclaration"))
    (let source-declaration
        (bml-model-find-class
            model
            "BMLSourceDeclaration"))
    (let parsed-parser
        (bml-model-find-class
            model
            "BMLParsedSourceParser"))
    (let concrete-stage
        (bml-model-find-class
            model
            "BMLCompilerDeclarationLoweringStage"))
    (let concrete-flow
        (bml-model-find-class
            model
            "BMLCompilerSourceLoweringFlow"))

    (let source-kind-method
        (bml-find-method
            (bml-class-own-methods source-declaration)
            "Kind"))
    (let source-name-method
        (bml-find-method
            (bml-class-own-methods source-declaration)
            "Name"))
    (let parser-parse-method
        (bml-find-method
            (bml-class-own-methods parsed-parser)
            "ParseDeclarations"))
    (let carrier-source-method
        (bml-find-method
            (bml-class-own-methods compiler-declaration)
            "Source"))
    (let declaration-kind-method
        (bml-find-method
            (bml-class-own-methods concrete-stage)
            "DeclarationKind"))
    (let declaration-name-method
        (bml-find-method
            (bml-class-own-methods concrete-stage)
            "DeclarationName"))
    (let build-carrier-method
        (bml-find-method
            (bml-class-own-methods concrete-stage)
            "BuildCarrier"))
    (let carrier-source-stage-method
        (bml-find-method
            (bml-class-own-methods concrete-stage)
            "CarrierSource"))
    (let is-template-method
        (bml-find-method
            (bml-class-own-methods concrete-flow)
            "IsTemplateDeclaration"))
    (let is-language-method
        (bml-find-method
            (bml-class-own-methods concrete-flow)
            "IsLanguagePortDeclaration"))
    (let is-bootstrap-method
        (bml-find-method
            (bml-class-own-methods concrete-flow)
            "IsBootstrapBoundaryDeclaration"))
    (let is-known-method
        (bml-find-method
            (bml-class-own-methods concrete-flow)
            "IsKnownLanguagePortName"))

    (let source-kind-body (bml-method-body source-kind-method))
    (let source-name-body (bml-method-body source-name-method))
    (let parser-parse-body (bml-method-body parser-parse-method))
    (let carrier-source-body (bml-method-body carrier-source-method))
    (let declaration-kind-body (bml-method-body declaration-kind-method))
    (let declaration-name-body (bml-method-body declaration-name-method))
    (let build-carrier-body (bml-method-body build-carrier-method))
    (let carrier-source-stage-body (bml-method-body carrier-source-stage-method))
    (let is-template-body (bml-method-body is-template-method))
    (let is-language-body (bml-method-body is-language-method))
    (let is-bootstrap-body (bml-method-body is-bootstrap-method))
    (let is-known-body (bml-method-body is-known-method))

    (let SourceDeclarationBP
        (bml-body-source-constructor-blueprint "BMLSourceDeclaration"))
    (let SourceCarrierBP
        (bml-body-source-constructor-blueprint "BMLSourceCarrier"))
    (let ParsedParserBP
        (bml-body-source-constructor-blueprint "BMLParsedSourceParser"))
    (let StageBP
        (bml-body-source-constructor-blueprint "BMLCompilerDeclarationLoweringStage"))
    (let FlowBP
        (bml-body-source-constructor-blueprint "BMLCompilerSourceLoweringFlow"))
    (let LowererEnvBP (bml-constructor-env-blueprint 0))

    (defn source-kind-dispatch (self)
        (bml-body-source-exec-return
            source-kind-body
            self
            (record_new LowererEnvBP)))

    (defn source-name-dispatch (self)
        (bml-body-source-exec-return
            source-name-body
            self
            (record_new LowererEnvBP)))

    (defn parsed-parser-parse-dispatch (self source-path)
        (bml-body-source-exec-return
            parser-parse-body
            self
            (record_new LowererEnvBP "strSourcePath" source-path)))

    (defn carrier-source-dispatch (self)
        (bml-body-source-exec-return
            carrier-source-body
            self
            (record_new LowererEnvBP)))

    (defn stage-declaration-kind-dispatch (self hDeclaration)
        (bml-body-source-exec-return
            declaration-kind-body
            self
            (record_new LowererEnvBP "hDeclaration" hDeclaration)))

    (defn stage-declaration-name-dispatch (self hDeclaration)
        (bml-body-source-exec-return
            declaration-name-body
            self
            (record_new LowererEnvBP "hDeclaration" hDeclaration)))

    (defn stage-build-carrier-dispatch
        (self strKind strName hDeclaration)
        (bml-body-source-exec-return
            build-carrier-body
            self
            (record_new
                LowererEnvBP
                "strKind"
                strKind
                "strName"
                strName
                "hDeclaration"
                hDeclaration)))

    (defn stage-carrier-source-dispatch (self hCarrier)
        (bml-body-source-exec-return
            carrier-source-stage-body
            self
            (record_new LowererEnvBP "hCarrier" hCarrier)))

    (defn flow-is-template-dispatch (self hDeclaration)
        (bml-body-source-exec-return
            is-template-body
            self
            (record_new LowererEnvBP "hDeclaration" hDeclaration)))

    (defn flow-is-language-dispatch (self hDeclaration)
        (bml-body-source-exec-return
            is-language-body
            self
            (record_new LowererEnvBP "hDeclaration" hDeclaration)))

    (defn flow-is-bootstrap-dispatch (self hDeclaration)
        (bml-body-source-exec-return
            is-bootstrap-body
            self
            (record_new LowererEnvBP "hDeclaration" hDeclaration)))

    (defn flow-is-known-dispatch (self strName)
        (bml-body-source-exec-if-local-eq-string-return-true-loop
            (bml-body-source-values is-known-body)
            self
            (record_new LowererEnvBP "strName" strName)))

    (method_define SourceDeclarationBP "Kind" source-kind-dispatch)
    (method_define SourceDeclarationBP "Name" source-name-dispatch)
    (method_define ParsedParserBP "ParseDeclarations" parsed-parser-parse-dispatch)
    (method_define SourceCarrierBP "Source" carrier-source-dispatch)
    (method_define StageBP "DeclarationKind" stage-declaration-kind-dispatch)
    (method_define StageBP "DeclarationName" stage-declaration-name-dispatch)
    (method_define StageBP "BuildCarrier" stage-build-carrier-dispatch)
    (method_define StageBP "CarrierSource" stage-carrier-source-dispatch)
    (method_define FlowBP "IsTemplateDeclaration" flow-is-template-dispatch)
    (method_define FlowBP "IsLanguagePortDeclaration" flow-is-language-dispatch)
    (method_define FlowBP "IsBootstrapBoundaryDeclaration" flow-is-bootstrap-dispatch)
    (method_define FlowBP "IsKnownLanguagePortName" flow-is-known-dispatch)

    (let syntax-node (head nodes))
    (let template-declaration
        (record_new
            SourceDeclarationBP
            "bmlClass"
            "BMLSourceDeclaration"
            "m_strKind"
            "Template"
            "m_strName"
            "BMLSourceLoweringFlow"
            "m_hSyntaxNode"
            syntax-node))
    (let language-declaration
        (record_new
            SourceDeclarationBP
            "bmlClass"
            "BMLSourceDeclaration"
            "m_strKind"
            "Class"
            "m_strName"
            "GoLanguage"
            "m_hSyntaxNode"
            syntax-node))
    (let bootstrap-declaration
        (record_new
            SourceDeclarationBP
            "bmlClass"
            "BMLSourceDeclaration"
            "m_strKind"
            "Class"
            "m_strName"
            "SelfHostingPlan"
            "m_hSyntaxNode"
            syntax-node))
    (let ordinary-declaration
        (record_new
            SourceDeclarationBP
            "bmlClass"
            "BMLSourceDeclaration"
            "m_strKind"
            "Class"
            "m_strName"
            "OrdinaryCompilerPart"
            "m_hSyntaxNode"
            syntax-node))

    (let parser
        (record_new
            ParsedParserBP
            "bmlClass"
            "BMLParsedSourceParser"
            "m_hDeclarations"
            (list
                template-declaration
                language-declaration
                bootstrap-declaration
                ordinary-declaration)))
    (let parsed-declarations
        (method_invoke
            parser
            "ParseDeclarations"
            "ignored.bml"))
    (let stage
        (record_new
            StageBP
            "bmlClass"
            "BMLCompilerDeclarationLoweringStage"))
    (let flow
        (record_new
            FlowBP
            "bmlClass"
            "BMLCompilerSourceLoweringFlow"))

    (let stage-kind
        (method_invoke
            stage
            "DeclarationKind"
            template-declaration))
    (let stage-name
        (method_invoke
            stage
            "DeclarationName"
            template-declaration))
    (let carrier
        (method_invoke
            stage
            "BuildCarrier"
            stage-kind
            stage-name
            template-declaration))
    (let carrier-source
        (method_invoke
            stage
            "CarrierSource"
            carrier))

    (sum
        (list
            (score-bool (bml-source-exec-parse-ok? parsed))
            (score-int (len (bml-source-exec-parse-rest parsed)) 0)
            (score-bool (not (nil? parsed-parser)))
            (score-int (bml-body-source-return-object-count source-kind-body) 1)
            (score-int (bml-body-source-return-object-count source-name-body) 1)
            (score-int (bml-body-source-return-object-count parser-parse-body) 1)
            (score-int
                (bml-body-source-return-receiver-call0-count
                    declaration-kind-body)
                1)
            (score-int
                (bml-body-source-return-receiver-call0-count
                    declaration-name-body)
                1)
            (score-int
                (bml-body-source-return-constructor3-count
                    build-carrier-body)
                1)
            (score-int
                (bml-body-source-return-receiver-call0-count
                    carrier-source-stage-body)
                1)
            (score-int
                (bml-body-source-return-receiver-call0-eq-string-count
                    is-template-body)
                1)
            (score-int
                (bml-body-source-return-implicit-call1-receiver-call0-count
                    is-language-body)
                1)
            (score-int
                (bml-body-source-return-receiver-call0-eq-string-count
                    is-bootstrap-body)
                1)
            (score-int
                (bml-body-source-if-local-eq-string-return-true-count
                    is-known-body)
                6)
            (score-int (len parsed-declarations) 4)
            (score-str (method_invoke template-declaration "Kind") "Template")
            (score-str
                (method_invoke template-declaration "Name")
                "BMLSourceLoweringFlow")
            (score-str stage-kind "Template")
            (score-str stage-name "BMLSourceLoweringFlow")
            (score-record-field-str carrier "bmlClass" "BMLSourceCarrier")
            (score-record-field-str carrier "m_strKind" "Template")
            (score-record-field-str
                carrier
                "m_strName"
                "BMLSourceLoweringFlow")
            (score-record-field-str
                carrier-source
                "m_strKind"
                "Template")
            (score-record-field-str
                carrier-source
                "m_strName"
                "BMLSourceLoweringFlow")
            (score-bool
                (method_invoke
                    flow
                    "IsTemplateDeclaration"
                    template-declaration))
            (score-bool
                (not
                    (method_invoke
                        flow
                        "IsTemplateDeclaration"
                        language-declaration)))
            (score-bool
                (method_invoke
                    flow
                    "IsLanguagePortDeclaration"
                    language-declaration))
            (score-bool
                (not
                    (method_invoke
                        flow
                        "IsLanguagePortDeclaration"
                        ordinary-declaration)))
            (score-bool
                (method_invoke
                    flow
                    "IsBootstrapBoundaryDeclaration"
                    bootstrap-declaration))
            (score-bool
                (not
                    (method_invoke
                        flow
                        "IsBootstrapBoundaryDeclaration"
                        language-declaration)))
            (score-bool
                (method_invoke flow "IsKnownLanguagePortName" "RustLanguage"))
            (score-bool
                (not
                    (method_invoke
                        flow
                        "IsKnownLanguagePortName"
                        "PythonLanguage")))
            (score-bool (method_has StageBP "BuildCarrier"))
            (score-bool (method_has FlowBP "IsLanguagePortDeclaration")))))
