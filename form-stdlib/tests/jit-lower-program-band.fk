; preludes: form-stdlib/minimal-surface.fk form-stdlib/hati-os-kernel.fk form-stdlib/jit-lower.fk
;
; jit-lower-program-band — the program-level lowering passes on multi-function
; tables: CALL inlining (JIT gap #2's recipe-lane close — dispatch overhead
; becomes substitution) and nested-defn lift (gap #4's recipe-lane close —
; CLOSURE-LIFTED markers become real function-table entries). Both run through
; the ONE generic engine; the multi-function walker (fkm-run) is the parity
; judge.
;
; Verdict 15 when the passes hold:
;   1   inlining: main ADD(CALL(1,ARG), CALL(1,LIT 2)) over helper ADD(ARG,1)
;       lowers to a main with NO CALL nodes, the literal call folds, and the
;       lowered table answers parity with the original at args 0 and 4
;   2   the purity gate holds: a callee that opens an organ door (SET) is
;       NOT inlined — its CALL stands
;   4   lift: one CLOSURE-LIFTED marker hoists into the table — the table
;       grows to 2 functions, no tag-77 remains, and the lifted program
;       answers exactly what the marked program answers (16 at arg 5)
;   8   lift then lower composes: inlining the lifted call dissolves the
;       marker's indirection entirely (no CALL, no tag-77) at the same answer
(do
    (let helper (fk-add (fk-arg) (fk-lit 1)))
    (let main0 (fk-add (fk-call 1 (fk-arg)) (fk-call 1 (fk-lit 2))))
    (let fns (list main0 helper))
    (let low (jit-lower-program fns))
    (let c0 (if (eq (jit-has-tag? (nth low 0) 12) 0)
                (if (eq (fkm-run low 0) (fkm-run fns 0))
                    (if (eq (fkm-run low 4) (fkm-run fns 4)) 1 0) 0) 0))

    (let impure (fk-set (fk-lit 0) (fk-arg)))
    (let fns2 (list (fk-add (fk-call 1 (fk-arg)) (fk-lit 5)) impure))
    (let low2 (jit-lower-program fns2))
    (let c1 (if (eq (jit-has-tag? (nth low2 0) 12) 1) 2 0))

    (let marked (fk-add (fk-closure-lifted 0 (fk-add (fk-arg) (fk-lit 1))) (fk-lit 10)))
    (let lifted (jit-lift-program (list marked)))
    (let c2 (if (eq (len lifted) 2)
                (if (eq (jit-has-tag? (nth lifted 0) 77) 0)
                    (if (eq (fkm-run lifted 5) (fkm-run (list marked) 5))
                        (if (eq (fkm-run lifted 5) 16) 4 0) 0) 0) 0))

    (let relow (jit-lower-program lifted))
    (let c3 (if (eq (jit-has-tag? (nth relow 0) 12) 0)
                (if (eq (jit-has-tag? (nth relow 0) 77) 0)
                    (if (eq (fkm-run relow 5) 16) 8 0) 0) 0))

    (add c0 (add c1 (add c2 c3))))
