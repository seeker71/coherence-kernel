; preludes: form-stdlib/trig.fk form-stdlib/mel-frame.fk form-stdlib/mel-full.fk
(do
  (defn mfb-abs (x) (if (lt x 0.0) (sub 0.0 x) x))
  (defn mfb-vd (a b)
    (if (eq (len a) 0) 0.0
        (do (let d (mfb-abs (sub (head a) (head b))))
            (let r (mfb-vd (tail a) (tail b))) (if (gt d r) d r))))
  (defn mfb-maxdiff (as bs)
    (if (eq (len as) 0) 0.0
        (do (let d (mfb-vd (head as) (head bs)))
            (let r (mfb-maxdiff (tail as) (tail bs))) (if (gt d r) d r))))
