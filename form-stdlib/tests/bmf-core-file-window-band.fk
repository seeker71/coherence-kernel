; bmf-core-file-window-band.fk -- bmf-core cursor-file over bbc windows.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/bmf-byte-cursor.fk form-stdlib/bmf-core.fk
;
; Expected: 32767

(do
    (defn bcfwb-score (ok bit) (if ok bit 0))
    (defn bcfwb-root ()
        (fs-path-join (fs-temp-dir) "bmf-core-file-window-band"))
    (defn bcfwb-path ()
        (fs-path-join (bcfwb-root) "fixture.bin"))
    (defn bcfwb-big-path ()
        (fs-path-join (bcfwb-root) "big.bin"))
    (defn bcfwb-repeat-byte-loop (b n acc)
        (if (le n 0)
            acc
            (bcfwb-repeat-byte-loop b (sub n 1) (cons b acc))))
    (defn bcfwb-repeat-byte (b n)
        (bcfwb-repeat-byte-loop b n (list)))
    (defn bcfwb-setup ()
        (do
            (let root (bcfwb-root))
            (let _pre_main (fs-remove-file (bcfwb-path)))
            (let _pre_big (fs-remove-file (bcfwb-big-path)))
            (let _pre_dir (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let _clear_main (fs-remove-file (bcfwb-path)))
            (let _clear_big (fs-remove-file (bcfwb-big-path)))
            ; A, two-byte ASCII payload, B, //X newline, 12+34
            (let _w (fs-append-bytes (bcfwb-path)
                                     (list 65 89 90 66 47 47 88 10 49 50 43 51 52)))
            (let _big (fs-append-bytes (bcfwb-big-path)
                                      (bcfwb-repeat-byte 65 (add (fbw-max-window) 1))))
            0))
    (defn bcfwb-cleanup ()
        (do
            (let _main (fs-remove-file (bcfwb-path)))
            (let _big (fs-remove-file (bcfwb-big-path)))
            (fs-remove-tree (bcfwb-root))))

    (defn bcfwb-bit-surface-file ()
        (do
            (let sf (surface-file (bcfwb-path)))
            (bcfwb-score
                (and (str_eq (surf-kind sf) "file-window")
                     (and (str_eq (surf-payload sf) (bcfwb-path))
                          (eq (surf-len sf) (sub 0 1))))
                1)))
    (defn bcfwb-bit-cursor-file-window ()
        (do
            (let c (cursor-file-window (bcfwb-path) 2))
            (bcfwb-score
                (and (eq (cur-peek c) 65)
                     (and (eq (cur-pos c) 0)
                     (and (str_eq (cur-peek-char c) "A")
                          (eq (bbc-window-size (cur-state c)) 2))))
                2)))
    (defn bcfwb-bit-cursor-file-default ()
        (do
            (let c (cursor-file (bcfwb-path)))
            (bcfwb-score
                (and (eq (cur-peek c) 65)
                     (eq (bbc-window-size (cur-state c)) (bbc-default-window-size)))
                4)))
    (defn bcfwb-bit-lit-a ()
        (do
            (let c (cursor-file-window (bcfwb-path) 2))
            (let m (match-pat (list "lit" "A") c (caps-empty)))
            (bcfwb-score
                (and (m-ok? m)
                     (and (eq (cur-pos (m-cur m)) 1)
                          (eq (cur-pos c) 0)))
                8)))
    (defn bcfwb-bit-lit-two-byte-boundary ()
        (do
            (let lit (fbw-window-slice (fbw-read-window (bcfwb-path) 1 2)))
            (let c (cur-advance (cursor-file-window (bcfwb-path) 2) 1))
            (let m (match-pat (list "lit" lit) c (caps-empty)))
            (bcfwb-score
                (and (m-ok? m)
                     (and (eq (str_len lit) 2)
                     (and (eq (cur-pos (m-cur m)) 3)
                          (eq (cur-peek (m-cur m)) 66))))
                16)))
    (defn bcfwb-bit-win2-comment-boundary ()
        (do
            (let c (cur-advance (cursor-file-window (bcfwb-path) 2) 4))
            (bcfwb-score (str_eq (cur-win2 c) "//") 32)))
    (defn bcfwb-bit-skip-comment ()
        (do
            (let c (cur-advance (cursor-file-window (bcfwb-path) 2) 4))
            (let after (skip-ws c))
            (bcfwb-score
                (and (eq (cur-pos after) 8)
                     (eq (cur-peek after) 49))
                64)))
    (defn bcfwb-bit-parse-after-comment ()
        (do
            (let c (skip-ws (cur-advance (cursor-file-window (bcfwb-path) 2) 4)))
            (let pat (list "seq"
                           (list "cap" "l" (list "run" "digit"))
                           (list "lit" "+")
                           (list "cap" "r" (list "run" "digit"))))
            (let m (match-pat pat c (caps-empty)))
            (bcfwb-score
                (and (m-ok? m)
                     (and (str_eq (caps-get (m-caps m) "l") "12")
                     (and (str_eq (caps-get (m-caps m) "r") "34")
                          (eq (cur-pos (m-cur m)) 13))))
                128)))
    (defn bcfwb-bit-string-regression ()
        (do
            (let c (cursor-str "12+34"))
            (let pat (list "seq"
                           (list "cap" "l" (list "run" "digit"))
                           (list "lit" "+")
                           (list "cap" "r" (list "run" "digit"))))
            (let m (match-pat pat c (caps-empty)))
            (bcfwb-score
                (and (m-ok? m)
                     (and (str_eq (caps-get (m-caps m) "l") "12")
                     (and (str_eq (caps-get (m-caps m) "r") "34")
                          (eq (cur-pos (m-cur m)) 5))))
                256)))
    (defn bcfwb-bit-long-slice-assembled ()
        (do
            (let c (cursor-file-window (bcfwb-big-path) 2))
            (let s (cur-slice c (add (fbw-max-window) 1)))
            (bcfwb-score
                (and (eq (str_len s) (add (fbw-max-window) 1))
                     (and (eq (bmf-str-byte-at s 0) 65)
                          (eq (bmf-str-byte-at s (fbw-max-window)) 65)))
                512)))
    (defn bcfwb-text-count-loop (text needle start acc)
        (do
            (let found (str_find text needle start))
            (if (lt found 0)
                acc
                (bcfwb-text-count-loop text needle (add found 1) (add acc 1)))))
    (defn bcfwb-text-count (text needle)
        (bcfwb-text-count-loop text needle 0 0))
    (defn bcfwb-text-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn bcfwb-source-text ()
        (if (ge (file_size "form/form-stdlib/bmf-core.fk") 0)
            (read_file "form/form-stdlib/bmf-core.fk")
            (if (ge (file_size "form-stdlib/bmf-core.fk") 0)
                (read_file "form-stdlib/bmf-core.fk")
                "")))
    (defn bcfwb-grammar-text ()
        (if (ge (file_size "grammars/bmf-core.fk") 0)
            (read_file "grammars/bmf-core.fk")
            (if (ge (file_size "../grammars/bmf-core.fk") 0)
                (read_file "../grammars/bmf-core.fk")
                "")))
    (defn bcfwb-bit-no-read-file-route ()
        (do
            (let text (bcfwb-source-text))
            (bcfwb-score
                (and (gt (str_len text) 0)
                     (and (not (bcfwb-text-has? text "surface-string (read_file"))
                     (and (not (bcfwb-text-has? text "(read_file path"))
                          (not (bcfwb-text-has? text "file_byte_at")))))
                1024)))
    (defn bcfwb-bit-central-cursor-row ()
        (do
            (let text (bcfwb-source-text))
            (bcfwb-score
                (and (gt (str_len text) 0)
                     (eq (bcfwb-text-count text "(list \"cursor\"") 1))
                2048)))
    (defn bcfwb-bit-mirror-parity ()
        (do
            (let a (bcfwb-source-text))
            (let b (bcfwb-grammar-text))
            (bcfwb-score
                (and (gt (str_len a) 0)
                     (and (gt (str_len b) 0)
                          (str_eq a b)))
                4096)))
    (defn bcfwb-bit-byte-cursor-source-still-green ()
        (do
            (let c (cursor-file-window (bcfwb-path) 2))
            (let c2 (cur-advance c 2))
            (bcfwb-score
                (and (eq (cur-peek c2) 90)
                     (and (eq (cur-pos c2) 2)
                          (eq (bbc-window-start (cur-state c2)) 2)))
                8192)))
    (defn bcfwb-bit-eof-file-window ()
        (do
            (let c (cur-advance (cursor-file-window (bcfwb-path) 2) 13))
            (let c2 (cur-advance c 1))
            (bcfwb-score
                (and (cur-eof? c)
                     (and (eq (cur-peek c) (sub 0 1))
                          (eq (cur-pos c2) (cur-pos c))))
                16384)))

    (defn bmf-core-file-window-band ()
        (do
            (let _setup (bcfwb-setup))
            (let score (sum (list
                (bcfwb-bit-surface-file)
                (bcfwb-bit-cursor-file-window)
                (bcfwb-bit-cursor-file-default)
                (bcfwb-bit-lit-a)
                (bcfwb-bit-lit-two-byte-boundary)
                (bcfwb-bit-win2-comment-boundary)
                (bcfwb-bit-skip-comment)
                (bcfwb-bit-parse-after-comment)
                (bcfwb-bit-string-regression)
                (bcfwb-bit-long-slice-assembled)
                (bcfwb-bit-no-read-file-route)
                (bcfwb-bit-central-cursor-row)
                (bcfwb-bit-mirror-parity)
                (bcfwb-bit-byte-cursor-source-still-green)
                (bcfwb-bit-eof-file-window))))
            (let _cleanup (bcfwb-cleanup))
            score))

    (bmf-core-file-window-band))
