                (and (not (scpb-has? text "fs-write-text"))
                (and (not (scpb-has? text "fs-read-text"))
                (and (not (scpb-has? text "read_file_slice"))
                (and (not (scpb-has? text "sha256"))
                     (not (scpb-has? text "fk_run"))))))))))))))))
                536870912)))
    (defn scpb-bit-mirror ()
        (do
            (let text (scpb-read-file-any "form/form-stdlib/source-compiler-persistence.fk"
                                           "../form/form-stdlib/source-compiler-persistence.fk"))
            (scpb-score
                (str_eq text (scpb-read-file-any "grammars/source-compiler-persistence.fk"
                                                  "../grammars/source-compiler-persistence.fk"))
                1073741824)))

    (defn source-compiler-persistence-band ()
        (sum (list
            (scpb-bit-manifest-1)
            (scpb-bit-manifest-2)
            (scpb-bit-reason-manifest)
            (scpb-bit-ready-fkb)
            (scpb-bit-ready-dylib)
            (scpb-bit-route-fkb)
            (scpb-bit-route-dylib)
            (scpb-bit-malformed-emission)
            (scpb-bit-non-emitted)
            (scpb-bit-malformed-bundle)
            (scpb-bit-malformed-source)
            (scpb-bit-source-absent)
            (scpb-bit-source-mismatch)
            (scpb-bit-malformed-fkb)
            (scpb-bit-fkb-absent)
            (scpb-bit-fkb-identity)
            (scpb-bit-fkb-seal)
            (scpb-bit-fkb-tbl)
            (scpb-bit-fkb-route)
            (scpb-bit-dylib-not-expected)
            (scpb-bit-dylib-missing)
            (scpb-bit-malformed-dylib)
            (scpb-bit-dylib-identity)
            (scpb-bit-dylib-policy)
            (scpb-bit-dylib-route)
            (scpb-bit-accessors)
            (scpb-bit-reason-coverage)
            (scpb-bit-reason-missing)
            (scpb-bit-sentinel-triple)
            (scpb-bit-static-boundary)
            (scpb-bit-mirror))))

    (source-compiler-persistence-band))
