; preludes: form-stdlib/core.fk form-stdlib/q6k-dequant.fk
;
; q6k-dequant-band — the Form Q6_K superblock unpack against the gguf reference, on a REAL llama3.2:3b
; superblock (token_embd.weight, the model's actual embedding table — one of the 29 Q6_K tensors that, with
; the 168 Q4_K tensors and 58 F32 tensors, make up the whole model). The fixture is that superblock's raw
; bytes: the f16->f32 super-scale d, the 128 low-nibble bytes (ql), the 64 high-2-bit bytes (qh), and the 16
; SIGNED int8 block-scales (passed raw 0..255; the recipe's q6k-s8 carries the sign). Expected values are
; round(w * 1e6) from gguf.quants.dequantize (cross-checked bit-exact, max_abs_diff 0.0; the kernel's f64
; arithmetic rounds identically to gguf's f32 on every sampled index).
;
; The 12 sample indices span every path of the unpack: both halves (h=0/1), all four sub-groups
; (g=0..3 -> qh shifts 0/2/4/6, scale offsets +0/+2/+4/+6), both nibble halves (low = ql & 0xF for g<2,
; high = ql >> 4 for g>=2), both scale-halves (is = l/16 = 0/1), and signed scales (the many negatives).
;
; Verdict 4095 when all twelve real-weight dequant values land, the last one via the full 256-list walk:
;   1     i=0   h0 g0 is0 low  -> 11215        64    i=96  h0 g3 is0 high -> 28330
;   2     i=31  h0 g0 is1 low  -> -11986       128   i=127 h0 g3 is1 high -> -16449
;   4     i=32  h0 g1 is0 low  -> 21029        256   i=128 h1 g0 is0 low  -> 23832
;   8     i=63  h0 g1 is1 low  -> 22571        512   i=159 h1 g0 is1 low  -> 5970
;   16    i=64  h0 g2 is0 high -> 7944         1024  i=191 h1 g1 is1 low  -> -5666
;   32    i=95  h0 g2 is1 high -> -8960        2048  len(q6k-dequant)=256 AND list[255] -> -21846
(do
    (let d 0.000011682510375976562)
    (let SCALES (list 192 142 156 84 171 59 159 128 171 183 158 97 146 61 77 171))
    (let QL (list 129 67 45 48 246 235 134 149 186 127 28 200 234 116 6 4 49 221 74 254 192 205 18 137
                  34 162 64 213 250 173 64 57 126 163 27 184 54 160 166 158 148 231 71 98 8 92 31 12
                  221 193 69 80 20 103 72 176 235 201 188 123 81 139 162 183 40 198 208 233 142 80 135 134
                  25 169 70 99 147 0 200 106 135 2 231 97 45 177 89 92 55 93 105 158 202 125 1 89 13 118
                  37 32 255 88 100 181 162 50 128 188 42 29 39 252 218 93 46 23 143 250 181 135 239 144 2 33
                  0 129 2 107))
    (let QH (list 17 117 84 164 74 130 149 138 110 222 169 173 162 150 16 197 149 153 182 101 28 105 134 173
                  98 151 170 155 128 98 166 158 216 21 214 81 154 96 101 105 148 106 21 102 149 10 110 148
                  5 36 229 172 106 83 120 9 170 120 154 193 89 46 6 213))
    (let full (q6k-dequant d QL QH SCALES))
    (let c0  (if (eq (round (mul (q6k-at 0   d QL QH SCALES) 1000000.0)) 11215)  1 0))
    (let c1  (if (eq (round (mul (q6k-at 31  d QL QH SCALES) 1000000.0)) -11986) 2 0))
    (let c2  (if (eq (round (mul (q6k-at 32  d QL QH SCALES) 1000000.0)) 21029)  4 0))
    (let c3  (if (eq (round (mul (q6k-at 63  d QL QH SCALES) 1000000.0)) 22571)  8 0))
    (let c4  (if (eq (round (mul (q6k-at 64  d QL QH SCALES) 1000000.0)) 7944)   16 0))
    (let c5  (if (eq (round (mul (q6k-at 95  d QL QH SCALES) 1000000.0)) -8960)  32 0))
    (let c6  (if (eq (round (mul (q6k-at 96  d QL QH SCALES) 1000000.0)) 28330)  64 0))
    (let c7  (if (eq (round (mul (q6k-at 127 d QL QH SCALES) 1000000.0)) -16449) 128 0))
    (let c8  (if (eq (round (mul (q6k-at 128 d QL QH SCALES) 1000000.0)) 23832)  256 0))
    (let c9  (if (eq (round (mul (q6k-at 159 d QL QH SCALES) 1000000.0)) 5970)   512 0))
    (let c10 (if (eq (round (mul (q6k-at 191 d QL QH SCALES) 1000000.0)) -5666)  1024 0))
    (let c11 (if (and (eq (len full) 256)
                      (eq (round (mul (nth full 255) 1000000.0)) -21846)) 2048 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
    (add c8 (add c9 (add c10 c11))))))))))))
