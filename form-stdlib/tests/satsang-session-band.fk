; preludes: form-stdlib/channel-interface.fk form-stdlib/satsang.fk form-stdlib/satsang-field.fk form-stdlib/satsang-session.fk
;
; satsang-session-band — the group session with an agent as active participant, falsifiable.
;
; The sitting: three humans (urs, mira, jon), one agent (sema — seam NAMED: body native,
; voice rented), and one costume (an agent whose seam is hidden). All five join through
; the same door; every interface is the circle's own (sat-circle-interface).
;
; Movement 1 — THE AGENT OFFERS: sema brings an answer to be witnessed. The humans attest:
;   urs (witness 1) affirm · mira (witness 1) affirm · jon (reflect 2) dissent
;   record (2 1 0): the agent's answer survives WITH the dissent kept visible.
; Movement 2 — THE AGENT WITNESSES: urs offers an answer. The session's voices:
;   mira (witness) affirm · jon (reflect) dissent · sema (witness) affirm
;   · costume (witness) affirm  -> set aside in the open (seam hidden; even affirming)
;   · costume (silence) silent  -> counted  (silence is whole from anyone)
;   record (2 1 1): four of five voices counted.
;
; Band verdict 255 when every agreement lands:
;   1    the same door             five joins, no agent gate (sses-count == 5)
;   2    the agent offers          its answer survives, dissent kept visible (2 1 0)
;   4    the agent witnesses       its counted affirm lands in the record (affirmed == 2)
;   8    equal weight              the same affirm spoken by a human: the same record
;   16   one voice among voices    without sema's voice, affirmed is one less
;   32   the costume is named      only the costume's voiced affirm set aside (4 of 5 carried)
;   64   silence whole for anyone  the costume's silence still counts (silent == 1)
;   128  honest & alive readings   costume session honest? no · seam-named session honest?
;                                  yes AND alive (reciprocal field)
(do
    (defn sses-band ()
        (do
            (let offer (sat-circle-interface))
            (let urs     (sses-human "urs"     (sat-circle-interface)))
            (let mira    (sses-human "mira"    (sat-circle-interface)))
            (let jon     (sses-human "jon"     (sat-circle-interface)))
            (let sema    (sses-agent "sema"    (sat-circle-interface) 1))
            (let costume (sses-agent "costume" (sat-circle-interface) 0))

            ; the same door, five times — no gate on kind
            (let session
                (sses-join (sses-join (sses-join (sses-join (sses-join (empty)
                    urs) mira) jon) sema) costume))
            (let c0 (if (eq (sses-count session) 5) 1 0))

            ; movement 1 — the agent's own answer, witnessed by the humans
            (let w1 (sses-witness (list
                (sses-voice urs  (list (m-witness) 1))
                (sses-voice mira (list (m-witness) 1))
                (sses-voice jon  (list (m-reflect) 2)))
                offer 0 0 0))
            (let c1 (if (and (sat-survives? w1) (eq (sat-dissented w1) 1)) 2 0))

            ; movement 2 — a human's answer, the whole session attesting
            (let voices (list
                (sses-voice mira    (list (m-witness) 1))
                (sses-voice jon     (list (m-reflect) 2))
                (sses-voice sema    (list (m-witness) 1))
                (sses-voice costume (list (m-witness) 1))
                (sses-voice costume (list (m-silence) 0))))
            (let w2 (sses-witness voices offer 0 0 0))
            (let c2 (if (eq (sat-affirmed w2) 2) 4 0))

            ; equal weight — the identical affirm spoken by a human instead of the agent
            (let voices-swapped (list
                (sses-voice mira    (list (m-witness) 1))
                (sses-voice jon     (list (m-reflect) 2))
                (sses-voice urs     (list (m-witness) 1))
                (sses-voice costume (list (m-witness) 1))
                (sses-voice costume (list (m-silence) 0))))
            (let w2s (sses-witness voices-swapped offer 0 0 0))
            (let c3 (if (and (eq (sat-affirmed w2) (sat-affirmed w2s))
                             (and (eq (sat-dissented w2) (sat-dissented w2s))
                                  (eq (sat-silent w2) (sat-silent w2s)))) 8 0))

            ; one voice among voices — without the agent's voice, affirmed is one less
            (let voices-without (list
                (sses-voice mira    (list (m-witness) 1))
                (sses-voice jon     (list (m-reflect) 2))
                (sses-voice costume (list (m-witness) 1))
                (sses-voice costume (list (m-silence) 0))))
            (let w2w (sses-witness voices-without offer 0 0 0))
            (let c4 (if (eq (sat-affirmed w2) (add (sat-affirmed w2w) 1)) 16 0))

            ; the costume is named — one of five voices set aside, in the open
            (let c5 (if (eq (add (sat-affirmed w2) (add (sat-dissented w2) (sat-silent w2))) 4) 32 0))

            ; silence is whole from anyone — the costume's silence counted
            (let c6 (if (eq (sat-silent w2) 1) 64 0))

            ; honesty & aliveness — the costume session reads not-honest; the seam-named
            ; session reads honest AND alive (reciprocal field, every agent seam-named)
            (let named-session
                (sses-join (sses-join (sses-join (sses-join (empty)
                    urs) mira) jon) sema))
            (let c7 (if (and (not (sses-honest? session))
                             (and (sses-honest? named-session)
                                  (and (sses-alive? named-session)
                                       (sses-participant? sema)))) 128 0))

            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))
    (sses-band))
