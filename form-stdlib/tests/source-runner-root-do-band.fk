; source-runner-root-do-band.fk -- root do locals after fat preludes.
;
; This catches the 2026-07-03 source-runner bug where a value-bearing
; top-level `(do ...)` inherited parser binding state from earlier prelude
; defns. With core+json+bmf-core loaded first, `s-peek` read back as 5 after
; later lets instead of staying 100.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/bmf-core.fk
;
; Expected: 31

(do
    (let src "12+34")
    (let c0 (cursor-str src))
    (let s-peek (if (str_eq (cur-peek-char c0) "1") 100 0))
    (let c2 (cur-advance c0 2))
    (let s-advance (if (str_eq (cur-peek-char c2) "+") 100 0))
    (let s-sum (add s-peek s-advance))
    (let c5 (cur-advance c0 5))

    (add (if (eq s-peek 100) 1 0)
    (add (if (eq s-advance 100) 2 0)
    (add (if (eq s-sum 200) 4 0)
    (add (if (eq (cur-pos c2) 2) 8 0)
         (if (eq (cur-pos c5) 5) 16 0))))))
