; bmf-grammar-band.fk — proves the recursive grammar engine.
;
; A recursive arithmetic grammar (expr → term → factor → expr) demonstrates
; everything full language grammars need: rule references, recursion, operator
; precedence (mul binds tighter than add), nesting through parentheses, and
; sub-rule node composition. A second grammar proves separator-lists + splice*.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    (defn leaf (s) (intern_trivial_string s))
    (defn add2 (a b) (intern_node (bp "add") (list a b)))
    (defn mul2 (a b) (intern_node (bp "mul") (list a b)))

    ;; recursive, precedence-aware arithmetic — pure data over the engine.
    (let arith (grammar "expr" (list
        (rule3 "expr"
            (p-cap "v" (list "alt" (p-ref "addexpr") (p-ref "term")))
            (t-splice "v"))
        (rule3 "addexpr"
            (list "seq" (p-cap "l" (p-ref "term")) (p-lit "+") (p-cap "r" (p-ref "expr")))
            (t-emit "add" (list (t-splice "l") (t-splice "r"))))
        (rule3 "term"
            (p-cap "v" (list "alt" (p-ref "mulexpr") (p-ref "factor")))
            (t-splice "v"))
        (rule3 "mulexpr"
            (list "seq" (p-cap "l" (p-ref "factor")) (p-lit "*") (p-cap "r" (p-ref "term")))
            (t-emit "mul" (list (t-splice "l") (t-splice "r"))))
        (rule3 "factor"
            (list "alt"
                (list "seq" (p-lit "(") (p-cap "v" (p-ref "expr")) (p-lit ")"))
                (p-cap "v" (p-ref "number")))
            (t-splice "v"))
        (rule3 "number"
            (p-cap "v" (p-run "digit"))
            (t-splice "v")))))

    ;; 1. precedence: 1 + 2 * 3  →  add[1, mul[2,3]]
    (let s-prec
        (if (node_eq (g-parse arith "1 + 2 * 3")
                     (add2 (leaf "1") (mul2 (leaf "2") (leaf "3"))))
            100 0))

    ;; 2. nesting / recursion through parens: ( 1 + 2 ) * 3  →  mul[add[1,2], 3]
    (let s-nest
        (if (node_eq (g-parse arith "( 1 + 2 ) * 3")
                     (mul2 (add2 (leaf "1") (leaf "2")) (leaf "3")))
            100 0))

    ;; 3. separator-list + splice*: "1 , 2 , 3"  →  do[1, 2, 3]
    (let listg (grammar "items" (list
        (rule3 "items"
            (p-cap "xs" (p-sep (p-ref "number") (p-lit ",")))
            (t-emit "do" (list (t-splices "xs"))))
        (rule3 "number" (p-cap "v" (p-run "digit")) (t-splice "v")))))
    (let s-list
        (if (node_eq (g-parse listg "1 , 2 , 3")
                     (intern_node (bp "do") (list (leaf "1") (leaf "2") (leaf "3"))))
            100 0))

    ; Expected total: 300
    (add s-prec (add s-nest s-list)))
