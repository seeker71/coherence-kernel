; bmf-grammar-band.fk -- recursive BMF grammar waist witness.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk
;
; The old monolithic grammar engine exceeded the direct-source AST node table
; before execution. This band proves the smaller layer-3 waist: grammar values,
; named rules, recursive refs, rep/sep, captures, template emit/splice/splice*,
; and honest parse failure. Universal NodeID equality with ontology/source
; attribution is a later integration witness, not this layer gate.
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/bmf-core.fk \
;          form/form-stdlib/bmf-grammar.fk \
;          form/form-stdlib/tests/bmf-grammar-band.fk > /tmp/bmf-grammar.fk
;      ./fkwu --src /tmp/bmf-grammar.fk    ; -> 2047
;
; Bits:
;   1     manifest declares grammar-value
;   2     manifest declares ref-recursion
;   4     manifest declares rep-sep
;   8     manifest declares no-line-grammar invariant
;   16    grammar start/rule lookup work
;   32    recursive arithmetic consumes "1 + 2 * 3"
;   64    nested recursive arithmetic consumes "( 1 + 2 ) * 3"
;   128   sep + splice* emits three children
;   256   rep has a zero-width guard
;   512   manual splice* emits two children
;   1024  parse failure returns the PARSE-FAIL sentinel

(do
    (defn bgl-score (ok bit) (if ok bit 0))
    (defn bgl-leaf (s) (intern_trivial_string s))

    (defn bgl-arith () (grammar "expr" (list
        (rule3 "expr"
            (p-cap "v" (list "alt" (p-ref "addexpr") (p-ref "term")))
            (t-splice "v"))
        (rule3 "addexpr"
            (list "seq" (p-cap "l" (p-ref "term")) (p-lit "+") (p-cap "r" (p-ref "expr")))
            (t-emit "add" (list (t-splice "l") (t-splice "r"))))
        (rule3 "term"
            (p-cap "v" (list "alt" (p-ref "mulexpr") (p-ref "factor")))
            (t-splice "v"))
        (rule3 "mulexpr"
            (list "seq" (p-cap "l" (p-ref "factor")) (p-lit "*") (p-cap "r" (p-ref "term")))
            (t-emit "mul" (list (t-splice "l") (t-splice "r"))))
        (rule3 "factor"
            (list "alt"
                (list "seq" (p-lit "(") (p-cap "v" (p-ref "expr")) (p-lit ")"))
                (p-cap "v" (p-ref "number")))
            (t-splice "v"))
        (rule3 "number" (p-cap "v" (p-run "digit")) (t-splice "v")))))

    (defn bgl-listg () (grammar "items" (list
        (rule3 "items"
            (p-cap "xs" (p-sep (p-ref "number") (p-lit ",")))
            (t-emit "do" (list (t-splices "xs"))))
        (rule3 "number" (p-cap "v" (p-run "digit")) (t-splice "v")))))

    (defn bmf-grammar-language-band ()
        (do
            (let manifest (bmf-grammar-language-manifest))
            (let arith (bgl-arith))
            (let listg (bgl-listg))
            (let rr1 (g-match-rule arith "expr" (cursor-str "1 + 2 * 3")))
            (let rr2 (g-match-rule arith "expr" (cursor-str "( 1 + 2 ) * 3")))
            (let rr3 (g-match-rule listg "items" (cursor-str "1 , 2 , 3")))
            (let mrep (g-match arith (p-rep (p-opt (p-lit "x"))) (cursor-str "") (gc-empty)))
            (let built
                (g-build
                    (t-emit "do" (list (t-splices "xs")))
                    (gc-put (gc-empty) "xs"
                        (nlist (list (bgl-leaf "1") (bgl-leaf "2"))))))
            (sum (list
                (bgl-score (eq (bmf-grammar-manifest-has? "grammar-value" manifest) 1) 1)
                (bgl-score (eq (bmf-grammar-manifest-has? "ref-recursion" manifest) 1) 2)
                (bgl-score (eq (bmf-grammar-manifest-has? "rep-sep" manifest) 1) 4)
                (bgl-score (eq (bmf-grammar-manifest-has? "no-line-grammar" manifest) 1) 8)
                (bgl-score (and (str_eq (g-start arith) "expr")
                                (not (nil? (g-rule arith "number")))) 16)
                (bgl-score (and (rok? rr1) (eq (cur-pos (rok-cur rr1)) 9)) 32)
                (bgl-score (and (rok? rr2) (eq (cur-pos (rok-cur rr2)) 13)) 64)
                (bgl-score (and (rok? rr3)
                                (and (eq (cur-pos (rok-cur rr3)) 9)
                                     (eq (len (node_children (rok-node rr3))) 3))) 128)
                (bgl-score (and (g-ok? mrep)
                                (and (eq (cur-pos (g-cur mrep)) 0)
                                     (eq (len (nlist-items (g-val mrep))) 0))) 256)
                (bgl-score (eq (len (node_children built)) 2) 512)
                (bgl-score (str_eq (node_value (g-parse arith "@")) "PARSE-FAIL") 1024)))))

    (bmf-grammar-language-band))
