; preludes: form-stdlib/jit-tensor-emit.fk
;
; llama-block-fwd-emit-band — the LLAMA DECODER BLOCK FORWARD emitter as recipe, four-way. jte-llama-block-fwd-msl
; authors the Metal kernel for one whole llama-shaped pre-norm block forward over a sequence —
;   n1 = RMSNorm1(x) ; h = x + Wo*attn(RoPE(Wq*n1), RoPE(Wk*n1), Wv*n1, scale) ; n2 = RMSNorm2(h) ;
;   y  = h + Wdown*SwiGLU(Wgate*n2, Wup*n2) — the INFERENCE half of llama-block.fk's lblk-block (proven four-way
; 4095) lowered to the GPU, next to the whisper block (jte-block-fwd-msl, block-fwd-emit-band). It composes the
; recipe's own folds: every dot is tb-dot's downward right-fold split through a named temporary (no fma
; contraction), the value-mix is the forward fold, softmax is tn-softmax's max-subtract over the recipe's own
; fexp, each RMSNorm is the biased mean-square + 50-step Newton sqrt walk, SiLU's sigmoid is fexp, and RoPE's
; sin/cos/pow are trig.fk's own Taylor (fsin/fcos/fln, fpow = fexp(e*fln b)) — never Metal's transcendentals.
; Dims (S tokens, d model, dq query/key, dv value, hid FFN, HD head-dim) arrive as runtime buffers, so the
; emitted source is one static string parameterized only by the kernel name. It COMPILES and RUNS on the M4 Max
; GPU (scripts/metal_llama_block_audit.sh): GPU fp32 bit-exact vs a CPU fp32 mirror of the same folds, tracking
; the proven fp64 recipe within fp32 epsilon — the whole llama block now runs forward on the silicon.
;
; Verdict 7 when the emission lands:
;   1   the full emitted f32 MSL for form_llama_block_fwd_f32 equals the canonical text
;   2   a different name lands in the same frame (emission is a function of the name)
;   4   two emissions of the same name are str_eq (deterministic text — same emission, same cell)
(do
    (let pre "float fexp_small(float x){ float n = 1.0f; float term = 1.0f; float acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } float fexp(float x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } float v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } float ftanh(float x){ float e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } float fgelu(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } float fgelud(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); float th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } float rr_2pi(float x){ float t = 6.283185307179586f; return x - t * round(x / t); } float fsin(float x){ float r = rr_2pi(x); float x2 = r * r; float term = r; float acc = 0.0f; int k = 0; while (k < 10) { acc = acc + term; int m = 2 * (k + 1); float den = float(m * (m + 1)); float nt = term * ((-1.0f * x2) / den); term = nt; k = k + 1; } return acc; } float fcos(float x){ return fsin(x + 1.5707963267948966f); } float fln(float x){ float a = x; int e = 0; while (a >= 2.0f) { a = a * 0.5f; e = e + 1; } while (a < 1.0f) { a = a * 2.0f; e = e - 1; } float z = (a - 1.0f) / (a + 1.0f); float z2 = z * z; float zpow = z; float acc = 0.0f; int j = 0; while (j < 14) { float num = zpow * z2; float den = float(2 * (j + 1) + 1); acc = acc + (num / den); zpow = zpow * z2; j = j + 1; } float lm = 2.0f * (z + acc); return float(e) * 0.6931471805599453f + lm; } float fpow(float b, float e){ if (b <= 0.0f) return 0.0f; return fexp(e * fln(b)); } kernel void ")
    (let post "(device const float* wq [[buffer(0)]], device const float* wk [[buffer(1)]], device const float* wv [[buffer(2)]], device const float* wo [[buffer(3)]], device const float* g1 [[buffer(4)]], device const float* wg [[buffer(5)]], device const float* wu [[buffer(6)]], device const float* wd [[buffer(7)]], device const float* g2 [[buffer(8)]], device const float* x [[buffer(9)]], device float* y [[buffer(10)]], device float* sc [[buffer(11)]], constant uint& S [[buffer(12)]], constant uint& d [[buffer(13)]], constant uint& dq [[buffer(14)]], constant uint& dv [[buffer(15)]], constant uint& hid [[buffer(16)]], constant uint& HD [[buffer(17)]], constant float& scale [[buffer(18)]], constant float& eps [[buffer(19)]], uint gid [[thread_position_in_grid]]) { if (gid != 0u) return; uint oN1 = 0; uint oQ = oN1 + S * d; uint oK = oQ + S * dq; uint oV = oK + S * dq; uint oA = oV + S * dv; uint oH = oA + S * dv; uint oN2 = oH + S * d; uint oSR = oN2 + S * d; uint oE = oSR + S; uint oG = oE + S; uint oU = oG + hid; uint oACT = oU + hid; { uint s = 0; while (s < S) { float ss = 0.0f; uint j = 0; while (j < d) { float xv = x[s * d + j]; float sq = xv * xv; ss = ss + sq; j += 1; } float meansq = ss / float(d); float sdv = meansq + eps; float g = sdv; uint it = 50; while (it > 0) { it -= 1; g = 0.5f * (g + sdv / g); } float inv = 1.0f / g; j = 0; while (j < d) { float nm = x[s * d + j] * inv; sc[oN1 + s * d + j] = nm * g1[j]; j += 1; } s += 1; } } { uint s = 0; while (s < S) { uint r = 0; while (r < dq) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wq[r * d + c] * sc[oN1 + s * d + c]; acc = p + acc; } sc[oQ + s * dq + r] = acc; r += 1; } s += 1; } } { uint s = 0; while (s < S) { uint r = 0; while (r < dq) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wk[r * d + c] * sc[oN1 + s * d + c]; acc = p + acc; } sc[oK + s * dq + r] = acc; r += 1; } s += 1; } } { uint s = 0; while (s < S) { uint r = 0; while (r < dv) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wv[r * d + c] * sc[oN1 + s * d + c]; acc = p + acc; } sc[oV + s * dv + r] = acc; r += 1; } s += 1; } } { uint s = 0; while (s < S) { uint i = 0; while (i + 1u < dq) { uint hd = i % HD; float fr = fpow(10000.0f, (-1.0f * float(hd)) / float(HD)); float a = float(s) * fr; float ca = fcos(a); float sa = fsin(a); float q0 = sc[oQ + s * dq + i]; float q1 = sc[oQ + s * dq + i + 1u]; float t0 = q0 * ca; float t1 = q1 * sa; sc[oQ + s * dq + i] = t0 - t1; float t2 = q0 * sa; float t3 = q1 * ca; sc[oQ + s * dq + i + 1u] = t2 + t3; i += 2u; } s += 1; } } { uint s = 0; while (s < S) { uint i = 0; while (i + 1u < dq) { uint hd = i % HD; float fr = fpow(10000.0f, (-1.0f * float(hd)) / float(HD)); float a = float(s) * fr; float ca = fcos(a); float sa = fsin(a); float q0 = sc[oK + s * dq + i]; float q1 = sc[oK + s * dq + i + 1u]; float t0 = q0 * ca; float t1 = q1 * sa; sc[oK + s * dq + i] = t0 - t1; float t2 = q0 * sa; float t3 = q1 * ca; sc[oK + s * dq + i + 1u] = t2 + t3; i += 2u; } s += 1; } } { uint s = 0; while (s < S) { uint t = 0; while (t < S) { float acc = 0.0f; uint c = dq; while (c > 0) { c -= 1; float p = sc[oQ + s * dq + c] * sc[oK + t * dq + c]; acc = p + acc; } sc[oSR + t] = acc * scale; t += 1; } float mx = sc[oSR + 0]; t = 1; while (t < S) { if (sc[oSR + t] > mx) { mx = sc[oSR + t]; } t += 1; } float sumes = 0.0f; t = 0; while (t < S) { float e = fexp(sc[oSR + t] - mx); sc[oE + t] = e; sumes = sumes + e; t += 1; } float invs = 1.0f / sumes; t = 0; while (t < S) { sc[oSR + t] = sc[oE + t] * invs; t += 1; } uint i = 0; while (i < dv) { sc[oA + s * dv + i] = 0.0f; i += 1; } t = 0; while (t < S) { i = 0; while (i < dv) { float pv = sc[oV + t * dv + i] * sc[oSR + t]; sc[oA + s * dv + i] = sc[oA + s * dv + i] + pv; i += 1; } t += 1; } s += 1; } } { uint s = 0; while (s < S) { uint i = 0; while (i < d) { float acc = 0.0f; uint c = dv; while (c > 0) { c -= 1; float p = wo[i * dv + c] * sc[oA + s * dv + c]; acc = p + acc; } sc[oH + s * d + i] = x[s * d + i] + acc; i += 1; } s += 1; } } { uint s = 0; while (s < S) { float ss = 0.0f; uint j = 0; while (j < d) { float xv = sc[oH + s * d + j]; float sq = xv * xv; ss = ss + sq; j += 1; } float meansq = ss / float(d); float sdv = meansq + eps; float g = sdv; uint it = 50; while (it > 0) { it -= 1; g = 0.5f * (g + sdv / g); } float inv = 1.0f / g; j = 0; while (j < d) { float nm = sc[oH + s * d + j] * inv; sc[oN2 + s * d + j] = nm * g2[j]; j += 1; } s += 1; } } { uint s = 0; while (s < S) { uint k = 0; while (k < hid) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wg[k * d + c] * sc[oN2 + s * d + c]; acc = p + acc; } sc[oG + k] = acc; k += 1; } k = 0; while (k < hid) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wu[k * d + c] * sc[oN2 + s * d + c]; acc = p + acc; } sc[oU + k] = acc; k += 1; } k = 0; while (k < hid) { float gv = sc[oG + k]; float sig = 1.0f / (1.0f + fexp(-1.0f * gv)); float sl = gv * sig; sc[oACT + k] = sl * sc[oU + k]; k += 1; } uint i = 0; while (i < d) { float acc2 = 0.0f; uint kk = hid; while (kk > 0) { kk -= 1; float p2 = wd[i * hid + kk] * sc[oACT + kk]; acc2 = p2 + acc2; } y[s * d + i] = sc[oH + s * d + i] + acc2; i += 1; } s += 1; } } }")
    (let want (str_concat pre (str_concat "form_llama_block_fwd_f32" post)))
    (let got (jte-llama-block-fwd-msl "form_llama_block_fwd_f32"))
    (let other (jte-llama-block-fwd-msl "b2"))
    (let c0 (if (str_eq got want) 1 0))
    (let c1 (if (str_eq other (str_concat pre (str_concat "b2" post))) 2 0))
    (let c2 (if (str_eq (jte-llama-block-fwd-msl "form_llama_block_fwd_f32") got) 4 0))
    (add c0 (add c1 c2)))
