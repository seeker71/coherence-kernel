; preludes: form-stdlib/core.fk form-stdlib/form-ptx.fk
;
; form-ptx-block-band - the exact-block emitters proven three-way: the projection (matvec+bias,
; tb-affine) and the gamma/beta affine (tb-ln-seq's *gamma+beta) PTX are byte-identical across
; kernels. Each is bit-exact on the GPU (native/cuda/form_cuda_ptx_proj_host.c). Split from the
; main form-ptx-band so neither band file outgrows the reference-kernel parser.
;
; Verdict 3 when the emission lands:
;   1   emitted projection PTX for form_proj_f32 equals the canonical template
;   2   emitted gamma/beta PTX for form_affine_gb_f32 equals the canonical template
(do
    (let c0 (if (str_eq (fptx-proj "form_proj_f32") "//\n// form-ptx proj f32: batched projection Y[t] = W . X[t] + b  (tb-affine per token).\n// one thread per (token,out): Y[t*outd+o] = (downward right-fold dot of W[o], X[t]) + b[o].\n//\n.version 8.3\n.target sm_89\n.address_size 64\n\n.visible .entry form_proj_f32(\n    .param .u64 p_w,\n    .param .u64 p_b,\n    .param .u64 p_x,\n    .param .u64 p_y,\n    .param .u32 p_ntok,\n    .param .u32 p_outd,\n    .param .u32 p_ind\n)\n{\n    .reg .pred  %p<2>;\n    .reg .f32   %f<6>;\n    .reg .b32   %r<16>;\n    .reg .b64   %rd<12>;\n\n    ld.param.u64    %rd1, [p_w];\n    ld.param.u64    %rd2, [p_b];\n    ld.param.u64    %rd3, [p_x];\n    ld.param.u64    %rd4, [p_y];\n    ld.param.u32    %r1, [p_ntok];\n    ld.param.u32    %r2, [p_outd];\n    ld.param.u32    %r3, [p_ind];\n    mov.u32         %r4, %ctaid.x;\n    mov.u32         %r5, %ntid.x;\n    mov.u32         %r6, %tid.x;\n    mad.lo.s32      %r7, %r4, %r5, %r6;       // tid\n    mul.lo.s32      %r8, %r1, %r2;            // total = ntok*outd\n    setp.ge.u32     %p1, %r7, %r8;\n    @%p1 bra        DONE;\n    div.u32         %r9, %r7, %r2;            // t = tid/outd\n    rem.u32         %r10, %r7, %r2;           // o = tid%outd\n    mul.lo.s32      %r11, %r10, %r3;          // wbase = o*ind\n    mul.lo.s32      %r12, %r9, %r3;           // xbase = t*ind\n    mov.f32         %f1, 0f00000000;\n    mov.u32         %r13, %r3;                // l = ind\nDOT:\n    setp.eq.u32     %p1, %r13, 0;\n    @%p1 bra        ENDDOT;\n    sub.u32         %r13, %r13, 1;\n    add.s32         %r14, %r11, %r13;\n    mul.wide.u32    %rd5, %r14, 4;\n    add.s64         %rd6, %rd1, %rd5;\n    ld.global.f32   %f2, [%rd6];\n    add.s32         %r15, %r12, %r13;\n    mul.wide.u32    %rd7, %r15, 4;\n    add.s64         %rd8, %rd3, %rd7;\n    ld.global.f32   %f3, [%rd8];\n    mul.f32         %f4, %f2, %f3;\n    add.f32         %f1, %f4, %f1;\n    bra             DOT;\nENDDOT:\n    mul.wide.u32    %rd9, %r10, 4;\n    add.s64         %rd10, %rd2, %rd9;\n    ld.global.f32   %f5, [%rd10];            // b[o]\n    add.f32         %f1, %f1, %f5;\n    mul.wide.u32    %rd11, %r7, 4;\n    add.s64         %rd6, %rd4, %rd11;\n    st.global.f32   [%rd6], %f1;\nDONE:\n    ret;\n}\n") 1 0))
    (let c1 (if (str_eq (fptx-affine-gb "form_affine_gb_f32") "//\n// form-ptx affine-gb f32: y[i][j] = x[i][j] * gamma[j] + beta[j]  (tb-ln-seq's *gamma+beta).\n// one thread per element; gamma/beta are per-channel (length cols).\n//\n.version 8.3\n.target sm_89\n.address_size 64\n\n.visible .entry form_affine_gb_f32(\n    .param .u64 p_x,\n    .param .u64 p_g,\n    .param .u64 p_be,\n    .param .u64 p_y,\n    .param .u32 p_rows,\n    .param .u32 p_cols\n)\n{\n    .reg .pred  %p<2>;\n    .reg .f32   %f<6>;\n    .reg .b32   %r<10>;\n    .reg .b64   %rd<12>;\n\n    ld.param.u64    %rd1, [p_x];\n    ld.param.u64    %rd2, [p_g];\n    ld.param.u64    %rd3, [p_be];\n    ld.param.u64    %rd4, [p_y];\n    ld.param.u32    %r1, [p_rows];\n    ld.param.u32    %r2, [p_cols];\n    mov.u32         %r3, %ctaid.x;\n    mov.u32         %r4, %ntid.x;\n    mov.u32         %r5, %tid.x;\n    mad.lo.s32      %r6, %r3, %r4, %r5;       // tid\n    mul.lo.s32      %r7, %r1, %r2;            // total\n    setp.ge.u32     %p1, %r6, %r7;\n    @%p1 bra        DONE;\n    rem.u32         %r8, %r6, %r2;            // j = tid%cols\n    mul.wide.u32    %rd5, %r6, 4;\n    add.s64         %rd6, %rd1, %rd5;\n    ld.global.f32   %f1, [%rd6];             // x\n    mul.wide.u32    %rd7, %r8, 4;\n    add.s64         %rd8, %rd2, %rd7;\n    ld.global.f32   %f2, [%rd8];             // gamma[j]\n    add.s64         %rd9, %rd3, %rd7;\n    ld.global.f32   %f3, [%rd9];             // beta[j]\n    mul.f32         %f4, %f1, %f2;\n    add.f32         %f5, %f4, %f3;\n    add.s64         %rd10, %rd4, %rd5;\n    st.global.f32   [%rd10], %f5;\nDONE:\n    ret;\n}\n") 2 0))
    (add c0 c1))
