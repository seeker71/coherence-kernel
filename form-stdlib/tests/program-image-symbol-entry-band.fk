; program-image-symbol-entry-band.fk -- Layer 8h8 symbol entry resolver proof.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/program-image-fkb.fk form-stdlib/reason-coverage.fk form-stdlib/program-image-symbol-entry.fk
;
; Expected: 33554431

(do
    (defn piseb-score (ok bit) (if ok bit 0))
    (defn piseb-manifest-has (name)
        (program-image-symbol-entry-manifest-has? name (program-image-symbol-entry-manifest)))
    (defn piseb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn piseb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))
    (defn piseb-none-of? (text needles)
        (if (nil? needles)
            1
            (if (piseb-has? text (head needles))
                0
                (piseb-none-of? text (tail needles)))))

    (defn piseb-table ()
        (pif-table-image 2
                         (list 0 3)
                         4
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 1 7 0 0)
                               (pif-node-row 1 35 0 0)
                               (pif-node-row 3 1 2 0))
                         0
                         (empty)))
    (defn piseb-duplicate-root-table ()
        (pif-table-image 3
                         (list 0 0 3)
                         4
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 1 7 0 0)
                               (pif-node-row 1 35 0 0)
                               (pif-node-row 3 1 2 0))
                         0
                         (empty)))
    (defn piseb-symbol-rows ()
        (list (pif-symbol-row 0 "core/main")
              (pif-symbol-row 1 "core/add")
              (pif-symbol-row 2 "core/local-literal")
              (pif-symbol-row 3 "core/orphan")))
    (defn piseb-duplicate-key-symbol-rows ()
        (list (pif-symbol-row 0 "dup")
              (pif-symbol-row 1 "dup")
              (pif-symbol-row 2 "core/local-literal")
              (pif-symbol-row 3 "core/orphan")))
    (defn piseb-node-symbol-rows ()
        (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 3)))
              (pif-node-symbol-row 1 2 (empty))
              (pif-node-symbol-row 3 1 (empty))))
    (defn piseb-anonymous-node-symbol-rows ()
        (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 3)))
              (pif-node-symbol-row 1 2 (empty))
              (pif-node-symbol-row 2 (sub 0 1) (empty))
              (pif-node-symbol-row 3 1 (empty))))
    (defn piseb-symbol-image ()
        (pif-symbol-image 4 (piseb-symbol-rows) 3 (piseb-node-symbol-rows)))
    (defn piseb-duplicate-key-symbol-image ()
        (pif-symbol-image 4 (piseb-duplicate-key-symbol-rows) 3 (piseb-node-symbol-rows)))
    (defn piseb-anonymous-symbol-image ()
        (pif-symbol-image 4 (piseb-symbol-rows) 4 (piseb-anonymous-node-symbol-rows)))
    (defn piseb-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   1
                                   (piseb-table)
                                   (piseb-symbol-image)))
    (defn piseb-invalid-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   0
                                   (piseb-table)
                                   (piseb-symbol-image)))
    (defn piseb-duplicate-key-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   1
                                   (piseb-table)
                                   (piseb-duplicate-key-symbol-image)))
    (defn piseb-duplicate-root-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   1
                                   (piseb-duplicate-root-table)
                                   (piseb-symbol-image)))
    (defn piseb-anonymous-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   1
                                   (piseb-table)
                                   (piseb-anonymous-symbol-image)))

    (defn piseb-resolve (request) (pise-resolve (piseb-envelope) request))
    (defn piseb-reason (resolution) (pise-resolution-reason resolution))
    (defn piseb-status (resolution) (pise-resolution-status resolution))

    (defn piseb-bit-manifest-1 ()
        (piseb-score
            (and (eq (piseb-manifest-has "layer-8h8-symbol-entry-resolver") 1)
            (and (eq (piseb-manifest-has "pure-pif-metadata-resolution") 1)
            (and (eq (piseb-manifest-has "embedded-fkb-symbol-truth-only") 1)
            (and (eq (piseb-manifest-has "symbol-id-request") 1)
            (and (eq (piseb-manifest-has "canonical-key-request") 1)
            (and (eq (piseb-manifest-has "id-key-agreement-request") 1)
                 (eq (piseb-manifest-has "diagnostic-node-request-not-calling-surface") 1)))))))
            1))
    (defn piseb-bit-manifest-2 ()
        (piseb-score
            (and (eq (piseb-manifest-has "canonical-key-must-be-unambiguous") 1)
            (and (eq (piseb-manifest-has "node-symbol-row-required") 1)
            (and (eq (piseb-manifest-has "non-anonymous-defined-symbol-required") 1)
            (and (eq (piseb-manifest-has "defined-node-must-be-unique-function-root") 1)
            (and (eq (piseb-manifest-has "dependency-targets-carried-not-walked") 1)
            (and (eq (piseb-manifest-has "no-presentation-lens-authority") 1)
            (and (eq (piseb-manifest-has "no-artifact-io") 1)
            (and (eq (piseb-manifest-has "no-execution-or-trace-production") 1)
            (and (eq (piseb-manifest-has "no-generated-table-authority") 1)
                 (eq (piseb-manifest-has "no-host-seed-growth") 1))))))))))
            2))
    (defn piseb-bit-version-row ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id 0)))
            (piseb-score
                (and (str_eq (pise-version) "program-image-symbol-entry-v1")
                (and (pise-resolution? r)
                (and (str_eq (piseb-status r) (pise-status-ready))
                     (str_eq (piseb-reason r) (pise-reason-ready)))))
                4)))
    (defn piseb-bit-by-id-main ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id 0)))
            (piseb-score
                (and (eq (pise-resolution-symbol-id r) 0)
                (and (str_eq (pise-resolution-canonical-key r) "core/main")
                (and (eq (pise-resolution-entry-index r) 0)
                     (eq (pise-resolution-root-node r) 0))))
                8)))
    (defn piseb-bit-by-key-nonzero-entry ()
        (do
            (let r (piseb-resolve (pise-request-by-canonical-key "core/add")))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-ready))
                (and (eq (pise-resolution-symbol-id r) 1)
                (and (eq (pise-resolution-entry-index r) 1)
                     (eq (pise-resolution-root-node r) 3))))
                16)))
    (defn piseb-bit-id-key-agrees ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id-key 1 "core/add")))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-ready))
                (and (eq (pise-resolution-symbol-id r) 1)
                     (str_eq (pise-resolution-canonical-key r) "core/add")))
                32)))
    (defn piseb-bit-dependency-target-preserved ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id 0)))
            (let deps (pise-resolution-dependency-targets r))
            (piseb-score
                (and (eq (len deps) 1)
                (and (eq (pif-symbol-dependency-target-symbol (head deps)) 1)
                     (eq (pif-symbol-dependency-target-node (head deps)) 3)))
                64)))
    (defn piseb-bit-diagnostic-node ()
        (do
            (let r (piseb-resolve (pise-diagnostic-request-by-node 3)))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-ready))
                (and (eq (pise-resolution-symbol-id r) 1)
                (and (eq (pise-resolution-entry-index r) 1)
                     (eq (pise-resolution-root-node r) 3))))
                128)))
    (defn piseb-bit-invalid-pif ()
        (do
            (let r (pise-resolve (piseb-invalid-envelope) (pise-request-by-symbol-id 0)))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-refused))
                     (str_eq (piseb-reason r) (pise-reason-invalid-pif)))
                256)))
    (defn piseb-bit-malformed-request ()
        (do
            (let a (piseb-resolve (list "bad-request")))
            (let b (piseb-resolve (pise-request "unknown-mode" 0 "" (sub 0 1))))
            (piseb-score
                (and (str_eq (piseb-reason a) (pise-reason-malformed-request))
                     (str_eq (piseb-reason b) (pise-reason-malformed-request)))
                512)))
    (defn piseb-bit-invalid-symbol-id ()
        (do
            (let a (piseb-resolve (pise-request-by-symbol-id (sub 0 1))))
            (let b (piseb-resolve (pise-request-by-symbol-id 4)))
            (piseb-score
                (and (str_eq (piseb-reason a) (pise-reason-invalid-symbol-id))
                     (str_eq (piseb-reason b) (pise-reason-invalid-symbol-id)))
                1024)))
    (defn piseb-bit-empty-and-missing-key ()
        (do
            (let a (piseb-resolve (pise-request-by-canonical-key "")))
            (let b (piseb-resolve (pise-request-by-canonical-key "core/missing")))
            (piseb-score
                (and (str_eq (piseb-reason a) (pise-reason-empty-canonical-key))
                     (str_eq (piseb-reason b) (pise-reason-canonical-key-not-found)))
                2048)))
    (defn piseb-bit-duplicate-key ()
        (do
            (let r (pise-resolve (piseb-duplicate-key-envelope) (pise-request-by-canonical-key "dup")))
            (piseb-score
                (and (pif-envelope-valid? (piseb-duplicate-key-envelope))
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-duplicate-canonical-key))))
                4096)))
    (defn piseb-bit-id-key-mismatch ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id-key 0 "core/add")))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-symbol-id-key-mismatch)))
                8192)))
    (defn piseb-bit-symbol-not-defined ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id 3)))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-symbol-not-defined-by-node)))
                16384)))
    (defn piseb-bit-defined-node-not-root ()
        (do
            (let r (piseb-resolve (pise-request-by-symbol-id 2)))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-defined-node-not-function-root)))
                32768)))
    (defn piseb-bit-duplicate-root ()
        (do
            (let r (pise-resolve (piseb-duplicate-root-envelope) (pise-request-by-symbol-id 0)))
            (piseb-score
                (and (pif-envelope-valid? (piseb-duplicate-root-envelope))
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-duplicate-function-root))))
                65536)))
    (defn piseb-bit-node-out-of-range ()
        (do
            (let r (piseb-resolve (pise-diagnostic-request-by-node 9)))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-refused))
                     (str_eq (piseb-reason r) (pise-reason-node-id-out-of-range)))
                131072)))
    (defn piseb-bit-node-symbol-row-not-found ()
        (do
            (let r (piseb-resolve (pise-diagnostic-request-by-node 2)))
            (piseb-score
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-node-symbol-row-not-found)))
                262144)))
    (defn piseb-bit-anonymous-node ()
        (do
            (let r (pise-resolve (piseb-anonymous-envelope) (pise-diagnostic-request-by-node 2)))
            (piseb-score
                (and (pif-envelope-valid? (piseb-anonymous-envelope))
                (and (str_eq (piseb-status r) (pise-status-investigate))
                     (str_eq (piseb-reason r) (pise-reason-anonymous-node))))
                524288)))

    (defn piseb-forbidden-needles ()
        (list "pifbd" "rale-" "rpiwt" "rpmw" "rpifa" "rpifc" "rpiftc"
              ".tbl" "table-text" "program-image-tbl-emit"
              "pif-table-numeric-stream" "read_file" "write_file"
              "recipe_to_bytes" "bytes_to_recipe" "fk_run" "form-eval"
              "dlopen" "bp_table" "bpTable" "BP_TABLE"))
    (defn piseb-bit-static-source ()
        (do
            (let text (piseb-read-file-any "form/form-stdlib/program-image-symbol-entry.fk"
                                           "../form/form-stdlib/program-image-symbol-entry.fk"))
            (piseb-score (piseb-none-of? text (piseb-forbidden-needles)) 1048576)))
    (defn piseb-bit-mirror ()
        (do
            (let text (piseb-read-file-any "form/form-stdlib/program-image-symbol-entry.fk"
                                           "../form/form-stdlib/program-image-symbol-entry.fk"))
            (let grammar (piseb-read-file-any "grammars/program-image-symbol-entry.fk"
                                              "../grammars/program-image-symbol-entry.fk"))
            (piseb-score (str_eq text grammar) 2097152)))
    (defn piseb-bit-architecture-and-receipt ()
        (do
            (let arch (piseb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (piseb-read-file-any "../receipts/2026-07-04-program-image-symbol-entry-layer-review.md"
                                              "receipts/2026-07-04-program-image-symbol-entry-layer-review.md"))
            (piseb-score
                (and (piseb-has? arch "8h8. Program-image symbol entry resolver")
                (and (piseb-has? arch "embedded executable symbol truth to a unique function-root entry")
                (and (piseb-has? receipt "Layer 8h8")
                (and (piseb-has? receipt "pure PIF metadata resolver")
                (and (piseb-has? receipt "not 9h6")
                     (piseb-has? receipt "duplicate canonical-key"))))))
                4194304)))
    (defn piseb-observed-reasons ()
        (list
            (piseb-reason (piseb-resolve (pise-request-by-symbol-id 0)))
            (piseb-reason (pise-resolve (piseb-invalid-envelope) (pise-request-by-symbol-id 0)))
            (piseb-reason (piseb-resolve (list "bad-request")))
            (piseb-reason (piseb-resolve (pise-request-by-symbol-id (sub 0 1))))
            (piseb-reason (piseb-resolve (pise-request-by-canonical-key "")))
            (piseb-reason (piseb-resolve (pise-request-by-canonical-key "core/missing")))
            (piseb-reason (pise-resolve (piseb-duplicate-key-envelope) (pise-request-by-canonical-key "dup")))
            (piseb-reason (piseb-resolve (pise-request-by-symbol-id-key 0 "core/add")))
            (piseb-reason (piseb-resolve (pise-request-by-symbol-id 3)))
            (piseb-reason (piseb-resolve (pise-diagnostic-request-by-node 9)))
            (piseb-reason (piseb-resolve (pise-diagnostic-request-by-node 2)))
            (piseb-reason (pise-resolve (piseb-anonymous-envelope) (pise-diagnostic-request-by-node 2)))
            (piseb-reason (piseb-resolve (pise-request-by-symbol-id 2)))
            (piseb-reason (pise-resolve (piseb-duplicate-root-envelope) (pise-request-by-symbol-id 0)))))
    (defn piseb-bit-reason-coverage ()
        (do
            (let c (rcov-coverage (pise-reason-manifest) (piseb-observed-reasons)))
            (piseb-score (rcov-covered? c) 8388608)))
    (defn piseb-bit-diagnostic-not-normal ()
        (piseb-score
            (and (eq (piseb-manifest-has "diagnostic-node-request-not-calling-surface") 1)
            (and (str_eq (pise-request-mode (pise-request-by-symbol-id 0)) (pise-mode-symbol-id))
            (and (str_eq (pise-request-mode (pise-request-by-canonical-key "core/main")) (pise-mode-canonical-key))
                 (str_eq (pise-request-mode (pise-diagnostic-request-by-node 0)) (pise-mode-diagnostic-node)))))
            16777216))

    (defn program-image-symbol-entry-band ()
        (sum (list
            (piseb-bit-manifest-1)
            (piseb-bit-manifest-2)
            (piseb-bit-version-row)
            (piseb-bit-by-id-main)
            (piseb-bit-by-key-nonzero-entry)
            (piseb-bit-id-key-agrees)
            (piseb-bit-dependency-target-preserved)
            (piseb-bit-diagnostic-node)
            (piseb-bit-invalid-pif)
            (piseb-bit-malformed-request)
            (piseb-bit-invalid-symbol-id)
            (piseb-bit-empty-and-missing-key)
            (piseb-bit-duplicate-key)
            (piseb-bit-id-key-mismatch)
            (piseb-bit-symbol-not-defined)
            (piseb-bit-defined-node-not-root)
            (piseb-bit-duplicate-root)
            (piseb-bit-node-out-of-range)
            (piseb-bit-node-symbol-row-not-found)
            (piseb-bit-anonymous-node)
            (piseb-bit-static-source)
            (piseb-bit-mirror)
            (piseb-bit-architecture-and-receipt)
            (piseb-bit-reason-coverage)
            (piseb-bit-diagnostic-not-normal))))

    (program-image-symbol-entry-band))
