; preludes: form-stdlib/geometric-learning.fk form-stdlib/metabolic-learning.fk form-stdlib/diffusion-q-learning.fk form-stdlib/champion-challenger.fk form-stdlib/diffusion-q-cc.fk
;
; diffusion-q-cc-band — the diffusion-Q policy wired into champion-challenger, VALUE-NATIVE, four-way.
; QAM's offline→online regime: a served champion policy reaches value Q=2.5; a challenger starts raw
; (Q=0) and earns authority ONLY by the Q-tilt. The competition compares REAL FLOAT VALUE (summed Q
; over the window), with real float ordering (ge/gt) — not a binary count. dql-improve is the move
; that raises the value; cc-val-promote? is the gate. Registered `fks` (carries float literals).
;
; Verdict 63 when every claim lands:
;   1   the raw challenger (Q=0) is behind on value → the champion keeps authority
;   2   a SUFFICIENT Q-tilt (focus 1/2, Q→2.5) reaches the champion's value → PROMOTED, authority flips
;   4   the trusted-window gate: reaching value on a SHORT window (< min-samples) is NOT promoted
;   8   an INSUFFICIENT Q-tilt (focus 1/8, Q→0.625) has not reached the value → still behind, not promoted
;   16  strict beat: a challenger that OVERSHOOTS (focus 3/4, Q→3.75) cc-val-exceeds; a tie (Q=2.5) does not
;   32  the margin is REAL-VALUED: the weak challenger reaches with slack 18.75 but not with slack 0
(do
    ; the critic Q(a) = 2·a0 + 1·a1; a one-hot context makes policy params BE the action
    (let qedges (list (list 0 0 2.0) (list 0 1 1.0)))
    (let x      (list 1.0 0.0))

    ; the served CHAMPION already reaches value 2.5: a = [1 0.5]
    (let champ (list (list 0 0 1.0) (list 1 0 0.5)))
    ; the CHALLENGER starts raw: a = [0 0], value 0
    (let raw   (list (list 0 0 0.0) (list 1 0 0.0)))

    ; train the challenger by the Q-tilt — the online move that raises its value
    (let good   (dqcc-improve qedges raw x 0.5))    ; Q → 2.5 (reaches the champion)
    (let weak   (dqcc-improve qedges raw x 0.125))  ; Q → 0.625 (has not reached)
    (let strong (dqcc-improve qedges raw x 0.75))   ; Q → 3.75 (overshoots — strictly exceeds)

    ; value windows of 10 identical-context trials (each trial a real (champ-Q chall-Q) pair)
    (let w-raw    (dqcc-window qedges champ raw    x 10))   ; chall value 0   → behind
    (let w-good   (dqcc-window qedges champ good   x 10))   ; chall value 2.5 → ties / reaches
    (let w-weak   (dqcc-window qedges champ weak   x 10))   ; chall value 0.625 → behind
    (let w-strong (dqcc-window qedges champ strong x 10))   ; chall value 3.75 → strictly exceeds
    (let w-good3  (dqcc-window qedges champ good   x 3))    ; reaches, but window too short to trust

    (let c0 (if (and (eq (cc-val-promote? w-raw 10 0.0) 0)
                     (str_eq (cc-val-authority w-raw 10 0.0) "champion")) 1 0))
    (let c1 (if (and (eq (cc-val-promote? w-good 10 0.0) 1)
                     (str_eq (cc-val-authority w-good 10 0.0) "challenger")) 2 0))
    (let c2 (if (and (eq (cc-val-promote? w-good3 10 0.0) 0)
                     (str_eq (cc-val-authority w-good3 10 0.0) "champion")) 4 0))
    (let c3 (if (and (eq (cc-val-promote? w-weak 10 0.0) 0)
                     (str_eq (cc-val-authority w-weak 10 0.0) "champion")) 8 0))
    (let c4 (if (and (eq (cc-val-exceeds? w-strong) 1)
                     (eq (cc-val-exceeds? w-good) 0)) 16 0))
    (let c5 (if (and (eq (cc-val-reaches? w-weak 18.75) 1)
                     (eq (cc-val-reaches? w-weak 0.0) 0)) 32 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 c5))))))
