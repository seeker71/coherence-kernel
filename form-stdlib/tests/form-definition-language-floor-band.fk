; form-definition-language-floor-band.fk -- executable floor target for FDL.
;
; This is the low-level source shape that form-definition-language lowers to:
; top-level module constants and top-level functions, not a wrapped `(do ...)`.
;
; Expected: 10

(let rows (list 8 13 21))
(defn bump (x) (add x 1))
(defn first () (head rows))
(add (bump 1) (first))
