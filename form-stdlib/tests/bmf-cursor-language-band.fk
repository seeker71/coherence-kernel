; bmf-cursor-language-band.fk -- BMF cursor layer without line grammar.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk
;
; This is the layer-appropriate language abstraction above core: a streaming,
; scannerless cursor over a surface, with patterns as data. It deliberately
; does not import line-grammar, tokenizers, form-ontology, json, or cache.
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/bmf-core.fk \
;          form/form-stdlib/tests/bmf-cursor-language-band.fk > /tmp/bmf-cursor.fk
;      ./fkwu --src /tmp/bmf-cursor.fk    ; -> 1023
;
; Bits:
;   1    manifest declares scannerless
;   2    manifest declares streaming-cursor
;   4    manifest declares no-token-stream invariant
;   8    manifest declares no-line-grammar invariant
;   16   cursor peeks the first byte/codepoint of the surface
;   32   advance returns a new cursor and leaves the old cursor at pos 0
;   64   digit run capture consumes "12" and ends at pos 2
;   128  alternation backtracks with no sediment on the source cursor
;   256  checkpoint/restore returns to the saved coordinate
;   512  base codepoint predicates are live in BMF core

(do
    (defn bcl-score (ok bit) (if ok bit 0))
    (defn bmf-cursor-language-band ()
        (do
            (let manifest (bmf-cursor-language-manifest))
            (let c0 (cursor-str "12+34"))
            (let c2 (cur-advance c0 2))
            (let mrun (match-pat (list "cap" "l" (list "run" "digit")) c0 (caps-empty)))
            (let alt (list "alt"
                           (list "seq" (list "lit" "12") (list "lit" "X"))
                           (list "lit" "12")))
            (let malt (match-pat alt c0 (caps-empty)))
            (let saved (cur-checkpoint c0))
            (let moved (cur-advance saved 3))
            (let back (cur-restore saved))
            (let c00 (bcl-score (eq (bmf-manifest-has? "scannerless" manifest) 1) 1))
            (let c01 (bcl-score (eq (bmf-manifest-has? "streaming-cursor" manifest) 1) 2))
            (let c02 (bcl-score (eq (bmf-manifest-has? "no-token-stream" manifest) 1) 4))
            (let c03 (bcl-score (eq (bmf-manifest-has? "no-line-grammar" manifest) 1) 8))
            (let c04 (bcl-score (eq (cur-peek c0) 49) 16))
            (let c05 (bcl-score (and (eq (cur-peek c2) 43) (eq (cur-pos c0) 0)) 32))
            (let c06 (bcl-score
                (and (m-ok? mrun)
                     (and (str_eq (caps-get (m-caps mrun) "l") "12")
                          (eq (cur-pos (m-cur mrun)) 2))) 64))
            (let c07 (bcl-score
                (and (m-ok? malt)
                     (and (eq (cur-pos (m-cur malt)) 2)
                          (eq (cur-pos c0) 0))) 128))
            (let c08 (bcl-score (and (eq (cur-pos moved) 3) (eq (cur-pos back) 0)) 256))
            (let c09 (bcl-score
                (and (is-digit-cp 48)
                     (and (is-alpha-cp 65)
                          (and (is-ident-cont-cp 63)
                               (is-ws-cp 32)))) 512))
            (add c00 (add c01 (add c02 (add c03 (add c04 (add c05 (add c06 (add c07 (add c08 c09)))))))))))

    (bmf-cursor-language-band))
