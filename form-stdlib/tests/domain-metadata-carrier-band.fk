; domain-metadata-carrier-band.fk -- attributes as metadata cargo.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/domain-grammar-core.fk form-stdlib/domain-metadata-carrier.fk
;
; Expected: 32767

(do
    (defn dmattrb-score (ok bit) (if ok bit 0))
    (defn dmattrb-manifest-has (name)
        (domain-metadata-carrier-manifest-has? name (domain-metadata-carrier-manifest)))
    (defn dmattrb-bml ()
        (dmattr-parse-row "@ bml class capability host:file"))
    (defn dmattrb-python ()
        (dmattr-parse-row "@ python function decorator lru_cache"))
    (defn dmattrb-rust ()
        (dmattr-parse-row "@ rust item derive Debug"))
    (defn dmattrb-bad ()
        (dmattr-parse-node "@ bml class capability host:file trailing"))
    (defn dmattrb-domain ()
        (dgcore-programming-domain))
    (defn dmattrb-bundle ()
        (dmattr-domain-bundle
            (dmattrb-domain)
            (list
                (dmattrb-bml)
                (dmattr-python-decorator "function" "lru_cache"))))
    (defn dmattrb-node ()
        (dgcore-parse (dgcore-domain-registry) "programming" "return 13"))
    (defn dmattrb-annotated ()
        (dmattr-annotated-node
            (dmattrb-node)
            (list (dmattrb-bml) (dmattrb-rust))))

    (defn domain-metadata-carrier-band ()
        (sum (list
            (dmattrb-score (eq (dmattrb-manifest-has "scannerless") 1) 1)
            (dmattrb-score (eq (dmattrb-manifest-has "attribute-surface") 1) 2)
            (dmattrb-score (eq (dmattrb-manifest-has "carrier-language-preserved") 1) 4)
            (dmattrb-score (eq (dmattrb-manifest-has "scope-key-value-row") 1) 8)
            (dmattrb-score (eq (dmattrb-manifest-has "domain-rule-capture-node-scopes") 1) 16)
            (dmattrb-score (eq (dmattrb-manifest-has "bml-attribute-example") 1) 32)
            (dmattrb-score (eq (dmattrb-manifest-has "decorator-annotation-compatible") 1) 64)
            (dmattrb-score (eq (dmattrb-manifest-has "metadata-bundle") 1) 128)
            (dmattrb-score (eq (dmattrb-manifest-has "annotated-node-wrapper") 1) 256)
            (dmattrb-score (eq (dmattrb-manifest-has "semantic-lane-compatible") 1) 512)
            (dmattrb-score (and (str_eq (dmattr-carrier (dmattrb-bml)) "bml")
                                (str_eq (dmattr-value (dmattrb-bml)) "host:file")) 1024)
            (dmattrb-score (and (str_eq (dmattr-key (dmattrb-python)) "decorator")
                                (str_eq (dmattr-value (dmattrb-python)) "lru_cache")) 2048)
            (dmattrb-score (and (str_eq (dmattr-carrier (dmattrb-rust)) "rust")
                                (str_eq (dmattr-key (dmattrb-rust)) "derive")) 4096)
            (dmattrb-score (not (dmattr-node-ok? (dmattrb-bad))) 8192)
            (dmattrb-score
                (and (dmattr-bundle? (dmattrb-bundle))
                (and (eq (dmattr-bundle-count (dmattrb-bundle)) 6)
                (and (dmattr-has? (dmattr-bundle-attrs (dmattrb-bundle))
                        "domain-grammar" "domain" "semantic-lane" "semantic-stdlib")
                (and (dmattr-has? (dmattr-bundle-attrs (dmattrb-bundle))
                        "bml" "class" "capability" "host:file")
                (and (dmattr-annotated-node? (dmattrb-annotated))
                (and (str_eq (dgcore-node-tag (dmattr-annotated-node-value (dmattrb-annotated)))
                        "__prog_return__")
                     (eq (len (dmattr-annotated-node-attrs (dmattrb-annotated))) 2)))))))
                16384))))

    (domain-metadata-carrier-band)
)
