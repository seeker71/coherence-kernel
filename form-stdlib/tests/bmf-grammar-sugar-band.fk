; bmf-grammar-sugar-band.fk -- literal sugar and typed template helpers.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk
;
; Expected: 63

(do
  (defn s (ok bit) (if ok bit 0))
  (let g (grammar "v" (list
    (rule3 "v" (p-cap "x" (list "alt" (p-str) (p-char) (p-num))) (t-splice "x"))
    (rule3 "i" (p-cap "x" (p-num)) (t-splice-int "x"))
    (rule3 "ci" (p-lit "ci") (t-const-int 7))
    (rule3 "bt" (p-lit "bt") (t-const-bool 1)))))
  (let a (g-parse-full g "\"x\""))
  (let b (g-parse-full g "'q'"))
  (let c (g-parse-full g "3.14"))
  (let d (g-match-full-rule g "i" (cursor-str "42")))
  (let e (g-match-full-rule g "ci" (cursor-str "ci")))
  (let f (g-match-full-rule g "bt" (cursor-str "bt")))
  (sum (list
    (s (str_eq (node_value a) "x") 1)
    (s (str_eq (node_value b) "q") 2)
    (s (str_eq (node_value c) "3.14") 4)
    (s (and (rok? d) (eq (node_value (rok-node d)) 42)) 8)
    (s (and (rok? e) (eq (node_value (rok-node e)) 7)) 16)
    (s (and (rok? f) (node_eq (rok-node f) (make_nodeid 1 1 3 1))) 32))))
