; runtime-artifact-load-envelope-band.fk -- Layer 9e load envelope witness.
;
; Expected: 2147483647
;
; This band proves request-envelope construction over selected 9b rows,
; retry-ready 9d rows, and descriptor bundles. It does not read disk, hash
; bytes, reverify seals/proofs/callability, generate observations, load or walk
; `.fkb`, load or call `.dylib`, execute fallbacks, emit compiler output,
; install a selector, or grow the C seed.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk

(do
    (defn raleb-score (ok bit) (if ok bit 0))
    (defn raleb-manifest-has (name)
        (runtime-artifact-load-envelope-manifest-has? name (runtime-artifact-load-envelope-manifest)))

    (defn raleb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn raleb-source-invalid () (sad-source "" "sha:src-a" 100))
    (defn raleb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn raleb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn raleb-native-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh))))
    (defn raleb-fkb-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raleb-source) (raleb-fkb-fresh) (sad-no-artifact))))
    (defn raleb-compile-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raleb-source) (sad-no-artifact) (sad-no-artifact))))
    (defn raleb-investigate-selection ()
        (ras-selection (sad-route-invalid) (rap-act-investigate) (rap-act-none) (ras-status-investigate) 0 0 (ras-reason-upstream-investigate)))
    (defn raleb-refused-selection ()
        (ras-selection (sad-route-invalid) (rap-act-none) (rap-act-none) (ras-status-refused) 0 0 (ras-reason-malformed-plan)))
    (defn raleb-unknown-status-selection ()
        (ras-selection (sac-run-fkb) (rap-act-run-program-image) (rap-act-compile-source) "unknown-selection-status" 1 0 "unknown"))
    (defn raleb-outcome (selection status)
        (rao-outcome-from-selection-observation selection
            (rao-run-observation (ras-selection-selected selection) status "detail" 7)))
    (defn raleb-native-soft-retry ()
        (rar-retry-from-outcome (raleb-outcome (raleb-native-selection) (rao-obs-loader-missing))))
    (defn raleb-fkb-soft-retry ()
        (rar-retry-from-outcome (raleb-outcome (raleb-fkb-selection) (rao-obs-error))))
    (defn raleb-native-ok-retry ()
        (rar-retry-from-outcome (raleb-outcome (raleb-native-selection) (rao-obs-ok))))
    (defn raleb-native-waiting-retry ()
        (rar-retry-from-outcome (rao-outcome-from-selection (raleb-native-selection))))

    (defn raleb-status? (e status) (str_eq (rale-envelope-status e) status))
    (defn raleb-reason? (e reason) (str_eq (rale-envelope-reason e) reason))
    (defn raleb-ready? (e) (raleb-status? e (rale-status-request-ready)))
    (defn raleb-investigate? (e) (raleb-status? e (rale-status-investigate)))
    (defn raleb-refused? (e) (raleb-status? e (rale-status-refused)))
    (defn raleb-no-compile-output? (e) (rale-no-compile-output? (rale-envelope-compile-output e)))
    (defn raleb-direct-provenance? (e)
        (rale-no-retry? (rale-envelope-retry e)))
    (defn raleb-retry-provenance? (e)
        (rar-retry? (rale-envelope-retry e)))

    (defn raleb-bit-manifest-1 ()
        (sum (list
            (raleb-score (eq (raleb-manifest-has "load-envelope-not-execution") 1) 1)
            (raleb-score (eq (raleb-manifest-has "identity-rejoin-via-sad-route-equality") 1) 2)
            (raleb-score (eq (raleb-manifest-has "bundle-route-must-match-selection-route") 1) 4)
            (raleb-score (eq (raleb-manifest-has "selection-or-retry-provenance") 1) 8)
            (raleb-score (eq (raleb-manifest-has "retry-inherits-next-selection-route") 1) 16)
            (raleb-score (eq (raleb-manifest-has "compile-source-uses-envelope-output-sentinel") 1) 32)
            (raleb-score (eq (raleb-manifest-has "request-ready-is-not-load-success") 1) 64)
            (raleb-score (eq (raleb-manifest-has "no-rap-plan-consumption") 1) 128))))

    (defn raleb-bit-manifest-2 ()
        (sum (list
            (raleb-score (eq (raleb-manifest-has "no-plan-coherence-rederivation") 1) 256)
            (raleb-score (eq (raleb-manifest-has "no-route-preference-or-fallback-policy") 1) 512)
            (raleb-score (eq (raleb-manifest-has "no-disk-io") 1) 1024)
            (raleb-score (eq (raleb-manifest-has "no-byte-hashing") 1) 2048)
            (raleb-score (eq (raleb-manifest-has "no-seal-proof-callable-reverify") 1) 4096)
            (raleb-score (eq (raleb-manifest-has "no-observation-generation") 1) 8192)
            (raleb-score (eq (raleb-manifest-has "no-runtime-load-walk-call-exec") 1) 16384)
            (raleb-score (eq (raleb-manifest-has "no-admission-policy-or-c-seed-growth") 1) 32768))))

    (defn raleb-bit-native-ready ()
        (do
            (let e (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) (raleb-native-selection)))
            (raleb-score
                (and (raleb-ready? e)
                     (and (eq (rale-envelope-route e) (sac-run-dylib))
                          (and (str_eq (rale-envelope-action e) (rap-act-run-native))
                               (and (str_eq (rale-envelope-artifact-kind e) (sad-kind-native-dylib))
                                    (and (str_eq (rale-envelope-artifact-path e) "src/kernel.dylib")
                                         (raleb-reason? e (rale-reason-selected-native-envelope)))))))
                65536)))

    (defn raleb-bit-fkb-ready ()
        (do
            (let e (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) (raleb-fkb-selection)))
            (raleb-score
                (and (raleb-ready? e)
                     (and (eq (rale-envelope-route e) (sac-run-fkb))
                          (and (str_eq (rale-envelope-action e) (rap-act-run-program-image))
                               (and (str_eq (rale-envelope-artifact-kind e) (sad-kind-program-image-fkb))
                                    (and (str_eq (rale-envelope-content-hash e) "sha:fkb-a")
                                         (raleb-reason? e (rale-reason-selected-program-image-envelope)))))))
                131072)))

    (defn raleb-bit-compile-ready ()
        (do
            (let e (rale-envelope-from-selection (raleb-source) (sad-no-artifact) (sad-no-artifact) (raleb-compile-selection)))
            (raleb-score
                (and (raleb-ready? e)
                     (and (eq (rale-envelope-route e) (sac-run-source-compile))
                          (and (str_eq (rale-envelope-action e) (rap-act-compile-source))
                               (and (str_eq (rale-envelope-artifact-kind e) (rale-kind-source))
                                    (and (str_eq (rale-envelope-artifact-path e) "src/kernel.fk")
                                         (and (str_eq (rale-envelope-content-hash e) "sha:src-a")
                                              (and (raleb-no-compile-output? e)
                                                   (raleb-reason? e (rale-reason-selected-compile-source-envelope)))))))))
                262144)))

    (defn raleb-bit-native-retry-ready ()
        (do
            (let r (raleb-native-soft-retry))
            (let e (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) r))
            (raleb-score
                (and (raleb-ready? e)
                     (and (raleb-retry-provenance? e)
                          (and (eq (rale-envelope-route e) (sac-run-fkb))
                               (and (str_eq (rale-envelope-action e) (rap-act-run-program-image))
                                    (and (str_eq (rale-envelope-artifact-path e) "src/kernel.fkb")
                                         (raleb-reason? e (rale-reason-retry-envelope)))))))
                524288)))

    (defn raleb-bit-fkb-retry-ready ()
        (do
            (let r (raleb-fkb-soft-retry))
            (let e (rale-envelope-from-retry (raleb-source) (sad-no-artifact) (sad-no-artifact) r))
            (raleb-score
                (and (raleb-ready? e)
                     (and (raleb-retry-provenance? e)
                          (and (eq (rale-envelope-route e) (sac-run-source-compile))
                               (and (str_eq (rale-envelope-action e) (rap-act-compile-source))
                                    (and (str_eq (rale-envelope-artifact-kind e) (rale-kind-source))
                                         (raleb-reason? e (rale-reason-retry-envelope)))))))
                1048576)))

    (defn raleb-bit-route-mismatch-investigates ()
        (do
            (let r (raleb-native-soft-retry))
            (let e (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) r))
            (raleb-score
                (and (raleb-investigate? e)
                     (and (not (raleb-ready? e))
                          (raleb-reason? e (rale-reason-descriptor-route-mismatch))))
                2097152)))

    (defn raleb-bit-action-and-missing-artifact-investigate ()
        (do
            (let wrong (ras-selection (sac-run-dylib) (rap-act-run-program-image) (rap-act-compile-source) (ras-status-selected) 1 0 "bad-action"))
            (let a (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) wrong))
            (let m (rale-ready-from-route (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) (sac-run-dylib) (rap-act-run-native) (raleb-native-selection) (rale-no-retry)))
            (raleb-score
                (and (raleb-investigate? a)
                     (and (raleb-reason? a (rale-reason-route-action-mismatch))
                          (and (raleb-investigate? m)
                               (raleb-reason? m (rale-reason-missing-artifact)))))
                4194304)))

    (defn raleb-bit-selection-terminal-propagates ()
        (do
            (let i (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) (raleb-investigate-selection)))
            (let f (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) (raleb-refused-selection)))
            (let u (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) (raleb-unknown-status-selection)))
            (raleb-score
                (and (raleb-investigate? i)
                     (and (raleb-refused? f)
                          (and (raleb-investigate? u)
                               (and (raleb-reason? i (rale-reason-selection-investigates))
                                    (and (raleb-reason? f (rale-reason-selection-refused))
                                         (raleb-reason? u (rale-reason-non-selected-selection)))))))
                8388608)))

    (defn raleb-bit-malformed-selection-refused ()
        (do
            (let a (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) (list "runtime-artifact-selection" 1)))
            (let b (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) 3))
            (raleb-score
                (and (raleb-refused? a)
                     (and (raleb-reason? a (rale-reason-malformed-selection))
                          (and (raleb-refused? b)
                               (raleb-reason? b (rale-reason-malformed-selection)))))
                16777216)))

    (defn raleb-bit-retry-not-ready-or-malformed ()
        (do
            (let c (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) (raleb-native-ok-retry)))
            (let w (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) (raleb-native-waiting-retry)))
            (let m (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) (list "runtime-artifact-retry" 1)))
            (let n (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) 3))
            (raleb-score
                (and (raleb-investigate? c)
                     (and (raleb-investigate? w)
                          (and (raleb-refused? m)
                               (and (raleb-refused? n)
                                    (and (raleb-reason? c (rale-reason-retry-not-ready))
                                         (raleb-reason? n (rale-reason-malformed-retry)))))))
                33554432)))

    (defn raleb-bit-invalid-descriptor-bundle-investigates ()
        (do
            (let e (rale-envelope-from-selection (raleb-source-invalid) (sad-no-artifact) (sad-no-artifact) (raleb-compile-selection)))
            (raleb-score
                (and (raleb-investigate? e)
                     (raleb-reason? e (rale-reason-invalid-descriptor-bundle)))
                67108864)))

    (defn raleb-bit-request-ready-not-load-success ()
        (do
            (let e (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) (raleb-native-selection)))
            (raleb-score
                (and (raleb-ready? e)
                     (and (not (str_eq (rale-envelope-status e) (rao-status-complete)))
                          (and (not (str_eq (rale-envelope-reason e) (rao-reason-observation-ok)))
                               (and (raleb-no-compile-output? e)
                                    (eq (len e) 14)))))
                134217728)))

    (defn raleb-bit-row-shape-provenance ()
        (do
            (let s (raleb-fkb-selection))
            (let d (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) s))
            (let r (raleb-native-soft-retry))
            (let e (rale-envelope-from-retry (raleb-source) (raleb-fkb-fresh) (sad-no-artifact) r))
            (raleb-score
                (and (rale-envelope? d)
                     (and (rale-envelope? e)
                          (and (raleb-direct-provenance? d)
                               (and (raleb-retry-provenance? e)
                                    (and (eq (ras-selection-route (rale-envelope-selection e)) (sac-run-fkb))
                                         (str_eq (rar-retry-status (rale-envelope-retry e)) (rar-status-retry-ready)))))))
                268435456)))

    (defn raleb-bit-idempotent ()
        (do
            (let s (raleb-native-selection))
            (let a (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) s))
            (let b (rale-envelope-from-selection (raleb-source) (raleb-fkb-fresh) (raleb-dylib-fresh) s))
            (raleb-score
                (and (str_eq (rale-envelope-status a) (rale-envelope-status b))
                     (and (str_eq (rale-envelope-reason a) (rale-envelope-reason b))
                          (and (str_eq (rale-envelope-artifact-path a) (rale-envelope-artifact-path b))
                               (eq (rale-envelope-route a) (rale-envelope-route b)))))
                536870912)))

    (defn raleb-bit-route-table-total ()
        (raleb-score
            (and (eq (rale-known-route? (sac-run-dylib)) 1)
                 (and (eq (rale-known-route? (sac-run-fkb)) 1)
                      (and (eq (rale-known-route? (sac-run-source-compile)) 1)
                           (and (eq (rale-known-route? 99) 0)
                                (and (eq (rale-route-action-match? (sac-run-dylib) (rap-act-run-native)) 1)
                                     (and (eq (rale-route-action-match? (sac-run-fkb) (rap-act-run-program-image)) 1)
                                          (and (eq (rale-route-action-match? (sac-run-source-compile) (rap-act-compile-source)) 1)
                                               (eq (rale-route-action-match? 99 (rap-act-run-native)) 0))))))))
            1073741824))

    (defn runtime-artifact-load-envelope-band ()
        (sum (list
            (raleb-bit-manifest-1)
            (raleb-bit-manifest-2)
            (raleb-bit-native-ready)
            (raleb-bit-fkb-ready)
            (raleb-bit-compile-ready)
            (raleb-bit-native-retry-ready)
            (raleb-bit-fkb-retry-ready)
            (raleb-bit-route-mismatch-investigates)
            (raleb-bit-action-and-missing-artifact-investigate)
            (raleb-bit-selection-terminal-propagates)
            (raleb-bit-malformed-selection-refused)
            (raleb-bit-retry-not-ready-or-malformed)
            (raleb-bit-invalid-descriptor-bundle-investigates)
            (raleb-bit-request-ready-not-load-success)
            (raleb-bit-row-shape-provenance)
            (raleb-bit-idempotent)
            (raleb-bit-route-table-total))))

    (runtime-artifact-load-envelope-band))
