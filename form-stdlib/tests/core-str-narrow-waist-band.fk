; core-str-narrow-waist-band.fk — proof of the string narrow waist.
;
; preludes: form-stdlib/core.fk
;
; str_len / str_byte_at / byte_to_str / str_concat are the only string
; primitives any kernel needs to carry natively (confirmed byte-identical on
; fkwu, Go, Rust, TS — receipts/2026-07-01-narrow-waist-string-cleanup.md).
; This band proves substring / char_at / ord / int_to_str — all Form
; composition over that floor — produce the same values a native
; implementation would, including the edges a naive version misses: an
; empty-range substring, zero, and a negative number for int_to_str.
;
; Verdict 255 when every assertion holds. On fkwu this exercises the native
; substring/int_to_str shadowing the Form defn (confirmed: native wins);
; on Go/Rust/TS post-cleanup this exercises the Form defn directly, since
; neither exists natively there anymore.

(do
    (defn cnw-score (ok bit) (if ok bit 0))
    (defn core-str-narrow-waist-band ()
        (do
    (let c0 (cnw-score (str_eq (substring "hello" 1 4) "ell") 1))
    (let c1 (cnw-score (str_eq (char_at "hello" 0) "h") 2))
    (let c2 (cnw-score (eq (ord "a") 97) 4))
    (let c3 (cnw-score (str_eq (int_to_str 42) "42") 8))
    (let c4 (cnw-score (str_eq (int_to_str 0) "0") 16))
    (let c5 (cnw-score (str_eq (int_to_str (sub 0 7)) "-7") 32))
    (let c6 (cnw-score (str_eq (int_to_str 100000) "100000") 64))
    (let c7 (cnw-score (str_eq (substring "hello" 0 0) "") 128))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (core-str-narrow-waist-band))
