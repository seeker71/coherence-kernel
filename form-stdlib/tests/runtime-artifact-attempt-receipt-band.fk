; runtime-artifact-attempt-receipt-band.fk -- Layer 9f attempt receipt witness.
;
; Expected: 2147483647
;
; This band proves envelope-bound attempt receipts over supplied host/runner
; observations. It does not read disk, hash bytes, reverify seals/proofs or
; callability, load or walk `.fkb`, load or call `.dylib`, execute native/source
; code, run fallbacks, schedule retries, decide admission, install a selector,
; or grow the C seed.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk

(do
    (defn raarb-score (ok bit) (if ok bit 0))
    (defn raarb-manifest-has (name)
        (runtime-artifact-attempt-receipt-manifest-has? name (runtime-artifact-attempt-receipt-manifest)))

    (defn raarb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn raarb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn raarb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn raarb-native-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raarb-source) (raarb-fkb-fresh) (raarb-dylib-fresh))))
    (defn raarb-fkb-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raarb-source) (raarb-fkb-fresh) (sad-no-artifact))))
    (defn raarb-compile-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raarb-source) (sad-no-artifact) (sad-no-artifact))))
    (defn raarb-native-envelope ()
        (rale-envelope-from-selection (raarb-source) (raarb-fkb-fresh) (raarb-dylib-fresh) (raarb-native-selection)))
    (defn raarb-fkb-envelope ()
        (rale-envelope-from-selection (raarb-source) (raarb-fkb-fresh) (sad-no-artifact) (raarb-fkb-selection)))
    (defn raarb-compile-envelope ()
        (rale-envelope-from-selection (raarb-source) (sad-no-artifact) (sad-no-artifact) (raarb-compile-selection)))
    (defn raarb-native-soft-retry ()
        (rar-retry-from-outcome
            (rao-outcome-from-selection-observation
                (raarb-native-selection)
                (rao-run-observation (rap-act-run-native) (rao-obs-loader-missing) "native missing" 17))))
    (defn raarb-retry-envelope ()
        (rale-envelope-from-retry (raarb-source) (raarb-fkb-fresh) (sad-no-artifact) (raarb-native-soft-retry)))
    (defn raarb-investigate-envelope ()
        (rale-envelope-from-selection
            (raarb-source)
            (raarb-fkb-fresh)
            (sad-no-artifact)
            (ras-selection (sad-route-invalid) (rap-act-investigate) (rap-act-none) (ras-status-investigate) 0 0 (ras-reason-upstream-investigate))))
    (defn raarb-refused-envelope ()
        (rale-envelope-from-selection
            (raarb-source)
            (raarb-fkb-fresh)
            (sad-no-artifact)
            (ras-selection (sad-route-invalid) (rap-act-none) (rap-act-none) (ras-status-refused) 0 0 (ras-reason-malformed-plan))))
    (defn raarb-attempt (e status)
        (raar-supplied-attempt
            (rale-envelope-action e)
            (rale-envelope-route e)
            (rale-envelope-artifact-kind e)
            (rale-envelope-artifact-path e)
            (rale-envelope-source-hash e)
            (rale-envelope-content-hash e)
            status
            "detail"
            7))
    (defn raarb-attempt-with-action (e action)
        (raar-supplied-attempt action (rale-envelope-route e) (rale-envelope-artifact-kind e)
                               (rale-envelope-artifact-path e) (rale-envelope-source-hash e)
                               (rale-envelope-content-hash e) (rao-obs-ok) "detail" 7))
    (defn raarb-attempt-with-route (e route)
        (raar-supplied-attempt (rale-envelope-action e) route (rale-envelope-artifact-kind e)
                               (rale-envelope-artifact-path e) (rale-envelope-source-hash e)
                               (rale-envelope-content-hash e) (rao-obs-ok) "detail" 7))
    (defn raarb-attempt-with-kind (e kind)
        (raar-supplied-attempt (rale-envelope-action e) (rale-envelope-route e) kind
                               (rale-envelope-artifact-path e) (rale-envelope-source-hash e)
                               (rale-envelope-content-hash e) (rao-obs-ok) "detail" 7))
    (defn raarb-attempt-with-path (e path)
        (raar-supplied-attempt (rale-envelope-action e) (rale-envelope-route e) (rale-envelope-artifact-kind e)
                               path (rale-envelope-source-hash e)
                               (rale-envelope-content-hash e) (rao-obs-ok) "detail" 7))
    (defn raarb-attempt-with-source-hash (e h)
        (raar-supplied-attempt (rale-envelope-action e) (rale-envelope-route e) (rale-envelope-artifact-kind e)
                               (rale-envelope-artifact-path e) h
                               (rale-envelope-content-hash e) (rao-obs-ok) "detail" 7))
    (defn raarb-attempt-with-content-hash (e h)
        (raar-supplied-attempt (rale-envelope-action e) (rale-envelope-route e) (rale-envelope-artifact-kind e)
                               (rale-envelope-artifact-path e) (rale-envelope-source-hash e)
                               h (rao-obs-ok) "detail" 7))

    (defn raarb-status? (r status) (str_eq (raar-receipt-status r) status))
    (defn raarb-reason? (r reason) (str_eq (raar-receipt-reason r) reason))
    (defn raarb-severity? (r severity) (str_eq (raar-receipt-severity r) severity))
    (defn raarb-derived? (r)
        (rao-run-observation? (raar-receipt-derived-observation r)))
    (defn raarb-no-derived? (r)
        (raar-no-derived-observation? (raar-receipt-derived-observation r)))

    (defn raarb-bit-manifest-1 ()
        (sum (list
            (raarb-score (eq (raarb-manifest-has "attempt-receipt-not-execution") 1) 1)
            (raarb-score (eq (raarb-manifest-has "supplied-host-attempt-only") 1) 2)
            (raarb-score (eq (raarb-manifest-has "binds-to-rale-envelope") 1) 4)
            (raarb-score (eq (raarb-manifest-has "identity-tuple-field-match") 1) 8)
            (raarb-score (eq (raarb-manifest-has "derived-rao-observation-only-after-match") 1) 16)
            (raarb-score (eq (raarb-manifest-has "mismatch-investigates-without-derived-observation") 1) 32)
            (raarb-score (eq (raarb-manifest-has "pending-can-age-to-investigate") 1) 64)
            (raarb-score (eq (raarb-manifest-has "hard-statuses-preserved-for-9c") 1) 128))))

    (defn raarb-bit-manifest-2 ()
        (sum (list
            (raarb-score (eq (raarb-manifest-has "no-outcome-algebra-or-retry-policy") 1) 256)
            (raarb-score (eq (raarb-manifest-has "no-disk-io") 1) 512)
            (raarb-score (eq (raarb-manifest-has "no-byte-hashing") 1) 1024)
            (raarb-score (eq (raarb-manifest-has "no-seal-proof-callable-reverify") 1) 2048)
            (raarb-score (eq (raarb-manifest-has "no-fkb-walk-or-dylib-call") 1) 4096)
            (raarb-score (eq (raarb-manifest-has "no-native-or-source-execution") 1) 8192)
            (raarb-score (eq (raarb-manifest-has "no-admission-policy-or-selector-install") 1) 16384)
            (raarb-score (eq (raarb-manifest-has "no-c-seed-growth") 1) 32768))))

    (defn raarb-bit-pending-and-aged ()
        (do
            (let p (raar-receipt-from-envelope (raarb-native-envelope)))
            (let s (raar-receipt-from-envelope-age (raarb-native-envelope) 11 10))
            (raarb-score
                (and (raarb-status? p (raar-status-pending-observation))
                     (and (raarb-no-derived? p)
                          (and (raarb-reason? p (raar-reason-pending-observation))
                               (and (raarb-status? s (raar-status-investigate))
                                    (and (raarb-no-derived? s)
                                         (raarb-reason? s (raar-reason-pending-observation-stalled)))))))
                65536)))

    (defn raarb-bit-native-ok-derived ()
        (do
            (let e (raarb-native-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e (rao-obs-ok))))
            (let o (raar-receipt-derived-observation r))
            (raarb-score
                (and (raarb-status? r (raar-status-observed))
                     (and (raarb-severity? r (raar-severity-ok))
                          (and (raarb-reason? r (raar-reason-observed-ok))
                               (and (raarb-derived? r)
                                    (and (str_eq (rao-observation-action o) (rale-envelope-action e))
                                         (str_eq (rao-observation-status o) (rao-obs-ok)))))))
                131072)))

    (defn raarb-bit-soft-derived-and-9c-fallback ()
        (do
            (let e (raarb-native-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e (rao-obs-loader-missing))))
            (let o (rao-outcome-from-selection-observation (raar-receipt-selection r) (raar-receipt-derived-observation r)))
            (raarb-score
                (and (raarb-status? r (raar-status-observed))
                     (and (raarb-severity? r (raar-severity-soft))
                          (and (raarb-reason? r (raar-reason-observed-soft))
                               (and (str_eq (rao-outcome-status o) (rao-status-fallback-available))
                                    (str_eq (rao-outcome-reason o) (rao-reason-soft-failure-fallback-available))))))
                262144)))

    (defn raarb-bit-hard-derived-and-9c-investigates ()
        (do
            (let e (raarb-native-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e (rao-obs-oom-killed))))
            (let o (rao-outcome-from-selection-observation (raar-receipt-selection r) (raar-receipt-derived-observation r)))
            (raarb-score
                (and (raarb-status? r (raar-status-observed))
                     (and (raarb-severity? r (raar-severity-hard))
                          (and (raarb-reason? r (raar-reason-observed-hard-investigates))
                               (and (str_eq (rao-outcome-status o) (rao-status-investigate))
                                    (str_eq (rao-outcome-reason o) (rao-reason-hard-observation-investigates))))))
                524288)))

    (defn raarb-bit-unknown-derived-and-9c-investigates ()
        (do
            (let e (raarb-fkb-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e "surprise-status")))
            (let o (rao-outcome-from-selection-observation (raar-receipt-selection r) (raar-receipt-derived-observation r)))
            (raarb-score
                (and (raarb-status? r (raar-status-observed))
                     (and (raarb-severity? r (raar-severity-unknown))
                          (and (raarb-reason? r (raar-reason-observed-unknown-investigates))
                               (and (str_eq (rao-outcome-status o) (rao-status-investigate))
                                    (str_eq (rao-outcome-reason o) (rao-reason-unknown-observation-status))))))
                1048576)))

    (defn raarb-bit-action-and-route-mismatch ()
        (do
            (let e (raarb-native-envelope))
            (let a (raar-receipt-from-envelope-attempt e (raarb-attempt-with-action e (rap-act-run-program-image))))
            (let b (raar-receipt-from-envelope-attempt e (raarb-attempt-with-route e (sac-run-fkb))))
            (raarb-score
                (and (raarb-status? a (raar-status-investigate))
                     (and (raarb-no-derived? a)
                          (and (raarb-reason? a (raar-reason-action-mismatch))
                               (and (raarb-status? b (raar-status-investigate))
                                    (and (raarb-no-derived? b)
                                         (raarb-reason? b (raar-reason-route-mismatch)))))))
                2097152)))

    (defn raarb-bit-artifact-identity-mismatch ()
        (do
            (let e (raarb-native-envelope))
            (let k (raar-receipt-from-envelope-attempt e (raarb-attempt-with-kind e (sad-kind-program-image-fkb))))
            (let p (raar-receipt-from-envelope-attempt e (raarb-attempt-with-path e "other.dylib")))
            (let s (raar-receipt-from-envelope-attempt e (raarb-attempt-with-source-hash e "sha:other-src")))
            (let c (raar-receipt-from-envelope-attempt e (raarb-attempt-with-content-hash e "sha:other-content")))
            (raarb-score
                (and (raarb-status? k (raar-status-investigate))
                     (and (raarb-reason? k (raar-reason-kind-mismatch))
                          (and (raarb-reason? p (raar-reason-path-mismatch))
                               (and (raarb-reason? s (raar-reason-source-hash-mismatch))
                                    (and (raarb-reason? c (raar-reason-content-hash-mismatch))
                                         (and (raarb-no-derived? k)
                                              (raarb-no-derived? c)))))))
                4194304)))

    (defn raarb-bit-malformed-attempt-refused ()
        (do
            (let e (raarb-native-envelope))
            (let a (raar-receipt-from-envelope-attempt e (list "runtime-artifact-supplied-attempt" 1)))
            (let b (raar-receipt-from-envelope-attempt e 3))
            (raarb-score
                (and (raarb-status? a (raar-status-refused))
                     (and (raarb-reason? a (raar-reason-malformed-attempt))
                          (and (raarb-status? b (raar-status-refused))
                               (and (raarb-reason? b (raar-reason-malformed-attempt))
                                    (and (raarb-no-derived? a) (raarb-no-derived? b))))))
                8388608)))

    (defn raarb-bit-terminal-envelopes-no-derived ()
        (do
            (let i (raar-receipt-from-envelope-attempt (raarb-investigate-envelope) (raarb-attempt (raarb-fkb-envelope) (rao-obs-ok))))
            (let f (raar-receipt-from-envelope-attempt (raarb-refused-envelope) (raarb-attempt (raarb-fkb-envelope) (rao-obs-ok))))
            (raarb-score
                (and (raarb-status? i (raar-status-investigate))
                     (and (raarb-reason? i (raar-reason-envelope-investigates))
                          (and (raarb-status? f (raar-status-refused))
                               (and (raarb-reason? f (raar-reason-envelope-refused))
                                    (and (raarb-no-derived? i) (raarb-no-derived? f))))))
                16777216)))

    (defn raarb-bit-malformed-and-nonready-envelope ()
        (do
            (let m (raar-receipt-from-envelope-attempt (list "runtime-artifact-load-envelope" 1) (raar-no-attempt)))
            (let e (rale-envelope (raarb-source) (sad-no-artifact) (rap-act-run-native) (sac-run-dylib)
                                  (sad-kind-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a"
                                  (raarb-native-selection) (rale-no-retry) (rale-no-compile-output)
                                  "surprise-status" "surprise"))
            (let n (raar-receipt-from-envelope e))
            (raarb-score
                (and (raarb-status? m (raar-status-refused))
                     (and (raarb-reason? m (raar-reason-malformed-envelope))
                          (and (raarb-status? n (raar-status-investigate))
                               (and (raarb-reason? n (raar-reason-non-ready-envelope))
                                    (and (raarb-no-derived? m) (raarb-no-derived? n))))))
                33554432)))

    (defn raarb-bit-compile-source-observed ()
        (do
            (let e (raarb-compile-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e (rao-obs-ok))))
            (let o (rao-outcome-from-selection-observation (raar-receipt-selection r) (raar-receipt-derived-observation r)))
            (raarb-score
                (and (raarb-status? r (raar-status-observed))
                     (and (str_eq (raar-receipt-action r) (rap-act-compile-source))
                          (and (str_eq (raar-receipt-artifact-kind r) (rale-kind-source))
                               (str_eq (rao-outcome-status o) (rao-status-complete)))))
                67108864)))

    (defn raarb-bit-retry-envelope-provenance ()
        (do
            (let e (raarb-retry-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e (rao-obs-error))))
            (let o (rao-outcome-from-selection-observation (raar-receipt-selection r) (raar-receipt-derived-observation r)))
            (raarb-score
                (and (raarb-status? r (raar-status-observed))
                     (and (rar-retry? (rale-envelope-retry (raar-receipt-envelope r)))
                          (and (eq (ras-selection-route (raar-receipt-selection r)) (sac-run-fkb))
                               (and (str_eq (rao-outcome-status o) (rao-status-fallback-available))
                                    (str_eq (raar-receipt-artifact-path r) "src/kernel.fkb")))))
                134217728)))

    (defn raarb-bit-derived-action-from-envelope ()
        (do
            (let e (raarb-fkb-envelope))
            (let a (raar-supplied-attempt (rale-envelope-action e) (rale-envelope-route e) (rale-envelope-artifact-kind e)
                                          (rale-envelope-artifact-path e) (rale-envelope-source-hash e)
                                          (rale-envelope-content-hash e) (rao-obs-ok) "detail" 7))
            (let r (raar-receipt-from-envelope-attempt e a))
            (let o (raar-receipt-derived-observation r))
            (raarb-score
                (and (raarb-derived? r)
                     (and (str_eq (rao-observation-action o) (rale-envelope-action e))
                          (str_eq (rao-observation-action o) (rap-act-run-program-image))))
                268435456)))

    (defn raarb-bit-row-shape-and-selection ()
        (do
            (let e (raarb-native-envelope))
            (let r (raar-receipt-from-envelope-attempt e (raarb-attempt e (rao-obs-ok))))
            (raarb-score
                (and (raar-receipt? r)
                     (and (eq (len r) 16)
                          (and (ras-selection? (raar-receipt-selection r))
                               (and (str_eq (raar-receipt-source-hash r) "sha:src-a")
                                    (str_eq (raar-receipt-content-hash r) "sha:dylib-a")))))
                536870912)))

    (defn raarb-bit-idempotent ()
        (do
            (let e (raarb-native-envelope))
            (let a (raarb-attempt e (rao-obs-ok)))
            (let r1 (raar-receipt-from-envelope-attempt e a))
            (let r2 (raar-receipt-from-envelope-attempt e a))
            (raarb-score
                (and (str_eq (raar-receipt-status r1) (raar-receipt-status r2))
                     (and (str_eq (raar-receipt-reason r1) (raar-receipt-reason r2))
                          (and (str_eq (raar-receipt-artifact-path r1) (raar-receipt-artifact-path r2))
                               (str_eq (raar-receipt-attempt-status r1) (raar-receipt-attempt-status r2)))))
                1073741824)))

    (defn runtime-artifact-attempt-receipt-band ()
        (sum (list
            (raarb-bit-manifest-1)
            (raarb-bit-manifest-2)
            (raarb-bit-pending-and-aged)
            (raarb-bit-native-ok-derived)
            (raarb-bit-soft-derived-and-9c-fallback)
            (raarb-bit-hard-derived-and-9c-investigates)
            (raarb-bit-unknown-derived-and-9c-investigates)
            (raarb-bit-action-and-route-mismatch)
            (raarb-bit-artifact-identity-mismatch)
            (raarb-bit-malformed-attempt-refused)
            (raarb-bit-terminal-envelopes-no-derived)
            (raarb-bit-malformed-and-nonready-envelope)
            (raarb-bit-compile-source-observed)
            (raarb-bit-retry-envelope-provenance)
            (raarb-bit-derived-action-from-envelope)
            (raarb-bit-row-shape-and-selection)
            (raarb-bit-idempotent))))

    (runtime-artifact-attempt-receipt-band))
