; domain-semantic-bridge-band.fk -- parsed domain AST to semantic stdlib bridge.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/domain-grammar-core.fk form-stdlib/semantic-stdlib.fk form-stdlib/domain-semantic-bridge.fk
;
; Expected: 268435455

(do
    (defn dsbb-score (ok bit) (if ok bit 0))
    (defn dsbb-manifest-has (name)
        (domain-semantic-bridge-manifest-has? name (domain-semantic-bridge-manifest)))
    (defn dsbb-prog-domain () (dgcore-programming-domain))
    (defn dsbb-nl-domain () (dgcore-natural-domain))
    (defn dsbb-return-node () (dgcore-parse (dgcore-domain-registry) "programming" "return 13"))
    (defn dsbb-yield-node () (dgcore-parse (dgcore-shadow-registry) "programming" "yield 7"))
    (defn dsbb-fact-node () (dgcore-parse (dgcore-domain-registry) "natural-language" "fact sun warm"))
    (defn dsbb-python () (dsb-bridge (dsbb-prog-domain) (dsbb-return-node) "python"))
    (defn dsbb-rust () (dsb-bridge (dsbb-prog-domain) (dsbb-return-node) "rust"))
    (defn dsbb-haskell () (dsb-bridge (dsbb-prog-domain) (dsbb-return-node) "haskell"))
    (defn dsbb-yield () (dsb-bridge (dsbb-prog-domain) (dsbb-yield-node) "python"))
    (defn dsbb-fact () (dsb-bridge (dsbb-nl-domain) (dsbb-fact-node) "python"))
    (defn dsbb-trap-rows ()
        (cons (dsb-row "natural-language" "__nl_fact__" "form" "return" (ssl-return)) (dsb-rows)))
    (defn dsbb-fact-trap ()
        (dsb-bridge-with-rows (dsbb-trap-rows) (dsbb-nl-domain) (dsbb-fact-node) "python"))

    (defn domain-semantic-bridge-band ()
        (add
            (dsbb-score (eq (dsbb-manifest-has "consumes-parsed-ast") 1) 1)
        (add
            (dsbb-score (eq (dsbb-manifest-has "no-raw-source-parse") 1) 2)
        (add
            (dsbb-score (eq (dsbb-manifest-has "no-tokenizer") 1) 4)
        (add
            (dsbb-score (eq (dsbb-manifest-has "lane-gate-before-ssl") 1) 8)
        (add
            (dsbb-score (eq (dsbb-manifest-has "ssl-delegate-only") 1) 16)
        (add
            (dsbb-score (eq (dsbb-manifest-has "bridge-row-table") 1) 32)
        (add
            (dsbb-score (eq (dsbb-manifest-has "single-row-table-v1") 1) 64)
        (add
            (dsbb-score (eq (dsbb-manifest-has "preserves-domain-metadata") 1) 128)
        (add
            (dsbb-score (eq (dsbb-manifest-has "preserves-node-args") 1) 256)
        (add
            (dsbb-score (eq (dsbb-manifest-has "residue-fidelity-pass-through") 1) 512)
        (add
            (dsbb-score (eq (dsbb-manifest-has "no-ontology") 1) 1024)
        (add
            (dsbb-score (eq (dsbb-manifest-has "no-artifact-route") 1) 2048)
        (add
            (dsbb-score
                (and (dgcore-ok? (dsbb-return-node))
                     (str_eq (dgcore-node-tag (dsbb-return-node)) "__prog_return__"))
                4096)
        (add
            (dsbb-score (str_eq (dgcore-node-slot (dsbb-return-node) 1) "13") 8192)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-status (dsbb-python)) "ok")
                     (and (str_eq (dsb-result-target-surface (dsbb-python)) "return")
                          (eq (dsb-result-sem (dsbb-python)) (ssl-return))))
                16384)
        (add
            (dsbb-score
                (and (eq (dsb-result-fidelity (dsbb-python)) 100)
                     (eq (len (dsb-result-residue (dsbb-python))) 0))
                32768)
        (add
            (dsbb-score (str_eq (dsb-result-arg-value (dsbb-python) 0) "13") 65536)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-evidence-lane (dsbb-python)) "compiler-proof")
                     (and (str_eq (dsb-result-residue-policy (dsbb-python)) "syntax-semantic-residue")
                          (str_eq (dsb-result-lower-target (dsbb-python)) "form-recipe")))
                131072)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-from-lang (dsbb-python)) "form")
                     (str_eq (dsb-result-source-surface (dsbb-python)) "return"))
                262144)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-status (dsbb-rust)) "lossy")
                     (eq (dsb-result-fidelity (dsbb-rust)) 50))
                524288)
        (add
            (dsbb-score
                (and (str_eq (head (dsb-result-residue (dsbb-rust))) "stmt")
                     (eq (dsb-result-sem (dsbb-rust)) (ssl-return)))
                1048576)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-status (dsbb-haskell)) "missing")
                     (str_eq (dsb-result-target-surface (dsbb-haskell)) "missing"))
                2097152)
        (add
            (dsbb-score
                (and (str_eq (head (dsb-result-residue (dsbb-haskell))) "missing-target")
                     (eq (dsb-result-sem (dsbb-haskell)) (ssl-return)))
                4194304)
        (add
            (dsbb-score
                (and (str_eq (dgcore-node-tag (dsbb-yield-node)) "__prog_yield__")
                     (str_eq (dsb-result-status (dsbb-yield)) "missing-domain-semantic-row"))
                8388608)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-arg-value (dsbb-yield) 0) "7")
                     (str_eq (head (dsb-result-residue (dsbb-yield))) "missing-domain-semantic-row"))
                16777216)
        (add
            (dsbb-score
                (and (str_eq (dgcore-node-tag (dsbb-fact-node)) "__nl_fact__")
                     (str_eq (dsb-result-status (dsbb-fact)) "semantic-lane-not-stdlib"))
                33554432)
        (add
            (dsbb-score
                (and (str_eq (dsb-result-status (dsbb-fact-trap)) "semantic-lane-not-stdlib")
                     (str_eq (head (dsb-result-residue (dsbb-fact-trap))) "semantic-lane-not-stdlib"))
                67108864)
            (dsbb-score
                (and (eq (len (dsb-rows)) 1)
                     (eq (dsb-row-sem (head (dsb-rows))) (ssl-return)))
                134217728)))))))))))))))))))))))))))))

    (domain-semantic-bridge-band))
