; fsh-federation-graph-band.fk — the native shell owns federation movement.
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-cli-carrier.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/offer-ack-core.fk form-stdlib/federation-graph-offer.fk form-stdlib/cell-log-store.fk form-stdlib/storage-port.fk form-stdlib/storage-port-file.fk form-stdlib/federation-graph-store.fk form-stdlib/shell-exec.fk
;
; 1111 = native dispatch, node ack, durable incoming traversal, matching
; outgoing traversal. No host command decides any of these bits.
(do
    (let dir (str_concat (temp_dir) "/fsh-federation-graph-band.d"))
    (fs_rmdir dir)
    (let offer-cmd (str_concat "federation-offer "
        (str_concat dir " mac android text hello e30= t1")))
    (let receipt (sh-out offer-cmd))
    (let incoming (sh-out (str_concat "federation-incoming "
        (str_concat dir " android"))))
    (let outgoing (sh-out (str_concat "federation-outgoing "
        (str_concat dir " mac"))))
    (let message-id (head (fgs-lines incoming)))
    (let has (sh-out (str_concat "federation-has "
        (str_concat dir (str_concat " " message-id)))))
    (let broadcast-cmd (str_concat "federation-offer "
        (str_concat dir " mac - text world e30= t2")))
    (sh-out broadcast-cmd)
    (let broadcasts (sh-out (str_concat "federation-broadcasts " dir)))
    (let dispatch-ok (if (str_eq (sh-step-kind (head (sh-plan (sh-parse offer-cmd)))) "native") 1 0))
    (let ack-ok (if (sh-contains? receipt "ack=node|message_id=msg_") 10 0))
    (let incoming-ok (if (sh-contains? incoming "msg_")
        (if (str_eq has "1\n") 100 0) 0))
    (let outgoing-ok (if (str_eq incoming outgoing)
        (if (sh-contains? broadcasts "msg_")
            (if (gt (str_len outgoing) 5) 1000 0) 0) 0))
    (fs_rmdir dir)
    (sum (list dispatch-ok ack-ok incoming-ok outgoing-ok)))
