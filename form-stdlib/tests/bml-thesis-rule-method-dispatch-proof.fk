; tests/bml-thesis-rule-method-dispatch-proof.fk - source method dispatch
;
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves that a method body parsed from the original thesis companion
; container-Rule.bml can be installed on a native blueprint and invoked through
; method_define/method_invoke, mutating per-instance native record state.

(do
    (defn bool-score (b bit)
        (if b bit 0))

    (defn int-score (actual expected bit)
        (if (eq actual expected) bit 0))

    (defn str-score (actual expected bit)
        (if (str_eq actual expected) bit 0))

    (let path "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/container-Rule.bml")
    (let parsed (bml-source-file-parse-declarations path))
    (let model (bml-source-declaration-model parsed))
    (let rule-class (bml-model-find-class model "Rule"))
    (let set-process-method
        (bml-find-method
            (bml-class-own-methods rule-class)
            "SetProcess"))
    (let set-process-body (bml-method-body set-process-method))

    (let DispatchRuleBP (make_nodeid 1 2 99 9203))
    (let DispatchEnvBP (bml-constructor-env-blueprint 0))
    (let dispatch-env
        (record_new DispatchEnvBP "DefaultProcess" "default-dispatch"))

    (defn rule-set-process-dispatch (self)
        (bml-body-source-exec-assignments
            set-process-body
            self
            dispatch-env))

    (let before-has (method_has DispatchRuleBP "SetProcess"))
    (method_define DispatchRuleBP "SetProcess" rule-set-process-dispatch)
    (let after-has (method_has DispatchRuleBP "SetProcess"))

    (let first-rule
        (record_new DispatchRuleBP "m_hProcess" "first-old"))
    (let second-rule
        (record_new DispatchRuleBP "m_hProcess" "second-old"))

    (method_invoke first-rule "SetProcess")
    (let first-after (record_get first-rule "m_hProcess"))
    (let second-before (record_get second-rule "m_hProcess"))
    (method_invoke second-rule "SetProcess")
    (let second-after (record_get second-rule "m_hProcess"))

    (sum
        (list
            (bool-score (bml-source-exec-parse-ok? parsed) 1)
            (str-score (bml-method-return set-process-method) "void" 2)
            (int-score (bml-body-source-assignment-count set-process-body) 1 4)
            (bool-score (bml-body-source-contains? set-process-body "DefaultProcess") 8)
            (bool-score (not before-has) 16)
            (bool-score after-has 32)
            (str-score first-after "default-dispatch" 64)
            (str-score second-before "second-old" 128)
            (str-score second-after "default-dispatch" 256)
            (bool-score (method_has first-rule "SetProcess") 512))))
