; form-cli-request-filesystem-band.fk — receipt-file framing is normalized once,
; then the strict 18-field parser sees the actual host-read bytes.
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/str-byte-at.fk
; preludes: form-stdlib/sha256.fk form-stdlib/hmac-sha256.fk form-stdlib/hex.fk
; preludes: form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
; preludes: form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-ask.fk
; preludes: form-stdlib/form-cli-router.fk form-stdlib/form-cli-judge.fk
; preludes: form-stdlib/form-cli-sufficiency.fk form-stdlib/form-freq-check.fk
; preludes: form-stdlib/trust-row.fk form-stdlib/form-cli-ask-gate.fk
; preludes: form-stdlib/form-cli-staged-trace.fk form-stdlib/form-cli-request.fk
;
; Verdict 255: LF and CRLF file framing round-trip; one framing terminator is
; removed; internal controls, a 19th field, and a second trailing LF remain bad;
; bounded chunk append preserves exact bytes for the live embed materializer.

(do
    (let path (str_concat (temp_dir) "/form-cli-request-filesystem.receipt"))
    (let logical "a|b|c|d|e|f|g|h|i|j|k|l|m|n|o|p|q|r")
    (let wrote-lf (write_file path (str_concat logical "\n")))
    (let raw-lf (read_file path))
    (let normalized-lf (fcr-strip-eol raw-lf))
    (let wrote-crlf (write_file path (str_concat logical "\r\n")))
    (let raw-crlf (read_file path))
    (let normalized-crlf (fcr-strip-eol raw-crlf))
    (let removed (fs_remove path))
    (let out-path (str_concat (temp_dir) "/form-cli-request-filesystem.output"))
    (let created (write_file out-path ""))
    (let append-a (fcr-append-string out-path "abc"))
    (let append-b (fcr-append-string out-path "\nxyz"))
    (let appended (read_file out-path))
    (let removed-output (fs_remove out-path))
    (let c0 (if (eq wrote-lf (add (str_len logical) 1)) 1 0))
    (let c1 (if (str_eq normalized-lf logical) 2 0))
    (let c2 (if (and (eq wrote-crlf (add (str_len logical) 2))
                     (str_eq normalized-crlf logical)) 4 0))
    (let c3 (if (eq (fcast-receipt-shape? normalized-lf) 1) 8 0))
    (let c4 (if (and (eq (fcast-receipt-shape?
                          (str_concat logical "\ninside")) 0)
                     (eq (fcast-receipt-shape?
                          (str_concat logical "|extra")) 0)) 16 0))
    (let c5 (if (eq (fcast-receipt-shape?
                      (fcr-strip-eol (str_concat logical "\n\n"))) 0) 32 0))
    (let c6 (if (and (eq created 0)
                     (and (eq append-a 0) (eq append-b 0))) 64 0))
    (let c7 (if (str_eq appended "abc\nxyz") 128 0))
    (sum (list c0 c1 c2 c3 c4 c5 c6 c7)))
