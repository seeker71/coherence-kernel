; source-compiler-grammar-bridge-band.fk -- FDL grammar feeds source compiler emission.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/defdata.fk form-stdlib/form-definition-language.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-tbl-emit.fk form-stdlib/source-compiler-emission.fk form-stdlib/source-compiler-grammar-bridge.fk
;
; Expected: 32767

(do
    (defn scgbb-score (ok bit) (if ok bit 0))
    (defn scgbb-manifest-has (name)
        (source-compiler-grammar-bridge-manifest-has?
            name
            (source-compiler-grammar-bridge-manifest)))

    (defn scgbb-surface ()
        "module calc { data rows = [40,2]; fn answer() = add(40,2); }")
    (defn scgbb-expected-lowered ()
        "(let rows (list 40 2))\n(defn answer () (add 40 2))")
    (defn scgbb-bad-surface ()
        (str_concat (scgbb-surface) " trailing"))

    (defn scgbb-source () (sad-source "src/calc.fdl" "sha:calc-fdl" 100))
    (defn scgbb-output-fkb () (sac-compile-output 0 0))
    (defn scgbb-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn scgbb-pif ()
        (pif-envelope "src/calc.fdl" "sha:calc-fdl" 100
                      "src/calc.fkb" "sha:calc-fkb" 101
                      1
                      (scgbb-table)))
    (defn scgbb-text ()
        (pite-table-text-from-envelope (scgbb-pif)))
    (defn scgbb-text-bad () "1 0 1 1 43 0 0 0\n")

    (defn scgbb-compile-selection ()
        (ras-selection-from-plan
            (rap-plan-from-descriptors
                (scgbb-source)
                (sad-no-artifact)
                (sad-no-artifact))))
    (defn scgbb-compile-envelope ()
        (rale-envelope-from-selection
            (scgbb-source)
            (sad-no-artifact)
            (sad-no-artifact)
            (scgbb-compile-selection)))
    (defn scgbb-ready-row ()
        (scgb-from-form-definition-source
            (scgbb-surface)
            (scgbb-compile-envelope)
            (scgbb-output-fkb)
            (scgbb-pif)
            (scgbb-text)
            (sce-no-dylib)))
    (defn scgbb-bad-parse-row ()
        (scgb-from-form-definition-source
            (scgbb-bad-surface)
            (scgbb-compile-envelope)
            (scgbb-output-fkb)
            (scgbb-pif)
            (scgbb-text)
            (sce-no-dylib)))
    (defn scgbb-bad-table-row ()
        (scgb-from-form-definition-source
            (scgbb-surface)
            (scgbb-compile-envelope)
            (scgbb-output-fkb)
            (scgbb-pif)
            (scgbb-text-bad)
            (sce-no-dylib)))

    (defn source-compiler-grammar-bridge-band ()
        (do
            (let ready (scgbb-ready-row))
            (let lower (scgb-row-lowering ready))
            (let emission (scgb-row-emission ready))
            (let bad-parse (scgbb-bad-parse-row))
            (let bad-table (scgbb-bad-table-row))
            (let bad-emission (scgb-row-emission bad-table))
            (add
                (scgbb-score (eq (scgbb-manifest-has "form-definition-grammar-admission") 1) 1)
            (add
                (scgbb-score (eq (scgbb-manifest-has "scannerless-bmf-cursor-required") 1) 2)
            (add
                (scgbb-score (eq (scgbb-manifest-has "source-compiler-emission-delegated") 1) 4)
            (add
                (scgbb-score (eq (scgbb-manifest-has "parse-failure-refuses-emission") 1) 8)
            (add
                (scgbb-score (scgb-ready? ready) 16)
            (add
                (scgbb-score (sce-emitted? emission) 32)
            (add
                (scgbb-score (str_eq (fdl-lowering-name lower) "calc") 64)
            (add
                (scgbb-score (str_eq (fdl-lowering-source lower) (scgbb-expected-lowered)) 128)
            (add
                (scgbb-score (str_eq (sad-artifact-path (sce-emission-fkb-descriptor emission)) "src/calc.fkb") 256)
            (add
                (scgbb-score (scgb-refused? bad-parse) 512)
            (add
                (scgbb-score (str_eq (scgb-row-reason bad-parse) (scgb-reason-parse-failed)) 1024)
            (add
                (scgbb-score (scgb-investigate? bad-table) 2048)
            (add
                (scgbb-score (str_eq (sce-emission-reason bad-emission) (sce-reason-table-text-mismatch)) 4096)
            (add
                (scgbb-score (eq (scgbb-manifest-has "no-c-seed-growth") 1) 8192)
                (scgbb-score (str_eq (scgb-row-reason ready) (scgb-reason-ready)) 16384)))))))))))))))))

    (source-compiler-grammar-bridge-band))
