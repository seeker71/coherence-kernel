; host-filesystem-band.fk — HostFilesystem mac carrier proven Go=Rust=TS=fkwu.
;
; preludes: form-stdlib/core.fk
;
; Mac carrier defs live inline so the fkwu manifest flatten path (shim + band)
; binds hfs-* in one module. host-filesystem-mac.fk mirrors the same surface for
; explicit multi-file loads and documents the BML source (host-filesystem.bml).
;
; Each door lights one bit:
;   1  hfs-list membership (core.fk in form-stdlib)
;   2  hfs-write + hfs-read round-trip
;   4  hfs-size matches payload
;   8  mac carrier aliases generic ops (same read result)
;
; All four => 15.

(do
    (defn hfs-list (dir) (fs_list dir))
    (defn hfs-read (path) (read_file path))
    (defn hfs-write (path text) (write_file_text path text))
    (defn hfs-size (path) (file_size path))
    (defn hfs-has (entries name)
        (if (eq (len entries) 0) 0
            (if (str_eq (head entries) name) 1
                (hfs-has (tail entries) name))))
    (defn mac-hfs-read (path) (hfs-read path))

    (let entries (hfs-list "form-stdlib"))
    (let path (str_concat (temp_dir) "/fk-host-filesystem-band.txt"))
    (let payload "host-fs-mac")
    (let wrote (hfs-write path payload))
    (let body (hfs-read path))
    (let sz (hfs-size path))
    (let mac-body (mac-hfs-read path))
    (add (if (eq (hfs-has entries "core.fk") 1) 1 0)
    (add (if (str_eq body payload) 2 0)
    (add (if (eq sz (str_len payload)) 4 0)
         (if (str_eq mac-body payload) 8 0)))))
