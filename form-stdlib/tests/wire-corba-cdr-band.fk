; wire-corba-cdr-band.fk — proof of the values+types+identity CORBA CDR round-trip.
;
; preludes: form-stdlib/core.fk form-stdlib/wire-registry.fk form-stdlib/wire-corba-cdr.fk
;
; Same north star as cell-serialize-band.fk (JSON) and wire-xml-band.fk
; (XML), same registry, same underlying cell — proving the wire-
; serialization lane's core (wire-registry.fk) generalizes to a genuinely
; different wire shape: binary octets with CDR alignment, not text. A
; nested cell (composite + negative int + string + float leaves) built via
; intern_node/bp survives a full trip through a CDR octet buffer and back
; to the exact same NodeID (axiom-3), verified via `eq`.
;
; Verdict 15 when every assertion holds.

(do
    (defn cdrb-score (ok bit) (if ok bit 0))
    (defn wire-corba-cdr-band ()
        (do
    (let registry (list (wr-entry "OUTER" (bp "OUTER")) (wr-entry "INNER" (bp "INNER"))))
    (let inner (intern_node (bp "INNER") (list (intern_trivial_int 1) (intern_trivial_int -2))))
    (let original (intern_node (bp "OUTER") (list inner (intern_trivial_string "hi") (intern_trivial_float "3.5"))))
    (let buf (cell-to-cdr original registry))
    (let reconstructed (cdr-to-cell buf registry))
    (let c0 (cdrb-score (eq original reconstructed) 1))                     ; THE north-star check
    (let c1 (cdrb-score (eq (node_category reconstructed) (bp "OUTER")) 2))
    (let c2 (cdrb-score (str_eq (node_value (nth (node_children reconstructed) 1)) "hi") 4))
    (let c3 (cdrb-score (eq (node_value (nth (node_children (head (node_children reconstructed))) 1)) -2) 8))
    (add c0 (add c1 (add c2 c3))))
    )
    (wire-corba-cdr-band))
