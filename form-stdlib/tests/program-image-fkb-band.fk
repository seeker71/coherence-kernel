; program-image-fkb-band.fk -- witness .tbl payload folded into program-image .fkb envelope.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/program-image-fkb.fk
;
; Expected: 2147483647

(do
    (defn pifb-score (ok bit) (if ok bit 0))
    (defn pifb-manifest-has (name)
        (program-image-fkb-manifest-has? name (program-image-fkb-manifest)))

    (defn pifb-table ()
        (pif-table-image 1
                         (list 0)
                         2
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 12 0 0 0))
                         1
                         (list (list 65 66))))
    (defn pifb-bad-nf ()
        (pif-table-image 2
                         (list 0)
                         2
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 12 0 0 0))
                         1
                         (list (list 65 66))))
    (defn pifb-bad-node-arity ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (list 1 42 0))
                         1
                         (list (list 65 66))))
    (defn pifb-bad-byte ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         1
                         (list (list 65 300))))
    (defn pifb-symbol-image ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 1)))
                                (pif-node-symbol-row 1 1 (empty)))))
    (defn pifb-bad-symbol-image-out-of-range-node ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          1
                          (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 2))))))
    (defn pifb-bad-symbol-image-wrong-target-symbol ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 1)))
                                (pif-node-symbol-row 1 0 (empty)))))
    (defn pifb-bad-symbol-image-duplicate-defined ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (pif-node-symbol-row 0 0 (empty))
                                (pif-node-symbol-row 1 0 (empty)))))
    (defn pifb-bad-symbol-image-duplicate-target ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (pif-node-symbol-row 0 0
                                      (list (pif-symbol-dependency-target 1 1)
                                            (pif-symbol-dependency-target 1 1)))
                                (pif-node-symbol-row 1 1 (empty)))))
    (defn pifb-bad-symbol-image-out-of-order-target ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (pif-node-symbol-row 0 0
                                      (list (pif-symbol-dependency-target 1 1)
                                            (pif-symbol-dependency-target 0 0)))
                                (pif-node-symbol-row 1 1 (empty)))))
    (defn pifb-bad-symbol-image-missing-target-row ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          1
                          (list (pif-node-symbol-row 0 0
                                    (list (pif-symbol-dependency-target 1 1))))))
    (defn pifb-old-symbol-image ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (list 0 0 (list 1))
                                (list 1 1 (empty)))))
    (defn pifb-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src-a" 100
                                   "src/kernel.fkb" "sha:fkb-a" 101
                                   1
                                   (pifb-table)
                                   (pifb-symbol-image)))
    (defn pifb-envelope-stale ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 99
                      1
                      (pifb-table)))
    (defn pifb-envelope-seal-bad ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      0
                      (pifb-table)))
    (defn pifb-envelope-bad-table ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pifb-bad-node-arity)))
    (defn pifb-envelope-bad-symbols ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src-a" 100
                                   "src/kernel.fkb" "sha:fkb-a" 101
                                   1
                                   (pifb-table)
                                   (pifb-bad-symbol-image-out-of-range-node)))
    (defn pifb-envelope-source-hash-missing ()
        (pif-envelope "src/kernel.fk" "" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pifb-table)))
    (defn pifb-source-other ()
        (sad-source "src/kernel.fk" "sha:other" 100))
    (defn pifb-direct-includes-only ()
        (sad-program-image-fkb (sad-version-program-image-fkb)
                               "src/kernel.fkb"
                               "sha:src-a"
                               "sha:fkb-a"
                               101
                               0
                               1))
    (defn pifb-parsed-data ()
        (sad-artifact (sad-kind-parsed-data-fkb)
                      "parsed-data-v1"
                      "src/data.fkb"
                      "sha:src-a"
                      "sha:data-a"
                      101
                      1
                      0
                      0
                      0
                      1))

    (defn pifb-bit-manifest-1 ()
        (sum (list
            (pifb-score (eq (pifb-manifest-has "tbl-shaped-payload-in-fkb-envelope") 1) 1)
            (pifb-score (eq (pifb-manifest-has "program-image-kind-not-parsed-data") 1) 2)
            (pifb-score (eq (pifb-manifest-has "program-image-kind-not-compiler-image") 1) 4)
            (pifb-score (eq (pifb-manifest-has "exact-node-row-arity-4") 1) 8)
            (pifb-score (and (eq (pifb-manifest-has "string-byte-rows") 1)
                             (eq (pifb-manifest-has "embedded-symbol-dependency-image") 1)) 16)
            (pifb-score (and (eq (pifb-manifest-has "table-counts-must-match") 1)
                         (and (eq (pifb-manifest-has "node-symbol-dependencies") 1)
                         (and (eq (pifb-manifest-has "node-symbol-dependency-targets") 1)
                              (eq (pifb-manifest-has "symbol-deps-resolve-to-nodes") 1)))) 32)
            (pifb-score (and (eq (pifb-manifest-has "descriptor-derived-only-after-valid-table") 1)
                             (eq (pifb-manifest-has "sym-sidecar-is-locale-lens") 1)) 64)
            (pifb-score (eq (pifb-manifest-has "seal-required-before-route") 1) 128))))
    (defn pifb-bit-manifest-2 ()
        (sum (list
            (pifb-score (eq (pifb-manifest-has "source-hash-required-before-route") 1) 256)
            (pifb-score (eq (pifb-manifest-has "table-numeric-stream") 1) 512)
            (pifb-score (eq (pifb-manifest-has "no-form-binary-io") 1) 1024)
            (pifb-score (eq (pifb-manifest-has "no-program-image-load") 1) 2048)
            (pifb-score (eq (pifb-manifest-has "no-selector-install") 1) 4096)
            (pifb-score (eq (pifb-manifest-has "no-c-seed-growth") 1) 8192)
            (pifb-score (eq (pifb-manifest-has "future-9h-loads-envelope") 1) 16384))))

    (defn pifb-bit-table-valid ()
        (pifb-score
            (and (pif-table-valid? (pifb-table))
                (and (eq (pif-table-nf (pifb-table)) 1)
                (and (eq (pif-table-nr (pifb-table)) 2)
                (and (eq (pif-table-ns (pifb-table)) 1)
                (and (pif-symbol-image-valid-for-table? (pifb-symbol-image) (pifb-table))
                (and (eq (pif-symbol-dependency-target-symbol
                            (head (pif-node-symbol-row-dependency-targets
                                (head (pif-symbol-image-node-rows (pifb-symbol-image))))))
                         1)
                     (eq (pif-symbol-dependency-target-node
                            (head (pif-node-symbol-row-dependency-targets
                                (head (pif-symbol-image-node-rows (pifb-symbol-image))))))
                         1)))))))
            32768))
    (defn pifb-bit-table-counts ()
        (pifb-score (not (pif-table-valid? (pifb-bad-nf))) 65536))
    (defn pifb-bit-node-arity ()
        (pifb-score (not (pif-table-valid? (pifb-bad-node-arity))) 131072))
    (defn pifb-bit-byte-range ()
        (pifb-score (not (pif-table-valid? (pifb-bad-byte))) 262144))
    (defn pifb-bit-numeric-stream ()
        (do
            (let stream (pif-table-numeric-stream (pifb-table)))
            (pifb-score
                (and (eq (len stream) 15)
                (and (eq (nth stream 0) 1)
                (and (eq (nth stream 1) 0)
                (and (eq (nth stream 2) 2)
                (and (eq (nth stream 3) 1)
                (and (eq (nth stream 4) 42)
                (and (eq (nth stream 7) 12)
                (and (eq (nth stream 11) 1)
                (and (eq (nth stream 12) 2)
                (and (eq (nth stream 13) 65)
                     (eq (nth stream 14) 66)))))))))))
                524288)))
    (defn pifb-bit-invalid-stream-empty ()
        (pifb-score (eq (len (pif-table-numeric-stream (pifb-bad-node-arity))) 0) 1048576))
    (defn pifb-bit-envelope-valid ()
        (do
            (let e (pifb-envelope))
            (let d (pif-descriptor-from-envelope e))
            (pifb-score
                (and (pif-envelope-valid? e)
                (and (str_eq (sad-artifact-kind d) (sad-kind-program-image-fkb))
                (and (str_eq (sad-artifact-version d) (sad-version-program-image-fkb))
                (and (str_eq (sad-artifact-source-hash d) "sha:src-a")
                     (eq (sad-artifact-includes-tbl d) 1)))))
                2097152)))
    (defn pifb-bit-route-fkb ()
        (pifb-score (eq (pif-route-from-envelope (pifb-envelope)) (sac-run-fkb)) 4194304))
    (defn pifb-bit-stale-routes-compile ()
        (pifb-score (eq (pif-route-from-envelope (pifb-envelope-stale)) (sac-run-source-compile)) 8388608))
    (defn pifb-bit-seal-bad-no-descriptor ()
        (do
            (let d (pif-descriptor-from-envelope (pifb-envelope-seal-bad)))
            (pifb-score
                (and (sad-no-artifact? d)
                     (eq (pif-route-from-envelope (pifb-envelope-seal-bad)) (sac-run-source-compile)))
                16777216)))
    (defn pifb-bit-bad-table-no-descriptor ()
        (do
            (let d (pif-descriptor-from-envelope (pifb-envelope-bad-table)))
            (pifb-score
                (and (sad-no-artifact? d)
                (and (eq (pif-route-from-envelope (pifb-envelope-bad-table)) (sac-run-source-compile))
                (and (not (pif-envelope-valid? (pifb-envelope-bad-symbols)))
                (and (not (pif-symbol-image-valid-for-table? (pifb-bad-symbol-image-out-of-range-node) (pifb-table)))
                (and (not (pif-symbol-image-valid-for-table? (pifb-bad-symbol-image-wrong-target-symbol) (pifb-table)))
                (and (not (pif-symbol-image-valid-for-table? (pifb-bad-symbol-image-duplicate-defined) (pifb-table)))
                (and (not (pif-symbol-image-valid-for-table? (pifb-bad-symbol-image-duplicate-target) (pifb-table)))
                (and (not (pif-symbol-image-valid-for-table? (pifb-bad-symbol-image-out-of-order-target) (pifb-table)))
                (and (not (pif-symbol-image-valid-for-table? (pifb-bad-symbol-image-missing-target-row) (pifb-table)))
                     (not (pif-symbol-image-valid-for-table? (pifb-old-symbol-image) (pifb-table))))))))))))
                33554432)))
    (defn pifb-bit-missing-source-hash-invalid ()
        (pifb-score
            (and (not (pif-envelope-valid? (pifb-envelope-source-hash-missing)))
                 (eq (pif-route-from-envelope (pifb-envelope-source-hash-missing)) (sad-route-invalid)))
            67108864))
    (defn pifb-bit-source-mismatch-quarantines ()
        (do
            (let d (pif-descriptor-from-envelope (pifb-envelope)))
            (pifb-score
                (eq (sad-route (pifb-source-other) d (sad-no-artifact)) (sac-run-source-compile))
                134217728)))
    (defn pifb-bit-includes-alone-cannot-route ()
        (pifb-score
            (and (eq (sad-route (pif-source-from-envelope (pifb-envelope))
                                (pifb-direct-includes-only)
                                (sad-no-artifact))
                     (sac-run-source-compile))
                 (not (sad-program-image-fkb-current? (pif-source-from-envelope (pifb-envelope))
                                                      (pifb-direct-includes-only))))
            268435456))
    (defn pifb-bit-parsed-data-rejected ()
        (pifb-score
            (and (sad-parsed-data-kind? (sad-artifact-kind (pifb-parsed-data)))
                 (not (sad-artifact-option-valid? (pifb-parsed-data))))
            536870912))
    (defn pifb-text-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn pifb-read-file-any (primary fallback)
        (if (ge (file_size primary) 0)
            (read_file primary)
            (read_file fallback)))
    (defn pifb-bit-static-and-mirror ()
        (do
            (let text (pifb-read-file-any "form/form-stdlib/program-image-fkb.fk"
                                          "../form/form-stdlib/program-image-fkb.fk"))
            (let grammar (pifb-read-file-any "grammars/program-image-fkb.fk"
                                             "../grammars/program-image-fkb.fk"))
            (pifb-score
                (and (not (pifb-text-has? text "write_form_binary"))
                (and (not (pifb-text-has? text "read_form_binary"))
                (and (not (pifb-text-has? text "recipe_to_bytes"))
                (and (not (pifb-text-has? text "bytes_to_recipe"))
                (and (not (pifb-text-has? text "dlopen"))
                (and (not (pifb-text-has? text "fk_run"))
                     (str_eq text grammar)))))))
                1073741824)))

    (defn program-image-fkb-band ()
        (sum (list
            (pifb-bit-manifest-1)
            (pifb-bit-manifest-2)
            (pifb-bit-table-valid)
            (pifb-bit-table-counts)
            (pifb-bit-node-arity)
            (pifb-bit-byte-range)
            (pifb-bit-numeric-stream)
            (pifb-bit-invalid-stream-empty)
            (pifb-bit-envelope-valid)
            (pifb-bit-route-fkb)
            (pifb-bit-stale-routes-compile)
            (pifb-bit-seal-bad-no-descriptor)
            (pifb-bit-bad-table-no-descriptor)
            (pifb-bit-missing-source-hash-invalid)
            (pifb-bit-source-mismatch-quarantines)
            (pifb-bit-includes-alone-cannot-route)
            (pifb-bit-parsed-data-rejected)
            (pifb-bit-static-and-mirror))))

    (program-image-fkb-band))
