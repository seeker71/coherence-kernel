; wire-bool-band.fk — the bool round-trip, proven across all three wire dialects.
;
; preludes: form-stdlib/core.fk form-stdlib/wire-registry.fk form-stdlib/cell-serialize.fk form-stdlib/wire-xml.fk form-stdlib/wire-corba-cdr.fk
;
; Until 2026-07-02 a trivial bool serialized as `null` in every wire dialect
; (JSON/XML/CDR): node_value returned the interning sentinel, not the boolean,
; so no dialect could read a bool's value, and each fell through to its null
; case. The C seed's node_value (tag 49) was fixed to return the boolean
; (nid[3]) for bool nodes; then each dialect gained a real bool leaf — JSON
; `true`/`false`, XML `<b>true</b>`/`<b>false</b>`, CDR tag 5 + one octet.
; This band proves the whole story: exact emitted text where it is text, and
; content-addressed identity (axiom-3, `eq`) on the full round trip in all
; three. See receipts/2026-07-02-bool-node-value-round-trip.md.
;
; Verdict 255 when every assertion holds.

(do
    (defn wbb-score (ok bit) (if ok bit 0))
    (defn wire-bool-band ()
        (do
    (let reg (list (wr-entry "OUTER" (bp "OUTER"))))
    (let cell (intern_node (bp "OUTER") (list (intern_trivial_bool true) (intern_trivial_bool false))))

    ; --- JSON dialect (cell-serialize.fk) ---
    (let jtext (cell-to-json cell reg))
    (let c0 (wbb-score (str_eq jtext "{\"bp\":\"OUTER\",\"c\":[true,false]}") 1))
    (let c1 (wbb-score (eq (json-to-cell jtext reg) cell) 2))                    ; identity round-trip

    ; --- XML dialect (wire-xml.fk) ---
    (let xtext (cell-to-xml cell reg))
    (let c2 (wbb-score (str_eq xtext "<OUTER><b>true</b><b>false</b></OUTER>") 4))
    (let c3 (wbb-score (eq (xml-to-cell xtext reg) cell) 8))                     ; identity round-trip

    ; --- CDR dialect (wire-corba-cdr.fk, binary) ---
    (let cbuf (cell-to-cdr cell reg))
    (let c4 (wbb-score (eq (cdr-to-cell cbuf reg) cell) 16))                     ; identity round-trip

    ; --- the two values stay distinct through the binary wire (no collapse) ---
    (let t-only (intern_node (bp "OUTER") (list (intern_trivial_bool true))))
    (let f-only (intern_node (bp "OUTER") (list (intern_trivial_bool false))))
    (let c5 (wbb-score (eq (cdr-to-cell (cell-to-cdr t-only reg) reg) t-only) 32))
    (let c6 (wbb-score (eq (cdr-to-cell (cell-to-cdr f-only reg) reg) f-only) 64))
    (let c7 (wbb-score (not (eq t-only f-only)) 128))                            ; true-cell and false-cell are NOT the same cell

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (wire-bool-band))
