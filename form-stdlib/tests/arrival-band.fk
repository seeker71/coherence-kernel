; arrival-band.fk — proof of the arrival protocol.
;
; preludes: form-stdlib/reception-consent.fk form-stdlib/arrival.fk
;
; Asserts: an arrival carries its subject/context/offering readably; the
; default welcome is spacious and deterministic (same content, same node);
; a cell-identity round-trips its parts; mutual-introduction is a distinct
; resonance from the bare welcome; and — the honest seam — whether a
; "remembered" welcome is even offered is read from the arriving cell's own
; consent (reception-consent.fk), never assumed: consent open composes into
; a resonance that names the persistence gap honestly, consent closed (or
; silence) falls back to the same spacious welcome-as-empty-room.
;
; Verdict 1023 when every assertion holds across sibling kernels and fkwu.

(do
    (defn ab-score (ok bit) (if ok bit 0))
    (defn arrival-band ()
        (do
    (let arr (arrival (intern_trivial_string "a-subject")
                       (intern_trivial_string "a-context")
                       (intern_trivial_string "an-offering")))
    (let id-a (cell-identity (intern_trivial_string "ref-a") (intern_trivial_string "desc-a")))
    (let id-b (cell-identity (intern_trivial_string "ref-b") (intern_trivial_string "desc-b")))
    (let c0 (ab-score (eq (arrival-subject arr) (intern_trivial_string "a-subject")) 1))
    (let c1 (ab-score (eq (arrival-context arr) (intern_trivial_string "a-context")) 2))
    (let c2 (ab-score (eq (arrival-offering arr) (intern_trivial_string "an-offering")) 4))
    (let c3 (ab-score (eq (welcome-as-empty-room) (welcome-as-empty-room)) 8))
    (let c4 (ab-score (eq (identity-ref id-a) (intern_trivial_string "ref-a")) 16))
    (let c5 (ab-score (eq (identity-description id-a) (intern_trivial_string "desc-a")) 32))
    (let c6 (ab-score (not (eq (mutual-introduction id-a id-b (list (QUALITY-RESONANT)))
                               (welcome-as-empty-room))) 64))
    (let c7 (ab-score (eq (arrival-remembered? (rc-open)) true) 128))
    (let c8 (ab-score (eq (arrival-remembered? (rc-closed)) false) 256))
    (let c9 (ab-score (eq (welcome-for-arrival (rc-closed)) (welcome-as-empty-room)) 512))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9))))))))))
    )
    (arrival-band))
