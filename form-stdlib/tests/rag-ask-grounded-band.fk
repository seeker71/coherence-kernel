; rag-ask-grounded-band.fk — paraphrase -> exact attributed answer, not an ID receipt.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk
; preludes: form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
; preludes: form-stdlib/rag-retrieve.fk form-stdlib/rag-index-codec.fk
; preludes: form-stdlib/rag-ask.fk
;
; verdict 65535 proves pure selection and the live host-read path:
;   1    a semantic paraphrase selects a hit
;   2    selected identity is the NamedCell REF NodeID
;   4    selected content CTOR remains bound independently
;   8    query coverage clears the explicit content threshold
;   16   top-vs-runner confidence is independently positive
;   32   answer_hex decodes to the exact intended answer content
;   64   the complete attributed answer binds exactly to the selected hit
;   128  a legacy path-id row is refused before ranking
;   256  an unrelated query misses rather than returning a nearest fiction
;   512  live write->read->parse->retrieve returns the exact answer on the kernel
;   1024 source path/key remain attached to the selected answer
;   2048 answer bytes whose SHA-256 does not match answer_key are refused
;   4096 an answer selected for B cannot satisfy A's complete output binding
;   8192 a three-feature nonsense query does not collide into a grounded hit
;   16384 a one-feature unknown query does not collide into a grounded hit
;   32768 sufficiency thresholds preserve whole dual-hash feature pairs

(do
    (defn rab-bytes-loop (s i n out)
        (if (ge i n) out
            (rab-bytes-loop s (add i 1) n (cons (str-byte-at s i) out))))
    (defn rab-reverse (xs out)
        (if (eq (len xs) 0) out (rab-reverse (tail xs) (cons (head xs) out))))
    (defn rab-bytes (s)
        (rab-reverse (rab-bytes-loop s 0 (str_len s) (empty)) (empty)))

    (let answer "Kernel deployment is live and verified by current production evidence.")
    (let answer-hex (hex-encode (rab-bytes answer)))
    (let answer-key (hex-encode (sha256 (rab-bytes answer))))
    (let other-answer "Garden soil moisture and seed planting guide.")
    (let other-answer-hex (hex-encode (rab-bytes other-answer)))
    (let other-answer-key (hex-encode (sha256 (rab-bytes other-answer))))
    (let right-key "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    (let other-key "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb")
    (let tampered-key "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc")
    (let right-line (ric-emit-grounded
        "@1.1.9.41" "@8.4.4.12" "docs/deployment.form" "cell" right-key
        answer-key answer-hex answer
        (re-semantic-vec "deployment evidence kernel production verified witness")))
    (let other-line (ric-emit-grounded
        "@1.1.9.42" "@8.4.4.13" "docs/gardening.form" "cell" other-key
        other-answer-key other-answer-hex other-answer
        (re-semantic-vec "garden soil moisture seed planting")))
    (let tampered-line (ric-emit-grounded
        "@1.1.9.43" "@8.4.4.14" "docs/tampered.form" "cell" tampered-key
        answer-key other-answer-hex other-answer
        (re-semantic-vec "deployment evidence kernel production verified witness")))
    (let legacy (ric-emit "docs/legacy-path.form" "cell" "old" "legacy" (re-semantic-vec "release proof")))
    (let raw (str_concat right-line
        (str_concat (byte_to_str 10)
        (str_concat legacy
        (str_concat (byte_to_str 10)
        (str_concat tampered-line
        (str_concat (byte_to_str 10) other-line)))))))
    (let entries (ra-entries-of (ra-lines raw)))
    (let hit (ra-select-hit "deployed proof kernel" entries))
    (let other-hit (ra-select-hit "garden moisture planting" entries))
    (let output (ra-hit-output hit))
    (let miss (ra-select-hit "banana photosynthesis galaxy" entries))
    (let collision-miss (ra-select-hit "quantum banana xylophone" entries))
    (let single-miss (ra-select-hit "aardvark" entries))

    (let b1 (if (eq (ra-hit? hit) 1) 1 0))
    (let b2 (if (str_eq (ra-hit-node-id hit) "@1.1.9.41") 2 0))
    (let b4 (if (str_eq (ra-hit-content-node-id hit) "@8.4.4.12") 4 0))
    (let b8 (if (eq (ra-hit-sufficient? hit) 1) 8 0))
    (let b16 (if (gt (ra-hit-confidence hit) 0) 16 0))
    (let b32 (if (str_eq (ra-output-answer output) answer) 32 0))
    (let b64 (if (and (eq (ra-output-binds-hit? output hit) 1)
                      (eq (ra-output-answer-binds-hit? output hit) 1)) 64 0))
    (let b128 (if (eq (len entries) 2) 128 0))
    (let b256 (if (eq (ra-hit? miss) 0) 256 0))

    ; Exercise the actual host carrier, not only literal rows.
    (let live-path (str_concat (temp_dir) "/rag-ask-grounded-band.jsonl"))
    (let wrote (write_file live-path raw))
    (let live-output (ra-grounded-at live-path "deployed proof kernel"))
    (let cleaned (fs_remove live-path))
    (let b512 (if (and (str_eq (ra-output-node-id live-output) "@1.1.9.41")
                       (str_eq (ra-output-answer live-output) answer)) 512 0))
    (let b1024 (if (and (str_eq (ra-hit-source-path hit) "docs/deployment.form")
                        (str_eq (ra-hit-key hit) right-key)) 1024 0))
    (let b2048 (if (and (eq (ra-line-ready? tampered-line) 0)
                         (eq (len entries) 2)) 2048 0))
    (let b4096 (if (and (eq (ra-hit? other-hit) 1)
                         (eq (ra-output-binds-hit? (ra-hit-output other-hit) hit) 0)) 4096 0))
    (let b8192 (if (eq (ra-hit? collision-miss) 0) 8192 0))
    (let b16384 (if (eq (ra-hit? single-miss) 0) 16384 0))
    (let b32768 (if (and
            (and (eq (ra-hit-threshold (ra-hit-row "hit" (ra-hit-entry hit) 2 0 2 100)) 2)
                 (eq (ra-hit-threshold (ra-hit-row "hit" (ra-hit-entry hit) 4 0 4 100)) 4))
            (and (eq (ra-hit-threshold (ra-hit-row "hit" (ra-hit-entry hit) 4 0 6 100)) 4)
                 (eq (ra-hit-threshold (ra-hit-row "hit" (ra-hit-entry hit) 6 0 8 100)) 6))) 32768 0))

    (add b1 (add b2 (add b4 (add b8 (add b16 (add b32
        (add b64 (add b128 (add b256 (add b512
        (add b1024 (add b2048 (add b4096 (add b8192
        (add b16384 b32768))))))))))))))))
