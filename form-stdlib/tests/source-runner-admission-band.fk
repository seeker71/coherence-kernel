; source-runner-admission-band.fk -- direct `--src` admission policy witness.
;
; preludes: form-stdlib/core.fk form-stdlib/source-runner-admission.fk
;
; run: cat form/form-stdlib/core.fk \
;          form/form-stdlib/source-runner-admission.fk \
;          form/form-stdlib/tests/source-runner-admission-band.fk > /tmp/sra.fk
;      ./fkwu --src /tmp/sra.fk    ; -> 2097151
;
; Bits:
;   1      manifest declares runner-health-first
;   2      manifest declares parity-noncircular
;   4      manifest declares capacity-routes-artifact
;   8      manifest declares silent-wrong-investigates
;   16     manifest declares oom-kill-investigates
;   32     manifest declares missing-observation-denies
;   64     manifest declares no-c-growth-remediation-constraint
;   128    manifest declares layer8-handles-artifacts
;   256    manifest declares source-identity-required
;   512    all-green gates admit direct source
;   1024   loud AST/capacity error routes to artifact lane
;   2048   silent wrong value routes to investigation
;   4096   OOM/killed routes to investigation
;   8192   stale freshness routes to investigation
;   16384  native-body failure routes to investigation
;   32768  semantic parity failure routes to investigation
;   65536  unknown/missing observation routes to investigation
;   131072 current let parity probe is green
;   262144 current ontology-loader probe is green
;   524288 current snapshot admits direct source because observed gates are green
;   1048576 mirror/static boundary holds

(do
    (defn srab-score (ok bit) (if ok bit 0))
    (defn srab-manifest-has (name)
        (sra-manifest-has? name (source-runner-admission-manifest)))
    (defn srab-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn srab-read-file-any (primary fallback)
        (if (ge (file_size primary) 0)
            (read_file primary)
            (read_file fallback)))
    (defn srab-green-gates ()
        (list
            (sra-gate "freshness" "health" "kernel" (sra-status-green) "ok" "binary-freshness-band" "15" "15")
            (sra-gate "native" "health" "kernel" (sra-status-green) "ok" "native-vs-rented" "11111" "11111")
            (sra-gate "let" "parity" "program" (sra-status-green) "ok" "(do (let x 40) (add x 2))" "42" "42")
            (sra-gate "c-growth" "remediation" "runtime/fkwu-uni.c" (sra-status-green) "ok" "runtime/fkwu-uni.c" "no AST-cap growth" "read repair receipted")))
    (defn srab-capacity-gates ()
        (list
            (sra-gate "freshness" "health" "kernel" (sra-status-green) "ok" "binary-freshness-band" "15" "15")
            (sra-gate "ontology" "capacity" "program" (sra-status-red) "loud-error" "form-ontology-loader.fk" "fits" "fk_smknode")))
    (defn srab-silent-wrong-gates ()
        (list
            (sra-gate "freshness" "health" "kernel" (sra-status-green) "ok" "binary-freshness-band" "15" "15")
            (sra-gate "hdc-core" "composition" "prelude+program" (sra-status-red) "silent-wrong" "core+homecoming" "39" "0")))

    (defn srab-manifest-band ()
        (add
            (srab-score (eq (srab-manifest-has "runner-health-first") 1) 1)
            (add
                (srab-score (eq (srab-manifest-has "parity-noncircular") 1) 2)
                (add
                    (srab-score (eq (srab-manifest-has "capacity-routes-artifact") 1) 4)
                    (add
                        (srab-score (eq (srab-manifest-has "silent-wrong-investigates") 1) 8)
                        (add
                            (srab-score (eq (srab-manifest-has "oom-kill-investigates") 1) 16)
                            (add
                                (srab-score (eq (srab-manifest-has "missing-observation-denies") 1) 32)
                                (add
                                    (srab-score (eq (srab-manifest-has "no-c-growth-remediation-constraint") 1) 64)
                                    (add
                                        (srab-score (eq (srab-manifest-has "layer8-handles-artifacts") 1) 128)
                                        (srab-score (eq (srab-manifest-has "source-identity-required") 1) 256))))))))))

    (defn srab-route-band ()
        (add
            (srab-score (eq (sra-route (srab-green-gates)) (sra-route-admit-direct)) 512)
            (add
                (srab-score (eq (sra-route (srab-capacity-gates)) (sra-route-artifact-lane)) 1024)
                (add
                    (srab-score (eq (sra-route (srab-silent-wrong-gates)) (sra-route-investigate)) 2048)
                    (add
                        (srab-score (eq (sra-route (list (sra-gate "oom" "health" "kernel" (sra-status-red) "oom-killed" "layer probe" "no kill" "killed"))) (sra-route-investigate)) 4096)
                        (add
                            (srab-score (eq (sra-route (list (sra-gate "freshness" "health" "kernel" (sra-status-red) "stale-binary" "binary-freshness-band" "15" "0"))) (sra-route-investigate)) 8192)
                            (add
                                (srab-score (eq (sra-route (list (sra-gate "native" "health" "kernel" (sra-status-red) "native-body-fail" "native-vs-rented" "11111" "0"))) (sra-route-investigate)) 16384)
                                (add
                                    (srab-score (eq (sra-route (list (sra-gate "let" "parity" "program" (sra-status-red) "semantic-divergence" "(do (let x 40) (add x 2))" "42" "2"))) (sra-route-investigate)) 32768)
                                    (srab-score (eq (sra-route (list (sra-gate "missing" "composition" "program" (sra-status-unknown) "missing" "unknown" "observed" "missing"))) (sra-route-investigate)) 65536)))))))))

    (defn srab-current-band ()
        (add
            (srab-score (sra-gate-green? (sra-current-let-parity-gate)) 131072)
            (add
                (srab-score (sra-gate-green? (sra-current-ontology-gate)) 262144)
                (srab-score (eq (sra-route (sra-current-gates)) (sra-route-admit-direct)) 524288))))

    (defn srab-static-and-mirror-band ()
        (do
            (let text (srab-read-file-any "form/form-stdlib/source-runner-admission.fk"
                                          "../form/form-stdlib/source-runner-admission.fk"))
            (let grammar (srab-read-file-any "grammars/source-runner-admission.fk"
                                             "../grammars/source-runner-admission.fk"))
            (srab-score
                (and (str_eq text grammar)
                (and (not (srab-has? text "read_file"))
                (and (not (srab-has? text "file_size"))
                (and (not (srab-has? text "file_mtime"))
                (and (not (srab-has? text "fs-read"))
                (and (not (srab-has? text "fs-write"))
                (and (not (srab-has? text "write_file"))
                (and (not (srab-has? text "write_form_binary"))
                (and (not (srab-has? text "read_form_binary"))
                (and (not (srab-has? text "recipe_to_bytes"))
                (and (not (srab-has? text "bytes_to_recipe"))
                (and (not (srab-has? text "walk_recipe"))
                (and (not (srab-has? text "fk_run"))
                (and (not (srab-has? text "dlopen"))
                (and (not (srab-has? text "dlsym"))
                (and (not (srab-has? text "runtime-artifact-attempt"))
                (and (not (srab-has? text "runtime-table-text-attempt"))
                (and (not (srab-has? text "source-artifact-probe-observation"))
                (and (not (srab-has? text "sap-observation"))
                (and (not (srab-has? text "rao-obs"))
                     (not (srab-has? text "selector-install"))))))))))))))))))))))
                1048576)))

    (defn source-runner-admission-band ()
        (add (srab-manifest-band)
            (add (srab-route-band)
            (add (srab-current-band) (srab-static-and-mirror-band)))))

    (source-runner-admission-band))
