; sibling-ref-authoring-language-band.fk -- fixed sibling-ref authoring witness.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/domain-grammar-core.fk form-stdlib/grammar-authoring-language.fk form-stdlib/sibling-ref-authoring-language.fk
;
; Expected: 2147483647

(do
    (defn sralb-score (ok bit) (if ok bit 0))
    (defn sralb-manifest-has (name)
        (sibling-ref-authoring-language-manifest-has? name (sibling-ref-authoring-language-manifest)))
    (defn sralb-source ()
        "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { pair left number right number -> pair number value digit -> number }")
    (defn sralb-loose-source ()
        "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe {   pair   left   number   right   number   ->   pair   number   value   digit   ->   number   }")
    (defn sralb-decl () (sral-parse (sralb-source)))
    (defn sralb-lower () (sral-lower-domain (sralb-decl)))
    (defn sralb-grammar () (dgcore-domain-grammar (sralb-lower)))
    (defn sralb-reg () (sral-register-lowered (sralb-decl)))
    (defn sralb-authored-result () (dgcore-parse (sralb-reg) "programming" "pair number 4 number 27"))
    (defn sralb-authored-bad () (dgcore-parse (sralb-reg) "programming" "pair number x number 27"))
    (defn sralb-left-node () (nth (node_children (sralb-authored-result)) 1))
    (defn sralb-right-node () (nth (node_children (sralb-authored-result)) 2))
    (defn sralb-hand-grammar ()
        (grammar "pair" (list
            (rule3 "pair"
                (list "seq"
                    (p-lit "pair")
                    (p-cap "left" (p-ref "number"))
                    (p-cap "right" (p-ref "number")))
                (t-emit "fncall"
                    (list (t-const "__pair__")
                          (t-splice "left")
                          (t-splice "right"))))
            (rule3 "number"
                (list "seq"
                    (p-lit "number")
                    (p-cap "value" (p-run "digit")))
                (t-emit "fncall"
                    (list (t-const "__number__")
                          (t-splice "value")))))))
    (defn sralb-hand-reg () (gl-register (gl-empty) "programming" (sralb-hand-grammar)))
    (defn sralb-hand-result () (dgcore-parse (sralb-hand-reg) "programming" "pair number 4 number 27"))
    (defn sralb-hand-bad () (dgcore-parse (sralb-hand-reg) "programming" "pair number x number 27"))
    (defn sralb-hand-left () (nth (node_children (sralb-hand-result)) 1))
    (defn sralb-hand-right () (nth (node_children (sralb-hand-result)) 2))
    (defn sralb-trailing-decl () (sral-parse (str_concat (sralb-source) " trailing")))
    (defn sralb-malformed-decl ()
        (sral-parse "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { pair left number right number pair number value digit -> number }"))
    (defn sralb-duplicate-decl ()
        (sral-parse "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { pair left pair right pair -> pair pair value digit -> pair }"))
    (defn sralb-mismatch-decl ()
        (sral-parse "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { pair left number right count -> pair number value digit -> number }"))
    (defn sralb-nospace-decl ()
        (sral-parse "domain programming family programming-language semantic semantic-stdlib evidence compiler-proof residue syntax-semantic-residue lower form-recipe { pair left number right number -> pair number value digit->number }"))

    (defn sibling-ref-authoring-language-band ()
        (add
            (sralb-score (eq (sralb-manifest-has "scannerless") 1) 1)
        (add
            (sralb-score (eq (sralb-manifest-has "bmf-cursor-grammar") 1) 2)
        (add
            (sralb-score (eq (sralb-manifest-has "no-line-grammar") 1) 4)
        (add
            (sralb-score (eq (sralb-manifest-has "no-tokenizer") 1) 8)
        (add
            (sralb-score (eq (sralb-manifest-has "not-s-expression-surface") 1) 16)
        (add
            (sralb-score (eq (sralb-manifest-has "not-form-cell-authoring") 1) 32)
        (add
            (sralb-score (eq (sralb-manifest-has "exactly-two-rules") 1) 64)
        (add
            (sralb-score (eq (sralb-manifest-has "fixed-sibling-pattern") 1) 128)
        (add
            (sralb-score (eq (sralb-manifest-has "leaf-second-rule") 1) 256)
        (add
            (sralb-score (eq (sralb-manifest-has "internal-ref-only") 1) 512)
        (add
            (sralb-score (eq (sralb-manifest-has "no-general-ref-surface") 1) 1024)
        (add
            (sralb-score (eq (sralb-manifest-has "metadata-only-lanes") 1) 2048)
        (add
            (sralb-score (eq (sralb-manifest-has "grammar-value-lowering") 1) 4096)
        (add
            (sralb-score (sral-ok? (sralb-decl)) 8192)
        (add
            (sralb-score (str_eq (sral-domain-name (sralb-decl)) "programming") 16384)
        (add
            (sralb-score (str_eq (sral-family (sralb-decl)) "programming-language") 32768)
        (add
            (sralb-score
                (and (str_eq (sral-semantic-lane (sralb-decl)) "semantic-stdlib")
                     (and (str_eq (sral-evidence-lane (sralb-decl)) "compiler-proof")
                          (and (str_eq (sral-residue-policy (sralb-decl)) "syntax-semantic-residue")
                               (str_eq (sral-lower-target (sralb-decl)) "form-recipe"))))
                65536)
        (add
            (sralb-score
                (and (str_eq (sral-start-literal (sralb-decl)) "pair")
                     (and (str_eq (sral-left-capture (sralb-decl)) "left")
                          (and (str_eq (sral-left-leaf (sralb-decl)) "number")
                               (and (str_eq (sral-right-capture (sralb-decl)) "right")
                                    (str_eq (sral-right-leaf (sralb-decl)) "number")))))
                131072)
        (add
            (sralb-score
                (and (str_eq (sral-start-emit (sralb-decl)) "pair")
                     (and (str_eq (sral-leaf-literal (sralb-decl)) "number")
                          (and (str_eq (sral-leaf-capture (sralb-decl)) "value")
                               (and (str_eq (sral-leaf-class (sralb-decl)) "digit")
                                    (str_eq (sral-leaf-emit (sralb-decl)) "number")))))
                262144)
        (add
            (sralb-score (sral-lower-ok? (sralb-lower)) 524288)
        (add
            (sralb-score (str_eq (dgcore-domain-kind (sralb-lower)) "domain-grammar") 1048576)
        (add
            (sralb-score (str_eq (g-start (sralb-grammar)) "pair") 2097152)
        (add
            (sralb-score (eq (len (g-rules (sralb-grammar))) 2) 4194304)
        (add
            (sralb-score
                (and (eq (gl-count (sralb-reg)) 1)
                     (gl-has? (sralb-reg) "programming"))
                8388608)
        (add
            (sralb-score
                (and (dgcore-ok? (sralb-authored-result))
                     (str_eq (dgcore-node-tag (sralb-authored-result)) "__pair__"))
                16777216)
        (add
            (sralb-score
                (and (str_eq (dgcore-node-tag (sralb-left-node)) "__number__")
                     (str_eq (dgcore-node-slot (sralb-left-node) 1) "4"))
                33554432)
        (add
            (sralb-score
                (and (str_eq (dgcore-node-tag (sralb-right-node)) "__number__")
                     (str_eq (dgcore-node-slot (sralb-right-node) 1) "27"))
                67108864)
        (add
            (sralb-score
                (and (str_eq (dgcore-node-tag (sralb-authored-result)) (dgcore-node-tag (sralb-hand-result)))
                     (and (str_eq (dgcore-node-tag (sralb-left-node)) (dgcore-node-tag (sralb-hand-left)))
                          (and (str_eq (dgcore-node-slot (sralb-left-node) 1) (dgcore-node-slot (sralb-hand-left) 1))
                               (and (str_eq (dgcore-node-tag (sralb-right-node)) (dgcore-node-tag (sralb-hand-right)))
                                    (and (str_eq (dgcore-node-slot (sralb-right-node) 1) (dgcore-node-slot (sralb-hand-right) 1))
                                         (and (not (dgcore-ok? (sralb-authored-bad)))
                                              (not (dgcore-ok? (sralb-hand-bad)))))))))
                134217728)
        (add
            (sralb-score
                (and (not (sral-ok? (sralb-trailing-decl)))
                     (and (not (sral-ok? (sralb-malformed-decl)))
                          (not (sral-ok? (sralb-nospace-decl)))))
                268435456)
        (add
            (sralb-score
                (and (not (sral-valid? (sralb-duplicate-decl)))
                     (not (sral-valid? (sralb-mismatch-decl))))
                536870912)
            (sralb-score (sral-ok? (sral-parse (sralb-loose-source))) 1073741824))))))))))))))))))))))))))))))))

    (sibling-ref-authoring-language-band))
