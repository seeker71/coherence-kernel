; program-image-table-text-witness-band.fk -- witness .tbl text file witness.
;
; preludes: form-stdlib/core.fk form-stdlib/form-fs.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-tbl-emit.fk form-stdlib/program-image-table-text-witness.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-table-text-attempt.fk
;
; Expected: 2147483647

(do
    (defn pitwb-score (ok bit) (if ok bit 0))
    (defn pitwb-manifest-has (name)
        (program-image-table-text-witness-manifest-has? name (program-image-table-text-witness-manifest)))
    (defn pitwb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn pitwb-read-text-any (primary fallback)
        (if (ge (fs-stat-size primary) 0)
            (fs-read-text primary)
            (fs-read-text fallback)))

    (defn pitwb-root ()
        (fs-path-join (fs-temp-dir) "program-image-table-text-witness-band"))
    (defn pitwb-path (name)
        (fs-path-join (pitwb-root) name))
    (defn pitwb-table-path () (pitwb-path "min42.tbl"))
    (defn pitwb-invalid-path () (pitwb-path "invalid.tbl"))
    (defn pitwb-fail-path () (fs-path-join (pitwb-path "missing-dir") "min42.tbl"))

    (defn pitwb-setup ()
        (do
            (let _pre (fs-remove-tree (pitwb-root)))
            (fs-mkdir (pitwb-root))))
    (defn pitwb-cleanup ()
        (fs-remove-tree (pitwb-root)))

    (defn pitwb-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn pitwb-bad-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (list 1 42 0))
                         0
                         (empty)))
    (defn pitwb-pif ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (pitwb-table)))
    (defn pitwb-pif-seal-bad ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      0
                      (pitwb-table)))
    (defn pitwb-pif-bad-table ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (pitwb-bad-table)))
    (defn pitwb-malformed-pif ()
        (list "program-image-fkb-envelope" 1))
    (defn pitwb-golden () "1 0 1 1 42 0 0 0\n")

    (defn pitwb-source () (pif-source-from-envelope (pitwb-pif)))
    (defn pitwb-fkb () (pif-descriptor-from-envelope (pitwb-pif)))
    (defn pitwb-selection ()
        (ras-selection-from-plan
            (rap-plan-from-descriptors (pitwb-source) (pitwb-fkb) (sad-no-artifact))))
    (defn pitwb-envelope ()
        (rale-envelope-from-selection (pitwb-source) (pitwb-fkb) (sad-no-artifact) (pitwb-selection)))
    (defn pitwb-run (path status first lines code)
        (rtta-supplied-table-run path first lines code status "pitw-supplied-table-run"))

    (defn pitwb-good-row ()
        (pitw-file-witness-from-envelope (pitwb-table-path) (pitwb-pif)))

    (defn pitwb-bit-manifest-1 ()
        (sum (list
            (pitwb-score (eq (pitwb-manifest-has "table-text-file-witness-carrier") 1) 1)
            (pitwb-score (eq (pitwb-manifest-has "uses-pite-write-table-text") 1) 2)
            (pitwb-score (eq (pitwb-manifest-has "readback-text-becomes-witness") 1) 4)
            (pitwb-score (eq (pitwb-manifest-has "witness-row-compatible-with-9h0") 1) 8)
            (pitwb-score (eq (pitwb-manifest-has "no-witness-sentinel") 1) 16)
            (pitwb-score (eq (pitwb-manifest-has "invalid-pif-nondestructive") 1) 32)
            (pitwb-score (eq (pitwb-manifest-has "write-readback-failure-observable") 1) 64)
            (pitwb-score (eq (pitwb-manifest-has "no-9h0-code-dependency") 1) 128))))
    (defn pitwb-bit-manifest-2 ()
        (sum (list
            (pitwb-score (eq (pitwb-manifest-has "no-binary-artifact-io") 1) 256)
            (pitwb-score (eq (pitwb-manifest-has "no-program-image-load") 1) 512)
            (pitwb-score (eq (pitwb-manifest-has "no-table-execution") 1) 1024)
            (pitwb-score (eq (pitwb-manifest-has "no-9f-attempt") 1) 2048)
            (pitwb-score (eq (pitwb-manifest-has "no-9c-observation") 1) 4096)
            (pitwb-score (eq (pitwb-manifest-has "no-selector-install") 1) 8192)
            (pitwb-score (eq (pitwb-manifest-has "no-c-seed-growth") 1) 16384)
            (pitwb-score (str_eq (pitw-version) "program-image-table-text-witness-v1") 32768))))

    (defn pitwb-bit-valid-file-witness ()
        (do
            (let _rm (fs-remove-file (pitwb-table-path)))
            (let row (pitwb-good-row))
            (let w (pitw-row-witness row))
            (pitwb-score
                (and (pitw-row? row)
                (and (str_eq (pitw-row-status row) (pitw-status-witness-ready))
                (and (str_eq (pitw-row-reason row) (pitw-reason-table-text-file-witness-ready))
                (and (eq (pitw-row-wrote row) 1)
                (and (pitw-table-text-witness? w)
                (and (str_eq (pitw-witness-path w) (pitwb-table-path))
                (and (str_eq (pitw-witness-text w) (pitwb-golden))
                     (str_eq (fs-read-text (pitwb-table-path)) (pitwb-golden)))))))))
                65536)))
    (defn pitwb-bit-carrier-golden ()
        (do
            (let row (pitwb-good-row))
            (pitwb-score
                (and (str_eq (nth row 0) "program-image-table-text-file-witness")
                (and (str_eq (nth row 1) (pitwb-table-path))
                (and (pif-envelope? (nth row 2))
                (and (str_eq (nth row 3) (pitwb-golden))
                (and (eq (nth row 4) 1)
                (and (pitw-table-text-witness? (nth row 5))
                (and (str_eq (nth row 6) (pitw-status-witness-ready))
                     (str_eq (nth row 7) (pitw-reason-table-text-file-witness-ready)))))))))
                131072)))
    (defn pitwb-bit-witness-readback-not-rendered-only ()
        (do
            (let row (pitwb-good-row))
            (pitwb-score
                (and (str_eq (pitw-row-table-text row) (pitwb-golden))
                     (str_eq (pitw-witness-text (pitw-row-witness row)) (fs-read-text (pitwb-table-path))))
                262144)))
    (defn pitwb-bit-invalid-absent-nondestructive ()
        (do
            (let _rm (fs-remove-file (pitwb-invalid-path)))
            (let row (pitw-file-witness-from-envelope (pitwb-invalid-path) (pitwb-pif-seal-bad)))
            (pitwb-score
                (and (str_eq (pitw-row-status row) (pitw-status-refused))
                (and (str_eq (pitw-row-reason row) (pitw-reason-invalid-pif-envelope))
                (and (pitw-no-witness? (pitw-row-witness row))
                     (eq (fs-stat-size (pitwb-invalid-path)) -1))))
                524288)))
    (defn pitwb-bit-invalid-sentinel-unchanged ()
        (do
            (let sentinel "do-not-overwrite\n")
            (let _seed (fs-write-text (pitwb-invalid-path) sentinel))
            (let row (pitw-file-witness-from-envelope (pitwb-invalid-path) (pitwb-pif-bad-table)))
            (pitwb-score
                (and (str_eq (pitw-row-status row) (pitw-status-refused))
                (and (str_eq (pitw-row-reason row) (pitw-reason-invalid-pif-envelope))
                (and (pitw-no-witness? (pitw-row-witness row))
                     (str_eq (fs-read-text (pitwb-invalid-path)) sentinel))))
                1048576)))
    (defn pitwb-bit-malformed-pif-refused ()
        (do
            (let row (pitw-file-witness-from-envelope (pitwb-invalid-path) (pitwb-malformed-pif)))
            (pitwb-score
                (and (str_eq (pitw-row-status row) (pitw-status-refused))
                (and (str_eq (pitw-row-reason row) (pitw-reason-malformed-pif-envelope))
                     (pitw-no-witness? (pitw-row-witness row))))
                2097152)))
    (defn pitwb-bit-forced-write-failure ()
        (do
            (let row (pitw-file-witness-from-envelope (pitwb-fail-path) (pitwb-pif)))
            (pitwb-score
                (and (str_eq (pitw-row-status row) (pitw-status-investigate))
                (and (str_eq (pitw-row-reason row) (pitw-reason-write-readback-failed))
                (and (eq (pitw-row-wrote row) 0)
                (and (pitw-no-witness? (pitw-row-witness row))
                     (eq (fs-stat-size (pitwb-fail-path)) -1)))))
                4194304)))
    (defn pitwb-bit-no-witness-invariant ()
        (do
            (let good (pitwb-good-row))
            (let bad (pitw-file-witness-from-envelope (pitwb-invalid-path) (pitwb-pif-seal-bad)))
            (let fail (pitw-file-witness-from-envelope (pitwb-fail-path) (pitwb-pif)))
            (pitwb-score
                (and (eq (pitw-row-wrote good) 1)
                (and (pitw-table-text-witness? (pitw-row-witness good))
                (and (eq (pitw-row-wrote bad) 0)
                (and (pitw-no-witness? (pitw-row-witness bad))
                     (pitw-no-witness? (pitw-row-witness fail))))))
                8388608)))
    (defn pitwb-bit-9h0-handshake ()
        (do
            (let row (pitwb-good-row))
            (let bridge
                (rtta-bridge-from-run
                    (pitwb-envelope)
                    (pitwb-pif)
                    (pitw-row-witness row)
                    (pitwb-run (pitw-witness-path (pitw-row-witness row)) (rao-obs-ok) 42 257 0)))
            (pitwb-score
                (and (str_eq (rtta-bridge-status bridge) (rtta-status-attempt-ready))
                (and (str_eq (rtta-bridge-reason bridge) (rtta-reason-table-run-bound))
                     (raar-supplied-attempt? (rtta-bridge-attempt bridge))))
                16777216)))
    (defn pitwb-bit-9f-9c-handshake ()
        (do
            (let row (pitwb-good-row))
            (let bridge
                (rtta-bridge-from-run
                    (pitwb-envelope)
                    (pitwb-pif)
                    (pitw-row-witness row)
                    (pitwb-run (pitw-witness-path (pitw-row-witness row)) (rao-obs-ok) 42 257 0)))
            (let receipt (raar-receipt-from-envelope-attempt (rtta-bridge-envelope bridge) (rtta-bridge-attempt bridge)))
            (let outcome (rao-outcome-from-selection-observation
                            (raar-receipt-selection receipt)
                            (raar-receipt-derived-observation receipt)))
            (pitwb-score
                (and (str_eq (raar-receipt-status receipt) (raar-status-observed))
                     (str_eq (rao-outcome-status outcome) (rao-status-complete)))
                33554432)))
    (defn pitwb-bit-runtime-path-mismatch-still-investigates ()
        (do
            (let row (pitwb-good-row))
            (let bridge
                (rtta-bridge-from-run
                    (pitwb-envelope)
                    (pitwb-pif)
                    (pitw-row-witness row)
                    (pitwb-run "/tmp/other.tbl" (rao-obs-ok) 42 257 0)))
            (pitwb-score
                (and (str_eq (rtta-bridge-status bridge) (rtta-status-investigate))
                     (str_eq (rtta-bridge-reason bridge) (rtta-reason-table-path-mismatch)))
                67108864)))
    (defn pitwb-bit-reason-shapes-and-empty-defensive ()
        (pitwb-score
            (and (str_eq (pitw-reason-table-text-file-witness-ready) "table-text-file-witness-ready")
            (and (str_eq (pitw-reason-malformed-pif-envelope) "malformed-pif-envelope")
            (and (str_eq (pitw-reason-invalid-pif-envelope) "invalid-pif-envelope")
            (and (str_eq (pitw-reason-empty-table-text) "empty-table-text")
            (and (str_eq (pitw-reason-write-readback-failed) "write-readback-failed")
                 (gt (str_len (pite-table-text-from-envelope (pitwb-pif))) 0))))))
            134217728))
    (defn pitwb-bit-no-runtime-dependency-static ()
        (do
            (let text (pitwb-read-text-any "form/form-stdlib/program-image-table-text-witness.fk"
                                           "../form/form-stdlib/program-image-table-text-witness.fk"))
            (pitwb-score
                (and (not (pitwb-has? text "runtime-table-text-attempt"))
                (and (not (pitwb-has? text "rtta-"))
                (and (not (pitwb-has? text "raar-"))
                (and (not (pitwb-has? text "rao-"))
                (and (not (pitwb-has? text "write_form_binary"))
                (and (not (pitwb-has? text "read_form_binary"))
                (and (not (pitwb-has? text "recipe_to_bytes"))
                (and (not (pitwb-has? text "bytes_to_recipe"))
                (and (not (pitwb-has? text "dlopen"))
                (and (not (pitwb-has? text "dlsym"))
                     (not (pitwb-has? text "fk_run"))))))))))))
                268435456)))
    (defn pitwb-bit-mirror ()
        (do
            (let text (pitwb-read-text-any "form/form-stdlib/program-image-table-text-witness.fk"
                                           "../form/form-stdlib/program-image-table-text-witness.fk"))
            (let grammar (pitwb-read-text-any "grammars/program-image-table-text-witness.fk"
                                              "../grammars/program-image-table-text-witness.fk"))
            (pitwb-score
                (str_eq text grammar)
                536870912)))
    (defn pitwb-bit-cleanup-and-neighbor-shape ()
        (do
            (let row (pitwb-good-row))
            (pitwb-score
                (and (pif-envelope-valid? (pitw-row-pif-envelope row))
                (and (str_eq (pite-table-text-from-envelope (pitw-row-pif-envelope row)) (pitw-row-table-text row))
                     (str_eq (pitw-row-path row) (pitw-witness-path (pitw-row-witness row)))))
                1073741824)))

    (defn program-image-table-text-witness-band ()
        (do
            (let _setup (pitwb-setup))
            (let score (sum (list
                (pitwb-bit-manifest-1)
                (pitwb-bit-manifest-2)
                (pitwb-bit-valid-file-witness)
                (pitwb-bit-carrier-golden)
                (pitwb-bit-witness-readback-not-rendered-only)
                (pitwb-bit-invalid-absent-nondestructive)
                (pitwb-bit-invalid-sentinel-unchanged)
                (pitwb-bit-malformed-pif-refused)
                (pitwb-bit-forced-write-failure)
                (pitwb-bit-no-witness-invariant)
                (pitwb-bit-9h0-handshake)
                (pitwb-bit-9f-9c-handshake)
                (pitwb-bit-runtime-path-mismatch-still-investigates)
                (pitwb-bit-reason-shapes-and-empty-defensive)
                (pitwb-bit-no-runtime-dependency-static)
                (pitwb-bit-mirror)
                (pitwb-bit-cleanup-and-neighbor-shape))))
            (let _cleanup (pitwb-cleanup))
            score))

    (program-image-table-text-witness-band))
