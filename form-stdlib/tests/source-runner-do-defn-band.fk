; source-runner-do-defn-band.fk -- top-level do defns after value lets.
;
; This pins the 2026-07-03 direct-source bug where a value-bearing top-level
; `(do ...)` switched into the value parser after a `(let ...)`; later `(defn
; ...)` forms were parsed as value expressions, so their prescanned function
; bodies were not filled and call/binding state was contaminated.
;
; Expected: 127

(defn hidden (x) (add x 100))

(defn local-probe () (do (defn hidden (x) (add x 9)) 5))

(do
    (do (defn nested (x) (add x 3)))
    (defn before (x) (add x 1))
    (let rows (list 8 13 21))
    (defn after (x) (add x 1))
    (defn two (x) 2)
    (defn plus2 (x) (add x 2))
    (let b1 (if (eq (after 1) 2) 1 0))
    (let b2 (if (eq (two 1) 2) 2 0))
    (let b3 (if (eq (head rows) 8) 4 0))
    (let b4 (if (eq (before 1) 2) 8 0))
    (let b5 (if (eq (plus2 3) 5) 16 0))
    (let b6 (if (eq (nested 4) 7) 32 0))
    (let b7 (if (and (eq (local-probe) 5) (eq (hidden 1) 101)) 64 0))
    (add b1 (add b2 (add b3 (add b4 (add b5 (add b6 b7)))))))
