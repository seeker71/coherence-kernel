; defdata-recipe-language-band.fk -- scannerless range recipe data authoring.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/defdata.fk form-stdlib/defdata-language.fk form-stdlib/defdata-recipe-language.fk
;
; Expected: 134217727

(do
    (defn ddrlb-score (ok bit) (if ok bit 0))
    (defn ddrlb-manifest-has (name)
        (defdata-recipe-language-manifest-has? name (defdata-recipe-language-manifest)))
    (defn ddrlb-source ()
        "data evens = range 0 count 6 step 2 cost 4")
    (defn ddrlb-loose-source ()
        "data   evens=range   0   count 6   step 2   cost 4")
    (defn ddrlb-decl () (ddrl-parse (ddrlb-source)))
    (defn ddrlb-lower () (ddrl-lowering (ddrlb-decl)))
    (defn ddrlb-equal-decl () (ddrl-parse "data equal = range 0 count 6 step 2 cost 6"))
    (defn ddrlb-large-fkb-decl () (ddrl-parse "data large = range 0 count 64 step 1 cost 64"))
    (defn ddrlb-large-hybrid-decl () (ddrl-parse "data huge = range 0 count 64 step 1 cost 4"))
    (defn ddrlb-empty-decl () (ddrl-parse "data empty = range 5 count 0 step 2 cost 0"))
    (defn ddrlb-flat-decl () (ddrl-parse "data flat = range 5 count 3 step 0 cost 1"))
    (defn ddrlb-trailing () (ddrl-parse (str_concat (ddrlb-source) " trailing")))
    (defn ddrlb-malformed () (ddrl-parse "data evens = range 0 step 2 count 6 cost 4"))
    (defn ddrlb-bracket-source () "data rows = [8,13,21]")

    (defn defdata-recipe-language-band ()
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "scannerless") 1) 1)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "bmf-cursor-grammar") 1) 2)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "no-line-grammar") 1) 4)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "range-recipe-v1-only") 1) 8)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "consumes-dd-policy") 1) 16)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "author-declared-cost") 1) 32)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "realizes-at-lowering") 1) 64)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "not-load-time-recipe") 1) 128)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "module-constant-lowering") 1) 256)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "not-runtime-primitive") 1) 512)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "carrier-policy-separate-from-lowering") 1) 1024)
        (add
            (ddrlb-score (eq (ddrlb-manifest-has "degenerate-range-realized") 1) 2048)
        (add
            (ddrlb-score (ddrl-ok? (ddrlb-decl)) 4096)
        (add
            (ddrlb-score
                (and (str_eq (ddrl-name (ddrlb-decl)) "evens")
                     (and (eq (ddrl-start (ddrlb-decl)) 0)
                          (and (eq (ddrl-count (ddrlb-decl)) 6)
                               (and (eq (ddrl-step (ddrlb-decl)) 2)
                                    (eq (ddrl-cost (ddrlb-decl)) 4)))))
                8192)
        (add
            (ddrlb-score
                (and (eq (ddrl-value-count (ddrlb-decl)) 6)
                     (and (eq (ddrl-value-head (ddrlb-decl)) 0)
                          (eq (nth (ddrl-values (ddrlb-decl)) 5) 10)))
                16384)
        (add
            (ddrlb-score (eq (ddrl-carrier (ddrlb-decl)) (dd-micro-recipe)) 32768)
        (add
            (ddrlb-score
                (and (str_eq (ddrl-lowering-kind (ddrlb-lower)) "module-constant")
                     (and (eq (ddrl-lowering-carrier (ddrlb-lower)) (dd-micro-recipe))
                          (and (str_eq (ddrl-lowering-realization (ddrlb-lower)) "realized-at-lowering")
                               (str_eq (ddrl-lowering-runtime-kind (ddrlb-lower)) "not-load-time-recipe"))))
                65536)
        (add
            (ddrlb-score
                (str_eq (ddrl-lowering-source (ddrlb-lower)) "(let evens (list 0 2 4 6 8 10))")
                131072)
        (add
            (ddrlb-score (ddrl-ok? (ddrl-parse (ddrlb-loose-source))) 262144)
        (add
            (ddrlb-score
                (and (not (ddrl-ok? (ddrlb-trailing)))
                     (not (ddrl-ok? (ddrlb-malformed))))
                524288)
        (add
            (ddrlb-score
                (and (eq (ddrl-carrier (ddrlb-equal-decl)) (dd-inline))
                     (not (eq (ddrl-carrier (ddrlb-equal-decl)) (dd-micro-recipe))))
                1048576)
        (add
            (ddrlb-score (eq (ddrl-carrier (ddrlb-large-fkb-decl)) (dd-fkb)) 2097152)
        (add
            (ddrlb-score (eq (ddrl-carrier (ddrlb-large-hybrid-decl)) (dd-hybrid)) 4194304)
        (add
            (ddrlb-score
                (and (eq (ddrl-value-count (ddrlb-empty-decl)) 0)
                     (str_eq (ddrl-lowering-source (ddrl-lowering (ddrlb-empty-decl))) "(let empty (list))"))
                8388608)
        (add
            (ddrlb-score
                (and (eq (ddrl-value-count (ddrlb-flat-decl)) 3)
                     (and (eq (ddrl-value-head (ddrlb-flat-decl)) 5)
                          (and (eq (nth (ddrl-values (ddrlb-flat-decl)) 2) 5)
                               (str_eq (ddrl-lowering-source (ddrl-lowering (ddrlb-flat-decl))) "(let flat (list 5 5 5))"))))
                16777216)
        (add
            (ddrlb-score
                (and (not (ddl-ok? (ddl-parse (ddrlb-source))))
                     (not (ddrl-ok? (ddrl-parse (ddrlb-bracket-source)))))
                33554432)
            (ddrlb-score
                (and (eq (ddrl-const-size (ddrlb-decl)) 6)
                     (eq (ddrl-recipe-size (ddrlb-decl)) 4))
                67108864))))))))))))))))))))))))))))

    (defdata-recipe-language-band))
