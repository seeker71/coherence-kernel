; rag-embed-band.fk — lexical floor plus sparse exact semantic feature map.
;
; preludes: form-stdlib/core.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
;
; verdict 8191:
;   1   lexical vectors are deterministic
;   2   distinct lexical text remains distinguishable
;   4   hand-pinned lexical histogram stays stable
;   8   grounded semantic kind is v2 and one feature emits exactly two codes
;   16  deployment synonyms become the exact same concept pair
;   32  evidence synonyms become the exact same concept pair
;   64  stop words contribute no semantic codes
;   128 a known term emits only its canonical concept pair
;   256 an unknown inflection emits only its conservative stem pair
;   512 repeated/synonymous terms dedupe to one feature pair
;   1024 the two hashes occupy non-overlapping bounded domains
;   2048 unrelated unknown terms share no sparse code with the target concepts
;   4096 related roles/artifacts and opposites remain distinct concept pairs

(do
    (defn rb-list-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (eq (head a) (head b)) (rb-list-eq (tail a) (tail b)) 0))
            0))
    (defn rb-code-in? (code codes)
        (if (eq (len codes) 0) 0
            (if (eq code (head codes)) 1 (rb-code-in? code (tail codes)))))
    (defn rb-shared-count (a b)
        (if (eq (len a) 0) 0
            (add (rb-code-in? (head a) b) (rb-shared-count (tail a) b))))

    (let det (if (eq (rb-list-eq (re-vec "hello world") (re-vec "hello world")) 1) 1 0))
    (let sens (if (eq (rb-list-eq (re-vec "cat") (re-vec "dog")) 0) 2 0))
    (let exact (if (eq (rb-list-eq (re-vec-dim "a b c" 4) (list 0 1 1 1)) 1) 4 0))
    (let anything (re-semantic-vec "anything"))
    (let sparse-kind (if (and (str_eq (re-semantic-kind) "form-semantic-v2")
                              (eq (len anything) 2)) 8 0))
    (let deploy-a (re-semantic-vec "deploy"))
    (let deploy-b (re-semantic-vec "deployment"))
    (let evidence-a (re-semantic-vec "proof"))
    (let evidence-b (re-semantic-vec "evidence"))
    (let deploy-exact (if (eq (rb-list-eq deploy-a deploy-b) 1) 16 0))
    (let evidence-exact (if (eq (rb-list-eq evidence-a evidence-b) 1) 32 0))
    (let stop-silent (if (eq (len (re-semantic-vec "the and is")) 0) 64 0))
    (let known-only (if (eq (rb-list-eq deploy-a
            (re-feature-codes "__concept_deploy")) 1) 128 0))
    (let unknown-stem (if (eq (rb-list-eq (re-semantic-vec "gardening")
            (re-feature-codes "garden")) 1) 256 0))
    (let deduped (if (eq (rb-list-eq (re-semantic-vec "deploy deployed deployment")
            deploy-a) 1) 512 0))
    (let first-code (nth anything 0))
    (let second-code (nth anything 1))
    (let dual-domains (if (and
            (and (ge first-code 0) (lt first-code (re-second-domain-offset)))
            (and (ge second-code (re-second-domain-offset)) (lt second-code 2000036))) 1024 0))
    (let unrelated (re-semantic-vec "quantum banana xylophone aardvark"))
    (let target (re-semantic-vec "deployment evidence kernel"))
    (let disjoint (if (eq (rb-shared-count unrelated target) 0) 2048 0))
    (let precise (if (and
            (and (eq (rb-list-eq (re-semantic-vec "kernel") (re-semantic-vec "runtime")) 0)
                 (eq (rb-list-eq (re-semantic-vec "kernel") (re-semantic-vec "submodule")) 0))
            (and
                (and (eq (rb-list-eq (re-semantic-vec "fear") (re-semantic-vec "love")) 0)
                     (eq (rb-list-eq (re-semantic-vec "merge") (re-semantic-vec "duplicate")) 0))
                (and
                    (and (eq (rb-list-eq (re-semantic-vec "native") (re-semantic-vec "local")) 0)
                         (eq (rb-list-eq (re-semantic-vec "local") (re-semantic-vec "offline")) 0))
                    (and (eq (rb-list-eq (re-semantic-vec "source") (re-semantic-vec "path")) 0)
                         (eq (rb-list-eq (re-semantic-vec "path") (re-semantic-vec "file")) 0))))) 4096 0))

    (add det (add sens (add exact (add sparse-kind
        (add deploy-exact (add evidence-exact (add stop-silent
        (add known-only (add unknown-stem (add deduped
        (add dual-domains (add disjoint precise)))))))))))))
