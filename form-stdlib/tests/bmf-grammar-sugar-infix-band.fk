; bmf-grammar-sugar-infix-band.fk -- precedence-climbing expression sugar.
;
; Expected: 15

(do
  (defn s (ok bit) (if ok bit 0))
  (defn kid (n i) (nth (node_children n) i))
  (defn cat? (n name) (node_eq (node_category n) (bp name)))
  (let g (grammar "e" (list
    (rule3 "e" (p-cap "v" (p-infix (p-ref "n") (list (list "+" "add" 1) (list "*" "mul" 2)))) (t-splice "v"))
    (rule3 "n" (p-cap "v" (p-num)) (t-splice-int "v")))))
  (let n (g-parse-full g "1 + 2 * 3"))
  (let m (kid n 1))
  (sum (list
    (s (cat? n "add") 1)
    (s (cat? m "mul") 2)
    (s (eq (node_value (kid m 0)) 2) 4)
    (s (eq (node_value (kid m 1)) 3) 8))))
