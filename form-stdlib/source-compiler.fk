; source-compiler.fk - Form-native source section compiler
;
; This module is runtime tissue above the kernel. It reads source text,
; lowers first-class BMF sections into ordinary Form object definitions,
; and writes compiled Form source through native file I/O.

;; --- text scanning ------------------------------------------------

    (defn fsc-sub (s a b) (substring s a b))

    (defn fsc-find-string-at-len? (s needle s-len needle-len i j)
        (if (eq j needle-len) true
            (if (ge (add i j) s-len) false
                (if (str_eq (char_at s (add i j)) (char_at needle j))
                    (fsc-find-string-at-len? s needle s-len needle-len i (add j 1))
                    false))))

    (defn fsc-find-string-at? (s needle i j)
        (fsc-find-string-at-len? s needle (str_len s) (str_len needle) i j))

    ;; --- streaming scanners — dispatched to kernel-native `str_find` ---
    ;;
    ;; The earlier recursive scanners (fsc-find-string-from-len,
    ;; fsc-find-char-from-len) blew Go's stack when section bodies grew past
    ;; ~165 BMF rules. The first attempt (string_fold-based) eliminated the
    ;; recursion but moved the cost into per-byte Form-closure dispatch,
    ;; which is too slow when called 800+ times per source-compile run.
    ;;
    ;; The cure: a `str_find` kernel native that does the whole search in
    ;; Go/Rust/JS (one for-loop per call, no Form callback, no recursion).
    ;; This is what `tokenizeSexp` already does internally; we expose it so
    ;; Form code doesn't pay the closure-dispatch tax. The universal-
    ;; translator stream property holds: arbitrary-length input, zero Form
    ;; recursion, constant per-call cost.

    (defn fsc-find-string-from (s needle i)
        (str_find s needle i))

    (defn fsc-find-string-from-len (s needle _s-len _needle-len i)
        (str_find s needle i))

    (defn fsc-contains? (s needle)
        (ge (str_find s needle 0) 0))

    (defn fsc-find-char-from (s ch i)
        (str_find s ch i))

    (defn fsc-find-char-from-len (s ch _s-len i)
        (str_find s ch i))

    (defn fsc-space? (ch)
        (or (str_eq ch " ") (or (str_eq ch "\n") (or (str_eq ch "\t") (str_eq ch "\r")))))

    (defn fsc-skip-spaces (s i)
        (if (ge i (str_len s)) i
            (if (fsc-space? (char_at s i))
                (fsc-skip-spaces s (add i 1))
                i)))

    (defn fsc-rtrim-index (s i)
        (if (le i 0) 0
            (if (fsc-space? (char_at s (sub i 1)))
                (fsc-rtrim-index s (sub i 1))
                i)))

    (defn fsc-trim (s)
        (do
            (let start (fsc-skip-spaces s 0))
            (let end (fsc-rtrim-index s (str_len s)))
            (if (ge start end) "" (fsc-sub s start end))))

    (defn fsc-line-end (s i)
        (do
            (let e (fsc-find-char-from s "\n" i))
            (if (lt e 0) (str_len s) e)))

    (defn fsc-line-next (s i)
        (do
            (let e (fsc-line-end s i))
            (if (lt e (str_len s)) (add e 1) e)))

    (defn fsc-line-opens-block? (line)
        (if (eq (str_len line) 0) false
            (str_eq (char_at line (fsc-last-char-index line)) "{")))

    (defn fsc-section-end-depth (s i depth)
        (do
            (let e (fsc-line-end s i))
            (let line (fsc-trim (fsc-sub s i e)))
            (if (str_eq line "}")
                (if (eq depth 0) i
                    (fsc-section-end-depth s (fsc-line-next s i) (sub depth 1)))
                (if (fsc-line-opens-block? line)
                    (fsc-section-end-depth s (fsc-line-next s i) (add depth 1))
                    (fsc-section-end-depth s (fsc-line-next s i) depth)))))

    (defn fsc-section-end (s i)
        (fsc-section-end-depth s i 0))

    ;; --- output strings ----------------------------------------------

    (defn fsc-quote-loop (s i)
        (if (ge i (str_len s)) ""
            (do
                (let ch (char_at s i))
                (let rest (fsc-quote-loop s (add i 1)))
                (if (str_eq ch "\\") (str_concat "\\\\" rest)
                (if (str_eq ch "\"") (str_concat "\\\"" rest)
                    (str_concat ch rest))))))

    (defn fsc-q (s)
        (str_concat "\"" (str_concat (fsc-quote-loop s 0) "\"")))

    (defn fsc-word-char? (ch)
        (do
            (let cp (ord ch))
            (or (and (ge cp 65) (le cp 90))
            (or (and (ge cp 97) (le cp 122))
            (or (and (ge cp 48) (le cp 57))
            (or (str_eq ch "_") (str_eq ch "-")))))))

    (defn fsc-word-start-char? (ch)
        (do
            (let cp (ord ch))
            (or (and (ge cp 65) (le cp 90))
            (or (and (ge cp 97) (le cp 122))
            (or (and (ge cp 48) (le cp 57))
                (str_eq ch "_"))))))

    (defn fsc-word-loop? (s i)
        (if (ge i (str_len s)) true
            (if (fsc-word-char? (char_at s i))
                (fsc-word-loop? s (add i 1))
                false)))

    (defn fsc-word? (s)
        (if (gt (str_len s) 0)
            (and (fsc-word-start-char? (char_at s 0))
                 (fsc-word-loop? s 1))
            false))

    (defn fsc-dialect-fn (dialect suffix)
        (str_concat dialect (str_concat "-" suffix)))

    (defn fsc-lit-fn (dialect value)
        (if (str_eq dialect "bmf")
            (if (fsc-word? value) "bmf-kw" "bmf-op")
            (if (fsc-word? value)
                (fsc-dialect-fn dialect "kw")
                (fsc-dialect-fn dialect "op"))))

    (defn fsc-literal-expr (dialect value)
        (str_concat "("
            (str_concat (fsc-lit-fn dialect value)
            (str_concat " " (str_concat (fsc-q value) ")")))))

    (defn fsc-capture-fn (dialect kind)
        (if (str_eq dialect "bmf")
            (if (str_eq kind "string") "bmf-string-lit"
            (if (str_eq kind "pattern") "bmf-pattern-lit"
            (if (str_eq kind "rules") "bmf-rules-lit" "bmf-name")))
            (if (str_eq kind "int") (fsc-dialect-fn dialect "int-lit")
            (if (str_eq kind "float") (fsc-dialect-fn dialect "float-lit")
            (if (str_eq kind "string") (fsc-dialect-fn dialect "string-lit")
            (if (str_eq kind "char") (fsc-dialect-fn dialect "char-lit")
            (if (str_eq kind "bytes") (fsc-dialect-fn dialect "bytes-lit")
            (if (str_eq kind "fstring") (fsc-dialect-fn dialect "fstring-lit")
            (if (str_eq kind "property") (fsc-dialect-fn dialect "prop")
                (fsc-dialect-fn dialect "name"))))))))))

    (defn fsc-capture-expr (dialect spec)
        (do
            (let colon (fsc-find-char-from spec ":" 0))
            (let name (fsc-sub spec 1 colon))
            (let kind (fsc-sub spec (add colon 1) (str_len spec)))
            (str_concat "("
                (str_concat (fsc-capture-fn dialect kind)
                (str_concat " " (str_concat (fsc-q name) ")"))))))

    (defn fsc-rule-ref-expr (dialect name)
        (str_concat "("
            (str_concat dialect
            (str_concat "-ref " (str_concat (fsc-q name) ")")))))

    (defn fsc-read-quoted-end (s i)
        (if (ge i (str_len s)) i
            (if (and (str_eq (char_at s i) "\\") (lt (add i 1) (str_len s)))
                (fsc-read-quoted-end s (add i 2))
            (if (str_eq (char_at s i) "\"") i
                (fsc-read-quoted-end s (add i 1))))))

    (defn fsc-read-part-end (s i)
        (if (ge i (str_len s)) i
            (if (fsc-space? (char_at s i)) i
                (fsc-read-part-end s (add i 1)))))

    ;; fsc-skip-rule-line? — used by the Recipe-build path's rules loop.
    (defn fsc-skip-rule-line? (line)
        (if (str_eq line "") true
            (str_eq (char_at line 0) ";")))

    ;; --- Composted ---------------------------------------------------
    ;; The text-build path (fsc-pattern-items-loop, fsc-rule-line,
    ;; fsc-rules-loop, fsc-compile-bmf-section) emitted .fk source text
    ;; while compiling each rule. Each rule cost ~13 nested str_concats; whole
    ;; sections piled hundreds. The Recipe-build path below is the live
    ;; replacement — it constructs Recipe objects via intern_node first. Callers
    ;; can carry those objects directly (recipe_to_bytes/bytes_to_recipe) or ask
    ;; the source emitter for executable Form text when a text artifact is the
    ;; desired lens.
    ;;
    ;; fsc-literal-expr / fsc-capture-expr / fsc-rule-ref-expr were the
    ;; text formatters for the old path; their Recipe equivalents live in
    ;; fsc-pattern-item-recipe + fsc-rec-* helpers (further down). fsc-q
    ;; (defined above near fsc-quote-loop) still serves the high-level Form
    ;; source dialects: form.bml, form.action, and form.route.
    ;; until that path also gets the Recipe treatment.

    ;; --- high-level Form source dialect maintenance ------------------
    ;; These dialects are deliberately above the kernel. They give stdlib,
    ;; compiler, and rule-action code a smaller BML-shaped authoring surface,
    ;; then lower to ordinary Form source before sibling kernels execute
    ;; anything.

    (defn fsc-last-char-index (s)
        (sub (str_len s) 1))

    (defn fsc-strip-semi (s)
        (do
            (let value (fsc-trim s))
            (if (eq (str_len value) 0) value
                (if (str_eq (char_at value (fsc-last-char-index value)) ";")
                    (fsc-trim (fsc-sub value 0 (fsc-last-char-index value)))
                    value))))

    (defn fsc-prefix? (s prefix)
        (fsc-find-string-at? s prefix 0 0))

    (defn fsc-compiler-error (message)
        (form_error (str_concat "source-compile: " message)))

    (defn fsc-compiler-error-line (message line)
        (fsc-compiler-error (str_concat message (str_concat ": " line))))

    (defn fsc-digit? (ch)
        (do
            (let cp (ord ch))
            (and (ge cp 48) (le cp 57))))

    (defn fsc-int-loop? (s i)
        (if (ge i (str_len s)) true
            (if (fsc-digit? (char_at s i))
                (fsc-int-loop? s (add i 1))
                false)))

    (defn fsc-int? (s)
        (do
            (let value (fsc-trim s))
            (if (eq (str_len value) 0) false
            (if (str_eq (char_at value 0) "-")
                (and (gt (str_len value) 1) (fsc-int-loop? value 1))
                (fsc-int-loop? value 0)))))

    ;; fsc-float? — a decimal float literal: optional leading "-", digits, one
    ;; ".", digits (e.g. "0.5", "-1.25"). Digits on both sides of the dot, exactly
    ;; one dot. The high-level Form expr compiler interns these as trivial float nodes
    ;; (intern_trivial_float); the artifact byte carrier preserves the f64 value
    ;; when a compiled Recipe object crosses into another kernel.
    (defn fsc-float-dot-loop? (s i seen-dot)
        (if (ge i (str_len s)) seen-dot
            (do
                (let ch (char_at s i))
                (if (str_eq ch ".")
                    (if seen-dot false (fsc-float-dot-loop? s (add i 1) true))
                    (if (fsc-digit? ch)
                        (fsc-float-dot-loop? s (add i 1) seen-dot)
                        false)))))

    (defn fsc-float-body? (body)
        ;; need at least one digit before AND after the dot: shortest is "d.d"
        ;; (len 3), first and last chars are digits, exactly one dot inside.
        (if (lt (str_len body) 3) false
        (if (fsc-digit? (char_at body 0))
        (if (fsc-digit? (char_at body (sub (str_len body) 1)))
            (fsc-float-dot-loop? body 0 false)
            false) false)))

    (defn fsc-float? (s)
        (do
            (let value (fsc-trim s))
            (if (eq (str_len value) 0) false
            (if (str_eq (char_at value 0) "-")
                (fsc-float-body? (fsc-sub value 1 (str_len value)))
                (fsc-float-body? value)))))

    (defn fsc-bml-find-comma-loop (s i depth quoted)
        (if (ge i (str_len s)) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (fsc-bml-find-comma-loop s (add i 2) depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-comma-loop s (add i 1) depth false)
                            (fsc-bml-find-comma-loop s (add i 1) depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-comma-loop s (add i 1) depth true)
                        (if (or (str_eq ch "(") (str_eq ch "{"))
                            (fsc-bml-find-comma-loop s (add i 1) (add depth 1) quoted)
                            (if (or (str_eq ch ")") (str_eq ch "}"))
                                (fsc-bml-find-comma-loop s (add i 1) (sub depth 1) quoted)
                                (if (and (eq depth 0) (str_eq ch ","))
                                    i
                                    (fsc-bml-find-comma-loop s (add i 1) depth quoted)))))))))

    (defn fsc-bml-find-comma (s i)
        (fsc-bml-find-comma-loop s i 0 false))

    (defn fsc-bml-block-end (body i depth)
        (do
            (let e (fsc-line-end body i))
            (let line (fsc-trim (fsc-sub body i e)))
            (if (str_eq line "}")
                (if (eq depth 0) i
                    (fsc-bml-block-end body (fsc-line-next body i) (sub depth 1)))
                (if (fsc-line-opens-block? line)
                    (fsc-bml-block-end body (fsc-line-next body i) (add depth 1))
                    (fsc-bml-block-end body (fsc-line-next body i) depth)))))

    (defn fsc-bml-comment-line? (line)
        (if (fsc-skip-rule-line? line) true
            (fsc-prefix? line "//")))

    (defn fsc-bml-normalize-ws-loop (s i quoted saw-space)
        (if (ge i (str_len s)) ""
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (str_concat ch
                            (str_concat
                                (char_at s (add i 1))
                                (fsc-bml-normalize-ws-loop s (add i 2) quoted false)))
                        (str_concat ch
                            (fsc-bml-normalize-ws-loop s (add i 1) (if (str_eq ch "\"") false true) false)))
                    (if (str_eq ch "\"")
                        (str_concat ch
                            (fsc-bml-normalize-ws-loop s (add i 1) true false))
                        (if (fsc-space? ch)
                            (if saw-space
                                (fsc-bml-normalize-ws-loop s (add i 1) quoted saw-space)
                                (str_concat " " (fsc-bml-normalize-ws-loop s (add i 1) quoted true)))
                            (str_concat ch
                                (fsc-bml-normalize-ws-loop s (add i 1) quoted false))))))))

    (defn fsc-bml-normalize-ws (s)
        (fsc-trim (fsc-bml-normalize-ws-loop s 0 false false)))

    (defn fsc-bml-stmt-end-loop (body i end depth quoted)
        (if (ge i end) end
            (do
                (let ch (char_at body i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) end))
                        (fsc-bml-stmt-end-loop body (add i 2) end depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-stmt-end-loop body (add i 1) end depth false)
                            (fsc-bml-stmt-end-loop body (add i 1) end depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-stmt-end-loop body (add i 1) end depth true)
                        (if (str_eq ch "(")
                            (fsc-bml-stmt-end-loop body (add i 1) end (add depth 1) quoted)
                            (if (str_eq ch ")")
                                (fsc-bml-stmt-end-loop body (add i 1) end (sub depth 1) quoted)
                                (if (and (eq depth 0) (str_eq ch ";"))
                                    (add i 1)
                                    (fsc-bml-stmt-end-loop body (add i 1) end depth quoted)))))))))

    (defn fsc-bml-stmt-end (body i end)
        (fsc-bml-stmt-end-loop body i end 0 false))

    (defn fsc-high-level-form-dialect? (dialect-name)
        (or (str_eq dialect-name "form.bml")
            (or (str_eq dialect-name "form.action")
                (str_eq dialect-name "form.route"))))

    ;; Local list-reverse — bounded by rule count (~200), not body length.
    ;; engine.fk's `reverse-list` isn't in scope during source-compile pre-pass.

    (defn fsc-empty? (xs) (eq (len xs) 0))

    (defn fsc-rev-into (xs acc)
        (if (fsc-empty? xs) acc
            (fsc-rev-into (tail xs) (cons (head xs) acc))))

    (defn fsc-rev (xs) (fsc-rev-into xs (empty)))

    ;; --- Recipe construction primitives ------------------------------
    ;;
    ;; Each helper builds a Recipe NodeID directly via intern_node (no
    ;; str_concat building source text the kernel re-parses). The shapes
    ;; mirror what the kernel's parser produces internally:
    ;;
    ;;   DO       : intern(catBlock(RBlockDo),    [child1, child2, ...])
    ;;   LET      : intern(catBlock(RBlockLet),   [string-trivial-name, value-recipe])
    ;;   IDENT    : intern(catIdent(),            [string-trivial-name])
    ;;   FNCALL   : intern(catFnCall(),           [ident-callee, arg1, arg2, ...])
    ;;
    ;; Built Recipe is emitted back to executable Form source by the source
    ;; emitter below, so source sections can cross kernel boundaries without a
    ;; binary sidecar. Persistence paths can still serialize Recipe nodes
    ;; deliberately when a cache or artifact is the desired carrier.
    ;; Source: form/form-kernel-go/main.go parseSexp around line 1942 (DO/LET) +
    ;; 2005 (FNCALL) + 1900 (IDENT).

    ;; --- Form ontology helpers — data lives in the kernel-native bp table --
    ;;
    ;; FORM-CATEGORY-TABLE and FORM-PRIMITIVE-TABLE are bound by
    ;; form-stdlib/form-ontology-loader.fk (loaded as a prelude before
    ;; this file). The loader asks the kernel-native bp table for the
    ;; coordinates and walks them into the row shape these helpers
    ;; consume. The authored ontology sources feed the generated bp table;
    ;; source compilation itself does not parse JSON.
    ;;
    ;; List-walk lookup — pure head/tail, no nth/nil? (we run before
    ;; core.fk). Returns the matched row or empty list.
    (defn form-table-lookup (table name)
        (if (fsc-empty? table) (empty)
            (if (str_eq (head (head table)) name)
                (head table)
                (form-table-lookup (tail table) name))))

    (defn form-row-type (row) (head (tail row)))
    (defn form-row-inst (row) (head (tail (tail row))))

    (defn form-cat-node (name)
        (do
            (let row (form-table-lookup FORM-CATEGORY-TABLE name))
            (make_nodeid 1 2 (form-row-type row) (form-row-inst row))))

    (defn form-prim-or-empty (name)
        (form-table-lookup FORM-PRIMITIVE-TABLE name))

    (defn form-prim-node (row)
        (make_nodeid 1 2 (form-row-type row) (form-row-inst row)))

    ;; Bind the common categories so emit sites read like names, not
    ;; table walks. The table is still the source — these are just the
    ;; rows resolved once at load time.
    (let fsc-rec-DO-CAT     (form-cat-node "do"))
    (let fsc-rec-LET-CAT    (form-cat-node "let"))
    (let fsc-rec-FNCALL-CAT (form-cat-node "fncall"))
    (let fsc-rec-IDENT-CAT  (form-cat-node "ident"))

    (defn fsc-rec-ident (name)
        (intern_node fsc-rec-IDENT-CAT (list (intern_trivial_string name))))

    (defn fsc-rec-let (name value-recipe)
        (intern_node fsc-rec-LET-CAT (list (intern_trivial_string name) value-recipe)))

    (defn fsc-rec-do (children-list)
        (intern_node fsc-rec-DO-CAT children-list))

    (defn fsc-rec-call (fn-name arg-recipes)
        (intern_node fsc-rec-FNCALL-CAT (cons (fsc-rec-ident fn-name) arg-recipes)))

    (defn fsc-rec-list-of (item-recipes)
        (fsc-rec-call "list" item-recipes))

    (defn fsc-rec-string (s)
        (intern_trivial_string s))

    (defn fsc-rec-string-list-items (xs)
        (if (fsc-empty? xs) (empty)
            (cons (fsc-rec-string (head xs))
                  (fsc-rec-string-list-items (tail xs)))))

    (defn fsc-rec-string-list (xs)
        (fsc-rec-list-of (fsc-rec-string-list-items xs)))

    ;; --- BMF section as Recipe ---------------------------------------
    ;;
    ;; Old (text path): fsc-rules-loop walks the body line by line,
    ;; building a giant str_concat'd .fk source string the kernel re-parses.
    ;; New (Recipe path): walk the body line by line, but each line becomes
    ;; a Recipe node directly. The list of rule recipes becomes the value
    ;; of the X-bmf-rules let.

    (defn fsc-pattern-item-recipe (dialect pattern i)
        (do
            (let p (fsc-skip-spaces pattern i))
            (if (ge p (str_len pattern)) (fsc-rec-call "empty" (list (intern_trivial_int 0)))
                (if (str_eq (char_at pattern p) "\"")
                    (do
                        (let e (fsc-read-quoted-end pattern (add p 1)))
                        (let value (fsc-sub pattern (add p 1) e))
                        (list (fsc-rec-call (fsc-lit-fn dialect value)
                                            (list (fsc-rec-string value)))
                              (add e 1)))
                    (do
                        (let e (fsc-read-part-end pattern p))
                        (let part (fsc-sub pattern p e))
                        (if (str_eq (char_at part 0) "$")
                            (do
                                (let colon (fsc-find-char-from part ":" 0))
                                (let name (fsc-sub part 1 colon))
                                (let kind (fsc-sub part (add colon 1) (str_len part)))
                                (list (fsc-rec-call (fsc-capture-fn dialect kind)
                                                    (list (fsc-rec-string name)))
                                      e))
                            (list (fsc-rec-call (fsc-dialect-fn dialect "ref")
                                                (list (fsc-rec-string part)))
                                  e)))))))

    (defn fsc-pattern-items-recipes (dialect pattern i acc)
        (do
            (let p (fsc-skip-spaces pattern i))
            (if (ge p (str_len pattern)) (fsc-rev acc)
                (do
                    (let result (fsc-pattern-item-recipe dialect pattern p))
                    (fsc-pattern-items-recipes dialect pattern
                                               (head (tail result))
                                               (cons (head result) acc))))))

    (defn fsc-rule-line-recipe (dialect line)
        (do
            (let sep (fsc-find-string-from line "::=" 0))
            (let arr (fsc-find-string-from line " => " sep))
            (let semi (fsc-find-char-from line ";" arr))
            (let rev (fsc-find-string-from line " <= " arr))
            (let name (fsc-trim (fsc-sub line 0 sep)))
            (let pattern (fsc-trim (fsc-sub line (add sep 3) arr)))
            (let action-end (if (and (ge rev 0) (lt rev semi)) rev semi))
            (let action (fsc-trim (fsc-sub line (add arr 4) action-end)))
            (let reverse (if (and (ge rev 0) (lt rev semi))
                             (fsc-trim (fsc-sub line (add rev 4) semi))
                             "bmf-default-reverse-emitter"))
            (let pattern-recipes (fsc-pattern-items-recipes dialect pattern 0 (empty)))
            (let sequence-recipe (fsc-rec-call "list"
                                               (cons (fsc-rec-string "sequence")
                                                     pattern-recipes)))
            (fsc-rec-list-of (list
                (fsc-rec-string name)
                sequence-recipe
                (fsc-rec-ident action)
                (fsc-rec-ident "bmf-identity-inverse")
                (fsc-rec-ident reverse)))))

    (defn fsc-rules-recipes-loop (dialect body i acc)
        (if (ge i (str_len body)) (fsc-rev acc)
            (do
                (let e (fsc-line-end body i))
                (let line (fsc-trim (fsc-sub body i e)))
                (let next-i (fsc-line-next body i))
                (if (fsc-skip-rule-line? line)
                    (fsc-rules-recipes-loop dialect body next-i acc)
                    (fsc-rules-recipes-loop dialect body next-i
                                            (cons (fsc-rule-line-recipe dialect line)
                                                  acc))))))

    (defn fsc-bmf-section-recipe (dialect-name body)
        (do
            (let dot (fsc-find-char-from dialect-name "." 0))
            (let dialect (fsc-sub dialect-name 0 dot))
            (let rules-name (str_concat dialect "-bmf-rules"))
            (let second-name (str_concat dialect "-bmf-second"))
            (let rule-recipes (fsc-rules-recipes-loop dialect body 0 (empty)))
            (let rules-list-recipe (fsc-rec-call "list" rule-recipes))
            (let second-value-recipe (fsc-rec-call "form-bmf-second" (list
                (fsc-rec-string dialect)
                (fsc-rec-call "bmf-section" (list
                    (fsc-rec-string dialect-name)
                    (fsc-rec-ident rules-name))))))
            (fsc-rec-do (list
                (fsc-rec-let rules-name rules-list-recipe)
                (fsc-rec-let second-name second-value-recipe)))))

    ;; --- high-level Form source section as Recipe -------------------
    ;;
    ;; Old (string path): line by line emit Form source text while compiling.
    ;; Recipe path: each line becomes a Recipe node directly. The section is a
    ;; DO Recipe over LET / FNDEF / FNCALL children, then a single emitter turns
    ;; the Recipe back into executable Form source for the next kernel.
    ;;
    ;; Categories (source: form-kernel-go/main.go parseSexp + walker):
    ;;   FNDEF (1 2 31 1): kids [trivial-string-name, SEQUENCE-of-trivial-
    ;;     strings (params), body-recipe]; walker ~1645 reads NameID
    ;;     straight from p.Inst on each param trivial — params must be
    ;;     trivial-strings, not IDENT-wrapped.
    ;;   IF3   (1 2 11 2): kids [cond, yes, no]
    ;;   SEQ   (1 2 9 2): block sequence (used for param-list)
    ;;   TrivBool (Level 1, Type 3): Inst 1=true, 0=false — bool literals
    ;;     bypass the env at parse time per main.go:1908.

    (let fsc-rec-FNDEF-CAT (form-cat-node "fndef"))
    (let fsc-rec-IF3-CAT   (form-cat-node "if"))
    (let fsc-rec-MATCH-CAT (form-cat-node "match"))
    (let fsc-rec-SEQ-CAT   (form-cat-node "sequence"))

    (defn fsc-rec-true ()  (make_nodeid 1 1 3 1))
    (defn fsc-rec-false () (make_nodeid 1 1 3 0))

    (defn fsc-rec-if3 (cond yes no)
        (intern_node fsc-rec-IF3-CAT (list cond yes no)))

    (defn fsc-rec-match-switch (children)
        (intern_node fsc-rec-MATCH-CAT children))

    ;; Param list: SEQUENCE of trivial-strings (NOT IDENT-wrapped).
    (defn fsc-rec-param-trivials (names)
        (if (fsc-empty? names) (empty)
            (cons (intern_trivial_string (head names))
                  (fsc-rec-param-trivials (tail names)))))

    (defn fsc-rec-fndef (name param-names body-recipe)
        (intern_node fsc-rec-FNDEF-CAT (list
            (intern_trivial_string name)
            (intern_node fsc-rec-SEQ-CAT (fsc-rec-param-trivials param-names))
            body-recipe)))

    ;; Append xs (in order) onto acc (reversed accumulator) → reversed.
    (defn fsc-rec-append-rev (xs acc)
        (if (fsc-empty? xs) acc
            (fsc-rec-append-rev (tail xs) (cons (head xs) acc))))

    (defn fsc-list-append (xs ys)
        (if (fsc-empty? xs) ys
            (cons (head xs) (fsc-list-append (tail xs) ys))))

    ;; --- BML route-domain lowering ------------------------------------
    ;;
    ;; `form.route` is a BML-shaped domain surface. Shared source cells live in
    ;; bml-source.fk; this compiler consumes them and lowers route-domain
    ;; objects into shared language-model cells instead of generic UE-* nodes.

    ;; Comma-separated names → list of trimmed name strings.
    (defn fsc-bml-name-list-strings-loop (args i acc)
        (do
            (let p (fsc-skip-spaces args i))
            (if (ge p (str_len args)) (fsc-rev acc)
                (do
                    (let comma (fsc-find-char-from args "," p))
                    (let end (if (lt comma 0) (str_len args) comma))
                    (let name (fsc-trim (fsc-sub args p end)))
                    (let rest-start (if (lt comma 0) (str_len args) (add comma 1)))
                    (fsc-bml-name-list-strings-loop args rest-start (cons name acc))))))

    ;; Comma-separated arg exprs → list of arg Recipes (in order).
    (defn fsc-bml-args-recipes-loop (args i acc)
        (do
            (let p (fsc-skip-spaces args i))
            (if (ge p (str_len args)) (fsc-rev acc)
                (do
                    (let comma (fsc-bml-find-comma args p))
                    (let end (if (lt comma 0) (str_len args) comma))
                    (let part (fsc-trim (fsc-sub args p end)))
                    (let rest-start (if (lt comma 0) (str_len args) (add comma 1)))
                    (fsc-bml-args-recipes-loop args rest-start
                        (cons (fsc-compile-form-bml-expr-recipe part) acc))))))

    (defn fsc-bml-route-data-arg-recipes (args)
        (do
            (let p (fsc-skip-spaces args 0))
            (let comma (fsc-bml-find-comma args p))
            (let route-id-end (if (lt comma 0) (str_len args) comma))
            (let handler-start (if (lt comma 0) (str_len args) (add comma 1)))
            (let route-id (fsc-trim (fsc-sub args p route-id-end)))
            (let handler-text (fsc-trim (fsc-sub args handler-start (str_len args))))
            (cons (fsc-rec-string route-id)
                  (cons (fsc-compile-form-bml-expr-recipe handler-text) (empty)))))

    (defn fsc-bml-class-member-name (class-name member-name)
        (str_concat class-name (str_concat "_" member-name)))

    (defn fsc-bml-route-data-arg-recipes-for-class (args class-name)
        (do
            (let p (fsc-skip-spaces args 0))
            (let comma (fsc-bml-find-comma args p))
            (let route-id-end (if (lt comma 0) (str_len args) comma))
            (let handler-start (if (lt comma 0) (str_len args) (add comma 1)))
            (let route-id (fsc-trim (fsc-sub args p route-id-end)))
            (let handler-text (fsc-trim (fsc-sub args handler-start (str_len args))))
            (cons (fsc-rec-string route-id)
                  (cons
                    (fsc-compile-form-bml-expr-recipe
                        (fsc-bml-class-member-name class-name handler-text))
                    (empty)))))

    (defn fsc-bml-route-call-arg-recipes (route-call)
        (if (str_eq (bml-source-route-call-name route-call) "route_data")
            (fsc-bml-route-data-arg-recipes (bml-source-route-call-args route-call))
            (fsc-bml-args-recipes-loop (bml-source-route-call-args route-call) 0 (empty))))

    (defn fsc-bml-route-call-arg-recipes-for-class (route-call class-name)
        (if (str_eq (bml-source-route-call-name route-call) "route_data")
            (fsc-bml-route-data-arg-recipes-for-class
                (bml-source-route-call-args route-call)
                class-name)
            (fsc-bml-args-recipes-loop (bml-source-route-call-args route-call) 0 (empty))))

    (defn fsc-bml-route-call-language-class-fn (route-call)
        (if (str_eq (bml-source-route-call-name route-call) "route_data")
            "language-route-class-route-data"
            "language-route-class"))

    (defn fsc-bml-route-call-kernel-route-fn (route-call)
        (if (str_eq (bml-source-route-call-name route-call) "route_data")
            "kh-route-data-ref"
            "kh-route"))

    ;; String literal escape interpretation. Mirrors the kernel parser so
    ;; Recipe-path source sections carry the same string cells as parsed Form.
    (defn fsc-unescape-str-loop (s i acc)
        (if (ge i (str_len s)) acc
            (do
                (let ch (char_at s i))
                (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                    (do
                        (let nx (char_at s (add i 1)))
                        (let lit
                            (if (str_eq nx "n") "\n"
                            (if (str_eq nx "t") "\t"
                            (if (str_eq nx "r") "\r"
                            (if (str_eq nx "\\") "\\"
                            (if (str_eq nx "\"") "\""
                                nx))))))
                        (fsc-unescape-str-loop s (add i 2) (str_concat acc lit)))
                    (fsc-unescape-str-loop s (add i 1) (str_concat acc ch))))))

    (defn fsc-unescape-str (s) (fsc-unescape-str-loop s 0 ""))

    ;; Math/compare/logic primitives are parser SPECIAL FORMS in the
    ;; kernel — there's no env binding for `gt`, `add`, etc. Look the
    ;; name up in FORM-PRIMITIVE-TABLE; if present, lift to the typed
    ;; category; otherwise fall through to a real FNCALL.
    (defn fsc-rec-form-call (name args)
        (do
            (let prim-row (form-prim-or-empty name))
            (if (fsc-empty? prim-row)
                (fsc-rec-call name args)
                (intern_node (form-prim-node prim-row) args))))

    (defn fsc-compile-form-bml-call-recipe (expr open)
        (do
            (let close (fsc-last-char-index expr))
            (let name (fsc-trim (fsc-sub expr 0 open)))
            (let args (fsc-sub expr (add open 1) close))
            (let arg-recipes (if (eq (str_len (fsc-trim args)) 0) (empty)
                                 (fsc-bml-args-recipes-loop args 0 (empty))))
            (fsc-rec-form-call name arg-recipes)))

    ;; Match inline `if ... then ... else ...` at the top level. The scanner
    ;; respects strings, call parentheses, and nested top-level if branches.
    (defn fsc-bml-prev-token-boundary? (s i)
        (if (le i 0) true
            (do
                (let prev (char_at s (sub i 1)))
                (or (fsc-space? prev)
                    (or (str_eq prev "(") (str_eq prev ","))))))

    (defn fsc-bml-if-token-at? (s i)
        (and (fsc-bml-prev-token-boundary? s i)
             (fsc-find-string-at? s "if " i 0)))

    (defn fsc-bml-find-top-then-loop (s i depth quoted)
        (if (ge i (str_len s)) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (fsc-bml-find-top-then-loop s (add i 2) depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-top-then-loop s (add i 1) depth false)
                            (fsc-bml-find-top-then-loop s (add i 1) depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-top-then-loop s (add i 1) depth true)
                        (if (str_eq ch "(")
                            (fsc-bml-find-top-then-loop s (add i 1) (add depth 1) quoted)
                            (if (str_eq ch ")")
                                (fsc-bml-find-top-then-loop s (add i 1) (sub depth 1) quoted)
                                (if (and (eq depth 0) (fsc-find-string-at? s " then " i 0))
                                    i
                                    (fsc-bml-find-top-then-loop s (add i 1) depth quoted)))))))))

    (defn fsc-bml-find-top-then (s)
        (fsc-bml-find-top-then-loop s 0 0 false))

    (defn fsc-bml-find-matching-else-loop (s i depth quoted nested)
        (if (ge i (str_len s)) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (fsc-bml-find-matching-else-loop s (add i 2) depth quoted nested)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-matching-else-loop s (add i 1) depth false nested)
                            (fsc-bml-find-matching-else-loop s (add i 1) depth quoted nested)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-matching-else-loop s (add i 1) depth true nested)
                        (if (str_eq ch "(")
                            (fsc-bml-find-matching-else-loop s (add i 1) (add depth 1) quoted nested)
                            (if (str_eq ch ")")
                                (fsc-bml-find-matching-else-loop s (add i 1) (sub depth 1) quoted nested)
                                (if (and (eq depth 0) (fsc-bml-if-token-at? s i))
                                    (fsc-bml-find-matching-else-loop s (add i 3) depth quoted (add nested 1))
                                    (if (and (eq depth 0) (fsc-find-string-at? s " else " i 0))
                                        (if (eq nested 0)
                                            i
                                            (fsc-bml-find-matching-else-loop s (add i 6) depth quoted (sub nested 1)))
                                        (fsc-bml-find-matching-else-loop s (add i 1) depth quoted nested))))))))))

    (defn fsc-bml-find-matching-else (s then-pos)
        (fsc-bml-find-matching-else-loop s (add then-pos 6) 0 false 0))

    (defn fsc-compile-form-bml-if-recipe (expr)
        (do
            (let then-pos (fsc-bml-find-top-then expr))
            (if (lt then-pos 0)
                (fsc-compiler-error-line "form.bml if missing 'then'" expr)
            (do
            (let else-pos (fsc-bml-find-matching-else expr then-pos))
            (if (lt else-pos 0)
                (fsc-compiler-error-line "form.bml if missing matching 'else'" expr)
            (do
            (let cond-text (fsc-trim (fsc-sub expr 3 then-pos)))
            (let yes-text (fsc-trim (fsc-sub expr (add then-pos 6) else-pos)))
            (let no-text (fsc-trim (fsc-sub expr (add else-pos 6) (str_len expr))))
            (fsc-rec-if3 (fsc-compile-form-bml-expr-recipe cond-text)
                         (fsc-compile-form-bml-expr-recipe yes-text)
                         (fsc-compile-form-bml-expr-recipe no-text))))))))

    (defn fsc-bml-find-top-eqeq-loop (s i depth quoted)
        (if (ge i (str_len s)) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (fsc-bml-find-top-eqeq-loop s (add i 2) depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-top-eqeq-loop s (add i 1) depth false)
                            (fsc-bml-find-top-eqeq-loop s (add i 1) depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-top-eqeq-loop s (add i 1) depth true)
                        (if (or (str_eq ch "(") (str_eq ch "{"))
                            (fsc-bml-find-top-eqeq-loop s (add i 1) (add depth 1) quoted)
                            (if (or (str_eq ch ")") (str_eq ch "}"))
                                (fsc-bml-find-top-eqeq-loop s (add i 1) (sub depth 1) quoted)
                                (if (and (eq depth 0) (fsc-find-string-at? s " == " i 0))
                                    (add i 1)
                                    (fsc-bml-find-top-eqeq-loop s (add i 1) depth quoted)))))))))

    (defn fsc-bml-find-top-eqeq (s)
        (fsc-bml-find-top-eqeq-loop s 0 0 false))

    (defn fsc-compile-form-bml-eq-recipe (expr pos)
        (do
            (let left-text (fsc-trim (fsc-sub expr 0 pos)))
            (let right-text (fsc-trim (fsc-sub expr (add pos 2) (str_len expr))))
            (fsc-rec-form-call "value_eq"
                (list
                    (fsc-compile-form-bml-expr-recipe left-text)
                    (fsc-compile-form-bml-expr-recipe right-text)))))

    (defn fsc-bml-find-top-brace-loop (s i depth quoted)
        (if (ge i (str_len s)) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (fsc-bml-find-top-brace-loop s (add i 2) depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-top-brace-loop s (add i 1) depth false)
                            (fsc-bml-find-top-brace-loop s (add i 1) depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-top-brace-loop s (add i 1) depth true)
                        (if (str_eq ch "(")
                            (fsc-bml-find-top-brace-loop s (add i 1) (add depth 1) quoted)
                            (if (str_eq ch ")")
                                (fsc-bml-find-top-brace-loop s (add i 1) (sub depth 1) quoted)
                                (if (and (eq depth 0) (str_eq ch "{"))
                                    i
                                    (fsc-bml-find-top-brace-loop s (add i 1) depth quoted)))))))))

    (defn fsc-bml-find-top-brace (s)
        (fsc-bml-find-top-brace-loop s 0 0 false))

    (defn fsc-bml-find-matching-brace-loop (s i depth quoted)
        (if (ge i (str_len s)) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) (str_len s)))
                        (fsc-bml-find-matching-brace-loop s (add i 2) depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-matching-brace-loop s (add i 1) depth false)
                            (fsc-bml-find-matching-brace-loop s (add i 1) depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-matching-brace-loop s (add i 1) depth true)
                        (if (str_eq ch "{")
                            (fsc-bml-find-matching-brace-loop s (add i 1) (add depth 1) quoted)
                            (if (str_eq ch "}")
                                (if (eq depth 1) i
                                    (fsc-bml-find-matching-brace-loop s (add i 1) (sub depth 1) quoted))
                                (fsc-bml-find-matching-brace-loop s (add i 1) depth quoted))))))))

    (defn fsc-bml-find-matching-brace (s open)
        (fsc-bml-find-matching-brace-loop s open 0 false))

    (defn fsc-bml-find-arrow-loop (s i end depth quoted)
        (if (ge i end) (sub 0 1)
            (do
                (let ch (char_at s i))
                (if quoted
                    (if (and (str_eq ch "\\") (lt (add i 1) end))
                        (fsc-bml-find-arrow-loop s (add i 2) end depth quoted)
                        (if (str_eq ch "\"")
                            (fsc-bml-find-arrow-loop s (add i 1) end depth false)
                            (fsc-bml-find-arrow-loop s (add i 1) end depth quoted)))
                    (if (str_eq ch "\"")
                        (fsc-bml-find-arrow-loop s (add i 1) end depth true)
                        (if (or (str_eq ch "(") (str_eq ch "{"))
                            (fsc-bml-find-arrow-loop s (add i 1) end (add depth 1) quoted)
                            (if (or (str_eq ch ")") (str_eq ch "}"))
                                (fsc-bml-find-arrow-loop s (add i 1) end (sub depth 1) quoted)
                                (if (and (eq depth 0) (fsc-find-string-at? s "=>" i 0))
                                    i
                                    (fsc-bml-find-arrow-loop s (add i 1) end depth quoted)))))))))

    (defn fsc-bml-find-arrow (s start end)
        (fsc-bml-find-arrow-loop s start end 0 false))

    (defn fsc-compile-form-bml-match-pattern-recipe (raw)
        (do
            (let pattern (fsc-trim raw))
            (if (str_eq pattern "_")
                (fsc-rec-ident "_")
                (fsc-compile-form-bml-expr-recipe pattern))))

    (defn fsc-bml-match-arm-recipes-loop (arms i end acc)
        (do
            (let p (fsc-skip-spaces arms i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let comma (fsc-bml-find-comma arms p))
                    (let arm-end (if (lt comma 0) end comma))
                    (let arrow (fsc-bml-find-arrow arms p arm-end))
                    (let pattern-text (fsc-trim (fsc-sub arms p arrow)))
                    (let body-text (fsc-trim (fsc-sub arms (add arrow 2) arm-end)))
                    (let rest-start (if (lt comma 0) end (add comma 1)))
                    (fsc-bml-match-arm-recipes-loop arms rest-start end
                        (cons (fsc-compile-form-bml-expr-recipe body-text)
                              (cons (fsc-compile-form-bml-match-pattern-recipe pattern-text)
                                    acc)))))))

    (defn fsc-compile-form-bml-match-recipe (expr)
        (do
            (let open (fsc-bml-find-top-brace expr))
            (let close (fsc-bml-find-matching-brace expr open))
            (let scrutinee-text (fsc-trim (fsc-sub expr 6 open)))
            (let arms-text (fsc-sub expr (add open 1) close))
            (let arm-recipes
                (fsc-bml-match-arm-recipes-loop arms-text 0 (str_len arms-text) (empty)))
            (fsc-rec-match-switch
                (cons (fsc-compile-form-bml-expr-recipe scrutinee-text)
                      arm-recipes))))

    (defn fsc-compile-form-bml-expr-recipe (raw)
        (do
            (let expr (fsc-bml-normalize-ws (fsc-strip-semi raw)))
            (let open (fsc-find-char-from expr "(" 0))
            (let eq-pos (fsc-bml-find-top-eqeq expr))
            (if (eq (str_len expr) 0) (fsc-rec-call "empty" (empty))
            (if (fsc-prefix? expr "if ")
                (fsc-compile-form-bml-if-recipe expr)
            (if (fsc-prefix? expr "match ")
                (fsc-compile-form-bml-match-recipe expr)
            (if (ge eq-pos 0)
                (fsc-compile-form-bml-eq-recipe expr eq-pos)
            (if (and (ge open 0) (str_eq (char_at expr (fsc-last-char-index expr)) ")"))
                (fsc-compile-form-bml-call-recipe expr open)
            (if (str_eq expr "empty") (fsc-rec-call "empty" (empty))
            (if (str_eq expr "true")  (fsc-rec-true)
            (if (str_eq expr "false") (fsc-rec-false)
            (if (str_eq expr "null")  (fsc-rec-ident "null")
            (if (fsc-float? expr) (intern_trivial_float expr)
            (if (fsc-int? expr) (intern_trivial_int (str_to_int expr))
            (if (str_eq (char_at expr 0) "\"")
                (intern_trivial_string
                    (fsc-unescape-str (fsc-sub expr 1 (fsc-last-char-index expr))))
                (fsc-rec-ident expr)))))))))))))))

    (defn fsc-compile-form-bml-def-recipe (line)
        (do
            (let open (fsc-find-char-from line "(" 4))
            (if (lt open 0)
                (fsc-compiler-error-line "form.bml def missing parameter list" line)
            (do
            (let close (fsc-find-char-from line ")" open))
            (if (lt close 0)
                (fsc-compiler-error-line "form.bml def missing closing ')' on the definition line" line)
            (do
            (let eq-pos (fsc-find-char-from line "=" close))
            (if (lt eq-pos 0)
                (fsc-compiler-error-line "form.bml def missing '=' before body" line)
            (do
            (let name (fsc-trim (fsc-sub line 4 open)))
            (let args (fsc-sub line (add open 1) close))
            (let body (fsc-sub line (add eq-pos 1) (str_len line)))
            (let param-names (fsc-bml-name-list-strings-loop args 0 (empty)))
            (fsc-rec-fndef name param-names
                           (fsc-compile-form-bml-expr-recipe body))))))))))

    (defn fsc-compile-form-bml-let-recipe (line)
        (do
            (let eq-pos (fsc-find-char-from line "=" 4))
            (if (lt eq-pos 0)
                (fsc-compiler-error-line "form.bml let missing '='" line)
            (do
            (let name (fsc-trim (fsc-sub line 4 eq-pos)))
            (let body (fsc-sub line (add eq-pos 1) (str_len line)))
            (fsc-rec-let name (fsc-compile-form-bml-expr-recipe body))))))

    (defn fsc-compile-form-bml-template-recipe (line)
        (do
            (let open (fsc-find-char-from line "<" 9))
            (let close (fsc-find-char-from line ">" open))
            (let name (fsc-trim (fsc-sub line 9 open)))
            (let params (fsc-sub line (add open 1) close))
            (let param-names (fsc-bml-name-list-strings-loop params 0 (empty)))
            (fsc-rec-let name
                (fsc-rec-call "language-template"
                    (list
                        (fsc-rec-string name)
                        (fsc-rec-string-list param-names))))))

    (defn fsc-compile-form-bml-template-member-recipe (line)
        (do
            (let value (fsc-strip-semi line))
            (let colon (fsc-find-char-from value ":" 7))
            (let name (fsc-trim (fsc-sub value 7 colon)))
            (let value-type (fsc-trim (fsc-sub value (add colon 1) (str_len value))))
            (fsc-rec-call "language-template-member"
                (list (fsc-rec-string name) (fsc-rec-string value-type)))))

    (defn fsc-bml-template-members-loop (body i end acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let line-end (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p line-end)))
                    (if (fsc-bml-comment-line? line)
                        (fsc-bml-template-members-loop body
                            (fsc-line-next body p) end acc)
                    (if (fsc-prefix? line "member ")
                        (fsc-bml-template-members-loop body
                            (fsc-line-next body p) end
                            (cons (fsc-compile-form-bml-template-member-recipe line) acc))
                        (fsc-bml-template-members-loop body
                            (fsc-line-next body p) end acc)))))))

    (defn fsc-compile-form-bml-template-block-recipe (body line body-start)
        (do
            (let open (fsc-find-char-from line "<" 9))
            (let close (fsc-find-char-from line ">" open))
            (let name (fsc-trim (fsc-sub line 9 open)))
            (let params (fsc-sub line (add open 1) close))
            (let param-names (fsc-bml-name-list-strings-loop params 0 (empty)))
            (let body-end (fsc-bml-block-end body body-start 0))
            (let members (fsc-bml-template-members-loop body body-start body-end (empty)))
            (fsc-rec-let name
                (fsc-rec-call "language-template-with-members"
                    (list
                        (fsc-rec-string name)
                        (fsc-rec-string-list param-names)
                        (fsc-rec-list-of members))))))

    (defn fsc-compile-form-bml-language-class-recipe (line)
        (do
            (let colon (fsc-find-char-from line ":" 6))
            (let eq-pos (fsc-find-char-from line "=" colon))
            (let class-name (fsc-trim (fsc-sub line 6 colon)))
            (let typed-template (fsc-trim (fsc-sub line (add colon 1) eq-pos)))
            (let template-use (bml-source-parse-template-use class-name typed-template))
            (let route-call
                (bml-source-route-call-from-expr
                    (fsc-sub line (add eq-pos 1) (str_len line))))
            (let route-arg-recipes (fsc-bml-route-call-arg-recipes route-call))
            (fsc-rec-let class-name
                (fsc-rec-call
                    (fsc-bml-route-call-language-class-fn route-call)
                    (cons (fsc-rec-string (bml-source-template-use-class-name template-use))
                    (cons (fsc-rec-ident (bml-source-template-use-template-name template-use))
                    (cons (fsc-rec-string-list (bml-source-template-use-type-arguments template-use))
                          route-arg-recipes)))))))

    (defn fsc-compile-form-bml-language-class-block-route-recipe
        (line class-name template-name type-args)
        (do
            (let route-call (bml-source-route-call-from-assignment line))
            (let route-arg-recipes
                (fsc-bml-route-call-arg-recipes-for-class route-call class-name))
            (fsc-rec-call "language-class-member-route"
                (list
                    (fsc-rec-string "route")
                    (fsc-rec-call
                        (fsc-bml-route-call-kernel-route-fn route-call)
                        route-arg-recipes)))))

    (defn fsc-compile-form-bml-class-def-block-recipe (body line body-start class-name)
        (do
            (let open (fsc-find-char-from line "(" 4))
            (let close (fsc-find-char-from line ")" open))
            (let method-name (fsc-trim (fsc-sub line 4 open)))
            (let args (fsc-sub line (add open 1) close))
            (let param-names (fsc-bml-name-list-strings-loop args 0 (empty)))
            (let body-end (fsc-bml-block-end body body-start 0))
            (let stmt-recipes
                (fsc-bml-block-stmts-recipes-loop body body-start body-end (empty)))
            (fsc-rec-fndef
                (fsc-bml-class-member-name class-name method-name)
                param-names
                (fsc-rec-do stmt-recipes))))

    (defn fsc-compile-form-bml-class-method-member-recipe (line class-name)
        (do
            (let open (fsc-find-char-from line "(" 4))
            (let method-name (fsc-trim (fsc-sub line 4 open)))
            (fsc-rec-call "language-class-member-method"
                (list
                    (fsc-rec-string method-name)
                    (fsc-rec-ident (fsc-bml-class-member-name class-name method-name))))))

    (defn fsc-bml-class-method-defs-loop
        (body i end class-name acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let line-end (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p line-end)))
                    (if (fsc-bml-comment-line? line)
                        (fsc-bml-class-method-defs-loop body
                            (fsc-line-next body p) end class-name acc)
                    (if (and (fsc-prefix? line "def ") (fsc-line-opens-block? line))
                        (do
                            (let method-start (fsc-line-next body p))
                            (let method-end (fsc-bml-block-end body method-start 0))
                            (fsc-bml-class-method-defs-loop body
                                (fsc-line-next body method-end) end class-name
                                (cons
                                    (fsc-compile-form-bml-class-def-block-recipe
                                        body line method-start class-name)
                                    acc)))
                        (fsc-bml-class-method-defs-loop body
                            (fsc-line-next body p) end class-name acc)))))))

    (defn fsc-bml-class-member-recipes-loop
        (body i end class-name template-name type-args acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let line-end (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p line-end)))
                    (if (fsc-bml-comment-line? line)
                        (fsc-bml-class-member-recipes-loop body
                            (fsc-line-next body p) end class-name template-name type-args acc)
                    (if (and (fsc-prefix? line "def ") (fsc-line-opens-block? line))
                        (do
                            (let method-start (fsc-line-next body p))
                            (let method-end (fsc-bml-block-end body method-start 0))
                            (fsc-bml-class-member-recipes-loop body
                                (fsc-line-next body method-end) end class-name template-name type-args
                                (cons
                                    (fsc-compile-form-bml-class-method-member-recipe line class-name)
                                    acc)))
                    (do
                        (let stmt-end (fsc-bml-stmt-end body p end))
                        (let stmt (fsc-trim (fsc-sub body p stmt-end)))
                        (let member-recipes
                            (if (fsc-prefix? (fsc-strip-semi stmt) "route ")
                                (list
                                    (fsc-compile-form-bml-language-class-block-route-recipe
                                        stmt class-name template-name type-args))
                                (empty)))
                        (fsc-bml-class-member-recipes-loop body stmt-end end class-name template-name type-args
                            (fsc-rec-append-rev member-recipes acc)))))))))

    (defn fsc-compile-form-bml-language-class-block-recipes (body line body-start)
        (do
            (let colon (fsc-find-char-from line ":" 6))
            (let brace (fsc-find-char-from line "{" colon))
            (let class-name (fsc-trim (fsc-sub line 6 colon)))
            (let typed-template (fsc-trim (fsc-sub line (add colon 1) brace)))
            (let template-use (bml-source-parse-template-use class-name typed-template))
            (let body-end (fsc-bml-block-end body body-start 0))
            (let method-defs
                (fsc-bml-class-method-defs-loop body body-start body-end class-name (empty)))
            (let members
                (fsc-bml-class-member-recipes-loop
                    body
                    body-start
                    body-end
                    class-name
                    (bml-source-template-use-template-name template-use)
                    (bml-source-template-use-type-arguments template-use)
                    (empty)))
            (fsc-list-append method-defs
                (list
                    (fsc-rec-let class-name
                        (fsc-rec-call "language-class"
                            (list
                                (fsc-rec-string (bml-source-template-use-class-name template-use))
                                (fsc-rec-ident (bml-source-template-use-template-name template-use))
                                (fsc-rec-string-list (bml-source-template-use-type-arguments template-use))
                                (fsc-rec-list-of members))))))))

    ;; A block-line returns a (possibly empty) list of recipes. Empty for
    ;; comments; one recipe for let or bare expr.
    (defn fsc-compile-form-bml-block-line-recipe (line)
        (do
            (let value (fsc-strip-semi line))
            (if (fsc-bml-comment-line? value) (empty)
                (if (fsc-prefix? value "let ")
                    (do
                    (let eq-pos (fsc-find-char-from value "=" 4))
                    (let name (fsc-trim (fsc-sub value 4 eq-pos)))
                    (let body (fsc-sub value (add eq-pos 1) (str_len value)))
                    (list (fsc-rec-let name (fsc-compile-form-bml-expr-recipe body))))
                (list (fsc-compile-form-bml-expr-recipe value))))))

    (defn fsc-bml-block-stmts-recipes-loop (body i end acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let line-end (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p line-end)))
                    (if (fsc-bml-comment-line? line)
                        (fsc-bml-block-stmts-recipes-loop body
                            (fsc-line-next body p) end acc)
                    (do
                    (let stmt-end (fsc-bml-stmt-end body p end))
                    (let stmt (fsc-trim (fsc-sub body p stmt-end)))
                    (let line-recipes (fsc-compile-form-bml-block-line-recipe stmt))
                    (fsc-bml-block-stmts-recipes-loop body stmt-end end
                        (fsc-rec-append-rev line-recipes acc))))))))

    (defn fsc-compile-form-bml-def-block-recipe (body line body-start)
        (do
            (let open (fsc-find-char-from line "(" 4))
            (let close (fsc-find-char-from line ")" open))
            (let name (fsc-trim (fsc-sub line 4 open)))
            (let args (fsc-sub line (add open 1) close))
            (let param-names (fsc-bml-name-list-strings-loop args 0 (empty)))
            (let body-end (fsc-bml-block-end body body-start 0))
            (let stmt-recipes
                (fsc-bml-block-stmts-recipes-loop body body-start body-end (empty)))
            (fsc-rec-fndef name param-names (fsc-rec-do stmt-recipes))))

    (defn fsc-compile-form-bml-line-recipe (line)
        (do
            (let value (fsc-strip-semi line))
            (if (fsc-bml-comment-line? value) (empty)
            ;; `import NAME;` is a declaration consumed by the ref resolver, not
            ;; runtime code — it adds NAME to the section's known-abstraction set
            ;; and lowers to nothing.
            (if (fsc-prefix? value "import ") (empty)
            (if (fsc-prefix? value "template ")
                (list (fsc-compile-form-bml-template-recipe value))
            (if (fsc-prefix? value "class ")
                (list (fsc-compile-form-bml-language-class-recipe value))
            (if (fsc-prefix? value "def ")
                (list (fsc-compile-form-bml-def-recipe value))
            (if (fsc-prefix? value "let ")
                (list (fsc-compile-form-bml-let-recipe value))
                (list (fsc-compile-form-bml-expr-recipe value))))))))))

    ;; --- plain generic stdlib class ----------------------------------
    ;;
    ;; A plain generic class `class Name<T,...> { def m(params) = expr; ... }`
    ;; (no `: Template` extension) is an organizing abstraction over stdlib
    ;; recipes. Its methods hoist to BARE top-level fndefs — built by the SAME
    ;; def lowerers a flat `def` rides, so the executable recipe is node-for-
    ;; node identical to writing those defs at the section top level. Callers
    ;; keep using the bare names; the type parameter is a contract that erases.
    ;; The class name also binds to a structural abstraction descriptor —
    ;; a nullary global `(defn Name () (list "abstraction" Name (type-params)
    ;; (member-names)))`, read as `(Name)`. A top-level `let` would leak its
    ;; binding to global scope on three kernels but stay `do`-scoped on fkwu
    ;; (the correct reading), so the descriptor rides a `defn` like every other
    ;; core binding — global and portable across all four arms.

    (defn fsc-bml-word-end (s i)
        (if (ge i (str_len s)) i
            (if (fsc-word-char? (char_at s i))
                (fsc-bml-word-end s (add i 1))
                i)))

    ;; A language class extends a template — `class Name : Template<..> { ..`.
    ;; A plain generic class has no `:` before its opening brace.
    (defn fsc-bml-class-header-has-colon? (line)
        (do
            (let colon (fsc-find-char-from line ":" 6))
            (let brace (fsc-find-char-from line "{" 6))
            (and (ge colon 0) (and (ge brace 0) (lt colon brace)))))

    (defn fsc-bml-def-line-name (line)
        (do
            (let open (fsc-find-char-from line "(" 4))
            (fsc-trim (fsc-sub line 4 open))))

    ;; A class member is a method (def), a field, a ref, or a thought. Methods
    ;; hoist to bare fndefs (reusing the flat def lowerers verbatim = node_eq to
    ;; the flat form). field / ref / thought each bind a nullary global
    ;; (defn NAME () <expr>): a field holds embedded knowledge (a constant), a
    ;; ref points at another cell, a thought computes derived knowledge. They
    ;; read as NAME(); the kind is recorded in the descriptor so the abstraction
    ;; DECLARES its structure (its knowledge), not just its callables.

    (defn fsc-bml-nullary-after-kw (line)
        (fsc-skip-spaces line (fsc-bml-word-end line 0)))

    (defn fsc-bml-nullary-line-name (line)
        (do
            (let after-kw (fsc-bml-nullary-after-kw line))
            (let eq-pos (fsc-find-char-from line "=" after-kw))
            (fsc-trim (fsc-sub line after-kw eq-pos))))

    (defn fsc-compile-form-bml-nullary-recipe (line)
        (do
            (let after-kw (fsc-bml-nullary-after-kw line))
            (let eq-pos (fsc-find-char-from line "=" after-kw))
            (let name (fsc-trim (fsc-sub line after-kw eq-pos)))
            ;; `;` terminates the statement; anything after it (e.g. an inline
            ;; comment) is not part of the expression.
            (let semi (fsc-find-char-from line ";" eq-pos))
            (let expr-end (if (ge semi 0) semi (str_len line)))
            (let expr-text (fsc-trim (fsc-sub line (add eq-pos 1) expr-end)))
            (fsc-rec-fndef name (empty)
                (fsc-compile-form-bml-expr-recipe expr-text))))

    (defn fsc-bml-class-nullary-member? (line)
        (or (fsc-prefix? line "field ")
            (or (fsc-prefix? line "ref ")
                (fsc-prefix? line "thought "))))

    (defn fsc-bml-class-member-kind (line)
        (if (fsc-prefix? line "def ") "method"
        (if (fsc-prefix? line "field ") "field"
        (if (fsc-prefix? line "ref ") "ref"
        (if (fsc-prefix? line "thought ") "thought" "")))))

    ;; Walk the class body once, hoisting every member to its recipe. Methods
    ;; ride the flat def lowerers; field/ref/thought ride the nullary lowerer.
    (defn fsc-bml-generic-class-defs-loop (body i end acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let line-end (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p line-end)))
                    (if (fsc-bml-comment-line? line)
                        (fsc-bml-generic-class-defs-loop body
                            (fsc-line-next body p) end acc)
                    (if (and (fsc-prefix? line "def ") (fsc-line-opens-block? line))
                        (do
                            (let method-start (fsc-line-next body p))
                            (let method-end (fsc-bml-block-end body method-start 0))
                            (fsc-bml-generic-class-defs-loop body
                                (fsc-line-next body method-end) end
                                (cons (fsc-compile-form-bml-def-block-recipe body line method-start)
                                      acc)))
                    (if (fsc-prefix? line "def ")
                        (fsc-bml-generic-class-defs-loop body
                            (fsc-line-next body p) end
                            (cons (fsc-compile-form-bml-def-recipe (fsc-strip-semi line))
                                  acc))
                    (if (fsc-bml-class-nullary-member? line)
                        (fsc-bml-generic-class-defs-loop body
                            (fsc-line-next body p) end
                            (cons (fsc-compile-form-bml-nullary-recipe line) acc))
                        (fsc-bml-generic-class-defs-loop body
                            (fsc-line-next body p) end acc)))))))))

    ;; Walk the class body once more, collecting (kind name) pairs. Skips def
    ;; block bodies so an inner `field` line inside a method is never miscounted.
    (defn fsc-bml-class-member-pairs-loop (body i end acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p end) (fsc-rev acc)
                (do
                    (let line-end (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p line-end)))
                    (if (fsc-bml-comment-line? line)
                        (fsc-bml-class-member-pairs-loop body
                            (fsc-line-next body p) end acc)
                    (if (and (fsc-prefix? line "def ") (fsc-line-opens-block? line))
                        (do
                            (let method-start (fsc-line-next body p))
                            (let method-end (fsc-bml-block-end body method-start 0))
                            (fsc-bml-class-member-pairs-loop body
                                (fsc-line-next body method-end) end
                                (cons (list "method" (fsc-bml-def-line-name line)) acc)))
                    (if (fsc-prefix? line "def ")
                        (fsc-bml-class-member-pairs-loop body
                            (fsc-line-next body p) end
                            (cons (list "method" (fsc-bml-def-line-name line)) acc))
                    (if (fsc-bml-class-nullary-member? line)
                        (fsc-bml-class-member-pairs-loop body
                            (fsc-line-next body p) end
                            (cons (list (fsc-bml-class-member-kind line)
                                        (fsc-bml-nullary-line-name line)) acc))
                        (fsc-bml-class-member-pairs-loop body
                            (fsc-line-next body p) end acc)))))))))

    (defn fsc-bml-names-of-kind (pairs kind)
        (if (fsc-empty? pairs) (empty)
            (if (str_eq (head (head pairs)) kind)
                (cons (head (tail (head pairs)))
                      (fsc-bml-names-of-kind (tail pairs) kind))
                (fsc-bml-names-of-kind (tail pairs) kind))))

    (defn fsc-compile-form-bml-generic-class-block-recipes (body line body-start)
        (do
            (let name-end (fsc-bml-word-end line 6))
            (let class-name (fsc-trim (fsc-sub line 6 name-end)))
            (let lt-pos (fsc-find-char-from line "<" name-end))
            (let brace (fsc-find-char-from line "{" name-end))
            (let type-params
                (if (and (ge lt-pos 0) (lt lt-pos brace))
                    (do
                        (let gt-pos (fsc-find-char-from line ">" lt-pos))
                        (fsc-bml-name-list-strings-loop
                            (fsc-sub line (add lt-pos 1) gt-pos) 0 (empty)))
                    (empty)))
            (let body-end (fsc-bml-block-end body body-start 0))
            (let member-defs
                (fsc-bml-generic-class-defs-loop body body-start body-end (empty)))
            (let pairs
                (fsc-bml-class-member-pairs-loop body body-start body-end (empty)))
            (fsc-list-append member-defs
                (list
                    (fsc-rec-fndef class-name (empty)
                        (fsc-rec-call "list"
                            (list
                                (fsc-rec-string "abstraction")
                                (fsc-rec-string class-name)
                                (fsc-rec-string-list type-params)
                                (fsc-rec-string-list (fsc-bml-names-of-kind pairs "method"))
                                (fsc-rec-string-list (fsc-bml-names-of-kind pairs "field"))
                                (fsc-rec-string-list (fsc-bml-names-of-kind pairs "ref"))
                                (fsc-rec-string-list (fsc-bml-names-of-kind pairs "thought")))))))))

    (defn fsc-form-bml-lines-recipes-loop (body i acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p (str_len body)) (fsc-rev acc)
            (do
                (let e (fsc-line-end body p))
                (let line (fsc-trim (fsc-sub body p e)))
                (if (and (fsc-prefix? line "template ") (fsc-line-opens-block? line))
                    (do
                        (let body-start (fsc-line-next body p))
                        (let body-end (fsc-bml-block-end body body-start 0))
                        (fsc-form-bml-lines-recipes-loop body
                            (fsc-line-next body body-end)
                            (cons (fsc-compile-form-bml-template-block-recipe body line body-start)
                                  acc)))
                (if (and (fsc-prefix? line "class ") (fsc-line-opens-block? line))
                    (do
                        (let body-start (fsc-line-next body p))
                        (let body-end (fsc-bml-block-end body body-start 0))
                        (let class-recipes
                            (if (fsc-bml-class-header-has-colon? line)
                                (fsc-compile-form-bml-language-class-block-recipes body line body-start)
                                (fsc-compile-form-bml-generic-class-block-recipes body line body-start)))
                        (fsc-form-bml-lines-recipes-loop body
                            (fsc-line-next body body-end)
                            (fsc-rec-append-rev class-recipes acc)))
                (if (and (fsc-prefix? line "def ") (fsc-line-opens-block? line))
                    (do
                        (let body-start (fsc-line-next body p))
                        (let body-end (fsc-bml-block-end body body-start 0))
                        (fsc-form-bml-lines-recipes-loop body
                            (fsc-line-next body body-end)
                            (cons (fsc-compile-form-bml-def-block-recipe body line body-start)
                                  acc)))
                    (do
                        (let line-recipes (fsc-compile-form-bml-line-recipe line))
                        (fsc-form-bml-lines-recipes-loop body
                            (fsc-line-next body p)
                            (fsc-rec-append-rev line-recipes acc))))))))))

    ;; --- import + ref resolution (compile-time) ----------------------
    ;;
    ;; A `ref NAME = TARGET;` member names another abstraction. TARGET must
    ;; resolve to a class defined in THIS section or a declared `import NAME;`.
    ;; An unresolved ref is a COMPILE error here — a clear diagnostic at the
    ;; ref site — not an `unbound identifier` crash when the recipe is later
    ;; walked. Scope is deliberately narrow: only ref TARGETS (which name
    ;; abstractions) are gated. Method-body names still resolve at runtime
    ;; against the prelude, so existing sections are unaffected. (Whether an
    ;; imported name actually exists in some prelude is the cross-prelude
    ;; resolver's job — the next step; the import here is the honest
    ;; declaration that satisfies the ref.)

    ;; leading identifier of an expression: "Seed()" -> "Seed", "Foo" -> "Foo"
    (defn fsc-bml-leading-name (s)
        (do
            (let t (fsc-trim s))
            (fsc-sub t 0 (fsc-bml-word-end t 0))))

    (defn fsc-bml-member? (xs name)
        (if (fsc-empty? xs) 0
            (if (str_eq (head xs) name) 1
                (fsc-bml-member? (tail xs) name))))

    ;; referenced targets that resolve to no known abstraction
    (defn fsc-bml-unresolved-refs (known targets)
        (if (fsc-empty? targets) (empty)
            (if (eq (fsc-bml-member? known (head targets)) 1)
                (fsc-bml-unresolved-refs known (tail targets))
                (cons (head targets) (fsc-bml-unresolved-refs known (tail targets))))))

    ;; one line-scan, dispatched by prefix, collecting whichever names the
    ;; caller asked for: "class " names, "import " names, or "ref " targets.
    (defn fsc-bml-section-names-loop (body i prefix kind acc)
        (do
            (let p (fsc-skip-spaces body i))
            (if (ge p (str_len body)) (fsc-rev acc)
                (do
                    (let e (fsc-line-end body p))
                    (let line (fsc-trim (fsc-sub body p e)))
                    (if (fsc-prefix? line prefix)
                        (fsc-bml-section-names-loop body (fsc-line-next body p) prefix kind
                            (cons
                                (if (str_eq kind "ref")
                                    (do
                                        (let eq-pos (fsc-find-char-from line "=" (str_len prefix)))
                                        (fsc-bml-leading-name
                                            (fsc-sub line (add eq-pos 1) (str_len line))))
                                    (fsc-bml-leading-name
                                        (fsc-sub line (str_len prefix) (str_len line))))
                                acc))
                        (fsc-bml-section-names-loop body (fsc-line-next body p) prefix kind acc))))))

    (defn fsc-bml-check-section-refs (body)
        (do
            (let classes (fsc-bml-section-names-loop body 0 "class " "name" (empty)))
            (let imports (fsc-bml-section-names-loop body 0 "import " "name" (empty)))
            (let known (fsc-list-append classes imports))
            (let targets (fsc-bml-section-names-loop body 0 "ref " "ref" (empty)))
            (let unresolved (fsc-bml-unresolved-refs known targets))
            (if (fsc-empty? unresolved) 0
                (fsc-compiler-error
                    (str_concat "unresolved ref target: "
                        (str_concat (head unresolved)
                            " — define it as a class in this section or declare `import <name>;`"))))))

    (defn fsc-compile-form-bml-section-recipe (body)
        (do
            (fsc-bml-check-section-refs body)
            (fsc-rec-do (fsc-form-bml-lines-recipes-loop body 0 (empty)))))

    (defn fsc-compile-form-route-section-recipe (body)
        (fsc-compile-form-bml-section-recipe body))


    ;; --- Recipe source emitter --------------------------------------
    ;;
    ;; The BML compiler builds Form Recipe nodes directly. This emitter lowers
    ;; those nodes back into executable Form source so source-authored route
    ;; manifests do not require .fkb sidecars just to cross into worker kernels.

    (defn fsc-source-emit-join (items)
        (if (fsc-empty? items) ""
            (if (fsc-empty? (tail items)) (head items)
                (str_concat (head items)
                    (str_concat " " (fsc-source-emit-join (tail items)))))))

    (defn fsc-source-emit-list-loop (recipes acc)
        (if (fsc-empty? recipes) (fsc-rev acc)
            (fsc-source-emit-list-loop (tail recipes)
                (cons (fsc-source-emit-recipe (head recipes)) acc))))

    (defn fsc-source-emit-list (recipes)
        (fsc-source-emit-join (fsc-source-emit-list-loop recipes (empty))))

    (defn fsc-source-emit-call (name args)
        (if (fsc-empty? args)
            (str_concat "(" (str_concat name ")"))
            (str_concat "("
                (str_concat name
                    (str_concat " "
                        (str_concat (fsc-source-emit-list args) ")"))))))

    (defn fsc-source-primitive-name-loop (rows cat)
        (if (fsc-empty? rows) ""
            (if (node_eq (form-prim-node (head rows)) cat)
                (head (head rows))
                (fsc-source-primitive-name-loop (tail rows) cat))))

    (defn fsc-source-primitive-name (cat)
        (fsc-source-primitive-name-loop FORM-PRIMITIVE-TABLE cat))

    (defn fsc-source-emit-params-loop (param-items acc)
        (if (fsc-empty? param-items) (fsc-rev acc)
            (fsc-source-emit-params-loop (tail param-items)
                (cons (node_value (head param-items)) acc))))

    (defn fsc-source-emit-params (param-items)
        (fsc-source-emit-join (fsc-source-emit-params-loop param-items (empty))))

    (defn fsc-source-emit-recipe (recipe)
        (do
            (let kids (node_children recipe))
            (if (and (fsc-empty? kids) (eq (node_level recipe) 1))
                (if (eq (node_type recipe) 2)
                    (fsc-q (node_value recipe))
                    (int_to_str (node_value recipe)))
                (do
                    (let cat (node_category recipe))
                    (if (node_eq cat fsc-rec-DO-CAT)
                        (fsc-source-emit-call "do" kids)
                    (if (node_eq cat fsc-rec-LET-CAT)
                        (str_concat "(let "
                            (str_concat (node_value (head kids))
                                (str_concat " "
                                    (str_concat
                                        (fsc-source-emit-recipe (head (tail kids)))
                                        ")"))))
                    (if (node_eq cat fsc-rec-FNCALL-CAT)
                        (fsc-source-emit-call
                            (fsc-source-emit-recipe (head kids))
                            (tail kids))
                    (if (node_eq cat fsc-rec-IDENT-CAT)
                        (node_value (head kids))
                    (if (node_eq cat fsc-rec-FNDEF-CAT)
                        (str_concat "(defn "
                            (str_concat (node_value (head kids))
                                (str_concat " ("
                                    (str_concat
                                        (fsc-source-emit-params
                                            (node_children (head (tail kids))))
                                        (str_concat ") "
                                            (str_concat
                                                (fsc-source-emit-recipe
                                                    (head (tail (tail kids))))
                                                ")"))))))
	                    (if (node_eq cat fsc-rec-IF3-CAT)
	                        (fsc-source-emit-call "if" kids)
	                    (if (node_eq cat fsc-rec-MATCH-CAT)
	                        (fsc-source-emit-call "match" kids)
	                    (do
	                        (let prim-name (fsc-source-primitive-name cat))
	                        (if (str_eq prim-name "")
	                            (fsc-source-emit-call "do" kids)
	                            (fsc-source-emit-call prim-name kids))))))))))))))

    ;; --- compile section as executable Form source -------------------

    (defn fsc-compile-section-recipe (dialect-name body)
        (if (str_eq dialect-name "form.route")
            (fsc-compile-form-route-section-recipe body)
        (if (str_eq dialect-name "form.bml")
            (fsc-compile-form-bml-section-recipe body)
        (if (fsc-high-level-form-dialect? dialect-name)
            (g-parse (bml-grammar) body)
            (fsc-bmf-section-recipe dialect-name body)))))

    (defn fsc-compile-section (dialect-name body)
        (do
            (let recipe (fsc-compile-section-recipe dialect-name body))
            (str_concat (fsc-source-emit-recipe recipe) "\n")))

    ;; --- form.action BMF object rules --------------------------------
    ;; The text lowering above is the bootstrap path for source sections. The
    ;; living action dialect shape is BMF: completed action source objects
    ;; lower rule-by-rule into Form recipe nodes, and each rule carries a
    ;; reverse path back to the matched source span.

    ;; form.action BMF rule actions resolve through the same ontology
    ;; table as the Recipe-emit path. Names → kernel categories.
    (let FSC-ACTION-BLOCK-DO   (form-cat-node "do"))
    (let FSC-ACTION-BLOCK-SEQ  (form-cat-node "sequence"))
    (let FSC-ACTION-BLOCK-LET  (form-cat-node "let"))
    (let FSC-ACTION-COND-IF    (form-cat-node "if"))
    (let FSC-ACTION-FNDEF      (form-cat-node "fndef"))
    (let FSC-ACTION-FNCALL     (form-cat-node "fncall"))
    (let FSC-ACTION-IDENT      (form-cat-node "ident"))

    (defn fsc-action-src-kw (value) (bmf-atom "form-action-keyword" value))
    (defn fsc-action-src-name (value) (bmf-atom "form-action-name" value))
    (defn fsc-action-src-int (value) (bmf-atom "form-action-int" value))
    (defn fsc-action-src-string (value) (bmf-atom "form-action-string" value))
    (defn fsc-action-src-op (value) (bmf-atom "form-action-op" value))
    (defn fsc-action-src-params (value) (bmf-atom "form-action-params" value))
    (defn fsc-action-src-args (value) (bmf-atom "form-action-args" value))
    (defn fsc-action-src-expr (value) (bmf-atom "form-action-expr" value))
    (defn fsc-action-src-items (value) (bmf-atom "form-action-items" value))

    ;; --- streaming BMF source scanner --------------------------------
    ;; A scanner state is a cursor over source. It emits one BMF source
    ;; object and the next cursor; callers decide how much of a stream to
    ;; consume. Grammar meaning stays in BMF object rules below.

    (defn fsc-source-cursor-with-len (source offset line col source-len)
        (list "fsc-source-cursor" source offset line col source-len))

    (defn fsc-file-source-cursor (path offset line col source-len)
        (list "fsc-file-source-cursor" path offset line col source-len))

    (defn fsc-file-source-cursor-window (path offset line col source-len window-start window)
        (list "fsc-file-source-cursor-window"
              path
              offset
              line
              col
              source-len
              window-start
              window))

    (defn fsc-source-cursor-file? (cursor)
        (and (gt (len cursor) 0)
             (or (str_eq (head cursor) "fsc-file-source-cursor")
                 (str_eq (head cursor) "fsc-file-source-cursor-window"))))

    (defn fsc-source-cursor-file-window? (cursor)
        (and (gt (len cursor) 0)
             (str_eq (head cursor) "fsc-file-source-cursor-window")))

    (defn fsc-source-cursor (source offset line col)
        (fsc-source-cursor-with-len source offset line col (str_len source)))

    (defn fsc-source-cursor-source (cursor) (nth cursor 1))
    (defn fsc-source-cursor-offset (cursor) (nth cursor 2))
    (defn fsc-source-cursor-line (cursor) (nth cursor 3))
    (defn fsc-source-cursor-col (cursor) (nth cursor 4))
    (defn fsc-source-cursor-source-len (cursor)
        (if (gt (len cursor) 5)
            (nth cursor 5)
            (if (fsc-source-cursor-file? cursor)
                (file_size (fsc-source-cursor-source cursor))
                (str_len (fsc-source-cursor-source cursor)))))

    (defn fsc-source-window-size () 4096)

    (defn fsc-source-cursor-window-start (cursor) (nth cursor 6))
    (defn fsc-source-cursor-window (cursor) (nth cursor 7))

    (defn fsc-source-cursor-window-contains? (cursor offset)
        (and (fsc-source-cursor-file-window? cursor)
             (and (ge offset (fsc-source-cursor-window-start cursor))
                  (lt offset
                      (add (fsc-source-cursor-window-start cursor)
                           (str_len (fsc-source-cursor-window cursor)))))))

    (defn fsc-source-cursor-windowed (cursor)
        (if (fsc-source-cursor-window-contains? cursor
                                                (fsc-source-cursor-offset cursor))
            cursor
            (fsc-file-source-cursor-window
                (fsc-source-cursor-source cursor)
                (fsc-source-cursor-offset cursor)
                (fsc-source-cursor-line cursor)
                (fsc-source-cursor-col cursor)
                (fsc-source-cursor-source-len cursor)
                (fsc-source-cursor-offset cursor)
                (read_file_slice (fsc-source-cursor-source cursor)
                                 (fsc-source-cursor-offset cursor)
                                 (fsc-source-window-size)))))

    (defn fsc-source-cursor-end? (cursor)
        (ge (fsc-source-cursor-offset cursor)
            (fsc-source-cursor-source-len cursor)))

    (defn fsc-source-cursor-char (cursor)
        (if (fsc-source-cursor-end? cursor) ""
            (if (fsc-source-cursor-file? cursor)
                (do
                    (let windowed (fsc-source-cursor-windowed cursor))
                    (char_at
                        (fsc-source-cursor-window windowed)
                        (sub (fsc-source-cursor-offset cursor)
                             (fsc-source-cursor-window-start windowed))))
                (char_at (fsc-source-cursor-source cursor)
                         (fsc-source-cursor-offset cursor)))))

    (defn fsc-source-cursor-next (cursor offset line col)
        (if (fsc-source-cursor-file? cursor)
            (if (and (fsc-source-cursor-file-window? cursor)
                     (fsc-source-cursor-window-contains? cursor offset))
                (fsc-file-source-cursor-window
                    (fsc-source-cursor-source cursor)
                    offset
                    line
                    col
                    (fsc-source-cursor-source-len cursor)
                    (fsc-source-cursor-window-start cursor)
                    (fsc-source-cursor-window cursor))
                (fsc-file-source-cursor
                    (fsc-source-cursor-source cursor)
                    offset
                    line
                    col
                    (fsc-source-cursor-source-len cursor)))
            (fsc-source-cursor-with-len
                (fsc-source-cursor-source cursor)
                offset
                line
                col
                (fsc-source-cursor-source-len cursor))))

    (defn fsc-source-cursor-advance (cursor)
        (do
            (let ch (fsc-source-cursor-char cursor))
            (if (str_eq ch "\n")
                (fsc-source-cursor-next
                    cursor
                    (add (fsc-source-cursor-offset cursor) 1)
                    (add (fsc-source-cursor-line cursor) 1)
                    0)
                (fsc-source-cursor-next
                    cursor
                    (add (fsc-source-cursor-offset cursor) 1)
                    (fsc-source-cursor-line cursor)
                    (add (fsc-source-cursor-col cursor) 1)))))

    (defn fsc-source-cursor-range (start end)
        (list "fsc-source-range"
              (fsc-source-cursor-offset start)
              (sub (fsc-source-cursor-offset end)
                   (fsc-source-cursor-offset start))
              (fsc-source-cursor-line start)
              (fsc-source-cursor-col start)
              (fsc-source-cursor-line end)
              (fsc-source-cursor-col end)))

    (defn fsc-source-object (kind value start end)
        (bmf-object kind
                    value
                    (bmf-match-source (bmf-empty 0)
                                      (list (fsc-source-cursor-range start end)))
                    bmf-identity-inverse))

    (defn fsc-scan-result (object cursor)
        (list "fsc-scan-result" object cursor))

    (defn fsc-scan-result-object (result) (nth result 1))
    (defn fsc-scan-result-cursor (result) (nth result 2))

    (defn fsc-string-list-contains? (xs value)
        (if (nil? xs) false
            (if (str_eq (head xs) value) true
                (fsc-string-list-contains? (tail xs) value))))

    (defn fsc-source-scan-skip (cursor)
        (if (fsc-source-cursor-end? cursor) cursor
            (if (fsc-space? (fsc-source-cursor-char cursor))
                (fsc-source-scan-skip (fsc-source-cursor-advance cursor))
                cursor)))

    (defn fsc-source-name-char? (ch)
        (or (fsc-word-char? ch) (str_eq ch "?")))

    (defn fsc-source-name-start-char? (ch)
        (do
            (let cp (ord ch))
            (or (and (ge cp 65) (le cp 90))
            (or (and (ge cp 97) (le cp 122))
                (str_eq ch "_")))))

    ;; Extract a slice [start, end) from the cursor's underlying source,
    ;; whether it is an in-memory string or a file path.
    (defn fsc-source-cursor-slice (cursor start end)
        (if (fsc-source-cursor-file? cursor)
            (read_file_slice (fsc-source-cursor-source cursor)
                             start
                             (sub end start))
            (substring (fsc-source-cursor-source cursor) start end)))

    ;; Walk forward through name-chars without copying.  start-cursor stays
    ;; pinned at the token's first byte; we only advance the moving cursor.
    ;; The token text is extracted in a single substring call at the end.
    (defn fsc-source-scan-name-loop (start-cursor cursor)
        (if (fsc-source-cursor-end? cursor)
            (list (fsc-source-cursor-slice
                       start-cursor
                       (fsc-source-cursor-offset start-cursor)
                       (fsc-source-cursor-offset cursor))
                  cursor)
            (do
                (let ch (fsc-source-cursor-char cursor))
                (if (fsc-source-name-char? ch)
                    (fsc-source-scan-name-loop start-cursor
                                               (fsc-source-cursor-advance cursor))
                    (list (fsc-source-cursor-slice
                               start-cursor
                               (fsc-source-cursor-offset start-cursor)
                               (fsc-source-cursor-offset cursor))
                          cursor)))))

    (defn fsc-source-name-kind (value keywords keyword-kind name-kind)
        (if (fsc-string-list-contains? keywords value)
            keyword-kind
            name-kind))

    (defn fsc-source-dialect (keywords keyword-kind name-kind int-kind string-kind op-kind eof-kind ops)
        (list "fsc-source-dialect"
              keywords
              keyword-kind
              name-kind
              int-kind
              string-kind
              op-kind
              eof-kind
              ops))

    (defn fsc-source-dialect-keywords (dialect) (nth dialect 1))
    (defn fsc-source-dialect-keyword-kind (dialect) (nth dialect 2))
    (defn fsc-source-dialect-name-kind (dialect) (nth dialect 3))
    (defn fsc-source-dialect-int-kind (dialect) (nth dialect 4))
    (defn fsc-source-dialect-string-kind (dialect) (nth dialect 5))
    (defn fsc-source-dialect-op-kind (dialect) (nth dialect 6))
    (defn fsc-source-dialect-eof-kind (dialect) (nth dialect 7))
    (defn fsc-source-dialect-ops (dialect) (nth dialect 8))

    (defn fsc-action-keyword? (value)
        (or (str_eq value "def")
        (or (str_eq value "let")
        (or (str_eq value "if")
        (or (str_eq value "then")
        (or (str_eq value "else")
            (str_eq value "do")))))))

    (defn fsc-action-name-kind (value)
        (if (fsc-action-keyword? value)
            "form-action-keyword"
            "form-action-name"))

    (defn fsc-source-scan-name (start keywords keyword-kind name-kind)
        (do
            (let read (fsc-source-scan-name-loop start start))
            (let value (nth read 0))
            (let end (nth read 1))
            (fsc-scan-result
                (fsc-source-object
                    (fsc-source-name-kind value keywords keyword-kind name-kind)
                    value
                    start
                    end)
                end)))

    (defn fsc-source-scan-int-loop (start-cursor cursor)
        (if (fsc-source-cursor-end? cursor)
            (list (fsc-source-cursor-slice
                       start-cursor
                       (fsc-source-cursor-offset start-cursor)
                       (fsc-source-cursor-offset cursor))
                  cursor)
            (do
                (let ch (fsc-source-cursor-char cursor))
                (if (fsc-digit? ch)
                    (fsc-source-scan-int-loop start-cursor
                                              (fsc-source-cursor-advance cursor))
                    (list (fsc-source-cursor-slice
                               start-cursor
                               (fsc-source-cursor-offset start-cursor)
                               (fsc-source-cursor-offset cursor))
                          cursor)))))

    (defn fsc-source-scan-int (start int-kind)
        (do
            (let read (fsc-source-scan-int-loop start start))
            (let value (nth read 0))
            (let end (nth read 1))
            (fsc-scan-result
                (fsc-source-object int-kind value start end)
                end)))

    (defn fsc-source-scan-string-loop (start-cursor cursor)
        (if (fsc-source-cursor-end? cursor)
            (list (fsc-source-cursor-slice
                       start-cursor
                       (fsc-source-cursor-offset start-cursor)
                       (fsc-source-cursor-offset cursor))
                  cursor)
            (if (str_eq (fsc-source-cursor-char cursor) "\"")
                (list (fsc-source-cursor-slice
                           start-cursor
                           (fsc-source-cursor-offset start-cursor)
                           (fsc-source-cursor-offset cursor))
                      (fsc-source-cursor-advance cursor))
                (fsc-source-scan-string-loop start-cursor
                                             (fsc-source-cursor-advance cursor)))))

    (defn fsc-source-scan-string (start string-kind)
        (do
            (let body-start (fsc-source-cursor-advance start))
            (let read (fsc-source-scan-string-loop body-start body-start))
            (let value (nth read 0))
            (let end (nth read 1))
            (fsc-scan-result
                (fsc-source-object string-kind value start end)
                end)))

    (defn fsc-source-advance-n (cursor n)
        (if (le n 0) cursor
            (fsc-source-advance-n (fsc-source-cursor-advance cursor)
                                  (sub n 1))))

    (defn fsc-source-cursor-prefix? (cursor prefix)
        (do
            (let offset (fsc-source-cursor-offset cursor))
            (if (fsc-source-cursor-file? cursor)
                (fsc-source-cursor-file-prefix? cursor prefix 0)
                (fsc-find-string-at-len?
                    (fsc-source-cursor-source cursor)
                    prefix
                    (fsc-source-cursor-source-len cursor)
                    (str_len prefix)
                    offset
                    0))))

    (defn fsc-source-cursor-file-prefix? (cursor prefix j)
        (if (eq j (str_len prefix)) true
            (if (ge (add (fsc-source-cursor-offset cursor) j)
                    (fsc-source-cursor-source-len cursor))
                false
                (if (eq
                        (file_byte_at
                            (fsc-source-cursor-source cursor)
                            (add (fsc-source-cursor-offset cursor) j))
                        (ord (char_at prefix j)))
                    (fsc-source-cursor-file-prefix? cursor prefix (add j 1))
                    false))))

    (defn fsc-source-match-op (cursor ops)
        (if (nil? ops) (fsc-source-cursor-char cursor)
            (if (fsc-source-cursor-prefix? cursor (head ops))
                (head ops)
                (fsc-source-match-op cursor (tail ops)))))

    (defn fsc-source-scan-op (start op-kind ops)
        (do
            (let value (fsc-source-match-op start ops))
            (let end (fsc-source-advance-n start (str_len value)))
            (fsc-scan-result
                (fsc-source-object op-kind value start end)
                end)))

    (defn fsc-source-scan-next (cursor keywords keyword-kind name-kind int-kind string-kind op-kind eof-kind ops)
        (do
            (let start (fsc-source-scan-skip cursor))
            (let ch (fsc-source-cursor-char start))
            (if (fsc-source-cursor-end? start)
                (fsc-scan-result
                    (fsc-source-object eof-kind "" start start)
                    start)
            (if (str_eq ch "\"")
                (fsc-source-scan-string start string-kind)
            (if (fsc-digit? ch)
                (fsc-source-scan-int start int-kind)
            (if (fsc-source-name-start-char? ch)
                (fsc-source-scan-name start keywords keyword-kind name-kind)
                (fsc-source-scan-op start op-kind ops)))))))

    (defn fsc-source-scan-next-dialect (cursor dialect)
        (fsc-source-scan-next cursor
                              (fsc-source-dialect-keywords dialect)
                              (fsc-source-dialect-keyword-kind dialect)
                              (fsc-source-dialect-name-kind dialect)
                              (fsc-source-dialect-int-kind dialect)
                              (fsc-source-dialect-string-kind dialect)
                              (fsc-source-dialect-op-kind dialect)
                              (fsc-source-dialect-eof-kind dialect)
                              (fsc-source-dialect-ops dialect)))

    (let fsc-action-keywords
        (list "def" "let" "if" "then" "else" "do"))

    (let fsc-common-op2
        (list "==" "!=" "<=" ">=" "->" "=>" ":=" "+=" "-=" "*=" "/=" "**" "//" "<<" ">>" "<-" "?."))

    (let fsc-action-source-dialect
        (fsc-source-dialect fsc-action-keywords
                            "form-action-keyword"
                            "form-action-name"
                            "form-action-int"
                            "form-action-string"
                            "form-action-op"
                            "form-action-eof"
                            fsc-common-op2))

    (defn fsc-action-scan-skip (cursor)
        (fsc-source-scan-skip cursor))

    (defn fsc-action-name-char? (ch)
        (fsc-source-name-char? ch))

    (defn fsc-action-scan-name-loop (cursor value)
        (fsc-source-scan-name-loop cursor value))

    (defn fsc-action-scan-name (start)
        (fsc-source-scan-name start
                              fsc-action-keywords
                              "form-action-keyword"
                              "form-action-name"))

    (defn fsc-action-scan-int-loop (cursor value)
        (fsc-source-scan-int-loop cursor value))

    (defn fsc-action-scan-int (start)
        (fsc-source-scan-int start "form-action-int"))

    (defn fsc-action-scan-string-loop (cursor value)
        (fsc-source-scan-string-loop cursor value))

    (defn fsc-action-scan-string (start)
        (fsc-source-scan-string start "form-action-string"))

    (defn fsc-action-scan-op (start)
        (fsc-source-scan-op start "form-action-op" fsc-common-op2))

    (defn fsc-action-scan-next (cursor)
        (fsc-source-scan-next-dialect cursor fsc-action-source-dialect))

    (defn fsc-action-kw (value) (object-lit "form-action-keyword" value))
    (defn fsc-action-op (value) (object-lit "form-action-op" value))
    (defn fsc-action-name (capture-name)
        (list "capture" capture-name (object-lit "form-action-name" "")))
    (defn fsc-action-int (capture-name)
        (list "capture" capture-name (object-lit "form-action-int" "")))
    (defn fsc-action-string (capture-name)
        (list "capture" capture-name (object-lit "form-action-string" "")))
    (defn fsc-action-params (capture-name)
        (list "capture" capture-name (object-lit "form-action-params" "")))
    (defn fsc-action-args (capture-name)
        (list "capture" capture-name (object-lit "form-action-args" "")))
    (defn fsc-action-expr (capture-name)
        (list "capture" capture-name (object-lit "form-action-expr" "")))
    (defn fsc-action-items (capture-name)
        (list "capture" capture-name (object-lit "form-action-items" "")))

    (defn fsc-action-cap (objects capture-name)
        (bmf-collection-value objects capture-name))

    (defn fsc-action-ident-node (name)
        (intern_node FSC-ACTION-IDENT (list (intern_trivial_string name))))

    (defn fsc-action-param-nodes (param-list)
        (if (nil? param-list) (empty)
            (cons (intern_trivial_string (head param-list))
                  (fsc-action-param-nodes (tail param-list)))))

    (defn fsc-action-param-block (param-list)
        (intern_node FSC-ACTION-BLOCK-SEQ
                     (fsc-action-param-nodes param-list)))

    ;; Same primitive lookup as the Recipe-emit path. Was previously a
    ;; subset-of-fsc-rec-form-call if-ladder (missing div/ne/and/or/
    ;; not) — drift this collapses by routing through one table.
    (defn fsc-action-call-node (name args)
        (do
            (let prim-row (form-prim-or-empty name))
            (if (fsc-empty? prim-row)
                (intern_node FSC-ACTION-FNCALL
                             (cons (intern_trivial_string name) args))
                (intern_node (form-prim-node prim-row) args))))

    (defn fsc-action-let-node (name value)
        (intern_node FSC-ACTION-BLOCK-LET
                     (list (intern_trivial_string name) value)))

    (defn fsc-action-do-node (items)
        (intern_node FSC-ACTION-BLOCK-DO items))

    (defn fsc-action-if-node (cond yes no)
        (intern_node FSC-ACTION-COND-IF (list cond yes no)))

    (defn fsc-action-emit-ident (objects)
        (fsc-action-ident-node (fsc-action-cap objects "name")))

    (defn fsc-action-emit-int (objects)
        (intern_trivial_int (str_to_int (fsc-action-cap objects "value"))))

    (defn fsc-action-emit-string (objects)
        (intern_trivial_string (fsc-action-cap objects "value")))

    (defn fsc-action-emit-call (objects)
        (fsc-action-call-node
            (fsc-action-cap objects "name")
            (fsc-action-cap objects "args")))

    (defn fsc-action-emit-let (objects)
        (fsc-action-let-node
            (fsc-action-cap objects "name")
            (fsc-action-cap objects "value")))

    (defn fsc-action-emit-if (objects)
        (fsc-action-if-node
            (fsc-action-cap objects "cond")
            (fsc-action-cap objects "yes")
            (fsc-action-cap objects "no")))

    (defn fsc-action-emit-def (objects)
        (intern_node FSC-ACTION-FNDEF
            (list
                (intern_trivial_string (fsc-action-cap objects "name"))
                (fsc-action-param-block (fsc-action-cap objects "params"))
                (fsc-action-cap objects "body"))))

    (defn fsc-action-emit-do (objects)
        (fsc-action-do-node (fsc-action-cap objects "items")))

    (defn fsc-action-source-span (object)
        (bmf-object-source-span object))

    (defn form-action-bmf-rules (_x)
        (list
            (list
                "ident"
                (fsc-action-name "name")
                fsc-action-emit-ident
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "int"
                (fsc-action-int "value")
                fsc-action-emit-int
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "string"
                (fsc-action-string "value")
                fsc-action-emit-string
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "call"
                (list "sequence"
                    (fsc-action-name "name")
                    (fsc-action-args "args"))
                fsc-action-emit-call
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "if"
                (list "sequence"
                    (fsc-action-kw "if")
                    (fsc-action-expr "cond")
                    (fsc-action-kw "then")
                    (fsc-action-expr "yes")
                    (fsc-action-kw "else")
                    (fsc-action-expr "no"))
                fsc-action-emit-if
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "let"
                (list "sequence"
                    (fsc-action-kw "let")
                    (fsc-action-name "name")
                    (fsc-action-op "=")
                    (fsc-action-expr "value")
                    (fsc-action-op ";"))
                fsc-action-emit-let
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "def"
                (list "sequence"
                    (fsc-action-kw "def")
                    (fsc-action-name "name")
                    (fsc-action-params "params")
                    (fsc-action-op "=")
                    (fsc-action-expr "body")
                    (fsc-action-op ";"))
                fsc-action-emit-def
                bmf-identity-inverse
                fsc-action-source-span)
            (list
                "do"
                (list "sequence"
                    (fsc-action-kw "do")
                    (fsc-action-items "items"))
                fsc-action-emit-do
                bmf-identity-inverse
                fsc-action-source-span)))

    (defn form-action-bmf-find-rule (name rules)
        (if (nil? rules) (empty)
            (if (str_eq (rule-name (head rules)) name)
                (head rules)
                (form-action-bmf-find-rule name (tail rules)))))

    (defn apply-form-action-bmf-rule (rule-name objects)
        (apply-object-rule
            (form-action-bmf-find-rule rule-name (form-action-bmf-rules 0))
            objects))

    (defn form-action-bmf-value (rule-name objects)
        (bmf-object-value
            (cap-get
                (match-caps (apply-form-action-bmf-rule rule-name objects))
                "result")))

    (defn form-action-bmf-ident (name)
        (form-action-bmf-value "ident"
            (list (fsc-action-src-name name))))

    (defn form-action-bmf-int (value)
        (form-action-bmf-value "int"
            (list (fsc-action-src-int value))))

    (defn form-action-bmf-string (value)
        (form-action-bmf-value "string"
            (list (fsc-action-src-string value))))

    (defn form-action-bmf-call (name args)
        (form-action-bmf-value "call"
            (list
                (fsc-action-src-name name)
                (fsc-action-src-args args))))

    (defn form-action-bmf-call0 (name)
        (form-action-bmf-call name (empty)))

    (defn form-action-bmf-call1 (name a)
        (form-action-bmf-call name (list a)))

    (defn form-action-bmf-call2 (name a b)
        (form-action-bmf-call name (list a b)))

    (defn form-action-bmf-call3 (name a b c)
        (form-action-bmf-call name (list a b c)))

    (defn form-action-bmf-call4 (name a b c d)
        (form-action-bmf-call name (list a b c d)))

    (defn form-action-bmf-call5 (name a b c d e)
        (form-action-bmf-call name (list a b c d e)))

    (defn form-action-bmf-if (cond yes no)
        (form-action-bmf-value "if"
            (list
                (fsc-action-src-kw "if")
                (fsc-action-src-expr cond)
                (fsc-action-src-kw "then")
                (fsc-action-src-expr yes)
                (fsc-action-src-kw "else")
                (fsc-action-src-expr no))))

    (defn form-action-bmf-let (name value)
        (form-action-bmf-value "let"
            (list
                (fsc-action-src-kw "let")
                (fsc-action-src-name name)
                (fsc-action-src-op "=")
                (fsc-action-src-expr value)
                (fsc-action-src-op ";"))))

    (defn form-action-bmf-def (name param-list body)
        (form-action-bmf-value "def"
            (list
                (fsc-action-src-kw "def")
                (fsc-action-src-name name)
                (fsc-action-src-params param-list)
                (fsc-action-src-op "=")
                (fsc-action-src-expr body)
                (fsc-action-src-op ";"))))

    (defn form-action-bmf-do-source (items)
        (list
            (fsc-action-src-kw "do")
            (fsc-action-src-items items)))

    (defn form-action-bmf-do-roundtrip (items)
        (bmf-roundtrip
            (form-action-bmf-find-rule "do" (form-action-bmf-rules 0))
            (form-action-bmf-do-source items)))

    (defn form-action-bmf-roundtrip-program (rt)
        (bmf-object-value (bmf-roundtrip-first-object rt)))

    (defn form-action-bmf-program (items)
        (form-action-bmf-roundtrip-program
            (form-action-bmf-do-roundtrip items)))

    (defn form-action-bmf-proof-score (payload rt program)
        (add payload
        (add (if (bmf-roundtrip-node-eq? rt) 100 0)
        (add (len (form-action-bmf-rules 0))
             (len (node_children program))))))

    ;; --- active corpus roundtrip cells -------------------------------
    ;; These cells describe source-file bodies and target source lenses
    ;; above the kernel. They carry source objects beside the compiled
    ;; Form binary node so source -> binary -> source -> binary proof can
    ;; stay generic across dialects.

    (defn fsc-source-corpus (name files)
        (compiler-object "fsc-source-corpus"
                         (list name files)
                         files
                         compiler-identity-inverse))

    (defn fsc-source-corpus-name (corpus)
        (nth (compiler-object-value corpus) 0))

    (defn fsc-source-corpus-files (corpus)
        (nth (compiler-object-value corpus) 1))

    (defn fsc-source-file (path kind sections)
        (compiler-object "fsc-source-file"
                         (list path kind sections)
                         sections
                         compiler-identity-inverse))

    (defn fsc-source-file-path (file)
        (nth (compiler-object-value file) 0))

    (defn fsc-source-file-kind (file)
        (nth (compiler-object-value file) 1))

    (defn fsc-source-file-sections (file)
        (nth (compiler-object-value file) 2))

    (defn fsc-source-section-binary (dialect rule-name source-stream binary)
        (compiler-object "fsc-source-section-binary"
                         (list dialect rule-name source-stream binary)
                         source-stream
                         compiler-identity-inverse))

    (defn fsc-source-section-dialect (section)
        (nth (compiler-object-value section) 0))

    (defn fsc-source-section-rule-name (section)
        (nth (compiler-object-value section) 1))

    (defn fsc-source-section-source (section)
        (nth (compiler-object-value section) 2))

    (defn fsc-source-section-binary-node (section)
        (nth (compiler-object-value section) 3))

    (defn fsc-source-section-node-eq? (section node)
        (node_eq (fsc-source-section-binary-node section) node))

    (defn fsc-repo-file (path kind media-type byte-count sensed)
        (compiler-object "fsc-repo-file"
                         (list path kind media-type byte-count sensed)
                         sensed
                         compiler-identity-inverse))

    (defn fsc-repo-file-from-text (path kind media-type text sensed)
        (fsc-repo-file path kind media-type (str_len text) sensed))

    (defn fsc-repo-file-from-bytes (path kind media-type bytes sensed)
        (fsc-repo-file path kind media-type (len bytes) sensed))

    (defn fsc-repo-file-path (file)
        (nth (compiler-object-value file) 0))

    (defn fsc-repo-file-kind (file)
        (nth (compiler-object-value file) 1))

    (defn fsc-repo-file-media-type (file)
        (nth (compiler-object-value file) 2))

    (defn fsc-repo-file-byte-count (file)
        (nth (compiler-object-value file) 3))

    (defn fsc-repo-file-sensed (file)
        (nth (compiler-object-value file) 4))

    ;; --- repo ingestion objects --------------------------------------
    ;; These are native Form nodes for decoded file meaning. Paths and
    ;; media labels stay on the fsc-repo-file boundary. Transport bytes/text
    ;; are decoder input only; queryable content lives here as local kind
    ;; nodes, source spans, and parsed structures supplied by domain grammars.

    (let FSC-REPO-DOCUMENT (make_nodeid 8 45 6 10))
    (let FSC-REPO-TEXT-LINES (make_nodeid 8 45 6 11))
    (let FSC-REPO-TEXT-LINE (make_nodeid 8 45 6 12))
    (let FSC-REPO-MEANING (make_nodeid 8 45 6 13))
    (let FSC-REPO-MEANING-FIELD (make_nodeid 8 45 6 14))

    (defn fsc-repo-field-int (field value)
        (intern_node
            FSC-REPO-MEANING-FIELD
            (list field (intern_trivial_int value))))

    (defn fsc-repo-field-string (field value)
        (intern_node
            FSC-REPO-MEANING-FIELD
            (list field (intern_trivial_string value))))

    (defn fsc-repo-field-node (field value)
        (intern_node
            FSC-REPO-MEANING-FIELD
            (list field value)))

    (defn fsc-repo-meaning (decoder fields)
        (intern_node FSC-REPO-MEANING (cons decoder fields)))

    (defn fsc-repo-meaning-decoder (meaning)
        (head (node_children meaning)))

    (defn fsc-repo-meaning-fields (meaning)
        (tail (node_children meaning)))

    (defn fsc-repo-field-key (field)
        (nth (node_children field) 0))

    (defn fsc-repo-field-value (field)
        (nth (node_children field) 1))

    (defn fsc-repo-field-value-int (field)
        (node_value (fsc-repo-field-value field)))

    (defn fsc-repo-field-value-string (field)
        (node_value (fsc-repo-field-value field)))

    (defn fsc-repo-text-line (offset length start-line start-col end-line end-col)
        (intern_node
            FSC-REPO-TEXT-LINE
            (list (intern_trivial_int offset)
                  (intern_trivial_int length)
                  (intern_trivial_int start-line)
                  (intern_trivial_int start-col)
                  (intern_trivial_int end-line)
                  (intern_trivial_int end-col))))

    (defn fsc-repo-text-lines-loop (text text-len start line acc)
        (if (ge start text-len)
            (intern_node
                FSC-REPO-TEXT-LINES
                (reverse
                    (if (eq text-len 0)
                        (cons (fsc-repo-text-line 0 0 1 0 1 0) acc)
                        acc)))
            (do
                (let end (fsc-line-end text start))
                (let next (fsc-line-next text start))
                (fsc-repo-text-lines-loop
                    text
                    text-len
                    next
                    (add line 1)
                    (cons (fsc-repo-text-line start (sub end start) line 0 line (sub end start)) acc)))))

    (defn fsc-repo-text-lines (text)
        (fsc-repo-text-lines-loop text (str_len text) 0 1 (empty)))

    (defn fsc-repo-empty-spans ()
        (intern_node FSC-REPO-TEXT-LINES (empty)))

    (defn fsc-repo-document (kind size structure spans)
        (intern_node
            FSC-REPO-DOCUMENT
            (list kind
                  (intern_trivial_int size)
                  structure
                  spans)))

    (defn fsc-repo-text-document (kind text structure)
        (do
            (let lines (fsc-repo-text-lines text))
            (fsc-repo-document
                kind
                (str_len text)
                structure
                lines)))

    (defn fsc-repo-binary-document (kind bytes structure)
        (fsc-repo-document kind (len bytes) structure (fsc-repo-empty-spans)))

    (defn fsc-repo-document-kind (document)
        (nth (node_children document) 0))

    (defn fsc-repo-document-size (document)
        (node_value (nth (node_children document) 1)))

    (defn fsc-repo-document-structure (document)
        (nth (node_children document) 2))

    (defn fsc-repo-document-spans (document)
        (nth (node_children document) 3))

    (defn fsc-repo-text-document-line-count (document)
        (len (node_children (fsc-repo-document-spans document))))

    (defn fsc-repo-text-document-lines (document)
        (fsc-repo-document-spans document))

    (defn fsc-repo-text-document-structure (document)
        (fsc-repo-document-structure document))

    (defn fsc-repo-text-line-number (line)
        (if (gt (len line) 0)
            (nth line 3)
            (node_value (nth (node_children line) 2))))

    (defn fsc-repo-text-line-start (line)
        (if (gt (len line) 0)
            (nth line 1)
            (node_value (nth (node_children line) 0))))

    (defn fsc-repo-text-line-length (line)
        (if (gt (len line) 0)
            (nth line 2)
            (node_value (nth (node_children line) 1))))

    (defn fsc-repo-text-line-end (line)
        (add (fsc-repo-text-line-start line) (fsc-repo-text-line-length line)))

    (defn fsc-repo-text-line-start-col (line)
        (if (gt (len line) 0)
            (nth line 4)
            (node_value (nth (node_children line) 3))))

    (defn fsc-repo-text-line-end-line (line)
        (if (gt (len line) 0)
            (nth line 5)
            (node_value (nth (node_children line) 4))))

    (defn fsc-repo-text-line-end-col (line)
        (if (gt (len line) 0)
            (nth line 6)
            (node_value (nth (node_children line) 5))))

    (defn fsc-repo-binary-document-byte-count (document)
        (fsc-repo-document-size document))

    (defn fsc-repo-binary-document-structure (document)
        (fsc-repo-document-structure document))

    (defn fsc-repo-corpus (name files)
        (compiler-object "fsc-repo-corpus"
                         (list name files)
                         files
                         compiler-identity-inverse))

    (defn fsc-repo-corpus-name (corpus)
        (nth (compiler-object-value corpus) 0))

    (defn fsc-repo-corpus-files (corpus)
        (nth (compiler-object-value corpus) 1))

    (defn fsc-repo-corpus-total-bytes (files)
        (if (nil? files) 0
            (add (fsc-repo-file-byte-count (head files))
                 (fsc-repo-corpus-total-bytes (tail files)))))

    (defn fsc-bmf-lower-node (rule source-stream)
        (do
            (let match (apply-object-rule rule source-stream))
            (let object (cap-get (match-caps match) "result"))
            (bmf-object-value object)))

    (defn fsc-bmf-source-node-eq? (rule source-stream node)
        (node_eq (fsc-bmf-lower-node rule source-stream) node))

    (defn fsc-bmf-roundtrip-node-eq? (rule source-stream)
        (bmf-roundtrip-node-eq? (bmf-roundtrip rule source-stream)))

    (defn fsc-lens-roundtrip-node-eq? (roundtrip node)
        (node_eq (bmf-lens-roundtrip-node roundtrip) node))

    (defn fsc-lens-roundtrip-anchor-eq? (roundtrip anchor)
        (str_eq (bmf-lens-roundtrip-anchor roundtrip) anchor))

    ;; --- source compiler ---------------------------------------------

    ;; Text outside `section [...]` blocks is emitted verbatim into the lowered
    ;; Form, but `.bml` modules carry `//` doc-comment lines (preludes, headers)
    ;; that the Form flattener cannot parse — it only knows `;` comments, so a
    ;; paren inside a `//` line would derail the function index. Strip the
    ;; `//`-only lines here in the compiler (after trimming leading space) and
    ;; pass Form code and `;` comments through untouched.
    (defn fsc-strip-bml-comments-loop (s i)
        (if (ge i (str_len s)) ""
            (do
                (let nxt (fsc-line-next s i))
                (let line (fsc-sub s i (fsc-line-end s i)))
                (if (fsc-prefix? (fsc-trim line) "//")
                    (fsc-strip-bml-comments-loop s nxt)
                    (str_concat (fsc-sub s i nxt)
                                (fsc-strip-bml-comments-loop s nxt))))))

    (defn fsc-strip-bml-comments (s)
        (fsc-strip-bml-comments-loop s 0))

    (defn form-source-compile-loop (src out-path i)
        (do
            (let pos (fsc-find-string-from src "section [" i))
            (if (lt pos 0) (fsc-strip-bml-comments (fsc-sub src i (str_len src)))
                (do
                    (let dialect-start (add pos 9))
                    (let dialect-end (fsc-find-char-from src "]" dialect-start))
                    (let open (fsc-find-char-from src "{" dialect-end))
                    (let close (fsc-section-end src (add open 1)))
                    (let dialect-name (fsc-sub src dialect-start dialect-end))
                    (let body (fsc-sub src (add open 1) close))
                        (str_concat
                            (fsc-strip-bml-comments (fsc-sub src i pos))
                            (str_concat
                            (fsc-compile-section dialect-name body)
                            (form-source-compile-loop src out-path (fsc-line-next src close))))))))

    (defn form-source-compile-text (src out-path)
        (form-source-compile-loop src out-path 0))

    (defn fsc-string-to-bytes-len-loop (s s-len i)
        (if (ge i s-len) (empty)
            (cons (ord (char_at s i))
                  (fsc-string-to-bytes-len-loop s s-len (add i 1)))))

    (defn fsc-string-to-bytes (s)
        (fsc-string-to-bytes-len-loop s (str_len s) 0))

    (defn form-source-compile-file (in-path out-path)
        (do
            (let src (read_file in-path))
            (let compiled (form-source-compile-text src out-path))
            (write_file_text out-path compiled)))

0
