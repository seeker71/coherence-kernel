; host-filesystem-mac.fk — mac POSIX carrier for HostFilesystem (dirent + read/write).
;
; preludes: form-stdlib/core.fk form-stdlib/form-fs.fk
;
; The BML source of truth is host-filesystem.bml (HostFilesystem + MacHostFilesystem).
; These hoisted recipes are what the four-way band walks today; the BML class lowers
; to the same host-fs membrane surface.

(do
    (defn hfs-list (dir) (fs-list dir))
    (defn hfs-read (path) (fs-read-text path))
    (defn hfs-write (path, text) (fs-write-text path text))
    (defn hfs-size (path) (fs-stat-size path))

    (defn hfs-has (entries name)
        (if (eq (len entries) 0) 0
            (if (str_eq (head entries) name) 1
                (hfs-has (tail entries) name))))

    (defn mac-hfs-list (dir) (hfs-list dir))
    (defn mac-hfs-read (path) (hfs-read path))
    (defn mac-hfs-write (path text) (hfs-write path text))
    (defn mac-hfs-size (path) (hfs-size path))

    0)
