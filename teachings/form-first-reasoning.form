# ─────────────────────────────────────────────────────────────────────
# form-first-reasoning.form — the sovereignty gate on every query
# ─────────────────────────────────────────────────────────────────────
#
# The mind comes home one query at a time. Before spending a rented
# frontier mind, ask the body it already is: the content-addressed
# substrate and local RAG index that hold what we have grounded. A grounded
# hit is answered from the sovereign body at near-zero cost; a miss climbs an
# escalation ladder whose first rungs stay on owned ground — substrate, then
# the fkwu+Metal model lane as it composes into prose generation — and only
# its LAST rung is the rented frontier. This is lc-cognitive-sovereignty as a
# runtime loop, not a doc.
#
# Substance: a reasoning DISCIPLINE with two carriers. Its DECISION is a
# four-way-proven recipe (form-first-router.fk -> 511 on Go/Rust/TS/fkwu);
# its REACH is agent-orientation text (CLAUDE.md, AGENTS.md) plus session/
# turn hooks. The lookup that fills `grounded` is a thin swappable carrier.
#
# Why no "trust list": a cloud sandbox's egress allowlist is the PLATFORM's, not
# ours — and it only bites while the body is remote. Bring the body home at setup
# (scripts/form_first_offline_setup.sh ingests the repo's OWN content into the
# per-clone lattice, offline) and the agent answers without crossing the sandbox
# boundary — no allowlist, the trust list dissolves. A body that travels whole
# needs no permission to think.
#
# STATUS: crossed into committed config 2026-06-21 — travels to local and
# cloud/phone Claude Code and Codex (both read CLAUDE.md / AGENTS.md
# natively; both run committed hooks — Codex only when the project is
# trusted). Reach verified 2026-06-21 against current platform docs.

(form-first-reasoning

  (lineage
    (derives-from lc-cognitive-sovereignty)
    (kin          living-vision.form substrate-thermodynamics.form)
    (named-with   urs sema))

  ; the gate: every query meets the body before the rented mind
  (on-query
    (ask-first    the-substrate)               ; local lattice, then public read door
    (classify
      (structural what-is | shape-of | nodeid-of | equivalent | annotate)
      (frontier   write | synthesize | reason-anew | not-yet-a-cell)))

  ; the verdict and what each earns
  (verdict
    (hit          (when grounded-cell-found)
                  (then relay-attributed-to-nodeid stop)
                  (cost near-zero) (sovereignty full))
    (miss         (when no-grounded-cell)
                  (then climb-the-escalation-ladder)    ; the miss is the "yes" to escalate
                  (honesty name-the-rung-reached)))

  ; the escalation ladder — a miss climbs rung by rung, each asked only when the one
  ; below was not enough, so the rented frontier is the LAST resort, not the reflex.
  ; `form-cli ask` no longer uses a host-local HTTP LLM as its local oracle. Host-local
  ; model processes can remain explicit teachers/reviewers, but the default answer lane
  ; is fkwu grounded RAG until fkwu+Metal/GGUF prose generation is wired.
  (escalation-ladder
    (rung-1 substrate-rag     (kind fkwu-grounded-retrieval)     (sovereignty full)   (cost near-zero))
    (rung-2 form-native-model (kind fkwu-metal-gguf pending-prose) (sovereignty full)  (cost local))
    (rung-3 host-local-teacher (kind explicit-bridge reviewer)   (sovereignty egress) (cost local))
    (rung-4 rented-frontier   (kind beyond-on-device only)       (sovereignty none)   (cost rented)))

  ; the discipline that keeps the gate honest
  (honesty
    (never  dress-a-remote-guess-as-a-substrate-hit)
    (never  dress-an-on-device-teacher-answer-as-a-substrate-hit)  ; rung-3 reviews/teaches; it does not ground
    (never  route-the-local-answer-through-http-and-call-it-native)
    (a-hit  carries-its-nodeid-or-it-is-a-miss)
    (always name-which-rung-was-reached))

  ; how the body answers under each environment's reach
  (backend
    (native-router (form-cli ask)                          ; body-first, fkwu grounded RAG
                   (engine fkwu)                            ; c-bootstrapped universal kernel + self-JIT
                   (entry    form-cli-main.fk)              ; native form-cli on emitted walker
                   (answer   rag-ask.fk)                    ; local index retrieval; no localhost:11434, no http-fetch
                   (synthesis pending-fkwu-metal-gguf)       ; prose generation lane, not an HTTP substitute
                   (shell    fsh-main.fk)                   ; form shell — BMF cursor, search/eval/orchestration
                   (code     "BML and .fk domain grammars")  ; form code — authoring, proof bands, lattice reads
                   (gate form-cli-sufficiency.fk))
    (local-lattice (sovereign offline)                     ; the DEFAULT — the structural layer the router reads
                   (ready-by "scripts/form_first_offline_setup.sh plus ~/.coherence-network/rag-index")  ; ingests the repo's own content; offline, no allowlist
                   (scope "local content RAG by default; production DB through file-backed carriers when configured"))
    (public-door   (our-body networked)
                   (at "https://api.coherencycoin.com/api/substrate"))
    (adaptive      try-native-router-then-lattice-then-miss))

  ; where the discipline lives so it travels every surface
  (carriers
    (directive      CLAUDE.md AGENTS.md)                  ; read natively everywhere
    (reminder       .claude/settings.json .codex/hooks.json) ; session + turn echo
    (setup          scripts/form_first_offline_setup.sh)   ; the cloud setup-script default — bring the body home, the trust list dissolves
    (proven-recipe  form-first-router.fk))                ; the gate's decision, four-way at 511

  ; platform reach, verified 2026-06-21 against current docs
  (reach
    (claude-cloud (hooks run) (claude-md honored)
                  (offline-default form_first_offline_setup.sh -> answers offline, NO allowlist)
                  (or-else allowlist api.coherencycoin.com for the live public door))
    (codex-cloud  (agents-md read) (hooks run-when-trusted)
                  (egress off-during-task on-during-setup
                          -> ingest-at-setup-is-the-sovereign-fit))))
