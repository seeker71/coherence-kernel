.DS_Store
.claude/

# obsidian vault window (SECOND-BRAIN.md): commit only the shared door
# settings; workspace/cache/plugins are per-witness, never the commons'
.obsidian/*
!.obsidian/app.json
!.obsidian/graph.json
fkwu
fkwu.exe
win-witness/
fkwu-cam-frame.bmp
fkwu-cam-frame.png
walkers/go/walker
gowalker.exe
fkwu.exe
/nvr.fk
/t.fk
/tiny.fk
*.flat
audio-training-runs/

# local runtime config (never commit -- read at startup, would change behavior)
fkwu.conf

# tool build cache (compiled artifacts; regenerable)
.forge/

# program-image artifacts fkwu emits beside any .fk it runs (regenerable;
# fkwu recompiles stale/missing ones -- like the fkwu binary, never committed)
*.fkb
*.sym

# the door's circle store: consented visitor memory is held by the BODY, never
# published to the public repo -- remembering is not publishing
# (plugin/chatgpt-plugin.fk's memory doors; reception-consent-policy.form)
plugin/circle/
plugin/circle-introductions/
__pycache__/
*.py[cod]
