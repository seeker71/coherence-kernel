#version 450
layout(local_size_x = 64) in;
layout(std430,binding=0) buffer Xb{float x[];};
layout(std430,binding=1) readonly buffer Cb{float cs[];};
layout(push_constant) uniform P{uint heads;uint hd;uint hf;uint csoff;}pc;
void main(){uint id=gl_GlobalInvocationID.x; if(id>=pc.heads*pc.hf)return; uint h=id/pc.hf; uint i=id%pc.hf; uint base=h*pc.hd; float c=cs[pc.csoff+i]; float s=cs[pc.csoff+pc.hf+i]; float x0=x[base+2u*i]; float x1=x[base+2u*i+1u]; x[base+2u*i]=x0*c - x1*s; x[base+2u*i+1u]=x0*s + x1*c;}
