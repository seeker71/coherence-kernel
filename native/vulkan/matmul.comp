#version 450
layout(local_size_x = 64) in;
layout(std430,binding=0) readonly buffer Xb{float x[];};
layout(std430,binding=1) readonly buffer Wb{float w[];};
layout(std430,binding=2) writeonly buffer Yb{float y[];};
layout(push_constant) uniform P{uint M;uint N;uint K;}pc;
void main(){uint id=gl_GlobalInvocationID.x; if(id>=pc.M*pc.N)return; uint m=id/pc.N; uint n=id%pc.N; precise float acc=0.0; for(int t=int(pc.K)-1;t>=0;--t){precise float p=x[m*pc.K+uint(t)]*w[n*pc.K+uint(t)]; acc=p+acc;} y[id]=acc;}

