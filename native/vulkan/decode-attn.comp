#version 450
layout(local_size_x = 32) in;
layout(std430,binding=0) readonly buffer Qb{float q[];};
layout(std430,binding=1) readonly buffer KVb{float kv[];};
layout(std430,binding=2) writeonly buffer Ab{float at[];};
layout(push_constant) uniform P{uint Pn;uint nh;uint nkv;uint hd;uint grp;float invs;uint koff;}pc;
float fexp(float v){float s=v;int k=0;while(abs(s)>0.5){s=s*0.5;k=k+1;}float nn=1.0;float term=1.0;float acc=1.0;for(int q2=0;q2<14;++q2){term=term*(s/nn);acc=acc+term;nn=nn+1.0;}while(k>0){acc=acc*acc;k=k-1;}return acc;}
void main(){uint h=gl_GlobalInvocationID.x; if(h>=pc.nh)return; uint kvh=h/pc.grp; uint stride=2u*pc.nkv*pc.hd; uint voff=pc.nkv*pc.hd; float sc[80]; float m=-1.0e30; for(uint p=0u;p<pc.Pn;++p){precise float acc=0.0; for(int t=int(pc.hd)-1;t>=0;--t){precise float pr=q[h*pc.hd+uint(t)]*kv[pc.koff+p*stride+kvh*pc.hd+uint(t)]; acc=pr+acc;} float sci=acc*pc.invs; sc[p]=sci; if(sci>m)m=sci;} precise float ssum=0.0; for(int p=int(pc.Pn)-1;p>=0;--p){ssum=fexp(sc[uint(p)]-m)+ssum;} for(uint t=0u;t<pc.hd;++t){precise float o=0.0; for(int p=int(pc.Pn)-1;p>=0;--p){precise float pr=(fexp(sc[uint(p)]-m)/ssum)*kv[pc.koff+uint(p)*stride+voff+kvh*pc.hd+t]; o=pr+o;} at[h*pc.hd+t]=o;}}
