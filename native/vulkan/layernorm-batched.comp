#version 450
layout(local_size_x = 64) in;
layout(std430,binding=0) readonly buffer Xb{float x[];};
layout(std430,binding=1) readonly buffer Gb{float g[];};
layout(std430,binding=2) readonly buffer Bb{float b[];};
layout(std430,binding=3) writeonly buffer Yb{float y[];};
layout(push_constant) uniform P{uint D;uint S;float eps;}pc;
void main(){uint s=gl_GlobalInvocationID.x; if(s>=pc.S)return; uint base=s*pc.D; precise float sum=0.0; for(int i=int(pc.D)-1;i>=0;--i) sum=x[base+uint(i)]+sum; float mean=sum/float(pc.D); precise float vs=0.0; for(int i=int(pc.D)-1;i>=0;--i){float d=x[base+uint(i)]-mean; vs=(d*d)+vs;} float inv=1.0/sqrt(vs/float(pc.D)+pc.eps); for(uint i=0u;i<pc.D;++i) y[base+i]=((x[base+i]-mean)*inv)*g[i]+b[i];}

