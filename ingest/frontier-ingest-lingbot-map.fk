; frontier-ingest-lingbot-map.fk — ingest what is healthy from LingBot-Map.
;
; Source arrival: https://x.com/i/status/2077779856050606155, Superman
; (@thesupermanmx), 2026-07-16. Grounded against the linked primary repository
; Robbyant/lingbot-map and Chen et al., "Geometric Context Transformer for
; Streaming 3D Reconstruction" (arXiv:2604.14141), not the social caption.
;
; Primary-source floor: LingBot-Map is a feed-forward streaming 3D model whose
; GCT separates anchor context, a pose-reference window, and trajectory memory.
; The repository reports about 20 FPS at 518x378 with paged-KV attention and
; sequences beyond 10,000 frames. It also says inference range is bounded by
; training distance, performance degrades beyond the 320-view RoPE range, and
; windowed resetting may be necessary. The released path requires PyTorch,
; CUDA, learned checkpoints, and preferably FlashInfer.
;
; unit=(depth fear); ki-ingest -> 2 body / 1 liquid / 0 compost.
; preludes: form/form-stdlib/core.fk ingest/knowledge-ingest.fk

(do
    ; BODY: this ingest built the transferable geometric and streaming spine as
    ; real Form: pinhole depth->world reconstruction, SE(3) inverse/compose and
    ; relative pose, anchor-scale normalization, exact GCA token accounting,
    ; dense-window eviction into six-token trajectory memory, paged allocation,
    ; and the k(k-1) causal relative-pose pair law. These are executable organs,
    ; not a claim that the learned predictor itself has been imported.
    (defn film-u1 () (list 5 0))
    ; BODY: the source's own caveats are healthy epistemic tissue: long-range
    ; success is conditional on training range, cache policy, and reset mode.
    (defn film-u2 () (list 4 0))

    ; LIQUID: the architecture is a concrete roadmap for a future visual world
    ; organ, but no LingBot weights or inference path run in this body.
    (defn film-u3 () (list 5 1))
    ; LIQUID: real-time 3D from monocular video is an enormous capability gap:
    ; no image encoder, pose head, dense depth/confidence head, or point-cloud
    ; reconstruction is wired into coherence-kernel.
    (defn film-u4 () (list 5 1))
    ; LIQUID: the CUDA/PyTorch/FlashInfer release is usable as an oracle carrier,
    ; not native Form tissue and not evidence of single-GPU speed on this host.
    (defn film-u5 () (list 4 1))

    ; COMPOST: "any scene" and "without falling apart" erase explicit range,
    ; RoPE, keyframe, and reset caveats in the primary repository.
    (defn film-u6 () (list 1 0))
    ; COMPOST: 20 FPS, 10k+ frames, and benchmark superiority are the authors'
    ; measurements, not locally reproduced coherence-kernel observations.
    (defn film-u7 () (list 1 0))

    (defn film-units ()
        (list (film-u1) (film-u2) (film-u3) (film-u4) (film-u5) (film-u6) (film-u7)))
    (defn film-count (us v)
        (if (eq (len us) 0) 0
            (add (if (eq (ki-ingest (head us)) v) 1 0)
                 (film-count (tail us) v))))
    (defn film-frozen () (film-count (film-units) 2))
    (defn film-witnessed () (film-count (film-units) 1))
    (defn film-composted () (film-count (film-units) 0))
    (defn film-field-code ()
        (add (mul (film-frozen) 10000)
        (add (mul (film-witnessed) 100) (film-composted))))
    0)
