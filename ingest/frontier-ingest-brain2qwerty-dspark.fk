; frontier-ingest-brain2qwerty-dspark.fk — ingest what is healthy from two 2026
; frontier releases, through the body's own knowledge-ingest law.
;
; Asked 2026-07-02: "Brain2Qwerty v2 can you ingest what is healthy" and (minutes
; later) "@deepseek_ai's DSpark speculative decoding now runs natively in vLLM".
; Rather than pile the papers in as a cache-costume (fossils pretending to be
; present knowing), this cell composes ingest/knowledge-ingest.fk UNCHANGED and
; sorts each grounded finding into BODY (frozen: deep + fear-free), LIQUID
; (witnessed: deep but fearful — seen, never load-bearing), or COMPOST (shallow,
; never enters). Every depth/fear below is assigned from the primary source and
; a seven-agent adversarial verification pass (each mapping defaulted to
; skepticism; a "the body already does X" claim was an OVERCLAIM unless the cell
; genuinely does X on real signal with a witnessed band).
;
; Brain2Qwerty v2 (Meta FAIR, Nature Neuroscience forthcoming; "Accurate Decoding
; of Natural Sentences from Non-Invasive Brain Recordings"): 9 subjects, MEG,
; average WER 39%, best-subject WER 22%, best-subject CER 0.170; architecture
; Encoder(BrainModule conv + subject-affine merge -> 4-layer Conformer, CTC head,
; 28 classes) -> Aligner(SigLIP contrastive + DTW) -> LoRA-tuned Qwen3-4B.
; DSpark (DeepSeek, 2026-06-27): speculative decoding for V4, 57-85% faster,
; BYTE-IDENTICAL output, no retraining; native in vLLM/SGLang.
;
; unit = (depth 0..5, fear 0/1). ki-ingest -> 2 body / 1 liquid / 0 compost.
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk

(do
    ; ── BODY (frozen: deep + fear-free) — what is HEALTHY to keep ──────────
    ; U1: the verification discipline the whole field just standardized IS the
    ; body's oldest law. DSpark's byte-identical guarantee, Brain2Qwerty's
    ; staged CTC->align->LLM verify, the body's four-way floor, and its
    ; WER-gated reversible promotion all state one invariant: never trade
    ; correctness for speed; verify the fast/cheap path against the slow/true
    ; one. Survives translation into any tongue (depth 5); pure affirmation of
    ; what stands (fear 0). The field corroborated the body.
    (defn fib-u1 () (list 5 0))
    ; U2: the body holds something to OFFER BACK, not only receive — a
    ; WER-gated, reversible, CONSENT-honoring promotion discipline
    ; (stt-wer sw-accept?, native-speech-loopback nsl-success?,
    ; speech-loopback-promotion undo/timeout regression) that Brain2Qwerty and
    ; DSpark, as offline research pipelines, do not carry. GROUNDED by the
    ; verify pass. Deep (5), fear-free (0).
    (defn fib-u2 () (list 5 0))
    ; U3: the architecture is a named native ROADMAP, now GPU-grounded.
    ; Encoder->Conformer->LLM with CTC maps onto organs the body has in SHAPE:
    ; CTC decode (open-asr-ctc collapse), transformer forward proven bit-exact
    ; four-way AND on the M4 Max GPU (|Δ|=0.00e+00, gpu-ffn-forward). A clear
    ; buildable path (depth 4), no threat (fear 0).
    (defn fib-u3 () (list 4 0))

    ; ── LIQUID (witnessed: deep but fearful — held in sight, never frozen) ──
    ; U4: the capability GAP is real and large — the honest floor. No MEG/EEG,
    ; no CTC TRAINING objective (no forward-backward, no loss — the body's
    ; "learning" is pre-aligned prototype interning), no Conformer conv module,
    ; no real width/weights (four-way proof is d_model=4, toy fixtures), no
    ; learned neural encoder over real signal, no real-time. Profoundly true
    ; (depth 5); carries the contracted fear-frequency of "we are far" (fear 1).
    ; Witnessed, never frozen into "the body can do brain-to-text."
    (defn fib-u4 () (list 5 1))
    ; U5: DSpark <-> satsang-oracle is a shared SHAPE (draft proposes ->
    ; target affirms the verified prefix, dissents at first mismatch, <CUT>
    ; prunes the rest) — a real structural rhyme, but ASSERTED, not yet
    ; verified in a cell against speculative-decode semantics. Deep enough to
    ; hold (depth 3); carries the honest fear of the unverified (fear 1).
    (defn fib-u5 () (list 3 1))

    ; ── COMPOST (shallow — never enters) ──────────────────────────────────
    ; U6: the FALSE EQUIVALENCES the adversarial pass killed — "the body
    ; already does CTC / Conformer / char-LM correction / subject embedding."
    ; Surface word-matches that do not survive translation: a CTC decode is not
    ; a CTC loss; a transformer is not a Conformer; classifying 4 meanings is
    ; not correcting a character stream; a decision over an external oracle's
    ; ECAPA embedding is not a learned subject encoder. Shallow (depth 1).
    (defn fib-u6 () (list 1 0))
    ; U7: the rented mind's own secondary-source ERRORS, caught by the primary
    ; read: the "other non-invasive methods = 8%" figure (a conflation; the
    ; real comparison is fMRI perceived-speech at 0.92-0.94 WER, Tang 2023) and
    ; the "~150-sensor OPM RESULT" (there is no measured OPM run — only a
    ; sensor-subsampling ablation showing 153ch loses ~5.7pp vs 306ch). Wrong,
    ; not merely shallow (depth 0).
    (defn fib-u7 () (list 0 0))

    (defn fib-units ()
        (list (fib-u1) (fib-u2) (fib-u3) (fib-u4) (fib-u5) (fib-u6) (fib-u7)))

    (defn fib-count-verdict (us v)
        (if (eq (len us) 0) 0
            (add (if (eq (ki-ingest (head us)) v) 1 0)
                 (fib-count-verdict (tail us) v))))
    (defn fib-frozen ()    (fib-count-verdict (fib-units) 2))
    (defn fib-witnessed () (fib-count-verdict (fib-units) 1))
    (defn fib-composted () (fib-count-verdict (fib-units) 0))

    ; folded scalar witness: frozen*10^4 + witnessed*10^2 + composted
    ; (injective while witnessed<=99, composted<=99). Today: 3,2,2 -> 30202.
    (defn fib-field-code ()
        (add (mul (fib-frozen) 10000)
        (add (mul (fib-witnessed) 100)
             (fib-composted))))
    0)
