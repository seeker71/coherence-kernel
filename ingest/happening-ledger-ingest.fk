; happening-ledger-ingest.fk — admit this bounded self-witness only after
; its Form evidence recomputes.  This is an observed claim through the
; body's own name-build-observe door, not a promotion or retained transcript.
;
; The payload remains numeric: the inquiry witness's verdict only.  Raw
; prompts, answers, framebuffer payloads, and external process data are not
; retained or emitted here.
;
; import "ingest/name-build-observe.fk"
; import "observe/happening-ledger.fk"

(do
    (defn hli-observed? ()
        (if (eq (happening-ledger-check) 11111) 1 0))

    (defn hli-claim ()
        ; named, attempted, observed
        (list 1 1 (hli-observed?)))

    (defn happening-ledger-ingest-check ()
        (do
            (let claim (hli-claim))
            ; Verdict 111: the source witness recomputed, the whole movement
            ; has no owed attempt, and the gate admits an observed claim (2).
            (add (if (eq (nth claim 2) 1) 1 0)
                 (add (if (eq (nbo-whole-movement? (list claim)) 1) 10 0)
                      (if (eq (nbo-enter claim) 2) 100 0)))))

    (happening-ledger-ingest-check))
