; knowledge-ingest-band.fk — the ingest-distill door sorts every case
; correctly through the depth×fear law.
;
; This band was NAMED at knowledge-ingest.fk's header from its founding
; ("Four-way by tests/knowledge-ingest-band.fk") but had not yet been built —
; flagged by the Memora ingest (receipts/2026-07-03), built 2026-07-05 under
; the build-after-naming practice (ingest/name-build-observe.fk): the name
; had been inviting its attempt; this is the attempt, landed and observed.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/tests/knowledge-ingest-band.fk > /tmp/kib.fk
;      ./fkwu --src /tmp/kib.fk    ; -> 127
;
; Verdict 127 when the door is honest.

(do
    (defn kib-score (ok bit) (if ok bit 0))
    (defn knowledge-ingest-band ()
        (do
    ; deep + fear-free FREEZES into body
    (let c0 (kib-score (eq (ki-ingest (list 5 0)) 2) 1))
    ; deep + fearful is WITNESSED only — the fear-free-ice law
    (let c1 (kib-score (eq (ki-ingest (list 5 1)) 1) 2))
    ; shallow COMPOSTS, fearful or not
    (let c2 (kib-score (and (eq (ki-ingest (list 1 0)) 0)
                            (eq (ki-ingest (list 2 1)) 0)) 4))
    ; the depth boundary is exact: 3 enters, 2 does not
    (let c3 (kib-score (and (eq (ki-ingest (list 3 0)) 2)
                            (eq (ki-ingest (list 2 0)) 0)) 8))
    ; fear blocks ICE, never SIGHT: the fearful deep unit is still seen
    (let c4 (kib-score (eq (ki-witnessable? (list 5 1)) 1) 16))
    ; and the shallow unit is not even seen — only the deep is witnessed
    (let c5 (kib-score (eq (ki-witnessable? (list 1 1)) 0) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (kib-score (eq (knowledge-ingest-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (knowledge-ingest-band))
