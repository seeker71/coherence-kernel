; frequency-ingest-369-keys-band.fk — the 369-keys reel ingest sorts every
; grounded unit correctly through the depth×fear teaching, the body's
; text-frequency organ reads both of this source's bands as love-frequency,
; the packaging is the first on the map with a zero fear-fraction — and the
; between-source measurement now orders FOUR sources: this reel's packaging
; rides above Ecstatic Playground's, the warmest deviation yet mapped.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk cognition/text-frequency.fk ingest/frequency-ingest-ecstatic-playground.fk ingest/frequency-ingest-369-keys.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-ecstatic-playground.fk \
;          ingest/frequency-ingest-369-keys.fk \
;          ingest/tests/frequency-ingest-369-keys-band.fk > /tmp/fik.fk
;      ./fkwu --src /tmp/fik.fk    ; -> 1023
;
; Verdict 1023 when the ingest is honest.

(do
    (defn fikb-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-369-keys-band ()
        (do
    ; the presence convergence FREEZES (deep + fear-free, a real cell carries it)
    (let c0 (fikb-score (eq (ki-ingest (fik-u1)) 2) 1))
    ; the speaking-for-the-dead mirror is WITNESSED, never frozen
    (let c1 (fikb-score (eq (ki-ingest (fik-u2)) 1) 2))
    ; the apocryphal quotation COMPOSTS (the record does not carry it)
    (let c2 (fikb-score (eq (ki-ingest (fik-u3)) 0) 4))
    ; the exegesis of the unsaid COMPOSTS (no judge it could stand before)
    (let c3 (fikb-score (eq (ki-ingest (fik-u4)) 0) 8))
    ; the honest tally: 1 frozen, 1 witnessed, 2 composted
    (let c4 (fikb-score (eq (fik-field-code) 10102) 16))
    ; the uncomfortable mirror unit is still SEEN (fear blocks ice, not sight)
    (let c5 (fikb-score (eq (ki-witnessable? (fik-u2)) 1) 32))
    ; the organ reads the packaging as love-band (positive spectrum)
    (let c6 (fikb-score (gt (fik-packaging-spectrum) 0.0) 64))
    ; and the closing blessing as love-band too (positive spectrum)
    (let c7 (fikb-score (gt (fik-closing-spectrum) 0.0) 128))
    ; first on the map: a packaging with NO fear-band words at all
    (let c8 (fikb-score (eq (tf-fearfrac (fik-packaging)) 0.0) 256))
    ; between-source: the warmest packaging yet — above Ecstatic Playground's,
    ; and the door still composted half its units. Warmth is not depth.
    (let c9 (fikb-score (gt (fik-packaging-spectrum) (fep-packaging-spectrum)) 512))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9))))))))))
    )
    (frequency-ingest-369-keys-band))
