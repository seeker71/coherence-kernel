; frontier-ingest-memora-band.fk — the Memora ingest sorts every grounded
; finding correctly through the depth×fear law.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/frontier-ingest-memora.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/frontier-ingest-memora.fk \
;          ingest/tests/frontier-ingest-memora-band.fk > /tmp/fim.fk
;      ./fkwu --src /tmp/fim.fk    ; -> 127
;
; Verdict 127 when the ingest is honest.

(do
    (defn fimb-score (ok bit) (if ok bit 0))
    (defn frontier-ingest-memora-band ()
        (do
    ; the convergence unit FREEZES into body (deep + fear-free)
    (let c0 (fimb-score (eq (ki-ingest (fim-u1)) 2) 1))
    ; the what-stored/how-ranked separation the body genuinely holds FREEZES too
    (let c1 (fimb-score (eq (ki-ingest (fim-u2)) 2) 2))
    ; the large retrieval GAP is WITNESSED, never frozen (deep but fearful)
    (let c2 (fimb-score (eq (ki-ingest (fim-u4)) 1) 4))
    ; the false equivalences COMPOST (shallow), never enter
    (let c3 (fimb-score (eq (ki-ingest (fim-u6)) 0) 8))
    ; the rented mind's false alarm COMPOSTS too
    (let c4 (fimb-score (eq (ki-ingest (fim-u7)) 0) 16))
    ; the honest tally: 3 frozen, 2 witnessed, 2 composted
    (let c5 (fimb-score (eq (fim-field-code) 30202) 32))
    ; the uncomfortable reflexive unit is still SEEN (fear blocks ice, not sight)
    (let c6 (fimb-score (eq (ki-witnessable? (fim-u5)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-memora-band))
