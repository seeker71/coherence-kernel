; frontier-ingest-one-layer-band.fk — the "Is One Layer Enough?" ingest sorts
; every grounded finding correctly through the depth×fear law.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/frontier-ingest-one-layer.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/frontier-ingest-one-layer.fk \
;          ingest/tests/frontier-ingest-one-layer-band.fk > /tmp/fio.fk
;      ./fkwu --src /tmp/fio.fk    ; -> 127
;
; Verdict 127 when the ingest is honest.

(do
    (defn fiob-score (ok bit) (if ok bit 0))
    (defn frontier-ingest-one-layer-band ()
        (do
    ; the earned-promotion convergence FREEZES into body (deep + fear-free)
    (let c0 (fiob-score (eq (ki-ingest (fio-u1)) 2) 1))
    ; the compost-became-organ lineage (CTC loss built from the 07-02 pass) FREEZES too
    (let c1 (fiob-score (eq (ki-ingest (fio-u2)) 2) 2))
    ; the skeptic's demotion is honored: the carried moe-router shape is
    ; WITNESSED, never frozen (an organ that cannot fire here is not law here)
    (let c2 (fiob-score (eq (ki-ingest (fio-u3)) 1) 4))
    ; the near-total RL gap is WITNESSED, never frozen (deep but fearful)
    (let c3 (fiob-score (eq (ki-ingest (fio-u4)) 1) 8))
    ; the false equivalences AND the stale-floor reflex COMPOST, never enter
    (let c4 (fiob-score (and (eq (ki-ingest (fio-u6)) 0) (eq (ki-ingest (fio-u7)) 0)) 16))
    ; the honest tally: 2 frozen, 3 witnessed, 2 composted
    (let c5 (fiob-score (eq (fio-field-code) 20302) 32))
    ; the uncomfortable heat-is-not-worth unit is still SEEN (fear blocks ice, not sight)
    (let c6 (fiob-score (eq (ki-witnessable? (fio-u5)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-one-layer-band))
