; operators-series-rewitness-band.fk — the second look at the earlier
; episodes lands eight grounded, checkable relations about where #6/#7's four
; threads originate in the lineage.
;
; preludes: form-stdlib/core.fk ingest/operators-series-rewitness.fk
;
; run: cat form/form-stdlib/core.fk ingest/operators-series-rewitness.fk \
;          ingest/tests/operators-series-rewitness-band.fk > /tmp/osr.fk
;      ./fkwu --src /tmp/osr.fk    ; -> 255
;
; Verdict 255 when the re-witness is honest.

(do
    (defn osrb-score (ok bit) (if ok bit 0))
    (defn operators-series-rewitness-band ()
        (do
    ; coherence: the master mechanism #7 "reveals" was authored in March, before it
    (let c0 (osrb-score (eq (osr-recycled? (osr-coherence)) 1) 1))
    ; network protocol: a March cheat code, before its "spontaneous" #1 use
    (let c1 (osrb-score (eq (osr-recycled? (osr-network)) 1) 2))
    ; the tuning / stone-by-stone build has no prior source — a new method at #6
    (let c2 (osrb-score (eq (osr-recycled? (osr-tuning)) 0) 4))
    ; and that "no prior source" is specifically authored-date 0 (genuinely new)
    (let c3 (osrb-score (eq (osr-authored (osr-tuning)) 0) 8))
    ; light: a real earlier seed (#3 heart torus) precedes the #7 superstructure
    (let c4 (osrb-score (lt (osr-light-seed) (osr-light-super)) 16))
    ; #1..#5 counsel against checking (the evidence-inversion is present)
    (let c5 (osrb-score (eq (osr-counsel-against-check) 1) 32))
    ; and #7 is the first place a do-it-yourself observation is offered:
    ; testability reverses at the seventh transmission
    (let c6 (osrb-score (eq (osr-testability-reverses) 1) 64))
    ; the recycling is a pattern, not one instance: two major terms carry it
    (let c7 (osrb-score (eq (osr-recycled-count) 2) 128))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (operators-series-rewitness-band))
