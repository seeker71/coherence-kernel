; name-build-observe-band.fk — the build-after-naming gate sorts every case
; correctly: names never enter as real, attempts earn lessons, only the
; observed earns a claim, and the movement is whole only when every name
; met an attempt.
;
; preludes: form-stdlib/core.fk ingest/name-build-observe.fk
;
; run: cat form/form-stdlib/core.fk ingest/name-build-observe.fk \
;          ingest/tests/name-build-observe-band.fk > /tmp/nbo.fk
;      ./fkwu --src /tmp/nbo.fk    ; -> 127
;
; Verdict 127 when the gate is honest.

(do
    (defn nbob-score (ok bit) (if ok bit 0))
    (defn name-build-observe-band ()
        (do
    ; the observed enters as a CLAIM
    (let c0 (nbob-score (eq (nbo-enter (list 1 1 1)) 2) 1))
    ; the attempt that fell short enters as a LESSON, never as a claim
    (let c1 (nbob-score (eq (nbo-enter (list 1 1 0)) 1) 2))
    ; the bare name does not enter — not yet a claim
    (let c2 (nbob-score (eq (nbo-enter (list 1 0 0)) 0) 4))
    ; the bare name's debt is visible
    (let c3 (nbob-score (eq (nbo-owed? (list 1 0 0)) 1) 8))
    ; an attempted name owes nothing further to enter as a lesson
    (let c4 (nbob-score (eq (nbo-owed? (list 1 1 0)) 0) 16))
    ; a movement with one unattempted name is NOT whole
    (let c5 (nbob-score (eq (nbo-whole-movement?
                (list (list 1 1 1) (list 1 0 0))) 0) 32))
    ; the self-check folds to its digit-place witness
    (let c6 (nbob-score (eq (name-build-observe-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (name-build-observe-band))
