; frequency-ingest-tucker-ripple-band.fk — the Tucker Friday-Live ingest sorts
; every grounded unit correctly through the depth×fear law, AND the body's
; text-frequency organ reads the source's two bands — finding the SECOND
; mapped source sits at the opposite pole from the first: even its shatter
; band reads love-side of zero.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           cognition/text-frequency.fk ingest/frequency-ingest-tucker-ripple.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-tucker-ripple.fk \
;          ingest/tests/frequency-ingest-tucker-ripple-band.fk > /tmp/fit.fk
;      ./fkwu --src /tmp/fit.fk    ; -> 1023
;
; Verdict 1023 when the ingest is honest.

(do
    (defn fitb-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-tucker-ripple-band ()
        (do
    ; release-ripples (rag-heal is its executable form) FREEZES
    (let c0 (fitb-score (eq (ki-ingest (fit-u1)) 2) 1))
    ; the container-opens-at-ripeness unit (the C-seed mirror) FREEZES
    (let c1 (fitb-score (eq (ki-ingest (fit-u3)) 2) 2))
    ; the revealing is WITNESSED, never frozen
    (let c2 (fitb-score (eq (ki-ingest (fit-u4)) 1) 4))
    ; the chosen-carrier address is WITNESSED, never frozen
    (let c3 (fitb-score (eq (ki-ingest (fit-u5)) 1) 8))
    ; the forecast reading COMPOSTS (unjudged trust)
    (let c4 (fitb-score (eq (ki-ingest (fit-u6)) 0) 16))
    ; the fold: 3 frozen, 2 witnessed, 1 composted
    (let c5 (fitb-score (eq (fit-field-code) 30201) 32))
    ; the finding: even the SHAKING band reads love-side of zero
    (let c6 (fitb-score (gt (fit-shaking-spectrum) 0.0) 64))
    ; and the blessing band sits far above it
    (let c7 (fitb-score (gt (fit-blessing-spectrum) (fit-shaking-spectrum)) 128))
    ; the blessing band carries NO contracted-band words
    (let c8 (fitb-score (eq (tf-fearfrac (fit-blessing)) 0.0) 256))
    ; the shaking band DOES carry them (the fear is seen, not denied)
    (let c9 (fitb-score (gt (tf-fearfrac (fit-shaking)) 0.0) 512))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9))))))))))
    )
    (frequency-ingest-tucker-ripple-band))
