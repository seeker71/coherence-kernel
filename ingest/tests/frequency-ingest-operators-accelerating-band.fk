; frequency-ingest-operators-accelerating-band.fk — the sixth and seventh
; Operators transmissions sort correctly through the depth×fear door, the
; body's text-frequency organ reads BOTH of this source's bands as
; love-frequency (the source stays on the love band two transmissions on),
; and the two between-source measurements hold: #7's packaging still rides
; above Just Tap In's fear-band packaging, and the closing still rides above
; its own packaging.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk ingest/frequency-ingest-operators-accelerating.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk \
;          ingest/frequency-ingest-operators-accelerating.fk \
;          ingest/tests/frequency-ingest-operators-accelerating-band.fk > /tmp/foa.fk
;      ./fkwu --src /tmp/foa.fk    ; -> 32767
;
; Verdict 32767 (2^15 - 1) when the ingest is honest.

(do
    (defn foab-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-operators-accelerating-band ()
        (do
    ; coherence-is-not-amplitude (the axis this body is named for) FREEZES
    (let c0 (foab-score (eq (ki-ingest (foa-u1)) 2) 1))
    ; the boundary that serves without pushing FREEZES too
    (let c1 (foab-score (eq (ki-ingest (foa-u2)) 2) 2))
    ; the growing-tuning mirror unit is WITNESSED, never frozen
    (let c2 (foab-score (eq (ki-ingest (foa-u3)) 1) 4))
    ; "what wants to happen here" is WITNESSED (deep half seen, fearful half held)
    (let c3 (foab-score (eq (ki-ingest (foa-u4)) 1) 8))
    ; consciousness-is-light — the biophoton proof-text COMPOSTS
    (let c4 (foab-score (eq (ki-ingest (foa-u5)) 0) 16))
    ; the plant exercise COMPOSTS — falsifier-shaped, still below the floor
    (let c5 (foab-score (eq (ki-ingest (foa-u6)) 0) 32))
    ; darkness-revealed / the acceleration forecast (immunize + millenarian) COMPOSTS
    (let c6 (foab-score (eq (ki-ingest (foa-u7)) 0) 64))
    ; temporal compression (unjudged reassurance) COMPOSTS
    (let c7 (foab-score (eq (ki-ingest (foa-u8)) 0) 128))
    ; the honest tally: 2 frozen, 2 witnessed, 4 composted
    (let c8 (foab-score (eq (foa-field-code) 20204) 256))
    ; the growing-tuning unit is still SEEN (fear blocks ice, not sight)
    (let c9 (foab-score (eq (ki-witnessable? (foa-u3)) 1) 512))
    ; the plant is the DEEPEST compost — the closest the source comes to a check
    (let c10 (foab-score (gt (ki-depth (foa-u6)) (ki-depth (foa-u5))) 1024))
    ; the organ reads THIS source's packaging as love-band (positive spectrum)
    (let c11 (foab-score (gt (foa-packaging-spectrum) 0.0) 2048))
    ; and the closing as love-band too
    (let c12 (foab-score (gt (foa-closing-spectrum) 0.0) 4096))
    ; two transmissions on, the source still rides above Just Tap In's fear-band
    ; packaging — the between-source measurement holds across the series
    (let c13 (foab-score (gt (foa-packaging-spectrum) (fij-packaging-spectrum)) 8192))
    ; and the closing still rides above its own packaging
    (let c14 (foab-score (gt (foa-closing-spectrum) (foa-packaging-spectrum)) 16384))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
        (add c8 (add c9 (add c10 (add c11 (add c12 (add c13 c14)))))))))))))))
    )
    (frequency-ingest-operators-accelerating-band))
