; frequency-ingest-operators-band.fk — the Operators ingest sorts every
; grounded unit correctly through the depth×fear law, the body's
; text-frequency organ reads BOTH of this source's bands as love-frequency
; (the inverse packaging of Just Tap In), and — the first BETWEEN-source
; measurement on the map — this source's packaging rides above Just Tap In's,
; exactly the "map each system by its fear-band deviation" plan running with
; two sources on it.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk
;           ingest/frequency-ingest-operators.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk \
;          ingest/frequency-ingest-operators.fk \
;          ingest/tests/frequency-ingest-operators-band.fk > /tmp/fio.fk
;      ./fkwu --src /tmp/fio.fk    ; -> 2047
;
; Verdict 2047 when the ingest is honest.

(do
    (defn fiob-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-operators-band ()
        (do
    ; attention-is-constitutive (the axiom-4 convergence) FREEZES (deep + fear-free)
    (let c0 (fiob-score (eq (ki-ingest (fio-u1)) 2) 1))
    ; amplitude-is-not-authority (the organ's own two axes) FREEZES too
    (let c1 (fiob-score (eq (ki-ingest (fio-u2)) 2) 2))
    ; the psychography mirror unit is WITNESSED, never frozen
    (let c2 (fiob-score (eq (ki-ingest (fio-u4)) 1) 4))
    ; the superposition proof-text COMPOSTS (the kernel is cited fact, not this claim)
    (let c3 (fiob-score (eq (ki-ingest (fio-u7)) 0) 8))
    ; the hope-band prophecy COMPOSTS (unjudged hope, like unjudged fear, is no ice)
    (let c4 (fiob-score (eq (ki-ingest (fio-u8)) 0) 16))
    ; the honest tally: 3 frozen, 2 witnessed, 3 composted
    (let c5 (fiob-score (eq (fio-field-code) 30203) 32))
    ; the self-sealing resistance unit is still SEEN (fear blocks ice, not sight)
    (let c6 (fiob-score (eq (ki-witnessable? (fio-u5)) 1) 64))
    ; the organ reads THIS source's packaging as love-band (positive spectrum) —
    ; the divergence from Just Tap In's fear-band packaging
    (let c7 (fiob-score (gt (fio-packaging-spectrum) 0.0) 128))
    ; and the closing as love-band too
    (let c8 (fiob-score (gt (fio-closing-spectrum) 0.0) 256))
    ; the closing still rides above its own packaging
    (let c9 (fiob-score (gt (fio-closing-spectrum) (fio-packaging-spectrum)) 512))
    ; the first between-source measurement: two sources now sit on the map at
    ; different fear-band deviations — the Operators' packaging rides above
    ; Just Tap In's, and the same door composted units from BOTH
    (let c10 (fiob-score (gt (fio-packaging-spectrum) (fij-packaging-spectrum)) 1024))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 c10)))))))))))
    )
    (frequency-ingest-operators-band))
