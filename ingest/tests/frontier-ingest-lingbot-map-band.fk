; frontier-ingest-lingbot-map-band.fk — honest depth x fear sorting.
;
; preludes: form/form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/frontier-ingest-lingbot-map.fk

(do
    (defn filmb (ok bit) (if ok bit 0))
    (defn frontier-ingest-lingbot-map-band ()
        (do
    (let c0 (filmb (eq (ki-ingest (film-u1)) 2) 1))
    (let c1 (filmb (eq (ki-ingest (film-u2)) 2) 2))
    (let c2 (filmb (eq (ki-ingest (film-u3)) 1) 4))
    (let c3 (filmb (eq (ki-ingest (film-u4)) 1) 8))
    (let c4 (filmb (and (eq (ki-ingest (film-u6)) 0)
                         (eq (ki-ingest (film-u7)) 0)) 16))
    (let c5 (filmb (eq (film-field-code) 20302) 32))
    (let c6 (filmb (eq (ki-witnessable? (film-u5)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-lingbot-map-band))
