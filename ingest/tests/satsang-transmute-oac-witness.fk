; satsang-transmute-oac-witness.fk — the transmutation law bound to the REAL acks:
; every arm constructed by control/offer-ack-core.fk, discriminated by oac-kind,
; lands the verdict the law claims. This closes the loop from the modeled tags to
; the kernel's own interned ack cells (axiom-5's actual vocabulary).
;
; SINGLE-WITNESS (fkwu): the proof walkers do not carry `nothing`/the substrate
; ack ops (witnessed 2026-07-04 — all three die on `unbound function "nothing"`),
; so this binding runs on the native kernel only. Named, never hidden; the LAW
; itself crosses four-way in satsang-transmute-band.fk.
;
; preludes: form-stdlib/core.fk control/offer-ack-core.fk ingest/satsang-transmute.fk
;
; run: cat form/form-stdlib/core.fk control/offer-ack-core.fk \
;          ingest/satsang-transmute.fk ingest/tests/satsang-transmute-oac-witness.fk > /tmp/stxw.fk
;      ./fkwu --src /tmp/stxw.fk    ; -> 15
;
; Verdict 15 when the law and the kernel's acks agree on all four arms.

(do
    (defn stxw-score (ok bit) (if ok bit 0))
    (defn satsang-transmute-oac-witness ()
        (add (add (add
            (stxw-score (eq (stx-verdict (oac-kind (oac-nothing))) 1) 1)                        ; real silence -> witnessed
            (stxw-score (eq (stx-verdict (oac-kind (oac-zero))) 0) 2))                          ; real dissent -> composts
            (stxw-score (eq (stx-verdict (oac-kind (oac-one (intern_trivial_int 7)))) 2) 4))    ; real affirmation -> freezes
            (stxw-score (eq (stx-verdict (oac-kind (oac-node (intern_trivial_int 9)))) 3) 8)))  ; real counter-offer -> recurs
    (satsang-transmute-oac-witness))
