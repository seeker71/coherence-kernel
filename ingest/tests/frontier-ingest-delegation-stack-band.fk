; frontier-ingest-delegation-stack-band.fk — the delegation-essay ingest
; sorts every grounded finding correctly through the depth×fear law.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/frontier-ingest-delegation-stack.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/frontier-ingest-delegation-stack.fk \
;          ingest/tests/frontier-ingest-delegation-stack-band.fk > /tmp/fid.fk
;      ./fkwu --src /tmp/fid.fk    ; -> 127
;
; Verdict 127 when the ingest is honest.

(do
    (defn fidb-score (ok bit) (if ok bit 0))
    (defn frontier-ingest-delegation-stack-band ()
        (do
    ; trust-only-past-the-judge FREEZES into body (deep + fear-free)
    (let c0 (fidb-score (eq (ki-ingest (fid-u1)) 2) 1))
    ; postconditions-first (the band convention) FREEZES too
    (let c1 (fidb-score (eq (ki-ingest (fid-u2)) 2) 2))
    ; escalation-at-insufficiency (arrow named: to the oracle) FREEZES too
    (let c2 (fidb-score (eq (ki-ingest (fid-u3)) 2) 4))
    ; the absent delegation layers are WITNESSED, never frozen (deep but fearful)
    (let c3 (fidb-score (eq (ki-ingest (fid-u4)) 1) 8))
    ; the uncontracted-voice seam is WITNESSED and still SEEN (fear blocks ice, not sight)
    (let c4 (fidb-score (and (eq (ki-ingest (fid-u5)) 1) (eq (ki-witnessable? (fid-u5)) 1)) 16))
    ; the false equivalences AND the two-sided relay error COMPOST, never enter
    (let c5 (fidb-score (and (eq (ki-ingest (fid-u6)) 0) (eq (ki-ingest (fid-u7)) 0)) 32))
    ; the honest tally: 3 frozen, 2 witnessed, 2 composted
    (let c6 (fidb-score (eq (fid-field-code) 30202) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-delegation-stack-band))
