; judged-trust-band.fk — trust over fear (judged): every quadrant lands right,
; and the door concords with knowledge-ingest's.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/judged-trust.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/judged-trust.fk ingest/tests/judged-trust-band.fk > /tmp/jt.fk
;      ./fkwu --src /tmp/jt.fk    ; -> 127
;
; Verdict 127 when the gate is honest.

(do
    (defn jtb-score (ok bit) (if ok bit 0))
    (defn judged-trust-band ()
        (do
    ; judged trust FREEZES into body
    (let c0 (jtb-score (eq (jt-verdict (list 1 1)) 2) 1))
    ; judged fear is WITNESSED, never frozen
    (let c1 (jtb-score (eq (jt-verdict (list 0 1)) 1) 2))
    ; unjudged trust (credulity) COMPOSTS
    (let c2 (jtb-score (eq (jt-verdict (list 1 0)) 0) 4))
    ; unjudged fear (the false alarm) COMPOSTS
    (let c3 (jtb-score (eq (jt-verdict (list 0 0)) 0) 8))
    ; trust over fear -- on the far side of the judge only
    (let c4 (jtb-score (gt (jt-verdict (list 1 1)) (jt-verdict (list 0 1))) 16))
    ; before judgment, trust and fear are EQUALS (both compost)
    (let c5 (jtb-score (eq (jt-verdict (list 1 0)) (jt-verdict (list 0 0))) 32))
    ; concord with knowledge-ingest: the two doors agree on all three verdicts
    ; (judged trust = deep fear-free = 2; judged fear = deep fearful = 1;
    ;  unjudged = shallow = 0)
    (let c6 (jtb-score
        (and (eq (jt-verdict (list 1 1)) (ki-ingest (list 5 0)))
        (and (eq (jt-verdict (list 0 1)) (ki-ingest (list 5 1)))
             (eq (jt-verdict (list 1 0)) (ki-ingest (list 1 0))))) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (judged-trust-band))
