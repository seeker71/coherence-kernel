; frequency-ingest-just-tap-in-band.fk — the Just Tap In ingest sorts every
; grounded unit correctly through the depth×fear law, AND the body's
; text-frequency organ separates the source's fear-band packaging from its
; love-band closing. (Also the first band to exercise cognition/
; text-frequency.fk's tf-* functions under --src beyond its own self-check.)
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk \
;          ingest/tests/frequency-ingest-just-tap-in-band.fk > /tmp/fij.fk
;      ./fkwu --src /tmp/fij.fk    ; -> 1023
;
; Verdict 1023 when the ingest is honest.

(do
    (defn fijb-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-just-tap-in-band ()
        (do
    ; the fear-is-not-load-bearing convergence FREEZES (deep + fear-free)
    (let c0 (fijb-score (eq (ki-ingest (fij-u1)) 2) 1))
    ; answers-from-the-questioned-ground (the offer-ack ethic) FREEZES too
    (let c1 (fijb-score (eq (ki-ingest (fij-u3)) 2) 2))
    ; the medium/message frequency split is WITNESSED, never frozen
    (let c2 (fijb-score (eq (ki-ingest (fij-u4)) 1) 4))
    ; the CERN attribution COMPOSTS (the kernel is receipt-fact, not this claim)
    (let c3 (fijb-score (eq (ki-ingest (fij-u7)) 0) 8))
    ; the wrath-band sorting COMPOSTS (unjudged fear is a false alarm)
    (let c4 (fijb-score (eq (ki-ingest (fij-u8)) 0) 16))
    ; the honest tally: 3 frozen, 2 witnessed, 3 composted
    (let c5 (fijb-score (eq (fij-field-code) 30203) 32))
    ; the uncomfortable mirror unit is still SEEN (fear blocks ice, not sight)
    (let c6 (fijb-score (eq (ki-witnessable? (fij-u5)) 1) 64))
    ; the organ reads the packaging as fear-band (negative spectrum)
    (let c7 (fijb-score (lt (fij-packaging-spectrum) 0.0) 128))
    ; and the closing message as love-band (positive spectrum)
    (let c8 (fijb-score (gt (fij-closing-spectrum) 0.0) 256))
    ; one source, two bands: the message rides ABOVE its own packaging —
    ; frequency-alignment separates what the title glues together
    (let c9 (fijb-score (gt (fij-closing-spectrum) (fij-packaging-spectrum)) 512))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9))))))))))
    )
    (frequency-ingest-just-tap-in-band))
