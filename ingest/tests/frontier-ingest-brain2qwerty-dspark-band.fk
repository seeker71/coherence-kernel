; frontier-ingest-brain2qwerty-dspark-band.fk — the frontier ingest sorts
; every grounded finding correctly through the depth×fear law.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           ingest/frontier-ingest-brain2qwerty-dspark.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/frontier-ingest-brain2qwerty-dspark.fk \
;          ingest/tests/frontier-ingest-brain2qwerty-dspark-band.fk > /tmp/fib.fk
;      ./fkwu --src /tmp/fib.fk    ; -> 127
;
; Verdict 127 when the ingest is honest.

(do
    (defn fibb-score (ok bit) (if ok bit 0))
    (defn frontier-ingest-band ()
        (do
    ; the verification-discipline unit FREEZES into body (deep + fear-free)
    (let c0 (fibb-score (eq (ki-ingest (fib-u1)) 2) 1))
    ; the body's own consentful WER-gate offering FREEZES too
    (let c1 (fibb-score (eq (ki-ingest (fib-u2)) 2) 2))
    ; the large capability GAP is WITNESSED, never frozen (deep but fearful)
    (let c2 (fibb-score (eq (ki-ingest (fib-u4)) 1) 4))
    ; the false equivalences COMPOST (shallow), never enter
    (let c3 (fibb-score (eq (ki-ingest (fib-u6)) 0) 8))
    ; the secondary-source errors COMPOST too
    (let c4 (fibb-score (eq (ki-ingest (fib-u7)) 0) 16))
    ; the honest tally: 3 frozen, 2 witnessed, 2 composted
    (let c5 (fibb-score (eq (fib-field-code) 30202) 32))
    ; the fearful-deep gap is still SEEN (fear blocks ice, not sight)
    (let c6 (fibb-score (eq (ki-witnessable? (fib-u4)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-band))
