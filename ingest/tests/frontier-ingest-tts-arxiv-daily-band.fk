; frontier-ingest-tts-arxiv-daily-band.fk — the TTS-arxiv-daily ingest sorts
; every grounded finding correctly through the depth×fear law.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/frontier-ingest-tts-arxiv-daily.fk
;
; run: ./fkwu --src ingest/tests/frontier-ingest-tts-arxiv-daily-band.fk   ; -> 127
;      (resolver-driven; the preludes line above is the live load directive —
;       never cat the units by hand)
;
; Verdict 127 when the ingest is honest.

(do
    (defn fitadb-score (ok bit) (if ok bit 0))
    (defn frontier-ingest-tts-arxiv-daily-band ()
        (do
    ; a stamp certifies the run, not the witness — FREEZES into body
    (let c0 (fitadb-score (eq (ki-ingest (fitad-u1)) 2) 1))
    ; the field's own agreement law (Best-of-N confounded by kin) FREEZES too
    (let c1 (fitadb-score (eq (ki-ingest (fitad-u3)) 2) 2))
    ; the open VOICE seam against a fast field is WITNESSED, never frozen
    (let c2 (fitadb-score (eq (ki-ingest (fitad-u4)) 1) 4))
    ; the true-arithmetic false-meaning trend COMPOSTS, never enters
    (let c3 (fitadb-score (eq (ki-ingest (fitad-u6)) 0) 8))
    ; the vestigial-config-read-as-wiring error COMPOSTS too
    (let c4 (fitadb-score (eq (ki-ingest (fitad-u7)) 0) 16))
    ; the honest tally: 3 frozen, 2 witnessed, 2 composted
    (let c5 (fitadb-score (eq (fitad-field-code) 30202) 32))
    ; the uncomfortable mirror unit is still SEEN (fear blocks ice, not sight)
    (let c6 (fitadb-score (eq (ki-witnessable? (fitad-u5)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-tts-arxiv-daily-band))
