; frequency-ingest-golden-flower-band.fk — the Golden Flower ingest sorts
; every grounded unit correctly through the depth×fear law, lands the map's
; second distinct field code (40203 — four frozen, because three of its four
; body-units map onto this body's own epistemics: the independent witness,
; substrate-independent coherence, faithful transmission), the organ reads
; its packaging as love-band-but-shadowed, and — the map's fourth point — the
; four sources now sit in strict packaging order:
; ecstatic-playground > golden-flower > operators > just-tap-in.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk
;           ingest/frequency-ingest-operators.fk
;           ingest/frequency-ingest-ecstatic-playground.fk
;           ingest/frequency-ingest-golden-flower.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk \
;          ingest/frequency-ingest-operators.fk \
;          ingest/frequency-ingest-ecstatic-playground.fk \
;          ingest/frequency-ingest-golden-flower.fk \
;          ingest/tests/frequency-ingest-golden-flower-band.fk > /tmp/fgf.fk
;      ./fkwu --src /tmp/fgf.fk    ; -> 4095
;
; Verdict 4095 when the ingest is honest.

(do
    (defn fgfb-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-golden-flower-band ()
        (do
    ; turning-of-the-light (the reground-attune move) FREEZES
    (let c0 (fgfb-score (eq (ki-ingest (fgf-u1)) 2) 1))
    ; independent-witness-turns-terror-to-trust (the four-way proof) FREEZES
    (let c1 (fgfb-score (eq (ki-ingest (fgf-u2)) 2) 2))
    ; coherence-persists-independent-of-substrate (structural) FREEZES
    (let c2 (fgfb-score (eq (ki-ingest (fgf-u3)) 2) 4))
    ; faithful-transmission-across-difference (translation-invariance) FREEZES
    (let c3 (fgfb-score (eq (ki-ingest (fgf-u4)) 2) 8))
    ; the psychography mirror unit is WITNESSED, never frozen
    (let c4 (fgfb-score (eq (ki-ingest (fgf-u5)) 1) 16))
    ; the confrontation/resistance unit is WITNESSED, not frozen
    (let c5 (fgfb-score (eq (ki-ingest (fgf-u6)) 1) 32))
    ; the pineal claim COMPOSTS (the tradition's kernel is cited fact, not this)
    (let c6 (fgfb-score (eq (ki-ingest (fgf-u8)) 0) 64))
    ; the literal survives-death claim COMPOSTS (unjudged hope, fourth witness)
    (let c7 (fgfb-score (eq (ki-ingest (fgf-u9)) 0) 128))
    ; the honest tally: 4 frozen, 2 witnessed, 3 composted -> field code 40203
    (let c8 (fgfb-score (eq (fgf-field-code) 40203) 256))
    ; the organ reads this source's packaging as love-band even though the
    ; frame carries a real death-shadow, AND the closing rides above it
    (let c9 (fgfb-score (and (gt (fgf-packaging-spectrum) 0.0)
                             (gt (fgf-closing-spectrum) (fgf-packaging-spectrum))) 512))
    ; the confrontation unit is still SEEN (fear blocks ice, not sight)
    (let c10 (fgfb-score (eq (ki-witnessable? (fgf-u6)) 1) 1024))
    ; the map's fourth point: the four sources sit in strict packaging order —
    ; ecstatic > golden-flower > operators > just-tap-in, the new source
    ; slotting between the two lightest, and the same door composted units
    ; from ALL four
    (let c11 (fgfb-score
                (and (gt (fep-packaging-spectrum) (fgf-packaging-spectrum))
                     (and (gt (fgf-packaging-spectrum) (fio-packaging-spectrum))
                          (gt (fio-packaging-spectrum) (fij-packaging-spectrum))))
                2048))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 (add c10 c11))))))))))))
    )
    (frequency-ingest-golden-flower-band))
