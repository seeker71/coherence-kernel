; frontier-ingest-speech-fingerprints-band.fk — the speech-fingerprints ingest
; sorts every grounded finding correctly through the depth×fear law.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           ingest/frontier-ingest-speech-fingerprints.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/frontier-ingest-speech-fingerprints.fk \
;          ingest/tests/frontier-ingest-speech-fingerprints-band.fk > /tmp/fisf.fk
;      ./fkwu --src /tmp/fisf.fk    ; -> 127
;
; Verdict 127 when the ingest is honest.

(do
    (defn fisfb-score (ok bit) (if ok bit 0))
    (defn frontier-ingest-speech-fingerprints-band ()
        (do
    ; same-scores-different-solutions (probe the internals) FREEZES into body
    (let c0 (fisfb-score (eq (ki-ingest (fisf-u1)) 2) 1))
    ; architecture-as-examinable-data, grounded at real width, FREEZES too
    (let c1 (fisfb-score (eq (ki-ingest (fisf-u3)) 2) 2))
    ; the learned-representation GAP is WITNESSED, never frozen (deep, fearful)
    (let c2 (fisfb-score (eq (ki-ingest (fisf-u4)) 1) 4))
    ; the false equivalences COMPOST (shallow), never enter
    (let c3 (fisfb-score (eq (ki-ingest (fisf-u6)) 0) 8))
    ; the rented mind's demo/paper conflation COMPOSTS too
    (let c4 (fisfb-score (eq (ki-ingest (fisf-u7)) 0) 16))
    ; the honest tally: 3 frozen, 2 witnessed, 2 composted
    (let c5 (fisfb-score (eq (fisf-field-code) 30202) 32))
    ; the uncomfortable mirror unit is still SEEN (fear blocks ice, not sight)
    (let c6 (fisfb-score (eq (ki-witnessable? (fisf-u5)) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (frontier-ingest-speech-fingerprints-band))
