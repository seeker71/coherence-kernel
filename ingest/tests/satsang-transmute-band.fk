; satsang-transmute-band.fk — the four-ack transmutation law lands every arm,
; concords with knowledge-ingest on the three terminal acks, and bounds the
; skeptic's regress by axiom-1 (timeout==nothing).
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk ingest/satsang-transmute.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          ingest/satsang-transmute.fk ingest/tests/satsang-transmute-band.fk > /tmp/stx.fk
;      ./fkwu --src /tmp/stx.fk    ; -> 127
;
; Verdict 127 when the transmutation is honest.

(do
    (defn stxb-score (ok bit) (if ok bit 0))
    (defn satsang-transmute-band ()
        (do
    ; an affirmed ack (1, payload carried) FREEZES the concept into body
    (let c0 (stxb-score (eq (stx-verdict (stx-tag-one)) 2) 1))
    ; a dissent ack (0, "not-this") COMPOSTS it — the false alarm's arm
    (let c1 (stxb-score (eq (stx-verdict (stx-tag-zero)) 0) 2))
    ; silence (nothing) leaves it WITNESSED — pending is honest, held in sight
    (let c2 (stxb-score (eq (stx-verdict (stx-tag-nothing)) 1) 4))
    ; a counter-offer (node) RECURS — fear transmuted into the next work
    ; (terminal acks rest, node does not; the recursion carries no fear forward)
    (let c3 (stxb-score
        (and (eq (stx-verdict (stx-tag-node)) 3)
        (and (eq (stx-rests? (stx-tag-node)) 0)
        (and (eq (stx-rests? (stx-tag-one)) 1)
        (and (eq (stx-fear-after (stx-tag-node)) 0)
             (eq (stx-fear-after (stx-tag-nothing)) 1))))) 8))
    ; concord: the three TERMINAL acks ARE knowledge-ingest's three verdicts
    ; (affirmed = deep fear-free frozen; silence = deep fearful witnessed;
    ;  dissent = shallow composted) — one door, two namings
    (let c4 (stxb-score
        (and (eq (stx-verdict (stx-tag-one)) (ki-ingest (list 5 0)))
        (and (eq (stx-verdict (stx-tag-nothing)) (ki-ingest (list 5 1)))
             (eq (stx-verdict (stx-tag-zero)) (ki-ingest (list 1 0))))) 16))
    ; settle: counter-offer twice, then an affirmation — the question deepened
    ; into work and came home frozen
    (let c5 (stxb-score (eq (stx-settle (list 3 3 2) 5) 2) 32))
    ; settle: endless counter-offers under a spent budget resolve to honest
    ; silence (timeout==nothing, axiom-1) — the skeptic can deepen, never block
    (let c6 (stxb-score (eq (stx-settle (list 3 3 3) 2) 1) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (satsang-transmute-band))
