; frequency-ingest-ecstatic-playground-band.fk — the Ecstatic Playground
; ingest sorts every grounded unit correctly through the depth×fear law,
; lands the map's first distinct field code (40202), and the frequency map
; now holds THREE sources in strict packaging order:
; ecstatic-playground > operators > just-tap-in — the organ's named plan
; ("map each system by its fear-band deviation") literally a map.
;
; preludes: form-stdlib/core.fk ingest/knowledge-ingest.fk
;           cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk
;           ingest/frequency-ingest-operators.fk
;           ingest/frequency-ingest-ecstatic-playground.fk
;
; run: cat form/form-stdlib/core.fk ingest/knowledge-ingest.fk \
;          cognition/text-frequency.fk ingest/frequency-ingest-just-tap-in.fk \
;          ingest/frequency-ingest-operators.fk \
;          ingest/frequency-ingest-ecstatic-playground.fk \
;          ingest/tests/frequency-ingest-ecstatic-playground-band.fk > /tmp/fep.fk
;      ./fkwu --src /tmp/fep.fk    ; -> 65535
;
; Verdict 65535 when the ingest is honest. (First-pass verdict was 4095 over
; 8 units; the 2026-07-06 second pass grew the cell to 16 units and this
; band to 16 checks — same door, deeper read.)

(do
    (defn fepb-score (ok bit) (if ok bit 0))
    (defn frequency-ingest-ecstatic-playground-band ()
        (do
    ; hold-both-perspectives (the paradox invariant, third witness) FREEZES
    (let c0 (fepb-score (eq (ki-ingest (fep-u1)) 2) 1))
    ; pain-witnessed-as-teacher (the verb Just Tap In got wrong) FREEZES
    (let c1 (fepb-score (eq (ki-ingest (fep-u2)) 2) 2))
    ; play (already tissue: value-planes / assemblage-point / field-door) FREEZES
    (let c2 (fepb-score (eq (ki-ingest (fep-u3)) 2) 4))
    ; the book-length mirror unit is WITNESSED, never frozen
    (let c3 (fepb-score (eq (ki-ingest (fep-u5)) 1) 8))
    ; the turbulence-with-a-deadline unit is WITNESSED, not frozen
    (let c4 (fepb-score (eq (ki-ingest (fep-u6)) 1) 16))
    ; the observer-effect borrow COMPOSTS (kernel in as cited fact)
    (let c5 (fepb-score (eq (ki-ingest (fep-u7)) 0) 32))
    ; the soft millenarian stratum COMPOSTS (unjudged hope, third witness)
    (let c6 (fepb-score (eq (ki-ingest (fep-u8)) 0) 64))
    ; the honest tally: 8 frozen, 4 witnessed, 4 composted — the first-pass
    ; proportions (4/2/2) held exactly under a doubled unit count
    (let c7 (fepb-score (eq (fep-field-code) 80404) 128))
    ; the organ reads this source's packaging as love-band even though the
    ; frame CARRIES the author's named descent — candor does not darken it
    (let c8 (fepb-score (gt (fep-packaging-spectrum) 0.0) 256))
    ; the closing rides above its own packaging
    (let c9 (fepb-score (gt (fep-closing-spectrum) (fep-packaging-spectrum)) 512))
    ; the three-source map holds strict order: this source above the Operators
    (let c10 (fepb-score (gt (fep-packaging-spectrum) (fio-packaging-spectrum)) 1024))
    ; and the prior order survives the new witness: Operators above Just Tap In
    (let c11 (fepb-score (gt (fio-packaging-spectrum) (fij-packaging-spectrum)) 2048))
    ; ── second-pass checks (the deeper read) ───────────────────────────────
    ; change-the-past COMPOSTS: the record is never overwritten (axiom-3);
    ; re-point the name, never scrape the vellum
    (let c12 (fepb-score (eq (ki-ingest (fep-u15)) 0) 4096))
    ; the implants vein COMPOSTS: unjudged fear, the same false-alarm arm
    ; that composted Just Tap In's wrath-band — valence-blind both ways
    (let c13 (fepb-score (eq (ki-ingest (fep-u16)) 0) 8192))
    ; the fear-of-boredom unit is WITNESSED (acedia seen, never frozen)
    (let c14 (fepb-score (eq (ki-ingest (fep-u13)) 1) 16384))
    ; the membrane and the dance both FREEZE — the source carrying axiom-4
    ; ("this boat only carries these things") and axiom-5 (nothing submits,
    ; everything acks) in its own words
    (let c15 (fepb-score (and (eq (ki-ingest (fep-u11)) 2) (eq (ki-ingest (fep-u12)) 2)) 32768))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 (add c9 (add c10 (add c11 (add c12 (add c13 (add c14 c15))))))))))))))))
    )
    (frequency-ingest-ecstatic-playground-band))
