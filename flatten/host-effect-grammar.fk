          (host-effect-row "sense_wav_loopback" "host-sense")
          (host-effect-row "mesh_serve" "host-mesh")
          (host-effect-row "mesh_announce" "host-mesh")
          (host-effect-row "mesh_discover" "host-mesh")
          (host-effect-row "mesh_register" "host-mesh")
          (host-effect-row "mesh_detect" "host-mesh")
          (host-effect-row "mesh_registry" "host-mesh")
          (host-effect-row "mesh_roster" "host-mesh")
          (host-effect-row "api_health" "host-api")
          (host-effect-row "native_call_test" "host-native-call")
          (host-effect-row "cuda_matvec" "host-gpu")
          (host-effect-row "cuda_matvec_f32" "host-gpu"))))
(defn host-effect-op? (name)
    (if (nil? (host-effect-find name (host-effect-vocabulary))) 0 1))
(defn host-effect-root-op? (name)
    (if (nil? (host-effect-find name (host-effect-root-vocabulary))) 0 1))
