; host-effect-grammar.fk -- root flattener projection of host-effect grammar.
;
; Source authority: grammars/host-effect-vocabulary.bmf
; Full executable grammar: form/form-stdlib/host-effect-grammar.fk

(defn host-effect-row (name domain)
    (list name domain))
(defn host-effect-name (row)
    (nth row 0))
(defn host-effect-find (name rows)
    (if (nil? rows)
        (empty)
        (if (str_eq (host-effect-name (head rows)) name)
            (head rows)
            (host-effect-find name (tail rows)))))
(defn host-effect-append (a b)
    (if (nil? a) b (cons (head a) (host-effect-append (tail a) b))))
(defn host-effect-vocabulary ()
    (list
          (host-effect-row "read_line" "terminal-input")
          (host-effect-row "print_str" "terminal-output")
          (host-effect-row "record_new" "record-carrier")
          (host-effect-row "host_file_append_bytes" "host-file")
          (host-effect-row "file_append_bytes" "host-file-compat")
          (host-effect-row "host_file_write_text" "host-file")
          (host-effect-row "write_file" "host-file-compat")
          (host-effect-row "write_file_text" "host-file-compat")
          (host-effect-row "host_file_read_text" "host-file")
          (host-effect-row "read_file" "host-file-compat")
          (host-effect-row "host_file_read_slice" "host-file")
          (host-effect-row "read_file_slice" "host-file-compat")
          (host-effect-row "host_file_size" "host-file-metadata")
          (host-effect-row "file_size" "host-file-metadata-compat")
          (host-effect-row "host_file_mtime" "host-file-metadata")
          (host-effect-row "file_mtime" "host-file-metadata-compat")
          (host-effect-row "file_byte_at" "host-file-compat")
          (host-effect-row "host_path_exists" "host-path")
          (host-effect-row "fs_exists" "host-path-compat")
          (host-effect-row "host_path_is_dir" "host-path")
          (host-effect-row "fs_is_dir" "host-path-compat")
          (host-effect-row "host_path_remove" "host-path")
          (host-effect-row "fs_remove" "host-path-compat")
          (host-effect-row "host_path_rename" "host-path")
          (host-effect-row "fs_rename" "host-path-compat")
          (host-effect-row "host_dir_mkdir" "host-directory")
          (host-effect-row "fs_mkdir" "host-directory-compat")
          (host-effect-row "host_dir_rmdir" "host-directory")
          (host-effect-row "fs_rmdir" "host-directory-compat")
          (host-effect-row "host_dir_list" "host-directory")
          (host-effect-row "fs_list" "host-directory-compat")
          (host-effect-row "host_temp_dir" "host-environment")
          (host-effect-row "temp_dir" "host-environment-compat")
          (host-effect-row "host_source_inventory" "host-source-inventory")
          (host-effect-row "source_inventory" "host-source-inventory-compat")
          (host-effect-row "file_open" "host-file-handle")
          (host-effect-row "file_read" "host-file-handle")
          (host-effect-row "file_close" "host-file-handle")
          (host-effect-row "scan_run" "host-scanner")
          (host-effect-row "http_get" "host-network")
          (host-effect-row "sock_request" "host-network")
          (host-effect-row "tls_request" "host-network")
          (host-effect-row "socket_listen" "host-socket")
          (host-effect-row "socket_port" "host-socket")
          (host-effect-row "socket_accept" "host-socket")
          (host-effect-row "socket_connect" "host-socket")
          (host-effect-row "socket_send" "host-socket")
          (host-effect-row "socket_recv" "host-socket")
          (host-effect-row "socket_close" "host-socket")))
(defn host-effect-root-vocabulary ()
    (host-effect-append
        (host-effect-vocabulary)
        (list
          (host-effect-row "host-exec" "host-process")
          (host-effect-row "sense_mic_count" "host-sense")
          (host-effect-row "sense_cam_count" "host-sense")
          (host-effect-row "sense_mic_name" "host-sense")
          (host-effect-row "sense_cam_name" "host-sense")
          (host-effect-row "sense_mic_health" "host-sense")
          (host-effect-row "sense_cam_health" "host-sense")
          (host-effect-row "sense_report" "host-sense")
          (host-effect-row "sense_cam_grab" "host-sense")
          (host-effect-row "sense_frame_read" "host-sense")
          (host-effect-row "sense_stream" "host-sense")
          (host-effect-row "sense_wifi_ssid" "host-sense")
          (host-effect-row "sense_wifi_signal" "host-sense")
          (host-effect-row "sense_bt_present" "host-sense")
          (host-effect-row "sense_bt_count" "host-sense")
          (host-effect-row "sense_power" "host-sense")
          (host-effect-row "sense_mem" "host-sense")
          (host-effect-row "sense_sensors" "host-sense")
