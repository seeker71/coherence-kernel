; gen-source-walker.fk — Form-native splice driver for the source-walker optable.
;
; The ONE op table (name arity tag) is flt-ops in flatten/form-flatten.fk
; (hand-maintained — a native-op-manifest.fk generator was named once but never
; came across). The generator that turns that table into the C
; header runtime/fkwu-optable.h is gen-source-walker-table.fk. fkwu --src is a
; single-file source-runner with no include, so the generator's (flt-ops) call
; needs flt-ops in scope — this recipe performs that splice in pure Form: it
; read_file's both sources, slices the flt-ops defn by str_find/substring (no
; grep/sed/awk), and write_file's a self-contained combined driver. No bash.
;
; Regeneration is two fkwu --src calls, both pure Form, zero shell — run from the
; repo root (the read_file / write_file paths are repo-relative). BOTH calls
; need form-stdlib/core.fk preluded (concatenated ahead of the file, same as any
; other recipe with a "preludes:" line): this script's own str_find/substring
; calls, and the combined driver's, are no longer native ops on a fresh fkwu
; build (retired to Form composition — receipts/2026-07-01-c-seed-shrink-*.md).
; A binary that still carries them natively works with or without the prelude;
; a shrunk one needs it every time, permanently, from here on:
;   cat form-stdlib/core.fk flatten/gen-source-walker.fk > /tmp/gsw1.fk
;   fkwu --src /tmp/gsw1.fk                     ; this recipe -> /tmp/gen-source-walker-combined.fk
;   cat form-stdlib/core.fk /tmp/gen-source-walker-combined.fk > /tmp/gsw2.fk
;   fkwu --src /tmp/gsw2.fk                     ; the generator -> runtime/fkwu-optable.h
; The combined driver's final action is (write_file "runtime/fkwu-optable.h"
; (header)) — the header lands via the host-io op the runtime already carries, so
; the second call's effect IS the regenerated header. The combined driver is a
; throwaway under /tmp, not committed. Adding a value op stays a manifest row ->
; a flt-ops row -> these two calls; NEVER a C edit, NEVER bash.

(do
    (defn ff () (read_file "flatten/form-flatten.fk"))
    ; the flt-ops defn spans from its "(defn flt-ops ()" head to the next
    ; top-level "\n(defn " — the SAME span the old bash awk derived, here as
    ; str_find/substring so adding an op row never silently truncates the table.
    (defn ops-beg () (str_find (ff) "(defn flt-ops ()" 0))
    (defn ops-end () (str_find (ff) (str_concat (byte_to_str 10) "(defn ") (add (ops-beg) 16)))
    (defn ops-defn () (substring (ff) (ops-beg) (ops-end)))

    ; the generator recipe, minus its leading "(do" line — the combined driver
    ; re-opens one (do over flt-ops + the generator body. Anchor the structural
    ; "(do" to a line start ("\n(do") so a "(do" inside the file's prose comments
    ; can never be mistaken for it.
    (defn tbl () (read_file "flatten/gen-source-walker-table.fk"))
    (defn tbl-do () (str_find (tbl) (str_concat (byte_to_str 10) "(do") 0))
    (defn tbl-body () (substring (tbl) (add (tbl-do) 4) (str_len (tbl))))

    (defn combined ()
        (str_concat "(do" (str_concat (byte_to_str 10)
            (str_concat (ops-defn) (str_concat (byte_to_str 10) (tbl-body))))))

    (write_file "/tmp/gen-source-walker-combined.fk" (combined)))
