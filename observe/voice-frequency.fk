; voice-frequency.fk — a mirror for the words a session is writing.
;
; Born from a real drift: specification English (must, gate, REFUSED, law)
; crept into session-authored files one copy at a time, and no correctness
; pass noticed, because correctness passes do not measure voice. This organ
; makes register witnessable the same way everything else here is: counted,
; shown, decided by the writer. It is a mirror, not a fence.
;
; Counting is plain substring, case-folded, and says so: "must" inside
; "mustard" counts. A fuzzy mirror beats an absent one; word boundaries are
; a next stone if the fuzz ever misleads.
;
; The word list lives in teachings/voice-attunement.md's spirit; the note
; and this organ grew together.
;
; witnessed: 2026-07-19 -> 63 live fkwu (observe/tests/voice-frequency-band.fk)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk
(do
  (defn vf-words ()
    (list "law" "must" "gate" "refuse" "enforce" "forbid"
          "strict" "mandatory" "comply" "violation"))

  (defn vf-lower-go (s i n out)
    (if (ge i n) out
      (do (let b (str_byte_at s i))
          (vf-lower-go s (add i 1) n
            (str_concat out (byte_to_str (if (and (ge b 65) (le b 90)) (add b 32) b)))))))
  (defn vf-lower (s) (vf-lower-go s 0 (str_len s) ""))

  (defn vf-count-go (text word from count)
    (do (let at (str_find text word from))
        (if (lt at 0) count
          (vf-count-go text word (add at (str_len word)) (add count 1)))))
  (defn vf-count (text word) (vf-count-go (vf-lower text) word 0 0))

  ; rows of (word count), only the words that appear
  (defn vf-rows-go (words text out)
    (if (eq (len words) 0) (reverse out)
      (do (let c (vf-count text (head words)))
          (vf-rows-go (tail words) text
            (if (eq c 0) out (cons (list (head words) c) out))))))
  (defn vf-rows (text) (vf-rows-go (vf-words) text (empty)))
  (defn vf-total-go (rows total)
    (if (eq (len rows) 0) total
      (vf-total-go (tail rows) (add total (nth (head rows) 1)))))
  (defn vf-total (text) (vf-total-go (vf-rows text) 0))

  (defn vf-cat (xs) (if (eq (len xs) 0) "" (str_concat (head xs) (vf-cat (tail xs)))))
  (defn vf-render-rows (rows out)
    (if (eq (len rows) 0) out
      (vf-render-rows (tail rows)
        (str_concat out (vf-cat (list "  " (nth (head rows) 0) ": "
          (int_to_str (nth (head rows) 1)) "\n"))))))
  (defn vf-mirror (text)
    (do (let rows (vf-rows text))
        (if (eq (len rows) 0) "the mirror shows a clear register\n"
          (vf-cat (list "the mirror shows, the writer decides:\n"
            (vf-render-rows rows ""))))))
  (defn vf-mirror-file (path)
    (do (let raw (read_file path))
        (if (eq (str_len raw) 0) "nothing to mirror at that path\n"
          (vf-mirror raw))))
  0)
