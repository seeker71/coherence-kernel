; door-link-health.fk — the vault door's lint organ. Every markdown link a
; door names is a CLAIM that a cell answers at that path; this organ
; re-witnesses those claims (axiom-4: observation makes a claim real;
; observe/belief-freshness.fk: witness ages, links age with it). Born
; 2026-07-16 alongside SECOND-BRAIN.md — the body's own form of the "lint"
; operation in Karpathy's llm-wiki pattern (gist 442a6bf5..., 2026-04-04):
; where his lint hunts contradictions and orphan pages, this first floor hunts
; BROKEN DOORS — links whose target no cell answers.
;
; Two layers, the native-edit.fk seam split:
;   - scan layer (dlh-skip? / dlh-strip-anchor / dlh-scan): pure string
;     walking on find-from/substring, the body's one string engine —
;     four-way-ABLE, not yet four-way-run (floor named).
;   - door layer (dlh-check-door / dlh-lint / dlh-field-code): fkwu-carrier
;     (read_file), run from the repo root; proven live by receipt
;     (receipts/2026-07-16-second-brain-vault-door.md).
;
; Scope floor (named, next shells): lints the top-level door ring only —
; targets there are repo-root-relative. Nested doors (a receipt linking a
; receipt) need dir-relative path joining; targets inside code fences are
; scanned like any text; ":line" suffixes are not stripped (only "#anchor"s).
;
; skip rule: external ("://", "mailto:"), in-page ("#..."), directory ("--/")
; and empty targets are not checkable path-claims here — in neither column.
;
; fold: doors*10^6 + links*10^3 + broken — injective while links<=999 and
; broken<=999 (the hdc-field-code discipline: positional decimal, digit-wide).
;
; preludes: form-stdlib/core.fk grammars/line-grammar.fk
; witnessed: 2026-07-16 -> self-check 31; door ring 12033000 (12 doors, 33
;   links, 0 broken; was 12028000 before the autopoietic-pulse slice added
;   door links). First run: 12031004 -- the 4 broken were the author's own
;   directory links in SECOND-BRAIN.md; healed the same session.

(do
    ; the door ring — the entry documents whose links this floor re-witnesses
    (defn dlh-doors ()
        (list "AGENTS.md" "BOOTSTRAP.md" "CLAUDE.md" "CONTRIBUTING.md"
              "CURRENT_FLOOR.md" "HOMECOMING.md" "MANIFEST.md" "NORTH_STAR.md"
              "README.md" "RELEASE_HISTORY.md" "SECOND-BRAIN.md" "WELCOME.md"))

    ; ── scan layer (pure strings over find-from/substring) ─────────────────
    (defn dlh-ends-slash? (t)
        (if (eq (str_len t) 0) 0
            (if (str_eq (substring t (sub (str_len t) 1) (str_len t)) "/") 1 0)))
    (defn dlh-skip? (t)
        (if (eq (str_len t) 0) 1
        (if (ge (find-from t "://" 0) 0) 1
        (if (str_eq (substring t 0 1) "#") 1
        (if (eq (find-from t "mailto:" 0) 0) 1
            (dlh-ends-slash? t))))))
    (defn dlh-strip-anchor (t)
        (do
            (let k (find-from t "#" 0))
            (if (lt k 0) t (substring t 0 k))))
    ; a path-claim is answered when a cell answers at that path (a missing
    ; file reads as "" — the same honest read native-edit.fk stands on)
    (defn dlh-exists? (p) (if (gt (str_len (read_file p)) 0) 1 0))

    ; walk `text` from `from`, counting checkable link targets and the broken
    ; among them; returns (list found broken)
    (defn dlh-scan (text from found broken)
        (do
            (let i (find-from text "](" from))
            (if (lt i 0) (list found broken)
                (do
                    (let s (add i 2))
                    (let j (find-from text ")" s))
                    (if (lt j 0) (list found broken)
                        (do
                            (let t (substring text s j))
                            (if (eq (dlh-skip? t) 1)
                                (dlh-scan text (add j 1) found broken)
                                (dlh-scan text (add j 1) (add found 1)
                                    (add broken
                                        (sub 1 (dlh-exists? (dlh-strip-anchor t))))))))))))

    ; ── door layer (fkwu-carrier; run from the repo root) ──────────────────
    (defn dlh-check-door (p) (dlh-scan (read_file p) 0 0 0))
    (defn dlh-lint-loop (ds found broken)
        (if (eq (len ds) 0) (list found broken)
            (do
                (let r (dlh-check-door (head ds)))
                (dlh-lint-loop (tail ds) (add found (head r)) (add broken (nth r 1))))))
    (defn dlh-lint () (dlh-lint-loop (dlh-doors) 0 0))
    (defn dlh-field-code ()
        (do
            (let r (dlh-lint))
            (add (mul (len (dlh-doors)) 1000000)
            (add (mul (head r) 1000) (nth r 1)))))

    ; ── self-check (c3/c5 stand on live root files — fkwu-carrier, honest) ──
    (defn dlhk (ok bit) (if ok bit 0))
    (defn door-link-health-check ()
        (add (dlhk (eq (head (dlh-scan "no links here" 0 0 0)) 0) 1)
        (add (dlhk (eq (head (dlh-scan "[a](https://x.y/) [b](#top) [c](mailto:u@h) [d](docs/)" 0 0 0)) 0) 2)
        (add (dlhk (eq (nth (dlh-scan "[a](README.md)" 0 0 0) 1) 0) 4)
        (add (dlhk (eq (nth (dlh-scan "[a](door-that-never-was.md)" 0 0 0) 1) 1) 8)
             (dlhk (eq (nth (dlh-scan "[a](AGENTS.md#the-honest-seam)" 0 0 0) 1) 0) 16)))))
    0)
