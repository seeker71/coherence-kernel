; lingbot-map-live-acceptance.fk — live, non-synthetic acceptance over upstream
; frame bytes and the released camera-token tensor. Expected: 2047.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk form/form-stdlib/transformer-numerics.fk cognition/transformer-block.fk model/geometric-camera.fk model/lingbot-pytorch-checkpoint.fk model/lingbot-vision-input.fk model/lingbot-gca-runtime.fk model/lingbot-geometry-heads.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk model/lingbot-map-runtime.fk

(do
  (defn lmla-bit (ok bit) (if ok bit 0))

  (defn lingbot-map-live-acceptance ()
    (do
      (let run
        (lmr-run-video-file
          "model/fixtures/lingbot-map/loop-two-frame.mkv"
          "/tmp/lingbot-live-acceptance-%06d.bmp"
          "/tmp/lingbot-live-acceptance-000001.bmp"
          "/tmp/lingbot-live-acceptance-000002.bmp"))
      (let infos (lmr-images run))
      (let weight (lmr-weight run))
      (let vision (lmr-vision run))
      (let attention (lmr-attention run))
      (let geometry (lmr-geometry run))
      (let pose (nth geometry 0))
      (let depths (nth geometry 1))
      (let cloud (lmr-cloud run))
      (let world (lmr-world run))
      (let comparison (lmr-comparison run))
      (sum (list
        (lmla-bit (and (eq (nth (nth infos 0) 0) 16)
                       (eq (nth (nth infos 0) 1) 16)) 1)
        (lmla-bit (and (eq (nth (nth infos 0) 5) 822)
                       (eq (nth (nth infos 1) 5) 822)) 2)
        (lmla-bit (eq (nth weight 0) 1) 4)
        (lmla-bit (and (eq (nth weight 2) 8192)
                       (eq (nth weight 3) 2898498933)) 8)
        (lmla-bit (and (eq (nth vision 0) 2)
                    (and (eq (nth vision 1) 17) (eq (nth vision 2) 4))) 16)
        (lmla-bit (gt (nth attention 2) 0.0) 32)
        (lmla-bit (and (gt (nth attention 3) 0)
                       (eq (len (nth attention 4)) 2)) 64)
        (lmla-bit (gt (abs (nth (gc-r pose) 1)) 0.0) 128)
        (lmla-bit (and (eq (len depths) 64) (gt (nth (head depths) 0) 0.0)) 256)
        (lmla-bit (eq (len cloud) 64) 512)
        (lmla-bit (and (eq (len world) 64)
                       (lt (nth comparison 1) (nth comparison 0))) 1024)))))

  (lingbot-map-live-acceptance))
