; jit-host-handoff.fk - source-byte payload to existing native carrier status.
;
; This is the last Form-side receipt before the actual arbitrary-byte host
; membrane. It composes the hot source -> exact byte pipeline with the existing
; `native_call_test` carrier. It only claims native when the carrier returns the
; expected value; an unavailable carrier deopts to walker, and a mismatch rejects.
;
; preludes: form-stdlib/form-asm-x64.fk observe/jit-runtime-fault.fk observe/form-static-analyzer.fk observe/jit-source-byte-pipeline.fk

(do
    (defn jhh-ok () 1)
    (defn jhh-unavailable () 2)
    (defn jhh-mismatch () 3)

    (defn jhh-sysv-add1-bytes ()
        (list 72 137 248 72 131 192 1 195))

    (defn jhh-status (arg observed)
        (if (eq observed -1)
            (jhh-unavailable)
            (if (eq observed (add arg 1)) (jhh-ok) (jhh-mismatch))))

    (defn jhh-admissible-status? (status)
        (if (eq status (jhh-ok))
            1
            (if (eq status (jhh-unavailable)) 1 0)))

    (defn jhh-complete-status? (status)
        (if (eq status (jhh-ok)) 1 0))

    (defn jhh-source-ready? (plan)
        (if (eq (jsbp-admit? plan) 1)
            (jsbp-eq-list (jsbp-bytes plan) (jhh-sysv-add1-bytes))
            0))

    (defn jhh-action-for-status (plan status guard-ok runtime-ok invalidated parity-ok)
        (if (eq (jhh-source-ready? plan) 1)
            (if (eq status (jhh-ok))
                (jsbp-action plan guard-ok runtime-ok invalidated parity-ok)
                (if (eq status (jhh-unavailable)) (jsbp-deopt) (jsbp-reject)))
            (jsbp-reject)))

    (defn jhh-live-status41 () (jhh-status 41 (native_call_test 41)))
    (defn jhh-live-status99 () (jhh-status 99 (native_call_test 99)))

    (defn jhh-bit (cond bit) (if cond bit 0))
    (defn jit-host-handoff-check ()
        (do
            (let live41 (jhh-live-status41))
            (let live99 (jhh-live-status99))
            (add
                (jhh-bit (eq (jsbp-admit? (jsbp-good-add1)) 1) 1)
                (add
                    (jhh-bit (eq (jhh-source-ready? (jsbp-good-add1)) 1) 2)
                    (add
                        (jhh-bit (eq (jhh-admissible-status? live41) 1) 4)
                        (add
                            (jhh-bit (eq (jhh-admissible-status? live99) 1) 8)
                            (add
                                (jhh-bit (eq (jhh-complete-status? (jhh-ok)) 1) 16)
                                (add
                                    (jhh-bit (eq (jhh-complete-status? (jhh-unavailable)) 0) 32)
                                    (add
                                        (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-unavailable) 1 1 0 1) (jsbp-deopt)) 64)
                                        (add
                                            (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-mismatch) 1 1 0 1) (jsbp-reject)) 128)
                                            (add
                                                (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-ok) 1 1 0 1) (jsbp-native)) 256)
                                                (add
                                                    (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-ok) 0 1 0 1) (jsbp-deopt)) 512)
                                                    (add
                                                        (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-ok) 1 0 0 1) (jsbp-exception-action)) 1024)
                                                        (add
                                                            (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-ok) 1 1 1 1) (jsbp-rewalk)) 2048)
                                                            (add
                                                                (jhh-bit (eq (jhh-action-for-status (jsbp-good-add1) (jhh-ok) 1 1 0 0) (jsbp-deopt)) 4096)
                                                                (add
                                                                    (jhh-bit (eq (jhh-action-for-status (jsbp-good-array) (jhh-ok) 1 1 0 1) (jsbp-reject)) 8192)
                                                                    (add
                                                                        (jhh-bit (eq (jhh-action-for-status (jsbp-cold) (jhh-ok) 1 1 0 1) (jsbp-reject)) 16384)
                                                                        (add
                                                                            (jhh-bit (eq (jhh-action-for-status (jsbp-static-bad) (jhh-ok) 1 1 0 1) (jsbp-reject)) 32768)
                                                                            (add
                                                                                (jhh-bit (eq (jsbp-bytes-preserved? (jsbp-good-add1)) 1) 65536)
                                                                                (add
                                                                                    (jhh-bit (eq (jsbp-byte-list? (jsbp-bytes (jsbp-good-add1))) 1) 131072)
                                                                                    (jhh-bit (eq (jhh-admissible-status? (jhh-mismatch)) 0) 262144))))))))))))))))))))

    0)
