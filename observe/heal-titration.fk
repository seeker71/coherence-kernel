; heal-titration.fk — the j-lens wired into the body's own healing loop:
; surprise -> etiology -> titrated push -> localized verify.
;
; The observe stack already carries each stage as an organ; this cell is the
; SEAM that runs them as one motion, the way the 2026-07-17 live heal
; actually moved (receipts/2026-07-17-jacobian-lens-and-the-cell-shadowing-heal.md):
;
;   1 SURPRISE   (surprise-receipt.fk) — the wound announces itself as
;     prediction-error at the OUTPUT: a band predicted 511, read 287. The
;     loss enters from the output, never the input — backprop-lens.fk's
;     "enter from the output," now lived, not analogized.
;   2 ETIOLOGY   (the word came home in its own corpus row; the receipt
;     2026-07-03 named the practice) — diagnosis is reverse credit
;     assignment over the body's own decision graph. Each theory is one
;     LANE; probing it evaluates one PARTIAL. A refuted theory is a zero
;     partial WITH a receipt (the probe that killed it); a theory nobody
;     probed is an UNKNOWN partial — jacobian-lens.fk's timeout teaching:
;     unknown is never zero. Diagnosis ends honestly only when the credited
;     site is the ONE non-zero partial and no lane was left untried.
;   3 TITRATION  — the heal is a PUSH, and the frame margins say what any
;     push will flip (jl-flips?: flip iff push > margin). The titration
;     window for a UNIFORM push is (wound-margin, min-other-margin]: enough
;     to flip the wound, not enough to flip anything else. When the wound
;     sits ABOVE the body's weakest margin the window is EMPTY — no uniform
;     dose can be safe, and the heal MUST be localized (zero push at every
;     other step). The 2026-07-17 heal was exactly that: one parameter
;     name, zero elsewhere. A rewrite-everything heal is a uniform overdose:
;     it flips steps the wound never touched.
;   4 VERIFY     — a heal is verified when the post-heal trace differs from
;     the pre-heal trace at EXACTLY the wound: divergence count 1, at the
;     credited step. Anything else that moved is a regression the heal
;     smuggled in. (The live sweep: choice-lane 1021, offer-ack 197,
;     invite-dispatch 0 — bit-identical pre/post, divergence set = {wound}.)
;
; The one law the four stages share, stated once: A SAFE HEAL IS A PUSH
; WHOSE PREDICTED DIVERGENCE SET IS EXACTLY THE WOUND. Prediction
; (jl-diverge-pred, before touching anything) and verification
; (ht-diverge-count, after) ask the SAME question on either side of the
; edit — that symmetry is what makes self-healing self-SENSING rather than
; hope.
;
; Honest floor: the probe log here is this session's hand-labeled
; retrospective (correction-reflex.fk's own precedent); the live version
; feeds probes and margins from the running framebuffer.
;
; preludes: form-stdlib/core.fk, form-stdlib/form-ontology-loader.fk, observe/surprise-receipt.fk, observe/thought-framebuffer.fk, observe/jacobian-lens.fk
; Proof: observe/tests/heal-titration-band.fk (fkwu --src, live).

(do
    ;; ── ETIOLOGY: probes as evaluated partials ──────────────────────────
    ;; a probe: (site, partial, receipted) — partial 1 means "this site
    ;; explains the error"; receipted 1 means the evaluation left a witness.
    (defn ht-probe (site partial receipted) (list site partial receipted))
    (defn ht-site      (p) (nth p 0))
    (defn ht-partial   (p) (nth p 1))
    (defn ht-receipted (p) (nth p 2))

    ;; the credited site: index of the first non-zero partial; -1 if none.
    (defn ht-credit-walk (probes i)
        (if (eq (len probes) 0) (sub 0 1)
            (if (eq (ht-partial (head probes)) 0)
                (ht-credit-walk (tail probes) (add i 1))
                i)))
    (defn ht-credited (probes) (ht-credit-walk probes 0))

    ;; how many partials are non-zero (a clean etiology credits exactly one).
    (defn ht-credit-count (probes)
        (if (eq (len probes) 0) 0
            (add (if (eq (ht-partial (head probes)) 0) 0 1)
                 (ht-credit-count (tail probes)))))

    ;; UNKNOWN partials: zero WITHOUT a receipt — never probed, never
    ;; refuted. jacobian-lens's timeout law at the diagnosis layer:
    ;; unknown is not zero, and a diagnosis that stops while unknowns
    ;; remain has timed out, not concluded.
    (defn ht-unknowns (probes)
        (if (eq (len probes) 0) 0
            (add (if (and (eq (ht-partial (head probes)) 0)
                          (eq (ht-receipted (head probes)) 0)) 1 0)
                 (ht-unknowns (tail probes)))))
    (defn ht-concluded? (probes)
        (if (and (eq (ht-credit-count probes) 1) (eq (ht-unknowns probes) 0)) 1 0))

    ;; ── TITRATION: the dose window a trace's margins allow ──────────────
    (defn ht-margins (trace)
        (if (eq (len trace) 0) (empty)
            (cons (fb-margin (head trace)) (ht-margins (tail trace)))))
    (defn ht-min-other-walk (ms i wound best)
        (if (eq (len ms) 0) best
            (ht-min-other-walk (tail ms) (add i 1) wound
                (if (eq i wound) best
                    (if (lt (head ms) best) (head ms) best)))))
    (defn ht-min-other (ms wound) (ht-min-other-walk ms 0 wound 1000000))
    (defn ht-wound-margin-at (ms wound) (nth ms wound))
    ;; a uniform dose exists only when the wound is the body's weakest step.
    (defn ht-uniform-possible? (ms wound)
        (if (lt (ht-wound-margin-at ms wound) (ht-min-other ms wound)) 1 0))

    ;; ── the flip set a push profile causes (jl-flips? per step) ─────────
    (defn ht-flip-count (pushes ms)
        (if (or (eq (len pushes) 0) (eq (len ms) 0)) 0
            (add (jl-flips? (head pushes) (head ms))
                 (ht-flip-count (tail pushes) (tail ms)))))
    (defn ht-flip-at-walk (pushes ms i)
        (if (or (eq (len pushes) 0) (eq (len ms) 0)) (sub 0 1)
            (if (eq (jl-flips? (head pushes) (head ms)) 1) i
                (ht-flip-at-walk (tail pushes) (tail ms) (add i 1)))))
    (defn ht-first-flip (pushes ms) (ht-flip-at-walk pushes ms 0))
    ;; THE LAW: safe <=> the flip set is exactly {wound}.
    (defn ht-safe-heal? (pushes ms wound)
        (if (and (eq (ht-flip-count pushes ms) 1)
                 (eq (ht-first-flip pushes ms) wound)) 1 0))

    ;; ── VERIFY: post-heal divergence set must be exactly {wound} ────────
    (defn ht-diverge-count (a b)
        (if (or (eq (len a) 0) (eq (len b) 0)) 0
            (add (if (eq (fb-token (head a)) (fb-token (head b))) 0 1)
                 (ht-diverge-count (tail a) (tail b)))))
    (defn ht-verified? (pre post wound)
        (if (and (eq (ht-diverge-count pre post) 1)
                 (eq (diverge pre post) wound)) 1 0))

    ;; ── the 2026-07-17 session, seeded as data (the honest floor) ───────
    ;; the wound: the band predicted 511, read 287.
    (defn ht-session-wound () (list 511 287))
    ;; five theories walked, four refuted WITH receipts, one credited.
    (defn ht-session-probes ()
        (list (ht-probe "source-cap"       0 1)
              (ht-probe "byte-threshold"   0 1)
              (ht-probe "comment-position" 0 1)
              (ht-probe "frame-depth"      0 1)
              (ht-probe "name-shadowing"   1 1)))

    0)
