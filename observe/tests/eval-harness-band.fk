; eval-harness-band.fk -- proof of the eval harness on a hand-built closed set.
;
; preludes: form-stdlib/core.fk observe/stt-wer.fk observe/eval-harness.fk
;
; run: cat form/form-stdlib/core.fk observe/stt-wer.fk observe/eval-harness.fk \
;          observe/tests/eval-harness-band.fk > /tmp/eh.fk
;      ./fkwu --src /tmp/eh.fk    ; -> 8  (four-way fkwu/Go/Rust/TS)
;
; Verdict 8 = all eight checks (avg WER 40, accuracy 60, exact 3, multi-token
; WER 25 and not-exact, and the three confusion rows green 1/1, red 2/0, blue 0/1).

(do
    ; =========================================================================
    ; PROOF -- hand-built closed-set example.
    ; Closed set of colors: red / green / blue. 5 single-word pairs.
    ; 3 correct, 2 wrong.
    ;   1. red   -> red    correct  (wer 0)
    ;   2. green -> green  correct  (wer 0)
    ;   3. blue  -> green  WRONG    (wer 100)   truth class = green
    ;   4. red   -> red    correct  (wer 0)
    ;   5. green -> blue   WRONG    (wer 100)   truth class = blue
    ; Expected avg WER  = (0+0+100+0+100)/5 = 40
    ; Expected accuracy = 3/5 = 60
    ; Confusion (by true class, insertion order = green, red, blue):
    ;   green: 1 correct, 1 wrong (pair 2 ok, pair 3 wrong-truth green)
    ;   red  : 2 correct, 0 wrong (pairs 1 & 4)
    ;   blue : 0 correct, 1 wrong (pair 5, truth blue)
    ; =========================================================================
    (let pair1 (list (list "red")   (list "red")))
    (let pair2 (list (list "green") (list "green")))
    (let pair3 (list (list "blue")  (list "green")))
    (let pair4 (list (list "red")   (list "red")))
    (let pair5 (list (list "green") (list "blue")))
    (let pairs (list pair1 pair2 pair3 pair4 pair5))

    (let got-avg (eh-avg-wer pairs))
    (let got-acc (eh-accuracy pairs))
    (let got-exact (eh-exact-count pairs))

    ; multi-token sanity: WER and accuracy legitimately differ here.
    ;   hyp "the quick brown fox" vs truth "the quick brown dog"
    ;   -> 1 substitution over 4 words = 25% WER, but NOT an exact match.
    (let mt (list (list "the" "quick" "brown" "fox")
                  (list "the" "quick" "brown" "dog")))
    (let got-mt-wer (eh-pair-wer mt))
    (let got-mt-exact (eh-exact? mt))

    ; confusion lookups
    (let conf (eh-confusion pairs))
    (let e-green (eh-find-entry "green" conf))
    (let e-red   (eh-find-entry "red"   conf))
    (let e-blue  (eh-find-entry "blue"  conf))

    ; ---- assertions: every check contributes 1 to a running band. 8 total. ----
    (add
        (if (eq got-avg 40) 1 0)                       ; average WER
        (add (if (eq got-acc 60) 1 0)                  ; word accuracy
        (add (if (eq got-exact 3) 1 0)                 ; exact-decode count
        (add (if (eq got-mt-wer 25) 1 0)               ; multi-token WER = 25
        (add (if (eq got-mt-exact 0) 1 0)              ; multi-token NOT exact
        (add (if (and (eq (nth e-green 1) 1) (eq (nth e-green 2) 1)) 1 0)  ; green 1/1
        (add (if (and (eq (nth e-red 1) 2)   (eq (nth e-red 2) 0))   1 0)  ; red   2/0
             (if (and (eq (nth e-blue 1) 0)  (eq (nth e-blue 2) 1))  1 0)  ; blue  0/1
        )))))))
    )
