; preludes: observe/speech-token-stream.fk
;
; speech-token-stream-band -- special tokens plus voice-side metadata.
;
; Verdict 65535:
;   1     identity/provenance tokens exist: <NODE>, <SOURCE>
;   2     route/contract tokens exist: <CHANNEL>, <INTERFACE>
;   4     control tokens exist: <CHOICE>, <FAIL>, <UNDO>, <TIMEOUT>, <CUT>
;   8     evidence tokens exist: <OBSERVE>, <GRADE>, <FEEDBACK>, <REPAIR>, <RECEIPT>
;   16    memory/scope tokens exist: <STATE>, <MEMORY>, <SCOPE>
;   32    voice-side metadata is valid
;   64    transcript words roundtrip through the stream
;   128   confidence is preserved
;   256   warmth/cadence/hesitation are preserved
;   512   excitement/attunement are preserved
;   1024  stream summary counts words and special tokens
;   2048  summary names the stream
;   4096  all token rows carry valid metadata
;   8192  word-token helper emits word tokens
;   16384 append preserves order across special+word segments
;   32768 the extended control family completes: <STOP>, <STORE>, <RESTORE>
;         each appear once and each reads as sts-control? -- choice, cut,
;         fail, stop, undo, store, restore, timeout are now all eight the
;         same recognizer sees, matching control/choice-lane-core.fk

(do
    (defn sts-test-meta () (sts-meta 91 82 73 14 66 88))
    (defn sts-test-words () (list "open" "speech" "flows"))
    (defn sts-test-prefix (m)
        (list
            (sts-node "sample-9101" m)
            (sts-source "macos-local" m)
            (sts-channel "audio" m)
            (sts-interface "open-asr-ctc" m)
            (sts-choice "continue" m)
            (sts-fail "clear" m)
            (sts-undo "none" m)
            (sts-timeout "none" m)
            (sts-cut "none" m)
            (sts-observe "frames" m)
            (sts-grade "wer" m)
            (sts-feedback "oracle" m)
            (sts-repair "none" m)
            (sts-receipt "open-dictation" m)
            (sts-state "speaking" m)
            (sts-memory "short" m)
            (sts-scope "utterance" m)
            (sts-stop "none" m)
            (sts-store "checkpoint-1" m)
            (sts-restore "checkpoint-1" m)))
    (defn sts-test-stream ()
        (do
            (let m (sts-test-meta))
            (sts-append (sts-test-prefix m) (sts-word-tokens (sts-test-words) m))))

    (defn sts-band-score (cond bit) (if cond bit 0))

    (defn speech-token-stream-band ()
        (do
            (let m (sts-test-meta))
            (let stream (sts-test-stream))
            (let summary (sts-summary stream))
            (let first (head stream))
            (let channel (nth stream 2))
            (let choice (nth stream 4))
            (let observe (nth stream 9))
            (let state (nth stream 14))
            (let words (sts-word-tokens (sts-test-words) m))
            (let c0 (sts-band-score (and (sts-identity? first)
                                         (eq (sts-count-tag stream (sts-source-tag)) 1)) 1))
            (let c1 (sts-band-score (and (sts-route? channel)
                                         (eq (sts-count-tag stream (sts-interface-tag)) 1)) 2))
            (let c2 (sts-band-score (and (sts-control? choice)
                                         (and (eq (sts-count-tag stream (sts-undo-tag)) 1)
                                              (and (eq (sts-count-tag stream (sts-timeout-tag)) 1)
                                                   (eq (sts-count-tag stream (sts-cut-tag)) 1)))) 4))
            (let c3 (sts-band-score (and (sts-evidence? observe)
                                         (and (eq (sts-count-tag stream (sts-feedback-tag)) 1)
                                              (and (eq (sts-count-tag stream (sts-repair-tag)) 1)
                                                   (eq (sts-count-tag stream (sts-receipt-tag)) 1)))) 8))
            (let c4 (sts-band-score (and (sts-memory? state)
                                         (and (eq (sts-count-tag stream (sts-memory-tag)) 1)
                                              (eq (sts-count-tag stream (sts-scope-tag)) 1))) 16))
            (let c5 (sts-band-score (eq (sts-meta-valid? m) 1) 32))
            (let c6 (sts-band-score (str_eq (sts-transcript stream) "open speech flows") 64))
            (let c7 (sts-band-score (eq (sts-confidence m) 91) 128))
            (let c8 (sts-band-score (and (eq (sts-warmth m) 82)
                                         (and (eq (sts-cadence m) 73)
                                              (eq (sts-hesitation m) 14))) 256))
            (let c9 (sts-band-score (and (eq (sts-excitement m) 66)
                                         (eq (sts-attunement m) 88)) 512))
            (let c10 (sts-band-score (and (eq (sts-summary-words summary) 3)
                                          (eq (sts-summary-count summary) 23)) 1024))
            (let c11 (sts-band-score (str_eq (sts-summary-kind summary) "speech-token-stream-summary") 2048))
            (let c12 (sts-band-score (eq (sts-summary-meta-valid summary) 1) 4096))
            (let c13 (sts-band-score (and (eq (len words) 3)
                                          (sts-tag? (head words) (sts-word-tag))) 8192))
            (let c14 (sts-band-score (and (sts-tag? (head stream) (sts-node-tag))
                                          (str_eq (sts-transcript stream) "open speech flows")) 16384))
            (let stop-tok (nth stream 17))
            (let store-tok (nth stream 18))
            (let restore-tok (nth stream 19))
            (let c15 (sts-band-score (and (eq (sts-count-tag stream (sts-stop-tag)) 1)
                                          (and (eq (sts-count-tag stream (sts-store-tag)) 1)
                                               (and (eq (sts-count-tag stream (sts-restore-tag)) 1)
                                                    (and (eq (sts-control? stop-tok) 1)
                                                         (and (eq (sts-control? store-tok) 1)
                                                              (eq (sts-control? restore-tok) 1)))))) 32768))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add
                    (add (add c8 c9) (add c10 c11))
                    (add (add c12 c13) (add c14 c15))))))

    (speech-token-stream-band))
