; jit-policy-cache-sweep-band.fk - deopt/cache half of the Form-native JIT policy spine.
; Stays under the current fkwu --src 256-symbol table.
; Run:
;   ( cat observe/jit-decision.fk observe/jit-profile-receipt.fk observe/jit-runtime-fault.fk observe/jit-tier-policy.fk observe/jit-deopt-cache.fk observe/tests/jit-policy-cache-sweep-band.fk ) > /tmp/jpcs.fk
;   ./fkwu --src /tmp/jpcs.fk

(do
    (defn jpcs-bit (cond bit) (if cond bit 0))
    (defn jit-policy-cache-sweep-check ()
        (add
            (jpcs-bit (eq (jit-profile-receipt-check) 127) 1)
            (add
                (jpcs-bit (eq (jit-runtime-fault-check) 255) 2)
                (add
                    (jpcs-bit (eq (jit-tier-policy-check) 1023) 4)
                    (jpcs-bit (eq (jit-deopt-cache-check) 511) 8)))))

    (jit-policy-cache-sweep-check))
