; preludes: observe/stt-wer.fk
;
; stt-tokenize-unicode-band -- transcript tokens keep Unicode evidence alive.
;
; Verdict 4095:
;   1     ASCII punctuation still splits and lowercases
;   2     ASCII token order remains stable
;   4     accented Latin stays inside one word token
;   8     CJK text becomes one token per ideograph
;   16    CJK token content is preserved
;   32    CJK punctuation is a delimiter, not a word
;   64    CJK WER sees one substitution in four characters
;   128   Arabic words stay grouped by spaces
;   256   Arabic token content is preserved
;   512   Arabic punctuation is a delimiter, not a word
;   1024  exact Unicode transcript is accepted at zero WER
;   2048  changed CJK transcript is rejected under a tighter WER ceiling

(do
    (defn stt-tokenize-unicode-band ()
        (do
            (let ascii (sw-tokens "Alle, FRAGEN!"))
            (let latin (sw-tokens "vérité claire"))
            (let cjk (sw-tokens "你好世界。"))
            (let cjk-punct (sw-tokens "你，好！"))
            (let cjk-truth (sw-tokens "你好世界"))
            (let cjk-changed (sw-tokens "你好世人"))
            (let arabic (sw-tokens "سلام، عالم؟"))
            (let arabic-truth (sw-tokens "سلام عالم"))
            (let c0 (if (and (str_eq (head ascii) "alle")
                              (str_eq (nth ascii 1) "fragen")) 1 0))
            (let c1 (if (eq (len ascii) 2) 2 0))
            (let c2 (if (str_eq (head latin) "vérité") 4 0))
            (let c3 (if (eq (len cjk) 4) 8 0))
            (let c4 (if (and (str_eq (head cjk) "你")
                              (str_eq (nth cjk 3) "界")) 16 0))
            (let c5 (if (eq (len cjk-punct) 2) 32 0))
            (let c6 (if (eq (sw-wer cjk-changed cjk-truth) 25) 64 0))
            (let c7 (if (eq (len arabic) 2) 128 0))
            (let c8 (if (and (str_eq (head arabic) "سلام")
                              (str_eq (nth arabic 1) "عالم")) 256 0))
            (let c9 (if (eq (sw-distance arabic arabic-truth) 0) 512 0))
            (let c10 (if (eq (sw-accept? arabic arabic-truth 0) 1) 1024 0))
            (let c11 (if (eq (sw-accept? cjk-changed cjk-truth 20) 0) 2048 0))
            (add
                (add (add c0 c1) (add c2 c3))
                (add (add c4 c5)
                     (add (add c6 c7)
                          (add (add c8 c9) (add c10 c11)))))))
    (stt-tokenize-unicode-band))
