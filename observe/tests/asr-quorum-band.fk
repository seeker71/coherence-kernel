; asr-quorum-band.fk — the ASR quorum gate reads oracle agreement exactly as
; four-way-verdict reads walker agreement: three near-identical transcripts pass
; as QUORUM (0), one wild transcript makes a SPLIT (1), a single oracle is LONE
; (2, the honest floor — never a fake consensus), the consensus is the MEDOID
; (the ensemble's centre, not an average belonging to no one), and the agreement
; value gates correctly on the tolerance.
;
; preludes: form-stdlib/core.fk observe/stt-wer.fk observe/asr-quorum.fk
;
; run: cat form/form-stdlib/core.fk observe/stt-wer.fk observe/asr-quorum.fk \
;          observe/tests/asr-quorum-band.fk > /tmp/aq.fk
;      ./fkwu --src /tmp/aq.fk    ; -> 127
;
; Verdict 127 when the gate is honest.

(do
    (defn aqb-score (ok bit) (if ok bit 0))
    ; walker-portable word-list equality (the minimal Rust walker has no
    ; value_eq) — the same exact-match shape hdc-tokens-eq proves four-way.
    (defn aqb-words-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (str_eq (head a) (head b)) (aqb-words-eq (tail a) (tail b)) 0))
            0))
    (defn asr-quorum-band ()
        (do
    (let tol 40)
    ; three oracles hearing the same utterance, one word apart at most (<= tol)
    (let A (list "the" "cat" "sat" "on" "the" "mat"))
    (let B (list "the" "cat" "sat" "on" "the" "mat"))
    (let C (list "the" "cat" "sat" "on" "a" "mat"))     ; 1/6 = 16% WER vs A/B
    (let agree (list A B C))
    ; a fourth oracle mishearing entirely -> a real divergence (100% WER)
    (let D (list "dogs" "run" "fast" "now" "over" "here"))
    (let split (list A B D))
    ; a single oracle on this host -> LONE, no quorum to be had
    (let lone (list A))

    ; the three-agree ensemble is a QUORUM (verdict 0)
    (let c0 (aqb-score (eq (aq-verdict agree tol) 0) 1))
    ; the one-wild ensemble is a SPLIT (verdict 1) — witness, don't act
    (let c1 (aqb-score (eq (aq-verdict split tol) 1) 2))
    ; the single-oracle ensemble is LONE (verdict 2) — the honest floor
    (let c2 (aqb-score (eq (aq-verdict lone tol) 2) 4))

    ; the MEDOID centres the ensemble: with X the central reading and Y, Z each
    ; one edit off X (but two edits from each other), the medoid is X.
    (let X (list "the" "cat" "sat"))
    (let Y (list "the" "bat" "sat"))                     ; 1 sub vs X
    (let Z (list "the" "cat" "ran"))                     ; 1 sub vs X, 2 vs Y
    (let c3 (aqb-score (eq (aqb-words-eq (aq-medoid (list X Y Z)) X) 1) 8))

    ; all-identical oracles agree perfectly — agreement value is 0
    (let c4 (aqb-score (eq (aq-agreement (list A B)) 0) 16))
    ; the quorum's worst pair sits within tolerance
    (let c5 (aqb-score (le (aq-agreement agree) tol) 32))
    ; the split's worst pair breaks tolerance — the gate sees the divergence
    (let c6 (aqb-score (gt (aq-agreement split) tol) 64))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (asr-quorum-band))
