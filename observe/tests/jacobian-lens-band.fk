; preludes: form-stdlib/core.fk, form-stdlib/form-ontology-loader.fk, control/offer-ack-core.fk, control/choice-lane-core.fk, observe/thought-framebuffer.fk, observe/jacobian-lens.fk
;
; jacobian-lens-band — the j-lens witnessed against thought-framebuffer.fk's
; OWN traces (tfb-trace-a / tfb-trace-b, the proven divergence-at-step-3
; pair) and choice-lane-core.fk's OWN receipts. Verdict 511 when every
; claim lands:
;
;   1    the flip law is strict: push 13 flips margin 12; push 12 (a tie)
;        and push 11 do not
;   2    a UNIFORM push (15) diverges the thought at its HESITATION step —
;        the min-margin frame is the most edit-sensitive moment, and the
;        j-lens finds it without a second run
;   4    zero push -> no divergence (-1), agreeing with the framebuffer's
;        diverge(a, a) = -1
;   8    a LOCALIZED push (0 0 0 60) predicts divergence at step 3 —
;        exactly where the framebuffer OBSERVES trace-b diverge from
;        trace-a; prediction meets observation
;   16   that predicted step is NOT the hesitation step: margin alone
;        cannot predict divergence; it takes margin AND push
;   32   silence is a zero jacobian, but the cut RECEIPT keeps the signal:
;        cut over (silent, five) acks nothing AND names 1 unknown partial
;   64   a real timeout leaves partials UNKNOWN, not zero: budget 2 over
;        (silent, silent, five) times out with 1 lane unreached
;   128  honest exhaustion leaves NO unknown partials: budget 5 over
;        (silent, silent) tried every lane; unknown = 0, and it is not
;        claimed as a timeout
;   256  the nine-word mapping holds at its two poles: nothing ->
;        zero-jacobian, interface -> visible-partials

(do
    ;; offered cells — the same 1-arg recipe shape every oac band uses.
    (defn jlb-silent (args) (oac-nothing))
    (defn jlb-five (args) (oac-one (intern_trivial_int 5)))

    ;; Each claim-group lives in its own SHALLOW defn frame. One deep frame
    ;; holding every let is exactly where the live slot-reservation defect
    ;; bites (receipts/2026-07-01-node-children-last-writer-wins.md: nested
    ;; calls can overwrite a deep frame's locals; the fix closed one
    ;; instance, not the class). Grounded here live: the SAME receipt
    ;; claims read wrong from a deep frame and right from a shallow one —
    ;; so the band keeps every frame shallow, the shape every proven band
    ;; in this repo already survives by.

    ;; the j-lens laws over the framebuffer's own traces (bits 1..16).
    (defn jlb-laws ()
        (do
            (let c1 (if (and (eq (jl-flips? 13 12) 1)
                             (and (eq (jl-flips? 12 12) 0)
                                  (eq (jl-flips? 11 12) 0)))
                        1 0))
            ;; uniform push finds hesitation: trace-a margins (40 12 90 55),
            ;; uniform 15 first exceeds margin at step 1.
            (let c2 (if (eq (jl-diverge-pred (tfb-trace-a) (jl-uniform 4 15))
                            (hesitation (tfb-trace-a))) 2 0))
            ;; zero push -> -1, the framebuffer's own no-change answer.
            (let c3 (if (eq (jl-diverge-pred (tfb-trace-a) (jl-uniform 4 0))
                            (diverge (tfb-trace-a) (tfb-trace-a))) 4 0))
            ;; localized push predicts the OBSERVED divergence step...
            (let c4 (if (eq (jl-diverge-pred (tfb-trace-a) (list 0 0 0 60))
                            (diverge (tfb-trace-a) (tfb-trace-b))) 8 0))
            ;; ...and that step is NOT the hesitation step.
            (let c5 (if (eq (jl-diverge-pred (tfb-trace-a) (list 0 0 0 60))
                            (hesitation (tfb-trace-a))) 0 16))
            (add c1 (add c2 (add c3 (add c4 c5))))))

    ;; silence's zero jacobian and the receipts that make it learnable:
    ;; the cut receipt (bit 32).
    (defn jlb-adjoint-cut ()
        (do
            (let cut1 (oac-cut-with-receipt (list jlb-silent jlb-five) (list)))
            (if (and (eq (oac-nothing? (oac-cut-receipt-ack cut1)) 1)
                     (and (eq (jl-cut-unknown cut1) 1)
                          (eq (jl-silence-grad) 0)))
                32 0)))

    ;; a real timeout leaves partials UNKNOWN (bit 64).
    (defn jlb-adjoint-timeout ()
        (do
            (let w1 (oac-timeout-walk (list jlb-silent jlb-silent jlb-five) (list) 2))
            (if (and (eq (oac-timed-out? w1) 1)
                     (eq (jl-timeout-unknown w1) 1))
                64 0)))

    ;; honest exhaustion leaves NO unknown partials (bit 128).
    (defn jlb-adjoint-exhaust ()
        (do
            (let w2 (oac-timeout-walk (list jlb-silent jlb-silent) (list) 5))
            (if (and (eq (oac-timed-out? w2) 0)
                     (eq (jl-timeout-unknown w2) 0))
                128 0)))

    ;; the nine-word mapping's two poles (bit 256).
    (defn jlb-map ()
        (if (and (eq (str_eq (jl-term "nothing") "zero-jacobian") 1)
                 (eq (str_eq (jl-term "interface") "visible-partials") 1))
            256 0))

    (defn jlb-band ()
        (add (jlb-laws)
        (add (jlb-adjoint-cut)
        (add (jlb-adjoint-timeout)
        (add (jlb-adjoint-exhaust) (jlb-map))))))
    (jlb-band))
