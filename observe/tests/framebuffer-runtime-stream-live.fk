; Cheap live proof that BEGIN/STAGE/END are emitted before the returned result.
; preludes: form/form-stdlib/core.fk observe/framebuffer-runtime-observation.fk

(do
  (let window (fbro-open-stream "stream-live-proof" "Sema" "observes-kernel"
    "see-work-while-it-runs" "trace-before-result" 64
    "observe/tests/framebuffer-runtime-stream-live.fk" 6 3))
  (let before (fbro-snapshot))
  (let result (add 40 2))
  (let after (fbro-snapshot))
  (let stage (fbro-stage-observed-stream "stream-live-proof" "native-add"
    "trace-begin" "Sema" "observes-kernel" "see-work-while-it-runs"
    "trace-before-result" before after "answer" result "completed"
    "observe/tests/framebuffer-runtime-stream-live.fk" 13 3))
  (let report (fbro-close-stream window "completed" 1
    "observe/tests/framebuffer-runtime-stream-live.fk" 15 3))
  (list "framebuffer-runtime-stream-live" result
    (len (fbro-events report)) (fbro-event-number-at
      (fbro-resources report) "dispatches" 0)))
