; audio-fingerprint-band.fk — the four fates are read in PARALLEL, not serial:
; a full window masks 15 (all four present); dropping ONE fate flips only its own
; presence-bit and leaves every OTHER read bit-identical (the independence a
; serial pipeline cannot promise); and a silent window masks 0 without error.
;
; preludes: form-stdlib/core.fk observe/audio-fingerprint.fk
;
; run: cat form/form-stdlib/core.fk observe/audio-fingerprint.fk \
;          observe/tests/audio-fingerprint-band.fk > /tmp/af.fk
;      ./fkwu --src /tmp/af.fk    ; -> 127
;
; Verdict 127 when the fates are genuinely parallel.

(do
    (defn afb-score (ok bit) (if ok bit 0))
    (defn audio-fingerprint-band ()
        (do
    ; one window, all four organs carrying signal (present 1, an integral value)
    (let fp (af-fingerprint (list 1 92) (list 1 7) (list 1 5) (list 1 3)))
    ; the SAME window with the identity organ silent this frame (present 0) —
    ; only the identity input changed; every other input is byte-identical.
    (let fp2 (af-fingerprint (list 1 92) (list 0 7) (list 1 5) (list 1 3)))
    ; a fully silent window — no organ fired
    (let fp0 (af-fingerprint (list 0 0) (list 0 0) (list 0 0) (list 0 0)))

    ; a full fingerprint masks 15 (content|identity|prosody|band)
    (let c0 (afb-score (eq (af-mask fp) 15) 1))
    ; dropping identity masks 13 (15 - 2): only the identity bit fell
    (let c1 (afb-score (eq (af-mask fp2) 13) 2))
    ; INDEPENDENCE: content read is unchanged when identity goes silent
    (let c2 (afb-score (eq (af-read-eq (af-content fp) (af-content fp2)) 1) 4))
    ; INDEPENDENCE: prosody read is unchanged too
    (let c3 (afb-score (eq (af-read-eq (af-prosody fp) (af-prosody fp2)) 1) 8))
    ; INDEPENDENCE: band read is unchanged too — a serial cascade could not
    ; promise any of these once an upstream stage dropped out
    (let c4 (afb-score (eq (af-read-eq (af-band fp) (af-band fp2)) 1) 16))
    ; the identity read is the ONLY one that changed (its presence-bit flipped),
    ; and its value is still carried — the mask says "don't trust", not "erased"
    (let c5 (afb-score (and (eq (af-read-eq (af-identity fp) (af-identity fp2)) 0)
                            (eq (af-value (af-identity fp2)) 7)) 32))
    ; a silent window masks 0 without error — the honest floor, no phantom fate
    (let c6 (afb-score (eq (af-mask fp0) 0) 64))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (audio-fingerprint-band))
