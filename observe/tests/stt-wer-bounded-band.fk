; preludes: observe/stt-wer.fk
;
; stt-wer-bounded-band -- bounded WER for real ASR transcript lengths.
;
; Verdict 2047:
;   1     bounded distance matches recursive distance on tiny rows
;   2     bounded WER matches recursive WER on tiny rows
;   4     insertion/deletion/substitution remain one edit each
;   8     reordered words are still penalized
;   16    long exact sentence returns zero WER
;   32    audio.cpp ASR smoke spoken-reference WER is zero
;   64    numeric written-reference WER is nonzero and must be named
;   128   numeric written-reference is still accepted under a loose ceiling
;   256   bounded accept works on the long spoken sentence
;   512   bounded reject works on a long altered sentence
;   1024  tokenizer keeps the audio.cpp sentence long enough to require bounded WER

(do
    (defn swbb-score (cond bit) (if cond bit 0))
    (defn swbb-truth-small () (list "we" "are" "the" "iris"))
    (defn swbb-sub-small () (list "we" "are" "an" "iris"))
    (defn swbb-del-small () (list "we" "are" "iris"))
    (defn swbb-ins-small () (list "we" "are" "the" "blue" "iris"))
    (defn swbb-reordered-small () (list "are" "we" "the" "iris"))

    (defn swbb-audiocpp-hyp ()
        "Some call me nature, others call me Mother Nature. I've been here for over four point five billion years, twenty-two thousand five hundred times longer than you.")
    (defn swbb-audiocpp-spoken-truth ()
        "Some call me nature. Others call me Mother Nature. I've been here for over four point five billion years. Twenty-two thousand five hundred times longer than you.")
    (defn swbb-audiocpp-written-truth ()
        "Some call me nature. Others call me Mother Nature. I've been here for over 4.5 billion years. Twenty-two thousand five hundred times longer than you.")
    (defn swbb-audiocpp-altered ()
        "Some call me weather. Others call me Mother Nature. I've been here for under four point five billion years. Twenty-two thousand five hundred times shorter than you.")

    (defn stt-wer-bounded-band ()
        (do
            (let tiny-truth (swbb-truth-small))
            (let tiny-sub (swbb-sub-small))
            (let c0 (swbb-score (eq (sw-distance-bounded tiny-sub tiny-truth)
                                    (sw-distance tiny-sub tiny-truth)) 1))
            (let c1 (swbb-score (eq (sw-wer-bounded tiny-sub tiny-truth)
                                    (sw-wer tiny-sub tiny-truth)) 2))
            (let c2 (swbb-score
                        (and (eq (sw-distance-bounded tiny-sub tiny-truth) 1)
                             (and (eq (sw-distance-bounded (swbb-del-small) tiny-truth) 1)
                                  (eq (sw-distance-bounded (swbb-ins-small) tiny-truth) 1))) 4))
            (let c3 (swbb-score (gt (sw-distance-bounded (swbb-reordered-small) tiny-truth) 0) 8))
            (let hyp (sw-tokens (swbb-audiocpp-hyp)))
            (let spoken (sw-tokens (swbb-audiocpp-spoken-truth)))
            (let written (sw-tokens (swbb-audiocpp-written-truth)))
            (let altered (sw-tokens (swbb-audiocpp-altered)))
            (let c4 (swbb-score (eq (sw-wer-bounded spoken spoken) 0) 16))
            (let c5 (swbb-score (eq (sw-wer-bounded hyp spoken) 0) 32))
            (let c6 (swbb-score (gt (sw-wer-bounded hyp written) 0) 64))
            (let c7 (swbb-score (eq (sw-accept-bounded? hyp written 20) 1) 128))
            (let c8 (swbb-score (eq (sw-accept-bounded? hyp spoken 0) 1) 256))
            (let c9 (swbb-score (eq (sw-accept-bounded? altered spoken 0) 0) 512))
            (let c10 (swbb-score (gt (len hyp) 20) 1024))
            (add
                (add
                    (add (add c0 c1) (add c2 c3))
                    (add (add c4 c5) (add c6 c7)))
                (add (add c8 c9) c10))))

    (stt-wer-bounded-band))
