; preludes: observe/stt-agree.fk observe/stt-wer.fk
;
; stt-wer-band -- sequence-aligned STT metric.
;
; Verdict 255:
;   1    exact transcript has distance 0
;   2    one substitution is 25 WER on a four-word truth
;   4    one deletion is one edit
;   8    one insertion is one edit
;   16   reordering is penalized
;   32   exact transcript is accepted under a tight WER ceiling
;   64   substitution is rejected under a tighter WER ceiling
;   128  overlap can miss order, WER catches it

(do
    (defn stt-wer-band ()
        (do
            (let truth (list "we" "are" "the" "iris"))
            (let same (list "we" "are" "the" "iris"))
            (let subbed (list "we" "are" "an" "iris"))
            (let deleted (list "we" "are" "iris"))
            (let inserted (list "we" "are" "the" "blue" "iris"))
            (let reordered (list "are" "we" "the" "iris"))
            (let c0 (if (eq (sw-distance same truth) 0) 1 0))
            (let c1 (if (eq (sw-wer subbed truth) 25) 2 0))
            (let c2 (if (eq (sw-distance deleted truth) 1) 4 0))
            (let c3 (if (eq (sw-distance inserted truth) 1) 8 0))
            (let c4 (if (gt (sw-distance reordered truth) 0) 16 0))
            (let c5 (if (eq (sw-accept? same truth 10) 1) 32 0))
            (let c6 (if (eq (sw-accept? subbed truth 20) 0) 64 0))
            (let c7 (if (and (eq (sa-accuracy reordered truth) 100)
                             (gt (sw-wer reordered truth) 0)) 128 0))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))
    (stt-wer-band))
