; concept-public-reality-world-live-band.fk -- exact public-content union gate.
; expected: 4095
; preludes: form/form-stdlib/core.fk observe/concept-public-reality-world.fk

(do
  (defn cprwb-bit (ok bit) (if ok bit 0))
  (let report (concept-public-reality-world-run))
  (let valid (nth report 1))
  (let sources (nth report 2))
  (let intersections (nth report 3))
  (let union (nth report 4))
  (let examples (nth report 5))
  (add
    (cprwb-bit (value_eq (tail valid) (list 1 1 1)) 1)
    (add (cprwb-bit (eq (nth sources 2) 828) 2)
      (add (cprwb-bit (eq (nth sources 4) 8) 4)
        (add (cprwb-bit (eq (nth sources 6) 24) 8)
          (add (cprwb-bit (gt (nth union 1) 828) 16)
            (add (cprwb-bit (eq (nth union 3) 1) 32)
              (add (cprwb-bit (eq (nth union 5) (nth union 1)) 64)
                (add (cprwb-bit (eq (nth union 7) (nth union 1)) 128)
                  (add (cprwb-bit (eq (nth union 9) 1) 256)
                    (add (cprwb-bit (eq (len (tail examples)) 6) 512)
                      (add (cprwb-bit (gt (nth intersections 8) 0) 1024)
                        (cprwb-bit (eq (nth (nth examples 1) 3) 7) 2048))))))))))))
)
