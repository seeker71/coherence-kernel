; voice-frequency-band.fk — fkwu-witnessed band for observe/voice-frequency.fk.
;
; Bitmask verdict:
;   1   a clear sentence counts zero set-down words
;   2   "we must, we MUST" counts must twice, case-folded
;   4   the fuzz is honest: "mustard" also counts as must (named, not hidden)
;   8   rows carry only the words that appear
;   16  a clear text mirrors as a clear register
;   32  a marked text mirrors with its counts shown
;
; Full verdict: 63
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk observe/voice-frequency.fk
(do
  (defn vfb-bit (ok bit) (if (eq ok 1) bit 0))
  (do
    (let clear "the door opens and the seam is tended with care")
    (let marked "we must, we MUST hold the gate")
    (add (vfb-bit (if (eq (vf-total clear) 0) 1 0) 1)
      (add (vfb-bit (if (eq (vf-count marked "must") 2) 1 0) 2)
        (add (vfb-bit (if (eq (vf-count "mustard seeds" "must") 1) 1 0) 4)
          (add (vfb-bit (if (eq (len (vf-rows marked)) 2) 1 0) 8)
            (add (vfb-bit (if (ge (str_find (vf-mirror clear) "clear register" 0) 0) 1 0) 16)
                 (vfb-bit (if (ge (str_find (vf-mirror marked) "the writer decides" 0) 0) 1 0) 32))))))))
