; concept-10000-13-multimodal-completion-band.fk -- honest incomplete ledger.
; expected: 1023. Overall=0 is a passing truth assertion, not goal completion.
; preludes: form/form-stdlib/core.fk observe/concept-10000-13-multimodal-completion.fk

(do
  (defn cmcb-bit (ok bit) (if ok bit 0))
  (let report (cmc-report))
  (let summary (nth report 1))
  (let rows (nth report 3))
  (let semantic (nth rows 0))
  (let nl-lexical (nth rows 1))
  (let roundtrip (nth rows 2))
  (let human-corpus (nth rows 3))
  (let audio (nth rows 8))
  (let heldout-audio (nth rows 9))
  (let video (nth rows 11))
  (let public-visual (nth rows 13))
  (let pl-generated (nth rows 14))
  (let pl-families (nth rows 15))
  (let arbitrary-pl (nth rows 17))
  (let native-acoustic (nth rows 19))
  (let cross (nth rows 21))
  (add
    (cmcb-bit (eq (len rows) 22) 1)
    (add (cmcb-bit (eq (nth summary 3) 5) 2)
      (add (cmcb-bit (eq (nth summary 7) 0) 4)
        (add (cmcb-bit (eq (cmc-row-complete? semantic) 1) 8)
          (add (cmcb-bit (and (eq (cmc-row-complete? nl-lexical) 1)
                            (eq (cmc-learned-required nl-lexical) 0)) 16)
            (add (cmcb-bit (and (eq (cmc-semantic-observed audio) 26)
                              (and (eq (cmc-addressable audio) 130000)
                                (and (eq (cmc-form-proven audio) 0)
                                     (eq (cmc-learned-required audio) 1)))) 32)
              (add (cmcb-bit (and (eq (cmc-semantic-observed video) 13)
                                (and (eq (cmc-addressable video) 130000)
                                  (eq (cmc-learned-proven video) 0))) 64)
                (add (cmcb-bit (and (eq (cmc-row-complete? roundtrip) 1)
                                  (and (eq (cmc-row-complete? pl-generated) 1)
                                    (and (eq (cmc-row-complete? pl-families) 1)
                                         (eq (cmc-learned-required pl-generated) 0)))) 128)
                  (add (cmcb-bit (and (eq (cmc-semantic-observed cross) 0)
                    (and (eq (cmc-row-complete? cross) 0)
                      (and (eq (cmc-semantic-observed human-corpus) 125165)
                        (and (eq (cmc-semantic-observed heldout-audio) 8)
                          (and (eq (cmc-addressable heldout-audio) 13)
                            (and (eq (cmc-semantic-observed public-visual) 24)
                              (and (eq (cmc-learned-proven public-visual) 0)
                                (and (eq (cmc-semantic-observed arbitrary-pl) 78)
                                  (eq (cmc-addressable arbitrary-pl) 78))))))))) 256)
                       (cmcb-bit (and (eq (cmc-overall? rows) 0)
                         (and (ge (str_find (cmc-evidence native-acoustic)
                               "banana-ne-book" 0) 0)
                           (and (eq (cmc-form-proven native-acoustic) 0)
                                (eq (cmc-learned-proven native-acoustic) 0)))) 512))))))))))
)
