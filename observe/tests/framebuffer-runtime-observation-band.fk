; framebuffer-runtime-observation-band.fk -- exact native trace/cost/world gate.
; expected: 262143
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk form/form-stdlib/world-model.fk observe/framebuffer-runtime-observation.fk observe/framebuffer-runtime-world.fk

(do
  (defn fbrob-bit (ok bit) (if ok bit 0))
  (defn framebuffer-runtime-observation-band ()
    (do
      (let window (fbro-open "real-native-probe" "Sema" "observes-kernel"
        "locate-cost-and-outcome" "user-requested-framebuffer-evidence"
        4096 "observe/tests/framebuffer-runtime-observation-band.fk" 13 7))
      (let stage-before (fbro-snapshot))
      ; A genuine attributed cell fires inside the bounded window.
      (let fired (intern_node_at (bp "PROBE-WORK")
        (list (intern_trivial_string "native-work") (intern_trivial_int 42))
        "observe/tests/framebuffer-runtime-observation-band.fk" 17 9))
      (let float-work (add 1.25 (mul 2.0 3.5)))
      (let stage-after (fbro-snapshot))
      (let stage-event (fbro-stage-observed "real-native-probe" "probe-work"
        "trace-begin" "Sema" "observes-kernel" "locate-cost-and-outcome"
        "user-requested-framebuffer-evidence" stage-before stage-after
        "result-milli" (round (mul float-work 1000.0)) "completed"
        "observe/tests/framebuffer-runtime-observation-band.fk" 22 7))
      (let follow-before (fbro-snapshot))
      (let integer-work (sum (list 1 2 3 4 5)))
      (let follow-after (fbro-snapshot))
      (let follow-event (fbro-stage-observed "real-native-probe" "integer-followup"
        "probe-work" "Sema" "observes-kernel" "locate-cost-and-outcome"
        "user-requested-framebuffer-evidence" follow-before follow-after
        "integer-sum" integer-work "completed"
        "observe/tests/framebuffer-runtime-observation-band.fk" 29 7))
      (let report (fbro-close window "completed" (len (node_children fired))
        "observe/tests/framebuffer-runtime-observation-band.fk" 31 7))
      (let resources (fbro-resources report))
      (let world (fbrw-world report))
      (let float-bottleneck (fbro-bottleneck report "boxed-floats"))
      (sum (list
        (fbrob-bit (str_eq (nth report 0) "framebuffer-runtime-observation") 1)
        (fbrob-bit (str_eq (nth (fbro-what report) 1) "real-native-probe") 2)
        (fbrob-bit (eq (nth (fbro-what report) 3) 5) 4)
        (fbrob-bit (value_eq (nth (fbro-where report) 1)
          (list "observe/tests/framebuffer-runtime-observation-band.fk" 13 7)) 8)
        (fbrob-bit (value_eq (nth (fbro-where report) 2)
          (list "observe/tests/framebuffer-runtime-observation-band.fk" 31 7)) 16)
        (fbrob-bit (str_eq (nth (fbro-with report) 1) "Sema") 32)
        (fbrob-bit (str_eq (nth (fbro-why report) 3)
          "user-requested-framebuffer-evidence") 64)
        (fbrob-bit (gt (nth (fbro-when report) 1) 1700000000000) 128)
        (fbrob-bit (ge (nth (fbro-when report) 5) 0) 256)
        (fbrob-bit (gt (fbrw-resource-number resources "dispatches" 0) 0) 512)
        (fbrob-bit (gt (fbrw-resource-number resources "interned-nodes" 0) 0) 1024)
        (fbrob-bit (ge (fbrw-resource-number resources "arena-cons" 0) 0) 2048)
        (fbrob-bit (eq (fbrw-resource-number resources "input-bytes" 0) 4096) 4096)
        (fbrob-bit (str_eq (nth (fbro-outcome report) 1) "completed") 8192)
        (fbrob-bit (and (eq (len world) 3)
          (and (str_eq (nth (head world) 0) "runtime-event")
            (str_eq (nth (nth world 1) 0) "runtime-stage"))) 16384)
        (fbrob-bit (and (gt (fbro-event-number (nth (fbro-events report) 2)
          "dispatches") 0) (gt (fbro-event-number (nth (fbro-events report) 3)
          "dispatches") 0)) 32768)
        (fbrob-bit (and (gt (nth float-bottleneck 1) 0)
          (str_eq (nth float-bottleneck 2) "probe-work")) 65536)
        (fbrob-bit (eq (fbro-trace-first? report) 1) 131072)))))
  (framebuffer-runtime-observation-band)
)
