; Fast protocol witness. The learning integration band supplies real model data;
; this band checks direction, control, actuation, re-observation, and no-response.
import "../bidirectional-framebuffer-channel.fk"
; witnessed: 2026-07-22 ->
; [nothing,0,1,1001099007,5,[0,4,17,1],0,[0,4,17,1],1001099097,4,1]

(do
  (framebuffer-clear)
  (let harmful (list 2 1 15 4))
  (let grounded (list 0 4 17 1))
  (let first (bfc-round 1 harmful harmful grounded 1001099099))
  (let selected (nth first 2))
  (let second (bfc-round 2 selected selected selected 1001099098))
  (let missing (bfc-envelope 0 3 0 selected 1001099097))
  (list (nothing) 0 1 1001099007
    (bfc-payload (nth first 1)) selected
    (bfc-payload (nth second 1)) (nth second 2)
    (bfc-apply missing (nothing) selected selected)
    (len (framebuffer-events))
    (if (and (eq (bfc-payload (nth first 1)) 5)
      (and (eq (nth selected 1) 4)
      (and (eq (bfc-payload (nth second 1)) 0)
      (and (eq (bfc-apply missing (nothing) selected selected) 1001099097)
           (eq (len (framebuffer-events)) 4))))) 1 0)))
