; Exact f64 process-boundary carrier, including real final-encoder values.
; preludes: form/form-stdlib/core.fk form/form-stdlib/format-arith.fk form/form-stdlib/f64-bytes.fk form/form-stdlib/wire-corba-cdr.fk model/lingbot-pytorch-checkpoint.fk audio/whisper-full-encoder-f64-carrier.fk
(do
  (defn waecb-values ()
    (list 0.0 1.0 -1.0 0.10761033183609459
      -0.44866364155795602 336.77942291693199))
  (defn waecb-string-go (xs out)
    (if (eq (len xs) 0) out
      (waecb-string-go (tail xs)
        (str_concat out (waec-f64-string (head xs))))))
  (defn waecb-read-go (carrier i count out)
    (if (eq i count) (reverse out)
      (waecb-read-go carrier (add i 1) count
        (cons (waec-f64-at carrier (mul i 8)) out))))
  (defn waecb-abs (x) (if (lt x 0.0) (sub 0.0 x) x))
  (defn waecb-distance (a b)
    (if (eq (len a) 0) 0.0
      (add (waecb-abs (sub (head a) (head b)))
        (waecb-distance (tail a) (tail b)))))
  (defn whisper-full-encoder-f64-carrier-check ()
    (do
      (let values (waecb-values))
      (let carrier (waecb-string-go values ""))
      (let readback (waecb-read-go carrier 0 (len values) (empty)))
      (sum (list
        (if (eq (str_len carrier) 48) 1 0)
        (if (eq (waecb-distance values readback) 0.0) 2 0)
        (if (eq (waec-byte-count) 107520) 4 0)
        (if (eq (waec-token-bytes) 3072) 8 0)
        (if (eq (waec-tokens) 35) 16 0)
        (if (eq (waec-width) 384) 32 0)))))
  0)
(whisper-full-encoder-f64-carrier-check)
