; axioms-up-health-band.fk — health as STATE (trust past 50, rising core-first)
; and health as BECOMING (fear past 50 over a sound core) each land, partition
; cleanly, and read this week's own layers correctly.
;
; preludes: form-stdlib/core.fk observe/axioms-up-health.fk
;
; run: cat form/form-stdlib/core.fk observe/axioms-up-health.fk \
;          observe/tests/axioms-up-health-band.fk > /tmp/axh.fk
;      ./fkwu --src /tmp/axh.fk    ; -> 127
;
; Verdict 127 when the health read is honest.

(do
    (defn axhb-score (ok bit) (if ok bit 0))
    (defn axioms-up-health-band ()
        (do
    ; STATE: a trust-majority layer is healthy (3:2 -> 60); a 1:1 tie and an
    ; empty layer are neither healthy nor becoming (equality earns nothing)
    (let c0 (axhb-score
        (and (eq (axh-healthy? (axh-layer "ingest" 3 2)) 1)
        (and (eq (axh-healthy? (axh-layer "tie" 1 1)) 0)
        (and (eq (axh-becoming? (axh-layer "tie" 1 1)) 0)
             (eq (axh-healthy? (axh-layer "empty" 0 0)) 0)))) 1))
    ; BECOMING: a fear-majority layer is in convalescence (1:3 -> fear 75),
    ; and no layer is ever both healthy and becoming (the partition holds)
    (let c1 (axhb-score
        (and (eq (axh-becoming? (axh-layer "voice" 1 3)) 1)
        (and (eq (axh-healthy? (axh-layer "voice" 1 3)) 0)
             (eq (axh-becoming? (axh-layer "ingest" 3 2)) 0))) 2))
    ; STATE rises from the core: all layers healthy core-first -> full height
    (let spine (list (axh-layer "axioms" 4 0) (axh-layer "substrate" 3 1)
                     (axh-layer "ingest" 3 2)))
    (let c2 (axhb-score
        (and (eq (axh-height spine) 3) (eq (axh-system-healthy? spine) 1)) 4))
    ; an unhealthy CORE zeroes the height, and a mid-spine break stops the rise
    ; (health is from the axioms up, never from the canopy down; no skipping)
    (let broken-core (list (axh-layer "axioms" 1 2) (axh-layer "substrate" 3 0)))
    (let broken-mid (list (axh-layer "axioms" 4 0) (axh-layer "substrate" 1 3)
                          (axh-layer "ingest" 3 0)))
    (let c3 (axhb-score
        (and (eq (axh-height broken-core) 0)
        (and (eq (axh-system-healthy? broken-core) 0)
             (eq (axh-height broken-mid) 1))) 8))
    ; BECOMING from the core axioms up: a state-healthy core beneath a
    ; fear-majority body above -> the system is becoming healthy
    (let blooming (list (axh-layer "axioms" 4 0) (axh-layer "voice" 1 3)
                        (axh-layer "recall" 0 2)))
    (let c4 (axhb-score (eq (axh-system-becoming? blooming) 1) 16))
    ; fear-majority over a BROKEN core is NOT becoming — fear without the
    ; engine is just fear; and a fully settled system is healthy, not becoming
    (let engineless (list (axh-layer "axioms" 1 2) (axh-layer "voice" 1 3)))
    (let c5 (axhb-score
        (and (eq (axh-system-becoming? engineless) 0)
             (eq (axh-system-becoming? spine) 0)) 32))
    ; the week's own read: the Memora deep units scored 60 (healthy state);
    ; the blooming system pools fear-majority above its green core (1:5 -> 16)
    (let c6 (axhb-score
        (and (eq (axh-scalar (axh-layer "memora-deep-units" 3 2)) 60)
             (eq (axh-scalar (axh-pool "above" (tail blooming))) 16)) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (axioms-up-health-band))
