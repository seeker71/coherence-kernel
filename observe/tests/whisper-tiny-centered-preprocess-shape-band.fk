; Real WAV centered-reflect + 30s pad semantics and 3000->1500 shape.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/trig.fk form/form-stdlib/mel-frame.fk form/form-stdlib/mel-filterbank.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/whisper-tiny-native-conv1.fk model/whisper-tiny-native-conv2.fk model/whisper-tiny-native-encoder0.fk model/whisper-tiny-native-encoder.fk model/whisper-tiny-native-vocabulary.fk model/whisper-tiny-native-frontend-full.fk model/whisper-tiny-native-affine-row-major.fk model/whisper-tiny-native-frontend-full-row-major.fk audio/whisper-tiny-centered-preprocess.fk
(do
  (defn wapb-abs-sum (xs acc)
    (if (eq (len xs) 0) acc
      (wapb-abs-sum (tail xs) (add acc (abs (head xs))))))
  (defn whisper-tiny-centered-preprocess-shape-check ()
    (do
      (let path "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav")
      (let wav (fs-read-slice path 0 (fs-stat-size path)))
      (let data-offset (wtc-wav-data-offset wav))
      (let samples (wtf-sample-count wav data-offset))
      (let shape (wap-shape-file path))
      (let last-window (wap-window wav data-offset samples 2999))
      (let first-mel (wap-log-mel-col wav data-offset samples 0))
      (let last-mel (wap-log-mel-col wav data-offset samples 2999))
      (sum (list
        (if (eq samples 11392) 1 0)
        (if (eq (wap-padded-samples samples) 491392) 2 0)
        (if (eq (wap-available-mel-frames samples) 3071) 4 0)
        (if (eq (wap-segment-frames samples) 3000) 8 0)
        (if (eq (wap-conv1-tokens 3000) 3000) 16 0)
        (if (eq (wap-conv2-tokens 3000) 1500) 32 0)
        (if (eq (wap-padded-sample wav data-offset samples -1)
                (wtc-wav-sample wav data-offset 1)) 64 0)
        (if (eq (wap-padded-sample wav data-offset samples -200)
                (wtc-wav-sample wav data-offset 200)) 128 0)
        (if (eq (wap-padded-sample wav data-offset samples samples) 0.0) 256 0)
        (if (eq (len last-window) 400) 512 0)
        (if (eq (wapb-abs-sum last-window 0.0) 0.0) 1024 0)
        (if (eq (len first-mel) 80) 2048 0)
        (if (gt (wtc-vector-max-go first-mel -10.0) -10.0) 4096 0)
        (if (eq (wtc-vector-max-go last-mel -10.0) -10.0) 8192 0)
        (if (eq (nth shape 17) 1) 16384 0)
        (if (eq (nth shape 19) 0) 32768 0)))))
  0)
(whisper-tiny-centered-preprocess-shape-check)
