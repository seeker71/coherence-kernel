; preludes: observe/stt-wer.fk presence/formant-vocoder.fk observe/asr-prompt-id.fk
;
; asr-prompt-id-band -- closed-set native ASR over vocoder loopback features.
;
; Verdict 255:
;   1    exact feature match has distance 0
;   2    prompt A is nearest for A-like loopback
;   4    prompt B is nearest for B-like loopback
;   8    A-like loopback is confident by distance and margin
;   16   ambiguous loopback is not confident
;   32   native transcript for A has WER 0 against truth
;   64   wrong transcript has nonzero WER
;   128  local closed-set ASR can be promoted when confidence and WER both pass

(do
    (defn pid-band-score (cond bit) (if cond bit 0))
    (defn pid-band-a-frames () (list (fv-frame 1 4 2 10 100 200 0)))
    (defn pid-band-b-frames () (list (fv-frame 2 6 3 20 200 300 0)))
    (defn pid-band-a-words () (list "we" "are"))
    (defn pid-band-b-words () (list "go" "home"))
    (defn pid-band-candidates ()
        (list
            (pid-candidate 1 (pid-band-a-words) (fv-fingerprint (pid-band-a-frames)))
            (pid-candidate 2 (pid-band-b-words) (fv-fingerprint (pid-band-b-frames)))))
    (defn pid-band-a-query () (list 4 55 1 1))
    (defn pid-band-b-query () (list 6 148 1 2))
    (defn pid-band-amb-query () (list 5 100 1 1))
    (defn pid-band-promote? (q candidates truth)
        (if (and (eq (pid-confident? q candidates 5 80) 1)
                 (le (sw-wer (pid-native-transcript q candidates) truth) 10)) 1 0))

    (defn asr-prompt-id-band ()
        (do
            (let candidates (pid-band-candidates))
            (let c0 (pid-band-score (eq (pid-l1 (fv-fingerprint (pid-band-a-frames))
                                                (fv-fingerprint (pid-band-a-frames))) 0) 1))
            (let c1 (pid-band-score (eq (pid-id (pid-nearest (pid-band-a-query) candidates)) 1) 2))
            (let c2 (pid-band-score (eq (pid-id (pid-nearest (pid-band-b-query) candidates)) 2) 4))
            (let c3 (pid-band-score (eq (pid-confident? (pid-band-a-query) candidates 5 80) 1) 8))
            (let c4 (pid-band-score (eq (pid-confident? (pid-band-amb-query) candidates 5 80) 0) 16))
            (let c5 (pid-band-score (eq (sw-wer (pid-native-transcript (pid-band-a-query) candidates)
                                                 (pid-band-a-words)) 0) 32))
            (let c6 (pid-band-score (gt (sw-wer (pid-native-transcript (pid-band-b-query) candidates)
                                                (pid-band-a-words)) 0) 64))
            (let c7 (pid-band-score (eq (pid-band-promote? (pid-band-a-query) candidates (pid-band-a-words)) 1) 128))
            (add (add (add c0 c1) (add c2 c3))
                 (add (add c4 c5) (add c6 c7)))))
    (asr-prompt-id-band))
