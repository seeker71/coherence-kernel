; src-exit-truth-band.fk -- the exit truth carries every printed error.
;
;   ./fkwu --src observe/tests/src-exit-truth-band.fk        (from repo root)
;
; Expected: 2047
;
; Witnessed 2026-07-17: `./fkwu --src learn/satsang-oracle.fk` (fresh artifacts)
; printed 8 `[unresolved-call] ... error:` lines yet exited 0 with no tally.
; Mechanism: fk_src_try_import_fkb_images speculatively compiles each direct
; dep STANDALONE to build a per-unit image; a unit that resolves only inside
; the root's flat prelude chain (form/form-stdlib/satsang.fk carries no
; "; preludes:" line) diagnosed its unresolved calls loudly there, the image
; was then rejected by the recorded-errors gate, and fk_src_reset_compile_state
; wiped fk_nerr before the authoritative flat compile -- printed errors gone
; from both the tally and the exit code. Same family as the axiom-5 silent-
; lowering law: never stamp+shape.
;
; The healed contract this band holds:
;   - a speculative standalone image compile prints NOTHING (its diagnostics
;     describe a candidate image, not the program);
;   - the import rejection surfaces as ONE counted warning, on every run that
;     recompiles, deterministically;
;   - the gcc-style tally counts exactly the diagnostics that PRINTED
;     (fk_nerr_seen/fk_nwarn_seen, monotone across compile-state resets);
;   - the exit code is nonzero iff an error printed; the .sym lenses agree
;     (dep records its standalone count, root records the flat-compile count).
;
; Fixtures (observe/tests/src-witness/): exit-truth-prov.fk (whole alone),
; exit-truth-dep.fk (INTENTIONALLY not standalone), exit-truth-root-whole.fk
; (flat chain whole), exit-truth-root-broken.fk (INTENTIONALLY unresolved).
; All .fkb/.sym artifacts are gitignored; runs are child fkwu processes via
; host-exec, so this band witnesses the real CLI exit codes.

(do
    (defn xtb-score (ok bit) (if ok bit 0))
    (defn xtb-is (cmd want) (if (str_eq (host-exec cmd) want) 1 0))

    ; bit 1: whole root, fresh compile -> exit 0
    (defn xtb-whole-exit ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-*.fkb observe/tests/src-witness/exit-truth-*.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-whole.fk >/dev/null 2>/dev/null; printf %s $?"
                "0"))
    ; bit 2: whole root, fresh compile -> NO bare \"error:\" lines on stderr
    (defn xtb-whole-no-errors ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-*.fkb observe/tests/src-witness/exit-truth-*.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-whole.fk 2>&1 >/dev/null | grep -c \" error: \" | tr -d \"\\n\""
                "0"))
    ; bit 4: whole root, fresh compile -> exactly ONE not-importable warning
    (defn xtb-whole-one-warning ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-*.fkb observe/tests/src-witness/exit-truth-*.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-whole.fk 2>&1 >/dev/null | grep -c \"not importable standalone\" | tr -d \"\\n\""
                "1"))
    ; bit 8: whole root, fresh compile -> tally names what printed: 0 err, 1 warn
    (defn xtb-whole-tally ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-*.fkb observe/tests/src-witness/exit-truth-*.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-whole.fk 2>&1 >/dev/null | grep -c \"fkwu: 0 error(s), 1 warning(s)\" | tr -d \"\\n\""
                "1"))
    ; bit 16: dep .sym lens records its standalone error count (the import gate's truth)
    (defn xtb-dep-sym ()
        (xtb-is "sed -n 2p observe/tests/src-witness/exit-truth-dep.sym | tr -d \"\\n\""
                "compile-errors 1"))
    ; bit 32: root .sym lens records the flat compile's truth: clean
    (defn xtb-root-sym ()
        (xtb-is "sed -n 2p observe/tests/src-witness/exit-truth-root-whole.sym | tr -d \"\\n\""
                "compile-errors 0"))
    ; bit 64: the rejection warning is DETERMINISTIC -- a recompile run that
    ; finds the dep image cached-with-errors says so again (no first-run-only
    ; messaging)
    (defn xtb-warning-deterministic ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-root-whole.fkb observe/tests/src-witness/exit-truth-root-whole.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-whole.fk 2>&1 >/dev/null | grep -c \"not importable standalone\" | tr -d \"\\n\""
                "1"))
    ; bit 128: broken root, fresh compile -> exit 1
    (defn xtb-broken-exit ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-*.fkb observe/tests/src-witness/exit-truth-*.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-broken.fk >/dev/null 2>/dev/null; printf %s $?"
                "1"))
    ; bit 256: broken root -> the tally carries the printed error AND the warning
    (defn xtb-broken-tally ()
        (xtb-is "rm -f observe/tests/src-witness/exit-truth-*.fkb observe/tests/src-witness/exit-truth-*.sym; ./fkwu --src observe/tests/src-witness/exit-truth-root-broken.fk 2>&1 >/dev/null | grep -c \"fkwu: 1 error(s), 1 warning(s)\" | tr -d \"\\n\""
                "1"))
    ; bit 512: broken root .sym lens records the error
    (defn xtb-broken-sym ()
        (xtb-is "sed -n 2p observe/tests/src-witness/exit-truth-root-broken.sym | tr -d \"\\n\""
                "compile-errors 1"))
    ; bit 1024: broken root rerun off the cached-with-errors image still exits 1
    ; (the cache must not launder recorded errors -- pre-existing door, held)
    (defn xtb-broken-cached-exit ()
        (xtb-is "./fkwu --src observe/tests/src-witness/exit-truth-root-broken.fk >/dev/null 2>/dev/null; printf %s $?"
                "1"))

    (defn src-exit-truth-check ()
        (add (xtb-score (eq (xtb-whole-exit) 1) 1)
        (add (xtb-score (eq (xtb-whole-no-errors) 1) 2)
        (add (xtb-score (eq (xtb-whole-one-warning) 1) 4)
        (add (xtb-score (eq (xtb-whole-tally) 1) 8)
        (add (xtb-score (eq (xtb-dep-sym) 1) 16)
        (add (xtb-score (eq (xtb-root-sym) 1) 32)
        (add (xtb-score (eq (xtb-warning-deterministic) 1) 64)
        (add (xtb-score (eq (xtb-broken-exit) 1) 128)
        (add (xtb-score (eq (xtb-broken-tally) 1) 256)
        (add (xtb-score (eq (xtb-broken-sym) 1) 512)
             (xtb-score (eq (xtb-broken-cached-exit) 1) 1024))))))))))))

    (src-exit-truth-check))
