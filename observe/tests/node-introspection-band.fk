; node-introspection-band.fk — the lamp the penumbra map named as its own
; highest-value next (docs/penumbra-map.md): node_type and node_level were
; dim (used daily, witnessed only through callers), and this week tripped
; over their semantics twice — the phantom "null/6" leaf types that no
; native ever produces, and the bool value-sentinel. This band pins the
; TRUE introspection contract directly, so the next drift fails here with
; its own name on it instead of surfacing as a wire-dialect mystery.
;
; preludes: form-stdlib/core.fk
;
; Verdict 4095 when every assertion holds.

(do
    (defn nib-score (ok bit) (if ok bit 0))
    (defn node-introspection-band ()
        (do
    ; --- node_type: the real leaf-type map (1 int, 2 string, 3 bool, 7 float;
    ;     4 and 6 are produced by NO native constructor — the phantom types) ---
    (let c0 (nib-score (eq (node_type (intern_trivial_int 42)) 1) 1))
    (let c1 (nib-score (eq (node_type (intern_trivial_string "x")) 2) 2))
    (let c2 (nib-score (eq (node_type (intern_trivial_bool true)) 3) 4))
    (let c3 (nib-score (eq (node_type (intern_trivial_float "3.5")) 7) 8))

    ; --- node_level: 1 for every trivial, 0 for a composite, and 0 for a RAW
    ;     literal (the classic trap: a bare 1 is not an interned node at all —
    ;     the false-lead saga of 2026-07-01 burned a day on exactly this) ---
    (let c4 (nib-score (eq (node_level (intern_trivial_int 1)) 1) 16))
    (let c5 (nib-score (eq (node_level (intern_node (bp "NIB") (list (intern_trivial_int 1)))) 0) 32))
    (let c6 (nib-score (eq (node_level 1) 0) 64))

    ; --- node_value: every leaf reads back exactly (bools since 2026-07-02,
    ;     receipts/2026-07-02-bool-node-value-round-trip.md) ---
    (let c7 (nib-score (eq (node_value (intern_trivial_int 42)) 42) 128))
    (let c8 (nib-score (str_eq (node_value (intern_trivial_string "hi")) "hi") 256))
    (let c9 (nib-score (and (eq (node_value (intern_trivial_bool true)) true)
                            (eq (node_value (intern_trivial_bool false)) false)) 512))

    ; --- node_category + node_children: a composite knows its blueprint and
    ;     its children BY IDENTITY (axiom-3), not by copy ---
    (let kid (intern_trivial_int 7))
    (let cell (intern_node (bp "NIB") (list kid)))
    (let c10 (nib-score (eq (node_category cell) (bp "NIB")) 1024))
    (let c11 (nib-score (and (eq (len (node_children cell)) 1)
                             (eq (head (node_children cell)) kid)) 2048))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
        (add c8 (add c9 (add c10 c11))))))))))))
    )
    (node-introspection-band))
