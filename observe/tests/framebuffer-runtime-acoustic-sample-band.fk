; Exact consistency gate for the immutable real-live sample; no heavy rerun.
; expected: 65535
; preludes: form/form-stdlib/core.fk observe/framebuffer-runtime-acoustic-sample.fk

(do
  (defn frasb-bit (ok bit) (if ok bit 0))
  (defn framebuffer-runtime-acoustic-sample-band ()
    (do
      (let s (fbras-live-20260720))
      (let stages (nth s 5))
      (sum (list
        (frasb-bit (str_eq (nth s 0) "framebuffer-runtime-acoustic-sample") 1)
        (frasb-bit (str_eq (nth s 2) "fkwu") 2)
        (frasb-bit (eq (nth s 4) 22828) 4)
        (frasb-bit (eq (len stages) 5) 8)
        (frasb-bit (eq (nth (nth stages 0) 3) 12) 16)
        (frasb-bit (eq (nth (nth stages 1) 3) 39292) 32)
        (frasb-bit (eq (nth (nth stages 2) 3) 45332) 64)
        (frasb-bit (eq (nth (nth stages 3) 3) 20885) 128)
        (frasb-bit (eq (nth (nth stages 4) 3) 0) 256)
        (frasb-bit (eq (nth s 6) 105521) 512)
        (frasb-bit (eq (nth s 7) 19531852595) 1024)
        (frasb-bit (eq (nth s 8) 40) 2048)
        (frasb-bit (eq (nth s 9) 6776) 4096)
        (frasb-bit (eq (nth s 10) 185942) 8192)
        (frasb-bit (eq (nth s 11) 1745915317) 16384)
        (frasb-bit (and (eq (nth s 12) 7280)
          (and (eq (nth s 13) 7) (eq (nth s 15) 50257))) 32768)))))
  (framebuffer-runtime-acoustic-sample-band)
)
