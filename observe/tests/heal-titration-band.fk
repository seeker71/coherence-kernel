; preludes: form-stdlib/core.fk, form-stdlib/form-ontology-loader.fk, observe/surprise-receipt.fk, observe/thought-framebuffer.fk, observe/jacobian-lens.fk, observe/heal-titration.fk
;
; heal-titration-band — the four-stage healing loop (surprise -> etiology ->
; titration -> verify) witnessed on the 2026-07-17 session's own data and on
; thought-framebuffer.fk's proven traces. Verdict 511 when every claim lands:
;
;   1    the wound announces itself as a surprise WITH a receipt:
;        |511 - 287| = 224, over threshold
;   2    etiology concludes: exactly ONE credited partial (name-shadowing,
;        index 4) and ZERO unknowns — every refuted theory carries its
;        receipt; refuted-with-receipt is never confused with untried
;   4    a diagnosis with an unreceipted zero partial does NOT conclude —
;        an unknown partial keeps the etiology open (timeout, not fail)
;   8    titration window, open: with margins (40 12 90 55) and the wound
;        at step 1 (the weakest), a uniform dose 30 is SAFE — it flips the
;        wound and nothing else
;   16   titration window, closed: with the wound at step 2 (margin 90,
;        above the body's weakest 12) NO uniform dose can be safe
;   32   the uniform overdose is named: uniform 100 flips all four steps —
;        flip-count 4, the rewrite-everything heal
;   64   the localized dose heals the closed-window wound: pushes
;        (0 0 100 0) flip exactly step 2 — safe
;   128  verify: a post-heal trace differing from pre-heal at exactly the
;        wound step is VERIFIED (divergence set = {wound})
;   256  a sloppy heal that also moved step 1 is NOT verified — the
;        smuggled regression is seen

(do
    ;; margins (40 12 90 55) — thought-framebuffer's own proven trace.
    (defn htb-ms () (ht-margins (tfb-trace-a)))

    ;; pre-heal trace and two post-heal candidates (tokens differ only).
    (defn htb-pre  () (tfb-trace-a))
    (defn htb-post () (list (fb-frame 0 5 40) (fb-frame 1 8 12) (fb-frame 2 9 90) (fb-frame 3 7 55)))
    (defn htb-sloppy () (list (fb-frame 0 5 40) (fb-frame 1 2 12) (fb-frame 2 9 90) (fb-frame 3 7 55)))

    ;; a probe log with one theory never probed (zero, no receipt).
    (defn htb-open-probes ()
        (list (ht-probe "a" 0 1) (ht-probe "b" 0 0) (ht-probe "c" 1 1)))

    (defn htb-surprise ()
        (if (and (eq (sr-surprise (ht-session-wound)) 224)
                 (eq (sr-receipt? (ht-session-wound)) 1)) 1 0))
    (defn htb-etiology ()
        (if (and (eq (ht-credited (ht-session-probes)) 4)
                 (and (eq (ht-credit-count (ht-session-probes)) 1)
                      (and (eq (ht-unknowns (ht-session-probes)) 0)
                           (eq (ht-concluded? (ht-session-probes)) 1)))) 2 0))
    (defn htb-open ()
        (if (and (eq (ht-unknowns (htb-open-probes)) 1)
                 (eq (ht-concluded? (htb-open-probes)) 0)) 4 0))
    (defn htb-window-open ()
        (if (and (eq (ht-uniform-possible? (htb-ms) 1) 1)
                 (eq (ht-safe-heal? (jl-uniform 4 30) (htb-ms) 1) 1)) 8 0))
    (defn htb-window-closed ()
        (if (eq (ht-uniform-possible? (htb-ms) 2) 0) 16 0))
    (defn htb-overdose ()
        (if (eq (ht-flip-count (jl-uniform 4 100) (htb-ms)) 4) 32 0))
    (defn htb-localized ()
        (if (eq (ht-safe-heal? (list 0 0 100 0) (htb-ms) 2) 1) 64 0))
    (defn htb-verified ()
        (if (eq (ht-verified? (htb-pre) (htb-post) 2) 1) 128 0))
    (defn htb-regression-seen ()
        (if (eq (ht-verified? (htb-pre) (htb-sloppy) 2) 0) 256 0))

    (defn htb-band ()
        (add (htb-surprise)
        (add (htb-etiology)
        (add (htb-open)
        (add (htb-window-open)
        (add (htb-window-closed)
        (add (htb-overdose)
        (add (htb-localized)
        (add (htb-verified) (htb-regression-seen))))))))))
    (htb-band))
