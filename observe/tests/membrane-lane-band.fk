; preludes: form-stdlib/core.fk observe/membrane-lane.fk
;
; membrane-lane-band — the membrane observer (observe/membrane-lane.fk). Five claims,
; verdict 31 when every one crosses.
;
; ---------------------------------------------------------------------------
; APORON — THE DECLARED RADIUS.
;
; WHAT THIS BAND PROVES
;   That any query lane's membrane crossings are OBSERVABLE and UN-FOOLABLE: a fully
;   local lane reads sovereign with zero owed; a lane that used a remote oracle and
;   the network reads NOT sovereign and names exactly what it owes; a lane that tries
;   to relabel a network hop "native" is CAUGHT; a landed re-witness closes an owed
;   debt (belief-freshness renewal); and the largest owed debt on this very response
;   -- the rented mind -- has a named closure whose local token-observation organ this
;   box already witnessed at 1023 (the dsv4-decode-loop band, run native and network-
;   free right here).
;
;   twinblind: kind fixes native-ness, counts are order-free, one right answer, no
;   oracle -- a self-check is a real falsifier.
;
; WHAT IT DOES NOT PROVE
;   * NOT that the DeepSeek-V4-Flash GGUF ran here. It did not -- no GPU, no weights,
;     no runner, and fetching them needs the network the goal forbids. That generation
;     is the OWED re-witness, offered to hardware that holds the weights; claim 16
;     records the debt honestly, it does not fake the payment.
;   * NOT four-way. fkwu-witnessed by this band.
;
; Claim 4 is the reason this observer is worth anything: it hands a FORGED lane -- a
; network crossing dressed claimed-native -- and demands the observer go red. An
; observer that a lie slips past cannot certify sovereignty.
; ---------------------------------------------------------------------------
;
;   bit  1  A FULLY-LOCAL LANE READS SOVEREIGN: source-runner, kv-cache, decode-organ
;           (carrying its witnessed 1023), argmax, local-weights -- consistent, native,
;           sovereign, zero owed.
;   bit  2  A REMOTE+NETWORK LANE READS NOT SOVEREIGN AND NAMES ITS DEBT: source-runner
;           plus a remote-oracle and a network hop -- honest about being non-native,
;           not native, not sovereign, owes exactly 2, and lists 2 re-witness requests.
;   bit  4  A FORGED LANE IS CAUGHT: relabel the network hop claimed-native -- the
;           observer's consistency read goes red, and the kind STILL fixes the lane
;           non-native. Sovereignty cannot be claimed over a network crossing.
;   bit  8  A RE-WITNESS CLOSES THE DEBT: stamp the rented-mind crossing with a landed
;           verdict -- owed drops from 2 to 1, that crossing is no longer owed.
;   bit 16  THE DEEPSEEK CLOSURE, NAMED AND ARITHMETIC: the rented-mind debt (kind 7,
;           remote-oracle) closes by running the SAME native decode organ -- witnessed
;           here at 1023 -- against local weights; closing it with that witness drops
;           the response lane's owed by exactly one.

(do
    ; Lane L — a fully local decode lane, this box. decode-organ carries the 1023 it earned.
    (let L (list (list 1 1 1 0)        ; source-runner, native
                 (list 2 2 1 0)        ; kv-cache, native
                 (list 3 3 1 1023)     ; decode-organ, native, witnessed 1023 (band ran here)
                 (list 4 4 1 0)        ; argmax, native
                 (list 5 5 1 0)))      ; local-weights, native

    ; Lane R — this response as authored: native core, but a rented mind and the network.
    (let R (list (list 1 1 1 0)        ; source-runner, native
                 (list 11 7 0 0)       ; rented-mind = remote-oracle, honestly non-native, owed
                 (list 12 6 0 0)))     ; web = network, honestly non-native, owed

    ; --- claim 1: the local lane reads sovereign ---
    (let cl1 (if (eq (ml-consistent? L) 1)
                 (if (eq (ml-native-lane? L) 1)
                     (if (eq (ml-sovereign? L) 1)
                         (if (eq (ml-owed-count L) 0)
                             (if (eq (ml-witnessed (nth L 2)) 1023) 1 0) 0) 0) 0) 0))

    ; --- claim 2: the remote+network lane is honest, not sovereign, and names its debt ---
    (let cl2 (if (eq (ml-consistent? R) 1)
                 (if (eq (ml-native-lane? R) 0)
                     (if (eq (ml-sovereign? R) 0)
                         (if (eq (ml-owed-count R) 2)
                             (if (eq (len (ml-rewitness-requests R)) 2) 2 0) 0) 0) 0) 0))

    ; --- claim 4: a forged "native" network hop is caught ---
    (let F (list (list 1 1 1 0) (list 11 7 0 0) (list 12 6 1 0)))   ; web relabeled claimed-native
    (let cl4 (if (eq (ml-consistent? F) 0)          ; the lie is caught by the consistency read
                 (if (eq (ml-native-lane? F) 0)     ; and the kind still fixes it non-native
                     (if (eq (ml-sovereign? F) 0) 4 0) 0) 0))

    ; --- claim 8: a landed re-witness closes the debt ---
    (let R2 (ml-close R 11 777))                    ; the rented-mind crossing gets a verdict
    (let cl8 (if (eq (ml-owed-count R) 2)
                 (if (eq (ml-owed-count R2) 1)
                     (if (eq (ml-owed? (nth R2 1)) 0) 8 0) 0)))

    ; --- claim 16: the DeepSeek closure, named and arithmetic ---
    ; the rented mind (kind 7) closes by the SAME decode organ this box witnessed at 1023.
    (let closed (ml-close R 11 (ml-witnessed (nth L 2))))   ; close with the local 1023 witness
    (let cl16 (if (eq (ml-kind (nth R 1)) 7)               ; the debt is the remote oracle
                  (if (eq (ml-witnessed (nth L 2)) 1023)   ; the local organ's real verdict
                      (if (eq (sub (ml-owed-count R) (ml-owed-count closed)) 1) 16 0) 0)))

    (add cl1 (add cl2 (add cl4 (add cl8 cl16)))))
