; Native NL grammar induction, MDL, held-out emission/inverse: expected 33554431.
; preludes: form/form-stdlib/core.fk cognition/nl-grammar-induction-rule.fk cognition/nl-grammar-induction.fk
(do
  (defn ngib-bit (condition value) (if condition value 0))
  (defn nl-grammar-induction-check ()
    (do
      (let pairs (ngi-training-pairs))
      (let grammar (ngi-grammar pairs (ngi-kinds)))
      (let property-record (ngi-grammar-record grammar "property"))
      (let question-record (ngi-grammar-record grammar "question"))
      (let alert-record (ngi-grammar-record grammar "alert"))
      (let property-candidates (nth property-record 2))
      (let question-candidates (nth question-record 2))
      (let alert-candidates (nth alert-record 2))
      (let property-selected (ngi-record-selected property-record))
      (let question-selected (ngi-record-selected question-record))
      (let alert-selected (ngi-record-selected alert-record))
      (let property-memory (ngi-candidate-payload (nth property-candidates 2)))
      (let alert-memory (ngi-candidate-payload (nth alert-candidates 2)))
      (sum (list
        (ngib-bit (eq (len pairs) 9) 1)
        (ngib-bit (eq (len (nth grammar 1)) 3) 2)
        (ngib-bit (eq (ngi-candidate-mdl property-selected) 24) 4)
        (ngib-bit (eq (ngi-candidate-mdl question-selected) 25) 8)
        (ngib-bit (str_eq (ngi-candidate-name property-selected)
          "ordered-slot-rule-forward") 16)
        (ngib-bit (str_eq (ngi-candidate-name question-selected)
          "ordered-slot-rule-forward") 32)
        (ngib-bit (eq (ngi-candidate-coverage property-selected) 3) 64)
        (ngib-bit (eq (ngi-candidate-coverage question-selected) 3) 128)
        (ngib-bit (lt (ngi-candidate-mdl property-selected)
          (ngi-candidate-mdl (nth property-candidates 2))) 256)
        (ngib-bit (lt (ngi-candidate-mdl question-selected)
          (ngi-candidate-mdl (nth question-candidates 2))) 512)
        (ngib-bit (eq (ngi-candidate-reusable? property-selected) 1) 1024)
        (ngib-bit (eq (len (ngi-rule-levels
          (ngi-candidate-payload property-selected))) 3) 2048)
        (ngib-bit (eq (ngi-held-word-seen? pairs "signal") 0) 4096)
        (ngib-bit (eq (ngi-held-word-seen? pairs "grounded") 0) 8192)
        (ngib-bit (str_eq (ngi-grammar-emit grammar (ngi-held-property))
          "the signal is grounded") 16384)
        (ngib-bit (str_eq (ngi-grammar-emit grammar (ngi-held-question))
          "is the signal grounded?") 32768)
        (ngib-bit (str_eq (ngi-grammar-parse grammar "property"
          "the signal is grounded") (ngi-held-property)) 65536)
        (ngib-bit (str_eq (ngi-grammar-parse grammar "question"
          "is the signal grounded?") (ngi-held-question)) 131072)
        (ngib-bit (str_eq (ngi-memory-emit property-memory
          (ngi-held-property)) "") 262144)
        (ngib-bit (str_eq (ngi-memory-emit property-memory
          "property|source|native") "the source is native") 524288)
        (ngib-bit (str_eq (ngi-grammar-emit-seq grammar
          (list (ngi-held-property) (ngi-held-question) (ngi-held-alert)) "; ")
          "the signal is grounded; is the signal grounded?; budget exceeded: framebuffer") 1048576)
        (ngib-bit (str_eq (ngi-candidate-name alert-selected)
          "ordered-slot-rule-reverse") 2097152)
        (ngib-bit (and (eq (ngi-candidate-mdl alert-selected) 15)
          (eq (ngi-memory-mdl alert-memory) 149)) 4194304)
        (ngib-bit (and (eq (ngi-candidate-coverage alert-selected) 3)
          (eq (ngi-candidate-reusable? alert-selected) 1)) 8388608)
        (ngib-bit (and
          (str_eq (ngi-grammar-emit grammar (ngi-held-alert))
            "budget exceeded: framebuffer")
          (and (str_eq (ngi-grammar-parse grammar "alert"
              "budget exceeded: framebuffer") (ngi-held-alert))
            (str_eq (ngi-memory-emit alert-memory (ngi-held-alert)) "")))
          16777216)))))
  0)
(nl-grammar-induction-check)
