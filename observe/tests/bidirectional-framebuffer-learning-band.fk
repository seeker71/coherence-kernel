; Real adaptation observations drive a two-round framebuffer control exchange.
import "../../learn/nl-meaning-error-adaptation.fk"
import "../bidirectional-framebuffer-channel.fk"
; witnessed: 2026-07-22 ->
; [nothing,0,1,1001099006,4,[2,1,15,4],5,[0,4,17,1],
;  0,[0,4,17,1],1001099097,4,1]

(do
  (let observed (nmea-observation-witness))
  (let error-only-transitions (nth observed 5))
  (let rehearsal-transitions (nth observed 6))
  (let frames-before (len (framebuffer-events)))
  ; Regressions exceed recoveries, so round 1 returns rehearse-ground and the
  ; actuator selects the measured rehearsal state.
  (let round1 (bfc-round 1 error-only-transitions
    error-only-transitions rehearsal-transitions 1001099099))
  (let selected1 (nth round1 2))
  ; The selected state is re-observed. Zero regressions returns continue.
  (let round2 (bfc-round 2 selected1 selected1 selected1 1001099098))
  (let selected2 (nth round2 2))
  ; No inbound response resolves to an explicit alternative node.
  (let missing-out (bfc-envelope 0 3 0 selected2 1001099097))
  (let missing-result (bfc-apply missing-out (nothing) selected2 selected2))
  (let frames-after (len (framebuffer-events)))
  (list (nothing) 0 1 1001099006 frames-before
    error-only-transitions (bfc-payload (nth round1 1)) selected1
    (bfc-payload (nth round2 1)) selected2 missing-result
    (sub frames-after frames-before)
    (if (and (eq (bfc-payload (nth round1 1)) 5)
      (and (eq (nth selected1 0) 0)
      (and (eq (nth selected1 1) 4)
      (and (eq (bfc-payload (nth round2 1)) 0)
      (and (eq missing-result 1001099097)
           (eq (sub frames-after frames-before) 4)))))) 1 0)))
