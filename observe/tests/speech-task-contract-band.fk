; import "observe/speech-task-contract.fk"
;
; speech-task-contract-band -- audio.cpp-style speech requests in Form.
;
; Verdict 2047:
;   1     ASR/TTS/VAD/diarization/conversion are named task ops
;   2     unknown ops are rejected
;   4     task validity requires typed op plus source/channel identity
;   8     result validity requires a valid task and valid voice-side metadata
;   16    result stream carries source/channel/interface route tokens
;   32    result stream roundtrips transcript words
;   64    result stream carries artifact count as observation evidence
;   128   result stream carries status as grade evidence
;   256   result stream carries task id as receipt evidence
;   512   artifact time bounds and confidence are observable
;   1024  controls remain task data, not prompt text

(do
  (defn stcb-score (cond bit) (if cond bit 0))
  (defn stcb-meta () (sts-meta 92 70 64 8 55 81))
  (defn stcb-task ()
    (stc-task "task-17" "asr" "audio.cpp-teacher" "mic" "wav-ref-9" "en" "pcm16-normalized" (list "no-send" "local-only")))
  (defn stcb-result ()
    (stc-result
      (stcb-task)
      "ok"
      (list (stc-artifact "segment" "seg-1" 10 40 91)
            (stc-artifact "tokens" "tok-1" 10 40 88))
      (list "speech" "lands")
      (stcb-meta)))

  (defn speech-task-contract-band ()
    (do
      (let t (stcb-task))
      (let r (stcb-result))
      (let stream (stc-result-stream r))
      (let a (head (stc-result-artifacts r)))
      (let c0 (stcb-score (and (eq (stc-op-allowed? "asr") 1)
                               (and (eq (stc-op-allowed? "tts") 1)
                                    (and (eq (stc-op-allowed? "vad") 1)
                                         (and (eq (stc-op-allowed? "diarization") 1)
                                              (eq (stc-op-allowed? "conversion") 1))))) 1))
      (let c1 (stcb-score (eq (stc-op-allowed? "guess") 0) 2))
      (let c2 (stcb-score (eq (stc-task-valid? t) 1) 4))
      (let c3 (stcb-score (eq (stc-result-valid? r) 1) 8))
      (let c4 (stcb-score (and (eq (sts-count-tag stream (sts-source-tag)) 1)
                               (and (eq (sts-count-tag stream (sts-channel-tag)) 1)
                                    (eq (sts-count-tag stream (sts-interface-tag)) 1))) 16))
      (let c5 (stcb-score (str_eq (sts-transcript stream) "speech lands") 32))
      (let c6 (stcb-score (eq (sts-value (nth stream 3)) 2) 64))
      (let c7 (stcb-score (str_eq (sts-value (nth stream 4)) "ok") 128))
      (let c8 (stcb-score (str_eq (sts-value (nth stream 5)) "task-17") 256))
      (let c9 (stcb-score (and (eq (stc-art-start a) 10)
                               (and (eq (stc-art-end a) 40)
                                    (eq (stc-art-confidence a) 91))) 512))
      (let c10 (stcb-score (and (eq (len (stc-controls t)) 2)
                                (eq (sts-count-tag stream (sts-choice-tag)) 0)) 1024))
      (add (add (add c0 c1) (add c2 c3))
           (add (add c4 c5) (add (add c6 c7) (add (add c8 c9) c10))))))

  (speech-task-contract-band))
