; jit-policy-access-sweep-band.fk - access/register half of the Form-native JIT policy spine.
;
; preludes: observe/jit-profile-receipt.fk observe/jit-runtime-fault.fk observe/jit-stack-frame.fk observe/jit-representation-specialization.fk observe/jit-register-lowering.fk
; Stays under the current fkwu --src 256-symbol table.
; Run:
;   ( cat observe/jit-profile-receipt.fk observe/jit-runtime-fault.fk observe/jit-stack-frame.fk observe/jit-representation-specialization.fk observe/jit-register-lowering.fk observe/tests/jit-policy-access-sweep-band.fk ) > /tmp/jpas.fk
;   ./fkwu --src /tmp/jpas.fk

(do
    (defn jpas-bit (cond bit) (if cond bit 0))
    (defn jit-policy-access-sweep-check ()
        (add
            (jpas-bit (eq (jit-stack-frame-check) 255) 1)
            (add
                (jpas-bit (eq (jit-representation-specialization-check) 1023) 2)
                (jpas-bit (eq (jit-register-lowering-check) 511) 4))))

    (jit-policy-access-sweep-check))
