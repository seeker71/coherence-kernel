; form-static-analyzer-direct-null-band.fk
;
; Verdict 31 when the static analyzer rejects known-nothing receivers before
; direct array/field/dict/hash/tree access can execute or lower with JIT.
;
; Run:
;   ( cat observe/jit-runtime-fault.fk observe/form-static-analyzer.fk observe/tests/form-static-analyzer-direct-null-band.fk ) > /tmp/fsadn.fk
;   ./fkwu --src /tmp/fsadn.fk

(do
    (defn fsadn-call (name)
        (fsa-call name (list (fsa-nothing (fsa-source-ok)) (fsa-int 0 (fsa-source-ok))) (fsa-source-call)))

    (defn fsadn-null-ref? (name)
        (eq (fsa-count-code (fsa-analyze-expr (fsadn-call name) (fsa-default-env)) (fsa-code-null-ref)) 1))

    (defn fsadn-bit (cond bit) (if cond bit 0))

    (add
        (fsadn-bit (fsadn-null-ref? "array-get") 1)
        (add
            (fsadn-bit (fsadn-null-ref? "field-load") 2)
            (add
                (fsadn-bit (fsadn-null-ref? "dict-get") 4)
                (add
                    (fsadn-bit (fsadn-null-ref? "hash-get") 8)
                    (fsadn-bit (fsadn-null-ref? "tree-get") 16))))))
