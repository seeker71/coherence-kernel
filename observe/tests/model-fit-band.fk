; model-fit-band.fk — fkwu-witnessed band for observe/model-fit.fk.
; Live-floor bits use only signs (the box's free memory moves); every fit
; computation is witnessed against FIXED floors so the verdict is stable.
;
; Bitmask verdict:
;   1   the measured host floor reports a positive total
;   2   the measured host floor reports positive available memory
;   4   4B params fit at Q8_0 within a 16000 MB floor
;   8   8B params step down honestly to Q6_K within a 9000 MB floor
;   16  70B params fit at NO quant within 16000 MB (honest no-fit, never forced)
;   32  MoE: mixtral's total does not fit at 16000 MB but its active set
;       carries a Q8_0 offload floor (llmfit's total-vs-active teaching)
;   64  the live report names the host floor
;   128 fixed-point resident math is exact: 1000M params x 1.000 B/p x 1.1 = 1100 MB
;
; Full verdict: 255
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/model-fit.fk
(do
  (defn mfb-bit (ok bit) (if (eq ok 1) bit 0))
  (do
    (let floor (mf-host-floor))
    (let mix (mf-verdict (list "mixtral-8x7b" 46700 12900) 16000))
    (add (mfb-bit (if (gt (nth floor 0) 0) 1 0) 1)
      (add (mfb-bit (if (gt (nth floor 1) 0) 1 0) 2)
        (add (mfb-bit (if (str_eq (mf-best-quant 4000 16000) "Q8_0") 1 0) 4)
          (add (mfb-bit (if (str_eq (mf-best-quant 8000 9000) "Q6_K") 1 0) 8)
            (add (mfb-bit (if (str_eq (mf-best-quant 70000 16000) "") 1 0) 16)
              (add (mfb-bit (if (and (str_eq (nth mix 1) "")
                                     (str_eq (nth mix 3) "Q8_0")) 1 0) 32)
                (add (mfb-bit (if (ge (str_find (mf-report) "host floor" 0) 0) 1 0) 64)
                     (mfb-bit (if (eq (mf-resident-mb 1000 1000) 1100) 1 0) 128))))))))))
