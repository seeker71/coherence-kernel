; belief-freshness-band.fk — the lifecycle holds on every arm: proven+fresh
; is law only for now, an older stamp invites a re-witness, the unproven
; rests as belief, renewal and desuetude both work, the epoch boundary is
; exact, and the larder audit folds honestly.
;
; preludes: form-stdlib/core.fk observe/belief-freshness.fk
;
; run: cat form/form-stdlib/core.fk observe/belief-freshness.fk \
;          observe/tests/belief-freshness-band.fk > /tmp/bf.fk
;      ./fkwu --src /tmp/bf.fk    ; -> 127
;
; Verdict 127 when the stamp is honest.

(do
    (defn bfb-score (ok bit) (if ok bit 0))
    (defn belief-freshness-band ()
        (do
    (let epoch 20260705)
    ; proven + freshly witnessed -> LAW
    (let c0 (bfb-score (eq (bf-status (bf-belief 1 1 20260705) epoch) 2) 1))
    ; the epoch boundary is exact: stamped AT the epoch is fresh, a day before is not
    (let c1 (bfb-score (and (eq (bf-law? (bf-belief 2 1 20260705) epoch) 1)
                            (eq (bf-owed? (bf-belief 3 1 20260704) epoch) 1)) 2))
    ; unproven stays belief-only even with today's stamp
    (let c2 (bfb-score (eq (bf-status (bf-belief 4 0 20260705) epoch) 0) 4))
    ; re-witness renews: the owed belief stands before the judge and is law again
    (let c3 (bfb-score (eq (bf-status (bf-rewitness (bf-belief 3 1 20260702) 20260705 1) epoch) 2) 8))
    ; desuetude: the failed re-witness lapses to belief-only, history kept (date stamped)
    (let c4 (bfb-score (and (eq (bf-status (bf-rewitness (bf-belief 3 1 20260702) 20260705 0) epoch) 0)
                            (eq (bf-date (bf-rewitness (bf-belief 3 1 20260702) 20260705 0)) 20260705)) 16))
    ; the larder audit: 1 law + 2 owed + 1 belief-only folds to 10201
    (let c5 (bfb-score (eq (bf-audit (list (bf-belief 1 1 20260705)
                                           (bf-belief 2 1 20260701)
                                           (bf-belief 3 1 20260630)
                                           (bf-belief 4 0 20260705)) epoch) 10201) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (bfb-score (eq (belief-freshness-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (belief-freshness-band))
