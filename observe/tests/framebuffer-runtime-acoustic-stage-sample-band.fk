; expected: 131071
; preludes: form/form-stdlib/core.fk observe/framebuffer-runtime-acoustic-stage-sample.fk

(do
  (defn fbrassb-bit (ok bit) (if ok bit 0))
  (defn fbrassb-sum-at (rows index)
    (if (eq (len rows) 0) 0
      (add (nth (head rows) index) (fbrassb-sum-at (tail rows) index))))
  (defn fbrassb-max-at (rows index best)
    (if (eq (len rows) 0) best
      (fbrassb-max-at (tail rows) index
        (if (gt (nth (head rows) index) best) (nth (head rows) index) best))))
  (defn framebuffer-runtime-acoustic-stage-sample-band ()
