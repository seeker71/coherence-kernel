          "framebuffer-runtime-acoustic-stage-sample") 1)
        (fbrassb-bit (str_eq (nth s 1) "2026-07-20T12:26:55+08:00") 2)
        (fbrassb-bit (eq (nth s 4) 22828) 4)
        (fbrassb-bit (eq (len stages) 5) 8)
        (fbrassb-bit (eq (fbrassb-sum-at stages 3) (nth s 6)) 16)
        (fbrassb-bit (eq (nth s 6) 155712) 32)
        (fbrassb-bit (eq (nth s 7) 19531866065) 64)
        (fbrassb-bit (eq (fbrassb-sum-at stages 7) 19531856666) 128)
        (fbrassb-bit (eq (fbrassb-sum-at stages 12) (nth s 11)) 256)
        (fbrassb-bit (eq (fbrassb-sum-at stages 9) (nth s 9)) 512)
        (fbrassb-bit (lt (fbrassb-sum-at stages 10) (nth s 10)) 1024)
        (fbrassb-bit (eq (fbrassb-sum-at stages 13) (nth s 12)) 2048)
        (fbrassb-bit (eq (fbrassb-max-at stages 3 0) 66335) 4096)
        (fbrassb-bit (eq (fbrassb-max-at stages 7 0) 9487930216) 8192)
        (fbrassb-bit (eq (fbrassb-max-at stages 12 0) 878432521) 16384)
        (fbrassb-bit (str_eq (nth s 18)
          "native-stages-complete-world-held-no-generated-text") 32768)
        (fbrassb-bit (and (eq (nth s 15) 50257)
