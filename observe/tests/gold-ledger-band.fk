; gold-ledger-band.fk — the gold ledger composes the surprise organ unchanged
; and keeps what witnessed discomfort became.
;
; preludes: form-stdlib/core.fk observe/surprise-receipt.fk observe/gold-ledger.fk
;
; run: cat form/form-stdlib/core.fk observe/surprise-receipt.fk \
;          observe/gold-ledger.fk observe/tests/gold-ledger-band.fk > /tmp/gl.fk
;      ./fkwu --src /tmp/gl.fk    ; -> 31
;
; Verdict 31 when every assertion holds.

(do
    (defn glb-score (ok bit) (if ok bit 0))
    (defn gold-ledger-band ()
        (do
    (let rows (gl-rows))
    ; the organ is composed, not duplicated: the vitality row's surprise is 38
    (let c0 (glb-score (eq (gl-surprise (nth rows 1)) 38) 1))
    ; two rows earn receipts under the organ's own threshold law
    (let c1 (glb-score (eq (gl-count-receipts rows) 2) 2))
    ; the foundings row honestly earns NO receipt (magnitude 1 < threshold 3),
    ; even though it was the evening's most-felt surprise — the salience gap
    ; is named in the ledger, not papered over by re-encoding
    (let c2 (glb-score (eq (gl-receipt? (nth rows 2)) 0) 4))
    ; every row keeps its gold — no witnessed discomfort evaporates
    (let c3 (glb-score (eq (gl-all-gold? rows) 1) 8))
    ; the folded scalar witness: 4 rows | 2 receipts | max surprise 38
    (let c4 (glb-score (eq (gl-field-code) 402038) 16))
    (add c0 (add c1 (add c2 (add c3 c4)))))
    )
    (gold-ledger-band))
