; native-crystallize.fk — OBSERVE the live crystallize flip: a hot, pure recipe
; dispatched to its native (the install+call carrier, fk_native_call) instead of
; tree-walked. Composes the decision (jit-decision.fk) with a witness record so the
; framebuffer SEES the flip — and refuses to count it unless the native held parity
; with the walk (the native IS the recipe, bit-identical, or it is not witnessed).
;
; Witnessed on the Windows kernel (recipe (add (arg) 1), arg 41):
;   cold (no threshold)  -> value 42, njit 0   (tree-walked)
;   hot  (thr 1)         -> value 42, njit 1   (crystallized -> native)
;   warm (thr 5)         -> value 42, njit 0   (heat below threshold, stays walked)
; value 42 across the flip; njit ticks on the dispatch. The heat threshold is the
; jit-decision policy (hot AND pure -> heat >= 5, hysteresis).
;
; preludes: core.fk jit-decision.fk
(do
    ; a crystallize event: (fn heat dispatched? value-cold value-hot)
    (defn nc-event (fn heat disp vc vh) (list fn heat disp vc vh))
    (defn nc-fn   (e) (nth e 0))
    (defn nc-heat (e) (nth e 1))
    (defn nc-disp (e) (nth e 2))
    (defn nc-vc   (e) (nth e 3))
    (defn nc-vh   (e) (nth e 4))

    ; the flip is HONEST only if cold == hot — the native is the recipe, bit-for-bit.
    (defn nc-parity? (e) (if (eq (nc-vc e) (nc-vh e)) 1 0))
    ; a recipe should crystallize exactly when jit-decision says so (hot AND pure).
    (defn nc-should? (heat pure) (jd-crystallize? heat pure))
    ; a flip is WITNESSED only when it dispatched native AND held parity.
    (defn nc-witnessed? (e)
        (if (and (eq (nc-disp e) 1) (eq (nc-parity? e) 1)) 1 0))

    (defn nck (cond bit) (if cond bit 0))
    (defn native-crystallize-check ()
        (add (add (add (add
            (nck (eq (nc-should? 6 1) 1) 1)                              ; hot pure -> crystallize (jit-decision)
            (nck (eq (nc-should? 1 1) 0) 10))                           ; cold -> stay tree-walked
            (nck (eq (nc-witnessed? (nc-event 0 6 1 42 42)) 1) 100))    ; dispatched + parity -> witnessed (the live flip)
            (nck (eq (nc-witnessed? (nc-event 0 6 1 42 99)) 0) 1000))   ; dispatched but NO parity -> NOT witnessed (honest)
            (nck (eq (jd-melt? 1) 1) 10000)))                          ; cooled -> melt back to the walker
    0)
