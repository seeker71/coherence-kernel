; whisper-affine-row-major-observation.fk -- framebuffer-led real affine audit.
;
; Runs one released 384x384 encoder query projection over two vectors from the
; committed CC0 human utterance through both loop nests.  Time, dispatches,
; arena cons, and boxed floats are read directly from fkwu around each lane.
; The optimized lane is admitted only if every output value equals the original
; Form streaming lane exactly.  A faster native-dot experiment was rejected
; after the real projection exposed 5.7534467641506826e-13 of drift.  This is a
; numeric/resource witness, not speech recognition.
; witnessed: 2026-07-20 -> live counters pending
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-affine-row-major.fk

(do
  (defn waro-snapshot ()
    (list (now_unix_ms) (kernel_stat 0) (kernel_stat 6) (kernel_stat 8)))
  (defn waro-delta (before after)
    (list "duration-ms" (sub (nth after 0) (nth before 0))
      "dispatches" (sub (nth after 1) (nth before 1))
      "arena-cons" (sub (nth after 2) (nth before 2))
      "boxed-floats" (sub (nth after 3) (nth before 3))))
  (defn waro-delta-number (delta key)
    (if (eq (len delta) 0) 0
      (if (str_eq (head delta) key) (nth delta 1)
        (waro-delta-number (tail (tail delta)) key))))

  (defn waro-real-query-input ()
    (do
      (let path "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav")
      (let wav (fs-read-slice path 0 (fs-stat-size path)))
      (let data-offset (wtc-wav-data-offset wav))
      (let normalized (wtc-normalize-tile (wte0-log-mel-cols wav data-offset)))
      (let pack (wte0-load))
      (let conv1 (wte0-conv1-tokens (wte0-stem pack) (nth normalized 1)))
      (let conv2 (wte0-conv2-tokens (wte0-stem pack) conv1))
      (let positioned (wte0-position-two (wte0-carrier pack) conv2))
      (list pack (wte0-layernorm-seq (wte0-carrier pack)
        (wte0-attn-ln-weight-off) (wte0-attn-ln-bias-off) positioned))))

  (defn whisper-affine-row-major-observation ()
    (do
      (let real (waro-real-query-input))
      (let carrier (wte0-carrier (nth real 0)))
      (let input (nth real 1))
      (let baseline-before (waro-snapshot))
      (let baseline (wte0-affine-seq carrier (wte0-q-weight-off)
        (wte0-q-bias-off) 384 384 input))
      (let baseline-after (waro-snapshot))
      (let optimized-before (waro-snapshot))
      (let optimized (wafr-affine-seq carrier (wte0-q-weight-off)
        (wte0-q-bias-off) 384 384 input))
      (let optimized-after (waro-snapshot))
      (let baseline-delta (waro-delta baseline-before baseline-after))
      (let optimized-delta (waro-delta optimized-before optimized-after))
      (let distance (add (wte0-vector-distance (nth baseline 0) (nth optimized 0))
        (wte0-vector-distance (nth baseline 1) (nth optimized 1))))
      (list "whisper-affine-row-major-observation"
        "source" "real-cc0-human-speech"
        "projection" "encoder.layers.0.self_attn.q_proj"
        "shape" (list 2 384 384)
        "baseline" baseline-delta
        "optimized" optimized-delta
        "exact-distance" distance
        "exact-parity" (if (eq distance 0.0) 1 0)
        "weight-decodes-baseline" (mul 2 (mul 384 384))
        "weight-decodes-optimized" (mul 384 384)
        "weight-decode-reuse-factor" 2
        "full-utterance-reuse-factor" 35
        "native-recognizer" 0
        "honest-floor" "one real released projection; complete 35-token encoder separately owed"
        "fingerprints" (list (wt2-fingerprint (nth optimized 0))
          (wt2-fingerprint (nth optimized 1))))))

  (defn whisper-affine-row-major-observation-check ()
    (do
      (let r (whisper-affine-row-major-observation))
      (let baseline (nth r 8))
      (let optimized (nth r 10))
      (add
        (if (str_eq (nth r 0) "whisper-affine-row-major-observation") 1 0)
        (add (if (str_eq (nth r 2) "real-cc0-human-speech") 2 0)
        (add (if (eq (nth r 14) 1) 4 0)
        (add (if (eq (nth r 16) 294912) 8 0)
        (add (if (eq (nth r 18) 147456) 16 0)
        (add (if (eq (nth r 20) 2) 32 0)
        (add (if (eq (nth r 22) 35) 64 0)
        (add (if (lt (waro-delta-number optimized "dispatches")
                     (waro-delta-number baseline "dispatches")) 128 0)
             (if (lt (waro-delta-number optimized "boxed-floats")
                     (waro-delta-number baseline "boxed-floats")) 256 0)))))))))))
  0)
