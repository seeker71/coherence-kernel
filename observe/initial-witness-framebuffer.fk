; initial-witness-framebuffer.fk — ground the checkout's first answer in the
; kernel's own bounded source-attribution framebuffer.
;
; Direct source admits the Form-native framebuffer carrier fb_record; the
; prelude convenience name intern_node_at is intentionally not required here.
; No display, external process, or retained payload participates.
;
; Verdict 111 = ground value 42 (1) + one bounded framebuffer event (10) +
; exact bootstrap/ground.fk source coordinate, line 6 / col 1 (100).

(do
    (defn iwf-bit (condition bit) (if condition bit 0))
    (defn initial-witness-framebuffer-check ()
        (do
            (framebuffer-clear)
            (let ground (add 40 2))
            (let nid
                (fb_record
                    (intern_node (make_nodeid 1 2 12 1)
                                 (list (intern_trivial_int ground)))
                    "bootstrap/ground.fk"
                    (add (mul 6 65536) 1)))
            (let events (framebuffer-events))
            (let source (node_source nid))
            (add (iwf-bit (eq ground 42) 1)
                 (add (iwf-bit (eq (len events) 1) 10)
                      (if (eq (nth source 1) 6)
                          (if (eq (nth source 2) 1) 100 0)
                          0)))))
    (initial-witness-framebuffer-check))
