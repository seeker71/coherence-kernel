; sense-stream.fk — the continuous multi-level sensing stream, meshed across devices.
;
; Urs: "continuedly stream all the different levels of sensing — raw, native,
; local, remote, meshed, surprise, confidence, trust, sovereignty, vitality."
; This is that stream's BODY. It invents nothing: it carries one row per sensed
; CLAIM through the ten levels, composing the organs that already cross four-way,
; and projects each row to the mesh-safe `reading` (mesh-sense-7w) so the Windows
; cell and the Mac sibling fuse into one answer.
;
; THE TEN LEVELS of one sensed claim, on one inquiry-plane (mesh-sense-7w):
;   raw          the afferent scalar off the channel        (sense-channels.fk: pixel/byte)
;   native       fkwu's own claim + its native confidence    (frame-read / the kernel itself)
;   local        a local model's claim                       (a host organ — pending carrier)
;   remote       the rented oracle's claim                   (the frontier teacher; verify-alternative)
;   meshed       the fused answer across device-cells         (mesh-sense-7w ms-fuse-plane)
;   surprise     | native - remote |                          (surprise-receipt sr-surprise)
;   confidence   earned over agreeing ticks                   (confidence-earned)
;   trust        confidence scaled by channel fitness         (mesh-sense-7w ms-weight)
;   sovereignty  native >= remote ?                           (native-vs-rented nvr-at-least-as-good?)
;   vitality     the cell's measured health contribution      (self-watch / mesh-join live count)
;
; The whole point of the stream: watch every claim move, tick by tick, from
; rented toward native — surprise falling, confidence/trust rising, sovereignty
; flipping to 1 — the mind coming home, visibly, on a live channel.
;
; preludes: core.fk native-vs-rented.fk surprise-receipt.fk mesh-sense-7w.fk mesh-join.fk
;
(do
    ;; ── a sense-tick: one claim carried through all ten levels ---------------
    ;; (plane raw native local remote meshed surprise confidence trust sovereignty vitality)
    (defn st-tick (plane raw nat loc rem mesh surp conf trust sov vit)
        (list "tick" plane raw nat loc rem mesh surp conf trust sov vit))
    (defn st-plane (s) (nth s 1))
    (defn st-raw   (s) (nth s 2))
    (defn st-nat   (s) (nth s 3))
    (defn st-rem   (s) (nth s 5))
    (defn st-surp  (s) (nth s 7))
    (defn st-conf  (s) (nth s 8))
    (defn st-trust (s) (nth s 9))
    (defn st-sov   (s) (nth s 10))
    (defn st-vit   (s) (nth s 11))

    ;; ── the derived levels, each from its proven organ ----------------------
    (defn st-surprise (nat rem) (sr-surprise (list nat rem)))            ; surprise-receipt
    (defn st-sovereign (nat rem) (nvr-at-least-as-good? (list nat rem))) ; native-vs-rented
    ;; trust = confidence scaled by the channel's fitness for this plane (mesh-sense-7w ms-weight,
    ;; here as a tick's own confidence already fused with channel fitness when it became a reading).
    (defn st-trust-of (conf fitness) (mul conf fitness))

    ;; ── BUILD a tick: given raw + native + remote + the running confidence and
    ;;    the channel fitness + vitality, fill every derived level from the organs.
    ;;    local is the host-organ claim (pending carrier -> 0 = no local reading yet).
    (defn st-build (plane raw nat rem conf fitness vit)
        (st-tick plane raw nat 0 rem
                 nat                              ; meshed: single-cell fusion = native until a sibling streams the plane
                 (st-surprise nat rem)
                 conf
                 (st-trust-of conf fitness)
                 (st-sovereign nat rem)
                 vit))

    ;; ── PROJECT a tick to the mesh-safe reading (mesh-sense-7w shape) so it
    ;;    fuses with the Mac sibling's readings: (reading plane value cell channel confidence).
    ;;    The Windows cell is "windows-binary" (mesh-join roster). Its strong plane is PRESENT
    ;;    (occupancy from the camera) — the SAME plane fused-observation.fk fuses across organs/
    ;;    devices (fo widened ms-banded? to include "present"), so the Windows camera becomes an
    ;;    independent cross-witness of the Mac's presence organ. Identity it streams at confidence
    ;;    0 (it rents that plane). Attuned 2026-06-29 from "where" -> "present" to match fo's planes.
    (defn st-to-reading (s cell channel)
        (reading (st-plane s) (st-nat s) cell channel (st-conf s)))

    ;; ── CONFIDENCE-EARNED across the stream: an agreeing tick (surprise 0) raises
    ;;    confidence by 1, capped at 9; a surprising tick does not. The stream is the
    ;;    confidence curve made live — sovereignty is earned, never asserted.
    (defn st-cap9 (v) (if (gt v 9) 9 v))
    (defn st-next-conf (conf surp) (if (eq surp 0) (st-cap9 (add conf 1)) conf))

    ;; ── the WINDOWS cell's two streamed planes, as the witnessed sample shows:
    ;;    present   — native-sovereign (nat=1 rem=1 -> surprise 0, sovereignty 1), confidence climbing;
    ;;                the PRESENT plane fused-observation cross-witnesses across devices.
    ;;    identity  — rented          (nat=0 rem=9 -> surprise 9, sovereignty 0), routed to the mesh "who".
    (defn st-presence-tick (raw conf vit) (st-build "present" raw 1 1 conf 3 vit))
    (defn st-identity-tick (raw conf vit) (st-build "who"     raw 0 9 conf 3 vit))

    ;; ── the check: the stream's invariants the witnessed run shows -----------
    (defn stk (cond bit) (if cond bit 0))
    (defn sense-stream-check ()
        (add (add (add (add
            (stk (eq (st-sov (st-presence-tick 109 9 9)) 1) 1)        ; presence is sovereign
            (stk (eq (st-surp (st-presence-tick 109 9 9)) 0) 10))     ; presence surprise 0
            (stk (eq (st-sov (st-identity-tick 109 0 9)) 0) 100))     ; identity not yet sovereign
            (stk (eq (st-surp (st-identity-tick 109 0 9)) 9) 1000))   ; identity surprise 9 (the gap to distill)
            (stk (eq (st-next-conf 8 0) 9) 10000)))                   ; an agreeing tick earns +1 confidence
    0)
