; bidirectional-framebuffer-channel.fk — a typed observation/control exchange.
; The kernel framebuffer stays the attributed carrier; this Form membrane adds
; direction, correlation, an actuator, and a no-response alternative.
(do
  ; [direction, exchange-id, kind, payload, alternative-node]
  ; direction 0=outbound observation, 1=inbound control; kind 0=transition,
  ; 1=control. Actions: 0 continue, 1 branch, 2 revise, 3 abstain,
  ; 4 request-evidence, 5 rehearse-ground.
  (defn bfc-envelope (direction exchange kind payload alternative)
    (list direction exchange kind payload alternative))
  (defn bfc-direction (m) (nth m 0))
  (defn bfc-exchange (m) (nth m 1))
  (defn bfc-kind (m) (nth m 2))
  (defn bfc-payload (m) (nth m 3))
  (defn bfc-alternative (m) (nth m 4))

  (defn bfc-adjudicate (outbound)
    (if (or (nothing? outbound)
      (or (not (eq (bfc-direction outbound) 0))
          (not (eq (bfc-kind outbound) 0))))
      (nothing)
      (do (let transitions (bfc-payload outbound))
        (let action (if (gt (nth transitions 0) (nth transitions 1)) 5 0))
        (bfc-envelope 1 (bfc-exchange outbound) 1 action
          (bfc-alternative outbound)))))

  ; A correlated response changes the selected next state. Missing or mismatched
  ; responses select the offered alternative instead of becoming silence.
  (defn bfc-apply (outbound inbound current-state rehearsed-state)
    (if (or (nothing? inbound)
      (or (not (eq (bfc-direction inbound) 1))
      (or (not (eq (bfc-kind inbound) 1))
          (not (eq (bfc-exchange outbound) (bfc-exchange inbound))))))
      (bfc-alternative outbound)
      (if (eq (bfc-payload inbound) 5) rehearsed-state current-state)))

  (defn bfc-record-out (message step)
    (fb_record (intern_trivial_int (mul (bfc-exchange message) 10))
      "bidirectional-framebuffer-channel.fk" step))
  (defn bfc-record-in (message step)
    (fb_record (intern_trivial_int (add (mul (bfc-exchange message) 10) 1))
      "bidirectional-framebuffer-channel.fk" step))

  (defn bfc-round (exchange transitions current-state rehearsed-state alternative)
    (do (let outbound (bfc-envelope 0 exchange 0 transitions alternative))
      (let out-event (bfc-record-out outbound (mul exchange 2)))
      (let inbound (bfc-adjudicate outbound))
      (let in-event (bfc-record-in inbound (add (mul exchange 2) 1)))
      (list outbound inbound
        (bfc-apply outbound inbound current-state rehearsed-state))))
  0)
