; happening-ledger.fk — a small Form-native happening that can answer about
; itself while it is in memory.
;
; This is the honest first density increase: an event is a numeric record of
; identity, parent, kind, subject, source coordinate, state transition, rule,
; and evidence.  The final evidence is the real bounded framebuffer witness,
; not a reconstructed story.  No raw prompt, output, or external process data
; crosses this cell.
;
; Live hooks for arbitrary evaluator fires remain pending.  This cell proves
; the query shape over one real Form observation in the same process.
;
; import "observe/initial-witness-framebuffer.fk"

(do
    ; Event fields: id parent kind subject source-line source-col before after rule evidence.
    ; Kinds: 1 run, 2 source, 3 result, 4 observation.
    (defn hl-event (id parent kind subject line col before after rule evidence)
        (list id parent kind subject line col before after rule evidence))
    (defn hl-id (event) (nth event 0))
    (defn hl-parent (event) (nth event 1))
    (defn hl-line (event) (nth event 4))
    (defn hl-col (event) (nth event 5))
    (defn hl-before (event) (nth event 6))
    (defn hl-after (event) (nth event 7))
    (defn hl-rule (event) (nth event 8))
    (defn hl-evidence (event) (nth event 9))

    (defn hl-find (ledger id)
        (if (eq (len ledger) 0) (empty)
            (if (eq (hl-id (head ledger)) id) (head ledger)
                (hl-find (tail ledger) id))))

    (defn hl-ancestors (ledger event)
        (if (eq (len event) 0) (empty)
            (cons (hl-id event)
                  (hl-ancestors ledger (hl-find ledger (hl-parent event))))))

    (defn hl-inquire (ledger question id)
        (do
            (let event (hl-find ledger id))
            (if (eq (len event) 0) (empty)
                (if (str_eq question "ancestors") (hl-ancestors ledger event)
                (if (str_eq question "why")
                    (list (hl-rule event) (hl-parent event) (hl-evidence event))
                (if (str_eq question "state")
                    (list (hl-before event) (hl-after event))
                (if (str_eq question "evidence")
                    (list (hl-line event) (hl-col event) (hl-evidence event))
                (if (str_eq question "source")
                    (list (hl-line event) (hl-col event))
                    (empty))))))))

    (defn hl-self-ledger ()
        (do
            (let framebuffer-witness (initial-witness-framebuffer-check))
            (list
                (hl-event 1 0 1 0 0 0 0 0 0 0)
                (hl-event 2 1 2 42 6 1 0 42 0 0)
                (hl-event 3 2 3 42 6 1 42 42 1 0)
                (hl-event 4 3 4 42 6 1 42 42 1 framebuffer-witness))))

    (defn happening-ledger-self-inquiries ()
        (do
            (let ledger (hl-self-ledger))
            (list
                (hl-inquire ledger "ancestors" 4)
                (hl-inquire ledger "why" 4)
                (hl-inquire ledger "state" 4)
                (hl-inquire ledger "evidence" 4)
                (hl-inquire ledger "unknown" 4))))

    (defn happening-ledger-check ()
        (do
            (let ledger (hl-self-ledger))
            (let ancestors (hl-inquire ledger "ancestors" 4))
            (let why (hl-inquire ledger "why" 4))
            (let state (hl-inquire ledger "state" 4))
            (let evidence (hl-inquire ledger "evidence" 4))
            (let unknown (hl-inquire ledger "unknown" 4))
            ; Verdict 11111: causal path, rule/parent/evidence, state,
            ; source/evidence, and an honest empty answer for an unoffered query.
            (add (if (eq (len ancestors) 4) 1 0)
                 (add (if (eq (nth why 0) 1) 10 0)
                      (add (if (eq (nth state 0) 42) 100 0)
                           (add (if (eq (nth evidence 0) 6)
                                    (if (eq (nth evidence 1) 1) 1000 0) 0)
                                (if (eq (len unknown) 0) 10000 0)))))))

    (happening-ledger-check))
