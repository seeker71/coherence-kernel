; membrane-lane.fk — make every membrane crossing on ANY query lane observable, and un-foolable.
;
; A query is answered by walking a LANE — an ordered list of crossings. A crossing either stays inside
; the native fkwu body (the source-runner, the KV cache, the decode organ, argmax, a local weights file) or
; it LEAVES the body (the network, a remote oracle, the C-seed/GPU, host git, an MCP service). The whole
; sovereignty question — "was this answer produced without a remote oracle and without the network?" — is
; just a read over the lane: are all its crossings native, and if not, which non-native ones are still OWED
; a closure (a re-witness)? This cell is that read, and it is built so a lane CANNOT be dressed sovereign
; when it is not: a crossing's KIND fixes its native-ness, so relabeling a network hop "native" is caught.
;
; THE CODE LEGEND (kinds are small ints so the read is pure arithmetic, no string primitives):
;   native kinds (1..5):  1 source-runner  2 kv-cache  3 decode-organ  4 argmax  5 local-weights
;   non-native (6..10):   6 network  7 remote-oracle  8 c-seed/gpu  9 host-git  10 mcp-service
; The dividing line is a single comparison: a kind <= 5 stays in the body, a kind >= 6 leaves it. That is
; the whole membrane, made countable.
;
; A CROSSING is (id kind claimed-native witnessed): `id` names it, `kind` fixes its true native-ness,
; `claimed-native` is what the lane ASSERTS about it (1/0), and `witnessed` is the verdict that closed it
; (0 = not yet witnessed / still owed; > 0 = a re-witness landed, e.g. a band verdict). belief-freshness's
; law holds here: a non-native crossing with witnessed = 0 is OWED; witnessed > 0 is a closed re-witness.
;
; THE FALSIFIER, named: a lane that marks a network crossing claimed-native = 1 is a sovereignty LIE. It is
; caught because ml-honest? compares the claim against the kind's fixed native-ness, and the kind cannot be
; forged — network is kind 6, and 6 > 5 no matter what the lane asserts. membrane-lane-band.fk hands the
; observer exactly this forged lane and demands ml-consistent? go red. An observer that can be fooled is not
; an observer.
;
; twinblind: every read here is CANONICAL — kind fixes native-ness, the counts are order-free, there is one
; right answer and no oracle. A self-check is a real falsifier.
;
; preludes: form-stdlib/core.fk
;
; Proven by: observe/tests/membrane-lane-band.fk (verdict 31).

(do
    (defn ml-id        (c) (nth c 0))
    (defn ml-kind      (c) (nth c 1))
    (defn ml-claimed   (c) (nth c 2))
    (defn ml-witnessed (c) (nth c 3))

    ; the membrane, made countable: a kind <= 5 stays in the body.
    (defn ml-kind-native? (k) (if (le k 5) 1 0))
    ; a crossing is HONEST when what the lane claims matches what the kind fixes.
    (defn ml-honest? (c) (if (eq (ml-claimed c) (ml-kind-native? (ml-kind c))) 1 0))

    ; the lane is CONSISTENT when no crossing lies about itself — this is what catches a
    ; network hop relabeled sovereign, and it must hold before any other read is trusted.
    (defn ml-consistent? (lane)
        (if (eq (len lane) 0) 1
            (if (eq (ml-honest? (head lane)) 1) (ml-consistent? (tail lane)) 0)))

    ; the lane is NATIVE when every crossing's kind stays in the body — a real sovereignty read,
    ; independent of what the lane claims (claims are checked separately by ml-consistent?).
    (defn ml-native-lane? (lane)
        (if (eq (len lane) 0) 1
            (if (eq (ml-kind-native? (ml-kind (head lane))) 1) (ml-native-lane? (tail lane)) 0)))

    ; OWED: a crossing that leaves the body and has not yet been closed by a witness.
    ; This is the re-witness list — the honest debt of a lane that touched the outside.
    (defn ml-owed? (c)
        (if (eq (ml-kind-native? (ml-kind c)) 0) (if (eq (ml-witnessed c) 0) 1 0) 0))
    (defn ml-owed-count (lane)
        (if (eq (len lane) 0) 0
            (add (ml-owed? (head lane)) (ml-owed-count (tail lane)))))
    ; the owed crossings themselves, so the offer can name each one.
    (defn ml-owed-list (lane)
        (if (eq (len lane) 0) (empty)
            (if (eq (ml-owed? (head lane)) 1)
                (cons (head lane) (ml-owed-list (tail lane)))
                (ml-owed-list (tail lane)))))

    ; a RE-WITNESS REQUEST for one owed crossing: (id kind "owed"). The ask is the crossing's
    ; identity plus the flag that it is still open. A closed crossing yields no request.
    (defn ml-rewitness-of (c) (list (ml-id c) (ml-kind c) 0))   ; the 0 is "owed", mirrors witnessed=0
    (defn ml-rewitness-requests (lane)
        (if (eq (len lane) 0) (empty)
            (if (eq (ml-owed? (head lane)) 1)
                (cons (ml-rewitness-of (head lane)) (ml-rewitness-requests (tail lane)))
                (ml-rewitness-requests (tail lane)))))

    ; CLOSE a crossing by id: stamp its witnessed verdict (a re-witness landed). Returns a new lane.
    ; belief-freshness: this is renewal — the owed debt becomes a closed, verdict-stamped crossing.
    (defn ml-close (lane id verdict)
        (if (eq (len lane) 0) (empty)
            (if (eq (ml-id (head lane)) id)
                (cons (list id (ml-kind (head lane)) (ml-claimed (head lane)) verdict) (tail lane))
                (cons (head lane) (ml-close (tail lane) id verdict)))))

    ; the one-line sovereignty verdict for a lane: 1 only when it is consistent AND fully native.
    (defn ml-sovereign? (lane)
        (if (eq (ml-consistent? lane) 1) (if (eq (ml-native-lane? lane) 1) 1 0) 0))
    0)
