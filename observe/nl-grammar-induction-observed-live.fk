; nl-grammar-induction-observed-live.fk -- learn before claiming language.
;
; Streams the training boundary, candidate induction, MDL selection, unseen
; emission, learned inverse, and memorization rejection before returning the
; result.  The held-out words `signal` and `grounded` occur in no training row.
; witnessed: 2026-07-20 -> 9 rows, 3 learned rules, 3 unseen roundtrips
; preludes: form/form-stdlib/core.fk cognition/nl-grammar-induction-rule.fk cognition/nl-grammar-induction.fk observe/framebuffer-runtime-observation.fk

(do
  (defn ngiol-begin (stage parent)
    (do
      (print_str (fbro-cat (list
        "FRAMEBUFFER STAGE-BEGIN trace=nl-grammar-induction"
        " stage=" stage " parent=" parent " actor=Sema"
        " relation=learns-reusable-surface-structure"
        " why=generalize-without-row-memorization")))
      (fbro-snapshot)))
  (defn ngiol-stage (stage parent before after metric value outcome line)
    (fbro-stage-observed-stream "nl-grammar-induction" stage parent "Sema"
      "learns-reusable-surface-structure"
      "generalize-without-row-memorization" "held-out-structural-transfer"
      before after metric value outcome
      "observe/nl-grammar-induction-observed-live.fk" line 7))

  (defn nl-grammar-induction-observed-live ()
    (do
      (let window (fbro-open-stream "nl-grammar-induction" "Sema"
        "learns-reusable-surface-structure"
        "generalize-without-row-memorization" "held-out-structural-transfer" 0
        "observe/nl-grammar-induction-observed-live.fk" 31 7))

      (let training-before (ngiol-begin "paired-training-observation" "trace-begin"))
      (let pairs (ngi-training-pairs))
      (let unseen (if (and (eq (ngi-held-word-seen? pairs "signal") 0)
        (and (eq (ngi-held-word-seen? pairs "grounded") 0)
          (and (eq (ngi-held-word-seen? pairs "framebuffer") 0)
            (eq (ngi-held-word-seen? pairs "budget exceeded") 0)))) 1 0))
      (let training-after (fbro-snapshot))
      (let training-event (ngiol-stage "paired-training-observation" "trace-begin"
        training-before training-after "paired-rows" (len pairs)
        (if (eq unseen 1) "held-content-unseen" "leaked-held-content") 40))

      (let induction-before (ngiol-begin "candidate-induction" "paired-training-observation"))
      (let grammar (ngi-grammar pairs (ngi-kinds)))
      (let property-record (ngi-grammar-record grammar "property"))
      (let question-record (ngi-grammar-record grammar "question"))
      (let alert-record (ngi-grammar-record grammar "alert"))
      (let induction-after (fbro-snapshot))
      (let induction-event (ngiol-stage "candidate-induction"
        "paired-training-observation" induction-before induction-after
        "candidates" 9
        (if (and (eq (len (nth property-record 2)) 3)
          (and (eq (len (nth question-record 2)) 3)
            (eq (len (nth alert-record 2)) 3))) "complete" "held") 51))

      (let mdl-before (ngiol-begin "mdl-selection" "candidate-induction"))
      (let property-selected (ngi-record-selected property-record))
      (let question-selected (ngi-record-selected question-record))
      (let alert-selected (ngi-record-selected alert-record))
      (let property-memory (nth (nth property-record 2) 2))
      (let question-memory (nth (nth question-record 2) 2))
      (let alert-memory (nth (nth alert-record 2) 2))
      (let mdl-win (if (and
        (lt (ngi-candidate-mdl property-selected) (ngi-candidate-mdl property-memory))
        (and (lt (ngi-candidate-mdl question-selected) (ngi-candidate-mdl question-memory))
          (lt (ngi-candidate-mdl alert-selected) (ngi-candidate-mdl alert-memory)))) 1 0))
      (let mdl-after (fbro-snapshot))
      (let mdl-event (ngiol-stage "mdl-selection" "candidate-induction"
        mdl-before mdl-after "reusable-winners" (if (and
          (eq (ngi-candidate-reusable? property-selected) 1)
          (and (eq (ngi-candidate-reusable? question-selected) 1)
            (eq (ngi-candidate-reusable? alert-selected) 1))) 3 0)
        (if (eq mdl-win 1) "minimal-reusable-rules" "held") 65))

      (let emit-before (ngiol-begin "held-out-emission" "mdl-selection"))
      (let property-surface (ngi-grammar-emit grammar (ngi-held-property)))
      (let question-surface (ngi-grammar-emit grammar (ngi-held-question)))
      (let alert-surface (ngi-grammar-emit grammar (ngi-held-alert)))
      (let emitted (if (and (str_eq property-surface "the signal is grounded")
        (and (str_eq question-surface "is the signal grounded?")
          (str_eq alert-surface "budget exceeded: framebuffer"))) 1 0))
      (let emit-after (fbro-snapshot))
      (let emit-event (ngiol-stage "held-out-emission" "mdl-selection"
        emit-before emit-after "unseen-surfaces" 3
        (if (eq emitted 1) "exact-structural-transfer" "held") 76))

      (let inverse-before (ngiol-begin "learned-inverse" "held-out-emission"))
      (let property-back (ngi-grammar-parse grammar "property" property-surface))
      (let question-back (ngi-grammar-parse grammar "question" question-surface))
      (let alert-back (ngi-grammar-parse grammar "alert" alert-surface))
      (let inverse (if (and (str_eq property-back (ngi-held-property))
        (and (str_eq question-back (ngi-held-question))
          (str_eq alert-back (ngi-held-alert)))) 1 0))
      (let inverse-after (fbro-snapshot))
      (let inverse-event (ngiol-stage "learned-inverse" "held-out-emission"
        inverse-before inverse-after "roundtrips" (if (eq inverse 1) 3 0)
        (if (eq inverse 1) "exact" "held") 86))

      (let memory-before (ngiol-begin "memorized-row-rejection" "learned-inverse"))
      (let property-memory-out (ngi-memory-emit
        (ngi-candidate-payload property-memory) (ngi-held-property)))
      (let question-memory-out (ngi-memory-emit
        (ngi-candidate-payload question-memory) (ngi-held-question)))
      (let alert-memory-out (ngi-memory-emit
        (ngi-candidate-payload alert-memory) (ngi-held-alert)))
      (let memory-rejected (if (and (str_eq property-memory-out "")
        (and (str_eq question-memory-out "")
          (str_eq alert-memory-out ""))) 1 0))
      (let memory-after (fbro-snapshot))
      (let memory-event (ngiol-stage "memorized-row-rejection" "learned-inverse"
        memory-before memory-after "held-out-matches" 0
        (if (eq memory-rejected 1) "row-memory-cannot-generalize" "held") 98))

      (let admitted (if (and (eq unseen 1) (and (eq mdl-win 1)
        (and (eq emitted 1) (and (eq inverse 1) (eq memory-rejected 1))))) 1 0))
      (let report (fbro-close-stream window
        (if (eq admitted 1) "bounded-two-slot-grammar-generalization-observed"
          "grammar-generalization-held")
        admitted "observe/nl-grammar-induction-observed-live.fk" 106 7))
      (list "nl-grammar-induction-observed-live"
        "training" (list "rows" (len pairs) "categories" 3
          "held-content-unseen" unseen)
        "property" (list
          "selected" (ngi-candidate-name property-selected)
          "rule-mdl" (ngi-candidate-mdl property-selected)
          "memory-mdl" (ngi-candidate-mdl property-memory)
          "coverage" (ngi-candidate-coverage property-selected)
          "levels" (ngi-rule-levels (ngi-candidate-payload property-selected)))
        "question" (list
          "selected" (ngi-candidate-name question-selected)
          "rule-mdl" (ngi-candidate-mdl question-selected)
          "memory-mdl" (ngi-candidate-mdl question-memory)
          "coverage" (ngi-candidate-coverage question-selected)
          "levels" (ngi-rule-levels (ngi-candidate-payload question-selected)))
        "alert" (list
          "selected" (ngi-candidate-name alert-selected)
          "rule-mdl" (ngi-candidate-mdl alert-selected)
          "memory-mdl" (ngi-candidate-mdl alert-memory)
          "coverage" (ngi-candidate-coverage alert-selected)
          "levels" (ngi-rule-levels (ngi-candidate-payload alert-selected)))
        "held-out" (list
          (ngi-held-property) property-surface property-back
          (ngi-held-question) question-surface question-back
          (ngi-held-alert) alert-surface alert-back)
        "memorized-held-out" (list property-memory-out question-memory-out
          alert-memory-out)
        "admitted" admitted
        "claim-bound" "two-slot fixed-literal property/question clauses only"
        "not-claimed" "general NL, morphology, lexical translation, language model"
        "framebuffer" report)))
  0)

(nl-grammar-induction-observed-live)
