; jit-post-ingress-sweep.fk - full-track sweep after byte/args ingress.
;
; This compact ledger folds the byte-ingress + native-args contract into the
; full Form-native JIT track. It does not claim completion: the current host
; arbitrary-byte ingress flag remains off until the runtime exposes that bridge.

(do
    (defn jpis-native () 1)
    (defn jpis-deopt () 2)
    (defn jpis-exception () 3)
    (defn jpis-rewalk () 4)
    (defn jpis-melt () 5)
    (defn jpis-reject () 6)
    (defn jpis-pending () 7)

    ; receipt = ("post-ingress-receipt" name total expected source maps)
    (defn jpis-receipt (name total expected source maps)
        (list "post-ingress-receipt" name total expected source maps))
    (defn jpis-receipt? (r) (if (eq (len r) 6) (str_eq (nth r 0) "post-ingress-receipt") 0))
    (defn jpis-total (r) (nth r 2))
    (defn jpis-expected (r) (nth r 3))
    (defn jpis-source (r) (nth r 4))
    (defn jpis-maps (r) (nth r 5))

    (defn jpis-ok? (r)
        (if (eq (jpis-receipt? r) 1)
            (if (eq (jpis-total r) (jpis-expected r))
                (if (eq (jpis-source r) 1)
                    (if (eq (jpis-maps r) 1) 1 0)
                    0)
                0)
            0))

    (defn jpis-full-track () (jpis-receipt "full-track-sweep" 134217727 134217727 1 1))
    (defn jpis-host-membrane () (jpis-receipt "host-membrane-readiness" 524287 524287 1 1))
    (defn jpis-byte-ingress () (jpis-receipt "byte-ingress-args" 2097151 2097151 1 1))
    (defn jpis-call-plan () (jpis-receipt "native-call-plan" 2097151 2097151 1 1))
    (defn jpis-byte-membrane () (jpis-receipt "byte-list-membrane" 134217727 134217727 1 1))
    (defn jpis-host-handoff () (jpis-receipt "host-handoff" 524287 524287 1 1))
    (defn jpis-bad-byte-ingress () (jpis-receipt "byte-ingress-args" 2097150 2097151 1 1))
    (defn jpis-bad-full-track () (jpis-receipt "full-track-sweep" 134217726 134217727 1 1))
    (defn jpis-no-source () (jpis-receipt "native-call-plan" 2097151 2097151 0 1))
    (defn jpis-no-maps () (jpis-receipt "host-membrane-readiness" 524287 524287 1 0))

    (defn jpis-receipts-ok? ()
        (if (eq (jpis-ok? (jpis-full-track)) 1)
            (if (eq (jpis-ok? (jpis-host-membrane)) 1)
                (if (eq (jpis-ok? (jpis-byte-ingress)) 1)
                    (if (eq (jpis-ok? (jpis-call-plan)) 1)
                        (if (eq (jpis-ok? (jpis-byte-membrane)) 1)
                            (if (eq (jpis-ok? (jpis-host-handoff)) 1) 1 0)
                            0)
                        0)
                    0)
                0)
            0))

    ; state = ("post-ingress-state" byte-ingress host-ingress args wx source-ex generation)
    (defn jpis-state (byte-ingress host-ingress args wx source-ex generation)
        (list "post-ingress-state" byte-ingress host-ingress args wx source-ex generation))
    (defn jpis-state? (s) (if (eq (len s) 7) (str_eq (nth s 0) "post-ingress-state") 0))
    (defn jpis-byte-ingress-flag (s) (nth s 1))
    (defn jpis-host-ingress-flag (s) (nth s 2))
    (defn jpis-args (s) (nth s 3))
    (defn jpis-wx (s) (nth s 4))
    (defn jpis-source-ex (s) (nth s 5))
    (defn jpis-generation (s) (nth s 6))

    (defn jpis-state-ready? (s)
        (if (eq (jpis-state? s) 1)
            (if (eq (jpis-receipts-ok?) 1)
                (if (eq (jpis-byte-ingress-flag s) 1)
                    (if (eq (jpis-args s) 1)
                        (if (eq (jpis-wx s) 1)
                            (if (eq (jpis-source-ex s) 1)
                                (if (gt (jpis-generation s) 0) 1 0)
                                0)
                            0)
                        0)
                    0)
                0)
            0))

    (defn jpis-complete? (s)
        (if (eq (jpis-state-ready? s) 1)
            (if (eq (jpis-host-ingress-flag s) 1) 1 0)
            0))

    (defn jpis-action (s guard-ok runtime-ok invalidated parity-ok carrier-ok stale)
        (if (eq (jpis-state-ready? s) 1)
            (if (eq (jpis-host-ingress-flag s) 1)
                (if (eq stale 1)
                    (jpis-melt)
                    (if (eq invalidated 1)
                        (jpis-rewalk)
                        (if (eq carrier-ok 1)
                            (if (eq guard-ok 1)
                                (if (eq runtime-ok 1)
                                    (if (eq parity-ok 1) (jpis-native) (jpis-deopt))
                                    (jpis-exception))
                                (jpis-deopt))
                            (jpis-deopt))))
                (jpis-pending))
            (jpis-reject)))

    (defn jpis-current () (jpis-state 1 0 1 1 1 1))
    (defn jpis-future () (jpis-state 1 1 1 1 1 1))
    (defn jpis-no-byte () (jpis-state 0 1 1 1 1 1))

    (defn jpis-bit (cond bit) (if cond bit 0))
    (defn jit-post-ingress-sweep-check ()
        (add
            (jpis-bit (eq (jpis-receipts-ok?) 1) 1)
            (add
                (jpis-bit (eq (jpis-state-ready? (jpis-current)) 1) 2)
                (add
                    (jpis-bit (eq (jpis-complete? (jpis-current)) 0) 4)
                    (add
                        (jpis-bit (eq (jpis-action (jpis-current) 1 1 0 1 1 0) (jpis-pending)) 8)
                        (add
                            (jpis-bit (eq (jpis-action (jpis-future) 1 1 0 1 1 0) (jpis-native)) 16)
                            (add
                                (jpis-bit (eq (jpis-action (jpis-future) 0 1 0 1 1 0) (jpis-deopt)) 32)
                                (add
                                    (jpis-bit (eq (jpis-action (jpis-future) 1 0 0 1 1 0) (jpis-exception)) 64)
                                    (add
                                        (jpis-bit (eq (jpis-action (jpis-future) 1 1 1 1 1 0) (jpis-rewalk)) 128)
                                        (add
                                            (jpis-bit (eq (jpis-action (jpis-future) 1 1 0 0 1 0) (jpis-deopt)) 256)
                                            (add
                                                (jpis-bit (eq (jpis-action (jpis-future) 1 1 0 1 1 1) (jpis-melt)) 512)
                                                (add
                                                    (jpis-bit (eq (jpis-action (jpis-future) 1 1 0 1 0 0) (jpis-deopt)) 1024)
                                                    (add
                                                        (jpis-bit (eq (jpis-ok? (jpis-bad-byte-ingress)) 0) 2048)
                                                        (add
                                                            (jpis-bit (eq (jpis-ok? (jpis-bad-full-track)) 0) 4096)
                                                            (add
                                                                (jpis-bit (eq (jpis-ok? (jpis-no-source)) 0) 8192)
                                                                (add
                                                                    (jpis-bit (eq (jpis-ok? (jpis-no-maps)) 0) 16384)
                                                                    (add
                                                                        (jpis-bit (eq (jpis-ok? (jpis-call-plan)) 1) 32768)
                                                                        (add
                                                                            (jpis-bit (eq (jpis-ok? (jpis-byte-ingress)) 1) 65536)
                                                                            (add
                                                                                (jpis-bit (eq (jpis-ok? (jpis-host-membrane)) 1) 131072)
                                                                                (add
                                                                                    (jpis-bit (eq (jpis-ok? (jpis-host-handoff)) 1) 262144)
                                                                                    (jpis-bit (eq (jpis-state-ready? (jpis-no-byte)) 0) 524288))))))))))))))))))))

    0)
