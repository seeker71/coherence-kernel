; Live corrected preprocessing shape over the committed human WAV.
;
; The shape and edge-window proof are streamed as separate framebuffer stages
; before the report.  This deliberately does not start the 3,000-column stem
; or 1,500-token encoder: their much larger resource envelope needs its own
; bounded run, while this door answers whether the official input geometry is
; correct and where this cheap proof spent its time.
; witnessed: 2026-07-20 -> real WAV shape/edge windows streamed trace-first
; preludes: form/form-stdlib/core.fk model/whisper-tiny-native-frontend-full-row-major.fk audio/whisper-tiny-centered-preprocess.fk observe/framebuffer-runtime-observation.fk
(do
  (defn wapl-abs-sum (xs acc)
    (if (eq (len xs) 0) acc
      (wapl-abs-sum (tail xs) (add acc (abs (head xs))))))
  (defn wapl-begin (stage parent)
    (do
      (print_str (fbro-cat (list
        "FRAMEBUFFER STAGE-BEGIN trace=whisper-centered-preprocess-shape"
        " stage=" stage " parent=" parent " actor=Sema"
        " relation=corrects-human-speech-input-geometry"
        " why=reject-false-decoder-semantic")))
      (fbro-snapshot)))
  (defn wapl-stage (stage parent before after metric value outcome line)
    (fbro-stage-observed-stream "whisper-centered-preprocess-shape"
      stage parent "Sema" "corrects-human-speech-input-geometry"
      "reject-false-decoder-semantic" "human-truth-book"
      before after metric value outcome
      "observe/whisper-tiny-centered-preprocess-live.fk" line 7))

  (defn whisper-tiny-centered-preprocess-live ()
    (do
      (let path "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav")
      (let window (fbro-open-stream "whisper-centered-preprocess-shape" "Sema"
        "corrects-human-speech-input-geometry" "reject-false-decoder-semantic"
        "human-truth-book" (fs-stat-size path)
        "observe/whisper-tiny-centered-preprocess-live.fk" 34 7))

      (let shape-before (wapl-begin "wav+official-shape" "trace-begin"))
      (let shape (wap-shape-file path))
      (let shape-after (fbro-snapshot))
      (let shape-event (wapl-stage "wav+official-shape" "trace-begin"
        shape-before shape-after "encoder-tokens" (nth shape 15)
        (if (eq (nth shape 17) 1) "3000-to-1500-ready" "held") 41))

      (let edge-before (wapl-begin "centered-edge-windows" "wav+official-shape"))
      (let wav (fs-read-slice path 0 (fs-stat-size path)))
      (let data-offset (wtc-wav-data-offset wav))
      (let samples (wtf-sample-count wav data-offset))
      (let first-mel (wap-log-mel-col wav data-offset samples 0))
      (let last-window (wap-window wav data-offset samples 2999))
      (let last-mel (wap-log-mel-col wav data-offset samples 2999))
      (let first-live (if (gt (wtc-vector-max-go first-mel -10.0) -10.0) 1 0))
      (let padded-zero (if (and (eq (wapl-abs-sum last-window 0.0) 0.0)
        (eq (wtc-vector-max-go last-mel -10.0) -10.0)) 1 0))
      (let edge-after (fbro-snapshot))
      (let edge-event (wapl-stage "centered-edge-windows" "wav+official-shape"
        edge-before edge-after "checked-mel-columns" 2
        (if (and (eq first-live 1) (eq padded-zero 1))
          "reflect-left+zero-tail-observed" "held") 55))

      (let ready (if (and (eq (nth shape 17) 1)
        (and (eq first-live 1) (eq padded-zero 1))) 1 0))
      (let report (fbro-close-stream window
        (if (eq ready 1) "official-input-geometry-ready"
          "official-input-geometry-held")
        (nth shape 15) "observe/whisper-tiny-centered-preprocess-live.fk" 65 7))
      (list "whisper-centered-preprocess-live"
        "source" path "samples" (nth shape 3)
        "trailing-zero-samples" (nth shape 5)
        "center-reflect-samples" (nth shape 7)
        "available-mel-frames" (nth shape 9)
        "segment-mel-frames" (nth shape 11)
        "conv1-tokens" (nth shape 13)
        "conv2-encoder-tokens" (nth shape 15)
        "first-centered-column-live" first-live
        "last-segment-column-zero-padded" padded-zero
        "shape-ready" ready "native-recognizer" 0
        "next-boundary" "full-3000-column-stem+1500-token-encoder-unwitnessed"
        "framebuffer" report)))
  0)

(whisper-tiny-centered-preprocess-live)
