; framebuffer-runtime-acoustic-stage-sample.fk -- immutable per-stage live data.
;
; One direct fkwu run over the committed 22,828-byte CC0 human utterance after
; stage snapshots were added to the framebuffer.  These are observed counter
; deltas, not elapsed-time allocations of the whole-run totals.  The small
; whole-minus-stage remainder is inter-stage observer/event work and stays
; visible rather than being assigned to model stages.
;
; witnessed: 2026-07-20 -> decoder is the duration, dispatch and float-boxing
; bottleneck; generated token still fails the human truth and world stays held
; preludes: form/form-stdlib/core.fk

(do
  ; name, source, line, duration, semantic metric/value/outcome, then exact
  ; dispatch/node/string/arena/stack/float/io deltas from fbro-snapshot.
  (defn fbrass-stage (name line duration-ms metric value outcome dispatches
                       nodes strings arena stack floats io)
    (list name "presence/whisper-tiny-native-acoustic-observed-live.fk"
      line duration-ms metric value outcome dispatches nodes strings arena
      stack floats io))

  (defn fbrass-live-20260720 ()
    (list "framebuffer-runtime-acoustic-stage-sample"
      "2026-07-20T12:26:55+08:00"
      "fkwu"
      "model/fixtures/whisper-tiny/lingua-libre-book-16k.wav"
      22828
      (list
        (fbrass-stage "source-verified" 40 22 "wav-bytes" 22828
          "verified-human-cc0" 5435934 0 1 54 0 0 4)
        (fbrass-stage "encoder-complete" 47 57377 "causal-parameters" 7633152
          "complete" 4778121041 0 5954 49035 0 392195261 5646)
        (fbrass-stage "decoder-complete" 57 66335 "causal-parameters" 9506304
          "complete" 9487930216 0 8 110353 0 878432521 8)
        (fbrass-stage "vocabulary-scanned" 70 31978 "rows" 51865
          "complete" 5260368199 0 812 26483 0 475287535 1622)
        (fbrass-stage "world-gate" 79 0 "admitted" 0
          "held-no-native-text" 1276 0 0 58 0 0 0))
      155712
      19531866065
      68
      6775
      186476
      1745915317
      7280
      7
      5
      50257
      0.10745982571117452
      0
      "native-stages-complete-world-held-no-generated-text"
      (list "duration-ms" "decoder-complete" 66335
            "dispatches" "decoder-complete" 9487930216
            "boxed-floats" "decoder-complete" 878432521)
      "stage-deltas-exclude-inter-stage-observer-work"))
)
