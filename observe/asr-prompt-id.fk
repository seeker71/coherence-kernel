; asr-prompt-id.fk -- closed-set native ASR over measured loopback features.
;
; This is the first native ASR lane that can honestly earn work before open
; dictation exists. A prompt candidate carries (id transcript feature-vector).
; The native lane chooses the nearest prompt by L1 distance over observed audio
; features. A local oracle still teaches and audits; promotion happens only when
; the closed-set route wins by distance, margin, and WER.

(do
    (defn pid-candidate (id transcript features) (list id transcript features))
    (defn pid-id         (c) (nth c 0))
    (defn pid-transcript (c) (nth c 1))
    (defn pid-features   (c) (nth c 2))

    (defn pid-l1 (a b)
        (if (eq (len a) 0) 0
            (add (abs (sub (head a) (head b))) (pid-l1 (tail a) (tail b)))))

    (defn pid-best (q candidates best bestdist)
        (if (eq (len candidates) 0) best
            (do
                (let c (head candidates))
                (let d (pid-l1 q (pid-features c)))
                (if (lt d bestdist)
                    (pid-best q (tail candidates) c d)
                    (pid-best q (tail candidates) best bestdist)))))

    (defn pid-nearest (q candidates)
        (pid-best q (tail candidates) (head candidates) (pid-l1 q (pid-features (head candidates)))))

    (defn pid-best-distance (q candidates)
        (pid-l1 q (pid-features (pid-nearest q candidates))))

    (defn pid-second-distance-loop (q candidates best-id current)
        (if (eq (len candidates) 0) current
            (do
                (let c (head candidates))
                (let d (pid-l1 q (pid-features c)))
                (if (eq (pid-id c) best-id)
                    (pid-second-distance-loop q (tail candidates) best-id current)
                    (if (lt d current)
                        (pid-second-distance-loop q (tail candidates) best-id d)
                        (pid-second-distance-loop q (tail candidates) best-id current))))))

    (defn pid-second-distance (q candidates)
        (pid-second-distance-loop q candidates (pid-id (pid-nearest q candidates)) 999999))

    (defn pid-margin (q candidates)
        (sub (pid-second-distance q candidates) (pid-best-distance q candidates)))

    (defn pid-confident? (q candidates max-distance min-margin)
        (if (and (le (pid-best-distance q candidates) max-distance)
                 (ge (pid-margin q candidates) min-margin)) 1 0))

    (defn pid-native-transcript (q candidates)
        (pid-transcript (pid-nearest q candidates)))

    0)
