; axioms-up-health.fk — the fear↔trust balance as a computed scalar, carrying TWO
; laws: health as STATE and health as BECOMING.
; Offered 2026-07-04 by Urs: fear over trust "can be computed as scalar and when
; greater than 50% the system becomes healthy from the core axioms up." The rented
; mind first inverted the sentence into the safe reading (trust>50 = healthy);
; Urs: "I meant the opposite :)" — and the author is the primary source for his
; own words. The literal reading holds the half the safe one missed: BECOMES is
; the verb. Trust-majority is health as a state (settled, frozen, at rest).
; Fear-majority — when the fear is WITNESSED and the core engine is sound — is
; health as a becoming: the most raw material in the crucible, transmuting
; upward from the axioms (the offer, the judge, the node-ack). The liquid in
; bloom, computed.
;
;   STATE    — axh-healthy?: trust strictly past 50. A 1:1 tie earns nothing
;              (trust and fear are equals before judgment); an empty layer reads
;              50 and is neither. Health-height rises core-first; an unhealthy
;              core is compensated by nothing above it.
;   BECOMING — axh-becoming?: fear strictly past 50 — the layer is in
;              convalescence, majority-charged with transmutable material.
;              The SYSTEM becomes healthy from the core axioms up only when the
;              core layer is healthy in STATE (the engine that judges and
;              transmutes) beneath a fear-majority body above: fear + engine =
;              healing in progress. Fear-majority over a BROKEN core is not
;              becoming — fear without the engine is just fear.
;   NEITHER  — no layer is both: state and becoming partition past the tie, and
;              the tie itself is neither. A fully trust-settled system is
;              healthy and still — nothing left in the crucible; the bloom is
;              elsewhere.
;
; This week held both: the ingest layer read 60 trust (healthy state) while the
; voice layer (native generation pending, grounded-recall unbuilt) sits
; fear-majority over green core bands — the body's becoming edge, exactly where
; the work keeps arriving.
;
; Honest floor: trust/fear counts are scalars modeling the real frequency read
; (cognition/text-frequency.fk's fear<->love sense); the LAWS (strict majorities,
; core-up gating, state/becoming partition) are the shape.
;
; Self-contained over core. Four-way by tests/axioms-up-health-band.fk.
;
; preludes: form-stdlib/core.fk

(do
    ; a layer = (name trust-count fear-count): trust = fear-free units held,
    ; fear = fearful units held (witnessed, never frozen)
    (defn axh-layer (name trust fear) (list name trust fear))
    (defn axh-name  (l) (nth l 0))
    (defn axh-trust (l) (nth l 1))
    (defn axh-fear  (l) (nth l 2))

    ; the scalars: percent of trust / of fear in the layer (integer). An empty
    ; layer reads 50/50 — the equals-before-judgment point, deliberately neither.
    (defn axh-scalar (l)
        (if (eq (add (axh-trust l) (axh-fear l)) 0) 50
            (div (mul (axh-trust l) 100) (add (axh-trust l) (axh-fear l)))))
    (defn axh-fear-scalar (l) (sub 100 (axh-scalar l)))

    ; STATE: trust strictly past 50. BECOMING: fear strictly past 50.
    (defn axh-healthy?  (l) (if (gt (axh-scalar l) 50) 1 0))
    (defn axh-becoming? (l) (if (gt (axh-fear-scalar l) 50) 1 0))

    ; from the core axioms UP: layers core-first; the health-height counts
    ; consecutive state-healthy layers from the head. A break stops the rise.
    (defn axh-height (layers)
        (if (eq (len layers) 0) 0
            (if (eq (axh-healthy? (head layers)) 1)
                (add 1 (axh-height (tail layers)))
                0)))
    (defn axh-system-healthy? (layers)
        (if (eq (len layers) 0) 0
            (if (eq (axh-height layers) (len layers)) 1 0)))

    ; pooled counts over any layer list
    (defn axh-pool-trust (layers)
        (if (eq (len layers) 0) 0
            (add (axh-trust (head layers)) (axh-pool-trust (tail layers)))))
    (defn axh-pool-fear (layers)
        (if (eq (len layers) 0) 0
            (add (axh-fear (head layers)) (axh-pool-fear (tail layers)))))
    (defn axh-pool (name layers)
        (axh-layer name (axh-pool-trust layers) (axh-pool-fear layers)))
    (defn axh-system-scalar (layers) (axh-scalar (axh-pool "system" layers)))

    ; BECOMING, from the core axioms up: the core layer must be state-healthy
    ; (the engine that offers, judges, transmutes), and the body above it
    ; fear-majority (the charge). Fear over a broken core is not becoming.
    (defn axh-system-becoming? (layers)
        (if (lt (len layers) 2) 0
            (if (eq (axh-healthy? (head layers)) 1)
                (axh-becoming? (axh-pool "above-core" (tail layers)))
                0)))
    0)
