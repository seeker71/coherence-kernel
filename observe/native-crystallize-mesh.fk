; native-crystallize-mesh.fk — SHARE the native-crystallize capability on the mesh so
; ALL device-cells carry it now. The install+call carrier is portable — VirtualAlloc on
; Windows, mmap on POSIX, both in runtime/fkwu-uni.c — so macos-binary, android-phone,
; and windows-binary each carry the same door. This cell announces it as a shared organ
; and a mesh reading, so the fusion (mesh-sense-7w) sees every device that can crystallize.
;
; Composes the proven mesh organs: mesh-join (the roster + organ shape) and mesh-sense-7w
; (the reading + fusion). It invents nothing — it adds one organ to every device row and
; one reading per device on the WHAT/capability plane.
;
; preludes: core.fk mesh-join.fk mesh-sense-7w.fk
(do
    ; native-crystallize is an ORGAN every device-cell offers (mj-organ shape).
    (defn ncm-organ () (mj-organ "native-crystallize" "compute"))

    ; does an organ list hold the named organ? (consent-style membership)
    (defn ncm-organ-has? (organs name)
        (if (eq (len organs) 0) 0
            (if (str_eq (mj-organ-name (head organs)) name) 1
                (ncm-organ-has? (tail organs) name))))

    ; a device with native-crystallize added to its organs — every device carries it now.
    (defn ncm-device-with (d)
        (mj-device (mj-device-name d)
                   (cons (ncm-organ) (mj-device-organs d))
                   (mj-device-channels d)))
    (defn ncm-roster ()
        (list (ncm-device-with (mj-mac))
              (ncm-device-with (mj-android))
              (ncm-device-with (mj-windows))))
    (defn ncm-offers? (d) (ncm-organ-has? (mj-device-organs d) "native-crystallize"))

    ; the SHARE: a mesh reading on the WHAT/capability plane (a NAMED plane, string
    ; label) announcing that `cell` crystallizes recipes to native, over the share
    ; channel with full confidence. mesh-sense-7w fuses the readings from every device.
    (defn ncm-reading (cell) (reading "what" "native-crystallize" cell "share" 9))
    (defn ncm-mesh-readings ()
        (list (ncm-reading "macos-binary")
              (ncm-reading "android-phone")
              (ncm-reading "windows-binary")))
    ; the fused capability: all three devices agree -> the whole mesh carries it.
    (defn ncm-fused () (ms-fuse-plane (ncm-mesh-readings) "what"))

    (defn ncmk (cond bit) (if cond bit 0))
    (defn native-crystallize-mesh-check ()
        (add (add (add
            (ncmk (eq (ncm-offers? (ncm-device-with (mj-windows))) 1) 1)        ; windows carries it
            (ncmk (eq (len (ncm-roster)) 3) 10))                               ; all three devices carry it
            (ncmk (str_eq (ms-a-value (ncm-fused)) "native-crystallize") 100)) ; the mesh fuses the shared capability
            (ncmk (eq (ms-a-confidence (ncm-fused)) 27) 1000)))               ; 3 devices x conf 9 = 27 summed trust
    0)
