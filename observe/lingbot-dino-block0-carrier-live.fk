; Live per-record provenance for the complete released DINO block-0 carrier.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk form/form-stdlib/transformer-numerics.fk form/form-stdlib/transformer-block.fk form/form-stdlib/transformer-mh.fk form/form-stdlib/transformer-gelu-erf.fk model/released-row-major-affine.fk model/lingbot-dino-block0.fk

(do
  (defn ldb0cl-row (loaded ordinal)
    (do (let row (nth loaded ordinal))
        (let entry (nth row 0))
        (list (add 9 ordinal) (lbpt-entry-size entry) (lbpt-entry-crc entry)
          (str_len (nth row 1)) (nth row 2))))
  (defn ldb0cl-rows (loaded ordinal)
    (if (eq ordinal 14) (empty)
      (cons (ldb0cl-row loaded ordinal)
        (ldb0cl-rows loaded (add ordinal 1)))))
  (defn lingbot-dino-block0-carrier-live ()
    (do (let loaded (ldb0-load))
        (list "lingbot-dino-block0-carrier-live"
          (fs-stat-size (ldb0-path)) (ldb0-valid? loaded)
          (ldb0cl-rows loaded 0))))
  (lingbot-dino-block0-carrier-live)
)
