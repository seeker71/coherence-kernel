; Exact released checkpoint directory rows for DINOv2-L/14 block 0.
; This observes ZIP provenance only; it performs no model arithmetic.
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/form-fs.fk form/form-stdlib/file-byte-window.fk form/form-stdlib/crc32.fk model/lingbot-pytorch-checkpoint.fk

(do
  (defn ldb0l-directory-path ()
    "model/fixtures/lingbot-map/checkpoint-central-directory.bin")
  (defn ldb0l-directory ()
    (fs-read-slice (ldb0l-directory-path) 0 (fs-stat-size (ldb0l-directory-path))))
  (defn ldb0l-entry-row (directory index)
    (do (let entry (lbpt-find-entry directory
          (str_concat "checkpoint/data/" (int_to_str index))))
        (list index (lbpt-entry-name entry) (lbpt-entry-crc entry)
          (lbpt-entry-size entry) (lbpt-entry-local-offset entry)
          (lbpt-entry-method entry) (lbpt-entry-flags entry))))
  (defn ldb0l-rows-go (directory index end out)
    (if (gt index end) (reverse out)
      (ldb0l-rows-go directory (add index 1) end
        (cons (ldb0l-entry-row directory index) out))))
  (defn lingbot-dino-block0-checkpoint-layout ()
    (do (let directory (ldb0l-directory))
        (list "lingbot-dino-block0-checkpoint-layout"
          (ldb0l-rows-go directory 9 23 (empty)))))
  (lingbot-dino-block0-checkpoint-layout)
)
