; concept-false-semantic-alias-rejection-observed.fk
; Trace-first production witness that every repaired junk surface is rejected
; by semantic detection while remaining attributable as migration evidence.
; witnessed: 2026-07-20 -> 111/111 false aliases rejected, 111/111 migration
; rows traceable, canonical welcoming -> stable id 104
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000-substantive-repair-data.fk model/concept-10000.fk observe/framebuffer-runtime-observation.fk
(do
  (defn cfsar-observed ()
    (do
      (let window (fbro-open-stream "false-semantic-alias-rejection" "Sema"
        "repairs-concept-detector" "remove-false-semantic-results"
        "canonical-production-meaning" 548886
        "observe/concept-false-semantic-alias-rejection-observed.fk" 11 7))
      (let before (fbro-snapshot))
      (let audit (c10-legacy-migration-audit))
      (let after (fbro-snapshot))
      (let rejected (nth audit 1))
      (let outcome (if (and (value_eq audit (list 111 111 111))
        (and (c10-missing? (c10-detect-text "didn"))
          (eq (c10-concept-id (c10-detect-text "welcoming")) 104)))
        "all-false-aliases-rejected" "semantic-rejection-failed"))
      (let stage (fbro-stage-observed-stream "false-semantic-alias-rejection"
        "audit-all-legacy-surfaces" "trace-begin" "Sema"
        "repairs-concept-detector" "remove-false-semantic-results"
        "canonical-production-meaning" before after "rejected-surfaces" rejected
        outcome "observe/concept-false-semantic-alias-rejection-observed.fk" 24 7))
      (let report (fbro-close-stream window outcome rejected
        "observe/concept-false-semantic-alias-rejection-observed.fk" 27 7))
      (list audit outcome (fbro-trace-first? report)
        (fbro-bottleneck report "dispatches") report)))
  0)
