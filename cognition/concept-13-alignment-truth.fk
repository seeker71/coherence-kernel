; concept-13-alignment-truth.fk -- do not confuse shared rows with translation.
;
; Three different evidence planes had been allowed to sit too close together:
; independent attributed Tatoeba sentences, concept-aligned lexical labels, and
; machine-translated lexical repairs.  This cell counts each plane from its
; pinned state and gives sentence alignment its own explicit zero.
;
; A common concept id is not a human translation pair.  A Tatoeba sentence in
; each locale is not aligned unless a retained Tatoeba link says so.  The
; The retained English->Swahili fixture now carries 94 direct translation
; edges with both attributed endpoints; 15 are held out.  Its executable
; source-copy baseline scores 0/15, so the evaluation door is real while the
; translation-success claim remains zero.  The BUNGE
; overlay is dataset-attributed human-source text, but its cleaned lines are
; not sentence-explicit and it carries neither individual authors nor targets.
; witnessed: 2026-07-20 -> 94 retained human-contributed unreviewed en-sw
; pairs, 15 held out, source-copy exact 0/15; lexical matrix is F=10000
; W=34941 D=16621 C=68 G=68370 absent=0
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-human-corpus-13-metadata.fk cognition/concept-human-corpus-130000-metadata.fk observe/framebuffer-runtime-observation.fk

(do
  (defn c13a-tatoeba-old-new-overlap () 718)
  (defn c13a-tatoeba-distinct-monolingual-rows ()
    (sub (add (hcnl13-row-count) (chc130-observed-rows))
         (c13a-tatoeba-old-new-overlap)))
  (defn c13a-retained-translation-links () 94)
  (defn c13a-human-aligned-sentence-pairs () 94)
  (defn c13a-human-reviewed-aligned-sentence-pairs () 0)
  (defn c13a-heldout-human-evaluation-pairs () 15)
  (defn c13a-heldout-translation-successes () 0)
  (defn c13a-source-counts (sources)
    (list
      "frequency-anchor" (cnl13-count-source sources "F")
      "wiktionary-omw-mapped-unreviewed" (cnl13-count-source sources "W")
      "dedicated-wordnet-mapped-unreviewed" (cnl13-count-source sources "D")
      "cldr-wordnet-mapped-unreviewed" (cnl13-count-source sources "C")
      "google-machine-translated-unreviewed" (cnl13-count-source sources "G")
      "absent" (cnl13-count-source sources "0")))
  (defn c13a-count-values (counts i total)
    (if (ge i (len counts)) total
      (c13a-count-values counts (add i 2) (add total (nth counts (add i 1))))))
  (defn c13a-observe ()
    (do
      (let window (fbro-open-stream "concept-13-alignment-truth"
        "Sema" "separates-alignment-from-co-presence"
        "measure-real-translation-evidence-before-claim"
        "held-out-human-pairs-required" 130000
        "cognition/concept-13-alignment-truth.fk" 39 7))
      (let before (fbro-snapshot))
      (let sources (read_file (cnl13-source-codes-path)))
      (let counts (c13a-source-counts sources))
      (let matrix-cells (c13a-count-values counts 0 0))
      (let after (fbro-snapshot))
      (let complete (and (eq (str_len sources) 130000)
                         (eq matrix-cells 130000)))
      (let outcome (if complete "alignment-floor-measured"
        "source-matrix-incomplete"))
      (let stage (fbro-stage-observed-stream "concept-13-alignment-truth"
        "classify-provenance-cells" "trace-begin" "Sema"
        "separates-alignment-from-co-presence"
        "measure-real-translation-evidence-before-claim"
        "held-out-human-pairs-required" before after "matrix-cells"
        matrix-cells outcome "cognition/concept-13-alignment-truth.fk" 56 7))
      (let report (fbro-close-stream window outcome matrix-cells
        "cognition/concept-13-alignment-truth.fk" 59 7))
      (list "concept-13-alignment-truth" report
        "distinct-attributed-tatoeba-monolingual-sentences"
          (c13a-tatoeba-distinct-monolingual-rows)
        "tatoeba-translation-links-retained" (c13a-retained-translation-links)
        "human-aligned-sentence-pairs" (c13a-human-aligned-sentence-pairs)
        "human-reviewed-aligned-sentence-pairs"
          (c13a-human-reviewed-aligned-sentence-pairs)
        "held-out-human-translation-evaluation-pairs"
          (c13a-heldout-human-evaluation-pairs)
        "held-out-translation-successes"
          (c13a-heldout-translation-successes)
        "held-out-baseline" "source-copy-exact-0-of-15"
        "bunge-human-source-text-passages" 5417
        "bunge-sentence-explicit" 0
        "bunge-source-target-aligned" 0
        "concept-aligned-lexical-cells" counts
        "nonmachine-mapped-unreviewed-lexical-cells" 51630
        "machine-translated-unreviewed-lexical-cells" 68370
        "human-reviewed-lexical-cells" 0
        "lexical-cell-total" matrix-cells
        "general-or-infinite-translation-proven" 0)))
)
