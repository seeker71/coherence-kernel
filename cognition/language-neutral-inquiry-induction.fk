; language-neutral-inquiry-induction.fk — compute neutral identity from aligned
; locale evidence, then open every inquiry lane from that identity.
;
; No surface alias table lives here. The resolver locates a complete token
; sequence in the attributed locale baseline, derives identity from its neutral
; meaning coordinate, and converts that identity into a valid recursive inquiry
; path. Adding another ready locale or meaning row extends coverage without a
; code change.
import "language-neutral-symbol-identity.fk"
import "native-inquiry-derivation.fk"
import "../learn/sanskrit-locale-baseline.fk"

(do
  (defn lnii-node-for-meaning (meaning)
    (if (gt meaning 0) (lnsi-node 1 1 10 meaning) (nothing)))

  (defn lnii-resolve (locale tokens)
    (lnii-node-for-meaning (slb-meaning-for-tokens locale tokens)))

  ; Encode an arbitrary positive canonical id as a base-8 inquiry path whose
  ; digits are only 0..6. This preserves the no-digit-7 invariant.
  (defn lnii-subject-go (n)
    (if (eq n 0) 1
      (nid-child (lnii-subject-go (div n 7)) (mod n 7))))
  (defn lnii-subject (node)
    (if (nothing? node) (nothing) (lnii-subject-go node)))

  (defn lnii-lanes-ok (subject lane count)
    (if (ge lane 7) count
      (do (let proof (nid-inquire subject lane 1))
        (let replay (nid-replay (nid-p-receipt proof)))
        (lnii-lanes-ok subject (add lane 1)
          (add count (if (and (eq (nid-p-reason proof) 0)
            (and (eq (nid-p-ack replay) 1)
            (and (eq (nid-p-reason replay) 0)
            (and (eq (nid-valid? (nid-p-alt proof)) 1)
                 (eq (nid-valid? (nid-p-alt replay)) 1))))) 1 0))))))

  ; Accumulator: [resolved surfaces, converged identities, inquiry replays].
  (defn lnii-observe-locales (row locales acc)
    (if (eq (len locales) 0) acc
      (do (let locale-row (head locales))
        (let code (slb-loc-code locale-row))
        (let tokens (slb-tokens row code))
        (if (or (eq (slb-loc-ready locale-row) 0) (eq (len tokens) 0))
          (lnii-observe-locales row (tail locales) acc)
          (do (let node (lnii-resolve code tokens))
            (let expected (lnii-node-for-meaning (slb-meaning row)))
            (let converged (if (eq node expected) 1 0))
            (let lanes (if (eq converged 1)
              (lnii-lanes-ok (lnii-subject node) 0 0) 0))
            (lnii-observe-locales row (tail locales)
              (list (add (nth acc 0) 1)
                    (add (nth acc 1) converged)
                    (add (nth acc 2) lanes))))))))

  (defn lnii-observe-rows (rows locales acc)
    (if (eq (len rows) 0) acc
      (lnii-observe-rows (tail rows) locales
        (lnii-observe-locales (head rows) locales acc))))

  (defn lnii-witness ()
    (do (let observed (lnii-observe-rows (slb-lines) (slb-locales) (list 0 0 0)))
      (let surfaces (nth observed 0))
      (let converged (nth observed 1))
      (let inquiries (nth observed 2))
      (let unknown (lnii-resolve "sa" (list "not" "a" "known" "row")))
      (let expected-inquiries (mul surfaces 7))

      ; Observe the coverage change rather than merely reporting it.
      (let before (list (fb-frame 0 1 1) (fb-frame 1 2 1)))
      (let after (list (fb-frame 0 1 1) (fb-frame 1 surfaces 1)))
      (let coverage-divergence (diverge before after))
      (framebuffer-clear)
      (let event0 (fb_record (intern_trivial_int 2)
        "language-neutral-inquiry-induction.fk" 1))
      (let event1 (fb_record (intern_trivial_int surfaces)
        "language-neutral-inquiry-induction.fk" 2))
      (let event2 (fb_record (intern_trivial_int inquiries)
        "language-neutral-inquiry-induction.fk" 3))
      (let runtime-frames (len (framebuffer-events)))
      (list (nothing) 0 1 1001099002
        2 surfaces converged expected-inquiries inquiries
        coverage-divergence runtime-frames unknown
        (if (and (gt surfaces 2)
          (and (eq surfaces converged)
          (and (eq inquiries expected-inquiries)
          (and (eq coverage-divergence 1)
          (and (eq runtime-frames 3)
               (nothing? unknown)))))) 1 0))))
  0)
