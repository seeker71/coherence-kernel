; concept-nl-semantic-13-runtime.fk — operational carrier for the pinned table.
;
; The pure cell keeps data and offsets explicit so proof siblings can witness
; its meaning. This carrier performs the one host effect: opening the committed
; TSV, then presenting a reusable runtime value to live cognition callers.
; witnessed: 2026-07-18 -> 8191 live fkwu
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk
(do
  ; runtime = (loaded UTF-8 TSV, generated byte-offset index)
  (defn cnl13-runtime-open ()
    (list (read_file (cnl13-data-path)) (cnl13-offsets)))
  (defn cnl13-runtime-data (runtime) (nth runtime 0))
  (defn cnl13-runtime-offsets (runtime) (nth runtime 1))

  (defn cnl13-runtime-lookup (runtime index code)
    (cnl13-lookup (cnl13-runtime-data runtime)
                  (cnl13-runtime-offsets runtime) index code))
  (defn cnl13-runtime-generate (runtime index code)
    (cnl13-generate (cnl13-runtime-data runtime)
                    (cnl13-runtime-offsets runtime) index code))
  (defn cnl13-runtime-detect-first (runtime code label)
    (cnl13-detect-first (cnl13-runtime-data runtime)
                        (cnl13-runtime-offsets runtime) code label))
  (defn cnl13-runtime-count-present (runtime code)
    (cnl13-count-present (cnl13-runtime-data runtime)
                         (cnl13-runtime-offsets runtime) code))
)
