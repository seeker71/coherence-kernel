; pl-lenses-13.fk — Form-native registry, detection, and bounded generation
; across thirteen widely used programming-language surfaces.
;
; The audit behind this organ found:
;   - languages.ts has substrate language cells and parse/emit walkers for
;     Python, TypeScript, Go, and Rust, but that authority lives in the foreign
;     TypeScript kernel family rather than this direct fkwu source path;
;   - seedbank/emits carries Form emit templates for those same four;
;   - lang-common.fk carries shared imperative expression grammar;
;   - source-compiler-text-lens emits Form source, not arbitrary foreign code.
;
; This cell closes a narrower native floor today: registry data, ranked lexical
; detection over real snippets, and exact binary-function generation for
; add/subtract/multiply. It does not claim thirteen parsers, AST round-tripping,
; name escaping, type checking, compilation, execution, or arbitrary
; transpilation. Division is excluded because integer semantics differ across
; these surfaces. Detection is evidence-scoring, not a proof of language.
; witnessed: 2026-07-18 -> band 1048575 four-way (fkwu/Go/Rust/TypeScript)
; preludes: form/form-stdlib/core.fk

(do
  ; lens = (id display extension markers fixture typing line-comment)
  (defn pl13-lens (id display extension markers fixture typing comment)
    (list id display extension markers fixture typing comment))
  (defn pl13-id (lens) (nth lens 0))
  (defn pl13-name (lens) (nth lens 1))
  (defn pl13-extension (lens) (nth lens 2))
  (defn pl13-markers (lens) (nth lens 3))
  (defn pl13-fixture (lens) (nth lens 4))
  (defn pl13-typing (lens) (nth lens 5))
  (defn pl13-comment (lens) (nth lens 6))

  ; Each fixture is executable-looking source from its actual surface, not a
  ; language name pasted into a generic placeholder.
  (defn pl13-registry ()
    (list
      (pl13-lens "python" "Python" ".py"
        (list "pl13-language[python]" "from " "def " "print(" "f\"")
        "from pathlib import Path\n\ndef greet(name):\n    print(f\"Hello {name}\")\n"
        "dynamic" "#")
      (pl13-lens "javascript" "JavaScript" ".js"
        (list "pl13-language[javascript]" "const " "=>" "console.log(")
        "const greet = (name) => {\n  console.log(\"Hello \" + name);\n};\n"
        "dynamic" "//")
      (pl13-lens "typescript" "TypeScript" ".ts"
        (list "pl13-language[typescript]" "interface " ": string" "const " "=>")
        "interface User { name: string }\nconst greet = (user: User): string => user.name;\n"
        "static-gradual" "//")
      (pl13-lens "java" "Java" ".java"
        (list "pl13-language[java]" "public static" "System.out." "class ")
        "public final class Hello {\n  public static void main(String[] args) { System.out.println(\"hi\"); }\n}\n"
        "static" "//")
      (pl13-lens "c" "C" ".c"
        (list "pl13-language[c]" "#include <stdio.h>" "int main(" "printf(")
        "#include <stdio.h>\nint main(void) { printf(\"hi\\n\"); return 0; }\n"
        "static-manual-memory" "//")
      (pl13-lens "cpp" "C++" ".cpp"
        (list "pl13-language[cpp]" "#include <iostream>" "std::" "cout")
        "#include <iostream>\nint main() { std::cout << \"hi\\n\"; }\n"
        "static-raii" "//")
      (pl13-lens "csharp" "C#" ".cs"
        (list "pl13-language[csharp]" "using System;" "namespace " "Console.WriteLine(")
        "using System;\nnamespace Demo { class Hello { static void Main() { Console.WriteLine(\"hi\"); } } }\n"
        "static-managed" "//")
      (pl13-lens "go" "Go" ".go"
        (list "pl13-language[go]" "package main" "func " "fmt.")
        "package main\nimport \"fmt\"\nfunc main() { fmt.Println(\"hi\") }\n"
        "static-gc" "//")
      (pl13-lens "rust" "Rust" ".rs"
        (list "pl13-language[rust]" "fn main(" "let mut " "println!(")
        "fn main() { let mut n: i64 = 1; n += 1; println!(\"{n}\"); }\n"
        "static-ownership" "//")
      (pl13-lens "ruby" "Ruby" ".rb"
        (list "pl13-language[ruby]" "puts " "def " "\nend")
        "class Greeter\n  def greet(name)\n    puts \"Hello #{name}\"\n  end\nend\n"
        "dynamic" "#")
      (pl13-lens "php" "PHP" ".php"
        (list "pl13-language[php]" "<?php" "$" "echo ")
        "<?php\n$name = \"world\";\necho \"Hello $name\";\n?>\n"
        "dynamic-gradual" "//")
      (pl13-lens "swift" "Swift" ".swift"
        (list "pl13-language[swift]" "import Foundation" "func " "let ")
        "import Foundation\nfunc greet(_ name: String) -> String { let prefix = \"Hello \"; return prefix + name }\n"
        "static-arc" "//")
      (pl13-lens "kotlin" "Kotlin" ".kt"
        (list "pl13-language[kotlin]" "data class " "val " "fun main(" "println(")
        "data class User(val name: String)\nfun main() { println(User(\"Ada\").name) }\n"
        "static-managed" "//")))

  (defn pl13-find (id lenses)
    (if (eq (len lenses) 0) (empty)
      (if (str_eq id (pl13-id (head lenses))) (head lenses)
        (pl13-find id (tail lenses)))))
  (defn pl13-lens-by-id (id) (pl13-find id (pl13-registry)))

  (defn pl13-marker-score (source markers score)
    (if (eq (len markers) 0) score
      (pl13-marker-score source (tail markers)
        (add score (if (ge (str_find source (head markers) 0) 0) 1 0)))))
  (defn pl13-score (source lens)
    (pl13-marker-score source (pl13-markers lens) 0))
  (defn pl13-ranked-go (source lenses out)
    (if (eq (len lenses) 0) (reverse out)
      (pl13-ranked-go source (tail lenses)
        (cons (list (pl13-id (head lenses)) (pl13-score source (head lenses))) out))))
  (defn pl13-detection-evidence (source)
    (pl13-ranked-go source (pl13-registry) (empty)))
  (defn pl13-best-go (source lenses best best-score)
    (if (eq (len lenses) 0)
      (if (eq best-score 0) "unknown" (pl13-id best))
      (do
        (let candidate (head lenses))
        (let score (pl13-score source candidate))
        (if (gt score best-score)
          (pl13-best-go source (tail lenses) candidate score)
          (pl13-best-go source (tail lenses) best best-score)))))
  (defn pl13-detect (source)
    (pl13-best-go source (pl13-registry) (empty) 0))

  ; The language-neutral input recipe for this rung.
  ; op is exactly one of add/sub/mul; names are assumed already valid.
  (defn pl13-binary-spec (name left right op)
    (list name left right op))
  (defn pl13-spec-name (spec) (nth spec 0))
  (defn pl13-spec-left (spec) (nth spec 1))
  (defn pl13-spec-right (spec) (nth spec 2))
  (defn pl13-spec-op (spec) (nth spec 3))
  (defn pl13-op-supported (op)
    (if (str_eq op "add") 1
      (if (str_eq op "sub") 1 (if (str_eq op "mul") 1 0))))
  (defn pl13-op-symbol (op)
    (if (str_eq op "add") "+"
      (if (str_eq op "sub") "-" (if (str_eq op "mul") "*" ""))))
  (defn pl13-expression (left op right)
    (str_concat left (str_concat " " (str_concat op (str_concat " " right)))))

  (defn pl13-gen-python (spec symbol)
    (str_concat "def " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat ", " (str_concat (pl13-spec-right spec)
      (str_concat "):\n    return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) "\n")))))))))
  (defn pl13-gen-javascript (spec symbol)
    (str_concat "function " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat ", " (str_concat (pl13-spec-right spec)
      (str_concat ") {\n  return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) ";\n}\n")))))))))
  (defn pl13-gen-typescript (spec symbol)
    (str_concat "function " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat ": number, " (str_concat (pl13-spec-right spec)
      (str_concat ": number): number {\n  return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) ";\n}\n")))))))))
  (defn pl13-gen-c-family (spec symbol)
    (str_concat "int " (str_concat (pl13-spec-name spec)
      (str_concat "(int " (str_concat (pl13-spec-left spec)
      (str_concat ", int " (str_concat (pl13-spec-right spec)
      (str_concat ") {\n  return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) ";\n}\n")))))))))
  (defn pl13-gen-java-family (spec symbol)
    (str_concat "static int " (str_concat (pl13-spec-name spec)
      (str_concat "(int " (str_concat (pl13-spec-left spec)
      (str_concat ", int " (str_concat (pl13-spec-right spec)
      (str_concat ") {\n  return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) ";\n}\n")))))))))
  (defn pl13-gen-go (spec symbol)
    (str_concat "func " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat " int, " (str_concat (pl13-spec-right spec)
      (str_concat " int) int {\n\treturn "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) "\n}\n")))))))))
  (defn pl13-gen-rust (spec symbol)
    (str_concat "fn " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat ": i64, " (str_concat (pl13-spec-right spec)
      (str_concat ": i64) -> i64 {\n    "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) "\n}\n")))))))))
  (defn pl13-gen-ruby (spec symbol)
    (str_concat "def " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat ", " (str_concat (pl13-spec-right spec)
      (str_concat ")\n  "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) "\nend\n")))))))))
  (defn pl13-gen-php (spec symbol)
    (str_concat "function " (str_concat (pl13-spec-name spec)
      (str_concat "($" (str_concat (pl13-spec-left spec)
      (str_concat ", $" (str_concat (pl13-spec-right spec)
      (str_concat ") {\n  return $"
        (str_concat (pl13-spec-left spec) (str_concat " " (str_concat symbol
        (str_concat " $" (str_concat (pl13-spec-right spec) ";\n}\n")))))))))))))
  (defn pl13-gen-swift (spec symbol)
    (str_concat "func " (str_concat (pl13-spec-name spec)
      (str_concat "(_ " (str_concat (pl13-spec-left spec)
      (str_concat ": Int, _ " (str_concat (pl13-spec-right spec)
      (str_concat ": Int) -> Int {\n    return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) "\n}\n")))))))))
  (defn pl13-gen-kotlin (spec symbol)
    (str_concat "fun " (str_concat (pl13-spec-name spec)
      (str_concat "(" (str_concat (pl13-spec-left spec)
      (str_concat ": Int, " (str_concat (pl13-spec-right spec)
      (str_concat ": Int): Int {\n    return "
        (str_concat (pl13-expression (pl13-spec-left spec) symbol (pl13-spec-right spec)) "\n}\n")))))))))

  (defn pl13-generate-supported (language spec symbol)
    (if (str_eq language "python") (pl13-gen-python spec symbol)
    (if (str_eq language "javascript") (pl13-gen-javascript spec symbol)
    (if (str_eq language "typescript") (pl13-gen-typescript spec symbol)
    (if (str_eq language "java") (pl13-gen-java-family spec symbol)
    (if (str_eq language "c") (pl13-gen-c-family spec symbol)
    (if (str_eq language "cpp") (pl13-gen-c-family spec symbol)
    (if (str_eq language "csharp") (pl13-gen-java-family spec symbol)
    (if (str_eq language "go") (pl13-gen-go spec symbol)
    (if (str_eq language "rust") (pl13-gen-rust spec symbol)
    (if (str_eq language "ruby") (pl13-gen-ruby spec symbol)
    (if (str_eq language "php") (pl13-gen-php spec symbol)
    (if (str_eq language "swift") (pl13-gen-swift spec symbol)
    (if (str_eq language "kotlin") (pl13-gen-kotlin spec symbol) ""))))))))))))))
  (defn pl13-generate (language spec)
    (if (eq (pl13-op-supported (pl13-spec-op spec)) 0) ""
      (if (eq (len (pl13-lens-by-id language)) 0) ""
        (pl13-generate-supported language spec (pl13-op-symbol (pl13-spec-op spec))))))
  ; Detectable generation is a separate, still-valid source surface. The plain
  ; generator above stays byte-exact and annotation-free; this one adds an
  ; explicit language comment so structurally-identical C-family functions can
  ; re-enter the intended registry lens without pretending syntax can decide.
  (defn pl13-language-sentinel (language)
    (do
      (let lens (pl13-lens-by-id language))
      (if (eq (len lens) 0) ""
        (str_concat (pl13-comment lens)
          (str_concat " pl13-language[" (str_concat language "]\n"))))))
  (defn pl13-generate-detectable (language spec)
    (do
      (let code (pl13-generate language spec))
      (if (eq (str_len code) 0) ""
        (if (str_eq language "php")
          (str_concat "<?php\n" (str_concat (pl13-language-sentinel language)
            (str_concat code "?>\n")))
          (str_concat (pl13-language-sentinel language) code)))))
  (defn pl13-generate-all-go (lenses spec out)
    (if (eq (len lenses) 0) (reverse out)
      (pl13-generate-all-go (tail lenses) spec
        (cons (list (pl13-id (head lenses))
                    (pl13-generate (pl13-id (head lenses)) spec)) out))))
  (defn pl13-generate-all (spec)
    (pl13-generate-all-go (pl13-registry) spec (empty)))

  ; Executable audit and boundary: flags are evidence, not aspirations.
  (defn pl13-artifact-audit ()
    (list
      (list "foreign-language-cells" 4
        (list "python" "typescript" "go" "rust")
        "form/form-kernel-ts/src/languages.ts + lang-*.ts")
      (list "form-seedbank-emitters" 4
        (list "python" "typescript" "go" "rust")
        "form/form-stdlib/seedbank/emits/")
      (list "shared-imperative-grammar" 1
        (list "expressions" "statements")
        "form/form-stdlib/lang-common.fk")
      (list "form-source-text-emitter" 1
        (list "form")
        "form/form-stdlib/source-compiler-text-lens.fk")
      (list "this-native-lens" 13
        (list "lexical-detect" "binary-add-sub-mul-emit")
        "cognition/pl-lenses-13.fk")))
  ; (lexical-detect, bounded-generate, full-parse, AST-roundtrip, typecheck,
  ;  compile, execute, arbitrary-transpile, identifier-escape)
  (defn pl13-capability-flags () (list 1 1 0 0 0 0 0 0 0))
)
