; nl-lenses-13-band.fk — one live bounded example for each of exactly 13 lenses.
; Each bit proves detection of all seated meanings, parameterized framing, and
; neutral-pivot transformation into the next lens. Verdict: 8191 four-way.
; preludes: form/form-stdlib/core.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk
(do
  (defn nl13b-next (row)
    (nl13-at (mod (nl13-id row) (nl13-count))))
  (defn nl13b-example-ok? (row)
    (do (let code (nl13-code row))
        (let next (nl13b-next row))
        (let framed (nl13-generate code 4 "Form"))
        (and (str_eq code (nth (nl13-selection-codes) (sub (nl13-id row) 1)))
          (and (str_eq (nl13-detect (nl13-presence row)) code)
          (and (str_eq (nl13-detect (nl13-need row)) code)
            (and (str_eq (nl13-detect (nl13-yes row)) code)
              (and (str_eq (nl13-detect framed) code)
                (and (str_eq (nl13-transform (nl13-presence row) (nl13-code next))
                             (nl13-presence next))
                  (and (str_eq (nl13-transform framed (nl13-code next))
                               (nl13-generate (nl13-code next) 4 "Form"))
                       (str_eq (nl13-reframe code (nl13-code next) "living-detail")
                               (nl13-generate (nl13-code next) 4 "living-detail")))))))))))
  (defn nl13b-go (rows bit total)
    (if (eq (len rows) 0) total
      (nl13b-go (tail rows) (mul bit 2)
        (add total (if (nl13b-example-ok? (head rows)) bit 0)))))
  (if (and (eq (nl13-count) 13)
           (and (eq (len (nl13-selection-codes)) 13)
                (eq (nth (nl13-selection-evidence) 4) 0)))
    (nl13b-go (nl13-data) 1 0) 0)
)
