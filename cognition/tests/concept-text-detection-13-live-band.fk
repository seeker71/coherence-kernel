; concept-text-detection-13-live-band.fk -- full-data multilingual text witness.
; Verdict 262143: 13 held-out real sentences, two context-ranked loop senses,
; a 17-concept Indonesian ambiguity set, general sentence scan, and pinned
; 34,244-sense integrity all hold on fkwu.
; witnessed: 2026-07-18 -> 262143 live fkwu
; preludes: form/form-stdlib/core.fk cognition/concept-text-detection-13-runtime.fk
(do
  ; fixture = locale, expected concept, exact pinned surface, real sentence.
  (defn ctd13lb-fixtures ()
    (list
      (list "en" 6196 "loop" "The computer program repeats instructions in a loop until the condition is satisfied.")
      (list "id" 751 "pengadilan" "Hakim memasuki pengadilan untuk sidang pagi.")
      (list "es" 959 "cámara" "La cámara grabó la reunión familiar en el jardín.")
      (list "fr" 440 "récit" "Son récit décrit le voyage réel de toute la famille.")
      (list "pt-br" 377 "água" "A família levou água limpa para a caminhada.")
      (list "sw" 150 "kazi" "Kazi ya leo ni kujenga daraja salama.")
      (list "de" 227 "Welt" "Die Welt verändert sich durch unsere täglichen Entscheidungen.")
      (list "ru" 596 "мир" "Сегодня мир вращается вокруг Солнца каждый день.")
      (list "zh" 959 "照相机" "她在公园里用照相机记录孩子们的比赛。")
      (list "ja" 46 "行く" "明日は家族と海へ行く予定です。")
      (list "ar" 916 "ضِفّة" "جلسنا على ضِفّة النهر نراقب الماء.")
      (list "hi" 959 "कैमरा" "परिवार ने यात्रा के लिए कैमरा तैयार किया।")
      (list "tr" 504 "özgür" "Her çocuk düşüncesini özgür biçimde söyleyebilir.")))
  (defn ctd13lb-find-id (candidates id)
    (if (eq (len candidates) 0) (empty)
      (if (eq (ctd13-candidate-id (head candidates)) id) (head candidates)
        (ctd13lb-find-id (tail candidates) id))))
  (defn ctd13lb-one? (runtime fixture)
    (do (let code (nth fixture 0))
        (let id (nth fixture 1))
        (let surface (nth fixture 2))
        (let sentence (nth fixture 3))
        (let observed (cnl13-runtime-generate (ctd13-runtime-nl runtime) id code))
        (let result (ctd13-runtime-detect-surface-in-sentence runtime code surface sentence))
        (let candidate (ctd13lb-find-id (nth result 4) id))
        (and (str_eq observed surface)
          (and (eq (nth result 3) 1)
            (and (gt (len (nth result 4)) 0)
              (and (not (eq (len candidate) 0))
                (and (not (str_eq (ctd13-candidate-source-code candidate) "0"))
                     (str_eq (ctd13-candidate-surface candidate) surface))))))))
  (defn ctd13lb-fixtures-go (runtime fixtures bit verdict)
    (if (eq (len fixtures) 0) verdict
      (ctd13lb-fixtures-go runtime (tail fixtures) (mul bit 2)
        (add verdict (if (ctd13lb-one? runtime (head fixtures)) bit 0)))))
  (defn ctd13lb-candidates-sourced? (candidates)
    (if (eq (len candidates) 0) 1
      (and (not (str_eq (ctd13-candidate-source-code (head candidates)) "0"))
           (ctd13lb-candidates-sourced? (tail candidates)))))
  (let runtime (ctd13-runtime-open))
  (let fixture-bits (ctd13lb-fixtures-go runtime (ctd13lb-fixtures) 1 0))
  (let code-context "The computer program repeats instructions in a loop until the condition is satisfied.")
  (let eyelet-context "The metal ring loop lines a small hole so cords can attach.")
  (let code-analysis (ctd13-runtime-analyze-senses runtime 6196 code-context))
  (let eyelet-analysis (ctd13-runtime-analyze-senses runtime 6196 eyelet-context))
  (let code-top (nth (head (nth code-analysis 2)) 0))
  (let eyelet-top (nth (head (nth eyelet-analysis 2)) 0))
  (let duplicates (ctd13-runtime-detect-all runtime "id" "ya" "Dia menjawab ya dengan tenang."))
  (let general (ctd13-runtime-detect-sentence runtime "en" code-context))
  (let general-loop (ctd13lb-find-id general 6196))
  (add fixture-bits
    (add (if (and (eq (nth code-analysis 1) 15)
                   (and (str_eq (nth code-analysis 0) "context-ranked-not-resolved")
                        (str_eq (cts10-sense-synset code-top) "n06585033"))) 8192 0)
      (add (if (and (eq (nth eyelet-analysis 1) 15)
                     (str_eq (cts10-sense-synset eyelet-top) "n03137089")) 16384 0)
        (add (if (and (eq (len duplicates) 17)
                       (ctd13lb-candidates-sourced? duplicates)) 32768 0)
          (add (if (and (gt (len general) 1)
                        (not (eq (len general-loop) 0))) 65536 0)
               (if (and (eq (str_len (ctd13-runtime-sense-data runtime)) 3867783)
                     (and (eq (len (ctd13-runtime-sense-offsets runtime)) 10001)
                       (and (eq (cts10-total-senses) 34244)
                            (eq (cts10-ambiguous-anchors) 5618)))) 131072 0))))))
)
