; concept-human-corpus-13-live-band.fk -- exhaustive public-corpus detector witness.
;
; Every one of 147 source sentences is sent, without a supplied surface, through
; ctd13-runtime-detect-sentence's full 10,000-label walk.  Stored ids/counts are
; checked expectations.  Expected-zero rows must remain zero and ambiguity is
; retained.  Quote retrieval must carry contributor/license/page and explicitly
; deny novel generation.
; witnessed: 2026-07-18 -> 1023 live fkwu
; preludes: form/form-stdlib/core.fk cognition/concept-human-corpus-13-runtime.fk
(do
  (let runtime (hcnl13-runtime-open))
  (let first (hcnl13-runtime-detect-index runtime 0))
  (let negative (hcnl13-runtime-detect-index runtime 10))
  (let quote (hcnl13-runtime-quote-for-concept runtime "en" 185))
  ; The selected Arabic rows include bus but no money quote.
  (let absent (hcnl13-runtime-quote-for-concept runtime "ar" 185))
  ; Indonesian source rows: index 14 detects water=377; index 12 is an honest
  ; no-candidate row and must abstain from the world.
  (let admitted (hcnl13-runtime-world-admit-index runtime 14))
  (let abstained (hcnl13-runtime-world-admit-index runtime 12))
  (let scan (hcnl13-runtime-scan runtime))
  (add
    (if (and (eq (hcnl13-row-count) 147)
             (and (eq (hcnl13-locale-count) 13)
               (and (eq (hcnl13-domain-count) 122)
                 (and (eq (hcnl13-ambiguity-count) 12)
                      (eq (hcnl13-negative-count) 13))))) 1 0)
    (add (if (and (str_eq (nth first 2) "attributed-domain-match")
                   (and (eq (len (nth first 1)) 13)
                        (hcnl13-candidates-have-id? (nth first 1) 185))) 2 0)
      (add (if (and (str_eq (nth negative 2) "expected-zero-detection")
                     (eq (len (nth negative 1)) 0)) 4 0)
        (add (if (and (str_eq (nth quote 0) "attributed-human-quote-not-novel-generation")
                       (and (eq (nth quote 2) 185)
                         (and (eq (nth quote 3) 1338)
                           (and (str_eq (nth quote 4) "AlanF_US")
                             (and (str_eq (nth quote 5) "CC-BY-2.0-FR")
                               (str_eq (nth quote 7) "human-contributed-unreviewed")))))) 8 0)
          (add (if (and (eq (len absent) 0)
                         (and (eq (nth admitted 1) 1)
                           (and (eq (nth admitted 3) 377)
                             (and (eq (nth admitted 11) 1)
                               (and (eq (nth admitted 13) 0)
                                 (and (eq (nth abstained 1) 0)
                                      (eq (nth abstained 9) 0))))))) 16 0)
            (add (if (and (eq (nth scan 0) 147)
                           (and (eq (nth scan 1) 147) (eq (nth scan 2) 0))) 32 0)
              (add (if (and (eq (nth scan 3) 1898)
                             (eq (nth scan 4) 828)) 64 0)
                (add (if (and (eq (nth scan 5) 122)
                               (and (eq (nth scan 6) 12)
                                    (eq (nth scan 7) 13))) 128 0)
                  (add (if (and (eq (nth scan 8) 147)
                                 (eq (nth scan 9) 0)) 256 0)
                    (if (and (eq (hcnl13-artifacts-valid?) 1)
                      (and (str_eq (hcnl13-data-sha256)
                               "fd291d23ca345c0ed68dfb20b700c47e6fcb9fe4ba734ee858cab241ba97b7c0")
                          (and (str_eq (hcnl13-manifest-sha256)
                                 "7fd8536857ae1ed1911228ec398befeced744c9fe7aa24186412a915b0f35a06")
                               (str_eq (hcnl13-row-source-hash (nth first 0))
                                 "13e4031d22ca37cc966aa41f73764cb8870d62a150bd735f7506eaddfaf757d8"))))
                      512 0))))))))))
)
