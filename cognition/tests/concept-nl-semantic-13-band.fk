; concept-nl-semantic-13-band.fk — pure metadata/API contract, four-way.
; witnessed: 2026-07-18 -> 1023 four-way after aligned full-surface expansion
; Full TSV mapping is witnessed separately on fkwu because proof walkers do not
; carry read_file and TS explicitly lacks byte-identical non-Latin substring.
; preludes: form/form-stdlib/core.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13.fk
(do
  (defn cnl13b-hit (ok bit) (if ok bit 0))
  (defn cnl13b-meta-whole? (rows)
    (if (eq (len rows) 0) 1
      (and (eq (add (cnl13-meta-present (head rows))
                    (cnl13-meta-absent (head rows))) 10000)
           (and (eq (str_len (cnl13-meta-source-hash (head rows))) 64)
                (cnl13b-meta-whole? (tail rows))))))
  (defn cnl13b-cols? (codes expected)
    (if (eq (len codes) 0) 1
      (and (eq (cnl13-locale-col (head codes)) expected)
           (cnl13b-cols? (tail codes) (add expected 1)))))
  (let source (cnl13-source-meta))
  (let machine (cnl13-machine-source-meta))
  (let rows (cnl13-locale-meta-rows))
  (let c0 (cnl13b-hit (eq (cnl13-anchor-count) 10000) 1))
  (let c1 (cnl13b-hit (eq (len rows) 13) 2))
  (let c2 (cnl13b-hit (cnl13b-meta-whole? rows) 4))
  (let c3 (cnl13b-hit (eq (cnl13-total-present) 130000) 8))
  (let c4 (cnl13b-hit (and (eq (str_len (nth source 1)) 40)
                            (and (eq (str_len (nth source 3)) 64)
                                 (eq (str_len (nth machine 1)) 64))) 16))
  (let c5 (cnl13b-hit (cnl13b-cols? (cnl13-locale-codes) 1) 32))
  (let c6 (cnl13b-hit (and (eq (nth (cnl13-review-summary "en") 2) 0)
                            (eq (nth (cnl13-review-summary "hi") 2) 0)) 64))
  (let c7 (cnl13b-hit (eq (cnl13-locale-col "not-a-locale") -1) 128))
  (let source-sample "FD00000000000")
  (let c8 (cnl13b-hit
            (and (str_eq (cnl13-source-code-at source-sample 0 "en") "F")
                 (str_eq (cnl13-source-code-at source-sample 0 "id") "D")) 256))
  (let c9 (cnl13b-hit
            (and (str_eq (cnl13-source-name "F") "frequency-anchor")
                 (str_eq (cnl13-source-name "G") "google-translate-machine")) 512))
  (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9)))))))))
)
