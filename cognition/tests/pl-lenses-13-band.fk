; pl-lenses-13-band.fk — all thirteen real fixtures detect, and every surface
; emits its exact bounded binary-function form from one neutral recipe.
; preludes: form/form-stdlib/core.fk cognition/pl-lenses-13.fk

(do
  (defn pl13t-bit (ok bit) (if ok bit 0))
  (defn pl13t-detect-fixtures (lenses)
    (if (eq (len lenses) 0) 1
      (if (str_eq (pl13-id (head lenses))
                  (pl13-detect (pl13-fixture (head lenses))))
        (pl13t-detect-fixtures (tail lenses)) 0)))
  (defn pl13t-generated-nonempty (rows)
    (if (eq (len rows) 0) 1
      (if (gt (str_len (nth (head rows) 1)) 0)
        (pl13t-generated-nonempty (tail rows)) 0)))
  (defn pl13t-list-eq (a b)
    (if (not (eq (len a) (len b))) 0
      (if (eq (len a) 0) 1
        (if (eq (head a) (head b))
          (pl13t-list-eq (tail a) (tail b)) 0))))
  (defn pl13t-code (language)
    (pl13-generate language (pl13-binary-spec "combine" "a" "b" "add")))
  (defn pl13t-detect-generated (lenses spec)
    (if (eq (len lenses) 0) 1
      (do
        (let id (pl13-id (head lenses)))
        (if (str_eq id (pl13-detect (pl13-generate-detectable id spec)))
          (pl13t-detect-generated (tail lenses) spec) 0))))
  (defn pl13-lenses-13-band ()
    (do
      (let spec (pl13-binary-spec "combine" "a" "b" "add"))
      (let all (pl13-generate-all spec))
      (let c0 (pl13t-bit (eq (len (pl13-registry)) 13) 1))
      (let c1 (pl13t-bit (eq (pl13t-detect-fixtures (pl13-registry)) 1) 2))
      (let c2 (pl13t-bit
        (and (eq (len all) 13) (eq (pl13t-generated-nonempty all) 1)) 4))
      (let c3 (pl13t-bit
        (str_eq (pl13t-code "python")
          "def combine(a, b):\n    return a + b\n") 8))
      (let c4 (pl13t-bit
        (str_eq (pl13t-code "javascript")
          "function combine(a, b) {\n  return a + b;\n}\n") 16))
      (let c5 (pl13t-bit
        (str_eq (pl13t-code "typescript")
          "function combine(a: number, b: number): number {\n  return a + b;\n}\n") 32))
      (let c6 (pl13t-bit
        (str_eq (pl13t-code "java")
          "static int combine(int a, int b) {\n  return a + b;\n}\n") 64))
      (let c7 (pl13t-bit
        (and
          (str_eq (pl13t-code "c")
            "int combine(int a, int b) {\n  return a + b;\n}\n")
          (and
            (str_eq (pl13t-code "cpp")
              "int combine(int a, int b) {\n  return a + b;\n}\n")
            (str_eq (pl13t-code "csharp")
              "static int combine(int a, int b) {\n  return a + b;\n}\n"))) 128))
      (let c8 (pl13t-bit
        (str_eq (pl13t-code "go")
          "func combine(a int, b int) int {\n\treturn a + b\n}\n") 256))
      (let c9 (pl13t-bit
        (str_eq (pl13t-code "rust")
          "fn combine(a: i64, b: i64) -> i64 {\n    a + b\n}\n") 512))
      (let c10 (pl13t-bit
        (str_eq (pl13t-code "ruby")
          "def combine(a, b)\n  a + b\nend\n") 1024))
      (let c11 (pl13t-bit
        (str_eq (pl13t-code "php")
          "function combine($a, $b) {\n  return $a + $b;\n}\n") 2048))
      (let c12 (pl13t-bit
        (str_eq (pl13t-code "swift")
          "func combine(_ a: Int, _ b: Int) -> Int {\n    return a + b\n}\n") 4096))
      (let c13 (pl13t-bit
        (str_eq (pl13t-code "kotlin")
          "fun combine(a: Int, b: Int): Int {\n    return a + b\n}\n") 8192))
      (let c14 (pl13t-bit
        (and
          (str_eq (pl13-generate "python" (pl13-binary-spec "bad" "a" "b" "div")) "")
          (str_eq (pl13-generate "brainfuck" spec) "")) 16384))
      (let c15 (pl13t-bit
        (pl13t-list-eq (pl13-capability-flags) (list 1 1 0 0 0 0 0 0 0)) 32768))
      (let c16 (pl13t-bit
        (and (eq (len (pl13-artifact-audit)) 5)
             (eq (nth (nth (pl13-artifact-audit) 4) 1) 13)) 65536))
      (let c17 (pl13t-bit
        (str_eq (pl13-detect "ordinary prose with no programming markers") "unknown") 131072))
      (let c18 (pl13t-bit
        (and
          (ge (str_find (pl13-generate "swift"
                (pl13-binary-spec "combine" "a" "b" "sub")) "a - b" 0) 0)
          (ge (str_find (pl13-generate "ruby"
                (pl13-binary-spec "combine" "a" "b" "mul")) "a * b" 0) 0)) 262144))
      (let c19 (pl13t-bit
        (eq (pl13t-detect-generated (pl13-registry) spec) 1) 524288))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6
        (add c7 (add c8 (add c9 (add c10 (add c11 (add c12
        (add c13 (add c14 (add c15 (add c16 (add c17 (add c18 c19)))))))))))))))))))))
  (pl13-lenses-13-band))
