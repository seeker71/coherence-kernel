; nl-lenses-13-live.fk — expose all thirteen executable phrase-lens examples.
; Each row: id, code, script, live phrase, detected code, next code, transformed
; phrase, generated grounded frame, frame detection, provenance, source.
; preludes: form/form-stdlib/core.fk cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk
(do
  (defn nl13l-example (row)
    (do (let next (nl13-at (mod (nl13-id row) (nl13-count))))
        (let phrase (nl13-generate (nl13-code row) 1 ""))
        (let framed (nl13-generate (nl13-code row) 4 "Form"))
        (list (nl13-id row) (nl13-code row) (nl13-script row)
              phrase (nl13-detect phrase)
              (nl13-code next) (nl13-transform phrase (nl13-code next))
              framed (nl13-detect framed)
              (nl13-provenance row) (nl13-source row))))
  (defn nl13l-go (rows)
    (if (eq (len rows) 0) (empty)
      (cons (nl13l-example (head rows)) (nl13l-go (tail rows)))))
  (list 1313 (nl13-count) (nl13-selection-evidence) (nl13l-go (nl13-data)))
)
