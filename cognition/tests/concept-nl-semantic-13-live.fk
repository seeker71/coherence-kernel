; concept-nl-semantic-13-live.fk — printable real-data witness for every lens.
; witnessed: 2026-07-18 -> 13 mapped UTF-8 rows + 1 honest absence
; The returned value is one string, so fkwu's source boundary prints the actual
; UTF-8 labels rather than the internal numeric handles used inside list output.
; preludes: form/form-stdlib/core.fk cognition/concept-nl-semantic-13-runtime.fk
(do
  (defn cnl13l-line (runtime code)
    (do (let label (cnl13-runtime-generate runtime 440 code))
        (let found (cnl13-runtime-detect-first runtime code label))
        (let meta (cnl13-locale-meta code))
        (str_concat code
          (str_concat " synset="
            (str_concat (cnl13-anchor-at (cnl13-runtime-data runtime)
                                         (cnl13-runtime-offsets runtime) 440)
              (str_concat " label="
                (str_concat label
                  (str_concat " state="
                    (str_concat (cnl13-label-state code label)
                      (str_concat " mapped="
                        (str_concat (int_to_str (cnl13-meta-present meta))
                          (str_concat " absent="
                            (str_concat (int_to_str (cnl13-meta-absent meta))
                              (str_concat " detect-index="
                                (str_concat (int_to_str (nth found 0)) "\n")))))))))))))))
  (defn cnl13l-lines (runtime codes)
    (if (eq (len codes) 0) ""
      (str_concat (cnl13l-line runtime (head codes))
                  (cnl13l-lines runtime (tail codes)))))
  (let runtime (cnl13-runtime-open))
  (let absent-label (cnl13-runtime-generate runtime 0 "id"))
  (str_concat "source-commit=406bf83b3c507a3d1f26e88252d5d66893fd36bf anchors=10000 cells=130000 mapped=45318 reviewed=0\n"
    (str_concat (cnl13l-lines runtime (cnl13-locale-codes))
      (str_concat "id synset="
        (str_concat (cnl13-anchor-at (cnl13-runtime-data runtime)
                                     (cnl13-runtime-offsets runtime) 0)
          (str_concat " label=<empty> state="
            (str_concat (cnl13-label-state "id" absent-label) "\n"))))))
)
