; Exact alignment/provenance floor; expected 4095.
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-human-corpus-13-metadata.fk cognition/concept-human-corpus-130000-metadata.fk observe/framebuffer-runtime-observation.fk cognition/concept-13-alignment-truth.fk
(do
  (defn c13ab-bit (ok bit) (if ok bit 0))
  (defn concept-13-alignment-truth-band ()
    (do
      (let sources (read_file (cnl13-source-codes-path)))
      (let counts (c13a-source-counts sources))
      (sum (list
        (c13ab-bit (eq (c13a-tatoeba-distinct-monolingual-rows) 125165) 1)
        (c13ab-bit (eq (c13a-tatoeba-old-new-overlap) 718) 2)
        (c13ab-bit (eq (hcnl13-human-reviewed-count) 0) 4)
        (c13ab-bit (eq (str_len sources) 130000) 8)
        (c13ab-bit (eq (nth counts 1) 10000) 16)
        (c13ab-bit (eq (nth counts 3) 34941) 32)
        (c13ab-bit (eq (nth counts 5) 16621) 64)
        (c13ab-bit (eq (nth counts 7) 68) 128)
        (c13ab-bit (eq (nth counts 9) 68370) 256)
        (c13ab-bit (eq (nth counts 11) 0) 512)
        (c13ab-bit (eq (c13a-count-values counts 0 0) 130000) 1024)
        ; Evaluation pairs are real; successful translation remains zero.
        (c13ab-bit (and (eq (c13a-retained-translation-links) 94)
          (and (eq (c13a-human-aligned-sentence-pairs) 94)
            (and (eq (c13a-heldout-human-evaluation-pairs) 15)
              (eq (c13a-heldout-translation-successes) 0)))) 2048)))))
  (concept-13-alignment-truth-band))
