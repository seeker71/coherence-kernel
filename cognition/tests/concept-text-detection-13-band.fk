; concept-text-detection-13-band.fk -- pure ambiguity/context contract, four-way.
; Verdict 8191: complete candidates, provenance, real sense sets, context
; ranking, boundary behavior, and all 13 writing-system lenses agree.
; witnessed: 2026-07-18 -> 8191 on fkwu / Go / Rust / TypeScript
; preludes: form/form-stdlib/core.fk form/form-stdlib/text-tokenize.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk
(do
  (defn ctd13b-hit (ok bit) (if ok bit 0))
  (defn ctd13b-bits (checks bit)
    (if (eq (len checks) 0) 0
      (add (ctd13b-hit (head checks) bit)
           (ctd13b-bits (tail checks) (mul bit 2)))))
  (defn ctd13b-nl-row (anchor en es)
    (str_concat anchor (str_concat "\t" (str_concat en
      (str_concat "\tid\t" (str_concat es
        "\tfr\tpt\tsw\tde\tru\tzh\tja\tar\thi\ttr\n"))))))
  (defn ctd13b-nl-data ()
    (str_concat (ctd13b-nl-row "00000001-n" "bank" "banco")
                (ctd13b-nl-row "00000002-n" "shore" "banco")))
  (defn ctd13b-nl-offsets ()
    (do (let a (str_len (ctd13b-nl-row "00000001-n" "bank" "banco")))
        (list 0 a (add a (str_len (ctd13b-nl-row "00000002-n" "shore" "banco"))))))
  (defn ctd13b-ranked ()
    (str_concat "bank                |00001000;" "shore               |00000900;"))
  (defn ctd13b-sem-row () "10000000000030n07558676006200042001")
  (defn ctd13b-sem-index () (str_concat (ctd13b-sem-row) (ctd13b-sem-row)))
  (defn ctd13b-sem-payload () "04love0009affection@ n07495208")
  (defn ctd13b-sources () "F0W0000000000F0G0000000000")
  (defn ctd13b-sense-row0 ()
    "0\t2\tn08437235\tn\t2\t20\ta financial institution accepts money deposits\tn09236472\tn\t1\t25\tsloping land beside a river\n")
  (defn ctd13b-sense-row1 ()
    "1\t1\tn09433442\tn\t1\t4\tthe land along the edge of water\n")
  (defn ctd13b-sense-data () (str_concat (ctd13b-sense-row0) (ctd13b-sense-row1)))
  (defn ctd13b-sense-offsets ()
    (do (let a (str_len (ctd13b-sense-row0)))
        (list 0 a (add a (str_len (ctd13b-sense-row1))))))
  (defn ctd13b-detect ()
    (ctd13-detect-surface-in-sentence-n-in
      (ctd13b-nl-data) (ctd13b-nl-offsets) (ctd13b-ranked)
      (ctd13b-sem-index) (ctd13b-sem-payload)
      (ctd13b-sense-data) (ctd13b-sense-offsets) (ctd13b-sources)
      "es" "banco" "I deposit money at banco" 2))
  (defn ctd13b-scripts? ()
    (and (eq (ctd13-occurs? "I use a camera outside." "camera" "en") 1)
      (and (eq (ctd13-occurs? "Saya memakai kamera di luar." "kamera" "id") 1)
       (and (eq (ctd13-occurs? "Uso una cámara afuera." "cámara" "es") 1)
        (and (eq (ctd13-occurs? "J'utilise un appareil photo dehors." "appareil photo" "fr") 1)
         (and (eq (ctd13-occurs? "Uso uma câmara fotográfica fora." "câmara fotográfica" "pt-br") 1)
          (and (eq (ctd13-occurs? "Ninatumia kamera nje." "kamera" "sw") 1)
           (and (eq (ctd13-occurs? "Ich benutze einen Fotoapparat draußen." "Fotoapparat" "de") 1)
            (and (eq (ctd13-occurs? "Я использую фотоаппарат на улице." "фотоаппарат" "ru") 1)
             (and (eq (ctd13-occurs? "我在外面用照相机拍照。" "照相机" "zh") 1)
              (and (eq (ctd13-occurs? "外でカメラを使います。" "カメラ" "ja") 1)
               (and (eq (ctd13-occurs? "أستخدم كاميرا في الخارج." "كاميرا" "ar") 1)
                (and (eq (ctd13-occurs? "मैं बाहर कैमरा इस्तेमाल करता हूँ।" "कैमरा" "hi") 1)
                     (eq (ctd13-occurs? "Dışarıda fotoğraf makinesi kullanıyorum." "fotoğraf makinesi" "tr") 1))))))))))))))
  (let result (ctd13b-detect))
  (let all (nth result 4))
  (let ranked (nth result 5))
  (let first (head ranked))
  (let analysis (ctd13-candidate-analysis first))
  (let top-sense (nth (head (nth analysis 2)) 0))
  (ctd13b-bits
    (list
      (and (eq (nth result 3) 1) (eq (len all) 2))
      (str_eq (nth result 6) "multiple-concepts")
      (and (str_eq (ctd13-candidate-source-code (head all)) "W")
           (str_eq (ctd13-candidate-source-code (head (tail all))) "G"))
      (and (eq (ctd13-candidate-id first) 0)
           (gt (ctd13-candidate-score first)
               (ctd13-candidate-score (head (tail ranked)))))
      (and (eq (ctd13-candidate-sense-count first) 6) (eq (nth analysis 1) 2))
      (and (str_eq (nth analysis 0) "context-ranked-not-resolved")
           (gt (nth analysis 3) 0))
      (and (str_eq (cts10-sense-synset top-sense) "n08437235")
           (str_eq (cts10-sense-pos top-sense) "n"))
      (and (eq (ctd13-occurs? "banking" "bank" "en") 0)
           (eq (ctd13-occurs? "BANK now" "bank" "en") 1))
      (ctd13b-scripts?)
      (and (eq (cts10-sense-count-in (ctd13b-sense-data)
                  (ctd13b-sense-offsets) 0) 2)
           (eq (len (cts10-senses-in (ctd13b-sense-data)
                  (ctd13b-sense-offsets) 1)) 1))
      (and (str_eq (ctd13-candidate-method first) "exact")
           (eq (ctd13-candidate-frequency first) 1000))
      (and (eq (cts10-total-senses) 34244) (eq (cts10-ambiguous-anchors) 5618))
      (and (eq (ctd13-occurs? "没有目标" "" "zh") 0)
           (eq (len (ctd13-detect-all-n-in
             (ctd13b-nl-data) (ctd13b-nl-offsets) (ctd13b-ranked)
             (ctd13b-sem-index) (ctd13b-sem-payload)
             (ctd13b-sense-data) (ctd13b-sense-offsets) (ctd13b-sources)
             "xx" "banco" "banco" 2)) 0))) 1)
)
