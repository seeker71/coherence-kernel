; concept-human-corpus-13-live.fk -- one attributed live observation per locale.
; Output is source truth + actual unprompted detector count, never invented prose.
; witnessed: 2026-07-18 -> pending live fkwu
; preludes: form/form-stdlib/core.fk cognition/concept-human-corpus-13-runtime.fk
(do
  (defn hcnl13l-find-first-locale-go (r code index)
    (if (ge index (hcnl13-row-count)) -1
      (if (str_eq (hcnl13-row-locale (hcnl13-runtime-row r index)) code) index
        (hcnl13l-find-first-locale-go r code (add index 1)))))
  (defn hcnl13l-line (r code)
    (do (let index (hcnl13l-find-first-locale-go r code 0))
        (let result (hcnl13-runtime-detect-index r index))
        (let row (nth result 0))
        (str_concat code (str_concat " | id="
          (str_concat (int_to_str (hcnl13-row-sentence-id row))
            (str_concat " | by=" (str_concat (hcnl13-row-author row)
              (str_concat " | detected=" (str_concat (int_to_str (len (nth result 1)))
                (str_concat " | state=" (str_concat (nth result 2)
                  (str_concat " | quote=" (hcnl13-row-sentence row)))))))))))))
  (defn hcnl13l-lines (r codes)
    (if (eq (len codes) 0) ""
      (str_concat (hcnl13l-line r (head codes))
        (str_concat "\n" (hcnl13l-lines r (tail codes))))))
  (let runtime (hcnl13-runtime-open))
  (hcnl13l-lines runtime (cnl13-locale-codes))
)
