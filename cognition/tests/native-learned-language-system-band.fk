; Integrated learned NL/PL -> neutral concept -> emission gate: 32767.
; preludes: form/form-stdlib/core.fk form/form-stdlib/bmf-core.fk form/form-stdlib/bmf-grammar.fk model/concept-10000-data.fk model/concept-10000.fk cognition/nl-grammar-induction-rule.fk cognition/nl-grammar-induction.fk model/pl-grammar-induction.fk cognition/neutral-rule-mdl-admission.fk cognition/neutral-rule-mdl-examples.fk observe/framebuffer-runtime-observation.fk cognition/native-learned-language-system.fk
(do
  (defn nllsb-bit (ok bit) (if ok bit 0))
  (defn native-learned-language-system-band ()
    (do
      (let nl (nlls-nl-witness))
      (let pl (nlls-pl-witness))
      (let admissions (nlls-admission-witness))
      (sum (list
        (nllsb-bit (eq (nth nl 6) 1) 1)
        (nllsb-bit (eq (nth pl 5) 1) 2)
        (nllsb-bit (eq (nlls-observed-adapters) 2) 4)
        (nllsb-bit (str_eq (nth nl 5) "the signal is grounded") 8)
        (nllsb-bit (str_eq (nth (nth pl 4) 1) "budget := 314159") 16)
        (nllsb-bit (and (eq (nlls-known? (nth nl 3)) 1)
          (eq (nlls-known? (nth nl 4)) 1)) 32)
        (nllsb-bit (eq (nlls-known? (nth pl 3)) 1) 64)
        (nllsb-bit (str_eq (nth (nth admissions 0) 0) "admitted") 128)
        (nllsb-bit (str_eq (nth (nth admissions 1) 0) "admitted") 256)
        (nllsb-bit (str_eq (nth (nth admissions 2) 0) "refused") 512)
        (nllsb-bit (eq (nlls-static-language-rows-required) 0) 1024)
        (nllsb-bit (eq (nlls-bmf-executable-learned-adapters) 1) 2048)
        (nllsb-bit (eq (nlls-unknown-family-routing) 1) 4096)
        (nllsb-bit (eq (nlls-unknown-language-semantic-translation) 0) 8192)
        (nllsb-bit (eq (nlls-general-or-infinite-translation) 0) 16384)))))
  (native-learned-language-system-band))
