; concept-nl-semantic-13-live-band.fk — all 10k rows and all 13 locales live.
; witnessed: 2026-07-18 -> 8191 fkwu
; Actual concept ID 46, "go" / PWN 01835496-v, has a mapped label in every
; locale and is the first exact occurrence of each of those labels.
; Each language gets one bit only when lookup, generation, first-match
; detection, state, and full 10k recomputed coverage all agree. Verdict 8191.
; preludes: form/form-stdlib/core.fk cognition/concept-nl-semantic-13-runtime.fk
(do
  (defn cnl13lb-one? (runtime code)
    (do (let label (cnl13-runtime-generate runtime 46 code))
        (let found (cnl13-runtime-detect-first runtime code label))
        (let meta (cnl13-locale-meta code))
        (and (not (str_eq label ""))
          (and (eq (nth found 0) 46)
            (and (str_eq (nth found 1) "01835496-v")
              (and (str_eq (nth found 4) "mapped-unreviewed")
                (and (eq (cnl13-runtime-count-present runtime code)
                         (cnl13-meta-present meta))
                     (eq (add (cnl13-meta-present meta) (cnl13-meta-absent meta)) 10000))))))))
  (defn cnl13lb-go (runtime codes bit total)
    (if (eq (len codes) 0) total
      (cnl13lb-go runtime (tail codes) (mul bit 2)
        (add total (if (cnl13lb-one? runtime (head codes)) bit 0)))))
  (let runtime (cnl13-runtime-open))
  (if (and (gt (str_len (cnl13-runtime-data runtime)) 700000)
        (and (eq (len (cnl13-runtime-offsets runtime)) 10001)
          (and (eq (str_len (cnl13-runtime-sources runtime)) 130000)
            (and (eq (cnl13-count-source (cnl13-runtime-sources runtime) "F") 10000)
              (and (eq (cnl13-count-source (cnl13-runtime-sources runtime) "W") 34941)
                (and (eq (cnl13-count-source (cnl13-runtime-sources runtime) "D") 16621)
                  (and (eq (cnl13-count-source (cnl13-runtime-sources runtime) "C") 68)
                    (and (eq (cnl13-count-source (cnl13-runtime-sources runtime) "G") 68370)
                         (eq (cnl13-count-source (cnl13-runtime-sources runtime) "0") 0))))))))
    (cnl13lb-go runtime (cnl13-locale-codes) 1 0) 0)
)
