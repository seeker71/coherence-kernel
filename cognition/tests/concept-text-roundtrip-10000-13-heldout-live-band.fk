; concept-text-roundtrip-10000-13-heldout-live-band.fk
; Distinct from self-round-trip: unseen practical sentences are scanned without
; supplying a target surface.  This is lexical recovery, not a
; claim of syntax, entailment, reference resolution, or language understanding.
; witnessed: 2026-07-18 -> 13 positive + 13 negative + 13 ambiguity probes
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk cognition/concept-text-detection-13-runtime.fk cognition/concept-text-roundtrip-10000-13-metadata.fk cognition/concept-text-roundtrip-10000-13.fk
(do
  ; code, expected id, exact surface, held-out positive, held-out negative.
  (defn ctr13hb-real-fixtures ()
    (list
      (list "en" 629 "street" "Because black ice covered the street, the road crew closed one lane before the morning commute." "The pharmacy checked every prescription before closing.")
      (list "id" 296 "pintu" "Petugas memeriksa pintu darurat sebelum gedung dibuka untuk umum." "Tim medis memeriksa persediaan obat sebelum klinik dibuka.")
      (list "es" 1102 "autobús" "El autobús llegó veinte minutos tarde por una avería durante la hora punta." "La farmacia confirmó la dosis antes de renovar la receta.")
      (list "fr" 370 "médecin" "Le médecin a vérifié la dose avec le pharmacien avant de renouveler le traitement." "Les pompiers ont fermé la route après la tempête.")
      (list "pt-br" 6600 "fogão" "Desliguei o fogão e conferi o detector de fumaça antes de sair de casa." "A equipe confirmou o endereço antes de enviar a ambulância.")
      (list "sw" 377 "maji" "Wahudumu wa dharura waligawa maji safi baada ya bomba kupasuka." "Timu ilikagua mpango wa usalama wa ghala.")
      (list "de" 1071 "Baum" "Nach dem Sturm blockierte ein Baum die Landstraße, bis die Feuerwehr eintraf." "Die Apotheke prüfte die Dosis vor der Abgabe.")
      (list "ru" 332 "телефон" "Предупреждение о сильной грозе пришло на телефон, поэтому поездку отменили." "Спасатели проверили мост после наводнения.")
      (list "zh" 571 "书" "暴雨停课后，老师通过网络把书和作业发给了学生。" "维修人员在开放前检查了所有紧急出口。")
      (list "ja" 916 "岸" "大雨で川の岸が浸水したため、住民は高台へ避難しました。" "薬剤師は処方箋の量をもう一度確認しました。")
      (list "ar" 377 "ماء" "وزعت فرق الطوارئ ماء نظيفًا على الأسر بعد انقطاع الأنابيب." "راجع الصيدلي الجرعة قبل تسليم الدواء.")
      (list "hi" 468 "बच्चा" "नर्स ने बताया कि बच्चा दवा की अगली खुराक भोजन के बाद लेगा।" "बाढ़ के बाद इंजीनियरों ने पुल की जाँच की।")
      (list "tr" 628 "hastane" "Ambulans yaralı bisikletçiyi öğleden önce hastane acil servisine getirdi." "Ekip fırtınadan sonra köprüyü yeniden denetledi.")))

  ; code, representative id, exact ambiguous surface, held-out sentence, count.
  (defn ctr13hb-ambiguity-fixtures ()
    (list
      (list "en" 629 "street" "The street remained closed while crews removed the ice." 1)
      (list "id" 283 "ya" "Petugas mengatakan ya setelah memeriksa semua pintu darurat." 17)
      (list "es" 176 "Señor" "El Señor coordinó la evacuación con los bomberos del barrio." 9)
      (list "fr" 61 "ouais" "Le responsable a répondu ouais après avoir vérifié la sortie de secours." 13)
      (list "pt-br" 55 "ah" "Ela disse ah quando o alarme de fumaça começou a tocar." 17)
      (list "sw" 929 "kupiga kelele" "Wakazi walianza kupiga kelele walipoona moshi katika ghala." 17)
      (list "de" 405 "schlagen" "Die Einsatzkräfte mussten gegen die verschlossene Tür schlagen." 9)
      (list "ru" 61 "да" "Диспетчер ответил да после проверки адреса вызова." 16)
      (list "zh" 308 "开始" "工作人员确认安全后，会议才开始。" 12)
      (list "ja" 152 "ああ" "係員は警報を聞いて、ああと声を上げました。" 17)
      (list "ar" 499 "رائع" "قال المسعف إن التعاون كان رائع أثناء الإخلاء." 15)
      (list "hi" 929 "चिल्लाना" "धुआँ देखकर लोग चिल्लाना शुरू कर दिए।" 13)
      (list "tr" 61 "evet" "Görevli, güvenlik kontrolünden sonra evet dedi." 17)))

  (defn ctr13hb-find-id? (rows id)
    (if (eq (len rows) 0) 0
      (if (eq (ctd13-candidate-id (head rows)) id) 1
        (ctr13hb-find-id? (tail rows) id))))
  (defn ctr13hb-candidate-ids (rows out)
    (if (eq (len rows) 0) (reverse out)
      (ctr13hb-candidate-ids (tail rows)
        (cons (ctd13-candidate-id (head rows)) out))))
  (defn ctr13hb-real-go (runtime fixtures positives negatives)
    (if (eq (len fixtures) 0) (list positives negatives)
      (do (let f (head fixtures))
          (let code (nth f 0))
          (let id (nth f 1))
          (let surface (nth f 2))
          (let positive (ctd13-runtime-detect-sentence runtime code (nth f 3)))
          (let negative (ctd13-runtime-detect-sentence runtime code (nth f 4)))
          (ctr13hb-real-go runtime (tail fixtures)
            (add positives (if (eq (ctr13hb-find-id? positive id) 1) 1 0))
            (add negatives (if (eq (ctr13hb-find-id? negative id) 0) 1 0))))))
  (defn ctr13hb-ambiguity-go (runtime index candidates fixtures counts-agree index-agree)
    (if (eq (len fixtures) 0) (list counts-agree index-agree)
      (do (let f (head fixtures))
          (let code (nth f 0))
          (let id (nth f 1))
          (let surface (nth f 2))
          (let expected (nth f 4))
          (let observed (ctd13-runtime-detect-all runtime code surface (nth f 3)))
          (let info (ctr13-index-at index (ctr13-cell-index id code)))
          (let indexed (ctr13-candidates-at candidates info))
          (ctr13hb-ambiguity-go runtime index candidates (tail fixtures)
            (add counts-agree (if (eq (len observed) expected) 1 0))
            (add index-agree (if (value_eq (ctr13hb-candidate-ids observed (empty)) indexed) 1 0))))))

  (let runtime (ctd13-runtime-open))
  (let real (ctr13hb-real-go runtime (ctr13hb-real-fixtures) 0 0))
  (let ambiguous (ctr13hb-ambiguity-go runtime
    (read_file (ctr13-index-path)) (read_file (ctr13-candidates-path))
    (ctr13hb-ambiguity-fixtures) 0 0))
  (list "concept-text-heldout-unprompted-lexical-13"
    (list "positive" (nth real 0) "negative" (nth real 1)
      "ambiguity-count" (nth ambiguous 0) "index-bruteforce-agreement" (nth ambiguous 1))
    "score" (add (if (eq (nth real 0) 13) 1 0)
      (add (if (eq (nth real 1) 13) 2 0)
        (add (if (eq (nth ambiguous 0) 13) 4 0)
          (if (eq (nth ambiguous 1) 13) 8 0)))) "expected" 15))
