; nl-neutral-trace-band.fk — fkwu-witnessed band for cognition/nl-neutral-trace.fk
; and cognition/nl-pivot-de.fk.
;
; This organ opens and writes committed/runtime files (read_file, write_file,
; file_size), so it is fkwu-witnessed with its own band, never claimed four-way.
;
; Bitmask verdict:
;   1     de "Wasser" resolves to concept row 377 through the asserted seat
;   2     id "air" resolves to the SAME row 377 (cross-lingual concept identity)
;   4     neutral -> id generation returns "air"
;   8     neutral -> de generation returns "Wasser"
;   16    the de walk commits at seat de with 6 fails and 6 pruned (cut) seats
;   32    the id walk surfaces the en/id homograph fork (walk row != asserted row)
;   64    the PERSISTED index answers both queries from disk through the
;         production ra-grounded-hit-at path, selecting cell @10.3.99.377
;   128   the measured choice receipt is valid and carries 0 silences (timeouts)
;   256   pivot: tr-id-en round-trips the exemplar
;   512   pivot: neutral symbol n0 resolves and is ice-phase
;   1024  de tongue: tr-de-en decodes 'die quelle ist nativ' to the en surface
;   2048  de tongue: en->de and id->de both restore the article from the column
;   4096  sovereignty: the SAME pivot node is interned from de, en, and id (node_eq)
;   8192  per-rule counters: both nl-de rules match the de exemplar (ok 2, fail 0)
;   16384 description: row 377 carries its WordNet 3.1 gloss at synset n14869913
;   32768 senses: row 377 opens 10 attributed senses (polysemy shown, not hidden)
;   65536 local oracle dictionary: machine row 377 says de "Wasser" (agrees with body)
;   131072 parent join: row 72 (why) -> synset n09201896 -> row 483 (reason), de "Ursache"
;   262144 honest miss: row 377's parent synset is named but not among the 10k anchors
;   524288 any language: the 13-seat row for 377 renders zh and ar seats
;
; Full verdict: 1048575
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/record-src-shim.fk
; preludes: form/form-stdlib/form-ontology-loader.fk form/form-stdlib/line-grammar.fk form/form-stdlib/bmf-core.fk form/form-stdlib/bmf-grammar.fk form/form-stdlib/string-case.fk form/form-stdlib/nl-lexicon-data.fk form/form-stdlib/nl-translate.fk cognition/nl-pivot-de.fk
; preludes: form/form-stdlib/sha256.fk form/form-stdlib/hex.fk
; preludes: form/form-stdlib/text-tokenize.fk form/form-stdlib/rag-embed.fk
; preludes: form/form-stdlib/rag-retrieve.fk form/form-stdlib/rag-index-codec.fk
; preludes: form/form-stdlib/rag-ask.fk form/form-stdlib/choice-receipt.fk
; preludes: form/form-stdlib/form-fs.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk
; preludes: model/concept-10000-data.fk model/concept-10000.fk
; preludes: model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk
; preludes: cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk
; preludes: cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk cognition/nl-neutral-trace.fk
(do
  (defn nntb-bit (ok bit) (if (eq ok 1) bit 0))
  (do
    (let rt (cnl13-runtime-open))
    (let de-hit (cnl13-runtime-detect-first rt "de" "Wasser"))
    (let id-hit (cnl13-runtime-detect-first rt "id" "air"))
    (let de-walk (nnt-walk rt "Wasser"))
    (let id-walk (nnt-walk rt "air"))
    (let fire-idx (nth (cnl13-runtime-detect-first rt "en" "fire") 0))
    (let written (nnt-write-index rt 377 fire-idx))
    (let de-rag (ra-grounded-hit-at (nnt-rag-index-home) "Wasser"))
    (let id-rag (ra-grounded-hit-at (nnt-rag-index-home) "air"))
    (let receipt (nnt-receipt "de" (nth de-walk 1) (nth de-walk 2) 2 0))
    (let rules (nnt-rule-trace (nl-de) "die quelle ist nativ"))
    (let sem377 (cs10-at 377))
    (let mach (read_file (nnt-mach-path)))
    (let parents72 (nnt-parents rt 72 "de" "id"))
    (let parents377 (nnt-parents rt 377 "de" "id"))
    (let seats377 (nnt-all-seats rt 377))
    (add (nntb-bit (if (and (eq (len de-hit) 5) (eq (nth de-hit 0) 377)) 1 0) 1)
      (add (nntb-bit (if (and (eq (len id-hit) 5) (eq (nth id-hit 0) 377)) 1 0) 2)
        (add (nntb-bit (if (str_eq (cnl13-runtime-generate rt 377 "id") "air") 1 0) 4)
          (add (nntb-bit (if (str_eq (cnl13-runtime-generate rt 377 "de") "Wasser") 1 0) 8)
            (add (nntb-bit (if (and (str_eq (nth de-walk 3) "de")
                                    (and (eq (nth de-walk 2) 6) (eq (nth de-walk 6) 6))) 1 0) 16)
              (add (nntb-bit (if (and (str_eq (nth id-walk 3) "en")
                                      (not (eq (nth (nth id-walk 4) 0) 377))) 1 0) 32)
                (add (nntb-bit (if (and (eq (ra-hit? de-rag) 1)
                                        (and (str_eq (ra-hit-node-id de-rag) "@10.3.99.377")
                                             (and (eq (ra-hit? id-rag) 1)
                                                  (str_eq (ra-hit-node-id id-rag) "@10.3.99.377")))) 1 0) 64)
                  (add (nntb-bit (if (and (cr-choice-receipt-valid? receipt)
                                          (eq (cr-trace-silences (cr-receipt-trace receipt)) 0)) 1 0) 128)
                    (add (nntb-bit (if (str_eq (tr-id-en "sumber adalah asli") "the source is native") 1 0) 256)
                      (add (nntb-bit (if (and (str_eq (nlt-id->c "sumber") "n0")
                                              (str_eq (nlt-phase "n0") "ice")) 1 0) 512)
                        (add (nntb-bit (if (str_eq (tr-de-en "die quelle ist nativ")
                                                   "the source is native") 1 0) 1024)
                          (add (nntb-bit (if (and (str_eq (tr-en-de "the source is native")
                                                          "die quelle ist nativ")
                                                  (str_eq (tr-id-de "sumber adalah asli")
                                                          "die quelle ist nativ")) 1 0) 2048)
                            (add (nntb-bit (npd-pivot-agree? "die quelle ist nativ"
                                             "the source is native" "sumber adalah asli") 4096)
                              (add (nntb-bit (if (and (eq (nth rules 1) 2)
                                                      (eq (nth rules 2) 0)) 1 0) 8192)
                                (add (nntb-bit (if (and (str_eq (cs10-synset-id sem377) "n14869913")
                                                        (gt (str_len (cs10-gloss sem377)) 0)) 1 0) 16384)
                                  (add (nntb-bit (if (eq (str_find (nnt-senses-line 377)
                                                           "10 attributed" 0) 0) 1 0) 32768)
                                    (add (nntb-bit (if (str_eq (nnt-mach-label mach 377 "de")
                                                               "Wasser") 1 0) 65536)
                                      (add (nntb-bit (if (and (ge (str_find parents72 "row 483" 0) 0)
                                                              (ge (str_find parents72 "Ursache" 0) 0)) 1 0) 131072)
                                        (add (nntb-bit (if (ge (str_find parents377 "not among" 0) 0) 1 0) 262144)
                                             (nntb-bit (if (and (ge (str_find seats377 "zh:" 0) 0)
                                                                (ge (str_find seats377 "ar:" 0) 0)) 1 0) 524288)))))))))))))))))))))
