; concept-text-roundtrip-10000-13-live-band.fk -- full 130,000-cell gate.
; Expected aggregate exact dimensions and zero failures.
; preludes: form/form-stdlib/core.fk cognition/concept-text-roundtrip-10000-13-runtime.fk

(do
  (let runtime (ctr13-runtime-open))
  (let result (ctr13-runtime-exhaustive-scan runtime))
  (let score
    (add
      (if (eq (nth result 0) 130000) 1 0)
      (add (if (eq (nth result 1) 130000) 2 0)
        (add (if (eq (nth result 2) 0) 4 0)
          (add (if (eq (nth result 3) 44606) 8 0)
            (add (if (eq (nth result 4) 85394) 16 0)
              (add (if (eq (nth result 5) 220504) 32 0)
                (add (if (value_eq (nth result 6) (ctr13-source-counts)) 64 0)
                  (add (if (value_eq (nth result 7) (ctr13-sense-cell-counts)) 128 0)
                    (add (if (and (eq (nth result 8) 130000)
                                  (and (eq (nth result 9) 130000)
                                    (and (eq (nth result 10) 130000)
                                         (eq (nth result 11) 130000)))) 256 0)
                      (add (if (eq (nth result 12) 1560000) 512 0)
                        (if (eq (nth result 13) 441008) 1024 0))))))))))))
  (list "concept-text-roundtrip-10000-13-live" result "score" score "expected" 2047))
