; A 100-row shard of the exhaustive 1,300 x 10,000 live detector proof.
; Thirteen disjoint HCNL13_START/END settings cover the whole corpus exactly.
; witnessed: 2026-07-18 -> 15 for each of 13 disjoint shards
; preludes: form/form-stdlib/core.fk cognition/concept-human-corpus-13-runtime.fk
(do
  (let start (str_to_int (host-exec "printf %s \"$HCNL13_START\"" "")))
  (let end (str_to_int (host-exec "printf %s \"$HCNL13_END\"" "")))
  (let scan (hcnl13-runtime-scan-range (hcnl13-runtime-open) start end))
  (add (if (eq (sub end start) 100) 1 0)
    (add (if (eq (nth scan 1) 100) 2 0)
      (add (if (eq (nth scan 2) 0) 4 0)
        (if (eq (nth scan 8) 100) 8 0))))
)
