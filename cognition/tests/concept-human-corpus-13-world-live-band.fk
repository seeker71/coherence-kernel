; concept-human-corpus-13-world-live-band.fk -- detection-only world admission.
; Indonesian water enters from a returned candidate; a real zero row abstains.
; witnessed: 2026-07-18 -> 15 live fkwu
; preludes: form/form-stdlib/core.fk cognition/concept-human-corpus-13-runtime.fk
(do
  (let runtime (hcnl13-runtime-open))
  (let admitted (hcnl13-runtime-world-admit-index runtime 14))
  (let abstained (hcnl13-runtime-world-admit-index runtime 12))
  (add (if (and (eq (nth admitted 1) 1)
                (eq (nth admitted 3) 377)) 1 0)
    (add (if (and (eq (nth admitted 11) 1)
                  (eq (nth admitted 13) 0)) 2 0)
      (add (if (and (eq (nth abstained 1) 0)
                    (eq (nth abstained 7) 0)) 4 0)
        (if (and (eq (nth abstained 9) 0)
                 (str_eq (nth abstained 3)
                   "expected-id-absent-from-independent-content-scan")) 8 0))))
)
