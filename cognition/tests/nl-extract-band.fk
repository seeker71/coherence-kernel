; nl-extract-band.fk — fkwu-witnessed band for cognition/nl-extract.fk.
; The exemplar text is fixed so every byte interval below can be checked exactly.
;
; Exemplar: "water fire time house xylophonez"
;   water [0..5)  fire [6..10)  time [11..15)  house [16..21)  xylophonez [22..32)
;
; Bitmask verdict:
;   1   four words ground to concept rows, one word misses honestly
;   2   the first extraction is water: concept 377 at bytes [0..5)
;   4   the second extraction is fire: concept 454 at bytes [6..10)
;   8   the source binding is a full sha256 (64 hex chars)
;   16  the report says its misses out loud
;   32  case falls away before lookup: "WATER" still grounds to 377 at [0..5)
;   64  empty text extracts nothing and misses nothing (no invention)
;   128 every returned row is grounded: rows == hits (nothing floats free)
;
; Full verdict: 255
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/sha256.fk form/form-stdlib/hex.fk
; preludes: form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk cognition/nl-extract.fk
(do
  (defn nxb-bit (ok bit) (if (eq ok 1) bit 0))
  (do
    (let x (nlx-extract "water fire time house xylophonez"))
    (let r0 (nth (nlx-rows x) 0))
    (let r1 (nth (nlx-rows x) 1))
    (let up (nlx-extract "WATER"))
    (let none (nlx-extract ""))
    (add (nxb-bit (if (and (eq (nlx-hits x) 4) (eq (nlx-misses x) 1)) 1 0) 1)
      (add (nxb-bit (if (and (eq (nlx-row-id r0) 377)
                             (and (eq (nlx-row-start r0) 0) (eq (nlx-row-end r0) 5))) 1 0) 2)
        (add (nxb-bit (if (and (eq (nlx-row-id r1) 454)
                               (and (eq (nlx-row-start r1) 6) (eq (nlx-row-end r1) 10))) 1 0) 4)
          (add (nxb-bit (if (eq (str_len (nlx-source-sha x)) 64) 1 0) 8)
            (add (nxb-bit (if (ge (str_find (nlx-report "water") "honest misses" 0) 0) 1 0) 16)
              (add (nxb-bit (if (and (eq (nlx-hits up) 1)
                                     (eq (nlx-row-id (nth (nlx-rows up) 0)) 377)) 1 0) 32)
                (add (nxb-bit (if (and (eq (nlx-hits none) 0) (eq (nlx-misses none) 0)) 1 0) 64)
                     (nxb-bit (if (eq (len (nlx-rows x)) (nlx-hits x)) 1 0) 128))))))))))
