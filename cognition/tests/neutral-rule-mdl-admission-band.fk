; Neutral multi-level NL/PL rule admission acceptance band: 65535.
; preludes: form/form-stdlib/core.fk observe/framebuffer-runtime-observation.fk cognition/neutral-rule-mdl-admission.fk cognition/neutral-rule-mdl-examples.fk
(do
  (defn nrmab-bit (ok bit) (if ok bit 0))
  (defn nrmab-route (text) (nth (nrma-route-unknown text) 0))
  (defn nrmab-run ()
    (do
      (let exact (nrma-rule "atom" "nl" 1 "atom" "exact"
        "hello" "" "hola" "" 1))
      (let prefix (nrma-rule "identifier" "pl" 2 "label" "prefix"
        "ID:" "" "IDENT:" "" 2))
      (let nl-model (nrmax-nl-model))
      (let pl-model (nrmax-pl-model))
      (let nl-admit (nrma-adapt-nl nl-model (nrmax-nl-baseline)))
      (let pl-admit (nrma-adapt-pl pl-model (nrmax-pl-baseline)))
      (let overfit (nrma-adapt-pl (nrmax-overfit-model) (nrmax-pl-baseline)))
      (let c0 (nrmab-bit (and (eq (nrma-rule-level exact) 1)
        (and (eq (nrma-rule-level prefix) 2)
          (and (eq (nrma-rule-level (head (nrma-model-rules nl-model))) 3)
               (eq (nrma-model-level nl-model) 4)))) 1))
      (let c1 (nrmab-bit (and (str_eq (nrma-rewrite-rule exact "forward" "hello") "hola")
        (str_eq (nrma-rewrite-rule exact "backward" "hola") "hello")) 2))
      (let c2 (nrmab-bit (and
        (str_eq (nrma-rewrite-rule prefix "forward" "ID:42") "IDENT:42")
        (str_eq (nrma-rewrite-rule prefix "backward" "IDENT:42") "ID:42")) 4))
      (let c3 (nrmab-bit (nrma-admitted? nl-admit) 8))
      (let c4 (nrmab-bit (nrma-admitted? pl-admit) 16))
      (let c5 (nrmab-bit (str_eq
        (nrma-apply-admitted nl-admit nl-model "forward"
          "The measured temperature is 37 C.")
        "La temperatura medida es 37 C.") 32))
      (let c6 (nrmab-bit (str_eq
        (nrma-apply-admitted pl-admit pl-model "forward" "print(sensor_value)")
        "console.log(sensor_value)") 64))
      (let nl-rt (nrma-roundtrip nl-model "heldout"))
      (let pl-rt (nrma-roundtrip pl-model "heldout"))
      (let c7 (nrmab-bit (and (eq (nth nl-rt 0) 2) (eq (nth nl-rt 1) 2)) 128))
      (let c8 (nrmab-bit (and (eq (nth pl-rt 0) 2) (eq (nth pl-rt 1) 2)) 256))
      (let c9 (nrmab-bit (and
        (str_eq (nrmab-route "fn f(x) { x + 1; }") "brace-semicolon")
        (and (str_eq (nrmab-route "def f(x):\n    return x") "indent-colon")
        (and (str_eq (nrmab-route "<x>value</x>") "paired-tag")
        (and (str_eq (nrmab-route "const f = (x) => x") "arrow-expression")
        (and (str_eq (nrmab-route "(define (f x) x)") "parenthesized")
             (str_eq (nrmab-route "Why does this observed form matter?")
               "natural-prose")))))) 512))
      (let c10 (nrmab-bit (and (lt (nth nl-admit 11) (nth nl-admit 12))
                                (lt (nth pl-admit 11) (nth pl-admit 12))) 1024))
      (let c11 (nrmab-bit (and (eq (nth nl-admit 4) (nrma-grammar-size nl-model))
        (and (eq (nth nl-admit 5) 0)
             (eq (nrma-mdl-cost nl-model) (nrma-grammar-size nl-model)))) 2048))
      (let c12 (nrmab-bit (and (not (nrma-admitted? overfit))
        (and (eq (nth overfit 5) 0)
          (and (gt (nth overfit 6) 0)
               (lt (nth overfit 11) (nth overfit 12))))) 4096))
      (let c13 (nrmab-bit (str_eq
        (nrma-apply-admitted overfit (nrmax-overfit-model) "forward"
          "print(sensor_value)") "") 8192))
      (let c14 (nrmab-bit (str_eq (nth
        (nrma-adapt-nl pl-model (nrmax-pl-baseline)) 0) "refused") 16384))
      (let route-evidence (nrma-route-unknown "fn f(x) { x + 1; }"))
      (let c15 (nrmab-bit (and (eq (len (nrma-family-exemplars)) 6)
        (and (str_eq (nth route-evidence 3) "scored-from-structural-exemplar")
          (and (gt (nth route-evidence 1) 0)
               (str_eq (nrmab-route "") "unknown-structure")))) 32768))
      (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
        (add c8 (add c9 (add c10 (add c11 (add c12 (add c13
          (add c14 c15))))))))))))))))
  (nrmab-run)
)
