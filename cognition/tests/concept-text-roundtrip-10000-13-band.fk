; concept-text-roundtrip-10000-13-band.fk -- pure indexed detector contract.
; Expected 511 on all proof walkers.
; preludes: form/form-stdlib/core.fk cognition/concept-text-roundtrip-10000-13.fk

(do
  ; One synthetic cell: candidate ids 2 and 7, attributed W, ambiguous three
  ; senses, expected present, collision.
  (let index (str_concat
    (byte_to_str 0) (str_concat (byte_to_str 0) (str_concat (byte_to_str 0)
    (str_concat (byte_to_str 0) (str_concat (byte_to_str 2)
    (str_concat (byte_to_str 0) (str_concat "W" (str_concat (byte_to_str 2)
    (str_concat (byte_to_str 3) (str_concat (byte_to_str 0)
    (str_concat (byte_to_str 1) (byte_to_str 1)))))))))))))
  (let candidates (str_concat (byte_to_str 2) (str_concat (byte_to_str 0)
                    (str_concat (byte_to_str 7) (byte_to_str 0)))))
  (let info (ctr13-index-at index 0))
  (let ids (ctr13-candidates-at candidates info))
  (add
    (if (eq (ctr13-info-candidate-offset info) 0) 1 0)
    (add (if (eq (ctr13-info-candidate-count info) 2) 2 0)
      (add (if (str_eq (ctr13-info-source-code info) "W") 4 0)
        (add (if (str_eq (ctr13-sense-state (ctr13-info-sense-state-code info))
                    "sense-ambiguous") 8 0)
          (add (if (eq (ctr13-info-sense-count info) 3) 16 0)
            (add (if (eq (ctr13-info-expected-present info) 1) 32 0)
              (add (if (eq (ctr13-info-collision info) 1) 64 0)
                (add (if (and (eq (len ids) 2)
                              (and (eq (nth ids 0) 2) (eq (nth ids 1) 7))) 128 0)
                  (if (and (eq (ctr13-candidates-have-id? candidates info 2) 1)
                           (eq (ctr13-candidates-have-id? candidates info 5) 0)) 256 0)))))))))
)
