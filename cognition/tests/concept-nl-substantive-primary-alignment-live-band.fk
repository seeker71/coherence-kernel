; Canonical primary-table witness for all 111 x 13 repaired cells.
; expected: 4095
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000-substantive-repair-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk model/concept-semantics-10000-wiktionary.fk model/concept-semantics-10000-wiktionary-lexical-data.fk model/concept-semantics-10000-wiktionary-lexical.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-10000-substantive-repair-111-nl-data.fk cognition/concept-10000-substantive-repair-111-nl.fk cognition/concept-text-roundtrip-10000-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk cognition/concept-text-detection-13-runtime.fk
(do
  (defn cnl13sp-cells-go (primary repair ids codes slot labels sources)
    (if (eq (len ids) 0) (list labels sources)
      (if (eq (len codes) 0)
        (cnl13sp-cells-go primary repair (tail ids) (cnl13-locale-codes)
          (add slot 1) labels sources)
        (do (let id (head ids))
            (let code (head codes))
            (let main-label (cnl13-runtime-generate primary id code))
            (let repair-label (csr111-nl-open-generate repair id code))
            (let main-source (cnl13-runtime-source-at primary id code))
            (let repair-source (csr111-nl-source-code-at (nth repair 2) slot code))
            (cnl13sp-cells-go primary repair ids (tail codes) slot
              (add labels (if (str_eq main-label repair-label) 1 0))
              (add sources (if (str_eq main-source repair-source) 1 0)))))))
  (defn cnl13sp-find-id (rows id)
    (if (eq (len rows) 0) (empty)
      (if (eq (ctd13-candidate-id (head rows)) id) (head rows)
        (cnl13sp-find-id (tail rows) id))))
  (let primary (cnl13-runtime-open))
  (let repair (csr111-nl-open))
  (let roundtrip (ctr13-runtime-open))
  (let detector (ctd13-runtime-open))
  (let cells (cnl13sp-cells-go primary repair (csr111-ids)
    (cnl13-locale-codes) 0 0 0))
  (let welcoming (ctd13-runtime-detect-all detector "en" "welcoming"
    "A welcoming neighbor opened the community meeting."))
  (let welcoming-candidate (cnl13sp-find-id welcoming 104))
  (let rt-method4 (ctr13-runtime-verify-cell roundtrip 0 "en"))
  (let rt-method5 (ctr13-runtime-verify-cell roundtrip 104 "id"))
  (let legacy-first (c10-detect-text "didn"))
  (let legacy-middle (c10-detect-text "yöu"))
  (let legacy-last (c10-detect-text "waitin"))
  (add
    (if (eq (nth cells 0) 1443) 1 0)
    (add (if (eq (nth cells 1) 1443) 2 0)
      (add (if (str_eq (cnl13-runtime-generate primary 104 "en") "welcoming") 4 0)
        (add (if (str_eq (cnl13-runtime-generate primary 104 "id") "menyambut") 8 0)
          (add (if (str_eq (cnl13-runtime-generate primary 5019 "en") "damp") 16 0)
            (add (if (str_eq (cnl13-runtime-generate primary 9965 "ja") "梅") 32 0)
              (add (if (and (eq (ctr13-runtime-verify-cell roundtrip 9965 "ja") 511)
                            (eq (nth (cnl13-runtime-detect-first primary "ja" "梅") 0) 7967)) 64 0)
                (add (if (eq rt-method4 511) 128 0)
                  (add (if (eq rt-method5 511) 256 0)
                    (add (if (and (not (eq (len welcoming-candidate) 0))
                                  (str_eq (ctd13-candidate-method welcoming-candidate)
                                    "substantive-id-repair-wiktionary")) 512 0)
                      (add (if (and (eq (c10-concept-id legacy-first) 104)
                                    (eq (c10-concept-id legacy-middle) 5019)) 1024 0)
                        (if (eq (c10-concept-id legacy-last) 9965) 2048 0))))))))))))
)
