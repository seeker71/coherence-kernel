; language-neutral-symbol-identity-band.fk — real NL + PL vertical witness.
import "../language-neutral-symbol-identity.fk"
;
; Public vector begins [nothing, 0, 1, node-id, ...].
; witnessed: 2026-07-22 ->
; [nothing,0,1,1001099001,1001010001,1001020001,1001020002,
;  47,2,2,1,1,1,1,1,1,1,1,nothing,nothing,1]

(do
  ; Identity derives from composition, never any spelling.
  (let peace-node (lnsi-node 1 1 10 1))
  (let add-node (lnsi-node 1 1 20 1))
  (let concat-node (lnsi-node 1 1 20 2))
  ; relations: 101 peaceful-state; 201 arithmetic-add; 202 string-combine.
  ; dialects: NL 1 English / 2 Sanskrit; PL 1 Form / 2 Python.
  (let aliases (list
    (lnsi-alias 1 101 1 "peace" peace-node)
    (lnsi-alias 1 101 2 "lokah" peace-node)
    (lnsi-alias 2 201 1 "add" add-node)
    (lnsi-alias 2 201 2 "+" add-node)
    (lnsi-alias 2 202 2 "+" concat-node)))

  ; Real, committed NL source planes. The locale baseline attributes `lokah`
  ; and English `peace` to meaning 304; the meaning corpus independently
  ; carries learned English paraphrases for that same meaning.
  (let english-source (read_file "learn/nl-meaning-corpus.fk"))
  (let sanskrit-source (read_file "learn/sanskrit-locale-baseline.fk"))
  (let english-evidence (lnsi-count-exact english-source "peace"))
  (let sanskrit-exact (lnsi-count-exact sanskrit-source "lokah"))
  (let sanskrit-substring (lnsi-count-sub sanskrit-source "lokah"))

  ; Real PL surfaces from two checked-in programs.
  (let form-source (read_file "bootstrap/ground.fk"))
  (let python-source (read_file "form/form-samples/test_module.py"))
  (let form-evidence (lnsi-count-exact form-source "add"))
  (let python-evidence (lnsi-count-sub python-source " + "))

  (let nl-en (lnsi-resolve aliases 1 101 1 "peace"))
  (let nl-sa (lnsi-resolve aliases 1 101 2 "lokah"))
  (let pl-form (lnsi-resolve aliases 2 201 1 "add"))
  (let pl-python (lnsi-resolve aliases 2 201 2 "+"))
  (let pl-python-string (lnsi-resolve aliases 2 202 2 "+"))
  (let wrong-relation (lnsi-resolve aliases 1 201 1 "peace"))

  ; A term present only in provenance/header must contribute zero content hits.
  (let fake-tei "<TEI><teiHeader><availability>peace śānta</availability></teiHeader><text><body>stillness</body></text></TEI>")
  (let fake-usfm "\\id peace metadata\n\\c 1\n\\v 1 stillness\n")
  (let fake-tei-body (lnsi-tei-body-range fake-tei))
  (let fake-usfm-body (lnsi-usfm-scripture-range fake-usfm))
  (let tei-header-excluded (if (and
    (eq (lnsi-count-exact-range fake-tei "peace" fake-tei-body) 0)
    (eq (lnsi-count-exact-range fake-tei "śānta" fake-tei-body) 0)) 1 0))
  (let usfm-header-excluded (if
    (eq (lnsi-count-exact-range fake-usfm "peace" fake-usfm-body) 0) 1 0))

  (let nl-converges (if (and (eq nl-en peace-node) (eq nl-sa peace-node)) 1 0))
  (let pl-converges (if (and (eq pl-form add-node) (eq pl-python add-node)) 1 0))
  (let relation-diverges (if (and (eq pl-python-string concat-node)
    (not (eq pl-python-string pl-python))) 1 0))
  (let labels-not-identity (if (and
    (eq peace-node (lnsi-node 1 1 10 1))
    (not (eq peace-node add-node))) 1 0))
  (let evidence-live (if (and (gt english-evidence 0)
    (and (gt sanskrit-substring 0)
    (and (gt form-evidence 0) (gt python-evidence 0)))) 1 0))
  (let miss-is-nothing (if (nothing? wrong-relation) 1 0))
  (let success (if (and (eq nl-converges 1)
    (and (eq pl-converges 1)
    (and (eq relation-diverges 1)
    (and (eq labels-not-identity 1)
    (and (eq tei-header-excluded 1)
    (and (eq usfm-header-excluded 1)
    (and (eq evidence-live 1) (eq miss-is-nothing 1)))))))) 1 0))

  ; Lexical evidence is not semantic frequency: semantic claim stays nothing.
  ; [nothing,0,1,witness-node, canonical nodes,
  ;  NL exact evidence, Sanskrit exact/substrings, PL evidence,
  ;  convergence/divergence, plane exclusions, label independence,
  ;  wrong-relation ack, semantic-frequency ack, success]
  (list (nothing) 0 1 (lnsi-node 1 1 99 1)
    peace-node add-node concat-node
    english-evidence sanskrit-exact sanskrit-substring
    form-evidence python-evidence
    nl-converges pl-converges relation-diverges
    tei-header-excluded usfm-header-excluded labels-not-identity
    wrong-relation (nothing) success))
