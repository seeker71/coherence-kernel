; concept-text-roundtrip-10000-13-runtime.fk -- operational exhaustive carrier.
; witnessed: 2026-07-18 -> complete indexed detector callable over 130000 cells
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk model/concept-semantics-10000-wiktionary-data.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-roundtrip-10000-13.fk

(do
  ; runtime = NL runtime, primary semantic index, Wiktionary morphology overlay,
  ; complete surface index, candidate ids.
  (defn ctr13-runtime-open ()
    (list (cnl13-runtime-open) (read_file (cs10-index-path)) (read_file (cs10w-index-path))
      (read_file (ctr13-index-path)) (read_file (ctr13-candidates-path))))
  (defn ctr13-runtime-nl (r) (nth r 0))
  (defn ctr13-runtime-primary-semantic-index (r) (nth r 1))
  (defn ctr13-runtime-overlay-semantic-index (r) (nth r 2))
  (defn ctr13-runtime-index (r) (nth r 3))
  (defn ctr13-runtime-candidates (r) (nth r 4))
  (defn ctr13-runtime-detect-cell (r id code)
    (ctr13-detect-cell-in
      (cnl13-runtime-data (ctr13-runtime-nl r))
      (cnl13-runtime-offsets (ctr13-runtime-nl r))
      (ctr13-runtime-index r) (ctr13-runtime-candidates r) id code))
  (defn ctr13-runtime-verify-cell (r id code)
    (ctr13-verify-cell-in
      (cnl13-runtime-data (ctr13-runtime-nl r))
      (cnl13-runtime-offsets (ctr13-runtime-nl r))
      (cnl13-runtime-sources (ctr13-runtime-nl r))
      (ctr13-runtime-primary-semantic-index r) (ctr13-runtime-overlay-semantic-index r)
      (ctr13-runtime-index r) (ctr13-runtime-candidates r) id code))
  (defn ctr13-runtime-exhaustive-scan (r)
    (ctr13-exhaustive-in
      (cnl13-runtime-data (ctr13-runtime-nl r))
      (cnl13-runtime-offsets (ctr13-runtime-nl r))
      (cnl13-runtime-sources (ctr13-runtime-nl r))
      (ctr13-runtime-primary-semantic-index r) (ctr13-runtime-overlay-semantic-index r)
      (ctr13-runtime-index r) (ctr13-runtime-candidates r)))
)
