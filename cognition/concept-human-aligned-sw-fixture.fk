; concept-human-aligned-sw-fixture.fk -- provenance-bearing en->sw pairs.
;
; Retains every direct Tatoeba link whose English endpoint is in the pinned
; 10,000-row projection.  Swahili is source-exhaustive in the same snapshot.
; Split is by source sentence id mod 5, so one English source cannot leak
; across development and heldout.  The executable baseline copies the English
; source; exact heldout comparison is measured, never promoted in advance.
; witnessed: 2026-07-20 -> 94 retained pairs; 79 development / 15 heldout;
; one unavailable projection endpoint refused; source-copy exact matches 0
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/framebuffer-runtime-observation.fk cognition/concept-human-aligned-sw.fk

(do
  (defn chaswf-output-path ()
    "cognition/fixtures/human-aligned-tatoeba-13/en-sw-direct-94-joined.tsv")
  (defn chaswf-en-path () "cognition/fixtures/human-corpus-130000/en.tsv")
  (defn chaswf-sw-path () "cognition/fixtures/human-corpus-130000/sw.tsv")
  (defn chaswf-en-index-path () "cognition/fixtures/human-corpus-130000/en.u32le")
  (defn chaswf-sw-index-path () "cognition/fixtures/human-corpus-130000/sw.u32le")
  (defn chaswf-archive-url ()
    "https://downloads.tatoeba.org/exports/per_language/eng/eng-swh_links.tsv.bz2")
  (defn chaswf-archive-sha256 ()
    "81a8c343458bb8fe472f1ff1f76b770da99604693b0b924a42cb1b2426fd30a9")
  (defn chaswf-header ()
    "split\tsource_locale\tsource_lang\tsource_id\tsource_author\tsource_license\tsource_url\tsource_review_state\tsource_row_sha256\tsource_text\ttarget_locale\ttarget_lang\ttarget_id\ttarget_author\ttarget_license\ttarget_url\ttarget_review_state\ttarget_row_sha256\ttarget_text\trelation_state\tpair_snapshot\tpair_archive_url\tpair_archive_sha256\tpair_link_row_sha256\tbaseline_name\tbaseline_output\tbaseline_exact_target\n")
  (defn chaswf-field-go (line target col start i n)
    (if (ge i n) (if (eq col target) (substring line start i) "")
      (if (eq (str_byte_at line i) 9)
        (if (eq col target) (substring line start i)
          (chaswf-field-go line target (add col 1) (add i 1) (add i 1) n))
        (chaswf-field-go line target col start (add i 1) n))))
  (defn chaswf-field (line col)
    (chaswf-field-go line col 0 0 0 (str_len line)))
  (defn chaswf-find-line (data data-len locale lang id)
    (do
      (let marker (str_concat (byte_to_str 10)
        (str_concat locale (str_concat (byte_to_str 9)
          (str_concat lang (str_concat (byte_to_str 9)
            (str_concat (int_to_str id) (byte_to_str 9))))))))
      (let at (str_find data marker 0))
      (if (lt at 0) ""
        (do
          (let start (add at 1))
          (let end (chasw-line-end data data-len start))
          (substring data start end)))))
  (defn chaswf-u32-at (path index)
    (do
      (let base (mul index 4))
      (add (fs-byte-at path base)
        (add (mul (fs-byte-at path (add base 1)) 256)
          (add (mul (fs-byte-at path (add base 2)) 65536)
               (mul (fs-byte-at path (add base 3)) 16777216))))))
  (defn chaswf-index-line (data-path index-path index)
    (do
      (let start (chaswf-u32-at index-path index))
      (let end (chaswf-u32-at index-path (add index 1)))
      (fs-read-slice data-path start (sub (sub end start) 1))))
  (defn chaswf-find-index-go (data-path index-path wanted low high)
    (if (gt low high) ""
      (do
        (let mid (div (add low high) 2))
        (let line (chaswf-index-line data-path index-path mid))
        (let observed (str_to_int (chaswf-field line 2)))
        (if (eq observed wanted) line
          (if (lt observed wanted)
            (chaswf-find-index-go data-path index-path wanted (add mid 1) high)
            (chaswf-find-index-go data-path index-path wanted low (sub mid 1)))))))
  (defn chaswf-find-en-indexed (id)
    (chaswf-find-index-go (chaswf-en-path) (chaswf-en-index-path) id 0 9999))
  (defn chaswf-find-sw-indexed (id)
    (chaswf-find-index-go (chaswf-sw-path) (chaswf-sw-index-path) id 0 4582))
  (defn chaswf-split (source-id)
    (if (eq (mod source-id 5) 0) "heldout" "development"))
  (defn chaswf-concat (parts)
    (if (eq (len parts) 0) ""
      (str_concat (head parts) (chaswf-concat (tail parts)))))
  (defn chaswf-row (link-line en-line sw-line)
    (do
      (let source-id (str_to_int (chaswf-field link-line 0)))
      (let split (chaswf-split source-id))
      (let source-text (chaswf-field en-line 10))
      (let target-text (chaswf-field sw-line 10))
      (let exact (if (str_eq source-text target-text) "1" "0"))
      (chaswf-concat (list split "\ten\teng\t" (chaswf-field en-line 2)
        "\t" (chaswf-field en-line 3) "\t" (chaswf-field en-line 6)
        "\t" (chaswf-field en-line 7) "\t" (chaswf-field en-line 8)
        "\t" (chaswf-field en-line 9) "\t" source-text "\tsw\tswh\t"
        (chaswf-field sw-line 2) "\t" (chaswf-field sw-line 3)
        "\t" (chaswf-field sw-line 6) "\t" (chaswf-field sw-line 7)
        "\t" (chaswf-field sw-line 8) "\t" (chaswf-field sw-line 9)
        "\t" target-text
        "\tdirect-translation-link-human-contributed-unreviewed\t2026-07-18\t"
        (chaswf-archive-url) "\t" (chaswf-archive-sha256)
        "\tpending-form-sha256-stage\tsource-copy\t" source-text "\t" exact "\n"))))
  ; state = reversed rows, selected, development, heldout, missing,
  ; baseline exact, scanned.  Cons avoids quadratic body copying.
  (defn chaswf-build-go (links links-len pos en-data en-len sw-data sw-len
                         body selected development heldout missing exact scanned)
    (if (ge pos links-len)
      (list body selected development heldout missing exact scanned)
      (do
        (let end (chasw-line-end links links-len pos))
        (let link-line (substring links pos end))
        (let source-id (str_to_int (chaswf-field link-line 0)))
        (let target-id (str_to_int (chaswf-field link-line 1)))
        (if (or (lt source-id (chasw-source-min))
                (gt source-id (chasw-source-max)))
          (chaswf-build-go links links-len (add end 1) en-data en-len sw-data sw-len body
            selected development heldout missing exact (add scanned 1))
          (do
            (let en-line (chaswf-find-line en-data en-len "en" "eng" source-id))
            (let sw-line (chaswf-find-line sw-data sw-len "sw" "swh" target-id))
            (if (or (str_eq en-line "") (str_eq sw-line ""))
              (chaswf-build-go links links-len (add end 1) en-data en-len sw-data sw-len body
                selected development heldout (add missing 1) exact (add scanned 1))
              (do
                (let split (chaswf-split source-id))
                (let baseline-exact (if (str_eq (chaswf-field en-line 10)
                                                (chaswf-field sw-line 10)) 1 0))
                (chaswf-build-go links links-len (add end 1) en-data en-len sw-data sw-len
                  (cons (chaswf-row link-line en-line sw-line) body)
                  (add selected 1)
                  (add development (if (str_eq split "development") 1 0))
                  (add heldout (if (str_eq split "heldout") 1 0))
                  missing (add exact baseline-exact) (add scanned 1)))))))))
  (defn chaswf-build-indexed-go
    (links links-len pos rows selected development heldout missing exact scanned)
    (if (ge pos links-len)
      (list rows selected development heldout missing exact scanned)
      (do
        (let end (chasw-line-end links links-len pos))
        (let link-line (substring links pos end))
        (let source-id (str_to_int (chaswf-field link-line 0)))
        (let target-id (str_to_int (chaswf-field link-line 1)))
        (if (or (lt source-id (chasw-source-min))
                (gt source-id (chasw-source-max)))
          (chaswf-build-indexed-go links links-len (add end 1) rows selected
            development heldout missing exact (add scanned 1))
          (do
            (let en-line (chaswf-find-en-indexed source-id))
            (let sw-line (chaswf-find-sw-indexed target-id))
            (if (or (str_eq en-line "") (str_eq sw-line ""))
              (chaswf-build-indexed-go links links-len (add end 1) rows selected
                development heldout (add missing 1) exact (add scanned 1))
              (do
                (let split (chaswf-split source-id))
                (let baseline-exact (if (str_eq (chaswf-field en-line 10)
                                                (chaswf-field sw-line 10)) 1 0))
                (chaswf-build-indexed-go links links-len (add end 1)
                  (cons (chaswf-row link-line en-line sw-line) rows)
                  (add selected 1)
                  (add development (if (str_eq split "development") 1 0))
                  (add heldout (if (str_eq split "heldout") 1 0))
                  missing (add exact baseline-exact) (add scanned 1)))))))))
  (defn chaswf-build-observed ()
    (do
      (let window (fbro-open-stream "human-aligned-sw-fixture-94"
        "Sema" "retains-provenance-bearing-direct-links"
        "make-development-and-heldout-translation-relations-real"
        "tatoeba-eng-swh-plus-attributed-projections" 3680945
        "cognition/concept-human-aligned-sw-fixture.fk" 121 7))
      (let before (fbro-snapshot))
      (let links (read_file (chasw-pair-path)))
      (let built (chaswf-build-indexed-go links (str_len links) 0
        (empty) 0 0 0 0 0 0))
      (let wrote (write_file (chaswf-output-path)
        (str_concat (chaswf-header) (chaswf-concat (reverse (nth built 0))))))
      (let after (fbro-snapshot))
      (let outcome (if (and (eq (nth built 1) 94) (eq (nth built 4) 1))
        "complete-94-direct-pairs-one-endpoint-refused" "unexpected-pair-projection"))
      (let stage (fbro-stage-observed-stream "human-aligned-sw-fixture-94"
        "join-link-and-attribution-provenance" "trace-begin" "Sema"
        "retains-provenance-bearing-direct-links"
        "make-development-and-heldout-translation-relations-real"
        "tatoeba-eng-swh-plus-attributed-projections" before after
        "retained-pairs" (nth built 1) outcome
        "cognition/concept-human-aligned-sw-fixture.fk" 141 7))
      (let report (fbro-close-stream window outcome (nth built 1)
        "cognition/concept-human-aligned-sw-fixture.fk" 143 7))
      (list "en-sw-direct-pairs" (tail built) "output-bytes" wrote report
        "baseline" "source-copy" "translation-success-not-promoted")))
  (defn chaswf-profile-one-observed ()
    (do
      (let window (fbro-open-stream "human-aligned-sw-join-profile-one"
        "Sema" "profiles-one-provenance-join"
        "locate-projection-lookup-or-row-construction-cost"
        "real-link-1326-to-3653235" 3680945
        "cognition/concept-human-aligned-sw-fixture.fk" 150 7))
      (let links (read_file (chasw-pair-path)))
      (let en-data (read_file (chaswf-en-path)))
      (let sw-data (read_file (chaswf-sw-path)))
      (let link-end (chasw-line-end links (str_len links) 0))
      (let link-line (substring links 0 link-end))
      (let before-en (fbro-snapshot))
      (let en-line (chaswf-find-line en-data (str_len en-data) "en" "eng" 1326))
      (let after-en (fbro-snapshot))
      (let en-stage (fbro-stage-observed-stream
        "human-aligned-sw-join-profile-one" "find-en-1326" "trace-begin"
        "Sema" "profiles-one-provenance-join"
        "locate-projection-lookup-or-row-construction-cost"
        "en-projection" before-en after-en "bytes" (str_len en-line)
        "source-found" "cognition/concept-human-aligned-sw-fixture.fk" 164 7))
      (let before-sw (fbro-snapshot))
      (let sw-line (chaswf-find-line sw-data (str_len sw-data) "sw" "swh" 3653235))
      (let after-sw (fbro-snapshot))
      (let sw-stage (fbro-stage-observed-stream
        "human-aligned-sw-join-profile-one" "find-sw-3653235" "find-en-1326"
        "Sema" "profiles-one-provenance-join"
        "locate-projection-lookup-or-row-construction-cost"
        "sw-projection" before-sw after-sw "bytes" (str_len sw-line)
        "target-found" "cognition/concept-human-aligned-sw-fixture.fk" 174 7))
      (let before-row (fbro-snapshot))
      (let row (chaswf-row link-line en-line sw-line))
      (let after-row (fbro-snapshot))
      (let row-stage (fbro-stage-observed-stream
        "human-aligned-sw-join-profile-one" "construct-provenance-row"
        "find-sw-3653235" "Sema" "profiles-one-provenance-join"
        "locate-projection-lookup-or-row-construction-cost"
        "joined-row" before-row after-row "bytes" (str_len row)
        "row-constructed" "cognition/concept-human-aligned-sw-fixture.fk" 184 7))
      (let report (fbro-close-stream window "one-real-pair-profiled" 1
        "cognition/concept-human-aligned-sw-fixture.fk" 186 7))
      (list link-line (str_len en-line) (str_len sw-line) (str_len row) report)))
  (defn chaswf-profile-ten-observed ()
    (do
      (let window (fbro-open-stream "human-aligned-sw-join-profile-ten"
        "Sema" "profiles-ten-provenance-joins"
        "measure-target-lookup-growth-before-full-build"
        "first-10-real-eng-swh-links" 3680945
        "cognition/concept-human-aligned-sw-fixture.fk" 193 7))
      (let links (read_file (chasw-pair-path)))
      (let boundary (nth (chasw-count-go links (str_len links) 0 10 0 0) 2))
      (let before (fbro-snapshot))
      (let built (chaswf-build-indexed-go links boundary 0
        (empty) 0 0 0 0 0 0))
      (let after (fbro-snapshot))
      (let stage (fbro-stage-observed-stream
        "human-aligned-sw-join-profile-ten" "join-first-10" "trace-begin"
        "Sema" "profiles-ten-provenance-joins"
        "measure-target-lookup-growth-before-full-build"
        "first-10-real-eng-swh-links" before after "pairs" (nth built 1)
        "ten-pair-profile-complete"
        "cognition/concept-human-aligned-sw-fixture.fk" 209 7))
      (let report (fbro-close-stream window "ten-pair-profile-complete"
        (nth built 1) "cognition/concept-human-aligned-sw-fixture.fk" 212 7))
      (list (tail built) report)))
)
