; nl-grammar-induction-rule.fk -- learned two-slot surface rule mechanics.
;
; This lower cell owns paired neutral rows, literal-boundary induction,
; bidirectional ordered-slot rules, exact training coverage, conditional MDL,
; and the deliberately non-generalizing row-memory competitor.
; witnessed: 2026-07-20 -> exact bidirectional rules within composed live proof
; preludes: form/form-stdlib/core.fk
(do
  (defn ngi-pair (surface neutral) (list surface neutral))
  (defn ngi-surface (pair) (nth pair 0))
  (defn ngi-neutral (pair) (nth pair 1))
  (defn ngi-neutral-parts (neutral)
    (do
      (let p1 (str_find neutral "|" 0))
      (let p2 (if (ge p1 0) (str_find neutral "|" (add p1 1)) -1))
      (if (and (ge p1 1) (gt p2 p1))
        (list (substring neutral 0 p1)
          (substring neutral (add p1 1) p2)
          (substring neutral (add p2 1) (str_len neutral)))
        (empty))))
  (defn ngi-neutral-kind (neutral) (nth (ngi-neutral-parts neutral) 0))
  (defn ngi-neutral-build (kind a b)
    (str_concat kind (str_concat "|" (str_concat a (str_concat "|" b)))))

  (defn ngi-rule (kind order prefix infix suffix valid)
    (list "nl-surface-rule" kind order prefix infix suffix
      (list (list "clause-category" kind)
        (list "slot-order" order)
        (list "surface-literals" prefix infix suffix)) valid))
  (defn ngi-rule-kind (rule) (nth rule 1))
  (defn ngi-rule-order (rule) (nth rule 2))
  (defn ngi-rule-prefix (rule) (nth rule 3))
  (defn ngi-rule-infix (rule) (nth rule 4))
  (defn ngi-rule-suffix (rule) (nth rule 5))
  (defn ngi-rule-levels (rule) (nth rule 6))
  (defn ngi-rule-valid? (rule) (nth rule 7))
  (defn ngi-invalid-rule (kind order) (ngi-rule kind order "" "" "" 0))

  (defn ngi-induce-order (pair order)
    (do
      (let surface (ngi-surface pair))
      (let parts (ngi-neutral-parts (ngi-neutral pair)))
      (if (not (eq (len parts) 3)) (ngi-invalid-rule "" order)
        (do
          (let kind (nth parts 0))
          (let a (nth parts 1))
          (let b (nth parts 2))
          (let first (if (eq order 0) a b))
          (let second (if (eq order 0) b a))
          (let p1 (str_find surface first 0))
          (let p2 (if (ge p1 0)
            (str_find surface second (add p1 (str_len first))) -1))
          (if (or (lt p1 0) (lt p2 0)) (ngi-invalid-rule kind order)
            (ngi-rule kind order (substring surface 0 p1)
              (substring surface (add p1 (str_len first)) p2)
              (substring surface (add p2 (str_len second)) (str_len surface))
              1))))))
  (defn ngi-rule-emit-parts (rule kind a b)
    (if (not (str_eq kind (ngi-rule-kind rule))) ""
      (do
        (let first (if (eq (ngi-rule-order rule) 0) a b))
        (let second (if (eq (ngi-rule-order rule) 0) b a))
        (str_concat (ngi-rule-prefix rule) (str_concat first
          (str_concat (ngi-rule-infix rule)
            (str_concat second (ngi-rule-suffix rule))))))))
  (defn ngi-rule-emit (rule neutral)
    (do
      (let parts (ngi-neutral-parts neutral))
      (if (or (eq (ngi-rule-valid? rule) 0) (not (eq (len parts) 3))) ""
        (ngi-rule-emit-parts rule (nth parts 0) (nth parts 1) (nth parts 2)))))

  (defn ngi-starts? (text prefix)
    (if (lt (str_len text) (str_len prefix)) 0
      (if (str_eq (substring text 0 (str_len prefix)) prefix) 1 0)))
  (defn ngi-ends? (text suffix)
    (if (lt (str_len text) (str_len suffix)) 0
      (if (str_eq (substring text (sub (str_len text) (str_len suffix))
        (str_len text)) suffix) 1 0)))
  (defn ngi-rule-parse-valid (rule surface prefix infix suffix split content-end)
    (if (or (eq (ngi-rule-valid? rule) 0)
      (or (eq (str_len infix) 0)
        (or (eq (ngi-starts? surface prefix) 0)
          (or (eq (ngi-ends? surface suffix) 0)
            (or (lt split (str_len prefix))
              (gt (add split (str_len infix)) content-end)))))) 0 1))
  (defn ngi-rule-parse (rule surface)
    (do
      (let prefix (ngi-rule-prefix rule))
      (let infix (ngi-rule-infix rule))
      (let suffix (ngi-rule-suffix rule))
      (let content-end (sub (str_len surface) (str_len suffix)))
      (let split (str_find surface infix (str_len prefix)))
      (if (eq (ngi-rule-parse-valid rule surface prefix infix suffix split content-end) 0) ""
        (do
          (let first (substring surface (str_len prefix) split))
          (let second (substring surface (add split (str_len infix)) content-end))
          (let a (if (eq (ngi-rule-order rule) 0) first second))
          (let b (if (eq (ngi-rule-order rule) 0) second first))
          (if (or (eq (str_len a) 0) (eq (str_len b) 0)) ""
            (ngi-neutral-build (ngi-rule-kind rule) a b))))))

  (defn ngi-filter-kind (pairs kind)
    (if (eq (len pairs) 0) (empty)
      (if (str_eq (ngi-neutral-kind (ngi-neutral (head pairs))) kind)
        (cons (head pairs) (ngi-filter-kind (tail pairs) kind))
        (ngi-filter-kind (tail pairs) kind))))
  (defn ngi-rule-coverage (rule pairs)
    (if (eq (len pairs) 0) 0
      (add (if (str_eq (ngi-rule-emit rule (ngi-neutral (head pairs)))
        (ngi-surface (head pairs))) 1 0)
        (ngi-rule-coverage rule (tail pairs)))))
  (defn ngi-rule-mdl (rule)
    (if (eq (ngi-rule-valid? rule) 0) 1000000000
      (add 8 (add (str_len (ngi-rule-kind rule))
        (add (str_len (ngi-rule-prefix rule))
          (add (str_len (ngi-rule-infix rule)) (str_len (ngi-rule-suffix rule))))))))
  (defn ngi-memory-mdl (pairs)
    (if (eq (len pairs) 0) 0
      (add 2 (add (str_len (ngi-neutral (head pairs)))
        (add (str_len (ngi-surface (head pairs))) (ngi-memory-mdl (tail pairs)))))))
  (defn ngi-memory-emit (pairs neutral)
    (if (eq (len pairs) 0) ""
      (if (str_eq (ngi-neutral (head pairs)) neutral) (ngi-surface (head pairs))
        (ngi-memory-emit (tail pairs) neutral))))
  0)
