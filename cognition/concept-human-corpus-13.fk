; concept-human-corpus-13.fk -- attributed human sentence evidence, never a fluency claim.
;
; The selected rows are an exact, bounded view over 13 hash-pinned Tatoeba
; detailed exports.  Every row retains its contributor, upstream sentence ID,
; page URL, dates, license, source-row hash, and the complete concept-id set
; found by an independent implementation of the 10k detector.  The live runtime
; re-runs the kernel's own full-10k detector; these stored counts are expectations,
; not an oracle substituted for detection.
;
; "human-contributed-unreviewed" is deliberately narrower than human-reviewed,
; native-speaker-authored, parallel translation, or known-correct.  Returning a
; source sentence is quote retrieval, not novel natural-language generation.
; witnessed: 2026-07-18 -> 1,300 attributed rows / 52 honest negatives
; preludes: form/form-stdlib/core.fk cognition/concept-human-corpus-13-metadata.fk cognition/concept-human-corpus-13-offsets.fk cognition/concept-text-detection-13.fk
(do
  (defn hcnl13-offset-tail (offsets index)
    (if (eq index 0) offsets (hcnl13-offset-tail (tail offsets) (sub index 1))))
  (defn hcnl13-row-line (data offsets index)
    (if (or (lt index 0) (ge index (hcnl13-row-count))) ""
      (do (let at (hcnl13-offset-tail offsets index))
          (substring data (head at) (sub (head (tail at)) 1)))))
  (defn hcnl13-field-go (line target col start i)
    (if (ge i (str_len line))
      (if (eq col target) (substring line start i) "")
      (if (eq (str_byte_at line i) 9)
        (if (eq col target) (substring line start i)
          (hcnl13-field-go line target (add col 1) (add i 1) (add i 1)))
        (hcnl13-field-go line target col start (add i 1)))))
  (defn hcnl13-field (line col) (hcnl13-field-go line col 0 0 0))

  ; row = locale, Tatoeba language, sentence id, author, added, modified,
  ; license, sentence URL, role, domain, expected concept, matched surface,
  ; exact detector count, exact detector ids, review state, row hash, sentence.
  (defn hcnl13-row-at-in (data offsets index)
    (do (let line (hcnl13-row-line data offsets index))
        (list (hcnl13-field line 0) (hcnl13-field line 1)
          (str_to_int (hcnl13-field line 2)) (hcnl13-field line 3)
          (hcnl13-field line 4) (hcnl13-field line 5) (hcnl13-field line 6)
          (hcnl13-field line 7) (hcnl13-field line 8) (hcnl13-field line 9)
          (str_to_int (hcnl13-field line 10)) (hcnl13-field line 11)
          (str_to_int (hcnl13-field line 12)) (hcnl13-field line 13)
          (hcnl13-field line 14) (hcnl13-field line 15) (hcnl13-field line 16))))
  (defn hcnl13-row-locale (row) (nth row 0))
  (defn hcnl13-row-sentence-id (row) (nth row 2))
  (defn hcnl13-row-author (row) (nth row 3))
  (defn hcnl13-row-license (row) (nth row 6))
  (defn hcnl13-row-url (row) (nth row 7))
  (defn hcnl13-row-role (row) (nth row 8))
  (defn hcnl13-row-domain (row) (nth row 9))
  (defn hcnl13-row-expected-concept (row) (nth row 10))
  (defn hcnl13-row-surface (row) (nth row 11))
  (defn hcnl13-row-detection-count (row) (nth row 12))
  (defn hcnl13-row-review-state (row) (nth row 14))
  (defn hcnl13-row-source-hash (row) (nth row 15))
  (defn hcnl13-row-sentence (row) (nth row 16))

  ; Stable completion-ledger row: address counts never stand in for reviewed
  ; language or novel generation.  The last two fields keep those zeros named.
  (defn hcnl13-completion-evidence ()
    (do (let valid (hcnl13-artifacts-valid?))
      (list "attributed-human-sentence-corpus"
        (if (eq valid 1) (hcnl13-row-count) 0)
        (if (eq valid 1) (hcnl13-locale-count) 0)
        (if (eq valid 1) (hcnl13-detection-count) 0)
        (if (eq valid 1) (hcnl13-unique-concept-count) 0)
        (if (eq valid 1) (hcnl13-domain-count) 0)
        (if (eq valid 1) (hcnl13-ambiguity-count) 0)
        (if (eq valid 1) (hcnl13-negative-count) 0)
        (if (eq valid 1) (hcnl13-attributed-count) 0)
        (hcnl13-human-reviewed-count) 0
        "quote-retrieval-not-novel-generation")))

  (defn hcnl13-candidates-have-id? (candidates id)
    (if (eq (len candidates) 0) 0
      (if (eq (ctd13-candidate-id (head candidates)) id) 1
        (hcnl13-candidates-have-id? (tail candidates) id))))
  (defn hcnl13-detection-valid? (row candidates)
    (and (eq (len candidates) (hcnl13-row-detection-count row))
      (if (str_eq (hcnl13-row-role row) "negative")
        (eq (len candidates) 0)
        (hcnl13-candidates-have-id? candidates (hcnl13-row-expected-concept row)))))
  (defn hcnl13-detection-state (row candidates)
    (if (eq (hcnl13-detection-valid? row candidates) 0) "mismatch"
      (if (str_eq (hcnl13-row-role row) "negative") "expected-zero-detection"
        (if (str_eq (hcnl13-row-role row) "ambiguity") "ambiguity-retained"
          "attributed-domain-match"))))

  ; Lightweight complete detector for exhaustive corpus accounting.  It walks
  ; all 10,000 locale labels and applies the exact shared occurrence predicate,
  ; but returns ids only; rich candidate/sense construction remains available
  ; from hcnl13-runtime-detect-index for an individual observation.
  (defn hcnl13-detect-ids-go (data offset-tail col code sentence id out)
    (if (ge id (cnl13-anchor-count)) (reverse out)
      (do (let line (cnl13-row-line-from-tail data offset-tail))
          (let surface (cnl13-field line col))
          (hcnl13-detect-ids-go data (tail offset-tail) col code sentence
            (add id 1) (if (eq (ctd13-occurs? sentence surface code) 1)
                         (cons id out) out)))))
  (defn hcnl13-detect-ids-in (data offsets code sentence)
    (do (let col (cnl13-locale-col code))
        (if (or (lt col 1) (str_eq sentence "")) (empty)
          (hcnl13-detect-ids-go data offsets col code sentence 0 (empty)))))
  (defn hcnl13-ids-have-id? (ids id)
    (if (eq (len ids) 0) 0
      (if (eq (head ids) id) 1 (hcnl13-ids-have-id? (tail ids) id))))
  (defn hcnl13-ids-valid? (row ids)
    (and (eq (len ids) (hcnl13-row-detection-count row))
      (if (str_eq (hcnl13-row-role row) "negative") (eq (len ids) 0)
        (hcnl13-ids-have-id? ids (hcnl13-row-expected-concept row)))))

  ; A quote is an upstream sentence plus attribution.  The leading state makes
  ; it impossible for callers to mistake retrieval for novel generation.
  (defn hcnl13-quote (row)
    (list "attributed-human-quote-not-novel-generation"
      (hcnl13-row-locale row) (hcnl13-row-expected-concept row)
      (hcnl13-row-sentence-id row) (hcnl13-row-author row)
      (hcnl13-row-license row) (hcnl13-row-url row)
      (hcnl13-row-review-state row) (hcnl13-row-source-hash row)
      (hcnl13-row-sentence row)))
)
