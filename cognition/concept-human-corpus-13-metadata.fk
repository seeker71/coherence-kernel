; Human-contributed does not imply native-speaker or human-reviewed; reviewed count is zero.
; witnessed: 2026-07-18 -> 147 source rows, 828 detected concepts, 13/13 negative rows
; preludes: form/form-stdlib/core.fk
(do
  (defn hcnl13-row-count () 147)
  (defn hcnl13-locale-count () 13)
  (defn hcnl13-domain-count () 122)
  (defn hcnl13-ambiguity-count () 12)
  (defn hcnl13-negative-count () 13)
  (defn hcnl13-detection-count () 1898)
  (defn hcnl13-unique-concept-count () 828)
  (defn hcnl13-attributed-count () 147)
  (defn hcnl13-human-reviewed-count () 0)
  (defn hcnl13-data-path () "cognition/fixtures/human-corpus-13/tatoeba-human-sentences.tsv")
  (defn hcnl13-manifest-path () "cognition/fixtures/human-corpus-13/ARCHIVES.tsv")
  (defn hcnl13-data-sha256 () "fd291d23ca345c0ed68dfb20b700c47e6fcb9fe4ba734ee858cab241ba97b7c0")
  (defn hcnl13-manifest-sha256 () "7fd8536857ae1ed1911228ec398befeced744c9fe7aa24186412a915b0f35a06")
  (defn hcnl13-hash-valid? (path expected)
    (if (str_eq (host-exec (str_concat "/usr/bin/shasum -a 256 "
      (str_concat path (str_concat " | /usr/bin/grep -q '^"
        (str_concat expected "  ' && printf 1")))) "") "1") 1 0))
  (defn hcnl13-artifacts-valid? ()
    (and (eq (hcnl13-hash-valid? (hcnl13-data-path)
               (hcnl13-data-sha256)) 1)
         (eq (hcnl13-hash-valid? (hcnl13-manifest-path)
               (hcnl13-manifest-sha256)) 1)))
  (defn hcnl13-locale-stats () (list
    (list "en" 11 10 0 1)
    (list "id" 10 8 1 1)
    (list "es" 12 10 1 1)
    (list "fr" 12 10 1 1)
    (list "pt-br" 12 10 1 1)
    (list "sw" 12 10 1 1)
    (list "de" 12 10 1 1)
    (list "ru" 12 10 1 1)
    (list "zh" 12 10 1 1)
    (list "ja" 11 9 1 1)
    (list "ar" 8 6 1 1)
    (list "hi" 11 9 1 1)
    (list "tr" 12 10 1 1)))
)
