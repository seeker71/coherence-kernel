; concept-text-detection-13-runtime.fk -- live carrier for complete text sense.
; witnessed: 2026-07-18 -> 13-lens sentence detection + explicit WordNet sets
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk model/concept-10000-data.fk model/concept-10000.fk model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk cognition/concept-nl-semantic-13-runtime.fk cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk cognition/concept-text-detection-13.fk
(do
  ; runtime = nl-runtime, ranked, semantic-index, semantic-payload, sense-data,
  ;           sense-offsets. All meaning stays in Form; read_file is the carrier.
  (defn ctd13-runtime-open ()
    (list (cnl13-runtime-open) (read_file (c10-ranked-path))
          (read_file (cs10-index-path)) (read_file (cs10-payload-path))
          (read_file (cts10-data-path)) (cts10-offsets)))
  (defn ctd13-runtime-nl (r) (nth r 0))
  (defn ctd13-runtime-ranked (r) (nth r 1))
  (defn ctd13-runtime-semantic-index (r) (nth r 2))
  (defn ctd13-runtime-semantic-payload (r) (nth r 3))
  (defn ctd13-runtime-sense-data (r) (nth r 4))
  (defn ctd13-runtime-sense-offsets (r) (nth r 5))
  (defn ctd13-runtime-detect-all (r code surface sentence)
    (ctd13-detect-all-in (cnl13-runtime-data (ctd13-runtime-nl r))
      (cnl13-runtime-offsets (ctd13-runtime-nl r)) (ctd13-runtime-ranked r)
      (ctd13-runtime-semantic-index r) (ctd13-runtime-semantic-payload r)
      (ctd13-runtime-sense-data r) (ctd13-runtime-sense-offsets r)
      (cnl13-runtime-sources (ctd13-runtime-nl r)) code surface sentence))
  (defn ctd13-runtime-detect-surface-in-sentence (r code surface sentence)
    (ctd13-detect-surface-in-sentence-in
      (cnl13-runtime-data (ctd13-runtime-nl r))
      (cnl13-runtime-offsets (ctd13-runtime-nl r)) (ctd13-runtime-ranked r)
      (ctd13-runtime-semantic-index r) (ctd13-runtime-semantic-payload r)
      (ctd13-runtime-sense-data r) (ctd13-runtime-sense-offsets r)
      (cnl13-runtime-sources (ctd13-runtime-nl r)) code surface sentence))
  (defn ctd13-runtime-detect-sentence (r code sentence)
    (ctd13-detect-sentence-in (cnl13-runtime-data (ctd13-runtime-nl r))
      (cnl13-runtime-offsets (ctd13-runtime-nl r)) (ctd13-runtime-ranked r)
      (ctd13-runtime-semantic-index r) (ctd13-runtime-semantic-payload r)
      (ctd13-runtime-sense-data r) (ctd13-runtime-sense-offsets r)
      (cnl13-runtime-sources (ctd13-runtime-nl r)) code sentence))
  (defn ctd13-runtime-senses (r id)
    (cts10-senses-in (ctd13-runtime-sense-data r) (ctd13-runtime-sense-offsets r) id))
  (defn ctd13-runtime-analyze-senses (r id sentence)
    (cts10-analyze-in (ctd13-runtime-sense-data r) (ctd13-runtime-sense-offsets r) id sentence))
)
