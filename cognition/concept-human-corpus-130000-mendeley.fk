; concept-human-corpus-130000-mendeley.fk -- add real Swahili source passages.
;
; Mendeley Data V2 is a CC BY 4.0 corpus extracted from official-source PDF
; and DOCX documents.  This cell selects 5,417 non-trivial, canonically
; distinct BUNGE text rows and writes their complete source lineage.  Dataset
; contributors are not mislabeled as the authors of individual parliamentary
; passages: the upstream cleaning retained category and line, but not each
; document author.
;
; Selection, normalization used only for duplicate detection, source-row
; hashing, projection, indexing, and audit counters are Form-native.  The
; committed BUNGE file is the exact downloaded artifact; no host program owns
; a semantic decision.
; Upstream does not define each cleaned line as a sentence: lines include
; headings, fragments and paragraphs.  Therefore these are human-source text
; passages under dataset-level attribution, not proof of the still-missing
; 5,417 individually attributed sentences.
; witnessed: 2026-07-20 -> 5417 text passages selected; 737 source duplicates
; and zero old-corpus overlaps refused; strict sentence closure remains 0
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/line-grammar.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/sha256.fk form/form-stdlib/text-tokenize.fk cognition/concept-human-corpus-130000-metadata.fk cognition/concept-human-corpus-130000-ingest.fk cognition/concept-human-corpus-130000.fk observe/framebuffer-runtime-observation.fk

(do
  (defn chc130m-target () 5417)
  (defn chc130m-input-path ()
    "cognition/fixtures/human-corpus-130000-mendeley/BUNGE_Cleaned.txt")
  (defn chc130m-output-path ()
    "cognition/fixtures/human-corpus-130000-mendeley/sw-bunge-5417.tsv")
  (defn chc130m-index-path ()
    "cognition/fixtures/human-corpus-130000-mendeley/sw-bunge-5417.u32le")
  (defn chc130m-source-url ()
    "https://data.mendeley.com/public-files/datasets/d4yhn5b9n6/files/6f043d7d-02ae-4de4-a7a1-5e43bddbe19f/file_downloaded")
  (defn chc130m-doi-url () "https://doi.org/10.17632/d4yhn5b9n6.2")
  (defn chc130m-source-sha256 ()
    "e6dd930be568924be2c84cf4566184b1e62fc8ea917d1d54cc9665f2518c9474")
  (defn chc130m-source-bytes () 3648233)
  (defn chc130m-output-bytes () 2879167)
  (defn chc130m-index-bytes () 21672)
  (defn chc130m-output-sha256 ()
    "ad8f30d8d8503ee40884078e0607652ed23c781d7a8b484284926ab3e1d8fc39")
  (defn chc130m-index-sha256 ()
    "0069270f13b734544c7c6c0fea1b1ca4e21b7db2eed71cec16572b17f025a8de")

  (defn chc130m-header ()
    "locale\tlanguage\tcategory\tsource_line\tdataset_contributors\tpublished\tlicense\tdataset_doi\tfile_uuid\thuman_source_state\tsource_row_sha256\tcanonical_sha256\ttext\n")
  (defn chc130m-output-open ()
    (do
      (let header (chc130m-header))
      (let data-size (write_file (chc130m-output-path) header))
      (let cleared-index (write_file (chc130m-index-path) ""))
      (let index-size (file_append_bytes (chc130m-index-path)
        (chc130-u32le (str_len header))))
      (list data-size cleared-index index-size)))

  (defn chc130m-tab-free-go (s i)
    (if (ge i (str_len s)) 1
      (if (eq (str-byte-at s i) 9) 0
        (chc130m-tab-free-go s (add i 1)))))
  (defn chc130m-word-count-go (s i count in-word)
    (if (ge i (str_len s)) (add count in-word)
      (do
        (let space (eq (str-byte-at s i) 32))
        (chc130m-word-count-go s (add i 1)
          (add count (if (and space (eq in-word 1)) 1 0))
          (if space 0 1)))))
  (defn chc130m-word-count (s) (chc130m-word-count-go s 0 0 0))
  (defn chc130m-canonical (text) (tk-words (trim text) 1))
  (defn chc130m-eligible? (raw canonical)
    (and (eq (chc130m-tab-free-go raw 0) 1)
      (and (ge (str_len canonical) 40)
        (and (le (str_len raw) 2000)
             (ge (chc130m-word-count canonical) 6)))))
  (defn chc130m-member? (wanted values)
    (if (eq (len values) 0) 0
      (if (str_eq wanted (head values)) 1
        (chc130m-member? wanted (tail values)))))

  ; Canonical old-text inventory makes overlap independently observable.  The
  ; canonical is only a comparison key; the exact upstream row stays intact in
  ; its own old projection and the trimmed BUNGE text is retained below.
  (defn chc130m-old-canonicals-go (index out)
    (if (ge index (chc130-spec-rows (chc130-spec-at "sw"))) out
      (do
        (let row (chc130-row-at "sw" index))
        (let canonical (chc130m-canonical (chc130-field row 10)))
        (chc130m-old-canonicals-go (add index 1)
          (if (str_eq canonical "") out (cons canonical out))))))
  (defn chc130m-old-canonicals () (chc130m-old-canonicals-go 0 (empty)))

  (defn chc130m-projection-row (source-line raw canonical)
    (chc130-concat (list
      "sw\tswh\tBUNGE\t" (int_to_str source-line)
      "\tNoel Masasi; Bernard Masua\t2024-01-24\tCC-BY-4.0\t"
      (chc130m-doi-url)
      "\t6f043d7d-02ae-4de4-a7a1-5e43bddbe19f"
      "\tofficial-source-document-extracted; individual-author-not-retained\t"
      (chc130-source-hash raw) "\t" (chc130-source-hash canonical)
      "\t" (trim raw) "\n")))

  ; scan = selected, source-lines-seen, rejected-shape, duplicate-old,
  ; duplicate-new, source-bytes, output-bytes, index-bytes, status.
  (defn chc130m-select-go
    (lines old selected-canons selected seen rejected duplicate-old duplicate-new
     source-bytes)
    (if (ge selected (chc130m-target))
      (list selected seen rejected duplicate-old duplicate-new source-bytes
        (fs-stat-size (chc130m-output-path))
        (fs-stat-size (chc130m-index-path)) "target-met")
      (if (eq (len lines) 0)
        (list selected seen rejected duplicate-old duplicate-new source-bytes
          (fs-stat-size (chc130m-output-path))
          (fs-stat-size (chc130m-index-path)) "source-exhausted")
        (do
          (let line-row (head lines))
          (let raw (line-text line-row))
          (let canonical (chc130m-canonical raw))
          (let next-bytes (add source-bytes (add (str_len raw) 1)))
          (if (eq (chc130m-eligible? raw canonical) 0)
            (chc130m-select-go (tail lines) old selected-canons selected
              (add seen 1) (add rejected 1) duplicate-old duplicate-new
              next-bytes)
            (if (eq (chc130m-member? canonical old) 1)
              (chc130m-select-go (tail lines) old selected-canons selected
                (add seen 1) rejected (add duplicate-old 1) duplicate-new
                next-bytes)
              (if (eq (chc130m-member? canonical selected-canons) 1)
                (chc130m-select-go (tail lines) old selected-canons selected
                  (add seen 1) rejected duplicate-old (add duplicate-new 1)
                  next-bytes)
                (do
                  (let row (chc130m-projection-row (line-num line-row) raw canonical))
                  (let data-size (file_append_bytes (chc130m-output-path)
                    (chc130-string-bytes row)))
                  (let index-size (file_append_bytes (chc130m-index-path)
                    (chc130-u32le data-size)))
                  (chc130m-select-go (tail lines) old
                    (cons canonical selected-canons) (add selected 1)
                    (add seen 1) rejected duplicate-old duplicate-new
                    next-bytes)))))))))

  (defn chc130m-ingest-observed ()
    (do
      (let window (fbro-open-stream "human-corpus-sw-bunge-5417"
        "Sema" "selects-attributed-official-swahili"
        "close-real-human-swahili-source-deficit"
        "mendeley-cc-by-4-bunge-v2" (chc130m-source-bytes)
        "cognition/concept-human-corpus-130000-mendeley.fk" 134 7))
      (let opened (chc130m-output-open))
      (let before (fbro-snapshot))
      (let source (read_file (chc130m-input-path)))
      (let old (chc130m-old-canonicals))
      (let scan (chc130m-select-go (lines-from-source source) old (empty)
        0 0 0 0 0 0))
      (let after (fbro-snapshot))
      (let outcome (if (and (eq (nth scan 0) (chc130m-target))
                            (str_eq (nth scan 8) "target-met"))
        "target-met-distinct-official-source" "source-shortfall-no-padding"))
      (let stage (fbro-stage-observed-stream "human-corpus-sw-bunge-5417"
        "canonical-deduplicate-and-project" "trace-begin" "Sema"
        "selects-attributed-official-swahili"
        "close-real-human-swahili-source-deficit"
        "mendeley-cc-by-4-bunge-v2" before after "attributed-rows"
        (nth scan 0) outcome
        "cognition/concept-human-corpus-130000-mendeley.fk" 153 7))
      (let report (fbro-close-stream window outcome (nth scan 0)
        "cognition/concept-human-corpus-130000-mendeley.fk" 156 7))
      (list "concept-human-corpus-sw-bunge-5417" report scan
        "prior-attributed-rows" 124583 "new-attributed-rows" (nth scan 0)
        "total-human-source-text-rows" (add 124583 (nth scan 0))
        "strict-new-attributed-sentences" 0
        "strict-attributed-sentence-shortfall" 5417
        "translations" 0 "novel-generation" 0)))
)
