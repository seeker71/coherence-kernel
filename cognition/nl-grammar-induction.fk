; nl-grammar-induction.fk -- bounded Form-native surface grammar learning.
;
; Learns reusable category/order/literal-boundary rules from paired surface and
; neutral rows, selects the shortest exact-coverage candidate by conditional
; MDL, and admits only a reusable rule to bidirectional emission/parsing.
;
; Honest boundary: the learned rule data directly matches BMF's pattern/template
; concepts (category, ordered captures, literal runs, inverse emission), but a
; lowerer from this learned value into `grammar`/`rule3` BMF values is not built
; here.  Runtime calls this learned value directly.  This is bounded two-slot
; fixed-literal induction, not general NL, morphology, translation, or fluency.
; witnessed: 2026-07-20 -> three reusable MDL winners transfer held-out content
; preludes: form/form-stdlib/core.fk cognition/nl-grammar-induction-rule.fk
(do
  ; candidate = tag, name, mdl, coverage, reusable?, payload
  (defn ngi-candidate (name mdl coverage reusable payload)
    (list "nl-grammar-candidate" name mdl coverage reusable payload))
  (defn ngi-candidate-name (c) (nth c 1))
  (defn ngi-candidate-mdl (c) (nth c 2))
  (defn ngi-candidate-coverage (c) (nth c 3))
  (defn ngi-candidate-reusable? (c) (nth c 4))
  (defn ngi-candidate-payload (c) (nth c 5))
  (defn ngi-best-covered-go (candidates required best)
    (if (eq (len candidates) 0) best
      (do
        (let c (head candidates))
        (if (and (eq (ngi-candidate-coverage c) required)
              (or (eq (len best) 0)
                (lt (ngi-candidate-mdl c) (ngi-candidate-mdl best))))
          (ngi-best-covered-go (tail candidates) required c)
          (ngi-best-covered-go (tail candidates) required best)))))
  (defn ngi-learn-kind (all-pairs kind)
    (do
      (let pairs (ngi-filter-kind all-pairs kind))
      (let forward (ngi-induce-order (head pairs) 0))
      (let reverse-order (ngi-induce-order (head pairs) 1))
      (let candidates (list
        (ngi-candidate "ordered-slot-rule-forward" (ngi-rule-mdl forward)
          (ngi-rule-coverage forward pairs) 1 forward)
        (ngi-candidate "ordered-slot-rule-reverse" (ngi-rule-mdl reverse-order)
          (ngi-rule-coverage reverse-order pairs) 1 reverse-order)
        (ngi-candidate "memorized-row-table" (ngi-memory-mdl pairs)
          (len pairs) 0 pairs)))
      (list kind pairs candidates
        (ngi-best-covered-go candidates (len pairs) (empty)))))
  (defn ngi-learn-kinds (pairs kinds)
    (if (eq (len kinds) 0) (empty)
      (cons (ngi-learn-kind pairs (head kinds))
        (ngi-learn-kinds pairs (tail kinds)))))
  (defn ngi-grammar (pairs kinds)
    (list "nl-induced-grammar" (ngi-learn-kinds pairs kinds)))
  (defn ngi-grammar-record-go (records kind)
    (if (eq (len records) 0) (empty)
      (if (str_eq (nth (head records) 0) kind) (head records)
        (ngi-grammar-record-go (tail records) kind))))
  (defn ngi-grammar-record (grammar kind)
    (ngi-grammar-record-go (nth grammar 1) kind))
  (defn ngi-record-selected (record) (nth record 3))
  (defn ngi-grammar-rule (grammar kind)
    (do
      (let selected (ngi-record-selected (ngi-grammar-record grammar kind)))
      (if (and (gt (len selected) 0) (eq (ngi-candidate-reusable? selected) 1))
        (ngi-candidate-payload selected) (ngi-invalid-rule kind 0))))
  (defn ngi-grammar-emit (grammar neutral)
    (do
      (let parts (ngi-neutral-parts neutral))
      (if (not (eq (len parts) 3)) ""
        (ngi-rule-emit (ngi-grammar-rule grammar (nth parts 0)) neutral))))
  (defn ngi-grammar-parse (grammar kind surface)
    (ngi-rule-parse (ngi-grammar-rule grammar kind) surface))
  (defn ngi-grammar-emit-seq (grammar neutrals separator)
    (if (eq (len neutrals) 0) ""
      (if (eq (len (tail neutrals)) 0)
        (ngi-grammar-emit grammar (head neutrals))
        (str_concat (ngi-grammar-emit grammar (head neutrals))
          (str_concat separator
            (ngi-grammar-emit-seq grammar (tail neutrals) separator))))))

  (defn ngi-training-pairs ()
    (list
      (ngi-pair "the source is native" "property|source|native")
      (ngi-pair "the kernel is stable" "property|kernel|stable")
      (ngi-pair "the body is present" "property|body|present")
      (ngi-pair "is the source native?" "question|source|native")
      (ngi-pair "is the kernel stable?" "question|kernel|stable")
      (ngi-pair "is the body present?" "question|body|present")
      (ngi-pair "disk full: cache" "alert|cache|disk full")
      (ngi-pair "deadline missed: decoder" "alert|decoder|deadline missed")
      (ngi-pair "checksum failed: carrier" "alert|carrier|checksum failed")))
  (defn ngi-kinds () (list "property" "question" "alert"))
  (defn ngi-held-property () "property|signal|grounded")
  (defn ngi-held-question () "question|signal|grounded")
  (defn ngi-held-alert () "alert|framebuffer|budget exceeded")
  (defn ngi-held-word-seen? (pairs word)
    (if (eq (len pairs) 0) 0
      (if (ge (str_find (ngi-neutral (head pairs)) word 0) 0) 1
        (ngi-held-word-seen? (tail pairs) word))))
  0)
