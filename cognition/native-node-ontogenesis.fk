; native-node-ontogenesis.fk — unresolved evidence proposes a blueprint,
; executable recipe, named cell, inquiry surface, and reversible admission.
import "native-self-orientation.fk"
import "../ingest/name-build-observe.fk"
import "../observe/belief-freshness.fk"

(do
  (defn nno-admit-action () 6)
  (defn nno-defer-action () 7)
  (defn nno-reject-action () 8)
  (defn nno-epoch () 20260722)

  ; Evidence record readers from ncc-triangulated-witness notable rows:
  ; [hash,length,truth,base,rehearsal,lexical,recognized,action,route]
  (defn nno-e-hash (e) (nth e 0))
  (defn nno-e-length (e) (nth e 1))
  (defn nno-e-truth (e) (nth e 2))
  (defn nno-e-base (e) (nth e 3))
  (defn nno-e-rehearsal (e) (nth e 4))
  (defn nno-e-lexical (e) (nth e 5))

  ; Candidate pressure is prediction structure only; truth is not consulted.
  (defn nno-independent-consensus? (e)
    (if (and (not (eq (nno-e-base e) (nno-e-rehearsal e)))
             (eq (nno-e-rehearsal e) (nno-e-lexical e))) 1 0))
  (defn nno-support (rows)
    (if (eq (len rows) 0) (list)
      (if (eq (nno-independent-consensus? (head rows)) 1)
        (cons (head rows) (nno-support (tail rows)))
        (nno-support (tail rows)))))

  ; The executable recipe returns a class only when its structural relation
  ; holds. Nothing remains a first-class result for every other observation.
  (defn nno-recipe-run (e)
    (if (eq (nno-independent-consensus? e) 1)
      (nno-e-rehearsal e) (nothing)))

  ; Identity derives from recipe content, never from an offered name.
  (defn nno-recipe-identity ()
    (nmn-hash "if-base-differs-and-rehearsal-equals-exact-token-return-consensus"))
  (defn nno-node () (add 2000000000 (nno-recipe-identity)))
  (defn nno-alternative () (nid-alternative (lnii-subject (nno-node)) 0))

  ; Blueprint is executable shape, recipe identity, observed support shape,
  ; and offered seven-lane interface. No evidence row is embedded as an answer.
  (defn nno-blueprint (support-count)
    (list 1001099201 (nno-recipe-identity) 3 support-count 7))
  (defn nno-recipe ()
    (list 1001099202 1 1 1 (nno-recipe-identity)))
  ; Named-cell aliases are surfaces pointing to the node, never its identity.
  (defn nno-names ()
    (list
      (lnsi-alias 1 301 1 "independent consensus" (nno-node))
      (lnsi-alias 2 301 1 "admit-independent-consensus" (nno-node))
      (lnsi-alias 0 301 0 "consensus" (nno-node))))
  (defn nno-interfaces () (list 0 1 2 3 4 5 6))

  ; Candidate = [node,blueprint,recipe,names,interfaces,support,alternative].
  (defn nno-candidate (support)
    (list (nno-node) (nno-blueprint (len support)) (nno-recipe)
      (nno-names) (nno-interfaces) support (nno-alternative)))

  (defn nno-validation-count (rows correct)
    (if (eq (len rows) 0) correct
      (nno-validation-count (tail rows)
        (add correct (if (eq (nno-recipe-run (head rows))
                             (nno-e-truth (head rows))) 1 0)))))
  (defn nno-take (rows n)
    (if (or (eq n 0) (eq (len rows) 0)) (list)
      (cons (head rows) (nno-take (tail rows) (sub n 1)))))
  (defn nno-drop (rows n)
    (if (or (eq n 0) (eq (len rows) 0)) rows
      (nno-drop (tail rows) (sub n 1))))

  ; Canonical identity and every offered name must resolve to the same node.
  (defn nno-names-valid? (names)
    (if (eq (len names) 0) 1
      (if (eq (nth (head names) 4) (nno-node))
        (nno-names-valid? (tail names)) 0)))
  (defn nno-candidate-valid? (candidate validation)
    (if (and (eq (nth candidate 0) (nno-node))
      (and (eq (nth (nth candidate 1) 1) (nno-recipe-identity))
      (and (eq (nth (nth candidate 2) 4) (nno-recipe-identity))
      (and (eq (nno-names-valid? (nth candidate 3)) 1)
      (and (eq (len (nth candidate 4)) 7)
           (eq (nno-validation-count validation 0) (len validation))))))) 1 0))

  (defn nno-tamper-node (candidate)
    (list (add (nth candidate 0) 1) (nth candidate 1) (nth candidate 2)
      (nth candidate 3) (nth candidate 4) (nth candidate 5) (nth candidate 6)))

  ; Admission composes name-build-observe, freshness, inquiry replay, and a
  ; correlated framebuffer decision. Status: 2 admitted claim, 1 lesson, 0 held.
  (defn nno-admit (candidate validation)
    (do (let valid (nno-candidate-valid? candidate validation))
      (let inquiry-ok (if (eq valid 1)
        (lnii-lanes-ok (lnii-subject (nth candidate 0)) 0 0) 0))
      (let observed (if (and (eq valid 1) (eq inquiry-ok 7)) 1 0))
      (let status (nbo-enter (list 1 1 observed)))
      (let freshness (bf-status
        (bf-belief (nth candidate 0) observed (nno-epoch)) (nno-epoch)))
      (let outbound (bfc-envelope 0 9201 0
        (list (nth candidate 0) valid inquiry-ok status freshness)
        (nth candidate 6)))
      (let out-event (bfc-record-out outbound 9201))
      (let action (if (and (eq status 2) (eq freshness 2))
        (nno-admit-action) (if (eq status 1) (nno-defer-action) (nno-reject-action))))
      (let inbound (bfc-control outbound action))
      (let in-event (bfc-record-in inbound 9202))
      (list status freshness inquiry-ok action valid)))

  (defn nno-witness ()
    (do
      ; Live unresolved evidence is produced by the cognition cycle.
      (let before-witness (ncc-triangulated-witness))
      (let before-floor (nso-floor before-witness))
      (let routed (nth before-witness 15))
      (let support (nno-support routed))
      ; First two matching rows admit; remaining matching rows are unseen by
      ; admission and adjudicate transfer afterward.
      (let validation (nno-take support 2))
      (let transfer (nno-drop support 2))
      (let candidate (nno-candidate support))

      (framebuffer-clear)
      (let admission (nno-admit candidate validation))
      (let tampered (nno-admit (nno-tamper-node candidate) validation))
      (let lapsed-belief (bf-rewitness
        (bf-belief (nno-node) 1 (nno-epoch)) (nno-epoch) 0))
      (let lapsed-status (bf-status lapsed-belief (nno-epoch)))
      (let transfer-correct (nno-validation-count transfer 0))
      (let transferred (if (eq (nth admission 0) 2) transfer-correct 0))
      (let admitted-rows (add (len validation) transferred))
      (let updated-native (add (nso-native before-floor) admitted-rows))
      (let updated-evidence (sub (nso-evidence before-floor) admitted-rows))
      (let updated-correct (add (nso-correct before-floor) admitted-rows))
      (let updated-inquiries (add (nso-inquiries before-floor) (mul admitted-rows 7)))
      (let updated-floor (list (nso-rows before-floor) updated-native updated-evidence
        updated-correct (nso-wrong before-floor) updated-inquiries
        (add (nso-expected before-floor) (mul admitted-rows 7))
        (nso-frames before-floor)))
      (let updated-next (nso-next-two updated-floor))
      (let graph (if (eq (nth admission 0) 2) (list candidate) (list)))
      (let frames (len (framebuffer-events)))
      ; [nothing,0,1,node,before floor,support/validation/transfer,
      ;  blueprint,recipe,names,admission,tamper status/action,lapse,graph count,
      ;  transfer correct,updated floor,next two,frames,success]
      (list (nothing) 0 1 1001099012 before-floor
        (len support) (len validation) (len transfer)
        (nth candidate 1) (nth candidate 2) (len (nth candidate 3))
        admission (nth tampered 0) (nth tampered 3) lapsed-status
        (len graph) transfer-correct
        updated-floor updated-next frames
        (if (and (eq (len support) 3)
          (and (eq (nth admission 0) 2)
          (and (eq (nth admission 1) 2)
          (and (eq (nth admission 2) 7)
          (and (eq (nth admission 3) (nno-admit-action))
          (and (eq (nth tampered 0) 1)
          (and (eq (nth tampered 3) (nno-defer-action))
          (and (eq lapsed-status 0)
          (and (eq transfer-correct (len transfer))
          (and (eq updated-native 19)
               (eq updated-evidence 3)))))))))) 1 0))))
  0)
