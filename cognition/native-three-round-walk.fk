; native-three-round-walk.fk — three sequential proposal/adjudication rounds.
; Source vector = [native recipe routes, local evidence routes, remote routes].
import "native-node-ontogenesis.fk"

(do
  (defn ntr-source-vector (native local) (list native local 0))
  (defn ntr-vector-is? (v native local remote)
    (if (and (eq (nth v 0) native)
      (and (eq (nth v 1) local) (eq (nth v 2) remote))) 1 0))

  (defn ntr-residual (rows)
    (if (eq (len rows) 0) (list)
      (if (eq (nno-independent-consensus? (head rows)) 1)
        (ntr-residual (tail rows))
        (cons (head rows) (ntr-residual (tail rows))))))

  ; Proposal 2: all three predictors disagree; rehearsal is offered as route.
  (defn ntr-three-way? (e)
    (if (and (not (eq (nno-e-base e) (nno-e-rehearsal e)))
      (and (not (eq (nno-e-base e) (nno-e-lexical e)))
           (not (eq (nno-e-rehearsal e) (nno-e-lexical e))))) 1 0))
  (defn ntr-three-way-support (rows)
    (if (eq (len rows) 0) (list)
      (if (eq (ntr-three-way? (head rows)) 1)
        (cons (head rows) (ntr-three-way-support (tail rows)))
        (ntr-three-way-support (tail rows)))))

  ; Proposal 3: base and rehearsal agree against lexical; agreement is offered.
  (defn ntr-agreement? (e)
    (if (and (eq (nno-e-base e) (nno-e-rehearsal e))
             (not (eq (nno-e-base e) (nno-e-lexical e)))) 1 0))
  (defn ntr-agreement-support (rows)
    (if (eq (len rows) 0) (list)
      (if (eq (ntr-agreement? (head rows)) 1)
        (cons (head rows) (ntr-agreement-support (tail rows)))
        (ntr-agreement-support (tail rows)))))
  (defn ntr-agreement-correct (rows)
    (if (eq (len rows) 0) 0
      (add (if (eq (nno-e-base (head rows)) (nno-e-truth (head rows))) 1 0)
           (ntr-agreement-correct (tail rows)))))

  (defn ntr-frame (exchange proposal support action before after result)
    (do (let out (bfc-envelope 0 exchange 0
          (list proposal support before after result) (nid-alternative proposal 0)))
      (let oe (bfc-record-out out exchange))
      (let ie (bfc-record-in (bfc-control out action) (add exchange 100)))
      (list proposal support action before after result)))

  (defn ntr-witness ()
    (do
      (let live (ncc-triangulated-witness))
      (let floor0 (nso-floor live))
      (let rows (nth live 15))
      (let learned (nno-support rows))
      (let residual (ntr-residual rows))
      (let native1 (add (nso-native floor0) (len learned)))
      (let local1 (sub (nso-evidence floor0) (len learned)))
      (let vector0 (ntr-source-vector (nso-native floor0) (nso-evidence floor0)))
      (let vector1 (ntr-source-vector native1 local1))

      (framebuffer-clear)
      (let round1 (ntr-frame 9301 (nno-node) (len learned)
        (nno-admit-action) vector0 vector1 2))

      ; One observation and no held-out transfer: retain as lesson/defer.
      (let three-way (ntr-three-way-support residual))
      (let round2-result (if (gt (len three-way) 1) 2 1))
      (let round2-action (if (eq round2-result 2)
        (nno-admit-action) (nno-defer-action)))
      (let vector2 vector1)
      (let round2 (ntr-frame 9302 2001099302 (len three-way)
        round2-action vector1 vector2 round2-result))

      ; Two examples invite validation/transfer. The held-out example
      ; contradicts the offered recipe, so it lapses/rejects without promotion.
      (let agreement (ntr-agreement-support residual))
      (let agreement-correct (ntr-agreement-correct agreement))
      (let round3-result (if (eq agreement-correct (len agreement)) 2 0))
      (let round3-action (if (eq round3-result 2)
        (nno-admit-action) (nno-reject-action)))
      (let vector3 vector2)
      (let round3 (ntr-frame 9303 2001099303 (len agreement)
        round3-action vector2 vector3 round3-result))
      (let frames (len (framebuffer-events)))

      ; [nothing,0,1,node,round1,round2,round3,correct/support in round3,
      ;  frames,final source vector,success]
      (list (nothing) 0 1 1001099300 round1 round2 round3
        agreement-correct (len agreement) frames vector3
        (if (and (eq (ntr-vector-is? vector0 16 6 0) 1)
          (and (eq (ntr-vector-is? vector1 19 3 0) 1)
          (and (eq round2-result 1)
          (and (eq round2-action (nno-defer-action))
          (and (eq agreement-correct 1)
          (and (eq (len agreement) 2)
          (and (eq round3-result 0)
          (and (eq round3-action (nno-reject-action))
               (eq frames 6))))))))) 1 0))))
  0)
