; concept-human-corpus-125165-union.fk -- exact old/new sentence-id union.
;
; The previous 1,300-row concept-stratified Tatoeba snapshot and the new
; source-order projection are views over the same pinned archives.  Adding their
; row counts would double-count shared source sentences.  This cell performs a
; Form-native binary search by globally unique Tatoeba sentence id and exposes
; the real union: 718 overlaps, 125,165 distinct attributed source rows.
; witnessed: 2026-07-20 -> 125165 distinct ids; 123865 net-new over old 1300
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk cognition/concept-human-corpus-13-metadata.fk cognition/concept-human-corpus-13-offsets.fk cognition/concept-human-corpus-130000.fk

(do
  ; Immutable aggregate from the live exact-id union below.  Production
  ; ledgers consume this compact reading; the corpus gate recomputes the union
  ; and proves these three values so every ledger call need not reopen tens of
  ; thousands of random-access windows.
  (defn chc125-distinct-source-rows () 125165)
  (defn chc125-overlap-rows () 718)
  (defn chc125-net-new-rows () 123865)
  (defn chc125-old-offset-tail (offsets index)
    (if (eq index 0) offsets
      (chc125-old-offset-tail (tail offsets) (sub index 1))))
  (defn chc125-old-row-line (data offsets index)
    (do
      (let at (chc125-old-offset-tail offsets index))
      (substring data (head at) (sub (head (tail at)) 1))))
  (defn chc125-find-id-go (spec wanted low high)
    (if (gt low high) 0
      (do
        (let mid (div (add low high) 2))
        (let observed (str_to_int (chc130-field (chc130-row-line spec mid) 2)))
        (if (eq observed wanted) 1
          (if (lt observed wanted)
            (chc125-find-id-go spec wanted (add mid 1) high)
            (chc125-find-id-go spec wanted low (sub mid 1)))))))
  (defn chc125-has-id? (locale sentence-id)
    (do
      (let spec (chc130-spec-at locale))
      (if (eq (len spec) 0) 0
        (chc125-find-id-go spec sentence-id 0
          (sub (chc130-spec-rows spec) 1)))))
  (defn chc125-overlap-locale-go (data offsets locale index overlap old-count)
    (if (ge index (hcnl13-row-count)) (list locale old-count overlap)
      (do
        (let row (chc125-old-row-line data offsets index))
        (if (str_eq (chc130-field row 0) locale)
          (chc125-overlap-locale-go data offsets locale (add index 1)
            (add overlap (chc125-has-id? locale
              (str_to_int (chc130-field row 2)))) (add old-count 1))
          (chc125-overlap-locale-go data offsets locale (add index 1)
            overlap old-count)))))
  (defn chc125-overlap-locale-in (data offsets locale)
    (chc125-overlap-locale-go data offsets locale 0 0 0))
  (defn chc125-overlap-stats ()
    (do
      (let data (read_file (hcnl13-data-path)))
      (let offsets (hcnl13-offsets))
      (list
        (chc125-overlap-locale-in data offsets "en")
        (chc125-overlap-locale-in data offsets "id")
        (chc125-overlap-locale-in data offsets "es")
        (chc125-overlap-locale-in data offsets "fr")
        (chc125-overlap-locale-in data offsets "pt-br")
        (chc125-overlap-locale-in data offsets "sw")
        (chc125-overlap-locale-in data offsets "de")
        (chc125-overlap-locale-in data offsets "ru")
        (chc125-overlap-locale-in data offsets "zh")
        (chc125-overlap-locale-in data offsets "ja")
        (chc125-overlap-locale-in data offsets "ar")
        (chc125-overlap-locale-in data offsets "hi")
        (chc125-overlap-locale-in data offsets "tr"))))
  (defn chc125-sum-field (rows field total)
    (if (eq (len rows) 0) total
      (chc125-sum-field (tail rows) field
        (add total (nth (head rows) field)))))
  (defn chc125-union-audit ()
    (do
      (let stats (chc125-overlap-stats))
      (let old (chc125-sum-field stats 1 0))
      (let overlap (chc125-sum-field stats 2 0))
      (list "attributed-human-sentence-id-union"
        "old-rows" old "new-projection-rows" (chc130-observed-rows)
        "overlap" overlap
        "distinct-source-rows"
          (sub (add old (chc130-observed-rows)) overlap)
        "net-new-over-old" (sub (chc130-observed-rows) overlap)
        "target" (chc130-target-rows) "shortfall" (chc130-shortfall)
        "per-locale" stats
        "novel-generation" 0)))
)
