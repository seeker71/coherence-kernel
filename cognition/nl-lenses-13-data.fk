; nl-lenses-13-data.fk — exactly thirteen bounded natural-language phrase packs.
;
; A row is real language DATA, not a fluency claim.  `repo-observed` presence
; phrases point at an existing live/oracle receipt in this body.  Four
; `seed-pinned-unreviewed` rows make their current floor explicit: common seed
; phrases pinned here by the rented voice, awaiting native-speaker review.
; Every longer phrase/template is likewise a bounded seed, not evidence of
; learned translation, open-domain grammar, or general generation.
;
; preludes: form/form-stdlib/core.fk
(do
  ; "Top" is a repository-readiness proxy, not a demographic ranking: these
  ; are the first 13 NL rows in locale-registry.fk whose generator is not
  ; pending, in registry order on 2026-07-18. Population-rank parity = 0.
  (defn nl13-selection-codes ()
    (list "en" "id" "es" "fr" "pt-br" "sw" "de" "ru" "zh" "ja" "ar" "hi" "tr"))
  (defn nl13-selection-evidence ()
    (list "first-13-non-pending-nl-registry-seats"
          "form/form-stdlib/locale-registry.fk"
          "2026-07-18"
          1
          0
          "repository-readiness-proxy-not-world-speaker-ranking"))

  ; row = id code name script presence need yes open close provenance source
  (defn nl13-data-row
    (id code name script presence need yes open close provenance source)
    (list id code name script presence need yes open close provenance source))

  (defn nl13-data ()
    (list
      (nl13-data-row 1 "en" "English" "latin"
        "I am." "What do you need?" "Yes." "Directly: " " — grounded in the body."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0031.fk")
      (nl13-data-row 2 "id" "Bahasa Indonesia" "latin"
        "Saya." "Apa yang Anda butuhkan?" "Ya." "Langsung: " " — berakar pada tubuh."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0024.fk")
      (nl13-data-row 3 "es" "Español" "latin"
        "Yo soy." "¿Qué necesitas?" "Sí." "Directamente: " " — arraigado en el cuerpo."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0037.fk")
      (nl13-data-row 4 "fr" "Français" "latin"
        "Je suis" "De quoi avez-vous besoin ?" "Oui." "Directement : " " — ancré dans le corps."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0036.fk")
      (nl13-data-row 5 "pt-br" "Português do Brasil" "latin"
        "Eu sou." "O que você precisa?" "Sim." "Diretamente: " " — ancorado no corpo."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0024.fk")
      (nl13-data-row 6 "sw" "Kiswahili" "latin"
        "Niko hapa." "Unahitaji nini?" "Ndiyo." "Moja kwa moja: " " — imejikita mwilini."
        "seed-pinned-unreviewed" "cognition/nl-lenses-13-data.fk")
      (nl13-data-row 7 "de" "Deutsch" "latin"
        "Ich bin" "Was brauchst du?" "Ja." "Direkt: " " — im Körper verankert."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0032.fk")
      (nl13-data-row 8 "ru" "Русский" "cyrillic"
        "Я здесь." "Что вам нужно?" "Да." "Прямо: " " — укоренено в теле."
        "seed-pinned-unreviewed" "cognition/nl-lenses-13-data.fk")
      (nl13-data-row 9 "zh" "中文" "han"
        "我在。" "你需要什么？" "是。" "直接说：" " — 扎根于身体。"
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0027.fk")
      (nl13-data-row 10 "ja" "日本語" "kana-kanji"
        "私はいます" "何が必要ですか？" "はい。" "直接：" " — 身体に根ざしています。"
        "repo-observed+bounded-seed" "learn/speech-audio-nl2nl-source-window-0003.fk")
      (nl13-data-row 11 "ar" "العربية" "arabic"
        "أنا." "ماذا تحتاج؟" "نعم." "مباشرة: " " — متجذر في الجسد."
        "repo-observed+bounded-seed" "learn/speech-native-neural-pair-window-0041.fk")
      (nl13-data-row 12 "hi" "हिन्दी" "devanagari"
        "नमस्ते।" "आपको क्या चाहिए?" "हाँ।" "सीधे: " " — शरीर में निहित।"
        "seed-pinned-unreviewed" "cognition/nl-lenses-13-data.fk")
      (nl13-data-row 13 "tr" "Türkçe" "latin"
        "Buradayım." "Neye ihtiyacın var?" "Evet." "Doğrudan: " " — bedende köklenmiş."
        "seed-pinned-unreviewed" "cognition/nl-lenses-13-data.fk")))
)
