; concept-human-aligned-sw.fk -- minimal exact en->sw direct-link lane.
;
; The English band bounds are the witnessed first/last sentence IDs in the
; hash-pinned 2026-07-18 en.tsv projection.  The Swahili projection exhausted
; its detailed export, so every Swahili endpoint in the same-snapshot pair
; export is retained.  Pair availability is not translation success.
; witnessed: 2026-07-20 -> 95 direct-link candidates in the bounded English
; source band after all 4,403 official en-swh link rows were scanned; the
; provenance join retained 94 and refused one absent committed endpoint
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk observe/framebuffer-runtime-observation.fk

(do
  (defn chasw-pair-path () "/tmp/tatoeba-align/eng-swh_links.tsv")
  (defn chasw-source-min () 1276)
  (defn chasw-source-max () 25194)
  (defn chasw-line-end (data data-len i)
    (if (ge i data-len) i
      (if (eq (str_byte_at data i) 10) i
        (chasw-line-end data data-len (add i 1)))))
  (defn chasw-source-id (line)
    (do
      (let tab (str_find line (byte_to_str 9) 0))
      (if (lt tab 0) -1 (str_to_int (substring line 0 tab)))))
  (defn chasw-count-go (data data-len pos limit count scanned)
    (if (or (ge pos data-len) (and (ge limit 0) (ge scanned limit)))
      (list count scanned pos)
      (do
        (let end (chasw-line-end data data-len pos))
        (let source-id (chasw-source-id (substring data pos end)))
        (chasw-count-go data data-len (add end 1) limit
          (add count (if (and (ge source-id (chasw-source-min))
                              (le source-id (chasw-source-max))) 1 0))
          (add scanned 1)))))
  (defn chasw-profile-10-observed ()
    (do
      (let path (chasw-pair-path))
      (let window (fbro-open-stream "human-aligned-sw-minimal-profile-10"
        "Sema" "profiles-direct-link-parser"
        "isolate-prelude-vs-parser-cost" "first-10-real-eng-swh-links"
        (fs-stat-size path) "cognition/concept-human-aligned-sw.fk" 37 7))
      (let before (fbro-snapshot))
      (let data (read_file path))
      (let result (chasw-count-go data (str_len data) 0 10 0 0))
      (let after (fbro-snapshot))
      (let stage (fbro-stage-observed-stream
        "human-aligned-sw-minimal-profile-10" "parse-first-10" "trace-begin"
        "Sema" "profiles-direct-link-parser"
        "isolate-prelude-vs-parser-cost" "first-10-real-eng-swh-links"
        before after "rows" (nth result 1) "bounded-profile-complete"
        "cognition/concept-human-aligned-sw.fk" 48 7))
      (let report (fbro-close-stream window "bounded-profile-complete"
        (nth result 1) "cognition/concept-human-aligned-sw.fk" 51 7))
      (list result report)))
  (defn chasw-count-observed ()
    (do
      (let path (chasw-pair-path))
      (let window (fbro-open-stream "human-aligned-sw-direct-links"
        "Sema" "intersects-direct-translation-links"
        "retain-source-target-relations-not-monolingual-copresence"
        "tatoeba-eng-swh-links-2026-07-18" (fs-stat-size path)
        "cognition/concept-human-aligned-sw.fk" 58 7))
      (let before (fbro-snapshot))
      (let data (read_file path))
      (let result (chasw-count-go data (str_len data) 0 -1 0 0))
      (let after (fbro-snapshot))
      (let outcome (if (gt (nth result 0) 0)
        "nonzero-direct-link-intersection" "zero-direct-link-intersection"))
      (let stage (fbro-stage-observed-stream "human-aligned-sw-direct-links"
        "scan-all-4403-links" "trace-begin" "Sema"
        "intersects-direct-translation-links"
        "retain-source-target-relations-not-monolingual-copresence"
        "tatoeba-eng-swh-links-2026-07-18" before after "direct-pairs"
        (nth result 0) outcome "cognition/concept-human-aligned-sw.fk" 72 7))
      (let report (fbro-close-stream window outcome (nth result 0)
        "cognition/concept-human-aligned-sw.fk" 74 7))
      (list result report)))
)
