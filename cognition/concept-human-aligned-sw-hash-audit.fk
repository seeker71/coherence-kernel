; concept-human-aligned-sw-hash-audit.fk -- seal and audit 94 direct pairs.
;
; This second stage replaces the join-stage marker with the Form-computed
; SHA-256 of the exact `english-id<TAB>swahili-id` upstream link row.  It also
; rechecks that every relation occurs in the pinned pair export and recounts
; development, heldout, and real source-copy output comparisons.
; witnessed: 2026-07-20 -> 94/94 links re-found and hashed, 79 development,
; 15 heldout, source-copy exact 0, failures 0; 6,991 ms / 417,132,867
; measured stage dispatches / 2 I/O
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/sha256.fk observe/framebuffer-runtime-observation.fk cognition/concept-human-aligned-sw.fk cognition/concept-human-aligned-sw-fixture.fk

(do
  (defn chaswa-joined-path ()
    "cognition/fixtures/human-aligned-tatoeba-13/en-sw-direct-94-joined.tsv")
  (defn chaswa-final-path ()
    "cognition/fixtures/human-aligned-tatoeba-13/en-sw-direct-94.tsv")
  (defn chaswa-bytes-go (s i out)
    (if (lt i 0) out
      (chaswa-bytes-go s (sub i 1) (cons (str_byte_at s i) out))))
  (defn chaswa-bytes (s) (chaswa-bytes-go s (sub (str_len s) 1) (empty)))
  (defn chaswa-hex-char (n) (substring "0123456789abcdef" n (add n 1)))
  (defn chaswa-hex-go (bytes out)
    (if (eq (len bytes) 0) out
      (chaswa-hex-go (tail bytes)
        (str_concat out (str_concat (chaswa-hex-char (div (head bytes) 16))
          (chaswa-hex-char (mod (head bytes) 16)))))))
  (defn chaswa-sha256 (s) (chaswa-hex-go (sha256 (chaswa-bytes s)) ""))
  (defn chaswa-replace-pending (line digest)
    (do
      (let marker "pending-form-sha256-stage")
      (let at (str_find line marker 0))
      (if (lt at 0) ""
        (str_concat (substring line 0 at)
          (str_concat digest (substring line (add at (str_len marker))
            (str_len line)))))))
  (defn chaswa-link-exists? (pairs link-line)
    (do
      (let bounded (str_concat (byte_to_str 10)
        (str_concat link-line (byte_to_str 10))))
      (if (ge (str_find pairs bounded 0) 0) 1
        (if (and (eq (str_find pairs link-line 0) 0)
                 (eq (str_byte_at pairs (str_len link-line)) 10)) 1 0))))
  ; state = reversed rows, rows, dev, heldout, links, hashes, exact, failures.
  (defn chaswa-seal-go (joined joined-len pos pairs rows count dev heldout
                        links hashes exact failures)
    (if (ge pos joined-len)
      (list rows count dev heldout links hashes exact failures)
      (do
        (let end (chasw-line-end joined joined-len pos))
        (let line (substring joined pos end))
        (let link-line (str_concat (chaswf-field line 3)
          (str_concat (byte_to_str 9) (chaswf-field line 12))))
        (let digest (chaswa-sha256 link-line))
        (let sealed (chaswa-replace-pending line digest))
        (let split (chaswf-field line 0))
        (let link-ok (chaswa-link-exists? pairs link-line))
        (let hash-ok (if (eq (str_len digest) 64) 1 0))
        (let exact-row (str_to_int (chaswf-field line 26)))
        (chaswa-seal-go joined joined-len (add end 1) pairs
          (cons (str_concat sealed (byte_to_str 10)) rows) (add count 1)
          (add dev (if (str_eq split "development") 1 0))
          (add heldout (if (str_eq split "heldout") 1 0))
          (add links link-ok) (add hashes hash-ok) (add exact exact-row)
          (add failures (if (and (not (str_eq sealed ""))
                                 (and (eq link-ok 1) (eq hash-ok 1))) 0 1))))))
  (defn chaswa-seal-observed ()
    (do
      (let joined (read_file (chaswa-joined-path)))
      (let joined-len (str_len joined))
      (let header-end (chasw-line-end joined joined-len 0))
      (let header (substring joined 0 (add header-end 1)))
      (let window (fbro-open-stream "human-aligned-sw-hash-audit-94"
        "Sema" "seals-and-audits-direct-link-provenance"
        "make-every-retained-relation-recheckable"
        "joined-pairs-plus-pinned-pair-export" (add joined-len 72120)
        "cognition/concept-human-aligned-sw-hash-audit.fk" 76 7))
      (let before (fbro-snapshot))
      (let pairs (read_file (chasw-pair-path)))
      (let sealed (chaswa-seal-go joined joined-len (add header-end 1)
        pairs (empty) 0 0 0 0 0 0 0))
      (let final-text (str_concat header (chaswf-concat (reverse (nth sealed 0)))))
      (let wrote (write_file (chaswa-final-path) final-text))
      (let after (fbro-snapshot))
      (let complete (and (eq (nth sealed 1) 94)
        (and (eq (nth sealed 2) 79)
        (and (eq (nth sealed 3) 15)
        (and (eq (nth sealed 4) 94)
        (and (eq (nth sealed 5) 94)
        (and (eq (nth sealed 6) 0) (eq (nth sealed 7) 0))))))))
      (let outcome (if complete "complete-94-hashed-audited-pairs"
        "incomplete-hash-audit"))
      (let stage (fbro-stage-observed-stream "human-aligned-sw-hash-audit-94"
        "hash-and-recheck-94-link-rows" "trace-begin" "Sema"
        "seals-and-audits-direct-link-provenance"
        "make-every-retained-relation-recheckable"
        "joined-pairs-plus-pinned-pair-export" before after "pairs"
        (nth sealed 1) outcome
        "cognition/concept-human-aligned-sw-hash-audit.fk" 102 7))
      (let report (fbro-close-stream window outcome (nth sealed 1)
        "cognition/concept-human-aligned-sw-hash-audit.fk" 104 7))
      (list "en-sw-direct-94" (tail sealed) "artifact-bytes" wrote
        "artifact-digest" "measure-after-form-write" report
        "translation-success" 0 "success-floor" "source-copy-heldout-exact")))
)
