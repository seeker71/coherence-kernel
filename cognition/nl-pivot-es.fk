; nl-pivot-es.fk — the Spanish tongue seated on the ONE language-neutral pivot.
;
; The fourth tongue, added exactly as nl-translate.fk teaches and
; nl-pivot-de.fk works through: one grammar, one column, the pivot and the
; engine untouched. "la fuente es nativa", "the source is native",
; "sumber adalah asli", and "die quelle ist nativ" intern to the SAME pivot
; node — witnessed by node identity across all four, never by claim.
;
; Grammatical dress is a COLUMN fact, not pivot content: encoding accepts
; el/la/los/las through an alt pattern and drops the article; decoding
; restores it from the lexicon row. Adjective gender agreement is seeded per
; symbol (nativa agrees with the feminine fuente) — agreement as a rule of
; its own is a named boundary, not smuggled fluency.
;
; Honest boundaries: seed rows are ASCII-safe by choice (nucleo without its
; accent — the byte-classed alpha run is the same documented boundary as
; text-tokenize.fk); rows are agent-authored seed vocabulary awaiting
; native-speaker review; this is the bounded property-sentence shape only.
;
; witnessed: 2026-07-19 within cognition/tests/nl-neutral-trace-band.fk (live fkwu)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/record-src-shim.fk
; preludes: form/form-stdlib/form-ontology-loader.fk form/form-stdlib/line-grammar.fk form/form-stdlib/bmf-core.fk form/form-stdlib/bmf-grammar.fk form/form-stdlib/string-case.fk form/form-stdlib/nl-lexicon-data.fk form/form-stdlib/nl-translate.fk cognition/nl-pivot-de.fk
(do
    ;; --- the Spanish property grammar over the one engine ---
    ;; prop := ("el"|"la"|"los"|"las") SUBJECT "es" PREDICATE
    (defn nl-es ()
        (grammar "s" (list
            (rule3 "s" (p-cap "v" (p-ref "prop")) (t-splice "v"))
            (rule3 "prop"
                (list "seq"
                    (list "alt" (p-lit "el") (p-lit "la") (p-lit "los") (p-lit "las"))
                    (p-cap "s" (p-run "alpha"))
                    (p-lit "es")
                    (p-cap "a" (p-run "alpha")))
                (t-emit "property" (list (t-splice "s") (t-splice "a")))))))

    ;; --- the Spanish column: rows of (symbol es-fem article es-masc) ---
    ;; Nouns carry their article; the adjective row carries BOTH gender forms
    ;; and the decoder picks by the subject's own article — agreement lives
    ;; in the column, never in the pivot (witnessed: "la fuente es nativa"
    ;; but "el nucleo es nativo").
    (defn npe-es-lexicon ()
        (list
            ;;     symbol  es/fem     article  es/masc
            (list "n0"   "fuente"   "la"     "fuente")
            (list "n1"   "nativa"   ""       "nativo")
            (list "n2"   "nucleo"   "el"     "nucleo")
            (list "n3"   "cuerpo"   "el"     "cuerpo")))
    (defn npe-map (i j w) (npd-pick (npd-find (npe-es-lexicon) i w) j w))
    ; both gender surfaces resolve to the same neutral symbol
    (defn npe-es->c (w)
        (do (let fem (npe-map 1 0 w))
            (if (str_eq fem w) (npe-map 3 0 w) (str_concat fem ""))))
    (defn npe-c->es (sy) (npe-map 0 1 sy))
    (defn npe-c->es-masc (sy) (npe-map 0 3 sy))
    (defn npe-c->es-art (sy) (npd-pick (npd-find (npe-es-lexicon) 0 sy) 2 ""))
    (defn npe-masc-art? (art)
        (if (or (str_eq art "el") (str_eq art "los")) 1 0))

    ;; --- normalize raw es parse -> the SAME pivot ---
    (defn norm-es (n)
        (intern_node (bp "property")
            (list (nlt-s (npe-es->c (nlt-kidv n 0)))
                  (nlt-s (npe-es->c (nlt-kidv n 1))))))
    ;; --- decode pivot -> es surface, article restored, adjective agreeing ---
    (defn dec-es (p)
        (do (let sy (nlt-kidv p 0))
            (let art (npe-c->es-art sy))
            (let subject (npe-c->es sy))
            (let predicate (if (eq (npe-masc-art? art) 1)
                (npe-c->es-masc (nlt-kidv p 1))
                (npe-c->es (nlt-kidv p 1))))
            (if (str_eq art "")
                (nlt-sp subject (nlt-sp "es" predicate))
                (nlt-sp art (nlt-sp subject (nlt-sp "es" predicate))))))

    ;; --- the translators: every pairing crosses the ONE pivot ---
    (defn npe-parse-es (x) (norm-es (g-parse (nl-es) (str-normalize x))))
    (defn tr-es-en (x) (dec-en (npe-parse-es x)))
    (defn tr-es-id (x) (dec-id (npe-parse-es x)))
    (defn tr-es-de (x) (dec-de (npe-parse-es x)))
    (defn tr-en-es (x) (dec-es (norm-en (g-parse (nl-en) (str-normalize x)))))
    (defn tr-id-es (x) (dec-es (norm-id (g-parse (nl-id) (str-normalize x)))))
    (defn tr-de-es (x) (dec-es (npd-parse-de x)))

    ;; --- the sovereignty witness: FOUR tongues, one cell ---
    (defn npe-pivot-agree4? (es-src de-src en-src id-src)
        (do (let pe (npe-parse-es es-src))
            (let pd (npd-parse-de de-src))
            (let pn (norm-en (g-parse (nl-en) (str-normalize en-src))))
            (let pi (norm-id (g-parse (nl-id) (str-normalize id-src))))
            (if (and (node_eq pe pd) (and (node_eq pe pn) (node_eq pe pi))) 1 0)))
    0)
