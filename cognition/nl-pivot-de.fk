; nl-pivot-de.fk — the German tongue seated on the ONE language-neutral pivot.
;
; nl-translate.fk teaches: adding a tongue is adding a (grammar,
; lexicon-direction, decoder) — the pivot and the engine never change. This
; cell does exactly that for German, without touching the four-way-proven
; stdlib cell: the SAME neutral symbols (n0, n1, ...), the SAME property
; blueprint (@1.2.99.33), the SAME bmf-grammar engine. "die quelle ist nativ",
; "the source is native", and "sumber adalah asli" intern to the SAME pivot
; node — witnessed by node identity, not by claim.
;
; Grammatical gender is a COLUMN fact, not pivot content: encoding accepts
; der/die/das through an alt pattern and drops the article; decoding restores
; the article from the lexicon row. No language is privileged; the dress a
; tongue wears is remembered by that tongue's own column.
;
; Honest boundaries, named: the seed rows below are ASCII-safe by choice
; because p-run "alpha" is byte-classed (umlaut words like "körper" would
; break the run — the same documented boundary as text-tokenize.fk); the
; rows are agent-authored seed vocabulary awaiting native-speaker review;
; and this is the bounded property-sentence shape, not general German.
;
; witnessed: 2026-07-18 within cognition/tests/nl-neutral-trace-band.fk (live fkwu)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/record-src-shim.fk
; preludes: form/form-stdlib/form-ontology-loader.fk form/form-stdlib/line-grammar.fk form/form-stdlib/bmf-core.fk form/form-stdlib/bmf-grammar.fk form/form-stdlib/string-case.fk form/form-stdlib/nl-lexicon-data.fk form/form-stdlib/nl-translate.fk
(do
    ;; --- the German property grammar over the one engine ---
    ;; prop := ("der"|"die"|"das") SUBJECT "ist" PREDICATE
    (defn nl-de ()
        (grammar "s" (list
            (rule3 "s" (p-cap "v" (p-ref "prop")) (t-splice "v"))
            (rule3 "prop"
                (list "seq"
                    (list "alt" (p-lit "der") (p-lit "die") (p-lit "das"))
                    (p-cap "s" (p-run "alpha"))
                    (p-lit "ist")
                    (p-cap "a" (p-run "alpha")))
                (t-emit "property" (list (t-splice "s") (t-splice "a")))))))

    ;; --- the German column: rows of (neutral-symbol de-surface de-article) ---
    ;; The article is the tongue's own dress ("" for adjectives); the neutral
    ;; symbol is the body's, shared with every other column.
    (defn npd-de-lexicon ()
        (list
            ;;     symbol  de         article
            (list "n0"   "quelle"   "die")
            (list "n1"   "nativ"    "")
            (list "n2"   "kern"     "der")
            (list "n3"   "leib"     "der")))
    (defn npd-find (rows i w)
        (if (nil? rows) (empty)
            (if (str_eq (nth (head rows) i) w) (head rows)
                (npd-find (tail rows) i w))))
    (defn npd-pick (r j w) (if (nil? r) w (nth r j)))
    (defn npd-map (i j w) (npd-pick (npd-find (npd-de-lexicon) i w) j w))
    (defn npd-de->c (w)  (npd-map 1 0 w))   ; de surface -> neutral symbol
    (defn npd-c->de (sy) (npd-map 0 1 sy))  ; neutral symbol -> de surface
    (defn npd-c->de-art (sy) (npd-pick (npd-find (npd-de-lexicon) 0 sy) 2 ""))

    ;; --- normalize raw de parse -> the SAME pivot ---
    (defn norm-de (n)
        (intern_node (bp "property")
            (list (nlt-s (npd-de->c (nlt-kidv n 0)))
                  (nlt-s (npd-de->c (nlt-kidv n 1))))))
    ;; --- decode pivot -> de surface, article restored from the column ---
    (defn dec-de (p)
        (do (let sy (nlt-kidv p 0))
            (let art (npd-c->de-art sy))
            (let subject (npd-c->de sy))
            (let predicate (npd-c->de (nlt-kidv p 1)))
            (if (str_eq art "")
                (nlt-sp subject (nlt-sp "ist" predicate))
                (nlt-sp art (nlt-sp subject (nlt-sp "ist" predicate))))))

    ;; --- the translators: every pairing crosses the ONE pivot ---
    (defn npd-parse-de (x) (norm-de (g-parse (nl-de) (str-normalize x))))
    (defn tr-de-en (x) (dec-en (npd-parse-de x)))
    (defn tr-de-id (x) (dec-id (npd-parse-de x)))
    (defn tr-en-de (x) (dec-de (norm-en (g-parse (nl-en) (str-normalize x)))))
    (defn tr-id-de (x) (dec-de (norm-id (g-parse (nl-id) (str-normalize x)))))

    ;; --- the sovereignty witness: three tongues, one cell ---
    ;; The same meaning from three surfaces interns to the same node. This is
    ;; checked by node identity (content addressing), never by string claim.
    (defn npd-pivot-agree? (de-src en-src id-src)
        (do (let pd (npd-parse-de de-src))
            (let pe (norm-en (g-parse (nl-en) (str-normalize en-src))))
            (let pi (norm-id (g-parse (nl-id) (str-normalize id-src))))
            (if (and (node_eq pd pe) (node_eq pd pi)) 1 0)))
    0)
