; concept-crystallization-contract.fk — an offered gas/water/ice readiness profile.
; Gas, water, and ice are reversible states available to a node, not node kinds.
; A concept may become reusable ground while these eight exposed facets replay;
; another profile may offer a different shape through the same core axioms.
import "native-node-ontogenesis.fk"
import "../form/form-stdlib/form-freq-check.fk"

(do
  (defn ccc-epoch () 20260722)
  (defn ccc-gas () 0)
  (defn ccc-water () 1)
  (defn ccc-ice () 2)

  ; concept = [state, aliases, recipe, [identity,blueprint], evidence lineage,
  ;            seven lane responses, held-out transfer, freshness belief]
  (defn ccc-concept (state aliases recipe identity blueprint lineage lanes transfer freshness)
    (list state aliases recipe (list identity blueprint) lineage lanes transfer freshness))
  (defn ccc-state (c) (nth c 0))
  (defn ccc-aliases (c) (nth c 1))
  (defn ccc-recipe (c) (nth c 2))
  (defn ccc-identity-shape (c) (nth c 3))
  (defn ccc-identity (c) (nth (ccc-identity-shape c) 0))
  (defn ccc-blueprint (c) (nth (ccc-identity-shape c) 1))
  (defn ccc-lineage (c) (nth c 4))
  (defn ccc-lanes (c) (nth c 5))
  (defn ccc-transfer (c) (nth c 6))
  (defn ccc-freshness (c) (nth c 7))

  (defn ccc-state-ok? (c)
    (if (or (eq (ccc-state c) (ccc-gas))
      (or (eq (ccc-state c) (ccc-water)) (eq (ccc-state c) (ccc-ice)))) 1 0))
  (defn ccc-aliases-ok? (c)
    (if (gt (len (ccc-aliases c)) 0) (nno-names-valid? (ccc-aliases c)) 0))
  (defn ccc-recipe-ok? (c)
    (if (and (eq (len (ccc-recipe c)) 5)
             (eq (nth (ccc-recipe c) 4) (nno-recipe-identity))) 1 0))
  (defn ccc-blueprint-ok? (c)
    (if (and (eq (len (ccc-blueprint c)) 5)
      (and (eq (nth (ccc-blueprint c) 1) (nno-recipe-identity))
           (eq (nth (ccc-blueprint c) 4) 7))) 1 0))
  (defn ccc-identity-ok? (c) (if (eq (ccc-identity c) (nno-node)) 1 0))
  (defn ccc-lineage-ok? (c) (if (gt (len (ccc-lineage c)) 0) 1 0))
  (defn ccc-lanes-ok? (c)
    (if (eq (len (ccc-lanes c)) 7)
      (if (eq (lnii-lanes-ok (lnii-subject (ccc-identity c)) 0 0) 7) 1 0) 0))
  (defn ccc-transfer-ok? (c)
    (if (and (gt (nth (ccc-transfer c) 1) 0)
             (eq (nth (ccc-transfer c) 0) (nth (ccc-transfer c) 1))) 1 0))
  (defn ccc-fresh-ok? (c)
    (if (eq (bf-status (ccc-freshness c) (ccc-epoch)) 2) 1 0))

  (defn ccc-facets (c)
    (list (ccc-state-ok? c) (ccc-aliases-ok? c) (ccc-recipe-ok? c)
      (if (and (eq (ccc-blueprint-ok? c) 1) (eq (ccc-identity-ok? c) 1)) 1 0)
      (ccc-lineage-ok? c) (ccc-lanes-ok? c) (ccc-transfer-ok? c)
      (ccc-fresh-ok? c)))
  (defn ccc-ready-profile? (xs)
    (if (eq (len xs) 0) 1
      (if (eq (head xs) 1) (ccc-ready-profile? (tail xs)) 0)))
  ; For this profile: 2 currently ready; 1 candidate retained for more observation.
  (defn ccc-status (c) (if (eq (ccc-ready-profile? (ccc-facets c)) 1) 2 1))

  ; No calibrated semantic signature was produced for the criterion sentence.
  ; The native frequency carrier therefore abstains rather than certifying it.
  (defn ccc-criterion-frequency () (fc-unmeasured-reading))
  ; Current compatibility reading against the five offered axioms:
  ; states, composed cell, content identity, observed interface, offer/ack.
  (defn ccc-axiom-reading (c)
    (list 1 (if (eq (len c) 8) 1 0) (ccc-identity-ok? c)
      (ccc-lanes-ok? c) 1))

  ; State changes retain the node's content identity and carried observations.
  (defn ccc-with-state (c state)
    (ccc-concept state (ccc-aliases c) (ccc-recipe c) (ccc-identity c)
      (ccc-blueprint c) (ccc-lineage c) (ccc-lanes c) (ccc-transfer c)
      (ccc-freshness c)))

  (defn ccc-record-decision (exchange c)
    (do (let facets (ccc-facets c))
      (let status (ccc-status c))
      (let action (if (eq status 2) (nno-admit-action) (nno-defer-action)))
      (let out (bfc-envelope 0 exchange 0
        (list (ccc-identity c) facets status) (nno-alternative)))
      (let oe (bfc-record-out out exchange))
      (let ie (bfc-record-in (bfc-control out action) (add exchange 100)))
      (list facets status action)))

  (defn ccc-witness ()
    (do
      (let live (ncc-triangulated-witness))
      (let support (nno-support (nth live 15)))
      (let validation (nno-take support 2))
      (let heldout (nno-drop support 2))
      (let transfer-correct (nno-validation-count heldout 0))
      (let good (ccc-concept (ccc-water) (nno-names) (nno-recipe)
        (nno-node) (nno-blueprint (len support)) support (nno-interfaces)
        (list transfer-correct (len heldout))
        (bf-belief (nno-node) 1 (ccc-epoch))))
      (let gas (ccc-with-state good (ccc-gas)))
      (let ice (ccc-with-state good (ccc-ice)))
      (let missing-aliases (ccc-concept (ccc-state good) (list) (ccc-recipe good)
        (ccc-identity good) (ccc-blueprint good) (ccc-lineage good)
        (ccc-lanes good) (ccc-transfer good) (ccc-freshness good)))
      (let failed-transfer (ccc-concept (ccc-state good) (ccc-aliases good) (ccc-recipe good)
        (ccc-identity good) (ccc-blueprint good) (ccc-lineage good)
        (ccc-lanes good) (list 0 1) (ccc-freshness good)))
      (let stale (ccc-concept (ccc-state good) (ccc-aliases good) (ccc-recipe good)
        (ccc-identity good) (ccc-blueprint good) (ccc-lineage good)
        (ccc-lanes good) (ccc-transfer good)
        (bf-belief (nno-node) 1 20260721)))

      (framebuffer-clear)
      (let ready (ccc-record-decision 9401 good))
      (let aliases-candidate (ccc-record-decision 9402 missing-aliases))
      (let transfer-candidate (ccc-record-decision 9403 failed-transfer))
      (let stale-candidate (ccc-record-decision 9404 stale))
      (let frames (len (framebuffer-events)))
      (let frequency (ccc-criterion-frequency))
      ; [nothing,0,1,node, ready,missing-aliases,failed-transfer,stale,
      ;  gas/water/ice identities,axiom reading,frequency reading,
      ;  lineage/validation/heldout,frames,success]
      (list (nothing) 0 1 1001099400 ready aliases-candidate
        transfer-candidate stale-candidate
        (list (ccc-identity gas) (ccc-identity good) (ccc-identity ice))
        (len support) (len validation) (len heldout)
        (ccc-axiom-reading good) frequency frames
        (if (and (eq (nth ready 1) 2)
          (and (eq (nth ready 2) (nno-admit-action))
          (and (eq (nth aliases-candidate 1) 1)
          (and (eq (nth transfer-candidate 1) 1)
          (and (eq (nth stale-candidate 1) 1)
          (and (eq (nth aliases-candidate 2) (nno-defer-action))
          (and (eq (nth transfer-candidate 2) (nno-defer-action))
          (and (eq (nth stale-candidate 2) (nno-defer-action))
          (and (eq (ccc-identity gas) (ccc-identity good))
          (and (eq (ccc-identity good) (ccc-identity ice))
          (and (eq (fc-reading-state frequency) (fc-state-unknown))
          (and (eq (fc-reading-valid frequency) 0)
               (eq frames 8)))))))))))) 1 0))))
  0)
