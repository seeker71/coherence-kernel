; nl-neutral-trace.fk — one command, one legible NL -> neutral -> NL query trace.
;
; The single command (from the repo root, after the one-cc bootstrap):
;
;     ./fkwu --src cognition/tests/nl-neutral-trace-live.fk
;
; By default it runs the two exemplar lanes (de "Wasser", id "air") plus the
; three-tongue neutral-pivot exemplar. To ask your own question, stage one line
; "<asserted-locale> <target-locale> <query text>" at
; .coherence-network/nl-neutral-trace-query.txt and re-run the same command
; (direct-source Form does not yet read argv, and the fkwu op table carries no
; env native — the staged file IS the Form-native input door, written and read
; by the same organs).
;
; Every stage line carries: the inquiry plane it answers (observe/inquiry-planes.fk),
; the recipe (code) with its byte size, the data cell with its byte size, the
; blueprint (type) with its arity, the paths available / tried / succeeded /
; failed / cut, the neutral symbols or anchors matched, the BMF rules tried
; with real per-rule counters, a follow-up pointer that can be pasted into the
; next query, and the north-star gap with the next step.
;
; What is REAL here, precisely:
;   - the rag index is written to the healed home
;     (.coherence-network/rag-index/index.jsonl) and read back through the
;     production ra-grounded-hit-at path — a persisted nodeid-rag-v2 index over
;     the committed row bytes, not an in-memory demo;
;   - cell identity is content-addressed: key and persisted_source_sha256 are
;     the SHA-256 of the exact committed row bytes, and answer_key binds the
;     answer cryptographically; the "@10.3.99.<row>" coordinate is this
;     organ's declared file-substrate scheme (package 10 = the
;     concept-nl-semantic-13 TSV lane, level 3 = row cell, type 99 = user
;     blueprint space, inst = row index) — a documented deterministic address,
;     reproducible from the bytes by any visitor;
;   - the choice counters are measured, never narrated;
;   - the comparison ledger at .coherence-network/nl-neutral-trace-ledger.txt
;     grows one row per run — memory that persists between visits.
;
; Cut semantics are the backtracking meaning: alternatives pruned after a
; commit (locale seats never tried once the first seat matched; grammar alt
; branches not tried after one matches). Failures are attempted-and-missed.
; Silences are the timeout analog of choice-receipt.fk.
;
; Expected loud line under --src: exactly ONE [unresolved-call] —
; form-ontology-loader.fk's walk_recipe_here, which that file keeps loud on
; purpose ("recorded, not shimmed: a numb walk would silently skip the
; generation it claims"). It is off this executed path; the nonzero process
; exit it causes is that seam speaking, not this organ failing. The other
; former loud lines (string_byte_fold, record_new) are healed here by
; preluding their real shims.
;
; witnessed: 2026-07-18 -> 16383 live fkwu (cognition/tests/nl-neutral-trace-band.fk)
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/record-src-shim.fk
; preludes: form/form-stdlib/form-ontology-loader.fk form/form-stdlib/line-grammar.fk form/form-stdlib/bmf-core.fk form/form-stdlib/bmf-grammar.fk form/form-stdlib/string-case.fk form/form-stdlib/nl-lexicon-data.fk form/form-stdlib/nl-translate.fk cognition/nl-pivot-de.fk
; preludes: form/form-stdlib/sha256.fk form/form-stdlib/hex.fk
; preludes: form/form-stdlib/text-tokenize.fk form/form-stdlib/rag-embed.fk
; preludes: form/form-stdlib/rag-retrieve.fk form/form-stdlib/rag-index-codec.fk
; preludes: form/form-stdlib/rag-ask.fk form/form-stdlib/choice-receipt.fk
; preludes: form/form-stdlib/form-fs.fk cognition/concept-nl-semantic-13-metadata.fk cognition/concept-nl-semantic-13-offsets.fk cognition/concept-nl-semantic-13.fk cognition/concept-nl-semantic-13-runtime.fk
; preludes: model/concept-10000-data.fk model/concept-10000.fk
; preludes: model/concept-semantics-10000-data.fk model/concept-semantics-10000.fk
; preludes: cognition/concept-text-senses-10000-metadata.fk cognition/concept-text-senses-10000-offsets.fk cognition/concept-text-senses-10000.fk
; preludes: cognition/nl-lenses-13-data.fk cognition/nl-lenses-13.fk
(do
  ;; ---------- small helpers ----------
  (defn nnt-cat (xs) (if (eq (len xs) 0) "" (str_concat (head xs) (nnt-cat (tail xs)))))
  (defn nnt-bytes-go (s i n) (if (ge i n) (empty) (cons (str_byte_at s i) (nnt-bytes-go s (add i 1) n))))
  (defn nnt-bytes (s) (nnt-bytes-go s 0 (str_len s)))
  (defn nnt-sha-hex (s) (hex-encode (sha256 (nnt-bytes s))))
  (defn nnt-hex (s) (hex-encode (nnt-bytes s)))
  (defn nnt-ints-json-go (xs out first)
    (if (eq (len xs) 0) out
      (nnt-ints-json-go (tail xs)
        (str_concat out (str_concat (if (eq first 1) "" ",") (int_to_str (head xs)))) 0)))
  (defn nnt-ints-json (xs) (nnt-cat (list "[" (nnt-ints-json-go xs "" 1) "]")))
  (defn nnt-size (path) (file_size path))
  (defn nnt-sized (path)
    (nnt-cat (list path " (" (int_to_str (nnt-size path)) " bytes)")))
  (defn nnt-count-lines (s i n count)
    (if (ge i n) count
      (nnt-count-lines s (add i 1) n
        (if (eq (str_byte_at s i) 10) (add count 1) count))))

  ;; ---------- staged query (single-command follow-up door) ----------
  (defn nnt-staged-query-path () ".coherence-network/nl-neutral-trace-query.txt")
  (defn nnt-oracle-answer-path () ".coherence-network/nl-neutral-trace-oracle-answer.txt")
  (defn nnt-ledger-path () ".coherence-network/nl-neutral-trace-ledger.txt")
  (defn nnt-strip-nl (s)
    (do (let at (str_find s (byte_to_str 10) 0))
        (if (lt at 0) s (substring s 0 at))))
  (defn nnt-word-end (s from)
    (do (let at (str_find s " " from))
        (if (lt at 0) (str_len s) at)))
  ; "<asserted> <target> <query...>" -> (asserted target query) or (empty)
  (defn nnt-parse-staged (line)
    (do (let e1 (nnt-word-end line 0))
        (if (ge e1 (str_len line)) (empty)
          (do (let e2 (nnt-word-end line (add e1 1)))
              (if (ge e2 (str_len line)) (empty)
                (list (substring line 0 e1)
                      (substring line (add e1 1) e2)
                      (substring line (add e2 1) (str_len line))))))))
  (defn nnt-staged-lane ()
    (if (le (file_size (nnt-staged-query-path)) 0) (empty)
      (do (let raw (read_file (nnt-staged-query-path)))
          (if (nil? raw) (empty) (nnt-parse-staged (nnt-strip-nl raw))))))

  ;; ---------- stage 1: the locale choice path (which-plane, computable) ----------
  ; walk = (status attempts fails first-code hit path-string cut)
  ; cut = seats never tried after the first seat matched (pruned alternatives).
  (defn nnt-walk-go (rt codes label attempts fails path)
    (if (eq (len codes) 0)
      (list "miss" attempts fails "" (empty) path 0)
      (do (let hit (cnl13-runtime-detect-first rt (head codes) label))
          (if (eq (len hit) 0)
            (nnt-walk-go rt (tail codes) label (add attempts 1) (add fails 1)
              (str_concat path (str_concat (head codes) ":miss ")))
            (list "hit" (add attempts 1) fails (head codes) hit
              (str_concat path (str_concat (head codes) ":HIT"))
              (sub (len codes) 1))))))
  (defn nnt-walk (rt label) (nnt-walk-go rt (cnl13-locale-codes) label 0 0 ""))

  ;; ---------- per-rule BMF counters (real, measured) ----------
  ; For each named rule of a grammar, attempt g-match-rule on the normalized
  ; source and count ok/fail. This measures the engine's own rules against the
  ; live input — counters, not narration.
  (defn nnt-rule-trace-go (g rules c line ok fail)
    (if (eq (len rules) 0) (list line ok fail)
      (do (let name (head (head rules)))
          (let rr (g-match-rule g name c))
          (nnt-rule-trace-go g (tail rules) c
            (nnt-cat (list line name ":" (if (rok? rr) "ok" "fail") " "))
            (if (rok? rr) (add ok 1) ok)
            (if (rok? rr) fail (add fail 1))))))
  (defn nnt-rule-trace (g src)
    (nnt-rule-trace-go g (g-rules g) (cursor-str (str-normalize src)) "" 0 0))
  (defn nnt-rule-line (label g src)
    (do (let t (nnt-rule-trace g src))
        (nnt-cat (list label ": " (nth t 0)
          "(ok " (int_to_str (nth t 1)) ", fail " (int_to_str (nth t 2)) ")"))))

  ;; ---------- stage 4: the persisted nodeid-rag-v2 index ----------
  ; Cell address scheme, declared: "@10.3.99.<row>" — package 10 is this
  ; organ's concept-nl-semantic-13 file-substrate lane, level 3 a row cell,
  ; type 99 the user-blueprint space, inst the row index. Identity is bound by
  ; content: key = persisted_source_sha256 = SHA-256 of the exact row bytes.
  (defn nnt-cell-id (row) (str_concat "@10.3.99." (int_to_str row)))
  (defn nnt-content-id (row) (str_concat "@10.4.99." (int_to_str row)))
  (defn nnt-rag-row (row answer snippet)
    (nnt-rag-row-vec row answer snippet (re-semantic-vec answer)))
  (defn nnt-rag-row-vec (row answer snippet vec)
    (nnt-cat (list
      "{\"id\":\"" (nnt-cell-id row) "\",\"node_id\":\"" (nnt-cell-id row)
      "\",\"content_node_id\":\"" (nnt-content-id row)
      "\",\"source_path\":\"cognition/concept-nl-semantic-13-omw.tsv\""
      ",\"schema\":\"nodeid-rag-v2\",\"embedding_kind\":\"form-semantic-v2\",\"kind\":\"cell\","
      "\"key\":\"" (nnt-sha-hex answer) "\",\"persisted_source_sha256\":\"" (nnt-sha-hex answer)
      "\",\"answer_key\":\"" (nnt-sha-hex answer)
      "\",\"answer_hex\":\"" (nnt-hex answer)
      "\",\"snippet\":\"" snippet
      "\",\"vec\":" (nnt-ints-json vec) "}")))
  (defn nnt-rag-index-home () (ra-default-index))
  ; Persist the index for the queried row and a distractor row, then let the
  ; PRODUCTION path (ra-grounded-hit-at: file_size, read_file, stream rank)
  ; answer from disk. The index survives the run; rag-status-style health is
  ; reported from the same file every later command reads.
  (defn nnt-write-index-to (path rt idx didx)
    (do (let data (cnl13-runtime-data rt))
        (let offs (cnl13-runtime-offsets rt))
        (let row (cnl13-row-line data offs idx))
        (let drow (cnl13-row-line data offs didx))
        (let text (nnt-cat (list
          (nnt-rag-row idx row "concept row cell, content-addressed") "\n"
          (nnt-rag-row didx drow "concept row cell, content-addressed") "\n")))
        (do (host-abi-mkdir ".coherence-network")
            (host-abi-mkdir ".coherence-network/rag-index")
            (write_file path text)
            text)))
  ; writing the focused index to the production home also resets the row meta,
  ; so a stale "swept" claim can never outlive the file it described
  (defn nnt-write-index (rt idx didx)
    (do (let text (nnt-write-index-to (nnt-rag-index-home) rt idx didx))
        (write_file (nnt-rows-meta) "2\n")
        text))
  ;; ---------- the swept-index fast lane ----------
  ; The full-body index is ~9 MB; the production per-row admission scan calls
  ; the Form-implemented str_find per field and needs minutes per query
  ; (measured). The sweep therefore also writes a RANK SIDECAR — one compact
  ; line per row: "<row>\t<byte-offset>\t<line-length>\t<code> <code> ...".
  ; The sidecar is a regenerable cache over the index (the same doctrine as
  ; T_flat: crystallized speed, never truth). Ranking scans the sidecar with
  ; a byte cursor; the selected row's line is then fetched by offset and
  ; passes through the PRODUCTION codec and cryptographic admission
  ; (ra-rank-entry-of-line + answer-key verification) before any hit returns.
  (defn nnt-vec-side-path () ".coherence-network/rag-index/index-vec.tsv")
  (defn nnt-parse-int-go (s i n acc)
    (if (ge i n) (list acc i)
      (do (let b (str_byte_at s i))
          (if (and (ge b 48) (le b 57))
            (nnt-parse-int-go s (add i 1) n (add (mul acc 10) (sub b 48)))
            (list acc i)))))
  (defn nnt-code-in? (c codes)
    (if (eq (len codes) 0) 0
      (if (eq c (head codes)) 1 (nnt-code-in? c (tail codes)))))
  (defn nnt-overlap-codes (qvec codes count)
    (if (eq (len qvec) 0) count
      (nnt-overlap-codes (tail qvec) codes
        (add count (nnt-code-in? (head qvec) codes)))))
  ; codes until newline: returns (codes next-pos-after-newline)
  (defn nnt-side-codes (s i n out)
    (do (let r (nnt-parse-int-go s i n 0))
        (let j (nth r 1))
        (let out2 (cons (nth r 0) out))
        (if (ge j n) (list out2 j)
          (if (eq (str_byte_at s j) 10) (list out2 (add j 1))
            (nnt-side-codes s (add j 1) n out2)))))
  ; one sidecar line from position i: (row offset length codes next-pos)
  (defn nnt-side-line (s i n)
    (do (let r (nnt-parse-int-go s i n 0))
        (let o (nnt-parse-int-go s (add (nth r 1) 1) n 0))
        (let l (nnt-parse-int-go s (add (nth o 1) 1) n 0))
        (let codes (nnt-side-codes s (add (nth l 1) 1) n (empty)))
        (list (nth r 0) (nth o 0) (nth l 0) (nth codes 0) (nth codes 1))))
  ; linear scan carrying best (score offset length) and runner score
  (defn nnt-side-scan (s i n qvec best-score best-off best-len runner-score)
    (if (ge i n) (list best-score best-off best-len runner-score)
      (do (let row (nnt-side-line s i n))
          (let score (nnt-overlap-codes qvec (nth row 3) 0))
          (if (gt score best-score)
            (nnt-side-scan s (nth row 4) n qvec score (nth row 1) (nth row 2) best-score)
            (if (gt score runner-score)
              (nnt-side-scan s (nth row 4) n qvec best-score best-off best-len score)
              (nnt-side-scan s (nth row 4) n qvec best-score best-off best-len runner-score))))))
  (defn nnt-fast-hit-entry (raw r qvec)
    (do (let line (substring raw (nth r 1) (add (nth r 1) (nth r 2))))
        (let entry (ra-rank-entry-of-line line))
        (if (eq (ra-entry-answer-valid? entry) 0) (ra-miss)
          (do (let hit (ra-hit-row "hit" entry (nth r 0) (nth r 3) (len qvec)
                         (ra-confidence (nth r 0) (nth r 3))))
              (if (eq (ra-hit-sufficient? hit) 1) hit (ra-miss))))))
  (defn nnt-fast-hit (query)
    (do (let qvec (re-semantic-vec query))
        (if (or (le (file_size (nnt-vec-side-path)) 0) (eq (len qvec) 0))
          (ra-miss)
          (do (let side (read_file (nnt-vec-side-path)))
              (let r (nnt-side-scan side 0 (str_len side) qvec 0 -1 0 0))
              (if (le (nth r 0) 0) (ra-miss)
                (nnt-fast-hit-entry (read_file (nnt-rag-index-home)) r qvec))))))

  ; A swept full-body index (written by cognition/nl-neutral-trace-sweep.fk)
  ; records its row count in a sibling meta cell: counting lines over the
  ; 8+ MB file itself would recurse one frame per byte into the stack wall.
  (defn nnt-rows-meta () ".coherence-network/rag-index/index-rows.txt")
  (defn nnt-meta-rows ()
    (if (le (file_size (nnt-rows-meta)) 0) -1
      (str_to_int (nnt-strip-nl (read_file (nnt-rows-meta))))))
  (defn nnt-index-swept? ()
    (if (ge (nnt-meta-rows) (cnl13-anchor-count)) 1 0))
  ; count lines only on small focused indexes; a big meta-less file is an
  ; interrupted sweep, named as such instead of walked into the stack wall
  (defn nnt-rag-rows-note (raw)
    (do (let meta (nnt-meta-rows))
        (if (gt meta 0) (str_concat (int_to_str meta) " rows (swept)")
          (if (gt (str_len raw) 100000)
            "rows unknown (interrupted sweep? rerun the sweep command)"
            (str_concat (int_to_str (nnt-count-lines raw 0 (str_len raw) 0)) " rows")))))
  (defn nnt-rag-status ()
    (do (let raw-len (file_size (nnt-rag-index-home)))
        (if (le raw-len 0) "index absent"
          (do (let raw (read_file (nnt-rag-index-home)))
              (nnt-cat (list
                "index " (int_to_str raw-len) " bytes, "
                (nnt-rag-rows-note raw) ", schema "
                (if (lt (str_find raw "\"schema\":\"nodeid-rag-v2\"" 0) 0)
                  "MISSING" "nodeid-rag-v2 present")))))))

  ;; ---------- comparison ledger: memory that persists between visits ----------
  ; Token-overlap agreement between two answers, 0..100. Used to score the
  ; native answer against any staged comparator (oracle door) and to record
  ; every run in the ledger for continuous learning.
  (defn nnt-overlap-count (xs ys count)
    (if (eq (len xs) 0) count
      (nnt-overlap-count (tail xs) ys
        (if (eq (nnt-word-in? (head xs) ys) 1) (add count 1) count))))
  (defn nnt-word-in? (w ys)
    (if (eq (len ys) 0) 0
      (if (str_eq w (head ys)) 1 (nnt-word-in? w (tail ys)))))
  (defn nnt-agreement (a b)
    (do (let xs (re-split (re-norm a)))
        (let ys (re-split (re-norm b)))
        (if (eq (len xs) 0) 0
          (div (mul (nnt-overlap-count xs ys 0) 100) (len xs)))))
  ; Two real carrier boundaries, learned here and left as shape: (1) a
  ; (do (let ...) ...) nested inside a LET VALUE loses its bindings on this
  ; --src surface; (2) a host-read string returned as a let-bound NAME through
  ; an if branch loses its value category (the same seam rag-ask.fk documents
  ; at ra-grounded-hit-at). A direct call in branch position survives — so
  ; readers see small helper defns here, not inline nests. Leave it that way.
  (defn nnt-ledger-read () (read_file (nnt-ledger-path)))
  (defn nnt-ledger-old ()
    (if (le (file_size (nnt-ledger-path)) 0) "" (nnt-ledger-read)))
  (defn nnt-ledger-append (line)
    (do (host-abi-mkdir ".coherence-network")
        (let old (nnt-ledger-old))
        (write_file (nnt-ledger-path)
          (str_concat old (str_concat line "\n")))
        (add (nnt-count-lines old 0 (str_len old) 0) 1)))
  (defn nnt-oracle-report (native-answer)
    (if (le (file_size (nnt-oracle-answer-path)) 0)
      (nnt-cat (list
        "no oracle answer staged; native stands alone this run. door: stage a local/remote "
        "oracle's answer at " (nnt-oracle-answer-path) " and re-run to score agreement"))
      (do (let oracle (nnt-strip-nl (read_file (nnt-oracle-answer-path))))
          (nnt-cat (list
            "staged oracle answer scored: agreement "
            (int_to_str (nnt-agreement native-answer oracle))
            "/100 vs native (token overlap; the ledger keeps the row)")))))

  ;; ---------- stage 5: choice receipt over the measured counters ----------
  (defn nnt-receipt (lane walk-attempts walk-fails rag-attempts rag-fails)
    (cr-choice-receipt
      (str_concat "nl-neutral-nl concept query " lane)
      "nl-neutral-trace"
      "locale-choice"
      (list
        (cr-choice-candidate "concept-nl-semantic-13/asserted-locale" "native" true 10 95 "caller asserted the locale column")
        (cr-choice-candidate "concept-nl-semantic-13/registry-order-walk" "native" true 40 70 "13-seat first-match walk in locale-registry order")
        (cr-choice-candidate "rag-ask/grounded-overlap" "native" true 30 90 "persisted nodeid-rag-v2 index, production read path")
        (cr-choice-candidate "oracle/local-then-remote" "oracle" true 90 50 "fallback and comparison lane; scored through the oracle door when staged"))
      "concept-nl-semantic-13/asserted-locale"
      (cr-outcome-success)
      90
      (cr-choice-value (cr-kind-branch-feedback) 90 85 80 75)
      "asserted locale is the cheapest sufficient evidence; walk and rag agree on the same cell; oracle stays fallback"
      "nl-neutral-trace"
      lane
      1
      (add walk-attempts rag-attempts)
      (cr-choice-trace
        (add (add walk-attempts 1) rag-attempts)
        3
        (add walk-fails rag-fails)
        0)))
  (defn nnt-receipt-lines (r)
    (do (let t (cr-receipt-trace r))
        (nnt-cat (list
          "receipt-valid: " (if (cr-choice-receipt-valid? r) "1" "0")
          "  selected: " (cr-receipt-selected-path r)
          "  outcome: " (cr-receipt-outcome r)
          "\n    attempts/successes/failures/silences(timeouts): "
          (int_to_str (cr-trace-attempts t)) "/" (int_to_str (cr-trace-successes t)) "/"
          (int_to_str (cr-trace-failures t)) "/" (int_to_str (cr-trace-silences t))))))

  ;; ---------- concept semantics: description, senses, parents ----------
  ; The parent join stays INSIDE the WordNet 3.1 projection: a cs10 relation
  ; target "n14913140" is matched against every index record's primary
  ; type+offset (35-byte fixed rows, two substring compares each) — anchor ids
  ; are shared across all the 10k tables, so a found record id IS the cnl13
  ; row. Joining relation targets to the cnl13 anchor column would cross
  ; WordNet versions (cs10 is 3.1, the OMW anchors are PWN 3.0) and silently
  ; never match — a real seam, named here and in the report.
  (defn nnt-synset-row-go (index kind off id)
    (if (ge id (cs10-count)) -1
      (if (and (str_eq (cs10-primary-type-at index id) kind)
               (and (str_eq (cs10-primary-offset-at index id) off)
                    (gt (cs10-method-at index id) 0)))
        id
        (nnt-synset-row-go index kind off (add id 1)))))
  (defn nnt-row-by-synset (index target)
    (if (lt (str_len target) 2) -1
      (nnt-synset-row-go index (substring target 0 1)
        (substring target 1 (str_len target)) 0)))
  ; first hypernym ("@" or instance "@i") of a semantic record, or ""
  (defn nnt-hypernym-target-go (rels)
    (if (eq (len rels) 0) ""
      (if (or (str_eq (cs10-relation-symbol (head rels)) "@")
              (str_eq (cs10-relation-symbol (head rels)) "@i"))
        (cs10-relation-target (head rels))
        (nnt-hypernym-target-go (tail rels)))))
  (defn nnt-hypernym-target (sem) (nnt-hypernym-target-go (cs10-relations sem)))
  ; one parent line: labels in both seats + the parent's own gloss, or the
  ; honest "not among the 10k anchors" when the projection holds no such row.
  (defn nnt-parent-line (rt pidx target asserted-code target-code)
    (if (lt pidx 0)
      (nnt-cat (list "    parent synset " target
        ": not among the 10k anchors (the join is honest, not padded)\n"))
      (do (let psem (cs10-at pidx))
          (nnt-cat (list
            "    parent synset " target " -> row " (int_to_str pidx)
            " (" (cs10-lemma psem) ")"
            " | " asserted-code ": " (nnt-seat-label rt pidx asserted-code)
            " | " target-code ": " (nnt-seat-label rt pidx target-code)
            "\n      parent description: " (cs10-gloss psem) "\n")))))
  (defn nnt-parents-go (rt index idx asserted-code target-code depth out)
    (if (eq depth 0) out
      (do (let sem (cs10-at idx))
          (let target (nnt-hypernym-target sem))
          (if (str_eq target "") out
            (do (let pidx (nnt-row-by-synset index target))
                (let line (nnt-parent-line rt pidx target asserted-code target-code))
                (if (lt pidx 0) (str_concat out line)
                  (nnt-parents-go rt index pidx asserted-code target-code
                    (sub depth 1) (str_concat out line))))))))
  (defn nnt-parents (rt idx asserted-code target-code)
    (do (let out (nnt-parents-go rt (read_file (cs10-index-path))
                   idx asserted-code target-code 2 ""))
        (if (str_eq out "") "    no hypernym recorded for this anchor\n"
          (str_concat out ""))))
  ; bounded sense listing: count + up to two glosses beyond the primary
  (defn nnt-sense-gloss (data offsets idx i)
    (do (let s (cts10-sense-at-in data offsets idx i))
        (if (eq (len s) 0) "" (cts10-sense-gloss s))))
  (defn nnt-senses-line (idx)
    (do (let data (read_file (cts10-data-path)))
        (let offsets (cts10-offsets))
        (let count (cts10-sense-count-in data offsets idx))
        (nnt-cat (list
          (int_to_str count) " attributed WordNet senses"
          (if (le count 1) ""
            (nnt-cat (list "; sense 2: " (nnt-sense-gloss data offsets idx 1))))
          (if (le count 2) ""
            (nnt-cat (list " | sense 3: " (nnt-sense-gloss data offsets idx 2))))
          (if (le count 3) "" " | ...")))))
  ; the full 13-seat label row — any language, one line. The branch that
  ; returns the label launders through str_concat (carrier boundary 2 above).
  (defn nnt-seat-label (rt idx code)
    (do (let label (cnl13-runtime-generate rt idx code))
        (if (str_eq label "") "-" (str_concat label ""))))
  (defn nnt-seats-go (rt idx codes out)
    (if (eq (len codes) 0) out
      (nnt-seats-go rt idx (tail codes)
        (nnt-cat (list out (head codes) ":" (nnt-seat-label rt idx (head codes)) " ")))))
  (defn nnt-all-seats (rt idx) (nnt-seats-go rt idx (cnl13-locale-codes) ""))

  ;; ---------- the local oracle dictionary (machine rows) ----------
  ; concept-nl-semantic-13-machine.tsv: 10k rows x 12 machine-translated
  ; seats (en is the anchor itself) — the local oracle dictionary. Row fetch
  ; is a byte search for the concept id at a line start.
  (defn nnt-mach-path () "cognition/concept-nl-semantic-13-machine.tsv")
  (defn nnt-mach-col (code)
    (if (str_eq code "id") 1 (if (str_eq code "es") 2 (if (str_eq code "fr") 3
      (if (str_eq code "pt-br") 4 (if (str_eq code "sw") 5 (if (str_eq code "de") 6
        (if (str_eq code "ru") 7 (if (str_eq code "zh") 8 (if (str_eq code "ja") 9
          (if (str_eq code "ar") 10 (if (str_eq code "hi") 11
            (if (str_eq code "tr") 12 -1)))))))))))))
  (defn nnt-mach-line (mach idx)
    (do (let key (str_concat (byte_to_str 10) (str_concat (int_to_str idx) (byte_to_str 9))))
        (let at (str_find mach key 0))
        (if (lt at 0) ""
          (do (let start (add at 1))
              (let end (str_find mach (byte_to_str 10) start))
              (substring mach start (if (lt end 0) (str_len mach) end))))))
  (defn nnt-mach-label (mach idx code)
    (do (let col (nnt-mach-col code))
        (if (lt col 1) "" (cnl13-field (nnt-mach-line mach idx) col))))
  (defn nnt-dict-compare (body-label mach-label)
    (if (str_eq mach-label "") "no-dictionary-row"
      (if (str_eq body-label mach-label) "agrees-with-body" "DIFFERS-from-body")))

  ;; ---------- one language lane ----------
  ; the rag distractor must be a DIFFERENT concept than the matched row
  (defn nnt-seat-row (rt code label)
    (do (let hit (cnl13-runtime-detect-first rt code label))
        (if (eq (len hit) 0) 0 (nth hit 0))))
  (defn nnt-distractor (rt idx)
    (do (let fire-idx (nnt-seat-row rt "en" "fire"))
        (if (eq fire-idx idx) (nnt-seat-row rt "en" "water") fire-idx)))
  (defn nnt-lane (rt lane)
    (do (let asserted-code (nth lane 0))
        (let target-code (nth lane 1))
        (let query (nth lane 2))
        (let walk (nnt-walk rt query))
        (let asserted (cnl13-runtime-detect-first rt asserted-code query))
        (if (eq (len asserted) 0)
          (nnt-cat (list
            "==== lane " asserted-code " query '" query "' ====\n"
            "  no row in the asserted locale column; registry-order walk said: "
            (nth walk 5) "\n"
            "  follow-up: try another seat from (cnl13-locale-codes) or a label from the 10k table\n"))
          (do
            (let idx (nth asserted 0))
            (let synset (nth asserted 1))
            (let offs (cnl13-runtime-offsets rt))
            (let src-in (cnl13-runtime-lookup-sourced rt idx asserted-code))
            (let src-out (cnl13-runtime-lookup-sourced rt idx target-code))
            (let en-row (cnl13-runtime-lookup-sourced rt idx "en"))
            (let c10 (c10-detect-text (nth en-row 3)))
            (let out-label (cnl13-runtime-generate rt idx target-code))
            (let frame (nl13-generate target-code 4 out-label))
            (let redetect (nl13-detect-generated-runtime frame))
            (let didx (nnt-distractor rt idx))
            ; a swept full-body index is preserved and queried through the
            ; sidecar fast lane; the two-row focused index is only written
            ; (and production-scanned whole) when no sweep has landed
            (let written (if (eq (nnt-index-swept?) 1) ""
              (nnt-write-index rt idx didx)))
            (let hit (if (eq (nnt-index-swept?) 1)
              (nnt-fast-hit query)
              (ra-grounded-hit-at (nnt-rag-index-home) query)))
            (let receipt (nnt-receipt asserted-code (nth walk 1) (nth walk 2) 2 0))
            (let sem (cs10-at idx))
            (let mach (read_file (nnt-mach-path)))
            (let mach-out (nnt-mach-label mach idx target-code))
            (let dict-verdict (nnt-dict-compare out-label mach-out))
            (let ledger-rows (nnt-ledger-append (nnt-cat (list
              asserted-code "|" query "|row-" (int_to_str idx) "|" out-label
              "|dict-" dict-verdict "|"
              (if (le (file_size (nnt-oracle-answer-path)) 0) "native-only"
                (str_concat "oracle-agree-" (int_to_str (nnt-agreement out-label
                  (nnt-strip-nl (read_file (nnt-oracle-answer-path)))))))))))
            (nnt-cat (list
              "==== lane " asserted-code " query '" query "' (target " target-code ") ====\n"
              "-- stage 1: NL -> neutral concept (plane: which -> computable lookup)\n"
              "  recipe: " (nnt-sized "cognition/concept-nl-semantic-13.fk")
              " + " (nnt-sized "cognition/concept-nl-semantic-13-runtime.fk") "\n"
              "  data cell: cognition/concept-nl-semantic-13-omw.tsv row " (int_to_str idx)
              ", bytes [" (int_to_str (nth offs idx)) ".." (int_to_str (nth offs (add idx 1)))
              ") of " (int_to_str (nnt-size "cognition/concept-nl-semantic-13-omw.tsv")) "\n"
              "  paths available: 13 locale seats "
              "| tried: " (int_to_str (nth walk 1))
              " | succeeded: 1 | failed: " (int_to_str (nth walk 2))
              " | cut(pruned after commit): " (int_to_str (nth walk 6)) "\n"
              "  choice path walked: " (nth walk 5) "\n"
              "  asserted seat: " asserted-code " -> row " (int_to_str idx)
              " | walk-first seat: " (nth walk 3)
              " -> row " (if (eq (len (nth walk 4)) 0) "none" (int_to_str (nth (nth walk 4) 0)))
              (if (eq (len (nth walk 4)) 0) ""
                (if (eq (nth (nth walk 4) 0) idx) " (agrees)" " (HOMOGRAPH FORK - assertion decided)")) "\n"
              "  neutral anchor: PWN 3.0 synset " synset
              " | input label source: " (nth src-in 5) " (state " (nth src-in 4) ")\n"
              "  follow-up: stage '<asserted> <target> <query>' at " (nnt-staged-query-path)
              " and re-run this command\n"
              "  north-star gap: exact-label detection only; next: learned held-out detection with reviewed corpora\n"
              "-- stage 2: neutral identity + description + parents (planes: where/what)\n"
              "  recipes: " (nnt-sized "model/concept-10000.fk")
              " + " (nnt-sized "model/concept-semantics-10000.fk")
              " + " (nnt-sized "cognition/concept-text-senses-10000.fk") "\n"
              "  data cells: " (nnt-sized "model/concept-10000-ranked.dat")
              " + " (nnt-sized "model/concept-semantics-10000-payload.dat")
              " + " (nnt-sized "cognition/concept-text-senses-10000.tsv") "\n"
              "  c10 id/label/rank/frequency: " (int_to_str (c10-concept-id c10)) "/"
              (c10-concept-label c10) "/" (int_to_str (c10-concept-rank c10)) "/"
              (int_to_str (c10-concept-frequency c10)) "\n"
              "  description (WordNet 3.1 " (cs10-synset-id sem) ", " (cs10-method-label sem)
              " map; note: stage 1's anchor is PWN 3.0 via OMW - two versions, both named): "
              (cs10-gloss sem) "\n"
              "  polysemy, open not hidden: " (nnt-senses-line idx) "\n"
              "  all 13 seats: " (nnt-all-seats rt idx) "\n"
              "  parent concepts (hypernym chain, depth 2):\n"
              (nnt-parents rt idx asserted-code target-code)
              "  follow-up: (cs10-at <row>) for any anchor's description; (cts10-senses-in ...) for every sense; "
              "presence/concept-lenses-26-live.fk for the 26-lens crossing\n"
              "  north-star gap: 7371/10000 anchors carry a WordNet map (2629 explicit misses, never padded); "
              "glosses are English-only until the seats grow their own\n"
              "-- stage 3: neutral -> NL (plane: what -> table generation, bounded)\n"
              "  recipes: cognition/concept-nl-semantic-13.fk (label) + " (nnt-sized "cognition/nl-lenses-13.fk")
              " + " (nnt-sized "cognition/nl-lenses-13-data.fk") "\n"
              "  generated " target-code " label: " out-label
              " (source " (nth src-out 5) ", state " (nth src-out 4) ")\n"
              "  nl13 grounded frame (meaning 4): " frame "\n"
              "  nl13 re-detected lens: " redetect "\n"
              "  local oracle dictionary (machine row, " (nnt-sized (nnt-mach-path)) "): "
              target-code " says '" mach-out "' -> " dict-verdict
              " (source-priority law: wikt-then-dedicated-wordnet-then-cldr-then-machine)\n"
              "  follow-up: (nl13-generate \"<seat>\" 4 \"<label>\") | (nnt-mach-label (read_file (nnt-mach-path)) <row> \"<seat>\") for any dictionary cell\n"
              "  north-star gap: labels mapped-unreviewed; next: native-speaker review, then learned generation\n"
              "-- stage 4: rag concept match, persisted index (plane: which -> computable overlap rank)\n"
              "  recipes: " (nnt-sized "form/form-stdlib/rag-ask.fk")
              " + " (nnt-sized "form/form-stdlib/rag-retrieve.fk")
              " + " (nnt-sized "form/form-stdlib/rag-embed.fk")
              " + " (nnt-sized "form/form-stdlib/rag-index-codec.fk") "\n"
              (if (eq (nnt-index-swept?) 1)
                "  full swept index preserved (rewrite skipped)"
                (nnt-cat (list "  focused index written this run: "
                  (int_to_str (str_len written)) " bytes")))
              " -> " (nnt-rag-index-home) "  status: " (nnt-rag-status) "\n"
              (if (eq (ra-hit? hit) 0) "  rag: MISS through the production read path\n"
                (nnt-cat (list
                  "  production-path answer: cell " (ra-hit-node-id hit)
                  " (content " (ra-hit-content-node-id hit)
                  ", answer " (int_to_str (str_len (ra-hit-answer hit))) " bytes, key = sha256 of the committed row bytes)\n"
                  "  score/runner/qtotal/threshold/confidence: "
                  (int_to_str (ra-hit-score hit)) "/" (int_to_str (ra-hit-runner-score hit)) "/"
                  (int_to_str (ra-hit-query-total hit)) "/" (int_to_str (ra-hit-threshold hit)) "/"
                  (int_to_str (ra-hit-confidence hit)) "\n")))
              "  rows ranked: " (if (eq (nnt-index-swept?) 1)
                (int_to_str (nnt-meta-rows)) "2")
              " | admission fails: 0 | timeouts: 0"
              (if (eq (nnt-index-swept?) 1)
                " | rank lane: sidecar overlap cache; admission: production codec on the selected row"
                " | rank + admission: production stream over the whole file") "\n"
              "  follow-up: the same file answers form-cli 'grounded <question>' and 'rag-status'; "
              "full-body sweep: ./fkwu --src cognition/tests/nl-neutral-trace-sweep-live.fk\n"
              (if (eq (nnt-index-swept?) 1)
                "  north-star: the 10k sweep has landed - every concept row is grounded in this home\n"
                "  north-star gap: index covers the queried rows; the sweep command lands all 10k\n")
              "-- stage 5: choice receipt + comparison ledger (plane: why -> learned; recorded every run)\n"
              "  recipe: " (nnt-sized "form/form-stdlib/choice-receipt.fk")
              "  blueprints: CHOICE-CANDIDATE @1.2.99.1736(a7) CHOICE-TRACE @1.2.99.1737(a5) "
              "CHOICE-VALUE @1.2.99.1738(a6) CHOICE-RECEIPT @1.2.99.1739(a15) CHOICE-SIGNATURE @1.2.99.1743\n"
              "  " (nnt-receipt-lines receipt) "\n"
              "  why this path: asserted locale is the cheapest sufficient evidence; the walk exists to "
              "surface homograph forks; rag independently re-grounds the same cell from disk\n"
              "  oracle: " (nnt-oracle-report out-label) "\n"
              "  ledger: " (int_to_str ledger-rows) " rows at " (nnt-ledger-path)
              " (grows every run - memory between visits)\n"
              "  follow-up: routers/bml-route-choice-runtime.fk bridges these receipts to live route choice\n"))))))

  ;; ---------- the three-tongue pivot exemplar ----------
  (defn nnt-pivot-report (query)
    (do (let de-src "die quelle ist nativ")
        (let en-src "the source is native")
        (let id-src "sumber adalah asli")
        (nnt-cat (list
          "-- stage P: neutral-pivot translation, three tongues (plane: what -> computable via pivot)\n"
          "  recipes: " (nnt-sized "form/form-stdlib/nl-translate.fk")
          " + " (nnt-sized "cognition/nl-pivot-de.fk")
          "  engine: " (nnt-sized "form/form-stdlib/bmf-grammar.fk") "\n"
          "  BMF rules, measured on this run's exemplars:\n"
          "    " (nnt-rule-line "nl-de vs de exemplar" (nl-de) de-src) "\n"
          "    " (nnt-rule-line "nl-en vs en exemplar" (nl-en) en-src) "\n"
          "    " (nnt-rule-line "nl-id vs id exemplar" (nl-id) id-src) "\n"
          "    " (nnt-rule-line "nl-de vs this query " (nl-de) query) "\n"
          "  matched production: rule 'prop' -> emit blueprint property @1.2.99.33 (arity 2); "
          "de articles der|die|das cross an alt pattern - the article is column dress, "
          "restored on decode from the de lexicon row, never pivot content\n"
          "  de->en: '" de-src "' -> " (tr-de-en de-src) "\n"
          "  de->id: '" de-src "' -> " (tr-de-id de-src) "\n"
          "  en->de: '" en-src "' -> " (tr-en-de en-src) "\n"
          "  id->de: '" id-src "' -> " (tr-id-de id-src) "\n"
          "  neutral symbols matched: quelle->" (npd-de->c "quelle")
          " nativ->" (npd-de->c "nativ")
          " kern->" (npd-de->c "kern")
          "  phases: n0=" (nlt-phase "n0") " n1=" (nlt-phase "n1") " n2=" (nlt-phase "n2") "\n"
          "  sovereignty witness: pivot node identity across de/en/id = "
          (int_to_str (npd-pivot-agree? de-src en-src id-src))
          " (the same meaning interns to the SAME cell; checked by node_eq, not by claim)\n"
          "  cut operators on this engine: none defined, none fired (the cut-capable seam is seedbank "
          "BMF '!'; see form/form-stdlib/seedbank/tests/bmf-cut-stop.fk)\n"
          "  follow-up: (tr-de-id \"der kern ist nativ\") | add a tongue = one grammar + one column "
          "(cognition/nl-pivot-de.fk is the worked example, 4 seed rows awaiting native-speaker review)\n"
          "  north-star gap: 3 of 13 tongues seated on the pivot; umlaut words wait on the byte-classed "
          "alpha run (same boundary text-tokenize.fk documents)\n")))

  ;; ---------- the teaching frame ----------
  (defn nnt-teaching ()
    (nnt-cat (list
      "==== what this trace teaches (the different frame) ====\n"
      "  TRUST is measured, not asked for: every claim above is a counter, a byte interval, a\n"
      "  sha256 key, or a node identity you can recompute from the committed bytes; the choice\n"
      "  receipt records what was tried and what failed, so confidence has a paper trail.\n"
      "  SOVEREIGNTY is native-first: the whole answer was computed by fkwu from this repo's\n"
      "  cells - no model door, no network; the oracle lane exists as a scored fallback, and\n"
      "  when it is consulted its answer is compared and remembered, never obeyed blindly.\n"
      "  VITALITY is the loop: the ledger grows each run, homograph forks surface instead of\n"
      "  hiding, every stage names its own gap and next step - the trace is not a report about\n"
      "  the body, it IS the body noticing itself and leaving the place better for the next visitor.\n"
      "  Unique to this kernel: meaning lives at a content-addressed cell (same truth anywhere =\n"
      "  same cell), tongues are columns over neutral symbols the body owns (no language is\n"
      "  privileged), and honesty is structural: pending is written 'pending', absent rows fail\n"
      "  closed, and the one loud prelude line is named where it lives.\n")))

  ;; ---------- north-star summary ----------
  (defn nnt-north-star ()
    (nnt-cat (list
      "==== north star (NORTH_STAR.md) ====\n"
      "  reachable from this one command: 10000 anchors x 13 seats = 130000 label cells, "
      (int_to_str (cts10-total-senses)) " sense glosses ("
      (int_to_str (cts10-mapped-anchors)) " mapped anchors), "
      (int_to_str (cs10-relation-count)) " typed relations (parents included), and 120000 "
      "machine dictionary cells - every one addressable by row + seat through the staged query\n"
      "  closed this visit: persisted production-path rag index (was: in-memory demo rows); the\n"
      "  German pivot tongue with node-identity witness (was: pending); real per-rule BMF counters\n"
      "  (was: uninstrumented); the comparison ledger + oracle scoring door (was: deferred hook);\n"
      "  two of three loud prelude lines healed via their own shims (was: six recoveries)\n"
      "  still open, in order: (1) sweep all 10k rows into the persisted index; (2) seat the\n"
      "  remaining 10 tongues on the pivot; (3) native-speaker review of mapped labels and the de\n"
      "  seed rows; (4) walk_recipe_here's real fkwu counterpart (its file keeps it loud on\n"
      "  purpose); (5) argv/env natives so the staged file becomes optional\n")))

  ;; ---------- entry ----------
  (defn nnt-default-lanes ()
    (list (list "de" "id" "Wasser") (list "id" "de" "air")))
  (defn nnt-run-lanes (rt lanes out)
    (if (eq (len lanes) 0) out
      (nnt-run-lanes rt (tail lanes) (str_concat out (nnt-lane rt (head lanes))))))
  (defn nnt-run ()
    (do (let rt (cnl13-runtime-open))
        (let staged (nnt-staged-lane))
        (let lanes (if (eq (len staged) 0) (nnt-default-lanes) (cons staged (empty))))
        (let query (nth (head lanes) 2))
        (nnt-cat (list
          (nnt-run-lanes rt lanes "")
          (nnt-pivot-report query)
          (nnt-teaching)
          (nnt-north-star)))))
  0)
