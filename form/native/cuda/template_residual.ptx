//
// form-ptx residual f32: y[i] = a[i] + b[i] (tb-vec-add), one thread per element.
//
.version 8.3
.target sm_89
.address_size 64

.visible .entry form_residual_f32(
    .param .u64 p_a,
    .param .u64 p_b,
    .param .u64 p_y,
    .param .u32 p_n
)
{
    .reg .pred  %p<2>;
    .reg .f32   %f<4>;
    .reg .b32   %r<8>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd1, [p_a];
    ld.param.u64    %rd2, [p_b];
    ld.param.u64    %rd3, [p_y];
    ld.param.u32    %r1, [p_n];
    mov.u32         %r2, %ctaid.x;
    mov.u32         %r3, %ntid.x;
    mov.u32         %r4, %tid.x;
    mad.lo.s32      %r5, %r2, %r3, %r4;
    setp.ge.u32     %p1, %r5, %r1;
    @%p1 bra        DONE;
    mul.wide.u32    %rd4, %r5, 4;
    add.s64         %rd5, %rd1, %rd4;
    ld.global.f32   %f1, [%rd5];
    add.s64         %rd6, %rd2, %rd4;
    ld.global.f32   %f2, [%rd6];
    add.f32         %f3, %f1, %f2;
    add.s64         %rd7, %rd3, %rd4;
    st.global.f32   [%rd7], %f3;
DONE:
    ret;
}
