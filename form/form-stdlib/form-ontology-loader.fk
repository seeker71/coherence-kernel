;; `(defn function-name () (factory-name int-value))`.
;; String rows: (function-name string-value), producing a string literal getter.

(let FOL-ENGINE-FACTORY-ROWS
    (list (list "bmf-domain-python" "bmf-domain-ref" 1) (list "bmf-domain-typescript" "bmf-domain-ref" 2) (list "bmf-domain-go" "bmf-domain-ref" 3) (list "bmf-domain-rust" "bmf-domain-ref" 4) (list "bmf-domain-bml" "bmf-domain-ref" 5) (list "bmf-domain-natural" "bmf-domain-ref" 6) (list "bmf-domain-image" "bmf-domain-ref" 7) (list "bmf-domain-audio" "bmf-domain-ref" 8) (list "bmf-domain-video" "bmf-domain-ref" 9) (list "bmf-domain-prolog" "bmf-domain-ref" 10) (list "bmf-domain-kind-language" "bmf-domain-kind-ref" 1) (list "bmf-domain-kind-media" "bmf-domain-kind-ref" 2) (list "bmf-domain-kind-runtime" "bmf-domain-kind-ref" 3) (list "bmf-lens-assertion" "bmf-lens-ref" 1) (list "bmf-lens-metadata" "bmf-lens-ref" 2) (list "bmf-lens-assign" "bmf-lens-ref" 3) (list "bmf-lens-var" "bmf-lens-ref" 4) (list "bmf-lens-quote" "bmf-lens-ref" 5) (list "bmf-lens-display" "bmf-lens-ref" 6)))

