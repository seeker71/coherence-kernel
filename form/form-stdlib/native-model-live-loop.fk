; native-model-live-loop.fk -- Form-owned live occurrence, evaluation, seal,
; and daily-accounting decisions for the local model loop.
;
; preludes: form-stdlib/core.fk form-stdlib/native-model-control-plane.fk
;
; The host shell is allowed to carry bytes to a local process and persist the
; resulting row.  It does not decide what a row means.  These constructors and
; gates are the executable meaning used by native_model_*.sh.  Raw prompts and
; answers never enter the occurrence row: only their SHA-256 identities do.
;
; witnessed: 2026-07-15 -> direct-source band 4095

(do
    ; One observed invocation.  `purpose` keeps evaluation/training traffic out
    ; of the production-final sovereignty denominator.
    (defn nmll-occurrence
        (day tick class model purpose success artifact input output latency-ms)
        (list "native-model-occurrence-v1" day tick class model purpose success
              artifact input output latency-ms))

    (defn nmll-occurrence? (r)
        (and (eq (len r) 11)
             (str_eq (nth r 0) "native-model-occurrence-v1")))
    (defn nmll-occ-day (r) (nth r 1))
    (defn nmll-occ-tick (r) (nth r 2))
    (defn nmll-occ-class (r) (nth r 3))
    (defn nmll-occ-model (r) (nth r 4))
    (defn nmll-occ-purpose (r) (nth r 5))
    (defn nmll-occ-success (r) (nth r 6))
    (defn nmll-occ-artifact (r) (nth r 7))
    (defn nmll-occ-input (r) (nth r 8))
    (defn nmll-occ-output (r) (nth r 9))
    (defn nmll-occ-latency-ms (r) (nth r 10))

    (defn nmll-class? (s)
        (if (str_eq s "form-native") 1
            (if (str_eq s "local-finetuned") 1
                (if (str_eq s "local-native") 1
                    (if (str_eq s "local-oracle") 1
                        (if (str_eq s "remote-oracle") 1 0))))))

    (defn nmll-purpose? (s)
        (if (str_eq s "production-final") 1
            (if (str_eq s "evaluation") 1
                (if (str_eq s "training") 1
                    (if (str_eq s "integration-probe") 1 0)))))

    (defn nmll-occurrence-valid? (r)
        (if (nmll-occurrence? r)
            (if (and (gt (nmll-occ-day r) 0) (ge (nmll-occ-tick r) 0))
                (if (and (eq (nmll-class? (nmll-occ-class r)) 1)
                         (gt (str_len (nmll-occ-model r)) 0))
                    (if (and (eq (nmll-purpose? (nmll-occ-purpose r)) 1)
                             (eq (nmcp-bit? (nmll-occ-success r)) 1))
                        (if (and (nmcp-sha256? (nmll-occ-artifact r))
                                 (nmcp-sha256? (nmll-occ-input r)))
                            (if (and (nmcp-sha256? (nmll-occ-output r))
                                     (ge (nmll-occ-latency-ms r) 0)) 1 0)
                            0)
                        0)
                    0)
                0)
            0))

    (defn nmll-occurrences-valid? (rows)
        (if (eq (len rows) 0) 1
            (if (eq (nmll-occurrence-valid? (head rows)) 1)
                (nmll-occurrences-valid? (tail rows)) 0)))

    (defn nmll-count-class (rows class)
        (if (eq (len rows) 0) 0
            (add (if (str_eq (nmll-occ-class (head rows)) class) 1 0)
                 (nmll-count-class (tail rows) class))))

    (defn nmll-count-purpose (rows purpose)
        (if (eq (len rows) 0) 0
            (add (if (str_eq (nmll-occ-purpose (head rows)) purpose) 1 0)
                 (nmll-count-purpose (tail rows) purpose))))

    (defn nmll-accepted-final? (r)
        (if (and (eq (nmll-occurrence-valid? r) 1)
                 (str_eq (nmll-occ-purpose r) "production-final"))
            (nmll-occ-success r) 0))

    (defn nmll-final-count (rows)
        (if (eq (len rows) 0) 0
            (add (nmll-accepted-final? (head rows))
                 (nmll-final-count (tail rows)))))

    (defn nmll-owned-final? (r)
        (if (eq (nmll-accepted-final? r) 0) 0
            (if (or (str_eq (nmll-occ-class r) "form-native")
                    (str_eq (nmll-occ-class r) "local-finetuned")) 1 0)))

    (defn nmll-owned-final-count (rows)
        (if (eq (len rows) 0) 0
            (add (nmll-owned-final? (head rows))
                 (nmll-owned-final-count (tail rows)))))

    ; -1 means unmeasured rather than the dishonest value 0/0.
    (defn nmll-owned-final-ppm (rows)
        (do (let total (nmll-final-count rows))
            (if (eq total 0) -1
                (div (mul (nmll-owned-final-count rows) 1000000) total))))

    ; Paired live diagnostic.  It can reject a bad candidate, but one daily row
    ; cannot promote a model; promotion remains nmcp-promote? over three days.
    (defn nmll-eval
        (samples candidate-exact candidate-f1 candidate-latency candidate-errors
         incumbent-exact incumbent-f1 incumbent-latency incumbent-errors
         identity-stable)
        (list "native-model-live-eval-v1" samples candidate-exact candidate-f1
              candidate-latency candidate-errors incumbent-exact incumbent-f1
              incumbent-latency incumbent-errors identity-stable))

    (defn nmll-eval? (r)
        (and (eq (len r) 11) (str_eq (nth r 0) "native-model-live-eval-v1")))
    (defn nmll-eval-samples (r) (nth r 1))
    (defn nmll-eval-candidate-exact (r) (nth r 2))
    (defn nmll-eval-candidate-f1 (r) (nth r 3))
    (defn nmll-eval-candidate-latency (r) (nth r 4))
    (defn nmll-eval-candidate-errors (r) (nth r 5))
    (defn nmll-eval-incumbent-exact (r) (nth r 6))
    (defn nmll-eval-incumbent-f1 (r) (nth r 7))
    (defn nmll-eval-incumbent-latency (r) (nth r 8))
    (defn nmll-eval-incumbent-errors (r) (nth r 9))
    (defn nmll-eval-identity-stable (r) (nth r 10))

    (defn nmll-ppm? (n) (if (and (ge n 0) (le n 1000000)) 1 0))
    (defn nmll-eval-valid? (r)
        (if (nmll-eval? r)
            (if (gt (nmll-eval-samples r) 0)
                (if (and (eq (nmll-ppm? (nmll-eval-candidate-exact r)) 1)
                         (eq (nmll-ppm? (nmll-eval-candidate-f1 r)) 1))
                    (if (and (eq (nmll-ppm? (nmll-eval-incumbent-exact r)) 1)
                             (eq (nmll-ppm? (nmll-eval-incumbent-f1 r)) 1))
                        (if (and (ge (nmll-eval-candidate-latency r) 0)
                                 (ge (nmll-eval-incumbent-latency r) 0))
                            (if (and (ge (nmll-eval-candidate-errors r) 0)
                                     (le (nmll-eval-candidate-errors r) (nmll-eval-samples r)))
                                (if (and (ge (nmll-eval-incumbent-errors r) 0)
                                         (le (nmll-eval-incumbent-errors r) (nmll-eval-samples r)))
                                    (nmcp-bit? (nmll-eval-identity-stable r)) 0)
                                0)
                            0)
                        0)
                    0)
                0)
            0))

    (defn nmll-diagnostic-verdict (r)
        (if (eq (nmll-eval-valid? r) 0) "invalid"
            (if (eq (nmll-eval-identity-stable r) 0) "identity-drift"
                (if (or (gt (nmll-eval-candidate-errors r) 0)
                        (gt (nmll-eval-incumbent-errors r) 0)) "call-errors"
                    (if (gt (nmll-eval-candidate-f1 r)
                            (nmll-eval-incumbent-f1 r)) "candidate-wins-diagnostic"
                        (if (lt (nmll-eval-candidate-f1 r)
                                (nmll-eval-incumbent-f1 r)) "incumbent-wins-diagnostic"
                            "diagnostic-tie"))))))

    ; Shell derives these booleans from real byte-level observations.  Form is
    ; the single gate: a missing bit keeps training closed.
    (defn nmll-seal-ready?
        (train-exists heldout-exists exact-disjoint prompt-disjoint consent license
         private-files content-addressed)
        (if (and (eq train-exists 1) (eq heldout-exists 1))
            (if (and (eq exact-disjoint 1) (eq prompt-disjoint 1))
                (if (and (eq consent 1) (eq license 1))
                    (if (and (eq private-files 1) (eq content-addressed 1)) 1 0)
                    0)
                0)
            0))

    ; One compact daily snapshot for the shell report.  It is derived from the
    ; validated occurrence list and preserves an explicit unmeasured -1 share.
    (defn nmll-snapshot (day rows)
        (list "native-model-live-snapshot-v1" day
              (nmll-count-class rows "form-native")
              (nmll-count-class rows "local-finetuned")
              (nmll-count-class rows "local-native")
              (nmll-count-class rows "local-oracle")
              (nmll-count-class rows "remote-oracle")
              (nmll-count-purpose rows "production-final")
              (nmll-count-purpose rows "evaluation")
              (nmll-count-purpose rows "training")
              (nmll-owned-final-ppm rows)))

    0)
