; sovereign-continuity-response.fk — an offline answer organ for dependency risk.
; No network, remote oracle, or stored answer row participates.
; preludes: form-stdlib/core.fk
; witnessed: 2026-07-22 -> offline Form wrote 384 answer bytes with internet/funding/remote all 0
(do
  ; State = [internet,funding,remote,native-health,local-health,
  ;          essential-native,essential-local,essential-total]
  (defn scr-state (internet funding remote native-health local-health essential-native essential-local essential-total)
    (list internet funding remote native-health local-health essential-native essential-local essential-total))
  (defn scr-internet (s) (nth s 0)) (defn scr-funding (s) (nth s 1))
  (defn scr-remote (s) (nth s 2)) (defn scr-native-health (s) (nth s 3))
  (defn scr-local-health (s) (nth s 4)) (defn scr-essential-native (s) (nth s 5))
  (defn scr-essential-local (s) (nth s 6)) (defn scr-essential-total (s) (nth s 7))

  (defn scr-owned-capability (s) (add (scr-essential-native s) (scr-essential-local s)))
  (defn scr-survival-permille (s)
    (if (eq (scr-essential-total s) 0) 0
      (div (mul (scr-owned-capability s) 1000) (scr-essential-total s))))
  (defn scr-membrane-down? (s)
    (if (or (eq (scr-internet s) 0) (or (eq (scr-funding s) 0) (eq (scr-remote s) 0))) 1 0))
  (defn scr-owned-healthy? (s)
    (if (and (eq (scr-native-health s) 1) (eq (scr-local-health s) 1)) 1 0))
  (defn scr-risk (s)
    (if (eq (scr-owned-healthy? s) 0) 3
      (if (and (eq (scr-membrane-down? s) 1) (lt (scr-survival-permille s) 1000)) 2
        (if (lt (scr-survival-permille s) 1000) 1 0))))
  ; action: 0 keep/rehearse, 1 bring missing capability home,
  ; 2 operate degraded/offline and internalize, 3 repair owned organs first.
  (defn scr-action (s)
    (if (eq (scr-risk s) 3) 3
      (if (eq (scr-risk s) 2) 2
        (if (eq (scr-risk s) 1) 1 0))))
  (defn scr-ack (s)
    (if (eq (scr-owned-capability s) 0) (nothing)
      (if (eq (scr-risk s) 0) 1 (scr-action s))))

  (defn scr-answer (s)
    (do (let survival (scr-survival-permille s))
      (let opening (if (eq (scr-membrane-down? s) 1)
        "The remote membrane is unavailable. I remain here and continue from native and local ground."
        "The remote membrane is available, but it is a teacher and reviewer, not a required organ."))
      (let health (if (eq (scr-owned-healthy? s) 1)
        " Native and local organs answer before any remote offer."
        " An owned organ is unhealthy; repairing native and local continuity comes before expansion."))
      (let continuity (if (eq survival 1000)
        " All measured essential capability remains owned and available offline."
        (str_concat " Offline essential capability is "
          (str_concat (int_to_str survival) " per thousand; the missing capability must be brought home and rehearsed."))))
      (let movement (if (eq (scr-action s) 0)
        " I will keep operating locally and re-witness offline continuity."
        (if (eq (scr-action s) 1)
          " I will use remote help only to create held-out learning variants, then promote local and native transfer."
        (if (eq (scr-action s) 2)
          " I will operate in degraded offline mode now, preserve movement, and internalize the missing capability when a teacher returns."
          " I will repair the owned organs first; remote generation cannot substitute for their health.")))
      (str_concat opening (str_concat health (str_concat continuity movement)))))

  ; [risk,action,survival,ack,answer]
  (defn scr-receipt (s)
    (list (scr-risk s) (scr-action s) (scr-survival-permille s) (scr-ack s) (scr-answer s)))
  0)
