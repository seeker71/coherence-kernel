; name-lexicon.fk — the name layer joins the pivot discipline.
;
; preludes: form-stdlib/core.fk
;
; Urs's directive (2026-07-17 night): at least 3 of the most dramatic unique
; languages represented as much as English. The lexifier correction
; (receipts/2026-07-17-neutral-dominance-count.md) measured the wound: the
; s-expr corpus's grammar is its own but its 61,335 distinct names are
; English — a creole with one lexifier. This cell begins relexification at
; the Zipf head: the ~44 most load-bearing names cover 42% of all 834,807
; identifier occurrences in the body, and every row is KEYED by a neutral
; y<k> symbol (English holds no key seat) and carries FOUR surface
; columns — en, zh (中文: isolating, logographic), ar (العربية:
; root-templatic, right-to-left abjad), sa (संस्कृतम्: the lineage tongue,
; fusional, Devanagari). For every seated row the three dramatic tongues are
; represented exactly as much as English: same table, same width, by
; construction. Single-letter variables (r s a b i n …) are left unseated —
; they carry no English.
;
; zh/ar/sa surfaces seeded by the rented mind (provenance: rented-oracle,
; phase gas); native speakers and the corpus refine them. The identity of a
; name is its NodeID; every column here — en included — is a projection.
;
; THE LAYERS (Urs, 2026-07-17 night): the first 3, 4, 5, 7, 8, 12, 13, and
; 64 symbols line up with core domain languages, each prefix a closed world:
;   y0-y2   (3)  the structural triad — define, bind, choose
;   +y3     (4)  time enters — sequence
;   +y4     (5)  discernment — the first question
;   +y5-y6  (7)  existence and joining
;   +y7     (8)  the first look inside
;   +y8-y11 (12) the list world closes
;   +y12    (13) language about language — grammar itself
;   +...    (64) the working world closes at the hexagram count
;
; nlx-render walks a source string and rewrites every seated name from the
; en column to a tongue's column; nlx-accept walks it back. The walk splits
; only at ASCII delimiters (space, lparen, rparen, newline), so every token
; boundary is a char boundary in every kernel's own string-index scheme —
; the cross-kernel string-unit seam is not crossed, and round-trip identity
; holds on all four arms. Proven by: tests/name-lexicon-band.fk.

(do
    ;; --- the rows: (en zh ar sa) ---
    (defn nlx-rows () (list
        (list "y0" "defn" "定义" "عرف" "विधि")
        (list "y1" "let" "设" "ليكن" "अस्तु")
        (list "y2" "if" "若" "إذا" "यदि")
        ;; --- L1 (3) closes: the structural triad — define, bind, choose ---
        (list "y3" "do" "行" "افعل" "कुरु")
        ;; --- L2 (4) closes: time enters — sequence ---
        (list "y4" "eq" "等" "يساوي" "समम्")
        ;; --- L3 (5) closes: discernment — the first question ---
        (list "y5" "empty" "空" "فارغ" "शून्यम्")
        (list "y6" "cons" "连" "صل" "सन्धिः")
        ;; --- L4 (7) closes: existence and joining ---
        (list "y7" "head" "首" "رأس" "शिरस्")
        ;; --- L5 (8) closes: the first look inside ---
        (list "y8" "tail" "尾" "ذيل" "पुच्छम्")
        (list "y9" "len" "长" "طول" "दैर्घ्यम्")
        (list "y10" "nth" "第" "رقم" "क्रमः")
        (list "y11" "list" "列" "قائمة" "सूची")
        ;; --- L6 (12) closes: the list world ---
        (list "y12" "grammar" "文法" "قواعد" "व्याकरणम्")
        ;; --- L7 (13) closes: language about language ---
        (list "y13" "add" "加" "اجمع" "योगः")
        (list "y14" "sub" "减" "اطرح" "वियोगः")
        (list "y15" "mul" "乘" "اضرب" "गुणनम्")
        (list "y16" "div" "除" "اقسم" "भागः")
        (list "y17" "mod" "余" "باقي" "शेषः")
        (list "y18" "ne" "不等" "لا_يساوي" "असमम्")
        (list "y19" "lt" "小于" "أصغر" "अल्पम्")
        (list "y20" "le" "小等" "أصغر_أو" "अल्पसमम्")
        (list "y21" "gt" "大于" "أكبر" "महत्")
        (list "y22" "ge" "大等" "أكبر_أو" "महत्समम्")
        (list "y23" "and" "与" "و" "च")
        (list "y24" "or" "或" "أو" "वا")
        (list "y25" "not" "非" "ليس" "न")
        (list "y26" "nil?" "空吗" "فارغ؟" "शून्यकिम्")
        (list "y27" "true" "真" "صحيح" "सत्यम्")
        (list "y28" "false" "假" "خطأ" "असत्यम्")
        (list "y29" "str_len" "串长" "نص_طول" "तन्तुदैर्घ्यम्")
        (list "y30" "str_eq" "串等" "نص_يساوي" "तन्तुसमम्")
        (list "y31" "str_concat" "串接" "نص_وصل" "तन्तुयोगः")
        (list "y32" "str_byte_at" "串字节" "نص_بايت" "तन्त्वष्टकः")
        (list "y33" "substring" "子串" "نص_جزء" "उपतन्तुः")
        (list "y34" "str_find" "串寻" "نص_بحث" "तन्तुखोजः")
        (list "y35" "char_at" "字于" "حرف_في" "वर्णः")
        (list "y36" "byte_to_str" "字节变串" "بايت_إلى_نص" "अष्टकतन्तुः")
        (list "y37" "int_to_str" "数变串" "عدد_إلى_نص" "अङ्कतन्तुः")
        (list "y38" "str_to_int" "串变数" "نص_إلى_عدد" "तन्त्वङ्कः")
        (list "y39" "str_to_float" "串变浮" "نص_إلى_عائم" "तन्तुप्लवः")
        (list "y40" "float_to_int" "浮变数" "عائم_إلى_عدد" "प्लवाङ्कः")
        (list "y41" "band" "位与" "بت_و" "बिट्च")
        (list "y42" "bor" "位或" "بت_أو" "बिट्वा")
        (list "y43" "bxor" "位异" "بت_غير" "बिट्भेदः")
        (list "y44" "shl_u32" "左移" "زح_يسار" "वामसरणम्")
        (list "y45" "shr_u32" "右移" "زح_يمين" "दक्षिणसरणम्")
        (list "y46" "rotr_u32" "右转" "در_يمين" "दक्षिणावर्तः")
        (list "y47" "add_u32" "环加" "اجمع_دائري" "चक्रयोगः")
        (list "y48" "bnot_u32" "位非" "بت_ليس" "बिट्न")
        (list "y49" "node_eq" "节点等" "عقدة_يساوي" "ग्रन्थिसमम्")
        (list "y50" "node_value" "节点值" "عقدة_قيمة" "ग्रन्थिमूल्यम्")
        (list "y51" "node_children" "节点子" "عقدة_أبناء" "ग्रन्थिसुताः")
        (list "y52" "intern_node" "存节点" "خزن_عقدة" "ग्रन्थिधारणम्")
        (list "y53" "intern_trivial_string" "存简串" "خزن_نص" "तन्तुधारणम्")
        (list "y54" "make_nodeid" "造节号" "اصنع_معرف" "ग्रन्थिकरणम्")
        (list "y55" "bp" "蓝图" "مخطط" "प्रारूपम्")
        (list "y56" "read_file" "读文件" "اقرأ_ملف" "पत्रपठनम्")
        (list "y57" "write_file" "写文件" "اكتب_ملف" "पत्रलेखनम्")
        (list "y58" "print_str" "印串" "اطبع_نص" "तन्तुमुद्रणम्")
        (list "y59" "match" "配" "طابق" "मेलनम्")
        (list "y60" "name" "名" "اسم" "नाम")
        (list "y61" "form_error" "形误" "خطأ_شكل" "रूपदोषः")
        (list "y62" "rule3" "规三" "قاعدة_ثلاثية" "त्रिनियमः")
        (list "y63" "g-parse" "文解" "حلل" "व्याकरणपठनम्")))
    ;; --- L8 (64) closes: the working world ---

    ;; column index per tongue: nsym 0 (the neutral symbol itself), en 1,
    ;; zh 2, ar 3, sa 4. English holds no key — the y<k> symbol is the key,
    ;; and "en" is a projection column like every other tongue.
    (defn nlx-col (tongue)
        (if (str_eq tongue "nsym") 0
            (if (str_eq tongue "en") 1
                (if (str_eq tongue "zh") 2 (if (str_eq tongue "ar") 3 (if (str_eq tongue "sa") 4 1))))))

    (defn nlx-find (rows i w)
        (if (nil? rows) (empty)
            (if (str_eq (nth (head rows) i) w) (head rows)
                (nlx-find (tail rows) i w))))
    ;; map token from column i to column j; unknown tokens pass through untouched
    (defn nlx-map (i j w)
        (do (let r (nlx-find (nlx-rows) i w))
            (if (nil? r) w (nth r j))))

    ;; --- the walk: split ONLY at ASCII delimiters, rewrite seated tokens ---
    (defn nlx-delim? (b) (or (eq b 32) (or (eq b 40) (or (eq b 41) (eq b 10)))))
    (defn nlx-flush (s start i ci cj acc)
        (if (ge i (add start 1))
            (str_concat acc (nlx-map ci cj (substring s start i)))
            (if (gt i start) (str_concat acc (nlx-map ci cj (substring s start i))) acc)))
    (defn nlx-walk (s i start ci cj acc)
        (if (ge i (str_len s))
            (if (gt i start) (str_concat acc (nlx-map ci cj (substring s start i))) acc)
            (if (nlx-delim? (str_byte_at s i))
                (nlx-walk s (add i 1) (add i 1) ci cj
                    (str_concat
                        (if (gt i start) (str_concat acc (nlx-map ci cj (substring s start i))) acc)
                        (byte_to_str (str_byte_at s i))))
                (nlx-walk s (add i 1) start ci cj acc))))

    ;; render: en names -> tongue's names.  accept: tongue's names -> en.
    (defn nlx-render (tongue src) (nlx-walk src 0 0 1 (nlx-col tongue) ""))
    (defn nlx-accept (tongue src) (nlx-walk src 0 0 (nlx-col tongue) 1 ""))

    ;; parity witness: every row carries all four columns non-empty
    (defn nlx-row-full? (r)
        (and (gt (str_len (nth r 0)) 0)
             (and (gt (str_len (nth r 1)) 0)
                  (and (gt (str_len (nth r 2)) 0)
                       (and (gt (str_len (nth r 3)) 0) (gt (str_len (nth r 4)) 0))))))
    (defn nlx-parity-loop (rows)
        (if (nil? rows) 1
            (if (eq (nlx-row-full? (head rows)) true)
                (nlx-parity-loop (tail rows))
                0)))
    (defn nlx-parity? () (nlx-parity-loop (nlx-rows)))
    (defn nlx-count () (len (nlx-rows)))

    0)
