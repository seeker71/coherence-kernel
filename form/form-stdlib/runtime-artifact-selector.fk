; runtime-artifact-selector.fk -- Layer 9b plan coherence selector.
;
; This layer consumes Layer 9a `rap-plan` rows and emits selection rows. It is
; a selector face, not runtime execution and not an installed `fkwu` startup
; selector. It validates plan coherence, but it does not derive routes from
; descriptors, read or write disk, load or walk `.fkb`, load or call `.dylib`,
; resolve symbols, execute native bytes, reverify seals/proofs/callability,
; decide source-runner admission, or grow the C seed.
;
; The selector is total over readable plan-shaped rows:
;   coherent execution intent -> selected
;   upstream investigate plan  -> investigate
;   incoherent readable plan   -> investigate
;   malformed unreadable plan  -> refused
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk

(do
    (defn ras-feature (name status) (list "runtime-artifact-selector-feature" name status))
    (defn ras-feature-name (f) (nth f 1))
    (defn ras-feature-status (f) (nth f 2))
    (defn runtime-artifact-selector-manifest ()
        (list
            (ras-feature "selection-face-not-execution" 1)
            (ras-feature "consumes-rap-plan-only" 1)
            (ras-feature "plan-coherence-gate" 1)
            (ras-feature "no-descriptor-route-derivation" 1)
            (ras-feature "total-selection-row" 1)
            (ras-feature "selected-investigate-refused-statuses" 1)
            (ras-feature "malformed-refused-incoherent-investigates" 1)
            (ras-feature "no-disk-io" 1)
            (ras-feature "no-runtime-load" 1)
            (ras-feature "no-native-execution" 1)
            (ras-feature "no-seal-verification" 1)
            (ras-feature "no-proof-callable-reverify" 1)
            (ras-feature "no-admission-policy" 1)
            (ras-feature "no-c-seed-growth" 1)
            (ras-feature "no-fkwu-selector-install" 1)
            (ras-feature "no-route-rederivation" 1)))
    (defn runtime-artifact-selector-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (ras-feature-name (head fs)) name)
                     (eq (ras-feature-status (head fs)) 1))
                1
                (runtime-artifact-selector-manifest-has? name (tail fs)))))

    (defn ras-status-selected () "selected")
    (defn ras-status-investigate () "investigate")
    (defn ras-status-refused () "refused")
    (defn ras-reason-selected-native () "selected-native")
    (defn ras-reason-selected-program-image () "selected-program-image")
    (defn ras-reason-selected-compile-source () "selected-compile-source")
    (defn ras-reason-upstream-investigate () "upstream-investigate")
    (defn ras-reason-malformed-plan () "malformed-plan")
    (defn ras-reason-incoherent-native () "incoherent-native-plan")
    (defn ras-reason-incoherent-program-image () "incoherent-program-image-plan")
    (defn ras-reason-incoherent-compile-source () "incoherent-compile-source-plan")
    (defn ras-reason-incoherent-investigate () "incoherent-investigate-plan")
    (defn ras-reason-unknown-primary () "unknown-primary")
    (defn ras-reason-route-mismatch () "route-mismatch")

    ; selection = ("runtime-artifact-selection" route selected fallback status
    ;              skip-parse skip-recompute reason)
    (defn ras-selection (route selected fallback status skip-parse skip-recompute reason)
        (list "runtime-artifact-selection" route selected fallback status
              skip-parse skip-recompute reason))
    (defn ras-selection? (s) (str_eq (nth s 0) "runtime-artifact-selection"))
    (defn ras-selection-route (s) (nth s 1))
    (defn ras-selection-selected (s) (nth s 2))
    (defn ras-selection-fallback (s) (nth s 3))
    (defn ras-selection-status (s) (nth s 4))
    (defn ras-selection-skip-parse (s) (nth s 5))
    (defn ras-selection-skip-recompute (s) (nth s 6))
    (defn ras-selection-reason (s) (nth s 7))
    (defn ras-selected? (s)
        (if (ras-selection? s)
            (if (str_eq (ras-selection-status s) (ras-status-selected)) 1 0)
            0))
    (defn ras-investigate? (s)
        (if (ras-selection? s)
            (if (str_eq (ras-selection-status s) (ras-status-investigate)) 1 0)
            0))
    (defn ras-refused? (s)
        (if (ras-selection? s)
            (if (str_eq (ras-selection-status s) (ras-status-refused)) 1 0)
            0))

    (defn ras-bit? (x)
        (if (eq x 0) 1 (if (eq x 1) 1 0)))
    (defn ras-plan-row? (p)
        (if (eq (len p) 8)
            (str_eq (nth p 0) "runtime-artifact-plan")
            0))
    (defn ras-plan-readable? (p)
        (if (ras-plan-row? p)
            (if (ras-bit? (rap-plan-skip-parse p))
                (if (ras-bit? (rap-plan-skip-recompute p))
                    (ras-bit? (rap-plan-deopt-anchor p))
                    0)
                0)
            0))
    (defn ras-route-matches-primary? (p)
        (if (str_eq (rap-plan-primary p) (rap-act-run-native))
            (if (eq (rap-plan-route p) (sac-run-dylib)) 1 0)
            (if (str_eq (rap-plan-primary p) (rap-act-run-program-image))
                (if (eq (rap-plan-route p) (sac-run-fkb)) 1 0)
                (if (str_eq (rap-plan-primary p) (rap-act-compile-source))
                    (if (eq (rap-plan-route p) (sac-run-source-compile)) 1 0)
                    (if (str_eq (rap-plan-primary p) (rap-act-investigate))
                        (if (eq (rap-plan-route p) (sad-route-invalid)) 1 0)
                        0)))))

    (defn ras-coherent-native? (p)
        (if (str_eq (rap-plan-primary p) (rap-act-run-native))
            (if (eq (ras-route-matches-primary? p) 1)
                (if (str_eq (rap-plan-fallback p) (rap-act-run-program-image))
                    (if (eq (rap-plan-skip-parse p) 1)
                        (if (eq (rap-plan-skip-recompute p) 1)
                            (if (eq (rap-plan-deopt-anchor p) 1) 1 0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn ras-coherent-program-image? (p)
        (if (str_eq (rap-plan-primary p) (rap-act-run-program-image))
            (if (eq (ras-route-matches-primary? p) 1)
                (if (str_eq (rap-plan-fallback p) (rap-act-compile-source))
                    (if (eq (rap-plan-skip-parse p) 1)
                        (if (eq (rap-plan-skip-recompute p) 0)
                            (if (eq (rap-plan-deopt-anchor p) 1) 1 0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn ras-coherent-compile-source? (p)
        (if (str_eq (rap-plan-primary p) (rap-act-compile-source))
            (if (eq (ras-route-matches-primary? p) 1)
                (if (str_eq (rap-plan-fallback p) (rap-act-none))
                    (if (eq (rap-plan-skip-parse p) 0)
                        (if (eq (rap-plan-skip-recompute p) 0)
                            (if (eq (rap-plan-deopt-anchor p) 0) 1 0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn ras-coherent-investigate? (p)
        (if (str_eq (rap-plan-primary p) (rap-act-investigate))
            (if (eq (ras-route-matches-primary? p) 1)
                (if (str_eq (rap-plan-fallback p) (rap-act-none))
                    (if (eq (rap-plan-skip-parse p) 0)
                        (if (eq (rap-plan-skip-recompute p) 0)
                            (if (eq (rap-plan-deopt-anchor p) 0) 1 0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn ras-known-primary? (p)
        (if (str_eq (rap-plan-primary p) (rap-act-run-native))
            1
            (if (str_eq (rap-plan-primary p) (rap-act-run-program-image))
                1
                (if (str_eq (rap-plan-primary p) (rap-act-compile-source))
                    1
                    (if (str_eq (rap-plan-primary p) (rap-act-investigate)) 1 0)))))

    (defn ras-selected-row (p reason)
        (ras-selection (rap-plan-route p) (rap-plan-primary p) (rap-plan-fallback p)
                       (ras-status-selected)
                       (rap-plan-skip-parse p)
                       (rap-plan-skip-recompute p)
                       reason))
    (defn ras-investigate-row (p reason)
        (ras-selection (if (ras-plan-row? p) (rap-plan-route p) (sad-route-invalid))
                       (rap-act-investigate)
                       (rap-act-none)
                       (ras-status-investigate)
                       0
                       0
                       reason))
    (defn ras-refused-row ()
        (ras-selection (sad-route-invalid)
                       (rap-act-none)
                       (rap-act-none)
                       (ras-status-refused)
                       0
                       0
                       (ras-reason-malformed-plan)))

    (defn ras-selection-from-plan (p)
        (if (eq (ras-plan-readable? p) 1)
            (if (str_eq (rap-plan-primary p) (rap-act-run-native))
                (if (eq (ras-coherent-native? p) 1)
                    (ras-selected-row p (ras-reason-selected-native))
                    (if (eq (ras-route-matches-primary? p) 1)
                        (ras-investigate-row p (ras-reason-incoherent-native))
                        (ras-investigate-row p (ras-reason-route-mismatch))))
                (if (str_eq (rap-plan-primary p) (rap-act-run-program-image))
                    (if (eq (ras-coherent-program-image? p) 1)
                        (ras-selected-row p (ras-reason-selected-program-image))
                        (if (eq (ras-route-matches-primary? p) 1)
                            (ras-investigate-row p (ras-reason-incoherent-program-image))
                            (ras-investigate-row p (ras-reason-route-mismatch))))
                    (if (str_eq (rap-plan-primary p) (rap-act-compile-source))
                        (if (eq (ras-coherent-compile-source? p) 1)
                            (ras-selected-row p (ras-reason-selected-compile-source))
                            (if (eq (ras-route-matches-primary? p) 1)
                                (ras-investigate-row p (ras-reason-incoherent-compile-source))
                                (ras-investigate-row p (ras-reason-route-mismatch))))
                        (if (str_eq (rap-plan-primary p) (rap-act-investigate))
                            (if (eq (ras-coherent-investigate? p) 1)
                                (ras-investigate-row p (ras-reason-upstream-investigate))
                                (if (eq (ras-route-matches-primary? p) 1)
                                    (ras-investigate-row p (ras-reason-incoherent-investigate))
                                    (ras-investigate-row p (ras-reason-route-mismatch))))
                            (ras-investigate-row p (ras-reason-unknown-primary))))))
            (ras-refused-row)))
)
