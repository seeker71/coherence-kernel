; form-cli-repl.fk — the interactive TTY front door on the emitted walker (fkwu).
;
; The INTERACTIVE surface (the headless one is form-cli-main.fk reading fk_src):
; a read-eval-print loop over real fd 0. read_line (walker tag 114) reads one
; line of stdin, fc-respond (form-cli.fk, four-way proven) dispatches the verb,
; print_str (tag 115) writes the response, and the loop recurses. isatty (tag
; 116) gates an interactive prompt so a piped session stays clean. The loop ends
; on EOF (read_line returns a negative sentinel) or the quit/exit verb.
;
; Deterministic and testable: output is a pure function of the stdin bytes —
; pipe a fixed transcript, get a fixed response stream (form_cli_test.go).
; read_line/print_str/isatty are host-io ops the emitted walker carries (tags
; 114/115/116); they are not in the three host walkers, so this is fkwu-native,
; the same way input_byte (tag 17) is. One native engine, both surfaces.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-cli.fk form-stdlib/form-cli-gguf-cell.fk
(do
    ; 'diagnose' reads the live framebuffer the walker is born with — fk_arms[t]
    ; per-op dispatch counts plus the node/string/arena/value-stack/float
    ; high-water — back into this running program through kernel_stat (a fkwu-only
    ; op, tag 127, the read twin of self_source). The readout is the kernel
    ; inspecting itself mid-session: what it is computing, how big its substrate
    ; has grown, where its time is going. fkwu-only, so it sits beside source/
    ; verify in the runtime wrapper, never in the four-way dispatch.
    (defn fc-diagnose ()
        (str_concat "fkwu live | ops="
        (str_concat (int_to_str (kernel_stat 0))
        (str_concat " distinct="
        (str_concat (int_to_str (kernel_stat 1))
        (str_concat " hottest=tag"
        (str_concat (int_to_str (kernel_stat 2))
        (str_concat "x"
        (str_concat (int_to_str (kernel_stat 3))
        (str_concat " nodes="
        (str_concat (int_to_str (kernel_stat 4))
        (str_concat " strings="
        (str_concat (int_to_str (kernel_stat 5))
        (str_concat " cons="
        (str_concat (int_to_str (kernel_stat 6))
        (str_concat " vstack="
        (str_concat (int_to_str (kernel_stat 7))
        (str_concat " floats="
                    (int_to_str (kernel_stat 8))))))))))))))))))))

    (defn fc-metal-matvec (arg)
        (do
            (let parts (split-on arg " "))
            (let msl-path (fc-part parts 0 ""))
            (let kernel (fc-part parts 1 "form_fkwu_generic_matvec_f32"))
            (let model-path (fc-part parts 2 ""))
            (if (or (str_eq msl-path "") (str_eq model-path ""))
                "usage: metal-matvec <msl-path> <kernel-name> <model-path>"
                (metal_matvec_f32 (read_file msl-path) kernel (read_file model-path)))))

    (defn fc-strip-last-byte-if (s code)
        (do
            (let n (str_len s))
            (if (and (gt n 0) (eq (str-byte-at s (sub n 1)) code))
                (substring s 0 (sub n 1))
                s)))

    (defn fc-strip-eol (s)
        (fc-strip-last-byte-if (fc-strip-last-byte-if s 10) 13))

    (defn fc-string-bytes-loop (s i n acc)
        (if (ge i n) acc
            (fc-string-bytes-loop
                s
                (add i 1)
                n
                (append acc (list (str-byte-at s i))))))

    (defn fc-string-bytes (s)
        (fc-string-bytes-loop s 0 (str_len s) (list)))

    (defn fc-model-cell-digest (bytes)
        (hex-encode (sha256 (fc-string-bytes bytes))))

    (defn fc-metal-model-cell (arg)
        (if (str_eq arg "")
            "usage: metal-model-cell <manifest-path>"
            (do
                (let manifest (fc-strip-eol (read_file arg)))
                (let parts (split-on manifest " "))
                (let kind (fc-part parts 0 ""))
                (let expected-sha (fc-part parts 1 ""))
                (let model-path (fc-part parts 2 ""))
                (let msl-path (fc-part parts 3 ""))
                (let kernel (fc-part parts 4 "form_fkwu_generic_matvec_f32"))
                (if (or (or (str_eq kind "") (str_eq expected-sha ""))
                        (or (str_eq model-path "") (str_eq msl-path "")))
                    "FAIL model-cell manifest expected: model-cell-v1 <sha256> <model-path> <msl-path> <kernel-name>"
                    (if (str_eq kind "model-cell-v1")
                        (do
                            (let model-bytes (read_file model-path))
                            (let actual-sha (fc-model-cell-digest model-bytes))
                            (if (str_eq actual-sha expected-sha)
                                (str_concat "model_cell_verified=true\n"
                                (str_concat "model_cell_source=content-addressed-manifest\n"
                                (str_concat "model_cell_format=f32-matvec-v1\n"
                                (str_concat "model_cell_sha256="
                                (str_concat actual-sha
                                (str_concat "\n"
                                    (metal_matvec_f32 (read_file msl-path) kernel model-bytes)))))))
                                (str_concat "FAIL model-cell sha256 mismatch\nmodel_cell_verified=false\nmodel_cell_expected_sha256="
                                (str_concat expected-sha
                                (str_concat "\nmodel_cell_sha256=" actual-sha)))))
                        (str_concat "FAIL model-cell manifest kind=" kind))))))

    ; the native-only verbs read this binary's own baked source via self_source
    ; (a fkwu-only op), so they live here in the runtime wrapper rather than in
    ; the four-way dispatch: 'source' prints the Form source the binary was built
    ; from; 'verify' reports that the binary carries its own source (self-coherence);
    ; 'diagnose' surfaces the live framebuffer/observability state (see above).
    ; 'metal-fixture' crosses the same fkwu-only door into a linked native
    ; Metal carrier when the proof binary supplies one; otherwise it reports a
    ; skip instead of pretending the bridge exists.
    ; 'metal-matvec' is the generic successor: MSL source bytes, kernel name, and
    ; model bytes cross the same fkwu-native door into a linked carrier.
    ; 'metal-model-cell' proves the model bytes are content-addressed by Form
    ; before the same native Metal carrier sees them. 'gguf-model-cell'
    ; proves the same content address gate for GGUF bytes, then parses tensor
    ; metadata through the GGUF reader shape mirrored inside this fkwu program.
    ; 'gguf-tensor-slice-math' reads one content-addressed real GGUF tensor
    ; byte window and runs Q6_K Form math over that slice. 'gguf-tensor-set-cell'
    ; reads a required-tensor row set from the same full GGUF through fkwu
    ; read_file_slice and verifies each row's content hash in Form.
    ; 'gguf-semantic-token-cell' reads one real tokenizer string row from the
    ; full GGUF, selects a token from manifest logits using Form argmax, and
    ; emits the decoded token text without HTTP/Ollama.
    ; 'gguf-fullwidth-logits-cell' walks the full tokenizer width through
    ; real GGUF token-embedding rows, computes the Q6_K dot4 projection in
    ; Form, then decodes the argmax token.
    ; Everything else routes to fc-respond, the four-way-proven brain.
    (defn fc-native (line)
        (if (str_eq (fc-verb line) "source") (self_source)
            (if (str_eq (fc-verb line) "verify")
                (str_concat "coherent: this binary carries "
                    (str_concat (int_to_str (str_len (self_source)))
                                " bytes of its own Form source (run 'source' to print it); program running native on fkwu."))
                (if (str_eq (fc-verb line) "diagnose") (fc-diagnose)
                        (if (str_eq (fc-verb line) "metal-fixture") (metal_matvec_fixture)
                        (if (str_eq (fc-verb line) "metal-matvec") (fc-metal-matvec (fc-arg line))
                            (if (str_eq (fc-verb line) "metal-model-cell") (fc-metal-model-cell (fc-arg line))
                            (if (str_eq (fc-verb line) "gguf-model-cell") (fc-gguf-model-cell (fc-arg line))
                            (if (str_eq (fc-verb line) "gguf-tensor-set-cell") (fc-gguf-tensor-set-cell (fc-arg line))
                            (if (str_eq (fc-verb line) "gguf-semantic-token-cell") (fc-gguf-semantic-token-cell (fc-arg line))
                            (if (str_eq (fc-verb line) "gguf-fullwidth-logits-cell") (fc-gguf-fullwidth-logits-cell (fc-arg line))
                            (if (str_eq (fc-verb line) "gguf-tensor-slice-math") (fc-gguf-tensor-slice-math (fc-arg line))
                                (fc-respond line)))))))))))))
    ; one self-recursive loop: prompt (only on a real tty), read a line, and
    ; either stop (EOF / quit / exit) or respond and loop. read_line is a stored
    ; let (an effect op) so it fires exactly once per turn, not once per use.
    (defn repl ()
        (do (if (eq (isatty) 2) (print_str "form-cli> ") 0)
            (let line (read_line))
            (if (lt line 0) ""
                (if (str_eq (fc-verb line) "quit") ""
                    (if (str_eq (fc-verb line) "exit") ""
                        (do (print_str (fc-native line))
                            (repl)))))))
    (repl))
