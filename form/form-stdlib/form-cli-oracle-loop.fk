; form-cli-oracle-loop.fk — the LLM-as-oracle-regent loop: every form-cli
; request is answered at least by an LLM oracle, and every request actively
; trains the non-LLM lane. Urs's law, 2026-07-16: "when using form-cli, we
; shall be using an LLM at least as oracle, and to actively learn and improve
; any non-LLM model in answering requests."
;
; The freq-check that shaped this cell: form-cli-judge.fk (fcj-) had ZERO
; callers outside its own band — an office never sat. This cell is fcj-'s
; first live caller, and lineage-discounted-vote's first composition point.
;
; THE LOOP, per request:
;   1. WITNESSES — every available oracle answer arrives as a lineage ballot
;      (answer weight lineage): the agent-cli LLM, any local LLM (ollama lane),
;      each with its earned reliability weight and declared ancestry.
;   2. REFERENCE — ldv-winner fuses them lineage-discounted (kin fold to the
;      strongest kin; independents accumulate): the oracle consensus.
;   3. JUDGE — the native (non-LLM) answer is scored 0..100 for coverage of
;      the reference (the fcj rubric; the score's carrier is a local oracle,
;      exactly as form-cli-judge.fk's header names).
;   4. ROUTE — the native answer is returned ONLY when it is grounded AND
;      judged strong (fcj-grade 3). Otherwise the ORACLE REFERENCE answers:
;      the LLM is the regent — ruling while the native heir is unproven,
;      bound to hand over. Authority flips per proven competition
;      (champion-challenger.fk; fcol-coin is the per-sample trial coin).
;   5. CAPTURE — EVERY request emits a training row (request, reference,
;      native, lane, grade): the oracle/native pair oracle-distill.fk's
;      student trains on. Active learning is unconditional — both lanes
;      teach. (A sibling of training-catalog.fk's tc-entry, not a reuse:
;      tc stores an oracle answer's raw/transmuted forms; this row stores
;      the oracle/native PAIR — different columns answering a different
;      question. Named per the freq-check discipline, not duplicated.)
;
; Honest floor: answers/sigs are opaque strings here; weights are earned
; reliability integers (cw- law); grounded?/judge-score arrive from the live
; lanes (ra-grounded, the judge carrier) — this cell is the routing and
; capture LOGIC, proven four-way; the carriers stay carriers. NOT yet in the
; form-cli build graph: adding it to MODS + FORM_CLI_SRCS and regenerating
; the bootstrap stamp is one atomic maintainer movement (build-form-cli.sh).
;
; preludes: form-stdlib/core.fk form-stdlib/confidence-weighted-vote.fk
; preludes: form-stdlib/lineage-discounted-vote.fk form-stdlib/form-cli-judge.fk

(do
    ; 1. a witness ballot — the ldv shape, named at this door
    (defn fcol-oracle-ballot (answer weight lineage) (ldv-ballot answer weight lineage))

    ; 2. the oracle consensus, lineage-honest
    (defn fcol-reference (ballots candidates) (ldv-winner ballots candidates))
    (defn fcol-reference-trust (ballots candidates) (ldv-score ballots candidates))

    ; 3./4. the route: native answers only grounded AND judged strong;
    ;       otherwise the regent (oracle reference) answers
    (defn fcol-native-strong? (grounded judge-score)
        (if (eq grounded 1) (if (eq (fcj-grade judge-score) 3) 1 0) 0))
    (defn fcol-answer-lane (grounded judge-score)
        (if (eq (fcol-native-strong? grounded judge-score) 1) "form-native" "oracle-regent"))
    (defn fcol-answer (native reference grounded judge-score)
        (if (eq (fcol-native-strong? grounded judge-score) 1) native reference))

    ; the champion-challenger per-sample coin: 1 = the native held this request
    (defn fcol-coin (grounded judge-score) (fcol-native-strong? grounded judge-score))

    ; 5. the unconditional capture — the oracle/native pair, lane, grade
    (defn fcol-capture (request-sig reference-sig native-sig grounded judge-score)
        (list request-sig reference-sig native-sig
              (fcol-answer-lane grounded judge-score)
              (fcj-grade judge-score)))
    (defn fcol-cap-request   (r) (nth r 0))
    (defn fcol-cap-reference (r) (nth r 1))
    (defn fcol-cap-native    (r) (nth r 2))
    (defn fcol-cap-lane      (r) (nth r 3))
    (defn fcol-cap-grade     (r) (nth r 4))

    ; ── self-check ──
    (defn fcolk (cond bit) (if cond bit 0))
    ; grounded + judged strong (80 -> grade 3): the native heir answers
    (defn fcol-heir-holds ()
        (fcolk (and (str_eq (fcol-answer-lane 1 80) "form-native")
                    (str_eq (fcol-answer "n" "r" 1 80) "n")) 1))
    ; grounded but only partial (60 -> grade 2): the regent answers
    (defn fcol-regent-holds ()
        (fcolk (and (str_eq (fcol-answer-lane 1 60) "oracle-regent")
                    (str_eq (fcol-answer "n" "r" 1 60) "r")) 10))
    ; ungrounded, even judged perfect: grounding gates — the regent answers
    (defn fcol-grounding-gates ()
        (fcolk (str_eq (fcol-answer-lane 0 100) "oracle-regent") 100))
    ; the reference is lineage-honest: two kin cannot outvote two independents
    (defn fcol-reference-honest ()
        (fcolk (str_eq (fcol-reference
                           (list (fcol-oracle-ballot "a" 2 "m") (fcol-oracle-ballot "a" 2 "m")
                                 (fcol-oracle-ballot "b" 2 "l") (fcol-oracle-ballot "b" 2 "x"))
                           (list "a" "b")) "b") 1000))
    ; BOTH lanes capture — active learning is unconditional
    (defn fcol-always-learns ()
        (fcolk (and (str_eq (fcol-cap-lane (fcol-capture "q" "r" "n" 1 80)) "form-native")
                    (str_eq (fcol-cap-lane (fcol-capture "q" "r" "n" 1 20)) "oracle-regent")) 10000))
    (defn form-cli-oracle-loop-check ()
        (add (add (add (add (fcol-heir-holds) (fcol-regent-holds)) (fcol-grounding-gates)) (fcol-reference-honest)) (fcol-always-learns)))
)
