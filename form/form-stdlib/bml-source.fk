; bml-source.fk - shared BML source cells.
;
; preludes: form-stdlib/core.fk
;
; This module names BML-shaped source forms before any dialect chooses what
; they mean. A route lowerer can map these cells to KernelHTTPRoute values;
; another domain lowerer can reuse the same source shape differently.

(do
    (defn bml-source-sub (s a b) (substring s a b))
    (defn bml-source-find (s needle i) (str_find s needle i))

    (defn bml-source-rev-into (xs acc)
        (if (eq (len xs) 0) acc
            (bml-source-rev-into (tail xs) (cons (head xs) acc))))

    (defn bml-source-rev (xs)
        (bml-source-rev-into xs (empty)))

    (defn bml-source-space? (ch)
        (or (str_eq ch " ") (or (str_eq ch "\n") (or (str_eq ch "\t") (str_eq ch "\r")))))

    (defn bml-source-skip-spaces (s i)
        (if (ge i (str_len s)) i
            (if (bml-source-space? (char_at s i))
                (bml-source-skip-spaces s (add i 1))
                i)))

    (defn bml-source-rtrim-index (s i)
        (if (le i 0) 0
            (if (bml-source-space? (char_at s (sub i 1)))
                (bml-source-rtrim-index s (sub i 1))
                i)))

    (defn bml-source-trim (s)
        (do
            (let start (bml-source-skip-spaces s 0))
            (let end (bml-source-rtrim-index s (str_len s)))
            (if (ge start end) "" (bml-source-sub s start end))))

    (defn bml-source-last-char-index (s)
        (sub (str_len s) 1))

    (defn bml-source-strip-semi (s)
        (do
            (let value (bml-source-trim s))
            (if (eq (str_len value) 0) value
                (if (str_eq (char_at value (bml-source-last-char-index value)) ";")
                    (bml-source-trim (bml-source-sub value 0 (bml-source-last-char-index value)))
                    value))))

    (defn bml-source-name-list-loop (args i acc)
        (do
            (let p (bml-source-skip-spaces args i))
            (if (ge p (str_len args)) (bml-source-rev acc)
                (do
                    (let comma (bml-source-find args "," p))
                    (let end (if (lt comma 0) (str_len args) comma))
                    (let name (bml-source-trim (bml-source-sub args p end)))
                    (let rest-start (if (lt comma 0) (str_len args) (add comma 1)))
                    (bml-source-name-list-loop args rest-start (cons name acc))))))

    (defn bml-source-name-list (args)
        (bml-source-name-list-loop args 0 (empty)))

    (defn bml-source-split-loop (s sep i acc)
        (do
            (let p (bml-source-skip-spaces s i))
            (if (ge p (str_len s)) (bml-source-rev acc)
                (do
                    (let next (bml-source-find s sep p))
                    (let end (if (lt next 0) (str_len s) next))
                    (let item (bml-source-trim (bml-source-sub s p end)))
                    (let rest-start (if (lt next 0) (str_len s) (add next (str_len sep))))
                    (bml-source-split-loop s sep rest-start (cons item acc))))))

    (defn bml-source-split (s sep)
        (bml-source-split-loop s sep 0 (empty)))

    (defn bml-source-bool (s)
        (str_eq (bml-source-trim s) "true"))

    (defn bml-source-template-use (class-name template-name type-arguments)
        (list "bml-source-template-use" class-name template-name type-arguments))

    (defn bml-source-template-use? (source)
        (if (eq (len source) 4)
            (str_eq (nth source 0) "bml-source-template-use")
            false))

    (defn bml-source-template-use-class-name (source) (nth source 1))
    (defn bml-source-template-use-template-name (source) (nth source 2))
    (defn bml-source-template-use-type-arguments (source) (nth source 3))

    (defn bml-source-parse-template-use (class-name typed-template)
        (do
            (let type-open (bml-source-find typed-template "<" 0))
            (let type-close (bml-source-find typed-template ">" type-open))
            (let template-name (bml-source-trim (bml-source-sub typed-template 0 type-open)))
            (let type-args-text (bml-source-sub typed-template (add type-open 1) type-close))
            (let type-args (bml-source-name-list type-args-text))
            (bml-source-template-use class-name template-name type-args)))

    (defn bml-source-route-call (name args)
        (list "bml-source-route-call" name args))

    (defn bml-source-route-call? (source)
        (if (eq (len source) 3)
            (str_eq (nth source 0) "bml-source-route-call")
            false))

    (defn bml-source-route-call-name (source) (nth source 1))
    (defn bml-source-route-call-args (source) (nth source 2))

    (defn bml-source-route-call-from-expr (expr)
        (do
            (let value (bml-source-strip-semi (bml-source-trim expr)))
            (let route-open (bml-source-find value "(" 0))
            (let route-close (bml-source-last-char-index value))
            (let route-call-name (bml-source-trim (bml-source-sub value 0 route-open)))
            (let route-args (bml-source-sub value (add route-open 1) route-close))
            (bml-source-route-call route-call-name route-args)))

    (defn bml-source-route-call-from-assignment (line)
        (do
            (let value (bml-source-strip-semi line))
            (let eq-pos (bml-source-find value "=" 0))
            (bml-source-route-call-from-expr
                (bml-source-sub value (add eq-pos 1) (str_len value)))))

    (defn bml-source-protocol-row
        (name surface channel capability codec status witness cost)
        (list "bml-source-protocol-row" name surface channel capability codec status witness cost))

    (defn bml-source-protocol-row? (source)
        (if (eq (len source) 9)
            (str_eq (nth source 0) "bml-source-protocol-row")
            false))

    (defn bml-source-protocol-row-name (row) (nth row 1))
    (defn bml-source-protocol-row-surface (row) (nth row 2))
    (defn bml-source-protocol-row-channel (row) (nth row 3))
    (defn bml-source-protocol-row-capability (row) (nth row 4))
    (defn bml-source-protocol-row-codec (row) (nth row 5))
    (defn bml-source-protocol-row-status (row) (nth row 6))
    (defn bml-source-protocol-row-witness (row) (nth row 7))
    (defn bml-source-protocol-row-cost (row) (nth row 8))
    (defn bml-source-protocol-ready? (row)
        (str_eq (bml-source-protocol-row-status row) "ready"))

    (defn bml-source-protocol-row-from-args (args)
        (bml-source-protocol-row
            (nth args 0)
            (nth args 1)
            (nth args 2)
            (nth args 3)
            (nth args 4)
            (nth args 5)
            (nth args 6)
            (str_to_int (nth args 7))))

    (defn bml-source-protocol-row-from-expr (expr)
        (do
            (let value (bml-source-strip-semi (bml-source-trim expr)))
            (let call-open (bml-source-find value "(" 0))
            (let call-close (bml-source-last-char-index value))
            (let call-name (bml-source-trim (bml-source-sub value 0 call-open)))
            (let call-args (bml-source-sub value (add call-open 1) call-close))
            (if (str_eq call-name "protocol")
                (bml-source-protocol-row-from-args (bml-source-split call-args ","))
                (empty))))

    (defn bml-source-protocol-row-from-assignment (line)
        (do
            (let value (bml-source-strip-semi line))
            (let eq-pos (bml-source-find value "=" 0))
            (bml-source-protocol-row-from-expr
                (bml-source-sub value (add eq-pos 1) (str_len value)))))

    (defn bml-source-capability-row
        (name surface channel value-kind trust-floor lane evidence)
        (list "bml-source-capability-row" name surface channel value-kind trust-floor lane evidence))

    (defn bml-source-capability-row? (source)
        (if (eq (len source) 8)
            (str_eq (nth source 0) "bml-source-capability-row")
            false))

    (defn bml-source-capability-row-name (row) (nth row 1))
    (defn bml-source-capability-row-surface (row) (nth row 2))
    (defn bml-source-capability-row-channel (row) (nth row 3))
    (defn bml-source-capability-row-value-kind (row) (nth row 4))
    (defn bml-source-capability-row-trust-floor (row) (nth row 5))
    (defn bml-source-capability-row-lane (row) (nth row 6))
    (defn bml-source-capability-row-evidence (row) (nth row 7))

    (defn bml-source-capability-row-from-args (args)
        (bml-source-capability-row
            (nth args 0)
            (nth args 1)
            (nth args 2)
            (nth args 3)
            (str_to_int (nth args 4))
            (nth args 5)
            (nth args 6)))

    (defn bml-source-capability-row-from-expr (expr)
        (do
            (let value (bml-source-strip-semi (bml-source-trim expr)))
            (let call-open (bml-source-find value "(" 0))
            (let call-close (bml-source-last-char-index value))
            (let call-name (bml-source-trim (bml-source-sub value 0 call-open)))
            (let call-args (bml-source-sub value (add call-open 1) call-close))
            (if (str_eq call-name "capability")
                (bml-source-capability-row-from-args (bml-source-split call-args ","))
                (empty))))

    (defn bml-source-capability-row-from-assignment (line)
        (do
            (let value (bml-source-strip-semi line))
            (let eq-pos (bml-source-find value "=" 0))
            (bml-source-capability-row-from-expr
                (bml-source-sub value (add eq-pos 1) (str_len value)))))

    (defn bml-source-protocol-accepts-capability? (protocol capability)
        (and
            (bml-source-protocol-row? protocol)
            (and
                (bml-source-capability-row? capability)
                (and
                    (str_eq
                        (bml-source-protocol-row-capability protocol)
                        (bml-source-capability-row-name capability))
                    (and
                        (str_eq
                            (bml-source-protocol-row-surface protocol)
                            (bml-source-capability-row-surface capability))
                        (and
                            (str_eq
                                (bml-source-protocol-row-channel protocol)
                                (bml-source-capability-row-channel capability))
                            (bml-source-protocol-ready? protocol)))))))

    (defn bml-source-choice-receipt-row
        (expression surface category candidates selected-path outcome certainty
         value-kind branch-feedback alignment knowing trust why who where
         when-tick cost trace)
        (list "bml-source-choice-receipt-row"
              expression surface category candidates selected-path outcome
              certainty value-kind branch-feedback alignment knowing trust why
              who where when-tick cost trace))

    (defn bml-source-choice-receipt-row? (source)
        (if (eq (len source) 19)
            (str_eq (nth source 0) "bml-source-choice-receipt-row")
            false))

    (defn bml-source-choice-row-expression (row) (nth row 1))
    (defn bml-source-choice-row-surface (row) (nth row 2))
    (defn bml-source-choice-row-category (row) (nth row 3))
    (defn bml-source-choice-row-candidates (row) (nth row 4))
    (defn bml-source-choice-row-selected-path (row) (nth row 5))
    (defn bml-source-choice-row-outcome (row) (nth row 6))
    (defn bml-source-choice-row-certainty (row) (nth row 7))
    (defn bml-source-choice-row-value-kind (row) (nth row 8))
    (defn bml-source-choice-row-branch-feedback (row) (nth row 9))
    (defn bml-source-choice-row-alignment (row) (nth row 10))
    (defn bml-source-choice-row-knowing (row) (nth row 11))
    (defn bml-source-choice-row-trust (row) (nth row 12))
    (defn bml-source-choice-row-why (row) (nth row 13))
    (defn bml-source-choice-row-who (row) (nth row 14))
    (defn bml-source-choice-row-where (row) (nth row 15))
    (defn bml-source-choice-row-when (row) (nth row 16))
    (defn bml-source-choice-row-cost (row) (nth row 17))
    (defn bml-source-choice-row-trace (row) (nth row 18))

    (defn bml-source-choice-candidate (path category eligible pressure score evidence)
        (list "bml-source-choice-candidate" path category eligible pressure score evidence))

    (defn bml-source-choice-candidate? (candidate)
        (if (eq (len candidate) 7)
            (str_eq (nth candidate 0) "bml-source-choice-candidate")
            false))

    (defn bml-source-choice-candidate-path (candidate) (nth candidate 1))
    (defn bml-source-choice-candidate-category (candidate) (nth candidate 2))
    (defn bml-source-choice-candidate-eligible? (candidate) (nth candidate 3))
    (defn bml-source-choice-candidate-pressure (candidate) (nth candidate 4))
    (defn bml-source-choice-candidate-score (candidate) (nth candidate 5))
    (defn bml-source-choice-candidate-evidence (candidate) (nth candidate 6))

    (defn bml-source-choice-candidate-from-text (text)
        (do
            (let parts (bml-source-split text ":"))
            (bml-source-choice-candidate
                (nth parts 0)
                (nth parts 1)
                (bml-source-bool (nth parts 2))
                (str_to_int (nth parts 3))
                (str_to_int (nth parts 4))
                (nth parts 5))))

    (defn bml-source-choice-candidates-from-list (items)
        (if (eq (len items) 0) (empty)
            (cons
                (bml-source-choice-candidate-from-text (head items))
                (bml-source-choice-candidates-from-list (tail items)))))

    (defn bml-source-choice-candidates-from-text (text)
        (bml-source-choice-candidates-from-list (bml-source-split text ";")))

    (defn bml-source-choice-row-from-args (args)
        (bml-source-choice-receipt-row
            (nth args 0)
            (nth args 1)
            (nth args 2)
            (bml-source-choice-candidates-from-text (nth args 3))
            (nth args 4)
            (nth args 5)
            (str_to_int (nth args 6))
            (nth args 7)
            (str_to_int (nth args 8))
            (str_to_int (nth args 9))
            (str_to_int (nth args 10))
            (str_to_int (nth args 11))
            (nth args 12)
            (nth args 13)
            (nth args 14)
            (str_to_int (nth args 15))
            (str_to_int (nth args 16))
            (cr-choice-trace
                (str_to_int (nth args 17))
                (str_to_int (nth args 18))
                (str_to_int (nth args 19))
                (str_to_int (nth args 20)))))

    (defn bml-source-choice-row-from-expr (expr)
        (do
            (let value (bml-source-strip-semi (bml-source-trim expr)))
            (let call-open (bml-source-find value "(" 0))
            (let call-close (bml-source-last-char-index value))
            (let call-name (bml-source-trim (bml-source-sub value 0 call-open)))
            (let call-args (bml-source-sub value (add call-open 1) call-close))
            (if (str_eq call-name "choiceReceipt")
                (bml-source-choice-row-from-args (bml-source-split call-args ","))
                (empty))))

    (defn bml-source-choice-row-value (row)
        (cr-choice-value
            (bml-source-choice-row-value-kind row)
            (bml-source-choice-row-branch-feedback row)
            (bml-source-choice-row-alignment row)
            (bml-source-choice-row-knowing row)
            (bml-source-choice-row-trust row)))

    (defn bml-source-choice-candidate->receipt-candidate (candidate)
        (cr-choice-candidate
            (bml-source-choice-candidate-path candidate)
            (bml-source-choice-candidate-category candidate)
            (bml-source-choice-candidate-eligible? candidate)
            (bml-source-choice-candidate-pressure candidate)
            (bml-source-choice-candidate-score candidate)
            (bml-source-choice-candidate-evidence candidate)))

    (defn bml-source-choice-candidates->receipt-candidates (candidates)
        (if (eq (len candidates) 0) (empty)
            (cons
                (bml-source-choice-candidate->receipt-candidate (head candidates))
                (bml-source-choice-candidates->receipt-candidates (tail candidates)))))

    (defn bml-source-choice-row->receipt (row)
        (cr-choice-receipt
            (bml-source-choice-row-expression row)
            (bml-source-choice-row-surface row)
            (bml-source-choice-row-category row)
            (bml-source-choice-candidates->receipt-candidates
                (bml-source-choice-row-candidates row))
            (bml-source-choice-row-selected-path row)
            (bml-source-choice-row-outcome row)
            (bml-source-choice-row-certainty row)
            (bml-source-choice-row-value row)
            (bml-source-choice-row-why row)
            (bml-source-choice-row-who row)
            (bml-source-choice-row-where row)
            (bml-source-choice-row-when row)
            (bml-source-choice-row-cost row)
            (bml-source-choice-row-trace row)))

    (defn bml-source-choice-score-bucket (score)
        (if (ge score 90) 5
            (if (ge score 80) 4
                (if (ge score 70) 3
                    (if (ge score 50) 2
                        (if (gt score 0) 1 0))))))

    (defn bml-source-choice-pressure-bucket (pressure)
        (if (ge pressure 80) 3
            (if (ge pressure 50) 2
                (if (ge pressure 20) 1 0))))

    (defn bml-source-choice-metadata-signal (candidate)
        (do
            (let signal
                (sub
                    (bml-source-choice-score-bucket
                        (bml-source-choice-candidate-score candidate))
                    (bml-source-choice-pressure-bucket
                        (bml-source-choice-candidate-pressure candidate))))
            (if (gt signal 0) signal 0)))

    (defn bml-source-choice-row->branch-candidate (row candidate)
        (bco-candidate
            (bml-source-choice-candidate-path candidate)
            (bml-source-choice-metadata-signal candidate)
            (bml-source-choice-pressure-bucket
                (bml-source-choice-candidate-pressure candidate))
            0
            0
            (bml-source-choice-row-alignment row)
            (bml-source-choice-row-trust row)))

    (defn bml-source-choice-row->branch-candidates-loop (row candidates)
        (if (eq (len candidates) 0) (empty)
            (cons
                (bml-source-choice-row->branch-candidate row (head candidates))
                (bml-source-choice-row->branch-candidates-loop row (tail candidates)))))

    (defn bml-source-choice-row->branch-candidates (row)
        (bml-source-choice-row->branch-candidates-loop
            row
            (bml-source-choice-row-candidates row)))

    (defn bml-source-choice-row-predicted-path (row)
        (bco-choose-best-path (bml-source-choice-row->branch-candidates row)))

    (defn bml-source-choice-row-trust-matrix-ready? (row threshold)
        (and (ge (bml-source-choice-row-certainty row) threshold)
             (and (ge (bml-source-choice-row-branch-feedback row) threshold)
                  (and (ge (bml-source-choice-row-alignment row) threshold)
                       (and (ge (bml-source-choice-row-knowing row) threshold)
                            (ge (bml-source-choice-row-trust row) threshold))))))

    (defn bml-source-choice-row-escalation-needed? (row threshold)
        (not (bml-source-choice-row-trust-matrix-ready? row threshold)))

    0)
