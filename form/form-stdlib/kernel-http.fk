; kernel-http.fk - HTTP/router value surface (BML-authored, now s-expr native).
;
; preludes: form-stdlib/core.fk
;
; This surface is value-shaped: requests, responses, routes, pressure rows,
; and route candidates are plain Form data with real validation and
; scoring recipes. Kernel adapters can carry these values without owning the
; routing decision.
;
; Ported 2026-07-17 from the BML section dialect to s-expr so the fkwu --src
; door can walk it directly; semantics preserved one-for-one (git history
; carries the BML original).

(let kh_tag_header 43001)
(let kh_tag_request 43002)
(let kh_tag_response 43003)
(let kh_tag_route 43004)
(let kh_tag_pressure_row 43005)
(let kh_tag_route_candidate 43006)
(let kh_tag_route_data_ref 43007)
(let kh_tag_field 43008)
(let kh_tag_route_decision 43009)
(let kh_tag_route_choice 43010)
(let kh_tag_route_decision_signature 43011)
(let kh_tag_route_choice_signature 43012)
(let kh_tag_channel_policy 43013)
(let kh_tag_method_bridge 43014)

(defn kh-bool-score (ok score) (if ok score 0))
(defn kh-tagged? (value tag arity)
    (if (eq (len value) arity) (eq (nth value 0) tag) false))
(defn kh-nonempty-string? (value) (gt (str_len value) 0))
(defn kh-path-valid? (path)
    (if (gt (str_len path) 0) (str_eq (char_at path 0) "/") false))
(defn kh-prefix? (text prefix)
    (if (gt (str_len prefix) (str_len text))
        false
        (str_eq (substring text 0 (str_len prefix)) prefix)))

; HTTP header names are ASCII case-insensitive. Keep the normalization here
; in Form so route-required headers, response finalization, and handler
; helpers all see the same protocol truth without host-side special casing.
(defn kh-ascii-lower-char (c)
    (do
        (let cp (ord c))
        (if (and (ge cp 65) (le cp 90))
            (char_at "abcdefghijklmnopqrstuvwxyz" (sub cp 65))
            c)))
(defn kh-ascii-lower-loop (text i)
    (if (ge i (str_len text))
        ""
        (str_concat (kh-ascii-lower-char (char_at text i))
                    (kh-ascii-lower-loop text (add i 1)))))
(defn kh-ascii-lower (text) (kh-ascii-lower-loop text 0))
(defn kh-str-eq-ci? (left right)
    (str_eq (kh-ascii-lower left) (kh-ascii-lower right)))

(defn kh-list-string-present? (values value)
    (if (nil? values)
        false
        (if (str_eq (head values) value)
            true
            (kh-list-string-present? (tail values) value))))
(defn kh-join-strings (values separator)
    (if (nil? values)
        ""
        (if (nil? (tail values))
            (head values)
            (str_concat (head values)
                        (str_concat separator (kh-join-strings (tail values) separator))))))

(defn kh-method-bridge (route-method request-method pressure)
    (list kh_tag_method_bridge route-method request-method pressure))
(defn kh-method-bridge? (bridge) (kh-tagged? bridge kh_tag_method_bridge 4))
(defn kh-method-bridge-route-method (bridge) (nth bridge 1))
(defn kh-method-bridge-request-method (bridge) (nth bridge 2))
(defn kh-method-bridge-pressure (bridge) (nth bridge 3))
(defn kh-method-bridge-valid? (bridge)
    (if (kh-method-bridge? bridge)
        (and (kh-nonempty-string? (kh-method-bridge-route-method bridge))
             (and (kh-nonempty-string? (kh-method-bridge-request-method bridge))
                  (ge (kh-method-bridge-pressure bridge) 0)))
        false))
(defn kh-method-bridges-valid? (bridges)
    (if (nil? bridges)
        true
        (if (kh-method-bridge-valid? (head bridges))
            (kh-method-bridges-valid? (tail bridges))
            false)))

; Channel policy is the Form-visible protocol invitation and pressure map.
; HTTP is one carrier/protocol value here, not a special host-owned branch.
(defn kh-channel-policy (carrier protocol allowed-methods method-bridges no-body-methods allow-methods cache-policy compression-policy stream-policy identity-policy authorization-policy)
    (list kh_tag_channel_policy carrier protocol allowed-methods method-bridges no-body-methods allow-methods cache-policy compression-policy stream-policy identity-policy authorization-policy))
(defn kh-channel-policy? (policy) (kh-tagged? policy kh_tag_channel_policy 12))
(defn kh-channel-policy-carrier (policy) (nth policy 1))
(defn kh-channel-policy-protocol (policy) (nth policy 2))
(defn kh-channel-policy-allowed-methods (policy) (nth policy 3))
(defn kh-channel-policy-method-bridges (policy) (nth policy 4))
(defn kh-channel-policy-no-body-methods (policy) (nth policy 5))
(defn kh-channel-policy-allow-methods (policy) (nth policy 6))
(defn kh-channel-policy-cache-policy (policy) (nth policy 7))
(defn kh-channel-policy-compression-policy (policy) (nth policy 8))
(defn kh-channel-policy-stream-policy (policy) (nth policy 9))
(defn kh-channel-policy-identity-policy (policy) (nth policy 10))
(defn kh-channel-policy-authorization-policy (policy) (nth policy 11))
(defn kh-channel-policy-valid? (policy)
    (if (kh-channel-policy? policy)
        (and (kh-nonempty-string? (kh-channel-policy-carrier policy))
             (and (kh-nonempty-string? (kh-channel-policy-protocol policy))
                  (kh-method-bridges-valid? (kh-channel-policy-method-bridges policy))))
        false))

(defn kh-default-allowed-methods ()
    (list "GET" "HEAD" "POST" "PUT" "PATCH" "DELETE" "OPTIONS"))
(defn kh-default-channel-policy ()
    (kh-channel-policy
        "tcp"
        "http/1.1"
        (kh-default-allowed-methods)
        (list (kh-method-bridge "GET" "HEAD" 20))
        (list "HEAD")
        (kh-default-allowed-methods)
        "cache-policy-observe"
        "compression-policy-observe"
        "stream-policy-buffered"
        "identity-policy-claim"
        "authorization-policy-capability"))
(defn kh-method-known-with-policy? (policy method)
    (kh-list-string-present? (kh-channel-policy-allowed-methods policy) method))
(defn kh-method-known? (method)
    (kh-method-known-with-policy? (kh-default-channel-policy) method))
(defn kh-route-method-valid-with-policy? (policy method)
    (or (kh-method-known-with-policy? policy method) (str_eq method "ANY")))
(defn kh-route-method-valid? (method)
    (kh-route-method-valid-with-policy? (kh-default-channel-policy) method))
(defn kh-policy-method-bridge-pressure-or (policy route-method request-method fallback)
    (kh-method-bridge-pressure-or (kh-channel-policy-method-bridges policy) route-method request-method fallback))
(defn kh-method-bridge-pressure-or (bridges route-method request-method fallback)
    (if (nil? bridges)
        fallback
        (if (and (kh-method-bridge? (head bridges))
                 (and (str_eq (kh-method-bridge-route-method (head bridges)) route-method)
                      (str_eq (kh-method-bridge-request-method (head bridges)) request-method)))
            (kh-method-bridge-pressure (head bridges))
            (kh-method-bridge-pressure-or (tail bridges) route-method request-method fallback))))
(defn kh-policy-no-body-method? (policy method)
    (kh-list-string-present? (kh-channel-policy-no-body-methods policy) method))
(defn kh-policy-allow-header-value (policy)
    (kh-join-strings (kh-channel-policy-allow-methods policy) ", "))

(defn kh-header (name value) (list kh_tag_header name value))
(defn kh-header? (header) (kh-tagged? header kh_tag_header 3))
(defn kh-header-name (header) (nth header 1))
(defn kh-header-value (header) (nth header 2))
(defn kh-headers-valid? (headers)
    (if (nil? headers)
        true
        (if (kh-header? (head headers))
            (kh-headers-valid? (tail headers))
            false)))
(defn kh-header-present? (headers name)
    (if (nil? headers)
        false
        (if (kh-str-eq-ci? (kh-header-name (head headers)) name)
            true
            (kh-header-present? (tail headers) name))))
(defn kh-header-value-or (headers name default-value)
    (if (nil? headers)
        default-value
        (if (kh-str-eq-ci? (kh-header-name (head headers)) name)
            (kh-header-value (head headers))
            (kh-header-value-or (tail headers) name default-value))))
(defn kh-header-observation (headers name)
    (if (str_eq name "")
        "not-required"
        (if (kh-header-present? headers name) "present" "missing")))

(defn kh-field (name value) (list kh_tag_field name value))
(defn kh-field? (field) (kh-tagged? field kh_tag_field 3))
(defn kh-field-name (field) (nth field 1))
(defn kh-field-value (field) (nth field 2))
(defn kh-fields-valid? (fields)
    (if (nil? fields)
        true
        (if (kh-field? (head fields))
            (kh-fields-valid? (tail fields))
            false)))
(defn kh-field-present? (fields name)
    (if (nil? fields)
        false
        (if (str_eq (kh-field-name (head fields)) name)
            true
            (kh-field-present? (tail fields) name))))
(defn kh-field-value-or (fields name default-value)
    (if (nil? fields)
        default-value
        (if (str_eq (kh-field-name (head fields)) name)
            (kh-field-value (head fields))
            (kh-field-value-or (tail fields) name default-value))))
(defn kh-field-int-or (fields name default-value)
    (do
        (let raw (kh-field-value-or fields name ""))
        (if (str_eq raw "") default-value (str_to_int raw))))
(defn kh-field-bool-or (fields name default-value)
    (do
        (let raw (kh-field-value-or fields name ""))
        (if (str_eq raw "")
            default-value
            (or (str_eq raw "true") (str_eq raw "1")))))

(defn kh-request (method path headers query body)
    (list kh_tag_request method path headers query body))
(defn kh-request? (request) (kh-tagged? request kh_tag_request 6))
(defn kh-request-method (request) (nth request 1))
(defn kh-request-path (request) (nth request 2))
(defn kh-request-headers (request) (nth request 3))
(defn kh-request-query (request) (nth request 4))
(defn kh-request-body (request) (nth request 5))
(defn kh-request-valid-with-policy? (policy request)
    (if (kh-request? request)
        (and (kh-method-known-with-policy? policy (kh-request-method request))
             (and (kh-path-valid? (kh-request-path request))
                  (and (kh-headers-valid? (kh-request-headers request))
                       (kh-fields-valid? (kh-request-query request)))))
        false))
(defn kh-request-valid? (request)
    (kh-request-valid-with-policy? (kh-default-channel-policy) request))
(defn kh-query-value-or (request name default-value)
    (kh-field-value-or (kh-request-query request) name default-value))
(defn kh-query-int-or (request name default-value)
    (kh-field-int-or (kh-request-query request) name default-value))
(defn kh-query-bool-or (request name default-value)
    (kh-field-bool-or (kh-request-query request) name default-value))

(defn kh-response (status headers body) (list kh_tag_response status headers body))
(defn kh-response? (response) (kh-tagged? response kh_tag_response 4))
(defn kh-response-status (response) (nth response 1))
(defn kh-response-headers (response) (nth response 2))
(defn kh-response-body (response) (nth response 3))
(defn kh-response-valid? (response)
    (if (kh-response? response)
        (and (ge (kh-response-status response) 100)
             (and (le (kh-response-status response) 599)
                  (kh-headers-valid? (kh-response-headers response))))
        false))

(defn kh-route (name method pattern priority handler required-header pressure-budget)
    (list kh_tag_route name method pattern priority handler required-header pressure-budget))
(defn kh-route? (route) (kh-tagged? route kh_tag_route 8))
(defn kh-route-name (route) (nth route 1))
(defn kh-route-method (route) (nth route 2))
(defn kh-route-pattern (route) (nth route 3))
(defn kh-route-priority (route) (nth route 4))
(defn kh-route-handler (route) (nth route 5))
(defn kh-route-required-header (route) (nth route 6))
(defn kh-route-pressure-budget (route) (nth route 7))
(defn kh-route-valid-with-policy? (policy route)
    (if (kh-route? route)
        (and (kh-route-method-valid-with-policy? policy (kh-route-method route))
             (and (kh-path-valid? (kh-route-pattern route))
                  (and (ge (kh-route-priority route) 0)
                       (and (kh-nonempty-string? (kh-route-handler route))
                            (ge (kh-route-pressure-budget route) 0)))))
        false))
(defn kh-route-valid? (route)
    (kh-route-valid-with-policy? (kh-default-channel-policy) route))

(defn kh-route-data-ref (route-id handler) (list kh_tag_route_data_ref route-id handler))
(defn kh-route-data-ref? (ref) (kh-tagged? ref kh_tag_route_data_ref 3))
(defn kh-route-data-ref-id (ref) (nth ref 1))
(defn kh-route-data-ref-handler (ref) (nth ref 2))
(defn kh-route-data-ref-valid? (ref)
    (if (kh-route-data-ref? ref) (kh-nonempty-string? (kh-route-data-ref-id ref)) false))

(defn kh-pattern-wildcard? (pattern)
    (if (gt (str_len pattern) 0)
        (str_eq (char_at pattern (sub (str_len pattern) 1)) "*")
        false))
(defn kh-pattern-prefix (pattern)
    (if (kh-pattern-wildcard? pattern)
        (substring pattern 0 (sub (str_len pattern) 1))
        pattern))
(defn kh-head-through-get? (route request)
    (and (str_eq (kh-route-method route) "GET")
         (str_eq (kh-request-method request) "HEAD")))
(defn kh-head-through-get-with-policy? (policy route request)
    (lt (kh-policy-method-bridge-pressure-or policy (kh-route-method route) (kh-request-method request) 400) 400))
(defn kh-method-pressure-with-policy (policy route request)
    (do
        (let bridge-pressure (kh-policy-method-bridge-pressure-or policy (kh-route-method route) (kh-request-method request) 400))
        (if (str_eq (kh-route-method route) (kh-request-method request))
            0
            (if (lt bridge-pressure 400)
                bridge-pressure
                (if (str_eq (kh-route-method route) "ANY") 40 400)))))
(defn kh-method-pressure (route request)
    (kh-method-pressure-with-policy (kh-default-channel-policy) route request))
(defn kh-path-pressure (route request)
    (if (str_eq (kh-route-pattern route) (kh-request-path request))
        0
        (if (and (kh-pattern-wildcard? (kh-route-pattern route))
                 (kh-prefix? (kh-request-path request) (kh-pattern-prefix (kh-route-pattern route))))
            25
            500)))
(defn kh-header-pressure (route request)
    (if (str_eq (kh-route-required-header route) "")
        0
        (if (kh-header-present? (kh-request-headers request) (kh-route-required-header route))
            0
            120)))
(defn kh-budget-pressure (total budget)
    (if (le total budget) 0 (sub total budget)))

(defn kh-pressure-row (axis observed expected pressure)
    (list kh_tag_pressure_row axis observed expected pressure))
(defn kh-pressure-row? (row) (kh-tagged? row kh_tag_pressure_row 5))
(defn kh-pressure-row-axis (row) (nth row 1))
(defn kh-pressure-row-observed (row) (nth row 2))
(defn kh-pressure-row-expected (row) (nth row 3))
(defn kh-pressure-row-pressure (row) (nth row 4))
(defn kh-pressure-matrix-total (matrix)
    (if (nil? matrix)
        0
        (add (kh-pressure-row-pressure (head matrix))
             (kh-pressure-matrix-total (tail matrix)))))

(defn kh-candidate-pressure-matrix-with-policy (policy route request)
    (do
        (let method-pressure (kh-method-pressure-with-policy policy route request))
        (let path-pressure (kh-path-pressure route request))
        (let header-pressure (kh-header-pressure route request))
        (let base-pressure (sum (list method-pressure path-pressure header-pressure)))
        (let budget-pressure (kh-budget-pressure base-pressure (kh-route-pressure-budget route)))
        (list
            (kh-pressure-row "method" (kh-request-method request) (kh-route-method route) method-pressure)
            (kh-pressure-row "path" (kh-request-path request) (kh-route-pattern route) path-pressure)
            (kh-pressure-row "header" (kh-header-observation (kh-request-headers request) (kh-route-required-header route)) (kh-route-required-header route) header-pressure)
            (kh-pressure-row "budget" base-pressure (kh-route-pressure-budget route) budget-pressure))))
(defn kh-candidate-pressure-matrix (route request)
    (kh-candidate-pressure-matrix-with-policy (kh-default-channel-policy) route request))

(defn kh-candidate-score-from (route pressure)
    (sub (add 1000 (mul (kh-route-priority route) 10)) pressure))
(defn kh-route-candidate-with-policy (policy route request)
    (do
        (let matrix (kh-candidate-pressure-matrix-with-policy policy route request))
        (let pressure (kh-pressure-matrix-total matrix))
        (list kh_tag_route_candidate route request matrix pressure (kh-candidate-score-from route pressure))))
(defn kh-route-candidate (route request)
    (kh-route-candidate-with-policy (kh-default-channel-policy) route request))
(defn kh-route-candidate? (candidate) (kh-tagged? candidate kh_tag_route_candidate 6))
(defn kh-route-candidate-route (candidate) (nth candidate 1))
(defn kh-route-candidate-request (candidate) (nth candidate 2))
(defn kh-route-candidate-matrix (candidate) (nth candidate 3))
(defn kh-route-candidate-pressure (candidate) (nth candidate 4))
(defn kh-route-candidate-score (candidate) (nth candidate 5))
(defn kh-route-candidate-valid? (candidate)
    (if (kh-route-candidate? candidate)
        (and (kh-route-valid? (kh-route-candidate-route candidate))
             (and (kh-request-valid? (kh-route-candidate-request candidate))
                  (and (eq (kh-route-candidate-pressure candidate)
                           (kh-pressure-matrix-total (kh-route-candidate-matrix candidate)))
                       (eq (kh-route-candidate-score candidate)
                           (kh-candidate-score-from (kh-route-candidate-route candidate) (kh-route-candidate-pressure candidate))))))
        false))

(defn kh-route-candidate-eligible? (candidate)
    (if (kh-route-candidate? candidate)
        (le (kh-route-candidate-pressure candidate)
            (kh-route-pressure-budget (kh-route-candidate-route candidate)))
        false))
(defn kh-route-candidates-with-policy (policy routes request)
    (if (nil? routes)
        (empty)
        (cons (kh-route-candidate-with-policy policy (head routes) request)
              (kh-route-candidates-with-policy policy (tail routes) request))))
(defn kh-route-candidates (routes request)
    (kh-route-candidates-with-policy (kh-default-channel-policy) routes request))
(defn kh-keep-eligible-candidate (candidate rest)
    (if (kh-route-candidate-eligible? candidate) (cons candidate rest) rest))
(defn kh-eligible-candidates (candidates)
    (if (nil? candidates)
        (empty)
        (kh-keep-eligible-candidate (head candidates) (kh-eligible-candidates (tail candidates)))))
(defn kh-route-eligible-candidates-with-policy (policy routes request)
    (kh-eligible-candidates (kh-route-candidates-with-policy policy routes request)))
(defn kh-route-eligible-candidates (routes request)
    (kh-route-eligible-candidates-with-policy (kh-default-channel-policy) routes request))
(defn kh-route-same? (left right)
    (if (kh-route? left)
        (if (kh-route? right)
            (and (str_eq (kh-route-name left) (kh-route-name right))
                 (and (str_eq (kh-route-method left) (kh-route-method right))
                      (and (str_eq (kh-route-pattern left) (kh-route-pattern right))
                           (and (eq (kh-route-priority left) (kh-route-priority right))
                                (and (str_eq (kh-route-handler left) (kh-route-handler right))
                                     (and (str_eq (kh-route-required-header left) (kh-route-required-header right))
                                          (eq (kh-route-pressure-budget left) (kh-route-pressure-budget right))))))))
            false)
        false))
(defn kh-route-candidate-same? (left right)
    (if (kh-route-candidate? left)
        (if (kh-route-candidate? right)
            (and (kh-route-same? (kh-route-candidate-route left) (kh-route-candidate-route right))
                 (and (eq (kh-route-candidate-pressure left) (kh-route-candidate-pressure right))
                      (eq (kh-route-candidate-score left) (kh-route-candidate-score right))))
            false)
        false))
(defn kh-better-candidate (left right)
    (if (gt (kh-route-candidate-score left) (kh-route-candidate-score right))
        left
        (if (eq (kh-route-candidate-score left) (kh-route-candidate-score right))
            (if (ge (kh-route-priority (kh-route-candidate-route left))
                    (kh-route-priority (kh-route-candidate-route right)))
                left
                right)
            right)))
(defn kh-select-route-candidate-loop (candidates best)
    (if (nil? candidates)
        best
        (kh-select-route-candidate-loop (tail candidates) (kh-better-candidate best (head candidates)))))
(defn kh-select-route-candidate (candidates)
    (if (nil? candidates)
        (empty)
        (kh-select-route-candidate-loop (tail candidates) (head candidates))))
(defn kh-route-decision (candidate eligible selected)
    (list kh_tag_route_decision candidate eligible selected))
(defn kh-route-decision? (decision) (kh-tagged? decision kh_tag_route_decision 4))
(defn kh-route-decision-candidate (decision) (nth decision 1))
(defn kh-route-decision-eligible? (decision) (nth decision 2))
(defn kh-route-decision-selected? (decision) (nth decision 3))
(defn kh-route-decision-valid? (decision)
    (if (kh-route-decision? decision)
        (kh-route-candidate-valid? (kh-route-decision-candidate decision))
        false))
(defn kh-route-decisions (candidates selected)
    (if (nil? candidates)
        (empty)
        (cons (kh-route-decision (head candidates)
                                 (kh-route-candidate-eligible? (head candidates))
                                 (kh-route-candidate-same? (head candidates) selected))
              (kh-route-decisions (tail candidates) selected))))
(defn kh-route-decisions-valid? (decisions)
    (if (nil? decisions)
        true
        (if (kh-route-decision-valid? (head decisions))
            (kh-route-decisions-valid? (tail decisions))
            false)))

; Fixed, data-oblivious buckets for route-choice attention. This borrows the
; TurboQuant teaching: compression remains content-addressable only when the
; quantizer is universal, not trained from the current route corpus.
(defn kh-pressure-bucket (pressure)
    (if (eq pressure 0) 0
        (if (le pressure 25) 1
            (if (le pressure 120) 2
                (if (le pressure 400) 3
                    (if (le pressure 500) 4 5))))))
(defn kh-score-bucket (score)
    (if (lt score 0) 0
        (if (lt score 500) 1
            (if (lt score 900) 2
                (if (lt score 1000) 3
                    (if (lt score 1100) 4 5))))))
(defn kh-pressure-code (row)
    (list (kh-pressure-row-axis row) (kh-pressure-bucket (kh-pressure-row-pressure row))))
(defn kh-pressure-codes (matrix)
    (if (nil? matrix)
        (empty)
        (cons (kh-pressure-code (head matrix)) (kh-pressure-codes (tail matrix)))))
(defn kh-route-decision-signature (decision)
    (do
        (let candidate (kh-route-decision-candidate decision))
        (let route (kh-route-candidate-route candidate))
        (list
            kh_tag_route_decision_signature
            (kh-route-name route)
            (kh-route-handler route)
            (kh-pressure-codes (kh-route-candidate-matrix candidate))
            (kh-pressure-bucket (kh-route-candidate-pressure candidate))
            (kh-score-bucket (kh-route-candidate-score candidate))
            (kh-route-decision-eligible? decision)
            (kh-route-decision-selected? decision))))
(defn kh-route-decision-signature? (signature)
    (kh-tagged? signature kh_tag_route_decision_signature 8))
(defn kh-route-decision-signature-codes (signature) (nth signature 3))
(defn kh-route-decision-signature-pressure-bucket (signature) (nth signature 4))
(defn kh-route-decision-signature-score-bucket (signature) (nth signature 5))
(defn kh-route-decision-signature-eligible? (signature) (nth signature 6))
(defn kh-route-decision-signature-selected? (signature) (nth signature 7))
(defn kh-route-decision-signatures (decisions)
    (if (nil? decisions)
        (empty)
        (cons (kh-route-decision-signature (head decisions))
              (kh-route-decision-signatures (tail decisions)))))

(defn kh-route-choice (request candidates decisions selected)
    (list kh_tag_route_choice request candidates decisions selected))
(defn kh-route-choice? (choice) (kh-tagged? choice kh_tag_route_choice 5))
(defn kh-route-choice-request (choice) (nth choice 1))
(defn kh-route-choice-candidates (choice) (nth choice 2))
(defn kh-route-choice-decisions (choice) (nth choice 3))
(defn kh-route-choice-selected (choice) (nth choice 4))
(defn kh-route-choice-valid? (choice)
    (if (kh-route-choice? choice)
        (and (kh-request-valid? (kh-route-choice-request choice))
             (and (eq (len (kh-route-choice-candidates choice))
                      (len (kh-route-choice-decisions choice)))
                  (kh-route-decisions-valid? (kh-route-choice-decisions choice))))
        false))
(defn kh-route-choice-signature (choice)
    (list kh_tag_route_choice_signature
          (kh-request-method (kh-route-choice-request choice))
          (kh-request-path (kh-route-choice-request choice))
          (kh-route-decision-signatures (kh-route-choice-decisions choice))))
(defn kh-route-choice-signature? (signature)
    (kh-tagged? signature kh_tag_route_choice_signature 4))
(defn kh-route-choice-signature-decision-signatures (signature) (nth signature 3))
(defn kh-route-choice-for-request-with-policy (policy routes request)
    (do
        (let candidates (kh-route-candidates-with-policy policy routes request))
        (let selected (kh-select-route-candidate (kh-eligible-candidates candidates)))
        (kh-route-choice request candidates (kh-route-decisions candidates selected) selected)))
(defn kh-route-choice-for-request (routes request)
    (kh-route-choice-for-request-with-policy (kh-default-channel-policy) routes request))
(defn kh-select-route-candidate-for-request-with-policy (policy routes request)
    (kh-route-choice-selected (kh-route-choice-for-request-with-policy policy routes request)))
(defn kh-select-route-candidate-for-request (routes request)
    (kh-route-choice-selected (kh-route-choice-for-request routes request)))
(defn kh-select-route-score (routes request)
    (do
        (let selected (kh-select-route-candidate-for-request routes request))
        (if (nil? selected) 0 (kh-route-candidate-score selected))))

0
