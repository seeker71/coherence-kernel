; rag-heal-shell.fk — merge-hook RAG heal as a form-shell cell (native on fkwu).
;
; The merge hook and agents call `form/scripts/rag-heal.sh`, which stages a
; one-line fsh script (`rag-heal <index-path>`) into fk_src and runs
; fsh-rag-heal-main.fk on fkwu — OR flattens this gate directly when fsh is
; not yet built. The heal DECISION (delta vs cold, which corpus) lives in
; rag-heal.fk's rh-heal-merge; this cell names the shell surface.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/shell-exec.fk form-stdlib/shell-lower.fk form-stdlib/adler32.fk form-stdlib/rag-key.fk form-stdlib/rag-freshness.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk form-stdlib/rag-index-codec.fk form-stdlib/rag-heal.fk

(do
    ; default index path — callers pass an explicit path; this names the convention.
    (defn rh-default-index () ".coherence-network/rag-index/index.jsonl")

    ; native gate: run the sovereign lexical heal over the full merge corpus.
    (defn rh-shell-heal (index-path repo-root)
        (do (rh-heal-merge-at index-path repo-root) 0))

    ; the fsh script shape the merge hook stages (two words: index + repo root).
    (defn rh-fsh-source (index-path repo-root)
        (str_concat "rag-heal "
            (str_concat index-path (str_concat " " repo-root))))

    (defn rh-fsh-cell (index-path repo-root) (sh-lower "rag-heal" (rh-fsh-source index-path repo-root)))
    (defn rh-fsh-plan (index-path repo-root) (sh-plan (sh-cell-ctor (rh-fsh-cell index-path repo-root))))

    0)
