; form-flatten.fk — m4e3's real-recipe flattener (path-b, the cursor lane):
; reads a REAL stdlib band's Form SOURCE (module file + band file, unmodified)
; and flattens it into a Hati-OS kernel program. defn becomes a function-table
; row (CALL by index, fn 0 = the band's verdict expression), module lets inline
; pure value cells, effecting nested do-lets and band top-level lets snapshot
; once through RAM slots, and the curated band vocabulary lowers onto
; the walker's op set: gt/ge/eq/and become IF/LE shapes; head/tail/len/nth/
; cons/list/empty map 1:1 to the arena tags 18..23. The output is program-as-
; cells — fkc-table-file serializes it and the universal fkw binary runs the
; band through the fs port: the Hati-OS arm's band ratchet.
;
; Builds on form-parse.fk (the expression stone: a cursor over the source
; string, no tokenizer — the BMF discipline). Multi-param defns ride PACKED
; ARGS (m4e4): an N-arg call right-folds its arguments into a CONS chain on
; the arena, the callee's params bind as NTH(ARG, i) by position — a pure
; flattening rule over the existing op set, no new walker tags. Single-param
; calls stay direct ARG (no allocation); zero-param packs EMPTY. Nested
; (do ...) is an EXPRESSION (m4e5): effecting lets bind once for the rest of the do,
; the last expression is the value — let-in-defn and do-in-do flatten by
; the same structural recursion as the top level. Integer literals may be
; negative; true/false flatten as 1/0; div/mod and the figure-ops family
; (band/bor/bxor/shl_u32/shr_u32/rotr_u32/add_u32/bnot_u32/mul, tags 34..42)
; are vocabulary rows — the checksum bands' unlock. Scope held honestly:
; PURE bands — defn bodies that see only their params + do-lets, top-level
; lets, one verdict expression. eq/and lowering and let-inlining re-evaluate
; pure operands. Non-recursive direct-call do-lets snapshot once through
; per-function RAM windows, so list-returning calls can be read more than once
; without re-walking. Packed args ride the emitted walker's VALUE STACK
; (hati-os-kernel-emit.fk: ARG reads fk_vs[fp], the melt roots and
; relocates every stack slot), so band-scale allocation melts safely
; mid-call — feature-vector's crossing is the witness (audit section 24).
; The str_* family rides the walker string-pool lane (tags 24..28): a
; pre-pass (flt-scan) interns every distinct "literal" into the program's
; pool — same bytes, same slot — and a literal lowers to SLIT carrying its
; pool index; the string family now carries str_eq/str_len/str_concat plus
; substring/str_find/str_to_int/int_to_str/byte_to_str. The explicit NodeID
; door carries make_nodeid/category/pkg/level/type/inst. Literal bp calls for
; the current fourth-floor registry names fold onto make_nodeid packets; the
; full generated bp table remains a follow-on lift.
;
; Native carrier floor: socket_listen/connect/accept/send/recv/close lower to
; tags 120..126 as the host-OS socket boundary. http_get/sock_request remain
; compatibility carriers above that floor; HTTP verbs belong in Form recipes
; over socket bytes, not as the primitive substrate. _get lowers to tag 106 so
; source recipes can read returned dict/list receipts inside fkwu.

; ── walker-carried ops as DATA rows (name arity tag) — one generic engine ──
; (div/mod ride the m4d tags 10/11; the figure-ops family rides 34..42 —
;  the bitwise-u32 + mul vocabulary the checksum bands need)
(defn flt-ops ()
    ; GENERATED: flt-ops body from native-op-manifest.fk — do not hand-edit
    (list (list "add" 2 3) (list "sub" 2 4) (list "le" 2 5) (list "cons" 2 19) (list "nth" 2 23)
          (list "head" 1 20)(list "tail" 1 21) (list "len" 1 22) (list "_plus" 2 3)
          (list "str_len" 1 25)(list "str_eq" 2 26) (list "str_concat" 2 27)
          (list "str_byte_at" 2 28)(list "substring" 3 29) (list "str_find" 3 30)
          (list "str_to_int" 1 31)(list "int_to_str" 1 32) (list "byte_to_str" 1 33)
          (list "input_byte" 1 17)(list "read_line" 0 114) (list "print_str" 1 115)
          (list "isatty" 0 116)(list "self_source" 0 117) (list "kernel_stat" 1 127)
          (list "fb_record" 3 128)(list "framebuffer-events" 0 129) (list "node_source" 1 130)
          (list "framebuffer-clear" 0 131)(list "intern_trivial_int" 1 43)
          (list "intern_trivial_bool" 1 112)(list "intern_trivial_float" 1 113)
          (list "make_nodeid" 4 91)(list "bp" 1 45) (list "intern_trivial_string" 1 46)
          (list "intern_node" 2 47)(list "node_children" 1 48) (list "node_value" 1 49)
          (list "node_category" 1 92)(list "node_type" 1 93) (list "node_inst" 1 94)
          (list "node_pkg" 1 95)(list "node_level" 1 96) (list "node_eq" 2 80)
          (list "value_eq" 2 80)(list "math_floor" 1 51) (list "floor" 1 51)
          (list "round_ndigits" 2 52)(list "str_to_float" 1 53) (list "float_to_int" 1 54)
          (list "math_sqrt" 1 81)(list "trunc" 1 82) (list "jit_compile_value" 1 83)
          (list "dot_product" 2 84)(list "magnitude" 1 85) (list "vector_cosine" 2 86)
          (list "round" 1 87)(list "ceil" 1 88) (list "math_ceil" 1 88) (list "math_exp" 1 89)
          (list "math_log" 1 90)(list "fs_rmdir" 1 55) (list "fs_mkdir" 1 56)
          (list "fs_exists" 1 57)(list "fs_remove" 1 58) (list "fs_rename" 2 59)
          (list "file_size" 1 60)(list "file_append_bytes" 2 61) (list "read_file_slice" 3 62)
          (list "read_file" 1 63)(list "temp_dir" 0 101) (list "write_file_text" 2 104)
          (list "fs_list" 1 132)(list "fs_is_dir" 1 200) (list "source_inventory" 3 202)
          (list "metal_matvec_fixture" 0 203)(list "metal_matvec_f32" 3 204)
          (list "file_open" 1 133)(list "file_read" 2 134) (list "file_close" 1 135)
          (list "http_get" 3 105)(list "sock_request" 3 118) (list "tls_request" 3 119)
          (list "socket_listen" 1 120)(list "socket_port" 1 121) (list "socket_accept" 1 122)
          (list "socket_connect" 2 123)(list "socket_send" 2 124) (list "socket_recv" 2 125)
          (list "socket_close" 1 126)(list "_get" 2 106) (list "file_mtime" 1 107)
          (list "scan_run" 3 108)(list "record_get" 2 65) (list "record_set" 3 66)
          (list "record_has" 2 67)(list "record?" 1 68) (list "record_keys" 1 99)
          (list "record_blueprint" 1 100)(list "div" 2 10) (list "mod" 2 11) (list "band" 2 34)
          (list "bor" 2 35)(list "bxor" 2 36) (list "shl_u32" 2 37) (list "shr_u32" 2 38)
          (list "rotr_u32" 2 39)(list "add_u32" 2 40) (list "bnot_u32" 1 41) (list "mul" 2 42)))

(defn flt-assoc (name rows)
    (if (eq (len rows) 0) (list)
        (if (str_eq (nth (head rows) 0) name) (head rows)
            (flt-assoc name (tail rows)))))

(defn flt-recq () "(defn-recursive)")
(defn flt-fidxq () "(defn-index)")
(defn flt-env-row-value (row dflt) (if (eq (len row) 0) dflt (nth row 1)))
(defn flt-current-recursive (env) (flt-env-row-value (flt-assoc (flt-recq) env) 0))
(defn flt-current-fidx (env) (flt-env-row-value (flt-assoc (flt-fidxq) env) 0))
(defn flt-slot (env) (fk-lit (add 128 (add (mul (flt-current-fidx env) 32) (len env)))))

; ── recursion-safe let binding on a RESERVED per-call frame block ──
; A stored let lives at fk_vs[fp+offset] in a block the function reserves at
; entry (RESERVE), so argument-packing scratch lands ABOVE the block and can
; never shift a frame let's slot. Each call gets its own fp, so a recursive
; re-entry reserves its own block — the deepest frame cannot clobber an outer
; binding. ARG is offset 0; the k-th frame let is offset k = letdepth+1.
(defn flt-letdepth-q () "(defn-letdepth)")
(defn flt-current-letdepth (env) (flt-env-row-value (flt-assoc (flt-letdepth-q) env) 0))
(defn fk-farg (off) (fk-node 110 (fk-lit off)))
(defn fk-letf (off value body) (fk-node 109 (ms-intern (fk-lit off) (ms-intern value body))))
(defn fk-reserve (k body) (fk-node 111 (ms-intern (fk-lit k) body)))
; K = how many frame slots a function reserves. We count "(let " occurrences in
; the function's SOURCE span — a linear, robust upper bound on the max frame-let
; offset (sequential do-lets take incrementing offsets, so the deepest chain's
; let count bounds it; inline/branch lets only over-reserve, never under). This
; replaces a recipe-tree walk that crashed (as_nid: null) on source-compiled
; module recipes. Over-reserving is safe: the slots cost value-stack space only.
(defn flt-count-lets (s pos end) (flt-count-lets-go s (str_find s "(let " pos) end 0))
(defn flt-count-lets-go (s found end acc)
    (if (lt found 0) acc
        (if (ge found end) acc
            (flt-count-lets-go s (str_find s "(let " (add found 5)) end (add acc 1)))))
(defn flt-reserve-wrap-k (k body) (if (eq k 0) body (fk-reserve k body)))

(defn flt-mkop (row a b)
    (if (eq (nth row 1) 1) (fk-node (nth row 2) a)
        (fk-node (nth row 2) (ms-intern a b))))

; ── the curated comparisons, lowered onto LE/IF (the compiler's vocabulary;
;    the band file itself stays unmodified) ────────────────────────────────
(defn flt-gt (a b) (fk-if (fk-le a b) (fk-lit 0) (fk-lit 1)))
(defn flt-ge (a b) (fk-le b a))
; eq/lt are native single-walk walker arms (tags 102/103): each operand is
; evaluated exactly once, matching le (tag 5) and the reference kernels. The
; old (le a b)&&(le b a) lowering walked each operand twice — re-firing side
; effects and doubling the operand sub-tree in the table.
(defn flt-lt (a b) (fk-node 103 (ms-intern a b)))
(defn flt-eq (a b) (fk-node 102 (ms-intern a b)))
(defn flt-and (a b) (fk-if a (fk-if b (fk-lit 1) (fk-lit 0)) (fk-lit 0)))
(defn flt-or (a b) (fk-if a (fk-lit 1) (fk-if b (fk-lit 1) (fk-lit 0))))
; unary lowerings: ord rides SCHAR at byte 0; not is the IF flip
(defn flt-ord (a) (fk-schar a (fk-lit 0)))
(defn flt-not (a) (fk-if a (fk-lit 0) (fk-lit 1)))
(defn flt-sequence (a b) (fk-node 69 (ms-intern a b)))

; ── words off the cursor ───────────────────────────────────────────────────
(defn flt-word (s pos) (substring s pos (fp-sym-end s pos)))

; head word of a parenthesized form at pos ("" when the item is an atom)
(defn flt-peek (s pos)
    (if (ge pos (fp-len s)) ""
        (if (eq (fp-at s pos) 40) (flt-word s (fp-skip s (add pos 1))) "")))

; ── expressions (env-aware; (cell end-pos) pairs, the fp-* discipline) ─────
(defn flt-expr (s pos fns env) (flt-expr2 s (fp-skip s pos) fns env))
(defn flt-expr2 (s pos fns env)
    (if (eq (fp-at s pos) 40) (flt-form s (fp-skip s (add pos 1)) fns env)
        (if (eq (fp-at s pos) 34) (flt-str s (add pos 1) env)
            (if (fp-isdigit (fp-at s pos)) (flt-num s pos env)
                (if (and (eq (fp-at s pos) 45) (fp-isdigit (fp-at s (add pos 1))))
                    (flt-neg-num s pos env)
                    (flt-var s pos env fns))))))

; a '-' immediately before digits is a negative integer literal
(defn flt-neg (ve) (list (fk-lit (sub 0 (nth ve 0))) (nth ve 1)))
(defn flt-num (s pos env) (flt-num2 s pos (fp-digits s pos 0) env))
; a bare integer mantissa followed by a valid exponent (1e-05, no decimal point —
; Python repr's shape) is still a float; flt-fe-exp returns >ie only for a valid exponent.
(defn flt-has-exp (s ie)
    (if (and (lt ie (fp-len s)) (or (eq (fp-at s ie) 101) (eq (fp-at s ie) 69)))
        (gt (flt-fe-exp s (add ie 1) ie) ie)
        0))
(defn flt-exp-lit (s ie whole start env)
    (do
        (let end (flt-fe-exp s (add ie 1) ie))
        (let lit (substring s start end))
        (list (fk-f64 (flt-sidx (flt-poolv env) lit 0) lit) end)))
(defn flt-num2 (s pos ve env)
    (if (and (lt (nth ve 1) (fp-len s))
             (and (eq (fp-at s (nth ve 1)) 46)
                  (fp-isdigit (fp-at s (add (nth ve 1) 1)))))
        (flt-float-lit s (nth ve 1) (nth ve 0) pos env)
        (if (eq (flt-has-exp s (nth ve 1)) 1)
            (flt-exp-lit s (nth ve 1) (nth ve 0) pos env)
            (fp-num ve))))
(defn flt-neg-num (s pos env)
    (do
        (let ve (fp-digits s (add pos 1) 0))
        (if (and (lt (nth ve 1) (fp-len s))
                 (and (eq (fp-at s (nth ve 1)) 46)
                      (fp-isdigit (fp-at s (add (nth ve 1) 1)))))
            (flt-float-lit s (nth ve 1) (sub 0 (nth ve 0)) pos env)
            (if (eq (flt-has-exp s (nth ve 1)) 1)
                (flt-exp-lit s (nth ve 1) (sub 0 (nth ve 0)) pos env)
                (flt-neg ve)))))
; consume a run of digits
(defn flt-fe-digits (s pos)
    (if (and (lt pos (fp-len s)) (fp-isdigit (fp-at s pos)))
        (flt-fe-digits s (add pos 1))
        pos))
; after the mantissa, consume a scientific-notation exponent (e/E [+/-] digits) if VALID;
; otherwise stop before the 'e' (ep) so a bare 'e' stays a separate token. strtod parses the
; captured literal, so the full "1.5e-05" must land in the lit substring (the fkwu float path).
(defn flt-fe-exp (s p ep)
    (do
        (let q (if (and (lt p (fp-len s)) (or (eq (fp-at s p) 43) (eq (fp-at s p) 45))) (add p 1) p))
        (if (and (lt q (fp-len s)) (fp-isdigit (fp-at s q)))
            (flt-fe-digits s q)
            ep)))
(defn flt-float-end (s pos)
    (do
        (let e1 (flt-fe-digits s pos))
        (if (and (lt e1 (fp-len s)) (or (eq (fp-at s e1) 101) (eq (fp-at s e1) 69)))
            (flt-fe-exp s (add e1 1) e1)
            e1)))
(defn flt-float-lit (s dot whole start env)
    (do
        (let end (flt-float-end s (add dot 1)))
        (let lit (substring s start end))
        (list (fk-f64 (flt-sidx (flt-poolv env) lit 0) lit) end)))

; ── string literals ride the pool: the pre-pass (flt-scan) interned every
;    distinct literal, so a "..." at the cursor lowers to SLIT carrying its
;    pool index; the pool itself travels in env under the quote-name (a name
;    no symbol can collide with — '"' is the literal door, never a var) ─────
(defn flt-strend (s pos)
    (if (ge pos (fp-len s)) pos
        (if (eq (fp-at s pos) 92) (flt-strend s (add pos 2))
            (if (eq (fp-at s pos) 34) pos (flt-strend s (add pos 1))))))
(defn flt-str (s pos env) (flt-str2 (substring s pos (flt-strend s pos)) (add (flt-strend s pos) 1) env))
(defn flt-str2 (lit end env)
    (do
        (let text (flt-unescape lit))
        (list (fk-slit (flt-sidx (flt-poolv env) text 0) text) end)))
(defn flt-unescape (s) (flt-unescape-loop s 0 (str_len s)))
(defn flt-unescape-loop (s i n)
    (if (ge i n)
        ""
        (if (and (str_eq (char_at s i) "\\") (lt (add i 1) n))
            (str_concat (flt-unescape-char (char_at s (add i 1)))
                        (flt-unescape-loop s (add i 2) n))
            (str_concat (char_at s i) (flt-unescape-loop s (add i 1) n)))))
(defn flt-unescape-char (ch)
    (if (str_eq ch "n") (byte_to_str 10)
        (if (str_eq ch "r") (byte_to_str 13)
        (if (str_eq ch "t") (byte_to_str 9)
        (if (str_eq ch "\"") (byte_to_str 34)
        (if (str_eq ch "\\") (byte_to_str 92) ch))))))
(defn flt-poolq () (byte_to_str 34))
(defn flt-pool-row (env) (flt-assoc (flt-poolq) env))
(defn flt-poolv (env) (nth (flt-pool-row env) 1))
(defn flt-sidx (pool lit i)
    (if (eq (len pool) 0) (sub 0 1)
        (if (str_eq (head pool) lit) i (flt-sidx (tail pool) lit (add i 1)))))

(defn flt-var (s pos env fns) (flt-var2 (flt-word s pos) (fp-sym-end s pos) env fns))
(defn flt-var2 (name end env fns)
    (if (str_eq name "true") (list (fk-lit 1) end)
        (if (str_eq name "false") (list (fk-lit 0) end)
            (list (flt-var3 (flt-assoc name env) name fns) end))))
(defn flt-var3 (row name fns)
    (if (eq (len row) 0) (flt-fref3 (flt-assoc name fns) (fk-lit 0))
        (nth row 1)))
(defn flt-fref (row) (fk-cons (fk-lit (nth row 1)) (fk-cons (fk-lit (nth row 2)) (fk-empty))))
(defn flt-fref3 (row dflt) (if (eq (len row) 0) dflt (flt-fref row)))

(defn flt-form (s pos fns env) (flt-form2 (flt-word s pos) s (fp-sym-end s pos) fns env))
(defn flt-form2 (op s pos fns env)
    (if (str_eq op "if") (flt-if s pos fns env)
    (if (str_eq op "list") (flt-list s pos fns env)
    (if (str_eq op "empty") (list (fk-empty) (fp-close s pos))
    (if (str_eq op "do") (flt-do s pos fns env (fk-lit 0))
    (if (str_eq op "gt") (flt-low 1 s pos fns env)
    (if (str_eq op "ge") (flt-low 2 s pos fns env)
    (if (str_eq op "lt") (flt-low 3 s pos fns env)
    (if (str_eq op "eq") (flt-low 4 s pos fns env)
    (if (str_eq op "and") (flt-low 5 s pos fns env)
    (if (str_eq op "or") (flt-low 6 s pos fns env)
    (if (str_eq op "char_at") (flt-char-at s pos fns env)
    (if (str_eq op "ord") (flt-low1 1 s pos fns env)
    (if (str_eq op "not") (flt-low1 2 s pos fns env)
    (if (str_eq op "record_new") (flt-record-new s pos fns env)
    (if (str_eq op "bp") (flt-bp s pos fns env)
        (flt-op op s pos fns env)))))))))))))))))

; one operand, then the unary lowering picked by selector k
(defn flt-low1 (k s pos fns env) (flt-low1-a k s (flt-expr s pos fns env)))
(defn flt-low1-a (k s ae) (list (flt-low1-mk k (nth ae 0)) (fp-close s (nth ae 1))))
(defn flt-low1-mk (k a) (if (eq k 1) (flt-ord a) (flt-not a)))

; ── nested (do ...) as an EXPRESSION (let-in-defn, do-in-do) ──────────────
; The same structural recursion as the top-level do-walker, scoped to a
; value position: an effecting (let name v), and a non-recursive direct-call
; pure let, walks v once, stores it in a per-function RAM slot, and binds a
; load cell into env for the REST of the do. Other pure values keep the old
; inline lowering so recursive/local compute does not contend on global slots. The
; last expression is the do's value. Nesting falls out of flt-expr — a
; child that is itself (do ...) re-enters here with its own env tail.
(defn flt-do (s pos fns env val) (flt-do2 s (fp-skip s pos) fns env val))
(defn flt-do2 (s pos fns env val)
    (if (ge pos (fp-len s)) (list val pos)
    (if (eq (fp-at s pos) 41) (list val (add pos 1))
    (if (str_eq (flt-peek s pos) "let") (flt-do-let s pos fns env val)
        (flt-do-e s (flt-expr s pos fns env) fns env val)))))
; A bare do-statement is an EFFECT, not dead weight: sequence the running value
; before the new expression (t==69 walks the left for effect, returns the right),
; so every statement fires exactly once in order and the last is the do's value.
; The initial (fk-lit 0) sentinel rides as a harmless first left-walk.
(defn flt-do-e (s ee fns env val) (flt-do2 s (fp-skip s (nth ee 1)) fns env (flt-sequence val (nth ee 0))))

; (let name value) inside a do — value parses under the CURRENT env, then
; binds for the remaining items (shadowing outer bindings by name)
(defn flt-do-let (s pos fns env val)
    (flt-do-let-n s (fp-skip s (fp-sym-end s (fp-skip s (add pos 1)))) fns env val))
(defn flt-do-let-n (s pos fns env val)
    (flt-do-let-v (flt-word s pos) s (fp-sym-end s pos) fns env val))
(defn flt-do-let-v (name s pos fns env val)
    (flt-do-let-done name (flt-peek s (fp-skip s pos)) s (flt-expr s pos fns env) fns env val))
(defn flt-do-let-effect-op (op)
    (if (str_eq op "read_line") 1
    (if (str_eq op "record_new") 1
    (if (str_eq op "file_append_bytes") 1
    (if (str_eq op "write_file_text") 1
    (if (str_eq op "fs_remove") 1
    (if (str_eq op "fs_rename") 1
    (if (str_eq op "fs_mkdir") 1
    (if (str_eq op "fs_rmdir") 1
    (if (str_eq op "read_file") 1
    (if (str_eq op "fs_list") 1
    (if (str_eq op "read_file_slice") 1
    (if (str_eq op "file_size") 1
    (if (str_eq op "file_mtime") 1
    (if (str_eq op "file_byte_at") 1
    (if (str_eq op "scan_run") 1
    (if (str_eq op "file_open") 1
    (if (str_eq op "file_read") 1
    (if (str_eq op "file_close") 1
    (if (str_eq op "http_get") 1 0))))))))))))))))))))
(defn flt-do-let-done (name op s ve fns env val)
    (if (eq (flt-do-let-store-op op fns env) 1)
        (flt-do-let-frame name s ve fns env val (add (flt-current-letdepth env) 1))
        (flt-do2 s (fp-skip s (fp-close s (nth ve 1))) fns
                 (cons (list name (nth ve 0)) env) val)))
(defn flt-do-let-store-op (op fns env)
    (if (eq (flt-do-let-effect-op op) 1) 1
        (if (eq (flt-current-recursive env) 1) 0
            (if (eq (len (flt-assoc op fns)) 0) 0 1))))
; A stored let lowers to LETF: walk the value once, write it to the reserved
; frame slot fp+offset, walk the rest of the do with a frame-relative FARG
; binding. No fk_vsp push — the slot is pre-reserved, so it survives sub-calls
; and a recursive re-entry that reserves its own block higher up the stack.
(defn flt-do-let-frame (name s ve fns env val offset)
    (flt-do-let-frame-rest offset (nth ve 0)
        (flt-do2 s (fp-skip s (fp-close s (nth ve 1))) fns
                 (cons (list name (fk-farg offset))
                       (cons (list (flt-letdepth-q) offset) env))
                 val)))
(defn flt-do-let-frame-rest (offset value rest)
    (list (fk-letf offset value (nth rest 0)) (nth rest 1)))

; two operands, then the lowering picked by selector k (lowerings are rules,
; not tag rows — they BUILD shapes instead of naming one)
(defn flt-low (k s pos fns env) (flt-low-a k s (flt-expr s pos fns env) fns env))
(defn flt-low-a (k s ae fns env) (flt-low-b k s (nth ae 0) (flt-expr s (nth ae 1) fns env)))
(defn flt-low-b (k s a be) (list (flt-low-mk k a (nth be 0)) (fp-close s (nth be 1))))
(defn flt-low-mk (k a b)
    (if (eq k 1) (flt-gt a b)
    (if (eq k 2) (flt-ge a b)
    (if (eq k 3) (flt-lt a b)
    (if (eq k 4) (flt-eq a b)
    (if (eq k 5) (flt-and a b) (flt-or a b)))))))

; char_at lowers onto substring(s, i, i+1): one string-family primitive,
; one arithmetic leaf, no extra walker tag.
(defn flt-char-at (s pos fns env) (flt-char-at-a s (flt-expr s pos fns env) fns env))
(defn flt-char-at-a (s ae fns env) (flt-char-at-b s (nth ae 0) (flt-expr s (nth ae 1) fns env)))
(defn flt-char-at-b (s a be)
    (list (fk-ssub a (nth be 0) (fk-add (nth be 0) (fk-lit 1)))
          (fp-close s (nth be 1))))

; record_new lowers to a packed entry list consumed by fkwu tag 64. The
; blueprint identity is stored in a sentinel entry whose key is -1, then field
; key/value pairs follow as ((key value) ...). The emitted walker initializes a
; real record-table carrier from this first-order packet.
(defn flt-record-new (s pos fns env)
    (flt-record-new-blueprint s (flt-expr s pos fns env) fns env))
(defn flt-record-new-blueprint (s be fns env)
    (flt-record-new-tag (flt-record-new-wrap (nth be 0) (flt-record-new-fields s (nth be 1) fns env))))
(defn flt-record-new-tag (re) (list (fk-node 64 (nth re 0)) (nth re 1)))
(defn flt-record-new-wrap (bp re)
    (list (fk-cons (flt-record-entry (fk-lit (sub 0 1)) bp) (nth re 0)) (nth re 1)))
(defn flt-record-new-fields (s pos fns env)
    (if (eq (fp-at s (fp-skip s pos)) 41) (list (fk-empty) (add (fp-skip s pos) 1))
        (flt-record-new-key s (flt-expr s pos fns env) fns env)))
(defn flt-record-new-key (s ke fns env)
    (flt-record-new-val s (nth ke 0) (flt-expr s (nth ke 1) fns env) fns env))
(defn flt-record-new-val (s key ve fns env)
    (flt-record-new-cons key (nth ve 0) (flt-record-new-fields s (nth ve 1) fns env)))
(defn flt-record-entry (key val) (fk-cons key (fk-cons val (fk-empty))))
(defn flt-record-new-cons (key val re) (list (fk-cons (flt-record-entry key val) (nth re 0)) (nth re 1)))

; Literal bp names fold at lowering time so fkwu sees the same NodeID identity
; the sibling kernels get from their generated BP_TABLE. Dynamic/unknown bp
; calls still lower to tag 45, preserving the old fallback while the generated
; table becomes native.
(defn flt-nodeid4 (p l t i)
    (fk-node 91
        (fk-cons (fk-lit p)
        (fk-cons (fk-lit l)
        (fk-cons (fk-lit t)
        (fk-cons (fk-lit i) (fk-empty)))))))
(defn flt-bp (s pos fns env)
    (if (eq (fp-at s (fp-skip s pos)) 34)
        (flt-bp-lit s (add (fp-skip s pos) 1) env)
        (flt-op "bp" s pos fns env)))
(defn flt-bp-lit (s pos env)
    (flt-bp-lit2 s
        (flt-unescape (substring s pos (flt-strend s pos)))
        (add (flt-strend s pos) 1)
        env))
(defn flt-bp-lit2 (s name end env)
    (list (flt-bp-node name env) (fp-close s end)))
(defn flt-bp-fallback (name env)
    (fk-node 45 (fk-slit (flt-sidx (flt-poolv env) name 0) name)))
(defn flt-bp-node (name env)
    ;; flatten-internal blueprints — folded so the flattener SELF-HOSTS on fkwu.
    ;; fkwu has no runtime bp-name table; an unfolded name hits the tag-45 fallback,
    ;; which returns the name STRING, so intern_node gets a string-not-a-nodeid and
    ;; every built node is malformed. MS-PAIR carries every ms-intern composition;
    ;; VALUE-NONE is the None sentinel. (1 2 99 1300 is MS-PAIR's registry nodeid.)
    (if (str_eq name "MS-PAIR")    (flt-nodeid4 1 2 99 1300)
    (if (str_eq name "VALUE-NONE") (flt-nodeid4 1 2 99 1399)
    (if (str_eq name "HEX-DECODE-ERROR") (flt-nodeid4 1 2 99 1770)
    (if (str_eq name "AUDIT-ENTRY")      (flt-nodeid4 1 2 99 1770)
    (if (str_eq name "URL-DECODE-ERROR") (flt-nodeid4 1 2 99 1771)
    (if (str_eq name "AUDIT-LOG")        (flt-nodeid4 1 2 99 1771)
    (if (str_eq name "TOKEN")            (flt-nodeid4 1 2 99 1790)
    (if (str_eq name "SESSION")          (flt-nodeid4 1 2 99 1860)
    (if (str_eq name "SESSION-TABLE")    (flt-nodeid4 1 2 99 1861)
    (if (str_eq name "SESSION-NOT-FOUND")(flt-nodeid4 1 2 99 1862)
    (if (str_eq name "UUID")             (flt-nodeid4 1 2 99 1870)
    (if (str_eq name "ARRIVAL")          (flt-nodeid4 1 2 99 1870)
    (if (str_eq name "UUID-PARSE-ERROR") (flt-nodeid4 1 2 99 1871)
    (if (str_eq name "ARRIVAL-QUALITY")  (flt-nodeid4 1 2 99 1871)
    (if (str_eq name "NAME-RECORD")       (flt-nodeid4 1 2 99 1850)
    (if (str_eq name "DNS-TABLE")         (flt-nodeid4 1 2 99 1851)
    (if (str_eq name "DNS-NOT-FOUND")     (flt-nodeid4 1 2 99 1852)
    (if (str_eq name "DNS-PREFIX-MATCH")  (flt-nodeid4 1 2 99 1853)
    (if (str_eq name "XPATH-RESULT")      (flt-nodeid4 1 2 99 1910)
    (if (str_eq name "XPATH-NOT-FOUND")   (flt-nodeid4 1 2 99 1911)
    (if (str_eq name "XPATH-STEP")        (flt-nodeid4 1 2 99 1912)
    (if (str_eq name "XPATH-PREDICATE")   (flt-nodeid4 1 2 99 1913)
    (if (str_eq name "DOC")               (flt-nodeid4 1 2 99 1920)
    (if (str_eq name "SECTION-LIST")      (flt-nodeid4 1 2 99 1921)
    (if (str_eq name "SECTION")           (flt-nodeid4 1 2 99 1922)
    (if (str_eq name "DOC-NOT-FOUND")     (flt-nodeid4 1 2 99 1923)
    (if (str_eq name "CONCEPT")           (flt-nodeid4 1 2 99 1930)
    (if (str_eq name "CONCEPT-NOT-FOUND") (flt-nodeid4 1 2 99 1931)
    (if (str_eq name "CONCEPT-CORPUS-C")  (flt-nodeid4 1 2 99 1932)
    (if (str_eq name "CONCEPT-XREFS")     (flt-nodeid4 1 2 99 1933)
    (if (str_eq name "SYMBOL-BIND")       (flt-nodeid4 1 2 99 1730)
    (if (str_eq name "SYMBOL-TABLE")      (flt-nodeid4 1 2 99 1731)
    (if (str_eq name "SYMBOL-NOT-FOUND")  (flt-nodeid4 1 2 99 1732)
    (if (str_eq name "QUERY")           (flt-nodeid4 1 2 99 1710)
    (if (str_eq name "RESPONSE")        (flt-nodeid4 1 2 99 1711)
    (if (str_eq name "SUBSTRATE-REF")   (flt-nodeid4 1 2 99 1712)
    (if (str_eq name "NOVEL-BLUEPRINT") (flt-nodeid4 1 2 99 1713)
    (if (str_eq name "RECIPE-CONTENT")  (flt-nodeid4 1 2 99 1714)
    (if (str_eq name "CELL-REF")        (flt-nodeid4 1 2 99 1715)
    (if (str_eq name "EXTERNAL-URI")    (flt-nodeid4 1 2 99 1716)
    (if (str_eq name "QUERY-PARSE-ERROR")(flt-nodeid4 1 2 99 1717)
    (if (str_eq name "SCHEMA-LIST-CAT") (flt-nodeid4 1 1 14 0)
    ;; SHAMBALLA-RAISED is read by node_level (sh-raise lifts a cell one level):
    ;; the string fallback has no level field, so node_level came back 0 not 3 and
    ;; shamballa-channel's raise-ok diverged (fkwu 1111101111 vs 1111111111).
    ;; Folding both Shamballa blueprints to their registry NodeIDs crosses it.
    ;; NOTE: the fallback is NOT blanket-foldable to a live (bp name) lookup — the
    ;; grammar bands (bmf-core/bmf-grammar/natural-language/shell-parse) build and
    ;; compare nodes through the string-carried category and regress when those
    ;; names fold to real NodeIDs. Generalizing this table to the registry is a
    ;; separate investigation (why the grammar path needs the string carrier),
    ;; tracked in docs/coherence-substrate/fourth-arm-substrate-carriers.form.
    (if (str_eq name "SHAMBALLA-RAISED")(flt-nodeid4 1 3 99 1718)
    (if (str_eq name "SHAMBALLA-CRYSTAL")(flt-nodeid4 1 2 99 1719)
        (flt-bp-fallback name env))))))))))))))))))))))))))))))))))))))))))))))

; table ops by arity, else a user function call (one evaluated argument)
(defn flt-op (op s pos fns env) (flt-op2 (flt-assoc op (flt-ops)) op s pos fns env))
(defn flt-op2 (row op s pos fns env)
    (if (eq (len row) 0) (flt-call op s pos fns env)
        (if (eq (nth row 1) 0) (flt-nullary row s pos)
        (if (eq (nth row 1) 1) (flt-un row s (flt-expr s pos fns env))
            (if (eq (nth row 1) 2) (flt-bin row s (flt-expr s pos fns env) fns env)
                (if (eq (nth row 1) 3) (flt-tri row s (flt-expr s pos fns env) fns env)
                    (flt-quad row s (flt-expr s pos fns env) fns env)))))))
; nullary walker op (host-io 0-arg, e.g. temp_dir): the walker arm reads no
; children, so the node carries a trivial body and we just close the form.
(defn flt-nullary (row s pos) (list (fk-node (nth row 2) (ms-cell 0)) (fp-close s pos)))
(defn flt-un (row s ae) (list (flt-mkop row (nth ae 0) 0) (fp-close s (nth ae 1))))
(defn flt-bin (row s ae fns env) (flt-bin2 row s (nth ae 0) (flt-expr s (nth ae 1) fns env)))
(defn flt-bin2 (row s a be) (list (flt-mkop row a (nth be 0)) (fp-close s (nth be 1))))
(defn flt-tri (row s ae fns env) (flt-tri2 row s (nth ae 0) (flt-expr s (nth ae 1) fns env) fns env))
(defn flt-tri2 (row s a be fns env) (flt-tri3 row s a (nth be 0) (flt-expr s (nth be 1) fns env)))
(defn flt-tri3 (row s a b ce)
    (list (fk-node (nth row 2) (ms-intern a (ms-intern b (nth ce 0))))
          (fp-close s (nth ce 1))))

; Four-operand native rows ride the existing list carrier in the body so the
; emitted program table stays fixed-width (tag + three operand slots).
(defn flt-quad (row s ae fns env) (flt-quad2 row s (nth ae 0) (flt-expr s (nth ae 1) fns env) fns env))
(defn flt-quad2 (row s a be fns env) (flt-quad3 row s a (nth be 0) (flt-expr s (nth be 1) fns env) fns env))
(defn flt-quad3 (row s a b ce fns env) (flt-quad4 row s a b (nth ce 0) (flt-expr s (nth ce 1) fns env)))
(defn flt-quad4 (row s a b c de)
    (list (fk-node (nth row 2)
              (fk-cons a (fk-cons b (fk-cons c (fk-cons (nth de 0) (fk-empty))))))
          (fp-close s (nth de 1))))

; ── user function calls: every argument until ')' parses, then the row's
;    arity picks the carrier — arity 1 rides ARG direct (no allocation),
;    any other arity right-folds the args into a CONS pack the callee
;    unpacks by NTH position (multi-param-via-packed-args, m4e4) ──────────
(defn flt-args (s pos fns env)
    (if (eq (fp-at s (fp-skip s pos)) 41) (list (list) (add (fp-skip s pos) 1))
        (flt-args2 s (flt-expr s pos fns env) fns env)))
(defn flt-args2 (s ae fns env) (flt-args3 (nth ae 0) (flt-args s (nth ae 1) fns env)))
(defn flt-args3 (a re) (list (cons a (nth re 0)) (nth re 1)))

(defn flt-pack (args arity) (if (eq arity 1) (head args) (flt-pack2 args)))
(defn flt-pack2 (args)
    (if (eq (len args) 0) (fk-empty)
        (fk-cons (head args) (flt-pack2 (tail args)))))

(defn flt-call (fname s pos fns env)
    (flt-call2 (flt-assoc fname env) (flt-assoc fname fns) s pos fns env))
(defn flt-call2 (erow frow s pos fns env)
    (if (eq (len erow) 0)
        (flt-call3 frow (flt-args s pos fns env))
        (flt-icall (nth erow 1) s pos fns env)))
(defn flt-call3 (row ae)
    (if (eq (len row) 0) (list (fk-lit 0) (nth ae 1))
        (list (fk-call (nth row 1) (flt-pack (nth ae 0) (nth row 2))) (nth ae 1))))
(defn flt-icall (fv s pos fns env)
    (flt-icall2 fv (flt-arglist s pos fns env)))
(defn flt-icall2 (fv ae)
    (list (fk-icall fv (nth ae 0)) (nth ae 1)))

; argument-list carrier for indirect calls: always a list of evaluated args.
(defn flt-arglist (s pos fns env)
    (if (eq (fp-at s (fp-skip s pos)) 41) (list (fk-empty) (add (fp-skip s pos) 1))
        (flt-arglist2 s (flt-expr s pos fns env) fns env)))
(defn flt-arglist2 (s ee fns env) (flt-arglist3 (nth ee 0) (flt-arglist s (nth ee 1) fns env)))
(defn flt-arglist3 (e re) (list (fk-cons e (nth re 0)) (nth re 1)))

(defn flt-if (s pos fns env) (flt-if-c s (flt-expr s pos fns env) fns env))
(defn flt-if-c (s ce fns env) (flt-if-t s (nth ce 0) (flt-expr s (nth ce 1) fns env) fns env))
(defn flt-if-t (s c te fns env) (flt-if-e s c (nth te 0) (flt-expr s (nth te 1) fns env)))
(defn flt-if-e (s c t ee) (list (fk-if c t (nth ee 0)) (fp-close s (nth ee 1))))

; (list e1 e2 ...) — right-fold into CONS chains, EMPTY at the tail
(defn flt-list (s pos fns env)
    (if (eq (fp-at s (fp-skip s pos)) 41) (list (fk-empty) (add (fp-skip s pos) 1))
        (flt-list2 s (flt-expr s pos fns env) fns env)))
(defn flt-list2 (s ee fns env) (flt-list3 (nth ee 0) (flt-list s (nth ee 1) fns env)))
(defn flt-list3 (e re) (list (fk-cons e (nth re 0)) (nth re 1)))

; ── the do-walker: defn registers a function row (name BEFORE body, so
;    self-recursion lands), let binds env, the last plain expression is the
;    program's main — one walker serves module files, band files, and minis ──
(defn flt-items (s pos fns rbodies env main)
    (flt-items2 s (fp-skip s pos) fns rbodies env main))
(defn flt-items2 (s pos fns rbodies env main)
    (if (ge pos (fp-len s)) (list fns rbodies main pos env)
    (if (eq (fp-at s pos) 41) (list fns rbodies main (add pos 1) env)
    (if (str_eq (flt-peek s pos) "defn") (flt-defn s pos fns rbodies env main)
    (if (str_eq (flt-peek s pos) "let") (flt-let s pos fns rbodies env main)
        (flt-main s (flt-expr s pos fns env) fns rbodies env main))))))
; Top-level bare statements are effects too: sequence the running main before the
; new expression so a do-block's intermediate statements fire once in order and
; the last is the program value (same discipline as flt-do-e for nested do).
(defn flt-main (s ee fns rbodies env main) (flt-items s (nth ee 1) fns rbodies env (flt-sequence main (nth ee 0))))

; (defn name (p0 p1 ...) body) — pos arrives at the form's '('. The param
; LIST reads whole first so the function row carries (name index arity)
; BEFORE the body parses — self-recursion sees its own arity and packs.
; The body env binds each param by position: arity 1 is ARG itself, any
; other arity is NTH(ARG, i) into the packed CONS chain.
(defn flt-params (s pos)
    (if (eq (fp-at s (fp-skip s pos)) 41) (list (list) (add (fp-skip s pos) 1))
        (flt-params2 s (fp-skip s pos))))
(defn flt-params2 (s pos) (flt-params3 (flt-word s pos) (flt-params s (fp-sym-end s pos))))
(defn flt-params3 (w re) (list (cons w (nth re 0)) (nth re 1)))

; (`params` itself is a defn-grammar keyword, so the list rides as `ps`)
(defn flt-penv (ps n i)
    (if (eq (len ps) 0) (list)
        (cons (list (head ps)
                    (if (eq n 1) (fk-arg) (fk-nth (fk-arg) (fk-lit i))))
              (flt-penv (tail ps) n (add i 1)))))

(defn flt-env-append (front back)
    (if (eq (len front) 0) back
        (cons (head front) (flt-env-append (tail front) back))))

(defn flt-expr-end (s pos)
    (flt-expr-end2 s (fp-skip s pos)))
(defn flt-expr-end2 (s pos)
    (if (ge pos (fp-len s)) pos
        (if (eq (fp-at s pos) 40) (fp-close s pos)
            (if (eq (fp-at s pos) 34) (add (flt-strend s (add pos 1)) 1)
                (fp-sym-end s pos)))))
(defn flt-calls-name (name s pos end)
    (if (ge pos end) 0
        (if (eq (fp-at s pos) 34)
            (flt-calls-name name s (add (flt-strend s (add pos 1)) 1) end)
            (if (and (eq (fp-at s pos) 40)
                     (str_eq (flt-word s (fp-skip s (add pos 1))) name))
                1
                (flt-calls-name name s (add pos 1) end)))))
(defn flt-defn-recursive (name s pos)
    (flt-calls-name name s (fp-skip s pos) (flt-expr-end s pos)))

; ── closure factories ────────────────────────────────────────────────────
; A defn whose body is  (do (defn inner (p..) body) inner)  is a CLOSURE
; FACTORY: it returns a function that closes over the outer params. The inner is
; lifted to a top-level function whose LEADING params are the captured outer
; params, then the real params; the outer body becomes a make-closure ref
; (fn-index arity . captured-values). flt-sig-scan already gave `inner` a
; function index (it scans into bodies), so we compile its body here with the
; capture params and place it in rbodies right after the outer — keeping
; fns/rbodies aligned. The walker's tag-44 prepends the captured tail to the
; call args (a closure is a partial application); a named ref (empty tail) is
; unchanged, so this is purely additive.
(defn flt-special-key? (name)
    (if (str_eq name (flt-recq)) 1
    (if (str_eq name (flt-fidxq)) 1
    (if (str_eq name (flt-letdepth-q)) 1
    (if (str_eq name (flt-poolq)) 1 0)))))
; the LEADING non-special env rows are exactly the outer function's params
; (flt-env-append puts penv first, then the recq/fidxq specials, then module env)
(defn flt-cap-rows (env)
    (if (eq (len env) 0) (list)
        (if (eq (flt-special-key? (nth (head env) 0)) 1) (list)
            (cons (head env) (flt-cap-rows (tail env))))))
(defn flt-names-of (rows) (if (eq (len rows) 0) (list) (cons (nth (head rows) 0) (flt-names-of (tail rows)))))
(defn flt-access-of (rows) (if (eq (len rows) 0) (list) (cons (nth (head rows) 1) (flt-access-of (tail rows)))))
(defn flt-append-l (a b) (if (eq (len a) 0) b (cons (head a) (flt-append-l (tail a) b))))
(defn flt-cap-chain (caps) (if (eq (len caps) 0) (fk-empty) (fk-cons (head caps) (flt-cap-chain (tail caps)))))
(defn flt-make-closure (fidx arity caps) (fk-cons (fk-lit fidx) (fk-cons (fk-lit arity) (flt-cap-chain caps))))

(defn flt-do-first (s dopos) (fp-skip s (fp-sym-end s (fp-skip s (add dopos 1)))))
(defn flt-factory-shape? (s dopos)
    (if (str_eq (flt-peek s dopos) "do")
        (if (str_eq (flt-peek s (flt-do-first s dopos)) "defn") 1 0) 0))
; -> (outer-body inner-body endpos) for a valid factory, else (list).
(defn flt-factory-parse (s pos fns benv)
    (if (eq (flt-factory-shape? s (fp-skip s pos)) 1)
        (flt-fp-name s (fp-skip s pos) fns benv (flt-fp-name-pos s (flt-do-first s (fp-skip s pos))))
        (list)))
(defn flt-fp-name-pos (s ipos) (fp-skip s (fp-sym-end s (fp-skip s (add ipos 1)))))
(defn flt-fp-name (s dopos fns benv npos)
    (flt-fp-params s dopos fns benv (flt-word s npos)
        (flt-params s (add (fp-skip s (fp-sym-end s npos)) 1))))
(defn flt-fp-params (s dopos fns benv iname pe)
    (flt-fp-build s dopos fns iname (nth pe 0) (nth pe 1) (flt-cap-rows benv) (nth (flt-assoc iname fns) 1)))
(defn flt-fp-build (s dopos fns iname iparams ibodypos caprows fidx)
    (flt-fp-compile s dopos fns iname ibodypos fidx (flt-access-of caprows)
        (flt-append-l (flt-names-of caprows) iparams)))
(defn flt-fp-compile (s dopos fns iname ibodypos fidx capaccess allparams)
    (flt-fp-finish s dopos fidx capaccess (len allparams)
        (flt-expr s ibodypos fns (flt-penv allparams (len allparams) 0)) ibodypos iname))
(defn flt-fp-finish (s dopos fidx capaccess total ibe ibodypos iname)
    (flt-fp-emit s dopos fidx capaccess total ibe ibodypos
        (flt-fp-ret-ok? s (fp-close s (nth ibe 1)) iname)))
(defn flt-fp-ret-ok? (s afterinner iname)
    (if (str_eq (flt-word s (fp-skip s afterinner)) iname)
        (if (eq (fp-at s (fp-skip s (fp-sym-end s (fp-skip s afterinner)))) 41) 1 0) 0))
(defn flt-fp-emit (s dopos fidx capaccess total ibe ibodypos ok)
    (if (eq ok 1)
        (list (flt-make-closure fidx total capaccess)
              (flt-reserve-wrap-k (flt-count-lets s ibodypos (fp-close s (nth ibe 1))) (nth ibe 0))
              (fp-close s dopos))
        (list)))

(defn flt-defn (s pos fns rbodies env main)
    (flt-defn-n s (fp-skip s (fp-sym-end s (fp-skip s (add pos 1)))) fns rbodies env main))
(defn flt-defn-n (s pos fns rbodies env main)
    (flt-defn-p (flt-word s pos) s (fp-sym-end s pos) fns rbodies env main))
(defn flt-defn-p (name s pos fns rbodies env main)
    (flt-defn-p2 name s (flt-params s (add (fp-skip s pos) 1)) fns rbodies env main))
(defn flt-defn-sig (name arity fns)
    (if (eq (len (flt-assoc name fns)) 0)
        (list name (add (len fns) 1) arity)
        (flt-assoc name fns)))
(defn flt-defn-fns (row fns)
    (if (eq (len (flt-assoc (nth row 0) fns)) 0) (cons row fns) fns))
(defn flt-defn-p2 (name s pe fns rbodies env main)
    (flt-defn-p3 name s pe fns rbodies env main
                 (flt-defn-sig name (len (nth pe 0)) fns)))
(defn flt-defn-p3 (name s pe fns rbodies env main row)
    (flt-defn-b s (nth pe 1)
                (flt-defn-fns row fns)
                (flt-env-append
                    (flt-penv (nth pe 0) (len (nth pe 0)) 0)
                    (cons (list (flt-recq) (flt-defn-recursive name s (nth pe 1)))
                          (cons (list (flt-fidxq) (nth row 1)) env)))
                rbodies env main))
(defn flt-defn-b (s pos fns benv rbodies env main)
    (flt-defn-b-disp (flt-factory-parse s pos fns benv) s pos fns benv rbodies env main))
(defn flt-defn-b-disp (fac s pos fns benv rbodies env main)
    (if (eq (len fac) 0)
        (flt-defn-b2 s pos (flt-expr s pos fns benv) fns rbodies env main)
        (flt-items s (nth fac 2) fns (cons (nth fac 1) (cons (nth fac 0) rbodies)) env main)))
(defn flt-defn-b2 (s pos be fns rbodies env main)
    (flt-defn-done s (flt-count-lets s pos (fp-close s (nth be 1))) be fns rbodies env main))
(defn flt-defn-done (s k be fns rbodies env main)
    (flt-items s (fp-close s (nth be 1)) fns (cons (flt-reserve-wrap-k k (nth be 0)) rbodies) env main))

; (let name value) — the value cell binds into env and inlines at each use
(defn flt-let (s pos fns rbodies env main)
    (flt-let-n s (fp-skip s (fp-sym-end s (fp-skip s (add pos 1)))) fns rbodies env main))
(defn flt-let-n (s pos fns rbodies env main)
    (flt-let-v (flt-word s pos) s (fp-sym-end s pos) fns rbodies env main))
(defn flt-let-v (name s pos fns rbodies env main)
    (flt-let-done name s (flt-expr s pos fns env) fns rbodies env main))
(defn flt-let-done (name s ve fns rbodies env main)
    (flt-items s (fp-close s (nth ve 1)) fns rbodies (cons (list name (nth ve 0)) env) main))

; The band source's top-level do is an ordered program, not a module constant
; carrier. Snapshot each top-level let once so reads before record_set keep
; their source-time value while module top-level constants still inline above.
(defn flt-items-s (s pos fns rbodies env main)
    (flt-items2-s s (fp-skip s pos) fns rbodies env main))
(defn flt-items2-s (s pos fns rbodies env main)
    (if (ge pos (fp-len s)) (list fns rbodies main pos env)
    (if (eq (fp-at s pos) 41) (list fns rbodies main (add pos 1) env)
    (if (str_eq (flt-peek s pos) "defn") (flt-defn-s s pos fns rbodies env main)
    (if (str_eq (flt-peek s pos) "let") (flt-let-s s pos fns rbodies env main)
        (flt-main-s s (flt-expr s pos fns env) fns rbodies env))))))
(defn flt-main-s (s ee fns rbodies env)
    (flt-main-next-s s ee (fp-skip s (nth ee 1)) fns rbodies env))
(defn flt-main-next-s (s ee pos fns rbodies env)
    (if (or (ge pos (fp-len s)) (eq (fp-at s pos) 41))
        (flt-items-s s (nth ee 1) fns rbodies env (nth ee 0))
        (flt-main-seq-s (nth ee 0) (flt-items-s s pos fns rbodies env (nth ee 0)))))
(defn flt-main-seq-s (val rest)
    (list (nth rest 0) (nth rest 1) (flt-sequence val (nth rest 2)) (nth rest 3) (nth rest 4)))
(defn flt-defn-s (s pos fns rbodies env main)
    (flt-defn-n-s s (fp-skip s (fp-sym-end s (fp-skip s (add pos 1)))) fns rbodies env main))
(defn flt-defn-n-s (s pos fns rbodies env main)
    (flt-defn-p-s (flt-word s pos) s (fp-sym-end s pos) fns rbodies env main))
(defn flt-defn-p-s (name s pos fns rbodies env main)
    (flt-defn-p2-s name s (flt-params s (add (fp-skip s pos) 1)) fns rbodies env main))
(defn flt-defn-p2-s (name s pe fns rbodies env main)
    (flt-defn-p3-s name s pe fns rbodies env main
                   (flt-defn-sig name (len (nth pe 0)) fns)))
(defn flt-defn-p3-s (name s pe fns rbodies env main row)
    (flt-defn-b-s s (nth pe 1)
                  (flt-defn-fns row fns)
                  (flt-env-append
                      (flt-penv (nth pe 0) (len (nth pe 0)) 0)
                      (cons (list (flt-recq) (flt-defn-recursive name s (nth pe 1)))
                            (cons (list (flt-fidxq) (nth row 1)) env)))
                  rbodies env main))
(defn flt-defn-b-s (s pos fns benv rbodies env main)
    (flt-defn-b-s-disp (flt-factory-parse s pos fns benv) s pos fns benv rbodies env main))
(defn flt-defn-b-s-disp (fac s pos fns benv rbodies env main)
    (if (eq (len fac) 0)
        (flt-defn-b2-s s pos (flt-expr s pos fns benv) fns rbodies env main)
        (flt-items-s s (nth fac 2) fns (cons (nth fac 1) (cons (nth fac 0) rbodies)) env main)))
(defn flt-defn-b2-s (s pos be fns rbodies env main)
    (flt-defn-done-s s (flt-count-lets s pos (fp-close s (nth be 1))) be fns rbodies env main))
(defn flt-defn-done-s (s k be fns rbodies env main)
    (flt-items-s s (fp-close s (nth be 1)) fns (cons (flt-reserve-wrap-k k (nth be 0)) rbodies) env main))
(defn flt-let-s (s pos fns rbodies env main)
    (flt-let-n-s s (fp-skip s (fp-sym-end s (fp-skip s (add pos 1)))) fns rbodies env main))
(defn flt-let-n-s (s pos fns rbodies env main)
    (flt-let-v-s (flt-word s pos) s (fp-sym-end s pos) fns rbodies env main))
(defn flt-let-v-s (name s pos fns rbodies env main)
    (flt-let-store-s name s (flt-expr s pos fns env) fns rbodies env main (flt-slot env)))
(defn flt-let-store-s (name s ve fns rbodies env main slot)
    (flt-let-store-rest-s
        (fk-store slot (nth ve 0))
        (flt-items-s s (fp-close s (nth ve 1)) fns rbodies
                     (cons (list name (fk-load slot)) env) main)))
(defn flt-let-store-rest-s (store rest)
    (list (nth rest 0) (nth rest 1) (flt-sequence store (nth rest 2)) (nth rest 3) (nth rest 4)))

; one source file's (do ...) — returns (fns rbodies main endpos env); env is
; seeded with the program's string pool under the quote-name, then threaded
; across module sources so top-level constants remain visible to bands.
; Register all top-level function signatures in this source before bodies parse.
; The regular walkers allow forward references; the fourth-arm flattener must
; carry the same contract for mutually recursive compiler recipes.
(defn flt-sig-scan (s pos fns) (flt-sig-scan-at s (fp-skip s pos) fns))
(defn flt-sig-scan-at (s pos fns)
    (if (ge pos (fp-len s)) fns
        (if (eq (fp-at s pos) 34)
            (flt-sig-scan s (add (flt-strend s (add pos 1)) 1) fns)
            (if (and (eq (fp-at s pos) 40)
                     (str_eq (flt-word s (fp-skip s (add pos 1))) "defn"))
                (flt-sig-defn s pos fns)
                (flt-sig-scan s (flt-scan-adv s pos) fns)))))
(defn flt-sig-defn (s pos fns)
    (flt-sig-defn-n s (fp-skip s (fp-sym-end s (fp-skip s (add pos 1)))) fns))
(defn flt-sig-defn-n (s pos fns)
    (flt-sig-defn-p (flt-word s pos) s (fp-sym-end s pos) fns))
(defn flt-sig-defn-p (name s pos fns)
    (flt-sig-defn-done name s (flt-params s (add (fp-skip s pos) 1)) fns))
(defn flt-sig-defn-done (name s pe fns)
    (flt-sig-scan s (nth pe 1) (cons (list name (add (len fns) 1) (len (nth pe 0))) fns)))

(defn flt-top (s fns rbodies pool)
    (flt-top-env s fns rbodies pool (list)))
(defn flt-top-env (s fns rbodies pool env)
    (flt-top2 s (fp-skip s 0) (flt-sig-scan s 0 fns) rbodies pool env))
(defn flt-top2 (s pos fns rbodies pool env)
    (flt-items s (flt-top-pos s pos) fns rbodies
               (flt-env-append (list (list (flt-poolq) pool)) env) (fk-lit 0)))
(defn flt-top-env-snap (s fns rbodies pool env)
    (flt-top2-snap s (fp-skip s 0) (flt-sig-scan s 0 fns) rbodies pool env))
(defn flt-top2-snap (s pos fns rbodies pool env)
    (flt-items-s s (flt-top-pos s pos) fns rbodies
                 (flt-env-append (list (list (flt-poolq) pool)) env) (fk-lit 0)))
(defn flt-top-pos (s pos)
    (if (ge pos (fp-len s)) pos
        (if (and (eq (fp-at s pos) 40)
                 (str_eq (flt-word s (fp-skip s (add pos 1))) "do"))
            (fp-sym-end s (fp-skip s (add pos 1)))
            pos)))

; ── the pool pre-pass: walk the source once (token jumps, comments and
;    whitespace through fp-skip) and intern every DISTINCT "literal" in
;    first-appearance order — the same order the parser meets them, so a
;    literal's pool index is stable between flatten and serialization ──────
(defn flt-scan (s pos acc) (flt-scan-at s (fp-skip s pos) acc))
(defn flt-scan-at (s pos acc)
    (if (ge pos (fp-len s)) acc
        (if (eq (fp-at s pos) 34) (flt-scan-lit s (add pos 1) acc)
            (if (fp-isdigit (fp-at s pos)) (flt-scan-num s pos acc)
            (if (and (eq (fp-at s pos) 45) (fp-isdigit (fp-at s (add pos 1))))
                (flt-scan-neg-num s pos acc)
            (flt-scan s (flt-scan-adv s pos) acc))))))
(defn flt-scan-adv (s pos)
    (if (gt (fp-sym-end s pos) pos) (fp-sym-end s pos) (add pos 1)))
(defn flt-scan-lit (s pos acc)
    (flt-scan-lit2 s (flt-strend s pos) (substring s pos (flt-strend s pos)) acc))
(defn flt-scan-lit2 (s end lit acc) (flt-scan s (add end 1) (flt-pool-add acc (flt-unescape lit))))
(defn flt-scan-num (s pos acc) (flt-scan-num2 s pos (fp-digits s pos 0) acc))
(defn flt-scan-neg-num (s pos acc) (flt-scan-num2 s pos (fp-digits s (add pos 1) 0) acc))
(defn flt-scan-num2 (s pos ve acc)
    (if (and (lt (nth ve 1) (fp-len s))
             (and (eq (fp-at s (nth ve 1)) 46)
                  (fp-isdigit (fp-at s (add (nth ve 1) 1)))))
        (flt-scan-float s pos (flt-float-end s (add (nth ve 1) 1)) acc)
        (if (eq (flt-has-exp s (nth ve 1)) 1)
            (flt-scan-float s pos (flt-fe-exp s (add (nth ve 1) 1) (nth ve 1)) acc)
            (flt-scan s (nth ve 1) acc))))
(defn flt-scan-float (s pos end acc)
    (flt-scan s end (flt-pool-add acc (substring s pos end))))
(defn flt-pool-add (pool lit)
    (if (ge (flt-sidx pool lit 0) 0) pool (flt-append pool lit)))
(defn flt-append (xs x)
    (if (eq (len xs) 0) (cons x (list)) (cons (head xs) (flt-append (tail xs) x))))

; ── entry doors ────────────────────────────────────────────────────────────
; module source + band source -> the walker's function list (fn 0 = the
; band's verdict expression; module/band defns at their CALL indices)
; (local reverse keeps this lane core.fk-free — the audit's emit drivers
; load plain-Form preludes only)
(defn flt-rev (xs acc)
    (if (eq (len xs) 0) acc (flt-rev (tail xs) (cons (head xs) acc))))
; the pool doors mirror the fns doors: the SAME scan order feeds both, so a
; SLIT row's index always names the right string-section entry
(defn flt-band-pool (modsrc bandsrc) (flt-scan bandsrc 0 (flt-scan modsrc 0 (list))))
(defn flt-src-pool (src) (flt-scan src 0 (list)))
(defn flt-srcs-pool (srcs acc)
    (if (eq (len srcs) 0) acc
        (flt-srcs-pool (tail srcs) (flt-scan (head srcs) 0 acc))))
(defn flt-band-sources-pool (modsrcs bandsrc)
    (flt-scan bandsrc 0 (flt-srcs-pool modsrcs (list))))
(defn flt-band-fns (modsrc bandsrc)
    (flt-band-fns2 modsrc bandsrc (flt-band-pool modsrc bandsrc)))
(defn flt-band-fns2 (modsrc bandsrc pool)
    (flt-band2 (flt-top modsrc (list) (list) pool) bandsrc pool))
(defn flt-band2 (mr bandsrc pool)
    (flt-band3 bandsrc (flt-top-env-snap bandsrc (nth mr 0) (nth mr 1) pool (nth mr 4))))
(defn flt-band3 (bandsrc br)
    (cons (flt-reserve-wrap-k (flt-count-lets bandsrc 0 (str_len bandsrc)) (nth br 2))
          (flt-rev (nth br 1) (list))))
(defn flt-modsrcs-top (modsrcs fns rbodies pool)
    (flt-modsrcs-top-env modsrcs fns rbodies pool (list)))
(defn flt-modsrcs-top-env (modsrcs fns rbodies pool env)
    (if (eq (len modsrcs) 0) (list fns rbodies (fk-lit 0) 0 env)
        (flt-modsrcs-top2 (flt-top-env (head modsrcs) fns rbodies pool env) (tail modsrcs) pool)))
(defn flt-modsrcs-top2 (mr rest pool)
    (flt-modsrcs-top-env rest (nth mr 0) (nth mr 1) pool (nth mr 4)))
(defn flt-band-sources-fns (modsrcs bandsrc)
    (flt-band-sources-fns2 modsrcs bandsrc (flt-band-sources-pool modsrcs bandsrc)))
(defn flt-band-sources-fns2 (modsrcs bandsrc pool)
    (flt-band2 (flt-modsrcs-top modsrcs (list) (list) pool) bandsrc pool))

; Compatibility door: older bands pass one list whose last source is the
; band and whose earlier sources are modules. Keep it as a stable recipe
; while new callers use the explicit band-sources door.
(defn flt-srcs-mods (srcs acc)
    (if (eq (len srcs) 0) acc
        (if (eq (len (tail srcs)) 0) acc
            (flt-srcs-mods (tail srcs) (flt-append acc (head srcs))))))
(defn flt-srcs-last (srcs)
    (if (eq (len (tail srcs)) 0) (head srcs) (flt-srcs-last (tail srcs))))
(defn flt-srcs-fns (srcs)
    (if (eq (len srcs) 0) (list)
        (flt-band-sources-fns (flt-srcs-mods srcs (list)) (flt-srcs-last srcs))))

; single-source door (prelude-free bands, mini programs)
(defn flt-src-fns (src) (flt-band3 src (flt-top src (list) (list) (flt-src-pool src))))
