; form-pe-coff.fk - PE/COFF x64 object wrapper for Windows native recipe DLLs.
;
; This is the Windows x86_64 twin of form-macho's recipe-object floor. It wraps
; caller-supplied x64 machine-code bytes in a minimal COFF object with one .text
; section and one external function symbol. A host linker carrier such as
; lld-link turns the object into a loadable DLL; the kernel keeps the linker and
; LoadLibrary/GetProcAddress as dumb host carriers while the object bytes are a
; Form recipe.
;
; The executable byte rules are kept as source-level BML functions. The public
; floor is a generic native object emitter class so recipes can swap host lanes
; behind a stable object-producing contract instead of reaching for raw helpers.

section [form.bml] {
    def pe-nil?(xs) = eq(len(xs), 0);

    def pe-app(xs, ys) {
        if pe-nil?(xs) then ys else cons(head(xs), pe-app(tail(xs), ys));
    }

    def pe-cat(xss) {
        if eq(len(xss), 0) then empty else if eq(len(xss), 1) then head(xss) else pe-app(head(xss), pe-cat(tail(xss)));
    }

    def pe-zeroes(n) {
        if le(n, 0) then empty else cons(0, pe-zeroes(sub(n, 1)));
    }

    def pe-u16(n) = list(mod(n, 256), mod(div(n, 256), 256));

    def pe-u32(n) {
        list(
            mod(n, 256),
            mod(div(n, 256), 256),
            mod(div(n, 65536), 256),
            mod(div(n, 16777216), 256));
    }

    def pe-code-off() = 60;

    def pe-sym-off(clen) = add(pe-code-off(), clen);

    def pe-text-characteristics() = 1615855648;

    def pe-coff-header(clen) {
        pe-cat(list(
            pe-u16(34404),
            pe-u16(1),
            pe-u32(0),
            pe-u32(pe-sym-off(clen)),
            pe-u32(1),
            pe-u16(0),
            pe-u16(0)));
    }

    def pe-section-text(clen) {
        pe-cat(list(
            list(46, 116, 101, 120, 116, 0, 0, 0),
            pe-u32(0),
            pe-u32(0),
            pe-u32(clen),
            pe-u32(pe-code-off()),
            pe-u32(0),
            pe-u32(0),
            pe-u16(0),
            pe-u16(0),
            pe-u32(pe-text-characteristics())));
    }

    def pe-name8(name) = pe-app(name, pe-zeroes(sub(8, len(name))));

    def pe-symbol-external-function(name) {
        pe-cat(list(
            pe-name8(name),
            pe-u32(0),
            pe-u16(1),
            pe-u16(32),
            list(2, 0)));
    }

    def pe-empty-string-table() = pe-u32(4);

    def pe-coff-object-sym(code, name) {
        pe-cat(list(
            pe-coff-header(len(code)),
            pe-section-text(len(code)),
            code,
            pe-symbol-external-function(name),
            pe-empty-string-table()));
    }

    def pe-x64-recipe-symbol() = list(114, 101, 99, 105, 112, 101);

    def pe-x64-recipe-mul3-add7-code() = list(72, 141, 68, 73, 7, 195);

    def pe-x64-recipe-mul5-add1-code() = list(72, 141, 68, 137, 1, 195);

    def pe-x64-recipe-add42-code() = list(72, 141, 65, 42, 195);

    def pe-recipe-object(code) = pe-coff-object-sym(code, pe-x64-recipe-symbol());

    ; ── Windows-arm64 twin: the SAME COFF container with one field flipped — the machine
    ; constant 0x8664 (AMD64) -> 0xAA64 (ARM64). Everything else (section, symbol, string
    ; table) is the x64 path's, reused verbatim; the payload is real arm64 recipe bytes.
    ; This closes form-pe-coff-arm64-pending (the .o object door); turning the object into a
    ; loadable arm64 DLL still needs a host linker carrier (form-pe-arm64-exec-pending).
    def pe-arm64-coff-header(clen) {
        pe-cat(list(
            pe-u16(43620),
            pe-u16(1),
            pe-u32(0),
            pe-u32(pe-sym-off(clen)),
            pe-u32(1),
            pe-u16(0),
            pe-u16(0)));
    }

    def pe-arm64-coff-object-sym(code, name) {
        pe-cat(list(
            pe-arm64-coff-header(len(code)),
            pe-section-text(len(code)),
            code,
            pe-symbol-external-function(name),
            pe-empty-string-table()));
    }

    ; a real arm64 leaf: mov w0, #42 (0x52800540) ; ret (0xd65f03c0), little-endian bytes.
    def pe-arm64-recipe-ret42-code() = list(64, 5, 128, 82, 192, 3, 95, 214);

    def pe-arm64-recipe-object(code) = pe-arm64-coff-object-sym(code, pe-x64-recipe-symbol());

    template NativeObjectEmitter<TCode, TObject> {
        member target: HostTarget;
        member abi: CallingConvention;
        member symbol: ExportSymbol;
    }

    class WindowsX64RecipeEmitter : NativeObjectEmitter<X64MachineCode, PeCoffObject> {
        def target() {
            "windows-x86_64";
        }

        def abi() {
            "windows-x64-i64-to-i64";
        }

        def symbol() {
            pe-x64-recipe-symbol();
        }

        def object_for(code) {
            pe-recipe-object(code);
        }

        def object_for_symbol(code, name) {
            pe-coff-object-sym(code, name);
        }

        def code_mul3_add7() {
            pe-x64-recipe-mul3-add7-code();
        }

        def code_mul5_add1() {
            pe-x64-recipe-mul5-add1-code();
        }

        def code_add42() {
            pe-x64-recipe-add42-code();
        }
    }
}
