; grammars/audio-bmf.fk - audio formats as Form-native objects and BMF rules
;
; The kernel provides byte/file access only. Container sensing, metadata
; lifting, and reverse source emission live here as ordinary Form recipes.

(do
    (let AUDIO-FILE (bp "AUDIO-FILE"))
    (let AUDIO-META-FILE (bp "AUDIO-META-FILE"))

    (defn audio-src-keyword (value) (bmf-atom "audio-keyword" value))
    (defn audio-src-int (value) (bmf-atom "audio-int" value))
    (defn audio-src-string (value) (bmf-atom "audio-string" value))

    (defn audio-kw (value) (object-lit "audio-keyword" value))
    (defn audio-int-lit (capture-name) (list "capture" capture-name (object-lit "audio-int" "")))
    (defn audio-string-lit (capture-name) (list "capture" capture-name (object-lit "audio-string" "")))

    (defn audio-cap (objects capture-name)
        (bmf-collection-value objects capture-name))

    (defn audio-format-media-type (format)
        (if (str_eq format "wav") "audio/wav"
        (if (str_eq format "mp3") "audio/mpeg"
        (if (str_eq format "flac") "audio/flac"
        (if (str_eq format "ogg") "audio/ogg"
        (if (str_eq format "aiff") "audio/aiff"
        (if (str_eq format "m4a") "audio/mp4"
        (if (str_eq format "aac") "audio/aac"
        (if (str_eq format "id3") "application/id3"
            (bmf-media-octet-stream))))))))))

    (defn audio-symbol-context (format codec lens bindings)
        (bmf-standard-symbol-context (bmf-domain-audio) lens bindings
            (empty)
            (bmf-domain-properties (bmf-semantic-audio) "" (bmf-lens-metadata) (bmf-environment-file) "" (bmf-purpose-representation) "")
            (bmf-media-properties
                (audio-format-media-type format)
                ""
                (bmf-encoding-binary)
                format
                codec
                (bmf-unit-samples)
                "")
            (bmf-provenance-properties "" "" "" "" "")))

    (defn audio-file (format sample-rate channels bits)
        (intern_node AUDIO-FILE
                     (list (intern_trivial_string format)
                           (intern_trivial_int sample-rate)
                           (intern_trivial_int channels)
                           (intern_trivial_int bits))))

    (defn audio-meta-file (format sample-rate channels bits metadata)
        (intern_node AUDIO-META-FILE
                     (list (intern_trivial_string format)
                           (intern_trivial_int sample-rate)
                           (intern_trivial_int channels)
                           (intern_trivial_int bits)
                           (intern_trivial_string metadata))))

    (defn audio-kids (object)
        (node_children (bmf-object-value object)))

    (defn audio-format-node (object) (nth (audio-kids object) 0))
    (defn audio-sample-rate-node (object) (nth (audio-kids object) 1))
    (defn audio-channels-node (object) (nth (audio-kids object) 2))
    (defn audio-bits-node (object) (nth (audio-kids object) 3))
    (defn audio-metadata-node (object) (nth (audio-kids object) 4))

    (defn audio-emit (format objects)
        (audio-file format
                    (str_to_int (audio-cap objects "sample_rate"))
                    (str_to_int (audio-cap objects "channels"))
                    (str_to_int (audio-cap objects "bits"))))

    (defn audio-emit-wav (objects) (audio-emit "wav" objects))
    (defn audio-emit-mp3 (objects) (audio-emit "mp3" objects))
    (defn audio-emit-flac (objects) (audio-emit "flac" objects))
    (defn audio-emit-ogg (objects) (audio-emit "ogg" objects))
    (defn audio-emit-aiff (objects) (audio-emit "aiff" objects))
    (defn audio-emit-m4a (objects) (audio-emit "m4a" objects))
    (defn audio-emit-aac (objects) (audio-emit "aac" objects))

    (defn audio-source (format object)
        (list (audio-src-keyword format)
              (audio-src-int (int_to_str (node_value (audio-sample-rate-node object))))
              (audio-src-keyword "hz")
              (audio-src-int (int_to_str (node_value (audio-channels-node object))))
              (audio-src-keyword "channels")
              (audio-src-int (int_to_str (node_value (audio-bits-node object))))
              (audio-src-keyword "bits")))

    (defn audio-source-wav (object) (audio-source "wav" object))
    (defn audio-source-mp3 (object) (audio-source "mp3" object))
    (defn audio-source-flac (object) (audio-source "flac" object))
    (defn audio-source-ogg (object) (audio-source "ogg" object))
    (defn audio-source-aiff (object) (audio-source "aiff" object))
    (defn audio-source-m4a (object) (audio-source "m4a" object))
    (defn audio-source-aac (object) (audio-source "aac" object))

    (defn audio-emit-meta (format objects)
        (audio-meta-file format
                         (str_to_int (audio-cap objects "sample_rate"))
                         (str_to_int (audio-cap objects "channels"))
                         (str_to_int (audio-cap objects "bits"))
                         (audio-cap objects "metadata")))

    (defn audio-emit-flac-metadata (objects) (audio-emit-meta "flac" objects))
    (defn audio-emit-ogg-metadata (objects) (audio-emit-meta "ogg" objects))

    (defn audio-emit-id3-metadata (objects)
        (audio-meta-file "id3" 0 0 0 (audio-cap objects "metadata")))

    (defn audio-source-meta (format object)
        (list (audio-src-keyword format)
              (audio-src-int (int_to_str (node_value (audio-sample-rate-node object))))
              (audio-src-keyword "hz")
              (audio-src-int (int_to_str (node_value (audio-channels-node object))))
              (audio-src-keyword "channels")
              (audio-src-int (int_to_str (node_value (audio-bits-node object))))
              (audio-src-keyword "bits")
              (audio-src-keyword "metadata")
              (audio-src-string (node_value (audio-metadata-node object)))))

    (defn audio-source-flac-metadata (object) (audio-source-meta "flac" object))
    (defn audio-source-ogg-metadata (object) (audio-source-meta "ogg" object))

    (defn audio-source-id3-metadata (object)
        (list (audio-src-keyword "id3")
              (audio-src-keyword "metadata")
              (audio-src-string (node_value (audio-metadata-node object)))))

    (let audio-bmf-native-section
        (list
            (bmf-native "audio-emit-wav" audio-emit-wav AUDIO-FILE)
            (bmf-native "audio-emit-mp3" audio-emit-mp3 AUDIO-FILE)
            (bmf-native "audio-emit-flac" audio-emit-flac AUDIO-FILE)
            (bmf-native "audio-emit-ogg" audio-emit-ogg AUDIO-FILE)
            (bmf-native "audio-emit-aiff" audio-emit-aiff AUDIO-FILE)
            (bmf-native "audio-emit-m4a" audio-emit-m4a AUDIO-FILE)
            (bmf-native "audio-emit-aac" audio-emit-aac AUDIO-FILE)
            (bmf-native "audio-emit-flac-metadata" audio-emit-flac-metadata AUDIO-META-FILE)
            (bmf-native "audio-emit-ogg-metadata" audio-emit-ogg-metadata AUDIO-META-FILE)
            (bmf-native "audio-emit-id3-metadata" audio-emit-id3-metadata AUDIO-META-FILE)))

    section [audio.bmf] {
      wav ::= "wav" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-wav <= audio-source-wav;
      mp3 ::= "mp3" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-mp3 <= audio-source-mp3;
      flac ::= "flac" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-flac <= audio-source-flac;
      ogg ::= "ogg" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-ogg <= audio-source-ogg;
      aiff ::= "aiff" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-aiff <= audio-source-aiff;
      m4a ::= "m4a" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-m4a <= audio-source-m4a;
      aac ::= "aac" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" => audio-emit-aac <= audio-source-aac;
      flac-metadata ::= "flac" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" "metadata" $metadata:string => audio-emit-flac-metadata <= audio-source-flac-metadata;
      ogg-metadata ::= "ogg" $sample_rate:int "hz" $channels:int "channels" $bits:int "bits" "metadata" $metadata:string => audio-emit-ogg-metadata <= audio-source-ogg-metadata;
      id3-metadata ::= "id3" "metadata" $metadata:string => audio-emit-id3-metadata <= audio-source-id3-metadata;
    }

    (defn audio-bmf-rule-name (r) (head r))

    (defn audio-bmf-find-rule (rule-name rules)
        (if (nil? rules) (empty)
            (if (str_eq (audio-bmf-rule-name (head rules)) rule-name)
                (head rules)
                (audio-bmf-find-rule rule-name (tail rules)))))

    (defn apply-audio-bmf-rule (rule-name object-stream)
        (apply-object-rule
            (audio-bmf-find-rule rule-name audio-bmf-rules)
            object-stream))

    (let audio-form-source
        (form-source "audio" (list audio-bmf-second)))

    (let audio-bmf-dialect
        (bmf-dialect "audio"
                     (form-section-object audio-bmf-second)
                     audio-bmf-native-section
                     audio-bmf-rules))

    ;; --- byte format sensing -----------------------------------------

    (defn audio-be16 (bs pos)
        (add (mul (nth bs pos) 256)
             (nth bs (add pos 1))))

    (defn audio-be32 (bs pos)
        (add (mul (nth bs pos) 16777216)
        (add (mul (nth bs (add pos 1)) 65536)
        (add (mul (nth bs (add pos 2)) 256)
             (nth bs (add pos 3))))))

    (defn audio-le16 (bs pos)
        (add (nth bs pos)
             (mul (nth bs (add pos 1)) 256)))

    (defn audio-le32 (bs pos)
        (add (nth bs pos)
        (add (mul (nth bs (add pos 1)) 256)
        (add (mul (nth bs (add pos 2)) 65536)
             (mul (nth bs (add pos 3)) 16777216)))))

    (defn audio-riff-wave? (bs)
        (and (eq (nth bs 0) 82)
        (and (eq (nth bs 1) 73)
        (and (eq (nth bs 2) 70)
        (and (eq (nth bs 3) 70)
        (and (eq (nth bs 8) 87)
        (and (eq (nth bs 9) 65)
        (and (eq (nth bs 10) 86)
             (eq (nth bs 11) 69)))))))))

    (defn audio-id3? (bs)
        (and (eq (nth bs 0) 73)
        (and (eq (nth bs 1) 68)
             (eq (nth bs 2) 51))))

    (defn audio-mp3-frame? (bs)
        (and (eq (nth bs 0) 255)
             (ge (nth bs 1) 224)))

    (defn audio-flac? (bs)
        (and (eq (nth bs 0) 102)
        (and (eq (nth bs 1) 76)
        (and (eq (nth bs 2) 97)
             (eq (nth bs 3) 67)))))

    (defn audio-ogg? (bs)
        (and (eq (nth bs 0) 79)
        (and (eq (nth bs 1) 103)
        (and (eq (nth bs 2) 103)
             (eq (nth bs 3) 83)))))

    (defn audio-aiff? (bs)
        (and (eq (nth bs 0) 70)
        (and (eq (nth bs 1) 79)
        (and (eq (nth bs 2) 82)
        (and (eq (nth bs 3) 77)
        (and (eq (nth bs 8) 65)
        (and (eq (nth bs 9) 73)
        (and (eq (nth bs 10) 70)
             (eq (nth bs 11) 70)))))))))

    (defn audio-m4a? (bs)
        (and (eq (nth bs 4) 102)
        (and (eq (nth bs 5) 116)
        (and (eq (nth bs 6) 121)
        (and (eq (nth bs 7) 112)
        (and (eq (nth bs 8) 77)
        (and (eq (nth bs 9) 52)
             (eq (nth bs 10) 65))))))))

    (defn audio-aac? (bs)
        (and (eq (nth bs 0) 255)
             (or (eq (nth bs 1) 241) (eq (nth bs 1) 249))))

    (defn audio-parse-wav-bytes (bs)
        (if (audio-riff-wave? bs)
            (audio-file "wav"
                        (audio-le32 bs 24)
                        (audio-le16 bs 22)
                        (audio-le16 bs 34))
            (audio-file "unknown" 0 0 0)))

    (defn audio-parse-mp3-bytes (bs)
        (if (or (audio-id3? bs) (audio-mp3-frame? bs))
            (audio-file "mp3" 0 0 0)
            (audio-file "unknown" 0 0 0)))

    (defn audio-parse-flac-bytes (bs)
        (if (audio-flac? bs)
            (audio-file "flac" 0 0 0)
            (audio-file "unknown" 0 0 0)))

    (defn audio-parse-ogg-bytes (bs)
        (if (audio-ogg? bs)
            (audio-file "ogg" 0 0 0)
            (audio-file "unknown" 0 0 0)))

    (defn audio-parse-aiff-bytes (bs)
        (if (audio-aiff? bs)
            (audio-file "aiff"
                        0
                        (audio-be16 bs 20)
                        (audio-be16 bs 26))
            (audio-file "unknown" 0 0 0)))

    (defn audio-parse-m4a-bytes (bs)
        (if (audio-m4a? bs)
            (audio-file "m4a" 0 0 0)
            (audio-file "unknown" 0 0 0)))

    (defn audio-parse-aac-bytes (bs)
        (if (audio-aac? bs)
            (audio-file "aac" 0 0 0)
            (audio-file "unknown" 0 0 0)))

    (defn audio-detect-bytes (bs)
        (if (audio-riff-wave? bs) (audio-parse-wav-bytes bs)
        (if (audio-aac? bs) (audio-parse-aac-bytes bs)
        (if (or (audio-id3? bs) (audio-mp3-frame? bs)) (audio-parse-mp3-bytes bs)
        (if (audio-flac? bs) (audio-parse-flac-bytes bs)
        (if (audio-ogg? bs) (audio-parse-ogg-bytes bs)
        (if (audio-aiff? bs) (audio-parse-aiff-bytes bs)
        (if (audio-m4a? bs) (audio-parse-m4a-bytes bs)
            (audio-file "unknown" 0 0 0)))))))))

    0)
