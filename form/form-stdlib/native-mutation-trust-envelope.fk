; native-mutation-trust-envelope.fk -- mutation trust as carried residual.
;
; Embodied trust here is not prediction-error denial. The compressed route
; model carries its residuals as first-class response data: what moved, what is
; intentionally deferred, and how ordinary traffic remains reversible.
;
; preludes: form-stdlib/core.fk
;
(do
    (defn nmte-cat (xs)
        (if (nil? xs) ""
            (str_concat (head xs) (nmte-cat (tail xs)))))

    (defn nmte-json-string-escape-loop (s i)
        (if (ge i (str_len s))
            ""
            (str_concat (char_at s i) (nmte-json-string-escape-loop s (add i 1)))))

    (defn nmte-json-string (s)
        (str_concat "\"" (str_concat (nmte-json-string-escape-loop s 0) "\"")))

    (defn nmte-side-effect-intents-json ()
        (nmte-cat (list
            "["
            "{\"name\":\"cache-invalidation\",\"surface\":\"ideas/specs/translation-read-caches\",\"mode\":\"intent-carried\"}"
            ",{\"name\":\"parent-edge-repair\",\"surface\":\"idea-parent-child-graph\",\"mode\":\"intent-carried\"}"
            ",{\"name\":\"contributor-key-audit\",\"surface\":\"contributor_api_keys.last_used_at\",\"mode\":\"intent-carried\"}"
            ",{\"name\":\"rollback-receipt\",\"surface\":\"native-mutation-front-door\",\"mode\":\"intent-carried\"}"
            "]")))

    (defn nmte-reversible-gate-json ()
        (nmte-cat (list
            "{\"default_route\":\"native-kernel\""
            ",\"default_protocol\":\"implicit-native-invitation\""
            ",\"native_route\":\"X-Form-Native-Preview\""
            ",\"fallback_route\":\"X-Form-Python-Fallback\""
            ",\"ordinary_traffic_flip_allowed\":true"
            ",\"ordinary_traffic_flip_performed\":true"
            ",\"rollback\":\"send X-Form-Python-Fallback, remove the default native route row, or retarget Traefik to api\""
            "}")))

    (defn nmte-trust-envelope-json (operation node-id)
        (nmte-cat (list
            "{\"state\":\"embodied-trust-preview\""
            ",\"operation\":" (nmte-json-string operation)
            ",\"node_id\":" (nmte-json-string node-id)
            ",\"choice_success\":1"
            ",\"silence\":\"not-knowing-is-native-invitation\""
            ",\"protocol\":\"X-Form-Native-Preview\""
            ",\"fail\":\"explicit-python-fallback\""
            ",\"stop\":\"native-default-observed\""
            ",\"bma\":\"native-mutation-trust-envelope\""
            ",\"prediction_error\":\"carried_as_residual\""
            ",\"residual\":\"side effects are named while no-header kernel traffic accepts native by default; explicit fallback remains observable\""
            ",\"side_effect_intents\":" (nmte-side-effect-intents-json)
            ",\"reversible_gate\":" (nmte-reversible-gate-json)
            "}")))

    (defn nmte-match-at? (s needle i j)
        (if (eq j (str_len needle))
            1
            (if (ge (add i j) (str_len s))
                0
                (if (str_eq (char_at s (add i j)) (char_at needle j))
                    (nmte-match-at? s needle i (add j 1))
                    0))))

    (defn nmte-contains-loop? (s needle i)
        (if (gt i (sub (str_len s) (str_len needle)))
            0
            (if (eq (nmte-match-at? s needle i 0) 1)
                1
                (nmte-contains-loop? s needle (add i 1)))))

    (defn nmte-contains? (s needle)
        (if (eq (str_len needle) 0)
            1
            (if (lt (str_len s) (str_len needle))
                0
                (nmte-contains-loop? s needle 0))))

    (defn nmte-and2 (a b) (if (eq a 1) (if (eq b 1) 1 0) 0))
    (defn nmte-and3 (a b c) (nmte-and2 (nmte-and2 a b) c))

    ;; 1111 = residual carried, side-effect intents named, reversible gate held,
    ;; and ordinary traffic explicitly native-default/reversible.
    (defn nmte-test ()
        (do
            (let envelope (nmte-trust-envelope-json "update-idea" "idea-trust"))
            (sum (list
                (if (eq (nmte-contains? envelope "\"prediction_error\":\"carried_as_residual\"") 1) 1 0)
                (if (eq (nmte-and3
                    (nmte-contains? envelope "\"cache-invalidation\"")
                    (nmte-contains? envelope "\"parent-edge-repair\"")
                    (nmte-contains? envelope "\"contributor-key-audit\"")) 1) 10 0)
                (if (eq (nmte-and3
                    (nmte-contains? envelope "\"default_route\":\"native-kernel\"")
                    (nmte-contains? envelope "\"native_route\":\"X-Form-Native-Preview\"")
                    (nmte-contains? envelope "\"rollback\"")) 1) 100 0)
                (if (eq (nmte-and2
                    (nmte-contains? envelope "\"ordinary_traffic_flip_allowed\":true")
                    (nmte-contains? envelope "\"ordinary_traffic_flip_performed\":true")) 1) 1000 0)
                (if (eq (nmte-and3
                    (nmte-contains? envelope "\"choice_success\":1")
                    (nmte-contains? envelope "\"stop\":\"native-default-observed\"")
                    (nmte-contains? envelope "\"bma\":\"native-mutation-trust-envelope\"")) 1) 10000 0)))))

    0)
