; sovereign-boundary-protocol.fk - reusable allow/stop/witness/re-entry rule.
;
; preludes: form-stdlib/core.fk form-stdlib/choice-receipt.fk
;
; A boundary is an offered interface plus a protocol. Observation is always
; allowed. Communication can stop when reach passes the interface or protocol.
; Re-entry is available when trusted repair evidence restores enough vitality.
;
; Ported 2026-07-17 from the BML section dialect to s-expr so the fkwu --src
; door can walk it directly; semantics preserved one-for-one (git history
; carries the BML original). The two tags are the registered Blueprint
; coordinates from form-stdlib/blueprint-registry.json — the same NodeIDs the
; BML `bp` door resolved:
;   SOVEREIGN-BOUNDARY-EVIDENCE  (pkg 1, level 2, type 99, inst 17)
;   SOVEREIGN-BOUNDARY-RECEIPT   (pkg 1, level 2, type 99, inst 16)

(let sbp_tag_evidence (make_nodeid 1 2 99 17))
(let sbp_tag_receipt (make_nodeid 1 2 99 16))

(defn sbp-category () "SOVEREIGN-BOUNDARY-PROTOCOL")
(defn sbp-choice-allow () "allow")
(defn sbp-choice-stop () "stop")
(defn sbp-choice-witness () "witness")
(defn sbp-choice-re-enter () "re_enter")
(defn sbp-reach-within-interface () "within_interface")
(defn sbp-reach-past-interface () "past_interface")
(defn sbp-reach-unknown () "unknown")

(defn sbp-bool-score (ok score) (if ok score 0))
(defn sbp-tagged? (value tag arity)
    (if (eq (len value) arity) (node_eq (nth value 0) tag) false))
(defn sbp-nonempty-string? (value) (gt (str_len value) 0))

(defn sbp-evidence (subject offered-interface protocol reach consent violation trusted-witness repair-evidence repair-threshold vitality certainty started-at-tick evidence-started-at-tick evidence-ended-at-tick)
    (list sbp_tag_evidence subject offered-interface protocol reach consent violation trusted-witness repair-evidence repair-threshold vitality certainty started-at-tick evidence-started-at-tick evidence-ended-at-tick))
(defn sbp-evidence? (e) (sbp-tagged? e sbp_tag_evidence 15))
(defn sbp-subject (e) (nth e 1))
(defn sbp-offered-interface (e) (nth e 2))
(defn sbp-protocol (e) (nth e 3))
(defn sbp-reach (e) (nth e 4))
(defn sbp-consent (e) (nth e 5))
(defn sbp-violation (e) (nth e 6))
(defn sbp-trusted-witness (e) (nth e 7))
(defn sbp-repair-evidence (e) (nth e 8))
(defn sbp-repair-threshold (e) (nth e 9))
(defn sbp-vitality (e) (nth e 10))
(defn sbp-certainty (e) (nth e 11))
(defn sbp-started-at (e) (nth e 12))
(defn sbp-evidence-started-at (e) (nth e 13))
(defn sbp-evidence-ended-at (e) (nth e 14))

(defn sbp-consented? (e) (eq (sbp-consent e) 1))
(defn sbp-violation-proven? (e)
    (or (eq (sbp-violation e) 1)
        (str_eq (sbp-reach e) (sbp-reach-past-interface))))
(defn sbp-repair-trusted? (e)
    (and (eq (sbp-trusted-witness e) 1)
         (ge (sbp-repair-evidence e) (sbp-repair-threshold e))))
(defn sbp-can-re-enter? (e)
    (and (sbp-violation-proven? e)
         (and (sbp-repair-trusted? e) (ge (sbp-vitality e) 50))))
(defn sbp-can-allow? (e)
    (and (sbp-consented? e)
         (and (str_eq (sbp-reach e) (sbp-reach-within-interface))
              (if (sbp-violation-proven? e) false true))))
(defn sbp-needs-stop? (e)
    (if (sbp-can-re-enter? e)
        false
        (or (sbp-violation-proven? e)
            (if (sbp-consented? e) false true))))

(defn sbp-choice (e)
    (if (sbp-can-re-enter? e) (sbp-choice-re-enter)
        (if (sbp-needs-stop? e) (sbp-choice-stop)
            (if (sbp-can-allow? e) (sbp-choice-allow) (sbp-choice-witness)))))
(defn sbp-note (e)
    (if (sbp-can-re-enter? e) "trusted repair evidence allows re-entry"
        (if (sbp-needs-stop? e) "boundary stop: reach passed interface/protocol or consent absent"
            (if (sbp-can-allow? e) "within offered interface and protocol"
                "witness without forcing a decision"))))

(defn sbp-candidate-allow (e)
    (cr-choice-candidate (sbp-choice-allow) (sbp-category) (sbp-can-allow? e) 0 90 "within-interface-with-consent"))
(defn sbp-candidate-stop (e)
    (cr-choice-candidate (sbp-choice-stop) (sbp-category) (sbp-needs-stop? e) 100 100 "sovereign-boundary-stop"))
(defn sbp-candidate-witness (e)
    (cr-choice-candidate (sbp-choice-witness) (sbp-category)
        (if (sbp-needs-stop? e) false (if (sbp-can-allow? e) false true))
        10 75 "observe-without-force"))
(defn sbp-candidate-re-enter (e)
    (cr-choice-candidate (sbp-choice-re-enter) (sbp-category) (sbp-can-re-enter? e) 0 100 "trusted-repair-evidence"))
(defn sbp-candidates (e)
    (list (sbp-candidate-allow e) (sbp-candidate-stop e) (sbp-candidate-witness e) (sbp-candidate-re-enter e)))

(defn sbp-trace (e)
    (cr-choice-trace 1 1
        (if (sbp-violation-proven? e) 1 0)
        (if (str_eq (sbp-choice e) (sbp-choice-witness)) 1 0)))
(defn sbp-value (e)
    (cr-choice-value (cr-kind-core-alignment)
        (if (sbp-violation-proven? e) 25 75)
        (sbp-vitality e) (sbp-certainty e) (sbp-certainty e)))
(defn sbp-evidence-valid? (e)
    (if (sbp-evidence? e)
        (and (sbp-nonempty-string? (sbp-subject e))
             (and (sbp-nonempty-string? (sbp-offered-interface e))
                  (and (sbp-nonempty-string? (sbp-protocol e))
                       (and (ge (sbp-repair-evidence e) 0)
                            (and (ge (sbp-repair-threshold e) 0)
                                 (and (ge (sbp-vitality e) 0)
                                      (and (le (sbp-vitality e) 100)
                                           (and (ge (sbp-certainty e) 0)
                                                (le (sbp-certainty e) 100)))))))))
        false))

(defn sbp-choice-receipt (e expression who where)
    (cr-choice-receipt expression (sbp-protocol e) (sbp-category) (sbp-candidates e)
        (sbp-choice e) (cr-outcome-success) (sbp-certainty e) (sbp-value e) (sbp-note e)
        who where (sbp-evidence-ended-at e) 0 (sbp-trace e)))
(defn sbp-boundary-receipt (e expression who where)
    (list sbp_tag_receipt (sbp-choice e) (sbp-note e) e
          (sbp-choice-receipt e expression who where) (sbp-evidence-ended-at e)))
(defn sbp-boundary-receipt? (receipt) (sbp-tagged? receipt sbp_tag_receipt 6))
(defn sbp-boundary-receipt-choice (receipt) (nth receipt 1))
(defn sbp-boundary-receipt-note (receipt) (nth receipt 2))
(defn sbp-boundary-receipt-evidence (receipt) (nth receipt 3))
(defn sbp-boundary-receipt-choice-receipt (receipt) (nth receipt 4))
(defn sbp-boundary-receipt-when (receipt) (nth receipt 5))
(defn sbp-boundary-receipt-valid? (receipt)
    (if (sbp-boundary-receipt? receipt)
        (and (sbp-evidence-valid? (sbp-boundary-receipt-evidence receipt))
             (cr-choice-receipt-valid? (sbp-boundary-receipt-choice-receipt receipt)))
        false))

0
