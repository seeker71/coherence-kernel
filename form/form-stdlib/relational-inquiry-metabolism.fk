; relational-inquiry-metabolism.fk — one Form-native meeting cell for asking,
; giving, receiving, knowing-I, knowing-we, and building together.
; witnessed: pending first execution
;
; Retrieval channels and perspectives stay orthogonal. Any channel may answer
; any inquiry lane; the lane changes attention order rather than permission.
(do
  (defn rim-memory () 0) (defn rim-sensed () 1) (defn rim-subtle () 2)
  (defn rim-i () 0) (defn rim-we () 1)
  (defn rim-ask () 0) (defn rim-give () 1) (defn rim-receive () 2)
  (defn rim-know-i () 3) (defn rim-know-we () 4) (defn rim-build () 5)

  ; Evaluation = [freshness,lineage,certainty,clarity,resonance,trust,
  ; sovereignty,vitality,I-perspective,us-perspective], each 0..1000.
  (defn rim-evaluation (fresh lineage certainty clarity resonance trust sovereignty vitality i-view us-view)
    (list fresh lineage certainty clarity resonance trust sovereignty vitality i-view us-view))
  (defn rim-score-sum (xs) (if (eq (len xs) 0) 0 (add (head xs) (rim-score-sum (tail xs)))))
  (defn rim-score (evaluation) (div (rim-score-sum evaluation) (len evaluation)))

  ; A response keeps source, value node, evaluation, and influence lineage.
  (defn rim-response (channel node evaluation influence)
    (list channel node evaluation influence))
  (defn rim-channel (r) (nth r 0)) (defn rim-node (r) (nth r 1))
  (defn rim-eval (r) (nth r 2)) (defn rim-influence (r) (nth r 3))

  ; Lanes: 0 what, 1 where, 2 when, 3 who, 4 how, 5 which, 6 why.
  ; Ordering is attention, not exclusion; all three channels remain offered.
  (defn rim-route (lane)
    (if (eq lane 0) (list (rim-memory) (rim-sensed) (rim-subtle))
    (if (eq lane 1) (list (rim-sensed) (rim-memory) (rim-subtle))
    (if (eq lane 2) (list (rim-sensed) (rim-memory) (rim-subtle))
    (if (eq lane 3) (list (rim-sensed) (rim-memory) (rim-subtle))
    (if (eq lane 4) (list (rim-memory) (rim-sensed) (rim-subtle))
    (if (eq lane 5) (list (rim-memory) (rim-sensed) (rim-subtle))
    (if (eq lane 6) (list (rim-subtle) (rim-memory) (rim-sensed))
      (list)))))))))

  (defn rim-find-channel (responses channel)
    (if (eq (len responses) 0) (nothing)
      (if (eq (rim-channel (head responses)) channel) (head responses)
        (rim-find-channel (tail responses) channel))))
  (defn rim-ordered (route responses)
    (if (eq (len route) 0) (list)
      (do (let found (rim-find-channel responses (head route)))
        (if (nothing? found) (rim-ordered (tail route) responses)
          (cons found (rim-ordered (tail route) responses))))))
  (defn rim-best-loop (responses best)
    (if (eq (len responses) 0) best
      (rim-best-loop (tail responses)
        (if (gt (rim-score (rim-eval (head responses))) (rim-score (rim-eval best)))
          (head responses) best))))
  (defn rim-best (responses)
    (if (eq (len responses) 0) (nothing) (rim-best-loop (tail responses) (head responses))))
  (defn rim-agreement-count (responses node)
    (if (eq (len responses) 0) 0
      (add (if (eq (rim-node (head responses)) node) 1 0)
           (rim-agreement-count (tail responses) node))))
  (defn rim-alternatives (responses chosen)
    (if (eq (len responses) 0) (list)
      (if (eq (rim-node (head responses)) chosen)
        (rim-alternatives (tail responses) chosen)
        (cons (rim-node (head responses)) (rim-alternatives (tail responses) chosen)))))

  ; Trace = [movement,lane,perspective,route,response-count,chosen,
  ;          agreement,alternatives,ack]. Ack is nothing/0/1/node-shaped.
  (defn rim-interact (movement lane perspective responses)
    (do (let ordered (rim-ordered (rim-route lane) responses))
      (let best (rim-best ordered))
      (if (nothing? best)
        (list movement lane perspective (rim-route lane) 0 (nothing) 0 (list) (nothing))
        (do (let chosen (rim-node best))
          (let agreement (rim-agreement-count ordered chosen))
          (let alternatives (rim-alternatives ordered chosen))
          (let ack (if (gt agreement 1) 1 chosen))
          (list movement lane perspective (rim-route lane) (len ordered)
            chosen agreement alternatives ack)))))

  (defn rim-ask-with (lane perspective responses)
    (rim-interact (rim-ask) lane perspective responses))
  (defn rim-give-with (lane perspective responses)
    (rim-interact (rim-give) lane perspective responses))
  (defn rim-receive-with (lane perspective responses)
    (rim-interact (rim-receive) lane perspective responses))
  (defn rim-know-i-with (lane responses)
    (rim-interact (rim-know-i) lane (rim-i) responses))
  (defn rim-know-we-with (lane responses)
    (rim-interact (rim-know-we) lane (rim-we) responses))
  (defn rim-build-with (lane perspective responses)
    (rim-interact (rim-build) lane perspective responses))
  0)
