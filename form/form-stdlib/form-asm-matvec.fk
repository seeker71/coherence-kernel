; form-asm-matvec.fk — native float compute as Form→asm BYTES, no rustc/clang. The first cell of
; sovereign inference compute: the matvec inner product (a dot) composed from form-asm's f64 instructions
; over a buffer pointer, the way ll-buffer composes alloc/store/load/free. Every instruction is an
; fa-* encoder already byte-identical to the clang oracle (form-asm-float 2047), so a composition of them
; is correct by construction; this recipe proves the COMPOSITION emits the exact program bytes four-way.
;
; fam-dot2: x0 points at four contiguous f64 [a0, a1, b0, b1]; returns d0 = a0*b0 + a1*b1, folded the
; SAME downward order as transformer-block.fk's tb-dot (j = cols-1 .. 0) so the native result is the
; recipe's result bit-for-bit, not epsilon-close. The body:
;   ldr d1,[x0,#8]  ; a1     ldr d2,[x0,#24] ; b1     fmul d0,d1,d2 ; d0 = a1*b1   (j=1)
;   ldr d1,[x0,#0]  ; a0     ldr d2,[x0,#16] ; b0     fmul d1,d1,d2 ; d1 = a0*b0   (j=0)
;   fadd d0,d1,d0   ; d0 = a0*b0 + a1*b1                ret
; (fa-ldr-d takes the SCALED immediate: byte offset / 8, so #8 -> 1, #24 -> 3, #16 -> 2.)
;
; A full matvec is rows of this dot (y[i] = dot(W[i], x)); the row/col loop generalizes fam-dot2 the way
; ll-buf wraps a loop around alloc/store/load/free — the next rung. This is the sovereign native lane:
; form-asm bytes -> form-macho/recipe-dylib -> fkwu dlopen+call over its own f64 pool. rustc's
; jit-tensor-emit matvec is the bootstrap-oracle speed reference only.
;
; preludes: form-stdlib/form-asm.fk
;
; Proven by: form-stdlib/tests/form-asm-matvec-band.fk (four-way; byte-identity vs the ARM/clang oracle)

(do
    (defn fam-dot2 ()
        (append (fa-ldr-d 1 0 1)            ; ldr d1,[x0,#8]   a1
            (append (fa-ldr-d 2 0 3)        ; ldr d2,[x0,#24]  b1
                (append (fa-fmul 0 1 2)     ; fmul d0,d1,d2    d0 = a1*b1
                    (append (fa-ldr-d 1 0 0)    ; ldr d1,[x0,#0]   a0
                        (append (fa-ldr-d 2 0 2)    ; ldr d2,[x0,#16]  b0
                            (append (fa-fmul 1 1 2)     ; fmul d1,d1,d2    d1 = a0*b0
                                (append (fa-fadd 0 1 0) ; fadd d0,d1,d0    d0 = a0*b0 + a1*b1
                                    (fa-ret)))))))))    ; ret

    ; fam-dot-loop: the dot as a LOOP over n elements (the matvec row kernel, no unrolling) — x0=a base,
    ; x1=b base, x2=n; returns d0 = sum_j a[j]*b[j], j=0..n. Pointer-increment so no register-indexed load
    ; is needed; the same instruction family ll-buf uses for its loop, now over f64. Branch offsets are in
    ; INSTRUCTIONS (the lo-streq discipline): b.ge exits +9 to the ret; b loops -9 back to the compare.
    ;   0 movz x3,#0 (j)   1 movz x4,#0   2 scvtf d0,x4 (acc=0.0)
    ;   3 cmp x3,x2   4 b.ge +9(end)   5 ldr d1,[x0]   6 ldr d2,[x1]   7 fmul d3,d1,d2   8 fadd d0,d0,d3
    ;   9 add x0,#8   10 add x1,#8   11 add x3,#1   12 b -9(loop)   13 ret
    ; (Upward fold; tb-dot's exact downward fold for bit-exact-vs-recipe needs register-shifted addressing
    ; — a named follow-up. This proves the LOOP emits four-way; correctness of each instruction is inherited
    ; from form-asm-float/form-asm. A full 2-D matvec wraps an outer row loop around this.)
    (defn fam-dot-loop ()
        (append (fa-movz-x 3 0)
            (append (fa-movz-x 4 0)
                (append (fa-scvtf 0 4)
                    (append (fa-cmp-r 3 2)
                        (append (fa-bcond 10 9)
                            (append (fa-ldr-d 1 0 0)
                                (append (fa-ldr-d 2 1 0)
                                    (append (fa-fmul 3 1 2)
                                        (append (fa-fadd 0 0 3)
                                            (append (fa-add-x-imm 0 0 8)
                                                (append (fa-add-x-imm 1 1 8)
                                                    (append (fa-add-x-imm 3 3 1)
                                                        (append (fa-b-off -9)
                                                            (fa-ret)))))))))))))))

    ; fam-matvec: the FULL 2-D matvec — the outer ROW loop around fam-dot-loop's body, the rung the
    ; header named ("A full matvec is rows of this dot … the next rung"). y[i] = sum_j W[i][j]*x[j],
    ; W row-major m×n contiguous f64. Same upward-counted fold as fam-dot-loop (and bj-dot-fam, its
    ; tree-walker twin) — so the native result is the recipe's result, bit-for-bit. The arm64 ABI is
    ; the natural matvec signature, args in x0..x4: x0=W base (advances across ALL elements row-major,
    ; so after a row it already points at the next row), x1=x base (reset to x7 each row), x2=n cols,
    ; x3=m rows, x4=y out. No register-indexed addressing, no rustc/clang; one program emits the whole
    ; matvec. Branch offsets in INSTRUCTIONS (the lo-streq discipline): inner b.ge +9 / b -9 are
    ; fam-dot-loop's; the new outer offsets are b.ge END +19 and b ROW -19. 23 instructions = 92 bytes.
    ;   0 add x7,x1,#0 (save x base)  1 movz x5,#0 (i=0)
    ;   ROW(2): 2 cmp x5,x3   3 b.ge END(+19)   4 add x1,x7,#0 (reset x ptr)
    ;           5 movz x6,#0 (j=0)   6 movz x8,#0   7 scvtf d0,x8 (acc=0.0)
    ;   INN(8): 8 cmp x6,x2   9 b.ge INNEND(+9)   10 ldr d1,[x0]   11 ldr d2,[x1]
    ;           12 fmul d3,d1,d2   13 fadd d0,d0,d3   14 add x0,#8   15 add x1,#8
    ;           16 add x6,#1   17 b INN(-9)
    ;   INNEND(18): 18 str d0,[x4] (y[i]=acc)   19 add x4,#8   20 add x5,#1   21 b ROW(-19)
    ;   END(22): 22 ret
    (defn fam-matvec ()
        (append (fa-add-x-imm 7 1 0)
            (append (fa-movz-x 5 0)
                (append (fa-cmp-r 5 3)
                    (append (fa-bcond 10 19)
                        (append (fa-add-x-imm 1 7 0)
                            (append (fa-movz-x 6 0)
                                (append (fa-movz-x 8 0)
                                    (append (fa-scvtf 0 8)
                                        (append (fa-cmp-r 6 2)
                                            (append (fa-bcond 10 9)
                                                (append (fa-ldr-d 1 0 0)
                                                    (append (fa-ldr-d 2 1 0)
                                                        (append (fa-fmul 3 1 2)
                                                            (append (fa-fadd 0 0 3)
                                                                (append (fa-add-x-imm 0 0 8)
                                                                    (append (fa-add-x-imm 1 1 8)
                                                                        (append (fa-add-x-imm 6 6 1)
                                                                            (append (fa-b-off -9)
                                                                                (append (fa-str-d 0 4 0)
                                                                                    (append (fa-add-x-imm 4 4 8)
                                                                                        (append (fa-add-x-imm 5 5 1)
                                                                                            (append (fa-b-off -19)
                                                                                                (fa-ret))))))))))))))))))))))))

    ; fam-ss-sqrt: the RMSNorm / LayerNorm reduction CORE as Form->asm bytes — sqrt(sum_j x[j]^2),
    ; the L2 norm (= sqrt(n) * RMS). This is the first NONLINEAR op on the native lane after the matvec:
    ; the gap form-native-models.form names ("exp/sin/cos/rsqrt for softmax/RoPE/RMSNorm/SwiGLU as asm").
    ; The accumulator loop is fam-dot-loop's twin with ONE buffer squared in place (fmul d2,d1,d1), and the
    ; new ground is the trailing fsqrt OUTSIDE the loop (fa-fsqrt, proven byte-exact in form-asm-float 2047)
    ; — a reduction that ends in a transcendental, not just the linear dot. ABI: x0 = x base, w1 = n (the
    ; counter compare rides the 32-bit fa-cmp-r, a count is small), returns d0 = sqrt(sum x^2). 13 arm64
    ; instructions = 52 bytes; branch offsets in INSTRUCTIONS (lo-streq discipline): b.ge exits +7 to the
    ; fsqrt, b loops -7 back to the compare.
    ;   0 movz x3,#0 (j)   1 movz x4,#0   2 scvtf d0,x4 (acc=0.0)
    ;   3 cmp w3,w1   4 b.ge +7(end)   5 ldr d1,[x0]   6 fmul d2,d1,d1 (x^2)   7 fadd d0,d0,d2
    ;   8 add x0,#8   9 add x3,#1   10 b -7(loop)   11 fsqrt d0,d0   12 ret
    (defn fam-ss-sqrt ()
        (append (fa-movz-x 3 0)
            (append (fa-movz-x 4 0)
                (append (fa-scvtf 0 4)
                    (append (fa-cmp-r 3 1)
                        (append (fa-bcond 10 7)
                            (append (fa-ldr-d 1 0 0)
                                (append (fa-fmul 2 1 1)
                                    (append (fa-fadd 0 0 2)
                                        (append (fa-add-x-imm 0 0 8)
                                            (append (fa-add-x-imm 3 3 1)
                                                (append (fa-b-off -7)
                                                    (append (fa-fsqrt 0 0)
                                                        (fa-ret))))))))))))))

    ; fam-rsqrt: the reciprocal-sqrt 1/sqrt(x) as Form->asm bytes — the RMSNorm/RoPE/SwiGLU normalizer
    ; (RMSNorm scale = g / sqrt(mean(x^2)+eps); RoPE inv-freq = 1/base^(2i/d); rsqrt is the shared core).
    ; The next nonlinear rung after fam-ss-sqrt: it closes a transcendental in a RECIPROCAL — the first
    ; fa-fdiv on the witnessed native lane, and the first FLOAT CONSTANT materialized via fa-fmov-imm
    ; (#1.0 = imm8 0x70). Scalar, no loop. ABI: d0 = x, returns d0 = 1/sqrt(x). 4 arm64 instructions = 16
    ; bytes, byte-identical to the clang -O2 oracle for `1.0/__builtin_sqrt(x)`:
    ;   0 fsqrt d0,d0 (1e61c000)   1 fmov d1,#1.0 (1e6e1001)   2 fdiv d0,d1,d0 (1e601820)   3 ret (d65f03c0)
    (defn fam-rsqrt ()
        (append (fa-fsqrt 0 0)
            (append (fa-fmov-imm 1 112)
                (append (fa-fdiv 0 1 0)
                    (fa-ret)))))

    ; fam-horner2: a degree-2 Horner polynomial p(x) = ((2*x + 3)*x + 4) as Form->asm bytes — the FIRST use of
    ; fa-fmadd on the witnessed native lane, and the literal eval engine of every transcendental yet to come.
    ; exp/sin/cos/gelu on the native lane are all polynomial (or rational) approximations; Horner folds a degree-n
    ; poly into n fused multiply-adds, one rounding each — this proves the 2-step fold byte-exact. The coefficients
    ; ride fa-fmov-imm (the float-constant primitive fam-rsqrt opened): 2.0=imm8 0, 3.0=imm8 8, 4.0=imm8 16 — all
    ; VFP-expressible, so no constant pool yet (real exp coeffs like 1/6 will need one; this is the clean floor).
    ; ABI: d0 = x, returns d0 = p(x). 6 arm64 instructions = 24 bytes, byte-identical to the clang -O2 oracle for
    ; `__builtin_fma(__builtin_fma(2.0,x,3.0),x,4.0)`:
    ;   0 fmov d1,#3.0 (1e611001)   1 fmov d2,#2.0 (1e601002)   2 fmadd d1,d0,d2,d1 (1f420401)
    ;   3 fmov d2,#4.0 (1e621002)   4 fmadd d0,d1,d0,d2 (1f400820)   5 ret (d65f03c0)
    (defn fam-horner2 ()
        (append (fa-fmov-imm 1 8)
            (append (fa-fmov-imm 2 0)
                (append (fa-fmadd 1 0 2 1)
                    (append (fa-fmov-imm 2 16)
                        (append (fa-fmadd 0 1 0 2)
                            (fa-ret)))))))

    ; fam-poly-pool: a Horner step p(x) = x*(1/6) + 1/120 as Form->asm bytes — the FIRST self-contained
    ; CONSTANT POOL on the witnessed native lane. fam-horner2 proved the fmadd fold but with VFP-expressible
    ; coefficients (2.0/3.0/4.0); the REAL transcendental coefficients exp/sin/cos need (1/6, 1/120, 1/5040 …)
    ; are NOT VFP-immediate-expressible, so they must live in a literal pool the function carries itself. This
    ; emits two real coefficients appended after `ret` and loads them position-independently via fa-ldr-d-lit
    ; (PC-relative literal load), then folds them with the proven fa-fmadd — the genuine Horner step over a pool,
    ; the thing fam-horner2's own note deferred. ABI: d0 = x, returns d0 = fma(x, 1/6, 1/120). 4 instructions
    ; (16 bytes) + a 16-byte pool of two f64 = 32 bytes, byte-identical to the as/clang assembler oracle:
    ;   0 ldr d1,Lc0 (5c000081, +16)   1 ldr d2,Lc1 (5c0000a2, +20)   2 fmadd d0,d0,d1,d2 (1f410800)   3 ret
    ;   16 .quad 0x3fc5555555555555 (1/6, LE 55 55 55 55 55 55 c5 3f)   24 .quad 0x3f81111111111111 (1/120)
    ; imm19 is the WORD distance from each ldr to its pool slot: d1 @0 -> c0 @16 = 4 words; d2 @4 -> c1 @24 = 5.
    ;
    ; fam-pool-fma: the COEFFICIENT-PARAMETERIZED engine — a Horner step fma(x, a, b) whose two pooled f64 are
    ; COMPUTED FROM THE VALUES a, b by f64-bytes (f64-bytes 127), not hand-typed. This is the core-lift fam-poly-pool's
    ; own kin named (f64-bytes.fk: "a HAND pattern only emits a KNOWN constant"): the coefficients become DATA, so the
    ; pool can carry ANY value — including the irregular-mantissa transcendental constants exp/sin need (ln2, log2e,
    ; 1/5040) that no repeating-nibble hand-pattern can produce. The 16 code bytes are the proven self-contained-pool
    ; shape (ldr d1,+16 / ldr d2,+20 / fmadd d0,d0,d1,d2 / ret); the 16 pool bytes are (f64-bytes a) ++ (f64-bytes b).
    ; ABI: d0 = x, returns d0 = fma(x, a, b). One engine; fam-poly-pool and the exp-coefficient pool are instances.
    (defn fam-pool-fma (a b)
        (append (fa-ldr-d-lit 1 4)
            (append (fa-ldr-d-lit 2 5)
                (append (fa-fmadd 0 0 1 2)
                    (append (fa-ret)
                        (append (f64-bytes a) (f64-bytes b)))))))

    ; fam-poly-pool: the named 1/6,1/120 instance of fam-pool-fma — the coefficients now COMPUTED by f64-bytes,
    ; not the hand byte-lists this once carried. The emitted 32-byte image is byte-identical to before (the
    ; assembler oracle is unchanged); the proof that f64-bytes fills the pool correctly is that byte-identity holds.
    (defn fam-poly-pool () (fam-pool-fma (div 1.0 6.0) (div 1.0 120.0)))

    ; fam-frintn: round-to-nearest-integral (ties to even) of d0 as Form->asm bytes — the range-reduction
    ; ROUNDING floor that exp/softmax need. The native exp lane is k = round(x*log2e), r = x - k*ln2: the
    ; pooled-coefficient fma (fam-pool-fma) carries ln2/log2e, but the k = round(...) step had no encoder —
    ; the only round op on the lane was fcvtzs (truncate toward zero), which rounds half-integers the wrong
    ; way for range reduction. fam-frintn closes that gap with the FIRST fa-frintn (ties-to-even), the
    ; rounding mode exp wants (it keeps |r| <= ln2/2 so the Horner poly converges). ABI: d0 = x, returns
    ; d0 = roundeven(x). 2 instructions = 8 bytes, byte-identical to the clang -O2 oracle for
    ; `__builtin_roundeven(x)`:   0 frintn d0,d0 (1e644000)   1 ret (d65f03c0)
    (defn fam-frintn ()
        (append (fa-frintn 0 0)
            (fa-ret)))

    ; fam-fmov-bits: REINTERPRET the i64 in x0 as the f64 it bit-encodes, as Form->asm bytes — the keystone
    ; the native 2^k/ldexp step needs. exp(x) = 2^k * Horner(r); fam-frintn gives k = round(x*log2e), the
    ; pooled fma gives r, the Horner poly is on the lane — the only missing piece is BUILDING 2^k, which is
    ; (k+1023)<<52 assembled in an integer register then read as an f64. fa-scvtf would give the integer's
    ; VALUE as a float (wrong); fa-fmov-d-x preserves the BITS, so the assembled exponent field becomes the
    ; power of two. ABI: x0 = raw i64 bits, returns d0 = the f64 those bits encode. 2 instructions = 8 bytes,
    ; byte-identical to clang -O2 for `double f(unsigned long x){double d;__builtin_memcpy(&d,&x,8);return d;}`:
    ;   0 fmov d0,x0 (9e670000)   1 ret (d65f03c0)
    (defn fam-fmov-bits ()
        (append (fa-fmov-d-x 0 0)
            (fa-ret)))

    ; fam-exp-reduce: the FIRST COMPOSED transcendental step on the native asm lane — exp's ARGUMENT RANGE
    ; REDUCTION, x -> r = x - round(x*log2e)*ln2, as Form->asm BYTES. exp(x) = 2^k * exp(r) where
    ; k = round(x*log2e) and r = x - k*ln2 in [-ln2/2, ln2/2] (the interval a short Horner poly converges over);
    ; this brick emits the k-and-r half. Every prior asm brick was a single primitive ending in ret; this is the
    ; first that CHAINS the pooled/materialized constant + fmul + frintn + fmadd into a function that computes
    ; real math for arbitrary x. It is the first CONSUMER of fam-fmov-bits' fa-fmov-d-x (#3933) and of the new
    ; fa-mov-imm64: clang -O2 does NOT pool these two constants — it materializes each f64 bit pattern with
    ; movz+3movk into x8 then fmov d,x8 (bit reinterpret), so the byte-exact path is mov-imm64 -> fmov-d-x, not
    ; a literal pool. log2e and -ln2 are the exact range-reduction constants (fam-frintn / fam-pool-fma named
    ; them); pooling -ln2 lets the reduction use fa-fmadd (k*(-ln2)+x = x-k*ln2) rather than a new fmsub encoder.
    ; ABI: d0 = x, returns d0 = r. 15 arm64 instructions / 60 bytes, byte-identical to the clang -O2 oracle for
    ;   double reduce(double x){ double k=__builtin_roundeven(x*0x1.71547652b82fep0);
    ;                            return __builtin_fma(k,-0x1.62e42fefa39efp-1,x); }
    (defn fam-exp-reduce ()
        (append (fa-mov-imm64 8 (f64-bytes 1.4426950408889634))      ; x8 = log2e bits
            (append (fa-fmov-d-x 1 8)                                 ; d1 = log2e
                (append (fa-fmul 1 0 1)                               ; d1 = x*log2e
                    (append (fa-frintn 1 1)                          ; d1 = k = round(x*log2e)
                        (append (fa-mov-imm64 8 (f64-bytes -0.6931471805599453))  ; x8 = (-ln2) bits
                            (append (fa-fmov-d-x 2 8)                ; d2 = -ln2
                                (append (fa-fmadd 0 1 2 0)          ; d0 = k*(-ln2)+x = x - k*ln2 = r
                                    (fa-ret)))))))))

    ; fam-relu: the rectified-linear ACTIVATION relu(x) = max(x, 0) as Form->asm bytes — the first NONLINEARITY
    ; on the native lane. Every transformer/MLP block needs a nonlinearity; relu is the simplest, and it is one
    ; fmax against zero. The zero is materialized by reinterpreting the xzr register (reg 31) as an f64 through
    ; the existing fa-fmov-d-x (fmov d1, xzr = 9e6703e1) — no new constant machinery. Then fmax d0,d0,d1 keeps
    ; the larger, so negatives clamp to 0 and positives pass. The SAME fa-fmax is stable-softmax's max-subtract
    ; and (with fa-fmin) the clamp; relu is its smallest runnable witness. ABI: d0 = x, returns d0 = max(x, 0).
    ; 3 instructions = 12 bytes:  0 fmov d1,xzr (9e6703e1)   1 fmax d0,d0,d1 (1e614800)   2 ret (d65f03c0).
    ; clang -O2 lowers `x>0?x:0` to movi-zero + fmaxnm (the NaN-QUIETING variant, 1e616800) — identical on every
    ; finite input; fmax is the fundamental primitive (oracle-as-teacher: the arm64 assembler confirms the word,
    ; the healthy difference is fmax propagates NaN where clang's fmaxnm quiets it).
    (defn fam-relu ()
        (append (fa-fmov-d-x 1 31)
            (append (fa-fmax 0 0 1)
                (fa-ret))))

    ; fam-max-loop: the MAX-REDUCTION max_j x[j] over a buffer as Form->asm bytes — the HEADLINE consumer of
    ; fa-fmax (#3937). fam-relu proved fa-fmax scalar; this folds it across a whole buffer, which is exactly
    ; stable softmax's max-subtract: softmax(x)_i = exp(x_i - m) / sum_j exp(x_j - m) with m = max_j x[j], so
    ; the largest exponent is 0 and exp never overflows. Every attention block runs this reduction before the
    ; softmax. It is fam-ss-sqrt's exact twin — the counted accumulate loop (matvec-loop discipline) — with the
    ; square-and-add fold replaced by a single fmax and NO trailing transcendental. The one structural
    ; difference from ss-sqrt: the accumulator cannot init to 0.0 (all-negative logits would wrongly return 0),
    ; so it inits to x[0] via ldr d0,[x0] — the max identity for n>=1 (a softmax always has >=1 logit); the
    ; loop then folds fmax over all n including x[0] again (fmax(x0,x0)=x0, idempotent, no n=0 special case).
    ; This composes ONLY encoders proven in prior bands (fa-ldr-d/fa-movz-x/fa-cmp-r/fa-bcond/fa-fmax/
    ; fa-add-x-imm/fa-b-off/fa-ret) — no new primitive; the claim is the COMPOSITION emits the exact 40-byte
    ; program four-way. ABI: x0 = x base, w1 = n (n>=1), returns d0 = max_j x[j]. 10 instructions = 40 bytes,
    ; byte-identical to the M4-assembled oracle (otool -t of the exact instruction sequence):
    ;   0 ldr d0,[x0] (fd400000, acc=x[0])   1 mov x3,#0 (j)   2 cmp w3,w1   3 b.ge +6(end)
    ;   4 ldr d1,[x0]   5 fmax d0,d0,d1   6 add x0,#8   7 add x3,#1   8 b -6(loop)   9 ret
    ; Branch offsets in INSTRUCTIONS (lo-streq discipline): b.ge exits +6 to the ret, b loops -6 to the compare.
    (defn fam-max-loop ()
        (append (fa-ldr-d 0 0 0)
            (append (fa-movz-x 3 0)
                (append (fa-cmp-r 3 1)
                    (append (fa-bcond 10 6)
                        (append (fa-ldr-d 1 0 0)
                            (append (fa-fmax 0 0 1)
                                (append (fa-add-x-imm 0 0 8)
                                    (append (fa-add-x-imm 3 3 1)
                                        (append (fa-b-off -6)
                                            (fa-ret)))))))))))

    ; fam-pow2: 2^k / ldexp(1,k) for an INTEGER exponent k, as Form->asm bytes — the exponent-ASSEMBLY step the
    ; whole native exp lane still lacked. exp(x) = 2^k * exp(r) with k = round(x*log2e) (fam-frintn -> fa-fcvtzs)
    ; and r the pooled range reduction (fam-exp-reduce); the Horner poly evaluates exp(r) on the lane. The one
    ; missing piece was BUILDING 2^k: an IEEE754 f64 with exponent field (k+1023) and zero mantissa IS exactly
    ; 2^k, so add the bias then shift it into the exponent bits and REINTERPRET. fa-add-x-imm biases, the new
    ; fa-lsl-x-imm shifts <<52 (the last non-present primitive, named in fa-fmov-d-x's own comment), fa-fmov-d-x
    ; reinterprets the bits (NOT fa-scvtf, which would give k's VALUE as a float). ABI: x0 = k (signed int,
    ; -1022..1023 for a normal 2^k), returns d0 = 2^k. 4 instructions = 16 bytes, byte-identical to the M4
    ; assembler oracle (otool -t of the exact sequence for `double f(long k){union{unsigned long u;double d;}v;
    ; v.u=((unsigned long)(k+1023))<<52; return v.d;}`):
    ;   0 add x0,x0,#1023 (910ffc00)   1 lsl x0,x0,#52 (d34c2c00)   2 fmov d0,x0 (9e670000)   3 ret (d65f03c0)
    ; This completes every exp-lane PRIMITIVE as asm bytes: k=round (fam-frintn), r (fam-exp-reduce), Horner
    ; (fam-pool-fma), and now 2^k (this). What remains is composing them into one fam-exp function.
    (defn fam-pow2 ()
        (append (fa-add-x-imm 0 0 1023)
            (append (fa-lsl-x-imm 0 0 52)
                (append (fa-fmov-d-x 0 0)
                    (fa-ret)))))

    ; fam-horner-list: a degree-(n-1) Horner polynomial p(x) = (..(c_{n-1}*x + c_{n-2})*x + ..)*x + c_0
    ; evaluated over a SELF-CONTAINED f64 pool, coefficients as a Form LIST (DATA) — the core-lift that
    ; generalizes fam-pool-fma (a single pooled fma, degree 1) to ANY degree in ONE engine. This is the
    ; polynomial EVALUATION ENGINE every transcendental is built from: exp(r), sin, cos, gelu, silu are all
    ; Horner polynomials over pooled coefficients. ABI: d0 = x, returns d0 = p(x). The accumulator lives in d1
    ; (x is preserved in d0 across every fma); the FINAL fmadd targets d0 so no trailing fmov is needed. For n
    ; coefficients the code is 2n words (56 bytes for n=7), the pool 8n bytes; each coefficient loads via a
    ; PC-relative literal whose imm19 (word distance to its pooled slot) is 2n for the leading load and a
    ; CONSTANT 2n+1 for every tail load — each tail step advances 2 words in code AND 2 words in the pool
    ; (a .quad is 2 words), so the distance is invariant. That is the layout math that generalizes, pinned
    ; against the M4 assembler oracle. coeffs are ordered c_{n-1} (highest power) first .. c_0 last; each
    ; pooled f64 is computed by f64-bytes so ANY value fills the pool (irregular transcendental mantissas
    ; included). fhl-tail emits the (n-1) trailing (ldr d2 ; fmadd) pairs then ret; fhl-pool concatenates the
    ; f64-bytes of every coefficient, in order, right after ret (position-independent, no relocation).
    (defn fhl-tail (cs imm)
        (if (nil? cs)
            (append (fa-fmov 0 1) (fa-ret))
            (if (nil? (tail cs))
                (append (fa-ldr-d-lit 2 imm) (append (fa-fmadd 0 1 0 2) (fa-ret)))
                (append (fa-ldr-d-lit 2 imm)
                    (append (fa-fmadd 1 1 0 2)
                        (fhl-tail (tail cs) imm))))))
    (defn fhl-pool (cs)
        (if (nil? cs) (list)
            (append (f64-bytes (head cs)) (fhl-pool (tail cs)))))
    (defn fam-horner-list (coeffs)
        (append (fa-ldr-d-lit 1 (mul 2 (len coeffs)))
            (append (fhl-tail (tail coeffs) (add (mul 2 (len coeffs)) 1))
                (fhl-pool coeffs))))

    ; fam-exp-poly: the degree-6 Taylor evaluator of exp(r) for r in [-ln2/2, ln2/2] — the fam-horner-list
    ; instance carrying the exp coefficients (1/720,1/120,1/24,1/6,1/2,1,1). |error| < ~1.2e-7 on the reduced
    ; interval (bounded by r^7/7!), so composed with fam-exp-reduce (which yields r) and fam-pow2 (2^k) it is
    ; the full native exp = 2^k * exp(r) — the softmax/gelu transcendental core, as Form->asm bytes.
    (defn fam-exp-poly ()
        (fam-horner-list (list
            (div 1.0 720.0) (div 1.0 120.0) (div 1.0 24.0)
            (div 1.0 6.0) (div 1.0 2.0) 1.0 1.0)))

    ; fam-exp: exp(x) END-TO-END as Form->asm BYTES — the first COMPOSED transcendental FUNCTION on the native
    ; asm lane, the softmax/gelu/silu core. Every exp-lane PART was proven four-way as a standalone program
    ; ending in ret — range reduction (fam-exp-reduce: k=round(x*log2e), r=x-k*ln2), 2^k (fam-pow2), the exp(r)
    ; Taylor evaluator (fam-exp-poly over a self-contained pool) — but NONE composed into exp itself. This chains
    ; them: exp(x) = 2^k * exp(r). The composition is genuinely NEW instruction shape, not a concatenation —
    ; the sub-programs share d0/d1/d2 and each ended in ret, so it re-lays the register allocation to carry k
    ; and 2^k ACROSS the poly (which clobbers d1,d2):
    ;   reduce:  x8=log2e; d1=x*log2e; d1=k_float=frintn; x9=k_int=fcvtzs(d1); x8=-ln2; d0=r=fma(d1,-ln2,x)
    ;   2^k:     x9=k_int+1023; x9<<=52; d3=2^k (reinterpret bits) — 2^k parked in d3, survives the poly
    ;   exp(r):  degree-6 Horner over the pool -> d0=exp(r) (uses d1,d2 scratch; d3 untouched)
    ;   combine: d0 = d0 * d3 = exp(r) * 2^k = exp(x); ret; then the 7-f64 pool
    ; ABI: d0 = x, returns d0 = exp(x). Accuracy is the poly's on r in [-ln2/2, ln2/2] (|err|<~1.2e-7) times an
    ; EXACT 2^k, so the whole exp matches libm within ~1.2e-7 relative across the finite range. 32 code words +
    ; a 56-byte 7-f64 pool = 184 bytes, byte-identical to the M4 assembler oracle (explicit movz/movk + the same
    ; instruction sequence, otool of the __text). The pool coefficients are computed by f64-bytes (any value),
    ; and its offsets are DERIVED from the coefficient count: the poly lives after a 17-word prologue and before
    ; a 2-word epilogue (fmul + ret) that sits between its final fmadd and the pool, so relative to standalone
    ; fam-horner-list (E=1, just ret) every literal-load distance grows by 1 -> LEAD=2n+1, TAIL=2n+2 (n=7 ->
    ; 15/16, confirmed against the oracle: ldr d1 = 5c0001e1 imm19=15, tail ldr d2 = 5c000202 imm19=16). This is
    ; the exp/softmax/gelu transcendental core as sovereign asm bytes: form-macho -> dlopen -> call over fkwu's
    ; own f64, no rustc/clang in the compute.
    (defn fam-exp-coeffs ()
        (list (div 1.0 720.0) (div 1.0 120.0) (div 1.0 24.0)
            (div 1.0 6.0) (div 1.0 2.0) 1.0 1.0))
    ; fam-exp-htail: the Horner tail WITHOUT a trailing ret (the composition appends fmul;ret then the pool).
    ; Same fold as fhl-tail (acc d1 = d1*r + c; final fmadd targets d0), minus the ret so exp can multiply by 2^k.
    (defn fam-exp-htail (cs imm)
        (if (nil? (tail cs))
            (append (fa-ldr-d-lit 2 imm) (fa-fmadd 0 1 0 2))
            (append (fa-ldr-d-lit 2 imm)
                (append (fa-fmadd 1 1 0 2)
                    (fam-exp-htail (tail cs) imm)))))
    (defn fam-exp ()
        (append (fa-mov-imm64 8 (f64-bytes 1.4426950408889634))     ; x8 = log2e bits
            (append (fa-fmov-d-x 1 8)                                ; d1 = log2e
                (append (fa-fmul 1 0 1)                              ; d1 = x*log2e
                    (append (fa-frintn 1 1)                          ; d1 = k_float = round(x*log2e)
                        (append (fa-fcvtzs 9 1)                      ; x9 = k_int (toward zero; k already integral)
                            (append (fa-mov-imm64 8 (f64-bytes -0.6931471805599453))  ; x8 = (-ln2) bits
                                (append (fa-fmov-d-x 2 8)            ; d2 = -ln2
                                    (append (fa-fmadd 0 1 2 0)      ; d0 = k_float*(-ln2)+x = r
                                        (append (fa-add-x-imm 9 9 1023)     ; x9 = k_int + 1023 (bias)
                                            (append (fa-lsl-x-imm 9 9 52)   ; x9 <<= 52 into the exponent field
                                                (append (fa-fmov-d-x 3 9)   ; d3 = 2^k (reinterpret bits)
                                                    (append (fa-ldr-d-lit 1 (add (mul 2 (len (fam-exp-coeffs))) 1))  ; d1 = c6 (LEAD=2n+1)
                                                        (append (fam-exp-htail (tail (fam-exp-coeffs)) (add (mul 2 (len (fam-exp-coeffs))) 2))  ; d0 = exp(r) (TAIL=2n+2)
                                                            (append (fa-fmul 0 0 3)     ; d0 = exp(r) * 2^k = exp(x)
                                                                (append (fa-ret)
                                                                    (fhl-pool (fam-exp-coeffs))))))))))))))))))

    ; fam-silu: the SiLU / swish ACTIVATION silu(x) = x * sigmoid(x) = x * e^x/(e^x + 1) as Form->asm BYTES —
    ; the FIRST activation composed from the native exp lane, and the exact gate llama3.2's SwiGLU MLP runs
    ; (silu(x*W_gate) * (x*W_up)). fam-exp (#3942) put the whole transcendental exp(x) on the lane; silu wraps
    ; it in a scalar sigmoid: sigmoid(x) = e^x/(e^x + 1) (the e^x form, so NO negate encoder is needed — there is
    ; no fa-fneg), then one fmul by x. It reuses fam-exp's ENTIRE body (range-reduce + 2^k + degree-6 exp(r)
    ; Horner + the 2^k multiply) unchanged; the only new instruction shape is (a) a save of x into d4 BEFORE exp
    ; runs (exp takes d0=x and clobbers d0/d1/d2/d3/x8/x9 — d4 it never touches, so x survives), and (b) the
    ; 4-instruction epilogue after exp(x) is in d0:
    ;   fmov d1,#1.0 ; fadd d1,d0,d1 (e^x+1) ; fdiv d0,d0,d1 (sigmoid) ; fmul d0,d4,d0 (x*sigmoid = silu)
    ; ABI: d0 = x, returns d0 = silu(x). Accuracy is fam-exp's on e^x (|rel err| < ~2e-7) carried through the
    ; sigmoid/multiply, so silu tracks the true silu within ~2e-7 relative across the finite range (the hardware
    ; witness, scripts/form_asm_fam_silu_witness.sh, checks both bit-exactness vs the exact-algorithm C mirror
    ; and closeness to libm-based x/(1+exp(-x))). No new asm ENCODER except fa-nop (the alignment filler): the
    ; save prologue grows exp's epilogue from 2 words (fmul+ret) to 6 (fmul + the 4 sigmoid/silu ops + ret) =
    ; 37 code words, an ODD count, so `.align 3` inserts one nop to 8-align the trailing 7-f64 pool. Because the
    ; epilogue is longer by 5 words than fam-exp's, EVERY PC-relative literal-load distance grows by 5: for the
    ; n=7 pool, LEAD = 2n+6 = 20 (fam-exp's 15 + 5) and TAIL = 2n+7 = 21 (fam-exp's 16 + 5) — DERIVED from the
    ; epilogue length and pinned against the M4 assembler oracle (leading ldr d1 = 5c000281 imm19=20, tail ldr
    ; d2 = 5c0002a2 imm19=21). 38 code words (incl. the nop) + a 56-byte 7-f64 pool = 208 bytes, byte-identical
    ; to the oracle. A standalone fam-sigmoid (drop the x-save + final fmul, its own shorter offsets) is the
    ; named follow-up; silu is the llama-relevant one and lands first.
    (defn fam-silu ()
        (append (fa-fmov 4 0)                                            ; d4 = x  (survives exp)
            (append (fa-mov-imm64 8 (f64-bytes 1.4426950408889634))      ; x8 = log2e bits
                (append (fa-fmov-d-x 1 8)                                ; d1 = log2e
                    (append (fa-fmul 1 0 1)                              ; d1 = x*log2e
                        (append (fa-frintn 1 1)                          ; d1 = k_float = round(x*log2e)
                            (append (fa-fcvtzs 9 1)                      ; x9 = k_int
                                (append (fa-mov-imm64 8 (f64-bytes -0.6931471805599453))  ; x8 = (-ln2) bits
                                    (append (fa-fmov-d-x 2 8)            ; d2 = -ln2
                                        (append (fa-fmadd 0 1 2 0)      ; d0 = k_float*(-ln2)+x = r
                                            (append (fa-add-x-imm 9 9 1023)     ; x9 = k_int + 1023
                                                (append (fa-lsl-x-imm 9 9 52)   ; x9 <<= 52
                                                    (append (fa-fmov-d-x 3 9)   ; d3 = 2^k
                                                        (append (fa-ldr-d-lit 1 20)  ; d1 = c6 (LEAD = 2n+6)
                                                            (append (fam-exp-htail (tail (fam-exp-coeffs)) 21)  ; d0 = exp(r) (TAIL = 2n+7)
                                                                (append (fa-fmul 0 0 3)     ; d0 = exp(r)*2^k = e^x
                                                                    (append (fa-fmov-imm 1 112)  ; d1 = 1.0
                                                                        (append (fa-fadd 1 0 1)     ; d1 = e^x + 1
                                                                            (append (fa-fdiv 0 0 1) ; d0 = e^x/(e^x+1) = sigmoid(x)
                                                                                (append (fa-fmul 0 4 0) ; d0 = x*sigmoid = silu(x)
                                                                                    (append (fa-ret)
                                                                                        (append (fa-nop)  ; 8-align the pool (37 code words is odd)
                                                                                            (fhl-pool (fam-exp-coeffs))))))))))))))))))))))))

    ; fam-tanh: the hyperbolic-tangent ACTIVATION tanh(x) = (e^{2x} - 1)/(e^{2x} + 1) as Form->asm BYTES — the
    ; sigmoid family's completion on the native exp lane (relu, silu shipped; tanh is the sibling), and the
    ; prerequisite for a native gelu-tanh (gelu(x) ~ 0.5x(1+tanh(sqrt(2/pi)(x+0.044715x^3))), whisper's/GPT's
    ; activation). It reuses fam-exp's ENTIRE body (range-reduce + 2^k + degree-6 exp(r) Horner + the 2^k multiply)
    ; unchanged, using the e^{2x} form so NO negate encoder is needed (there is no fa-fneg) — exactly silu's trick.
    ; Two shape changes vs fam-silu, same code length:
    ;   (a) PROLOGUE: fadd d0,d0,d0 (2x) replaces silu's fmov d4,d0 (save x). tanh feeds exp with 2x and never
    ;       needs the original x back, so the double is done in place with NO constant 2.0 (self-add).
    ;   (b) EPILOGUE after exp(2x) is in d0 — 4 ops, the FIRST activation to exercise real subtraction (fa-fsub)
    ;       end-to-end on hardware:
    ;         fmov d1,#1.0 ; fsub d2,d0,d1 (e^{2x}-1, num) ; fadd d1,d0,d1 (e^{2x}+1, den) ; fdiv d0,d2,d1 (tanh)
    ;       num is computed into d2 BEFORE d1 is overwritten by den (order matters); d2 is free scratch after
    ;       exp's final poly load, d1 held 1.0.
    ; ABI: d0 = x, returns d0 = tanh(x). Accuracy is fam-exp's on e^{2x} (|rel err| < ~2e-7) carried through the
    ; rational form, so tanh tracks true tanh within ~2e-7 relative across the finite range (the hardware witness,
    ; scripts/form_asm_fam_tanh_witness.sh: bit-exact vs the exact-algorithm C mirror + close to libm tanh).
    ; The code layout is byte-for-byte the SAME LENGTH as fam-silu (1-word prologue + fam-exp body + 4-word
    ; epilogue + ret + one alignment nop = 38 code words, an odd 37 before the nop), so EVERY PC-relative literal
    ; distance is identical: LEAD = 2n+6 = 20, TAIL = 2n+7 = 21 for n=7 — DERIVED from the shared epilogue length
    ; and pinned against the M4 assembler oracle. 38 code words + a 56-byte 7-f64 pool = 208 bytes.
    (defn fam-tanh ()
        (append (fa-fadd 0 0 0)                                          ; d0 = 2x  (fed into exp; no constant 2.0)
            (append (fa-mov-imm64 8 (f64-bytes 1.4426950408889634))      ; x8 = log2e bits
                (append (fa-fmov-d-x 1 8)                                ; d1 = log2e
                    (append (fa-fmul 1 0 1)                              ; d1 = 2x*log2e
                        (append (fa-frintn 1 1)                          ; d1 = k_float = round(2x*log2e)
                            (append (fa-fcvtzs 9 1)                      ; x9 = k_int
                                (append (fa-mov-imm64 8 (f64-bytes -0.6931471805599453))  ; x8 = (-ln2) bits
                                    (append (fa-fmov-d-x 2 8)            ; d2 = -ln2
                                        (append (fa-fmadd 0 1 2 0)      ; d0 = k_float*(-ln2)+2x = r
                                            (append (fa-add-x-imm 9 9 1023)     ; x9 = k_int + 1023
                                                (append (fa-lsl-x-imm 9 9 52)   ; x9 <<= 52
                                                    (append (fa-fmov-d-x 3 9)   ; d3 = 2^k
                                                        (append (fa-ldr-d-lit 1 20)  ; d1 = c6 (LEAD = 2n+6)
                                                            (append (fam-exp-htail (tail (fam-exp-coeffs)) 21)  ; d0 = exp(r) (TAIL = 2n+7)
                                                                (append (fa-fmul 0 0 3)     ; d0 = exp(r)*2^k = e^{2x}
                                                                    (append (fa-fmov-imm 1 112)  ; d1 = 1.0
                                                                        (append (fa-fsub 2 0 1)     ; d2 = e^{2x} - 1  (numerator)
                                                                            (append (fa-fadd 1 0 1)     ; d1 = e^{2x} + 1  (denominator)
                                                                                (append (fa-fdiv 0 2 1) ; d0 = (e^{2x}-1)/(e^{2x}+1) = tanh(x)
                                                                                    (append (fa-ret)
                                                                                        (append (fa-nop)  ; 8-align the pool (37 code words is odd)
                                                                                            (fhl-pool (fam-exp-coeffs))))))))))))))))))))))))

    0)
