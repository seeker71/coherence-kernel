; semantic-stdlib.fk -- high-semantic stdlib pivot for language surfaces.
;
; Common programming languages should map into one semantic operation layer
; before they emit back to a surface. This cell proves the pivot with a tiny
; catalog: add, return, function declaration, immutable binding, mutable
; binding.
;
; The second rung adds qualifiers and residue. Coarse semantic ids stay shared
; where languages mean the same family of operation, but translation now returns
; evidence about what the target surface cannot carry. `ssl-translate` remains a
; simple surface-or-missing wrapper; callers that care about honesty use
; `ssl-translate-result`.
;
; preludes: form-stdlib/core.fk

(do
    (defn ssl-add () 101)
    (defn ssl-return () 102)
    (defn ssl-fn-decl () 103)
    (defn ssl-bind-immutable () 104)
    (defn ssl-bind-mutable () 105)

    (defn ssl-sem-label (sem-id)
        (if (eq sem-id (ssl-add)) "add"
            (if (eq sem-id (ssl-return)) "return"
                (if (eq sem-id (ssl-fn-decl)) "fn-decl"
                    (if (eq sem-id (ssl-bind-immutable)) "bind-immutable"
                        (if (eq sem-id (ssl-bind-mutable)) "bind-mutable"
                            "missing"))))))

    (defn ssl-op (id name arity form-name)
        (list id name arity form-name))
    (defn ssl-op-id (o) (nth o 0))
    (defn ssl-op-name (o) (nth o 1))
    (defn ssl-op-arity (o) (nth o 2))
    (defn ssl-op-form-name (o) (nth o 3))

    (defn ssl-catalog ()
        (list
            (ssl-op (ssl-add) "add" 2 "add")
            (ssl-op (ssl-return) "return" 1 "return")
            (ssl-op (ssl-fn-decl) "function-declaration" 3 "defn")
            (ssl-op (ssl-bind-immutable) "immutable-binding" 2 "let")
            (ssl-op (ssl-bind-mutable) "mutable-binding" 2 "set")))

    (defn ssl-map-row (lang surface sem-id quals)
        (list lang surface sem-id quals))
    (defn ssl-map-lang (m) (nth m 0))
    (defn ssl-map-surface (m) (nth m 1))
    (defn ssl-map-sem (m) (nth m 2))
    (defn ssl-map-quals (m) (nth m 3))
    (defn ssl-map-missing () (ssl-map-row "missing" "missing" 0 (list)))

    (defn ssl-result (status surface sem-id fidelity residue)
        (list status surface sem-id fidelity residue))
    (defn ssl-result-status (r) (nth r 0))
    (defn ssl-result-surface (r) (nth r 1))
    (defn ssl-result-sem (r) (nth r 2))
    (defn ssl-result-fidelity (r) (nth r 3))
    (defn ssl-result-residue (r) (nth r 4))

    ; Layer observation: high-level enough to read as a semantic event, detailed
    ; enough to descend back into the exact sem-id and residue tags.
    (defn ssl-observation (from-lang source-surface to-lang result)
        (list "semantic-translation"
              from-lang
              source-surface
              to-lang
              (ssl-result-status result)
              (ssl-result-surface result)
              (ssl-result-sem result)
              (ssl-result-fidelity result)
              (ssl-result-residue result)))
    (defn ssl-obs-kind (o) (nth o 0))
    (defn ssl-obs-from-lang (o) (nth o 1))
    (defn ssl-obs-source-surface (o) (nth o 2))
    (defn ssl-obs-to-lang (o) (nth o 3))
    (defn ssl-obs-status (o) (nth o 4))
    (defn ssl-obs-target-surface (o) (nth o 5))
    (defn ssl-obs-sem (o) (nth o 6))
    (defn ssl-obs-fidelity (o) (nth o 7))
    (defn ssl-obs-residue (o) (nth o 8))

    (defn ssl-residue-head-text (residue)
        (if (eq (len residue) 0) "none" (head residue)))

    (defn ssl-has-qual? (quals q)
        (if (eq (len quals) 0) 0
            (if (str_eq (head quals) q) 1 (ssl-has-qual? (tail quals) q))))
    (defn ssl-residue-delta (source target)
        (if (eq (len source) 0) (list)
            (if (eq (ssl-has-qual? target (head source)) 1)
                (ssl-residue-delta (tail source) target)
                (cons (head source) (ssl-residue-delta (tail source) target)))))
    (defn ssl-status-for-residue (residue)
        (if (eq (len residue) 0) "ok" "lossy"))
    ; Categorical, not calibrated: 100 means all tracked qualifiers survived,
    ; 50 means tracked residue remains, 0 means no honest translation row.
    (defn ssl-fidelity-for-residue (residue)
        (if (eq (len residue) 0) 100 50))

    (defn ssl-mappings ()
        (list
            (ssl-map-row "form" "add" (ssl-add) (list "expr" "pure" "binary-op"))
            (ssl-map-row "python" "+" (ssl-add) (list "expr" "pure" "binary-op"))
            (ssl-map-row "javascript" "+" (ssl-add) (list "expr" "pure" "binary-op"))
            (ssl-map-row "go" "+" (ssl-add) (list "expr" "pure" "binary-op"))
            (ssl-map-row "rust" "+" (ssl-add) (list "expr" "pure" "binary-op"))
            (ssl-map-row "form" "return" (ssl-return) (list "stmt" "control-flow"))
            (ssl-map-row "python" "return" (ssl-return) (list "stmt" "control-flow"))
            (ssl-map-row "javascript" "return" (ssl-return) (list "stmt" "control-flow"))
            (ssl-map-row "go" "return" (ssl-return) (list "stmt" "control-flow"))
            (ssl-map-row "rust" "return" (ssl-return) (list "expr" "control-flow"))
            (ssl-map-row "form" "defn" (ssl-fn-decl) (list "stmt" "decl" "function"))
            (ssl-map-row "python" "def" (ssl-fn-decl) (list "stmt" "decl" "function"))
            (ssl-map-row "javascript" "function" (ssl-fn-decl) (list "stmt" "decl" "function"))
            (ssl-map-row "go" "func" (ssl-fn-decl) (list "stmt" "decl" "function"))
            (ssl-map-row "rust" "fn" (ssl-fn-decl) (list "stmt" "decl" "function"))
            (ssl-map-row "form" "let" (ssl-bind-immutable) (list "expr" "binding" "immutable"))
            (ssl-map-row "javascript" "const" (ssl-bind-immutable) (list "stmt" "decl" "block-scope" "immutable" "no-reassign" "no-redeclare"))
            (ssl-map-row "rust" "let" (ssl-bind-immutable) (list "stmt" "decl" "block-scope" "immutable" "immutable-default" "type-inferred"))
            (ssl-map-row "form" "set" (ssl-bind-mutable) (list "stmt" "assign" "mutable"))
            (ssl-map-row "javascript" "let" (ssl-bind-mutable) (list "stmt" "decl" "block-scope" "mutable" "no-redeclare"))
            (ssl-map-row "go" ":=" (ssl-bind-mutable) (list "stmt" "short-decl" "block-scope" "mutable" "type-inferred"))
            (ssl-map-row "python" "=" (ssl-bind-mutable) (list "stmt" "assign" "rebindable" "no-decl"))))

    (defn ssl-find-map (maps lang surface)
        (if (eq (len maps) 0) (ssl-map-missing)
            (if (and (str_eq (ssl-map-lang (head maps)) lang)
                     (str_eq (ssl-map-surface (head maps)) surface))
                (head maps)
                (ssl-find-map (tail maps) lang surface))))

    (defn ssl-find-map-for-sem (maps lang sem-id)
        (if (eq (len maps) 0) (ssl-map-missing)
            (if (and (str_eq (ssl-map-lang (head maps)) lang)
                     (eq (ssl-map-sem (head maps)) sem-id))
                (head maps)
                (ssl-find-map-for-sem (tail maps) lang sem-id))))

    (defn ssl-find-sem (maps lang surface)
        (ssl-map-sem (ssl-find-map maps lang surface)))

    (defn ssl-find-surface (maps lang sem-id)
        (ssl-map-surface (ssl-find-map-for-sem maps lang sem-id)))

    (defn ssl-find-op (ops sem-id)
        (if (eq (len ops) 0) (ssl-op 0 "missing" 0 "missing")
            (if (eq (ssl-op-id (head ops)) sem-id)
                (head ops)
                (ssl-find-op (tail ops) sem-id))))

    (defn ssl-translate-result (from-lang surface to-lang)
        (do
            (let source (ssl-find-map (ssl-mappings) from-lang surface))
            (if (eq (ssl-map-sem source) 0)
                (ssl-result "missing" "missing" 0 0 (list "missing-source"))
                (do
                    (let target (ssl-find-map-for-sem (ssl-mappings) to-lang (ssl-map-sem source)))
                    (if (eq (ssl-map-sem target) 0)
                        (ssl-result "missing" "missing" (ssl-map-sem source) 0 (list "missing-target"))
                        (do
                            (let residue (ssl-residue-delta (ssl-map-quals source) (ssl-map-quals target)))
                            (ssl-result
                                (ssl-status-for-residue residue)
                                (ssl-map-surface target)
                                (ssl-map-sem source)
                                (ssl-fidelity-for-residue residue)
                                residue)))))))

    (defn ssl-observe-translation (from-lang surface to-lang)
        (ssl-observation from-lang surface to-lang
            (ssl-translate-result from-lang surface to-lang)))

    (defn ssl-translate (from-lang surface to-lang)
        (ssl-result-surface (ssl-translate-result from-lang surface to-lang)))

    (defn ssl-arity-of-surface (lang surface)
        (ssl-op-arity (ssl-find-op (ssl-catalog)
            (ssl-find-sem (ssl-mappings) lang surface))))

    (defn ssl-form-name-of-surface (lang surface)
        (ssl-op-form-name (ssl-find-op (ssl-catalog)
            (ssl-find-sem (ssl-mappings) lang surface))))

    (defn ssl-sum (xs)
        (if (eq (len xs) 0) 0 (add (head xs) (ssl-sum (tail xs)))))
    (defn sslk (ok bit) (if ok bit 0))
    (defn semantic-stdlib-check ()
        (do
            (let plus (ssl-translate-result "python" "+" "javascript"))
            (let py-js (ssl-translate-result "python" "=" "javascript"))
            (let go-py (ssl-translate-result "go" ":=" "python"))
            (let rust-js (ssl-translate-result "rust" "let" "javascript"))
            (let missing-in (ssl-translate-result "python" "walrus" "javascript"))
            (let missing-out (ssl-translate-result "python" "+" "haskell"))
            (let obs (ssl-observe-translation "python" "=" "javascript"))
            (ssl-sum (list
                (sslk (eq (ssl-find-sem (ssl-mappings) "python" "+")
                          (ssl-find-sem (ssl-mappings) "javascript" "+")) 1)
                (sslk (str_eq (ssl-translate "python" "+" "javascript") "+") 2)
                (sslk (str_eq (ssl-translate "javascript" "function" "python") "def") 4)
                (sslk (str_eq (ssl-translate "javascript" "const" "form") "let") 8)
                (sslk (not (eq (ssl-find-sem (ssl-mappings) "javascript" "const")
                               (ssl-find-sem (ssl-mappings) "javascript" "let"))) 16)
                (sslk (eq (ssl-arity-of-surface "python" "+") 2) 32)
                (sslk (str_eq (ssl-form-name-of-surface "rust" "fn") "defn") 64)
                (sslk (and (str_eq (ssl-result-status plus) "ok")
                           (eq (ssl-result-fidelity plus) 100)) 128)
                (sslk (eq (len (ssl-result-residue plus)) 0) 256)
                (sslk (str_eq (ssl-result-status py-js) "lossy") 512)
                (sslk (str_eq (head (ssl-result-residue py-js)) "assign") 1024)
                (sslk (str_eq (ssl-result-status go-py) "lossy") 2048)
                (sslk (str_eq (head (ssl-result-residue go-py)) "short-decl") 4096)
                (sslk (str_eq (ssl-result-status rust-js) "lossy") 8192)
                (sslk (str_eq (head (ssl-result-residue rust-js)) "immutable-default") 16384)
                (sslk (and (str_eq (ssl-result-status missing-in) "missing")
                           (str_eq (head (ssl-result-residue missing-in)) "missing-source")) 32768)
                (sslk (and (str_eq (ssl-result-status missing-out) "missing")
                           (str_eq (head (ssl-result-residue missing-out)) "missing-target")) 65536)
                (sslk (and (str_eq (ssl-obs-kind obs) "semantic-translation")
                           (str_eq (ssl-obs-status obs) "lossy")) 131072)
                (sslk (and (eq (ssl-obs-sem obs) (ssl-bind-mutable))
                           (str_eq (head (ssl-obs-residue obs)) "assign")) 262144)
                (sslk (str_eq (ssl-result-surface missing-in) "missing") 524288)
                (sslk (eq (ssl-result-sem missing-in) 0) 1048576)
                (sslk (str_eq (ssl-result-surface missing-out) "missing") 2097152)
                (sslk (eq (ssl-result-sem missing-out) (ssl-add)) 4194304)))))

    0)
