; runtime-computed-observation-ingest.fk -- Layer 10d guide over computed 9h8 observations.
;
; This layer consumes one 9h8 computed-observation row and turns it into a
; learning/ingest/reasoning guide row. It does not produce runtime evidence,
; execute, mutate storage, install selectors, or grow the C seed.
;
; preludes: form-stdlib/core.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk form-stdlib/runtime-program-image-fkb-symbol-observation.fk

(do
    (defn rcoi-version () "runtime-computed-observation-ingest-v1")

    (defn rcoi-feature (name status) (list "runtime-computed-observation-ingest-feature" name status))
    (defn rcoi-feature-name (f) (nth f 1))
    (defn rcoi-feature-status (f) (nth f 2))
    (defn runtime-computed-observation-ingest-manifest ()
        (list
            (rcoi-feature "layer-10d-computed-observation-guide" 1)
            (rcoi-feature "consumes-9h8-row-only" 1)
            (rcoi-feature "single-public-guide-entrypoint" 1)
            (rcoi-feature "no-raw-trace-input" 1)
            (rcoi-feature "no-raw-observation-input" 1)
            (rcoi-feature "no-raw-outcome-input" 1)
            (rcoi-feature "no-raw-9h7-join-input" 1)
            (rcoi-feature "no-9h1-9h2-9h3-9h4-supplied-join-input" 1)
            (rcoi-feature "does-not-reuse-10b-record-shape" 1)
            (rcoi-feature "nested-agreement-reread-required" 1)
            (rcoi-feature "body-freeze-candidate-requires-full-ok-agreement" 1)
            (rcoi-feature "hard-statuses-become-exact-investigation-work" 1)
            (rcoi-feature "oom-killed-must-never-be-ignored" 1)
            (rcoi-feature "soft-statuses-become-repair-work" 1)
            (rcoi-feature "fallback-available-is-not-success" 1)
            (rcoi-feature "non-bound-rows-stay-held-or-refused" 1)
            (rcoi-feature "no-storage-mutation" 1)
            (rcoi-feature "no-artifact-load" 1)
            (rcoi-feature "no-native-call" 1)
            (rcoi-feature "no-selector-install" 1)
            (rcoi-feature "no-table-text-authority" 1)
            (rcoi-feature "no-symbol-lens-authority" 1)
            (rcoi-feature "no-generated-table-authority" 1)
            (rcoi-feature "no-c-seed-growth" 1)))
    (defn runtime-computed-observation-ingest-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rcoi-feature-name (head fs)) name)
                     (eq (rcoi-feature-status (head fs)) 1))
                1
                (runtime-computed-observation-ingest-manifest-has? name (tail fs)))))

    (defn rcoi-lane-body () "body-guide")
    (defn rcoi-lane-investigation () "investigation-guide")
    (defn rcoi-lane-repair () "repair-guide")
    (defn rcoi-lane-held () "held-guide")
    (defn rcoi-lane-refused () "refused-guide")

    (defn rcoi-work-freeze-candidate () "freeze-candidate-work")
    (defn rcoi-work-investigation () "investigation-work")
    (defn rcoi-work-repair () "repair-work")
    (defn rcoi-work-held () "held-work")
    (defn rcoi-work-refused () "refused-work")

    (defn rcoi-attention-freeze-candidate () "freeze-candidate")
    (defn rcoi-attention-oom-killed () "oom-killed")
    (defn rcoi-attention-killed () "killed")
    (defn rcoi-attention-stalled () "stalled")
    (defn rcoi-attention-timeout () "timeout")
    (defn rcoi-attention-wrong-value () "wrong-value")
    (defn rcoi-attention-loader-missing () "loader-missing")
    (defn rcoi-attention-error () "error")
    (defn rcoi-attention-fallback-available () "fallback-available")
    (defn rcoi-attention-nested-agreement () "nested-agreement")
    (defn rcoi-attention-non-bound () "non-bound")
    (defn rcoi-attention-malformed () "malformed")
    (defn rcoi-attention-unknown () "unknown")

    (defn rcoi-reason-freeze-candidate () "body-freeze-candidate-from-computed-observation")
    (defn rcoi-reason-oom-killed-investigation () "oom-killed-investigation")
    (defn rcoi-reason-killed-investigation () "killed-investigation")
    (defn rcoi-reason-stalled-investigation () "stalled-investigation")
    (defn rcoi-reason-timeout-investigation () "timeout-investigation")
    (defn rcoi-reason-wrong-value-investigation () "wrong-value-investigation")
    (defn rcoi-reason-loader-missing-repair () "loader-missing-repair")
    (defn rcoi-reason-error-repair () "error-repair")
    (defn rcoi-reason-fallback-available-repair () "fallback-available-repair")
    (defn rcoi-reason-unknown-status-investigation () "unknown-status-investigation")
    (defn rcoi-reason-malformed-9h8-row () "malformed-9h8-row")
    (defn rcoi-reason-malformed-9h7-bind () "malformed-9h7-bind")
    (defn rcoi-reason-malformed-bound-trace () "malformed-bound-trace")
    (defn rcoi-reason-malformed-observation () "malformed-observation")
    (defn rcoi-reason-no-derived-outcome () "no-derived-outcome")
    (defn rcoi-reason-nested-observation-mismatch () "nested-observation-mismatch")
    (defn rcoi-reason-nested-outcome-mismatch () "nested-outcome-mismatch")
    (defn rcoi-reason-non-bound-held () "non-bound-held")
    (defn rcoi-reason-manifest ()
        (list
            (rcoi-reason-freeze-candidate)
            (rcoi-reason-oom-killed-investigation)
            (rcoi-reason-killed-investigation)
            (rcoi-reason-stalled-investigation)
            (rcoi-reason-timeout-investigation)
            (rcoi-reason-wrong-value-investigation)
            (rcoi-reason-loader-missing-repair)
            (rcoi-reason-error-repair)
            (rcoi-reason-fallback-available-repair)
            (rcoi-reason-unknown-status-investigation)
            (rcoi-reason-malformed-9h8-row)
            (rcoi-reason-malformed-9h7-bind)
            (rcoi-reason-malformed-bound-trace)
            (rcoi-reason-malformed-observation)
            (rcoi-reason-no-derived-outcome)
            (rcoi-reason-nested-observation-mismatch)
            (rcoi-reason-nested-outcome-mismatch)
            (rcoi-reason-non-bound-held)))

    (defn rcoi-status-none () "none")
    (defn rcoi-reason-none () "none")
    (defn rcoi-text-none () "")
    (defn rcoi-num-none () 0)

    (defn rcoi-no-9h7-bind () (list "runtime-computed-observation-ingest-no-9h7-bind"))
    (defn rcoi-no-9h7-bind? (b)
        (if (eq (len b) 1)
            (str_eq (nth b 0) "runtime-computed-observation-ingest-no-9h7-bind")
            0))
    (defn rcoi-no-trace () (list "runtime-computed-observation-ingest-no-trace"))
    (defn rcoi-no-trace? (t)
        (if (eq (len t) 1)
            (str_eq (nth t 0) "runtime-computed-observation-ingest-no-trace")
            0))
    (defn rcoi-no-observation () (list "runtime-computed-observation-ingest-no-observation"))
    (defn rcoi-no-observation? (o)
        (if (eq (len o) 1)
            (str_eq (nth o 0) "runtime-computed-observation-ingest-no-observation")
            0))
    (defn rcoi-no-outcome () (list "runtime-computed-observation-ingest-no-outcome"))
    (defn rcoi-no-outcome? (o)
        (if (eq (len o) 1)
            (str_eq (nth o 0) "runtime-computed-observation-ingest-no-outcome")
            0))

    ; guide = ("runtime-computed-observation-ingest" 9h8-row 9h7-bind trace
    ;          observation outcome artifact-path source-hash content-hash
    ;          trace-status stop-reason trace-detail trace-exit-code
    ;          observation-status outcome-status 9h8-status 9h8-reason
    ;          9h7-status 9h7-reason guide-lane work-kind attention
    ;          priority freeze-candidate reason)
    (defn rcoi-guide? (g)
        (if (eq (len g) 25)
            (str_eq (nth g 0) "runtime-computed-observation-ingest")
            0))
    (defn rcoi-guide-9h8-row (g) (nth g 1))
    (defn rcoi-guide-9h7-bind (g) (nth g 2))
    (defn rcoi-guide-trace (g) (nth g 3))
    (defn rcoi-guide-observation (g) (nth g 4))
    (defn rcoi-guide-outcome (g) (nth g 5))
    (defn rcoi-guide-artifact-path (g) (nth g 6))
    (defn rcoi-guide-source-hash (g) (nth g 7))
    (defn rcoi-guide-content-hash (g) (nth g 8))
    (defn rcoi-guide-trace-status (g) (nth g 9))
    (defn rcoi-guide-stop-reason (g) (nth g 10))
    (defn rcoi-guide-trace-detail (g) (nth g 11))
    (defn rcoi-guide-trace-exit-code (g) (nth g 12))
    (defn rcoi-guide-observation-status (g) (nth g 13))
    (defn rcoi-guide-outcome-status (g) (nth g 14))
    (defn rcoi-guide-9h8-status (g) (nth g 15))
    (defn rcoi-guide-9h8-reason (g) (nth g 16))
    (defn rcoi-guide-9h7-status (g) (nth g 17))
    (defn rcoi-guide-9h7-reason (g) (nth g 18))
    (defn rcoi-guide-lane (g) (nth g 19))
    (defn rcoi-guide-work-kind (g) (nth g 20))
    (defn rcoi-guide-attention (g) (nth g 21))
    (defn rcoi-guide-priority (g) (nth g 22))
    (defn rcoi-guide-freeze-candidate (g) (nth g 23))
    (defn rcoi-guide-reason (g) (nth g 24))

    (defn rcoi-terminal-row-status? (status)
        (if (str_eq status (rpswo-status-refused))
            1
            (if (str_eq status (rpswo-status-investigate))
                1
                (if (str_eq status (rpswc-status-unavailable)) 1 0))))
    (defn rcoi-terminal-lane (status)
        (if (str_eq status (rpswo-status-refused))
            (rcoi-lane-refused)
            (if (str_eq status (rpswo-status-investigate))
                (rcoi-lane-investigation)
                (rcoi-lane-held))))
    (defn rcoi-terminal-work (status)
        (if (str_eq status (rpswo-status-refused))
            (rcoi-work-refused)
            (if (str_eq status (rpswo-status-investigate))
                (rcoi-work-investigation)
                (rcoi-work-held))))
    (defn rcoi-terminal-attention (status)
        (if (str_eq status (rpswo-status-refused))
            (rcoi-attention-malformed)
            (if (str_eq status (rpswo-status-investigate))
                (rcoi-attention-nested-agreement)
                (rcoi-attention-non-bound))))
    (defn rcoi-terminal-priority (status)
        (if (str_eq status (rpswo-status-refused))
            0
            (if (str_eq status (rpswo-status-investigate))
                80
                30)))
    (defn rcoi-terminal-reason (status reason)
        (if (str_eq status (rpswc-status-unavailable))
            (rcoi-reason-non-bound-held)
            reason))

    (defn rcoi-non-bound-row-agrees? (row bind)
        (if (not (str_eq (rpswo-row-status row) (rpswc-join-status bind)))
            0
            (str_eq (rpswo-row-reason row) (rpswc-join-reason bind))))
    (defn rcoi-non-bound-no-derived? (row)
        (and (rpswo-no-derived-observation? (rpswo-row-observation row))
             (rpswo-no-derived-outcome? (rpswo-row-outcome row))))
    (defn rcoi-non-bound-lane (status)
        (if (str_eq status (rpswc-status-refused))
            (rcoi-lane-refused)
            (rcoi-lane-held)))
    (defn rcoi-non-bound-work (status)
        (if (str_eq status (rpswc-status-refused))
            (rcoi-work-refused)
            (rcoi-work-held)))
    (defn rcoi-non-bound-attention (status)
        (if (str_eq status (rpswc-status-refused))
            (rcoi-attention-malformed)
            (rcoi-attention-non-bound)))
    (defn rcoi-non-bound-priority (status)
        (if (str_eq status (rpswc-status-refused)) 0 30))
    (defn rcoi-non-bound-reason (status reason)
        (if (str_eq status (rpswc-status-refused))
            reason
            (rcoi-reason-non-bound-held)))

    (defn rcoi-hard-attention (status)
        (if (str_eq status (rao-obs-oom-killed))
            (rcoi-attention-oom-killed)
            (if (str_eq status (rao-obs-killed))
                (rcoi-attention-killed)
                (if (str_eq status (rao-obs-stalled))
                    (rcoi-attention-stalled)
                    (if (str_eq status (rao-obs-timeout))
                        (rcoi-attention-timeout)
                        (rcoi-attention-wrong-value))))))
    (defn rcoi-hard-reason (status)
        (if (str_eq status (rao-obs-oom-killed))
            (rcoi-reason-oom-killed-investigation)
            (if (str_eq status (rao-obs-killed))
                (rcoi-reason-killed-investigation)
                (if (str_eq status (rao-obs-stalled))
                    (rcoi-reason-stalled-investigation)
                    (if (str_eq status (rao-obs-timeout))
                        (rcoi-reason-timeout-investigation)
                        (rcoi-reason-wrong-value-investigation))))))
    (defn rcoi-soft-attention (status)
        (if (str_eq status (rao-obs-loader-missing))
            (rcoi-attention-loader-missing)
            (rcoi-attention-error)))
    (defn rcoi-soft-reason (status)
        (if (str_eq status (rao-obs-loader-missing))
            (rcoi-reason-loader-missing-repair)
            (rcoi-reason-error-repair)))

    (defn rcoi-expected-observation-detail (trace)
        (str_concat "synthetic-computed-trace-observation: "
                    (rpiwt-trace-detail trace)))
    (defn rcoi-row-bind-agrees? (row bind)
        (if (not (rpswc-envelope-identity-matches? (rpswo-row-envelope row) (rpswc-join-envelope bind)))
            0
            (if (not (rpsw-request-matches? (rpswo-row-symbol-request row) (rpswc-join-symbol-request bind)))
                0
                (if (not (eq (rpswo-row-step-budget row) (rpswc-join-step-budget bind)))
                    0
                    (eq (rpswo-row-input-value row) (rpswc-join-input-value bind))))))
    (defn rcoi-observation-derived-from-trace? (row bind trace observation)
        (if (not (rcoi-row-bind-agrees? row bind))
            0
            (if (not (rao-run-observation? observation))
                0
                (if (not (str_eq (rao-observation-action observation)
                                  (rale-envelope-action (rpswo-row-envelope row))))
                    0
                    (if (not (str_eq (rao-observation-status observation)
                                      (rpiwt-trace-status trace)))
                        0
                        (if (not (eq (rao-observation-code observation)
                                     (rpiwt-trace-exit-code trace)))
                            0
                            (str_eq (rao-observation-detail observation)
                                    (rcoi-expected-observation-detail trace))))))))
    (defn rcoi-outcome-fields-match? (actual expected)
        (if (not (eq (rao-outcome-route actual) (rao-outcome-route expected)))
            0
            (if (not (str_eq (rao-outcome-attempted actual) (rao-outcome-attempted expected)))
                0
                (if (not (str_eq (rao-outcome-fallback actual) (rao-outcome-fallback expected)))
                    0
                    (if (not (str_eq (rao-outcome-selection-status actual) (rao-outcome-selection-status expected)))
                        0
                        (if (not (str_eq (rao-outcome-status actual) (rao-outcome-status expected)))
                            0
                            (if (not (str_eq (rao-outcome-observation-status actual) (rao-outcome-observation-status expected)))
                                0
                                (if (not (str_eq (rao-outcome-selection-reason actual) (rao-outcome-selection-reason expected)))
                                    0
                                    (if (not (str_eq (rao-outcome-reason actual) (rao-outcome-reason expected)))
                                        0
                                        (if (not (str_eq (rao-outcome-detail actual) (rao-outcome-detail expected)))
                                            0
                                            (eq (rao-outcome-code actual) (rao-outcome-code expected))))))))))))
    (defn rcoi-outcome-agrees-with-observation? (row outcome observation)
        (if (not (rao-outcome? outcome))
            0
            (do
                (let selection (rale-envelope-selection (rpswo-row-envelope row)))
                (let expected (rao-outcome-from-selection-observation selection observation))
                (if (not (rao-outcome? expected))
                    0
                    (if (not (rcoi-outcome-fields-match? outcome expected))
                        0
                        (if (not (str_eq (rpswo-row-status row) (rao-outcome-status outcome)))
                            0
                            (str_eq (rpswo-row-reason row) (rao-outcome-reason outcome))))))))
    (defn rcoi-rpmw-no-trace? (trace)
        (if (eq (len trace) 1)
            (str_eq (nth trace 0) "runtime-program-image-fkb-micro-walker-no-trace")
            0))
    (defn rcoi-trace-equivalent? (actual expected)
        (if (rpiwt-trace? actual)
            (if (rpiwt-trace? expected)
                (rpsw-trace-fields-match? actual expected)
                0)
            (if (rpswc-no-bound-trace? actual)
                (rpswc-no-bound-trace? expected)
                (if (rcoi-rpmw-no-trace? actual)
                    (rcoi-rpmw-no-trace? expected)
                    0))))
    (defn rcoi-symbol-walk-equivalent? (actual expected)
        (if (rpswc-no-symbol-walk? actual)
            (rpswc-no-symbol-walk? expected)
            (if (rpsw-receipt? actual)
                (if (rpsw-receipt? expected)
                    (and (rpswc-envelope-identity-matches? (rpsw-receipt-envelope actual)
                                                           (rpsw-receipt-envelope expected))
                    (and (rpsw-request-matches? (rpsw-receipt-symbol-request actual)
                                                (rpsw-receipt-symbol-request expected))
                    (and (eq (rpsw-receipt-step-budget actual)
                             (rpsw-receipt-step-budget expected))
                    (and (eq (rpsw-receipt-input-value actual)
                             (rpsw-receipt-input-value expected))
                    (and (str_eq (rpsw-receipt-status actual)
                                 (rpsw-receipt-status expected))
                    (and (str_eq (rpsw-receipt-reason actual)
                                 (rpsw-receipt-reason expected))
                         (rcoi-trace-equivalent? (rpsw-receipt-trace actual)
                                                 (rpsw-receipt-trace expected))))))))
                    0)
                0)))
    (defn rcoi-bind-equivalent? (actual expected)
        (if (not (rpswc-join? actual))
            0
            (if (not (rpswc-join? expected))
                0
                (and (rpswc-envelope-identity-matches? (rpswc-join-envelope actual)
                                                       (rpswc-join-envelope expected))
                (and (rpsw-request-matches? (rpswc-join-symbol-request actual)
                                            (rpswc-join-symbol-request expected))
                (and (eq (rpswc-join-step-budget actual)
                         (rpswc-join-step-budget expected))
                (and (eq (rpswc-join-input-value actual)
                         (rpswc-join-input-value expected))
                (and (str_eq (rpswc-join-status actual)
                             (rpswc-join-status expected))
                (and (str_eq (rpswc-join-reason actual)
                             (rpswc-join-reason expected))
                (and (rcoi-symbol-walk-equivalent? (rpswc-join-symbol-walk actual)
                                                   (rpswc-join-symbol-walk expected))
                     (rcoi-trace-equivalent? (rpswc-join-bound-trace actual)
                                             (rpswc-join-bound-trace expected))))))))))))
    (defn rcoi-observation-equivalent? (actual expected)
        (if (rpswo-no-derived-observation? actual)
            (rpswo-no-derived-observation? expected)
            (if (rao-run-observation? actual)
                (if (rao-run-observation? expected)
                    (and (str_eq (rao-observation-action actual)
                                 (rao-observation-action expected))
                    (and (str_eq (rao-observation-status actual)
                                 (rao-observation-status expected))
                    (and (str_eq (rao-observation-detail actual)
                                 (rao-observation-detail expected))
                         (eq (rao-observation-code actual)
                             (rao-observation-code expected)))))
                    0)
                0)))
    (defn rcoi-outcome-equivalent? (actual expected)
        (if (rpswo-no-derived-outcome? actual)
            (rpswo-no-derived-outcome? expected)
            (if (rao-outcome? actual)
                (if (rao-outcome? expected)
                    (rcoi-outcome-fields-match? actual expected)
                    0)
                0)))
    (defn rcoi-row-recomputed-agrees? (row expected)
        (if (not (rpswo-row? expected))
            0
            (if (value_eq row expected) 1 0)))
    (defn rcoi-drift-hard-trace? (bind)
        (if (not (rpswc-join? bind))
            0
            (if (not (rpiwt-trace? (rpswc-join-bound-trace bind)))
                0
                (rao-hard-status? (rpiwt-trace-status (rpswc-join-bound-trace bind))))))
    (defn rcoi-freeze-candidate? (row trace observation outcome)
        (and (str_eq (rpiwt-trace-status trace) (rao-obs-ok))
        (and (str_eq (rpiwt-trace-stop-reason trace) (rpiwt-stop-completed))
        (and (str_eq (rao-observation-status observation) (rao-obs-ok))
        (and (str_eq (rao-outcome-status outcome) (rao-status-complete))
        (and (str_eq (rpswo-row-status row) (rao-status-complete))
             (str_eq (rpswo-row-reason row) (rao-reason-observation-ok))))))))

    (defn rcoi-ingest (row)
        (if (not (rpswo-row? row))
            (list "runtime-computed-observation-ingest"
                  row (rcoi-no-9h7-bind) (rcoi-no-trace)
                  (rcoi-no-observation) (rcoi-no-outcome)
                  (rcoi-text-none) (rcoi-text-none) (rcoi-text-none)
                  (rcoi-status-none) (rcoi-status-none) (rcoi-text-none)
                  (rcoi-num-none) (rcoi-status-none) (rcoi-status-none)
                  (rcoi-status-none) (rcoi-reason-none)
                  (rcoi-status-none) (rcoi-reason-none)
                  (rcoi-lane-refused) (rcoi-work-refused)
                  (rcoi-attention-malformed) 0 0
                  (rcoi-reason-malformed-9h8-row))
            (do
                (let bind (rpswo-row-9h7-bind row))
                (let expected (rpswo-adapt (rpswo-row-envelope row)
                                           (rpswo-row-readiness row)
                                           (rpswo-row-admission row)
                                           (rpswo-row-symbol-request row)
                                           (rpswo-row-step-budget row)
                                           (rpswo-row-input-value row)))
                (if (not (rpswc-join? bind))
                    (list "runtime-computed-observation-ingest"
                          row bind (rcoi-no-trace)
                          (rpswo-no-derived-observation) (rpswo-no-derived-outcome)
                          (rcoi-text-none) (rcoi-text-none) (rcoi-text-none)
