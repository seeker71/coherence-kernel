; world-model-lingbot-map.fk — LingBot geometry enters the native world model.
;
; A point-cloud row (xyz confidence) becomes an ordinary world-model region;
; wm-observe performs the same generic region->entity walk used for people,
; devices, and objects. The visual context embedding is carried unchanged for
; recognition and every reconstructed xyz is carried as its world position.
;
; This organ deliberately composes world-model.fk instead of creating a second
; map vocabulary. It accepts any confidence-bearing cloud and any visual
; embedding; the live LingBot pipeline supplies both from real frame bytes.
;
; witnessed: 2026-07-18 -> live upstream pair enters wm-model as 64 objects
; preludes: form/form-stdlib/core.fk form/form-stdlib/world-model.fk

(do
  (defn wmlm-cloud-position (row) (nth row 0))
  (defn wmlm-cloud-confidence (row) (nth row 1))

  ; Keep recognition sensitive to both attended visual context and local
  ; reconstruction confidence while preserving a fixed embedding width.
  (defn wmlm-embedding (visual confidence)
    (list
      (nth visual 0)
      (nth visual 1)
      (nth visual 2)
      (add (nth visual 3) (mul confidence 0.125))))

  (defn wmlm-regions-go (cloud visual)
    (if (eq (len cloud) 0)
      (empty)
      (do
        (let row (head cloud))
        (cons
          (list "object"
            (wmlm-embedding visual (wmlm-cloud-confidence row))
            (wmlm-cloud-position row))
          (wmlm-regions-go (tail cloud) visual)))))

  (defn wmlm-observe-cloud (cloud visual)
    (wm-observe (wmlm-regions-go cloud visual) (empty)))

  (defn wmlm-world-from-cloud (cloud visual)
    (wm-model (wmlm-observe-cloud cloud visual)))

  (defn wmlm-object-count (cloud visual)
    (wm-orient-count (wmlm-observe-cloud cloud visual) "object"))

  0)
