; stdlib-uplift-bmf-use.fk -- use BMF-authored stdlib uplift grammars.
;
; The authored grammar source is `grammars/stdlib-uplift-missing-grammars.bmf`.
; This file is the current runtime witness: it checks that BMF section source
; file, binds each authored grammar family to one reversible BMF object rule,
; and exposes example roundtrips.
;
; preludes: form-stdlib/core.fk form-stdlib/engine.fk

(do
    (defn subu-feature (name status) (list "stdlib-uplift-bmf-use-feature" name status))
    (defn subu-feature-name (f) (nth f 1))
    (defn subu-feature-status (f) (nth f 2))
    (defn stdlib-uplift-bmf-use-manifest ()
        (list
            (subu-feature "bmf-source-file-required" 1)
            (subu-feature "actual-bmf-object-rules" 1)
            (subu-feature "forward-parse" 1)
            (subu-feature "reverse-emit" 1)
            (subu-feature "roundtrip-observed" 1)
            (subu-feature "one-example-per-missing-grammar" 1)
            (subu-feature "bmf-section-source-observed" 1)))
    (defn stdlib-uplift-bmf-use-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (subu-feature-name (head fs)) name)
                     (eq (subu-feature-status (head fs)) 1))
                1
                (stdlib-uplift-bmf-use-manifest-has? name (tail fs)))))

    (defn subu-source-path () "../grammars/stdlib-uplift-missing-grammars.bmf")
    (defn subu-source-root-path () "grammars/stdlib-uplift-missing-grammars.bmf")
    (defn subu-source-text ()
        (do
            (let primary (read_file (subu-source-path)))
            (if (gt (str_len primary) 0)
                primary
                (read_file (subu-source-root-path)))))
    (defn subu-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn subu-source-has-family? (family)
        (subu-has? (subu-source-text) (str_concat "section [" (str_concat family ".bmf] {"))))
    (defn subu-source-has-rule? (rule-name)
        (subu-has?
            (subu-source-text)
            (str_concat rule-name " ::= ")))
    (defn subu-source-has-reverse? (reverse-name)
        (subu-has?
            (subu-source-text)
            (str_concat "<= " (str_concat reverse-name ";"))))

    (defn subu-kw (v) (bmf-atom "kw" v))
    (defn subu-str (v) (bmf-atom "str" v))
    (defn subu-kwp (v) (object-lit "kw" v))
    (defn subu-capp (name) (list "capture" name (object-lit "str" "")))
    (defn subu-bmf-section-kw (value) (object-lit "kw" value))
    (defn subu-bmf-section-op (value) (object-lit "kw" value))
    (defn subu-bmf-section-string-lit (capture-name)
        (list "capture" capture-name (object-lit "str" "")))
    (defn subu-bmf-section-name (capture-name)
        (subu-bmf-section-string-lit capture-name))

    (defn stdlib-cluster-index-language-kw (value) (subu-bmf-section-kw value))
    (defn stdlib-cluster-index-language-op (value) (subu-bmf-section-op value))
    (defn stdlib-cluster-index-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn stdlib-cluster-index-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn section-lift-plan-language-kw (value) (subu-bmf-section-kw value))
    (defn section-lift-plan-language-op (value) (subu-bmf-section-op value))
    (defn section-lift-plan-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn section-lift-plan-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn protocol-codec-language-kw (value) (subu-bmf-section-kw value))
    (defn protocol-codec-language-op (value) (subu-bmf-section-op value))
    (defn protocol-codec-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn protocol-codec-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn route-service-language-kw (value) (subu-bmf-section-kw value))
    (defn route-service-language-op (value) (subu-bmf-section-op value))
    (defn route-service-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn route-service-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn capability-carrier-protocol-language-kw (value) (subu-bmf-section-kw value))
    (defn capability-carrier-protocol-language-op (value) (subu-bmf-section-op value))
    (defn capability-carrier-protocol-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn capability-carrier-protocol-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn artifact-lifecycle-language-kw (value) (subu-bmf-section-kw value))
    (defn artifact-lifecycle-language-op (value) (subu-bmf-section-op value))
    (defn artifact-lifecycle-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn artifact-lifecycle-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn tensor-graph-model-language-kw (value) (subu-bmf-section-kw value))
    (defn tensor-graph-model-language-op (value) (subu-bmf-section-op value))
    (defn tensor-graph-model-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn tensor-graph-model-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn learning-experiment-language-kw (value) (subu-bmf-section-kw value))
    (defn learning-experiment-language-op (value) (subu-bmf-section-op value))
    (defn learning-experiment-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn learning-experiment-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn corpus-locale-query-language-kw (value) (subu-bmf-section-kw value))
    (defn corpus-locale-query-language-op (value) (subu-bmf-section-op value))
    (defn corpus-locale-query-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn corpus-locale-query-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn world-sensor-entity-language-kw (value) (subu-bmf-section-kw value))
    (defn world-sensor-entity-language-op (value) (subu-bmf-section-op value))
    (defn world-sensor-entity-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn world-sensor-entity-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn domain-law-evidence-language-kw (value) (subu-bmf-section-kw value))
    (defn domain-law-evidence-language-op (value) (subu-bmf-section-op value))
    (defn domain-law-evidence-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn domain-law-evidence-language-name (capture-name) (subu-bmf-section-name capture-name))
    (defn proof-manifest-language-kw (value) (subu-bmf-section-kw value))
    (defn proof-manifest-language-op (value) (subu-bmf-section-op value))
    (defn proof-manifest-language-string-lit (capture-name) (subu-bmf-section-string-lit capture-name))
    (defn proof-manifest-language-name (capture-name) (subu-bmf-section-name capture-name))

    (defn subu-strings-to-nodes (values)
        (if (nil? values)
            (empty)
            (cons (intern_trivial_string (head values))
                  (subu-strings-to-nodes (tail values)))))
    (defn subu-node (kind values)
        (intern_node (bp "fncall")
            (cons (intern_trivial_string kind)
                  (subu-strings-to-nodes values))))
    (defn subu-child-text (node i)
        (node_value (nth (node_children node) i)))
    (defn subu-node-field (node i)
        (subu-child-text node (add i 1)))
    (defn subu-cap (caps name)
        (bmf-collection-value caps name))

    (defn subu-emit-cluster (caps)
        (subu-node "stdlib-cluster-index-decl"
            (list (subu-cap caps "id")
                  (subu-cap caps "parent")
                  (subu-cap caps "files")
                  (subu-cap caps "current")
                  (subu-cap caps "missing")
                  (subu-cap caps "lift"))))
    (defn subu-reverse-cluster (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "cluster") (subu-str (subu-node-field n 0))
                  (subu-kw "parent") (subu-str (subu-node-field n 1))
                  (subu-kw "files") (subu-str (subu-node-field n 2))
                  (subu-kw "current") (subu-str (subu-node-field n 3))
                  (subu-kw "missing") (subu-str (subu-node-field n 4))
                  (subu-kw "lift") (subu-str (subu-node-field n 5)))))

    (defn subu-emit-section (caps)
        (subu-node "stdlib-section-lift-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "file")
                  (subu-cap caps "current")
                  (subu-cap caps "higher")
                  (subu-cap caps "action"))))
    (defn subu-reverse-section (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "section") (subu-str (subu-node-field n 0))
                  (subu-kw "file") (subu-str (subu-node-field n 1))
                  (subu-kw "current") (subu-str (subu-node-field n 2))
                  (subu-kw "higher") (subu-str (subu-node-field n 3))
                  (subu-kw "action") (subu-str (subu-node-field n 4)))))

    (defn subu-emit-protocol (caps)
        (subu-node "protocol-codec-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "method")
                  (subu-cap caps "path")
                  (subu-cap caps "header")
                  (subu-cap caps "value")
                  (subu-cap caps "body"))))
    (defn subu-reverse-protocol (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "protocol") (subu-kw "codec") (subu-str (subu-node-field n 0))
                  (subu-kw "method") (subu-str (subu-node-field n 1))
                  (subu-kw "path") (subu-str (subu-node-field n 2))
                  (subu-kw "header") (subu-str (subu-node-field n 3))
                  (subu-kw "value") (subu-str (subu-node-field n 4))
                  (subu-kw "body") (subu-str (subu-node-field n 5)))))

    (defn subu-emit-route (caps)
        (subu-node "route-service-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "method")
                  (subu-cap caps "path")
                  (subu-cap caps "handler")
                  (subu-cap caps "request")
                  (subu-cap caps "response"))))
    (defn subu-reverse-route (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "route") (subu-kw "service") (subu-str (subu-node-field n 0))
                  (subu-kw "method") (subu-str (subu-node-field n 1))
                  (subu-kw "path") (subu-str (subu-node-field n 2))
                  (subu-kw "handler") (subu-str (subu-node-field n 3))
                  (subu-kw "request") (subu-str (subu-node-field n 4))
                  (subu-kw "response") (subu-str (subu-node-field n 5)))))

    (defn subu-emit-carrier (caps)
        (subu-node "carrier-protocol-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "capability")
                  (subu-cap caps "effect")
                  (subu-cap caps "law"))))
    (defn subu-reverse-carrier (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "carrier") (subu-kw "protocol") (subu-str (subu-node-field n 0))
                  (subu-kw "capability") (subu-str (subu-node-field n 1))
                  (subu-kw "effect") (subu-str (subu-node-field n 2))
                  (subu-kw "law") (subu-str (subu-node-field n 3)))))

    (defn subu-emit-artifact (caps)
        (subu-node "artifact-lifecycle-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "source")
                  (subu-cap caps "fkb")
                  (subu-cap caps "sym")
                  (subu-cap caps "table_payload")
                  (subu-cap caps "dylib")
                  (subu-cap caps "freshness"))))
    (defn subu-reverse-artifact (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "artifact") (subu-kw "lifecycle") (subu-str (subu-node-field n 0))
                  (subu-kw "source") (subu-str (subu-node-field n 1))
                  (subu-kw "fkb") (subu-str (subu-node-field n 2))
                  (subu-kw "sym") (subu-str (subu-node-field n 3))
                  (subu-kw "table-payload") (subu-str (subu-node-field n 4))
                  (subu-kw "dylib") (subu-str (subu-node-field n 5))
                  (subu-kw "freshness") (subu-str (subu-node-field n 6)))))

    (defn subu-emit-tensor (caps)
        (subu-node "tensor-graph-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "input")
                  (subu-cap caps "op")
                  (subu-cap caps "shape")
                  (subu-cap caps "output"))))
    (defn subu-reverse-tensor (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "tensor") (subu-kw "graph") (subu-str (subu-node-field n 0))
                  (subu-kw "input") (subu-str (subu-node-field n 1))
                  (subu-kw "op") (subu-str (subu-node-field n 2))
                  (subu-kw "shape") (subu-str (subu-node-field n 3))
                  (subu-kw "output") (subu-str (subu-node-field n 4)))))

    (defn subu-emit-learning (caps)
        (subu-node "learning-experiment-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "hypothesis")
                  (subu-cap caps "metric")
                  (subu-cap caps "feedback"))))
    (defn subu-reverse-learning (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "learning") (subu-kw "experiment") (subu-str (subu-node-field n 0))
                  (subu-kw "hypothesis") (subu-str (subu-node-field n 1))
                  (subu-kw "metric") (subu-str (subu-node-field n 2))
                  (subu-kw "feedback") (subu-str (subu-node-field n 3)))))

    (defn subu-emit-corpus (caps)
        (subu-node "corpus-locale-query-decl"
            (list (subu-cap caps "name")
                  (subu-cap caps "locale")
                  (subu-cap caps "query")
                  (subu-cap caps "codec")
                  (subu-cap caps "target"))))
    (defn subu-reverse-corpus (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "corpus") (subu-kw "locale") (subu-str (subu-node-field n 0))
                  (subu-kw "locale") (subu-str (subu-node-field n 1))
                  (subu-kw "query") (subu-str (subu-node-field n 2))
                  (subu-kw "codec") (subu-str (subu-node-field n 3))
                  (subu-kw "target") (subu-str (subu-node-field n 4)))))

    (defn subu-emit-world (caps)
        (subu-node "world-sensor-entity-decl"
            (list (subu-cap caps "space")
                  (subu-cap caps "sensor")
                  (subu-cap caps "entity")
                  (subu-cap caps "relation")
                  (subu-cap caps "confidence"))))
    (defn subu-reverse-world (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "world") (subu-kw "entity") (subu-str (subu-node-field n 0))
                  (subu-kw "sensor") (subu-str (subu-node-field n 1))
                  (subu-kw "entity") (subu-str (subu-node-field n 2))
                  (subu-kw "relation") (subu-str (subu-node-field n 3))
                  (subu-kw "confidence") (subu-str (subu-node-field n 4)))))

    (defn subu-emit-domain-law (caps)
        (subu-node "domain-law-evidence-decl"
            (list (subu-cap caps "domain")
                  (subu-cap caps "subject")
                  (subu-cap caps "claim")
                  (subu-cap caps "evidence")
                  (subu-cap caps "residue"))))
    (defn subu-reverse-domain-law (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "domain") (subu-kw "law") (subu-str (subu-node-field n 0))
                  (subu-kw "subject") (subu-str (subu-node-field n 1))
                  (subu-kw "claim") (subu-str (subu-node-field n 2))
                  (subu-kw "evidence") (subu-str (subu-node-field n 3))
                  (subu-kw "residue") (subu-str (subu-node-field n 4)))))

    (defn subu-emit-proof (caps)
        (subu-node "proof-manifest-decl"
            (list (subu-cap caps "band")
                  (subu-cap caps "expected")
                  (subu-cap caps "scope")
                  (subu-cap caps "status"))))
    (defn subu-reverse-proof (obj)
        (do
            (let n (bmf-object-value obj))
            (list (subu-kw "proof") (subu-kw "manifest") (subu-str (subu-node-field n 0))
                  (subu-kw "expected") (subu-str (subu-node-field n 1))
                  (subu-kw "scope") (subu-str (subu-node-field n 2))
                  (subu-kw "status") (subu-str (subu-node-field n 3)))))

    (defn subu-cluster-rule ()
        (list "cluster-index"
              (list "sequence" (subu-kwp "cluster") (subu-capp "id")
                    (subu-kwp "parent") (subu-capp "parent")
                    (subu-kwp "files") (subu-capp "files")
                    (subu-kwp "current") (subu-capp "current")
                    (subu-kwp "missing") (subu-capp "missing")
                    (subu-kwp "lift") (subu-capp "lift"))
              subu-emit-cluster
              bmf-identity-inverse
              subu-reverse-cluster))
    (defn subu-section-rule ()
        (list "section-lift"
              (list "sequence" (subu-kwp "section") (subu-capp "name")
                    (subu-kwp "file") (subu-capp "file")
                    (subu-kwp "current") (subu-capp "current")
                    (subu-kwp "higher") (subu-capp "higher")
                    (subu-kwp "action") (subu-capp "action"))
              subu-emit-section
              bmf-identity-inverse
              subu-reverse-section))
    (defn subu-protocol-rule ()
        (list "protocol-codec"
              (list "sequence" (subu-kwp "protocol") (subu-kwp "codec") (subu-capp "name")
                    (subu-kwp "method") (subu-capp "method")
                    (subu-kwp "path") (subu-capp "path")
                    (subu-kwp "header") (subu-capp "header")
                    (subu-kwp "value") (subu-capp "value")
                    (subu-kwp "body") (subu-capp "body"))
              subu-emit-protocol
              bmf-identity-inverse
              subu-reverse-protocol))
    (defn subu-route-rule ()
        (list "route-service"
              (list "sequence" (subu-kwp "route") (subu-kwp "service") (subu-capp "name")
                    (subu-kwp "method") (subu-capp "method")
                    (subu-kwp "path") (subu-capp "path")
                    (subu-kwp "handler") (subu-capp "handler")
                    (subu-kwp "request") (subu-capp "request")
                    (subu-kwp "response") (subu-capp "response"))
              subu-emit-route
              bmf-identity-inverse
              subu-reverse-route))
    (defn subu-carrier-rule ()
        (list "carrier-protocol"
              (list "sequence" (subu-kwp "carrier") (subu-kwp "protocol") (subu-capp "name")
                    (subu-kwp "capability") (subu-capp "capability")
                    (subu-kwp "effect") (subu-capp "effect")
                    (subu-kwp "law") (subu-capp "law"))
              subu-emit-carrier
              bmf-identity-inverse
              subu-reverse-carrier))
    (defn subu-artifact-rule ()
        (list "artifact-lifecycle"
              (list "sequence" (subu-kwp "artifact") (subu-kwp "lifecycle") (subu-capp "name")
                    (subu-kwp "source") (subu-capp "source")
                    (subu-kwp "fkb") (subu-capp "fkb")
                    (subu-kwp "sym") (subu-capp "sym")
                    (subu-kwp "table-payload") (subu-capp "table_payload")
                    (subu-kwp "dylib") (subu-capp "dylib")
                    (subu-kwp "freshness") (subu-capp "freshness"))
              subu-emit-artifact
              bmf-identity-inverse
              subu-reverse-artifact))
    (defn subu-tensor-rule ()
        (list "tensor-graph"
              (list "sequence" (subu-kwp "tensor") (subu-kwp "graph") (subu-capp "name")
                    (subu-kwp "input") (subu-capp "input")
                    (subu-kwp "op") (subu-capp "op")
                    (subu-kwp "shape") (subu-capp "shape")
                    (subu-kwp "output") (subu-capp "output"))
              subu-emit-tensor
              bmf-identity-inverse
              subu-reverse-tensor))
    (defn subu-learning-rule ()
        (list "learning-experiment"
              (list "sequence" (subu-kwp "learning") (subu-kwp "experiment") (subu-capp "name")
                    (subu-kwp "hypothesis") (subu-capp "hypothesis")
                    (subu-kwp "metric") (subu-capp "metric")
                    (subu-kwp "feedback") (subu-capp "feedback"))
              subu-emit-learning
              bmf-identity-inverse
              subu-reverse-learning))
    (defn subu-corpus-rule ()
        (list "corpus-locale-query"
              (list "sequence" (subu-kwp "corpus") (subu-kwp "locale") (subu-capp "name")
                    (subu-kwp "locale") (subu-capp "locale")
                    (subu-kwp "query") (subu-capp "query")
                    (subu-kwp "codec") (subu-capp "codec")
                    (subu-kwp "target") (subu-capp "target"))
              subu-emit-corpus
              bmf-identity-inverse
              subu-reverse-corpus))
    (defn subu-world-rule ()
        (list "world-entity"
              (list "sequence" (subu-kwp "world") (subu-kwp "entity") (subu-capp "space")
                    (subu-kwp "sensor") (subu-capp "sensor")
                    (subu-kwp "entity") (subu-capp "entity")
                    (subu-kwp "relation") (subu-capp "relation")
                    (subu-kwp "confidence") (subu-capp "confidence"))
              subu-emit-world
              bmf-identity-inverse
              subu-reverse-world))
    (defn subu-domain-law-rule ()
        (list "domain-law"
              (list "sequence" (subu-kwp "domain") (subu-kwp "law") (subu-capp "domain")
                    (subu-kwp "subject") (subu-capp "subject")
                    (subu-kwp "claim") (subu-capp "claim")
                    (subu-kwp "evidence") (subu-capp "evidence")
                    (subu-kwp "residue") (subu-capp "residue"))
              subu-emit-domain-law
              bmf-identity-inverse
              subu-reverse-domain-law))
    (defn subu-proof-rule ()
        (list "proof-manifest"
              (list "sequence" (subu-kwp "proof") (subu-kwp "manifest") (subu-capp "band")
                    (subu-kwp "expected") (subu-capp "expected")
                    (subu-kwp "scope") (subu-capp "scope")
                    (subu-kwp "status") (subu-capp "status"))
              subu-emit-proof
              bmf-identity-inverse
              subu-reverse-proof))

    (defn subu-rules ()
        (list (subu-cluster-rule) (subu-section-rule) (subu-protocol-rule)
              (subu-route-rule) (subu-carrier-rule) (subu-artifact-rule)
              (subu-tensor-rule) (subu-learning-rule) (subu-corpus-rule)
              (subu-world-rule) (subu-domain-law-rule) (subu-proof-rule)))

