              (subu-route-source) (subu-carrier-source) (subu-artifact-source)
              (subu-tensor-source) (subu-learning-source) (subu-corpus-source)
              (subu-world-source) (subu-domain-law-source) (subu-proof-source)))

    (defn subu-roundtrips-loop (rules sources)
        (if (nil? rules)
            (empty)
            (cons (bmf-roundtrip (head rules) (head sources))
                  (subu-roundtrips-loop (tail rules) (tail sources)))))
    (defn subu-roundtrips ()
        (subu-roundtrips-loop (subu-rules) (subu-sources)))
    (defn subu-roundtrip-ok? (rt)
        (node_eq (bmf-object-value (bmf-roundtrip-first-object rt))
                 (bmf-object-value (bmf-roundtrip-second-object rt))))
    (defn subu-all-roundtrip-ok? (rts)
        (if (nil? rts)
            1
            (if (subu-roundtrip-ok? (head rts))
                (subu-all-roundtrip-ok? (tail rts))
                0)))
    (defn subu-all-source-families-present? (families)
        (if (nil? families)
            1
            (if (subu-source-has-family? (head families))
                (subu-all-source-families-present? (tail families))
                0)))
    (defn subu-family-names ()
        (list "stdlib-cluster-index-language"
              "section-lift-plan-language"
              "protocol-codec-language"
              "route-service-language"
              "capability-carrier-protocol-language"
              "artifact-lifecycle-language"
              "tensor-graph-model-language"
              "learning-experiment-language"
              "corpus-locale-query-language"
              "world-sensor-entity-language"
              "domain-law-evidence-language"
              "proof-manifest-language"))
)
