; runtime-artifact-handoff.fk -- persistence-ready artifacts into request lane.
;
; This layer is a pure composition receipt. It consumes a persistence-ready 8k
; row, derives plan/selection/load-envelope through the existing 9a/9b/9e
; layers, and admits only artifact routes into request-ready handoff rows. It
; does not install a selector, load artifacts, execute anything, read/write
; disk, hash bytes, produce attempts/observations, or grow the C seed.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/source-compiler-persistence.fk

(do
    (defn rah-feature (name status) (list "runtime-artifact-handoff-feature" name status))
    (defn rah-feature-name (f) (nth f 1))
    (defn rah-feature-status (f) (nth f 2))
    (defn runtime-artifact-handoff-manifest ()
        (list
            (rah-feature "persistence-ready-input-only" 1)
            (rah-feature "fixed-admission-order" 1)
            (rah-feature "composes-rap-ras-rale" 1)
            (rah-feature "artifact-routes-only" 1)
            (rah-feature "request-ready-not-load-success" 1)
            (rah-feature "defensive-envelope-drift-checks" 1)
            (rah-feature "inject-helper-for-unreachable-drift" 1)
            (rah-feature "reason-manifest-covered" 1)
            (rah-feature "no-disk-io" 1)
            (rah-feature "no-byte-hashing" 1)
            (rah-feature "no-runtime-load-walk-call" 1)
            (rah-feature "no-attempt-or-observation-production" 1)
            (rah-feature "no-fallback-execution" 1)
            (rah-feature "no-selector-install" 1)
            (rah-feature "no-c-seed-growth" 1)))
    (defn runtime-artifact-handoff-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rah-feature-name (head fs)) name)
                     (eq (rah-feature-status (head fs)) 1))
                1
                (runtime-artifact-handoff-manifest-has? name (tail fs)))))

    (defn rah-status-handoff-ready () "handoff-ready")
    (defn rah-status-investigate () "investigate")
    (defn rah-status-refused () "refused")

    (defn rah-reason-handoff-ready-program-image () "handoff-ready-program-image")
    (defn rah-reason-handoff-ready-native () "handoff-ready-native")
    (defn rah-reason-malformed-persistence () "malformed-persistence")
    (defn rah-reason-non-ready-persistence () "non-ready-persistence")
    (defn rah-reason-malformed-descriptor-triple () "malformed-descriptor-triple")
    (defn rah-reason-descriptor-route-not-artifact () "descriptor-route-not-artifact")
    (defn rah-reason-selection-investigates () "selection-investigates")
    (defn rah-reason-selection-refused () "selection-refused")
    (defn rah-reason-envelope-investigates () "envelope-investigates")
    (defn rah-reason-envelope-refused () "envelope-refused")
    (defn rah-reason-envelope-route-action-mismatch () "envelope-route-action-mismatch")
    (defn rah-reason-envelope-artifact-kind-mismatch () "envelope-artifact-kind-mismatch")

    (defn rah-reason-manifest ()
        (list
            (rah-reason-handoff-ready-program-image)
            (rah-reason-handoff-ready-native)
            (rah-reason-malformed-persistence)
            (rah-reason-non-ready-persistence)
            (rah-reason-malformed-descriptor-triple)
            (rah-reason-descriptor-route-not-artifact)
            (rah-reason-selection-investigates)
            (rah-reason-selection-refused)
            (rah-reason-envelope-investigates)
            (rah-reason-envelope-refused)
            (rah-reason-envelope-route-action-mismatch)
            (rah-reason-envelope-artifact-kind-mismatch)))

    (defn rah-no-plan () (list "runtime-artifact-handoff-no-plan"))
    (defn rah-no-selection () (list "runtime-artifact-handoff-no-selection"))
    (defn rah-no-envelope () (list "runtime-artifact-handoff-no-envelope"))
    (defn rah-empty-triple () (scp-empty-triple))
    (defn rah-triple? (t)
        (if (eq (len t) 3)
            (if (sad-source-valid? (sap-triple-source t))
                (if (sad-artifact-option-valid? (sap-triple-fkb t))
                    (sad-artifact-option-valid? (sap-triple-dylib t))
                    0)
                0)
            0))
    (defn rah-artifact-route? (route)
        (if (eq route (sac-run-fkb))
            1
            (if (eq route (sac-run-dylib)) 1 0)))
    (defn rah-expected-kind-for-route (route)
        (if (eq route (sac-run-fkb))
            (sad-kind-program-image-fkb)
            (if (eq route (sac-run-dylib))
                (sad-kind-native-dylib)
                (rale-kind-none))))

    ; handoff = ("runtime-artifact-handoff" persistence descriptor-triple
    ;            plan selection envelope status reason)
    (defn rah-handoff (persistence triple plan selection envelope status reason)
        (list "runtime-artifact-handoff" persistence triple plan selection envelope status reason))
    (defn rah-handoff? (h)
        (if (eq (len h) 8)
            (str_eq (nth h 0) "runtime-artifact-handoff")
            0))
    (defn rah-handoff-persistence (h) (nth h 1))
    (defn rah-handoff-descriptor-triple (h) (nth h 2))
    (defn rah-handoff-plan (h) (nth h 3))
    (defn rah-handoff-selection (h) (nth h 4))
    (defn rah-handoff-envelope (h) (nth h 5))
    (defn rah-handoff-status (h) (nth h 6))
    (defn rah-handoff-reason (h) (nth h 7))
    (defn rah-handoff-ready? (h)
        (if (rah-handoff? h)
            (str_eq (rah-handoff-status h) (rah-status-handoff-ready))
            0))
    (defn rah-investigate? (h)
        (if (rah-handoff? h)
            (str_eq (rah-handoff-status h) (rah-status-investigate))
            0))
    (defn rah-refused? (h)
        (if (rah-handoff? h)
            (str_eq (rah-handoff-status h) (rah-status-refused))
            0))
    (defn rah-ready-row (persistence triple plan selection envelope reason)
        (rah-handoff persistence triple plan selection envelope (rah-status-handoff-ready) reason))
    (defn rah-investigate-row (persistence triple plan selection envelope reason)
        (rah-handoff persistence triple plan selection envelope (rah-status-investigate) reason))
    (defn rah-refused-row (persistence triple plan selection envelope reason)
        (rah-handoff persistence triple plan selection envelope (rah-status-refused) reason))

    (defn rah-envelope-route-action-ok? (selection envelope)
        (if (rale-envelope? envelope)
            (if (eq (rale-envelope-route envelope) (ras-selection-route selection))
                (str_eq (rale-envelope-action envelope) (ras-selection-selected selection))
                0)
            0))
    (defn rah-envelope-kind-ok? (selection envelope)
        (if (rale-envelope? envelope)
            (str_eq (rale-envelope-artifact-kind envelope)
                    (rah-expected-kind-for-route (ras-selection-route selection)))
            0))
    (defn rah-ready-reason (selection)
        (if (eq (ras-selection-route selection) (sac-run-dylib))
            (rah-reason-handoff-ready-native)
            (rah-reason-handoff-ready-program-image)))

    ; This helper exists so bands can inject impossible downstream drift cases
    ; without widening the public handoff input surface.
    (defn rah-handoff-from-components (persistence triple plan selection envelope)
        (if (ras-refused? selection)
            (rah-refused-row persistence triple plan selection envelope (rah-reason-selection-refused))
            (if (ras-investigate? selection)
                (rah-investigate-row persistence triple plan selection envelope (rah-reason-selection-investigates))
                (if (not (ras-selected? selection))
                    (rah-investigate-row persistence triple plan selection envelope (rah-reason-selection-investigates))
                    (if (not (rah-artifact-route? (ras-selection-route selection)))
                        (rah-investigate-row persistence triple plan selection envelope (rah-reason-descriptor-route-not-artifact))
                        (if (not (rale-envelope? envelope))
                            (rah-refused-row persistence triple plan selection envelope (rah-reason-envelope-refused))
                            (if (str_eq (rale-envelope-status envelope) (rale-status-refused))
                                (rah-refused-row persistence triple plan selection envelope (rah-reason-envelope-refused))
                                (if (str_eq (rale-envelope-status envelope) (rale-status-investigate))
                                    (rah-investigate-row persistence triple plan selection envelope (rah-reason-envelope-investigates))
                                    (if (not (str_eq (rale-envelope-status envelope) (rale-status-request-ready)))
                                        (rah-investigate-row persistence triple plan selection envelope (rah-reason-envelope-investigates))
                                        (if (not (rah-envelope-route-action-ok? selection envelope))
                                            (rah-investigate-row persistence triple plan selection envelope (rah-reason-envelope-route-action-mismatch))
                                            (if (not (rah-envelope-kind-ok? selection envelope))
                                                (rah-investigate-row persistence triple plan selection envelope (rah-reason-envelope-artifact-kind-mismatch))
                                                (rah-ready-row persistence triple plan selection envelope (rah-ready-reason selection))))))))))))
    )

    ; Public admission order is fixed: malformed persistence, non-ready
    ; persistence, malformed descriptor triple, then downstream composition.
    (defn rah-handoff-from-persistence (persistence)
        (if (not (scp-persistence? persistence))
            (rah-refused-row persistence (rah-empty-triple) (rah-no-plan) (rah-no-selection) (rah-no-envelope) (rah-reason-malformed-persistence))
            (if (not (scp-persistence-ready? persistence))
                (rah-investigate-row persistence (rah-empty-triple) (rah-no-plan) (rah-no-selection) (rah-no-envelope) (rah-reason-non-ready-persistence))
                (do
                    (let triple (scp-persistence-descriptor-triple persistence))
                    (if (not (rah-triple? triple))
                        (rah-refused-row persistence triple (rah-no-plan) (rah-no-selection) (rah-no-envelope) (rah-reason-malformed-descriptor-triple))
                        (do
                            (let source (sap-triple-source triple))
                            (let fkb (sap-triple-fkb triple))
                            (let dylib (sap-triple-dylib triple))
                            (let plan (rap-plan-from-descriptors source fkb dylib))
                            (let selection (ras-selection-from-plan plan))
                            (let envelope (rale-envelope-from-selection source fkb dylib selection))
                            (rah-handoff-from-components persistence triple plan selection envelope)))))))
)
