; native-idea-valuation-audit-ledger.fk -- Form-native parity for Python
; idea valuation audit entries.
;
; Python update_idea appends AuditEntryType.VALUATION_CHANGE rows to the
; transparent audit ledger for each changed idea field. This module carries the
; same durable audit-ledger table shape and hash-chain append through Postgres.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/application-graph-node-port.fk
;           form-stdlib/native-mutation-side-effects.fk
;
(do
    (defn nival-genesis-hash ()
        "sha256:f7fda58584854be3a8fb954f44723ff9bad5efb41039ff30efccdb677a3b199f")

    (defn nival-pgcrypto-extension-sql ()
        "CREATE EXTENSION IF NOT EXISTS pgcrypto")

    (defn nival-audit-ledger-ddl-sql ()
        (nms-cat (list
            "CREATE TABLE IF NOT EXISTS audit_ledger ("
            "id INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,"
            "entry_type VARCHAR(255) NOT NULL,"
            "timestamp TIMESTAMPTZ NOT NULL,"
            "sender_id VARCHAR(255) NOT NULL,"
            "receiver_id VARCHAR(255) NOT NULL,"
            "amount_cc DOUBLE PRECISION NOT NULL,"
            "reason TEXT NOT NULL,"
            "reference_id VARCHAR(255),"
            "metadata_json TEXT NOT NULL DEFAULT '{}',"
            "hash VARCHAR(255) NOT NULL UNIQUE,"
            "previous_hash VARCHAR(255) NOT NULL"
            ")")))

    (defn nival-create-audit-ledger-table (conn)
        (do
            (pg_exec conn (nival-pgcrypto-extension-sql))
            (pg_exec conn (nival-audit-ledger-ddl-sql))
            conn))

    (defn nival-metadata-json (field old-value-json new-value-json)
        (nms-cat (list
            "{\"field\": \"" field
            "\", \"new_value\": " new-value-json
            ", \"old_value\": " old-value-json
            "}")))

    (defn nival-reason (field idea-id)
        (nms-cat (list "Updated " field " for idea " idea-id)))

    (defn nival-batch-reason (field idea-id)
        (nms-cat (list "Updated " field " for idea " idea-id " (batch)")))

    (defn nival-valuation-change-insert-sql (idea-id field old-value-json new-value-json reason)
        (do
            (let metadata (nival-metadata-json field old-value-json new-value-json))
            (nms-join " " (list
                "WITH previous AS ("
                (nms-cat (list
                    "SELECT COALESCE((SELECT hash FROM audit_ledger ORDER BY id DESC LIMIT 1), "
                    (nms-quote (nival-genesis-hash))
                    ") AS previous_hash"))
                "), stamp AS ("
                "SELECT date_trunc('second', CURRENT_TIMESTAMP) AS ts"
                "), payload AS ("
                (nms-cat (list
                    "SELECT "
                    (nms-quote "VALUATION_CHANGE") " AS entry_type, "
                    (nms-quote "SYSTEM") " AS sender_id, "
                    (nms-quote "SYSTEM") " AS receiver_id, "
                    "0.0::double precision AS amount_cc, "
                    (nms-quote reason) " AS reason, "
                    (nms-quote idea-id) " AS reference_id, "
                    (nms-quote metadata) " AS metadata_json"))
                ")"
                "INSERT INTO audit_ledger"
                "(entry_type, timestamp, sender_id, receiver_id, amount_cc, reason, reference_id, metadata_json, hash, previous_hash)"
                "SELECT"
                "payload.entry_type,"
                "stamp.ts,"
                "payload.sender_id,"
                "payload.receiver_id,"
                "payload.amount_cc,"
                "payload.reason,"
                "payload.reference_id,"
                "payload.metadata_json,"
                (nms-cat (list
                    "'sha256:' || encode(digest(previous.previous_hash || payload.entry_type || "
                    "to_char(stamp.ts AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS\"Z\"') || "
                    "payload.sender_id || payload.receiver_id || "
                    "to_char(payload.amount_cc::numeric, 'FM999999999990.00000000') || "
                    "payload.reason || COALESCE(payload.reference_id, '') || payload.metadata_json, 'sha256'), 'hex'),"))
                "previous.previous_hash"
                "FROM previous, stamp, payload"))))

    (defn nival-record-valuation-change (conn idea-id field old-value-json new-value-json)
        (do
            (nival-create-audit-ledger-table conn)
            (pg_exec conn (nival-valuation-change-insert-sql
                idea-id
                field
                old-value-json
                new-value-json
                (nival-reason field idea-id)))
            conn))

    (defn nival-record-batch-valuation-change (conn idea-id field old-value-json new-value-json)
        (do
            (nival-create-audit-ledger-table conn)
            (pg_exec conn (nival-valuation-change-insert-sql
                idea-id
                field
                old-value-json
                new-value-json
                (nival-batch-reason field idea-id)))
            conn))

    (defn nival-hash-recompute-sql ()
        (nms-cat (list
            "SELECT count(*) FROM audit_ledger WHERE hash = 'sha256:' || encode(digest("
            "previous_hash || entry_type || "
            "to_char(timestamp AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS\"Z\"') || "
            "sender_id || receiver_id || "
            "to_char(amount_cc::numeric, 'FM999999999990.00000000') || "
            "reason || COALESCE(reference_id, '') || metadata_json, 'sha256'), 'hex')")))

    (defn nival-run-idea-update-with-valuation-audit
        (conn mutation-id revision-id node-id name description phase property-patch fields-changed contributor-key-hash author field old-value-json new-value-json)
        (do
            (agn-update-node conn revision-id node-id name description phase property-patch fields-changed "kernel-route-runner" author)
            (nms-create-receipts-table conn)
            (nms-record-cache-invalidation conn mutation-id node-id)
            (if (gt (str_len contributor-key-hash) 0)
                (nms-audit-contributor-key conn contributor-key-hash)
                conn)
            (nms-record-rollback-receipt conn mutation-id node-id)
            (nival-record-valuation-change conn node-id field old-value-json new-value-json)
            conn))

    (defn nival-audit-ledger-contract-json ()
        (nms-cat (list
            "{\"state\":\"idea-valuation-audit-ledger-native\""
            ",\"entry_type\":\"VALUATION_CHANGE\""
            ",\"sender_id\":\"SYSTEM\""
            ",\"receiver_id\":\"SYSTEM\""
            ",\"hash_chain\":\"sha256(previous_hash || payload)\""
            ",\"ordinary_traffic_flip_performed\":false"
            "}")))

    ;; 111111 =
    ;;   audit table + pgcrypto extension
    ;;   VALUATION_CHANGE insert shape
    ;;   Python parity fields and metadata order
    ;;   sha256 hash-chain recompute SQL
    ;;   pg_exec wrappers exposed
    ;;   idea update route-runner wrapper binds graph update + audit ledger
    (defn nival-audit-ledger-test ()
        (do
            (let ddl (nival-audit-ledger-ddl-sql))
            (let ext (nival-pgcrypto-extension-sql))
            (let meta (nival-metadata-json "actual_value" "5.0" "7.0"))
            (let insert-sql (nival-valuation-change-insert-sql "idea-audit-native" "actual_value" "5.0" "7.0" "Updated actual_value for idea idea-audit-native"))
            (let recompute-sql (nival-hash-recompute-sql))
            (let contract (nival-audit-ledger-contract-json))
            (let ddl-ok (if (eq (nms-and4
                (nms-contains? ddl "CREATE TABLE IF NOT EXISTS audit_ledger")
                (nms-contains? ddl "previous_hash")
                (nms-contains? ext "CREATE EXTENSION IF NOT EXISTS pgcrypto")
                (nms-contains? ddl "hash VARCHAR")) 1) 1 0))
            (let insert-ok (if (eq (nms-and4
                (nms-contains? insert-sql "VALUATION_CHANGE")
                (nms-contains? insert-sql "SYSTEM")
                (nms-contains? insert-sql "INSERT INTO audit_ledger")
                (nms-contains? insert-sql "ORDER BY id DESC LIMIT 1")) 1) 10 0))
            (let metadata-ok (if (eq (nms-and3
                (nms-contains? meta "\"field\": \"actual_value\"")
                (nms-contains? meta "\"new_value\": 7.0")
                (nms-contains? meta "\"old_value\": 5.0")) 1) 100 0))
            (let hash-ok (if (eq (nms-and4
                (nms-contains? insert-sql "sha256:")
                (nms-contains? insert-sql "digest(previous.previous_hash")
                (nms-contains? insert-sql "0.00000000")
                (nms-contains? recompute-sql "metadata_json")) 1) 1000 0))
            (let wrapper-ok (if (eq (nms-and3
                (nms-contains? "nival-record-valuation-change nival-record-batch-valuation-change nival-create-audit-ledger-table" "nival-record-valuation-change")
                (nms-contains? "nival-record-valuation-change nival-record-batch-valuation-change nival-create-audit-ledger-table" "nival-record-batch-valuation-change")
                (nms-contains? "nival-record-valuation-change nival-record-batch-valuation-change nival-create-audit-ledger-table" "nival-create-audit-ledger-table")) 1) 10000 0))
            (let route-ok (if (eq (nms-and4
                (nms-contains? "nival-run-idea-update-with-valuation-audit agn-update-node nms-record-cache-invalidation nival-record-valuation-change" "nival-run-idea-update-with-valuation-audit")
                (nms-contains? "nival-run-idea-update-with-valuation-audit agn-update-node nms-record-cache-invalidation nival-record-valuation-change" "agn-update-node")
                (nms-contains? "nival-run-idea-update-with-valuation-audit agn-update-node nms-record-cache-invalidation nival-record-valuation-change" "nms-record-cache-invalidation")
                (nms-contains? contract "ordinary_traffic_flip_performed")) 1) 100000 0))
            (sum (list ddl-ok insert-ok metadata-ok hash-ok wrapper-ok route-ok))))

    0)
