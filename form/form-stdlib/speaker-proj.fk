; speaker-proj.fk — Challenger 2-full ("Proj"): a learned FULL linear projection, FLOAT SGD.
;
; C2-diagonal only rescaled axes and lost; identity that lives in a COMBINATION of bands needs a
; rotation. This learns a full matrix W (K rows × N) by squared-loss SGD toward speaker target
; codes — the i-vector→LDA projection. It runs on plain floats (the same arithmetic the Form
; whisper block trains on, fp64, four-way) — NOT integer fixed-point, whose rounding silently
; zeroed the small gradients. W·x rotates the supervector; cosine scores in that space.
;
; All float (0.0 init, float lr). Proven by form-stdlib/tests/speaker-proj-band.fk.

(do
    ; --- float dot + forward: y_j = W_j · x ---
    (defn sp-dot (w x) (if (eq (len w) 0) 0.0 (add (mul (head w) (head x)) (sp-dot (tail w) (tail x)))))
    (defn sp-matvec (W x) (if (eq (len W) 0) (empty) (cons (sp-dot (head W) x) (sp-matvec (tail W) x))))
    (defn sp-project (W x) (sp-matvec W x))

    ; --- errors e = y − t and squared loss ---
    (defn sp-err (y t) (if (eq (len y) 0) (empty) (cons (sub (head y) (head t)) (sp-err (tail y) (tail t)))))
    (defn sp-sqsum (e) (if (eq (len e) 0) 0.0 (add (mul (head e) (head e)) (sp-sqsum (tail e)))))
    (defn sp-loss (W x t) (sp-sqsum (sp-err (sp-matvec W x) t)))

    ; --- SGD: w_i <- w_i − lr · 2 · e_j · x_i   (pure float — no fixed-point, no rounding) ---
    (defn sp-row-step (w x ej lr)
        (if (eq (len w) 0) (empty)
            (cons (sub (head w) (mul lr (mul (mul 2.0 ej) (head x)))) (sp-row-step (tail w) (tail x) ej lr))))
    (defn sp-step-rows (W x e lr)
        (if (eq (len W) 0) (empty)
            (cons (sp-row-step (head W) x (head e) lr) (sp-step-rows (tail W) x (tail e) lr))))
    (defn sp-step (W x t lr) (sp-step-rows W x (sp-err (sp-matvec W x) t) lr))

    ; --- fold over the corpus (list of (x t)) for N epochs ---
    (defn sp-x (s) (nth s 0))
    (defn sp-t (s) (nth s 1))
    (defn sp-epoch (W corpus lr)
        (if (eq (len corpus) 0) W
            (sp-epoch (sp-step W (sp-x (head corpus)) (sp-t (head corpus)) lr) (tail corpus) lr)))
    (defn sp-train (W corpus lr epochs)
        (if (eq epochs 0) W (sp-train (sp-epoch W corpus lr) corpus lr (sub epochs 1)))))
