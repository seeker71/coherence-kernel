; shell-lower.fk — shell source -> recipe -> blueprint -> cell.
;
; The last leg of the form-native shell pipeline. The shell grammar already
; produces a Form recipe (the fncall AST is a walkable recipe tree). This wraps
; that recipe with a blueprint marker into a CELL — the addressable, persistable,
; executable unit the substrate stores (persistence.fk make-cell-recipe shape:
; child 0 name, 1 domain, 2 blueprint, 3 ctor). A lowered fsh cell can be put in
; a cell store, shared between presences, and run on the 4th kernel; the ctor
; recipe is exactly what shell-exec walks, and what JIT-lowers to native.
;
; New blueprint NAMES can't be minted without rebuilding every kernel (bp_table
; is generated + compiled in), so the cell SHAPE reuses the registered CELL-V0,
; and the fsh-script identity is a directly-minted type-99 NodeID (make_nodeid),
; which needs no registry entry because nothing looks it up by name.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/shell-exec.fk

(do
    ;; the fsh-script blueprint marker — a type-99 user shape, minted directly.
    (defn fsh-bp () (make_nodeid 1 2 99 31415))

    ;; build a CELL recipe (CELL-V0 shape): name, domain, blueprint, ctor.
    (defn sh-cell (name domain blueprint ctor)
        (intern_node (bp "CELL-V0")
            (list (intern_trivial_string name)
                  (intern_trivial_string domain)
                  blueprint
                  ctor)))
    (defn sh-cell-name (c) (node_value (head (node_children c))))
    (defn sh-cell-domain (c) (node_value (nth (node_children c) 1)))
    (defn sh-cell-blueprint (c) (nth (node_children c) 2))
    (defn sh-cell-ctor (c) (nth (node_children c) 3))

    ;; lower shell SOURCE into a cell: parse -> AST recipe -> CELL(fsh, fsh-bp).
    (defn sh-lower (name src) (sh-cell name "fsh" (fsh-bp) (sh-parse src)))

    ;; run a lowered cell's ctor recipe from an empty env -> stdout.
    (defn sh-cell-run (c) (head (sh-eval (sh-cell-ctor c) (sh-env-empty))))
)
