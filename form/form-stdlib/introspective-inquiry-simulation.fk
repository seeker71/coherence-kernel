; introspective-inquiry-simulation.fk — compare an observed inquiry path with
; a native recursive inquiry receipt, choose the next repair from the missing
; frontier, and re-measure after every intervention.
; witnessed: 2026-07-22 -> iteration 4 reaches 16/16 native path capabilities
(do
  ; Receipt capabilities, in path order.
  (defn iis-arrive () 1)       (defn iis-recognize () 2)
  (defn iis-perspective () 4)  (defn iis-channels () 8)
  (defn iis-subtle-typed () 16)(defn iis-compare () 32)
  (defn iis-sufficiency () 64) (defn iis-interface () 128)
  (defn iis-tool-offer () 256) (defn iis-raw-observation () 512)
  (defn iis-ground () 1024)    (defn iis-reflect () 2048)
  (defn iis-emit () 4096)      (defn iis-execute () 8192)
  (defn iis-rewitness () 16384)(defn iis-ack-recur () 32768)
  (defn iis-full () 65535)

  (defn iis-has? (mask bit) (mod (div mask bit) 2))
  (defn iis-add (mask bit) (if (eq (iis-has? mask bit) 1) mask (add mask bit)))
  (defn iis-add-all (mask bits)
    (if (eq (len bits) 0) mask (iis-add-all (iis-add mask (head bits)) (tail bits))))
  (defn iis-merge-loop (mask offered bit left)
    (if (eq left 0) mask
      (iis-merge-loop (if (eq (iis-has? offered bit) 1) (iis-add mask bit) mask)
        offered (mul bit 2) (sub left 1))))
  (defn iis-merge (mask offered) (iis-merge-loop mask offered 1 16))
  (defn iis-count-loop (mask bit left)
    (if (eq left 0) 0
      (add (iis-has? mask bit) (iis-count-loop mask (mul bit 2) (sub left 1)))))
  (defn iis-count (mask) (iis-count-loop mask 1 16))
  (defn iis-overlap-loop (a b bit left)
    (if (eq left 0) 0
      (add (if (and (eq (iis-has? a bit) 1) (eq (iis-has? b bit) 1)) 1 0)
        (iis-overlap-loop a b (mul bit 2) (sub left 1)))))
  (defn iis-overlap (a b) (iis-overlap-loop a b 1 16))
  (defn iis-percent (candidate target)
    (div (mul (iis-overlap candidate target) 1000) (iis-count target)))

  ; The observed previous assistant path: it arrived, recognized, searched,
  ; compared, selected and called a read interface, grounded, reflected, and
  ; emitted. It did not type a subtle candidate, mutate/execute the proposed
  ; design, re-witness the consequence, or recursively acknowledge it.
  (defn iis-observed-assistant-path () 8175)

  ; Existing relational metabolism floor: question/lane/perspective/channels,
  ; comparison, sufficiency, and nothing/0/1/node acknowledgement.
  (defn iis-native-floor () 32879)

  ; Intervention ids are data, not commands:
  ; 1 hint, 2 prompt, 3 system-card, 4 base-tuning, 5 native-choice-tree,
  ; 6 observation-binding, 7 closed-loop reflection, 8 native emission.
  (defn iis-intervention-mask (id)
    (if (eq id 1) (iis-add-all 0 (list (iis-recognize) (iis-reflect)))
    (if (eq id 2) (iis-add-all 0 (list (iis-recognize) (iis-ground) (iis-emit)))
    (if (eq id 3) (iis-add-all 0 (list (iis-compare) (iis-reflect) (iis-rewitness)))
    (if (eq id 4) (iis-add-all 0 (list (iis-recognize) (iis-reflect) (iis-emit)))
    (if (eq id 5) (iis-add-all 0 (list (iis-interface) (iis-tool-offer)))
    (if (eq id 6) (iis-add-all 0 (list (iis-raw-observation) (iis-ground) (iis-execute)))
    (if (eq id 7) (iis-add-all 0 (list (iis-subtle-typed) (iis-reflect) (iis-rewitness) (iis-ack-recur)))
    (if (eq id 8) (iis-emit)
      0)))))))))

  (defn iis-gain (mask target intervention)
    (sub (iis-overlap (iis-merge mask (iis-intervention-mask intervention)) target)
         (iis-overlap mask target)))
  (defn iis-best-loop (mask target ids best best-gain)
    (if (eq (len ids) 0) best
      (do (let id (head ids)) (let gain (iis-gain mask target id))
        (iis-best-loop mask target (tail ids)
          (if (gt gain best-gain) id best) (if (gt gain best-gain) gain best-gain)))))
  (defn iis-best (mask target ids) (iis-best-loop mask target ids 0 0))

  ; Prefer structural native repairs (5..7). Hints/prompts/system/base tuning
  ; remain comparison candidates: they may improve rented behavior but cannot
  ; make an absent native observation interface real.
  (defn iis-native-choice (mask target)
    (iis-best mask target (list 5 6 7 8)))
  (defn iis-rented-choice (mask target)
    (iis-best mask target (list 1 2 3 4)))

  ; [iteration,mask,matched,target-count,permille,native,local,remote,
  ;  native-intervention,rented-counterfactual]
  (defn iis-row (iteration mask target native-count local-count remote-count native-id rented-id)
    (list iteration mask (iis-overlap mask target) (iis-count target)
      (iis-percent mask target) native-count local-count remote-count native-id rented-id))

  (defn iis-simulate ()
    (do (let target (iis-observed-assistant-path))
      (let m0 (iis-native-floor))
      (let n1 (iis-native-choice m0 target))
      (let m1 (iis-merge m0 (iis-intervention-mask n1)))
      (let n2 (iis-native-choice m1 target))
      (let m2 (iis-merge m1 (iis-intervention-mask n2)))
      (let n3 (iis-native-choice m2 (iis-full)))
      (let m3 (iis-merge m2 (iis-intervention-mask n3)))
      (let n4 (iis-native-choice m3 (iis-full)))
      (let m4 (iis-merge m3 (iis-intervention-mask n4)))
      (list
        (iis-row 0 m0 target 7 3 3 0 (iis-rented-choice m0 target))
        (iis-row 1 m1 target (iis-count m1) 0 (sub (iis-count target) (iis-overlap m1 target)) n1 (iis-rented-choice m1 target))
        (iis-row 2 m2 target (iis-count m2) 0 (sub (iis-count target) (iis-overlap m2 target)) n2 (iis-rented-choice m2 target))
        (iis-row 3 m3 (iis-full) (iis-count m3) 0 (sub 16 (iis-count m3)) n3 (iis-rented-choice m3 (iis-full)))
        (iis-row 4 m4 (iis-full) (iis-count m4) 0 (sub 16 (iis-count m4)) n4 (iis-rented-choice m4 (iis-full))))))
  0)
