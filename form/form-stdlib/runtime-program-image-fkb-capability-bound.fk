; runtime-program-image-fkb-capability-bound.fk -- 9h2 capability-bound join.
;
; Layer 9h2 joins the 9g executor-readiness evidence with the 9h1 supplied
; program-image attempt adapter. A supplied run is capability-bound only when the
; readiness row, its nested capability evidence, and the 9h1 bridge all agree on
; the same 9e request identity. This is not artifact loading or execution.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/runtime-artifact-attempt-receipt.fk
;           form-stdlib/runtime-artifact-executor-capability.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-fkb-byte-container.fk
;           form-stdlib/program-image-fkb-byte-file-witness.fk
;           form-stdlib/program-image-fkb-byte-decode.fk
;           form-stdlib/runtime-program-image-fkb-attempt.fk

(do
    (defn rpifc-version () "runtime-program-image-fkb-capability-bound-v1")

    (defn rpifc-feature (name status) (list "runtime-program-image-fkb-capability-bound-feature" name status))
    (defn rpifc-feature-name (f) (nth f 1))
    (defn rpifc-feature-status (f) (nth f 2))
    (defn runtime-program-image-fkb-capability-bound-manifest ()
        (list
            (rpifc-feature "capability-bound-join-not-loader" 1)
            (rpifc-feature "wraps-9g-and-9h1-without-mutating-them" 1)
            (rpifc-feature "supplied-readiness-and-run-only" 1)
            (rpifc-feature "envelope-must-be-program-image-fkb" 1)
            (rpifc-feature "readiness-row-shape-required" 1)
            (rpifc-feature "ready-status-alone-not-trusted" 1)
            (rpifc-feature "capability-ready-reason-required" 1)
            (rpifc-feature "supplied-current-evidence-required" 1)
            (rpifc-feature "attempt-supplier-authority-required" 1)
            (rpifc-feature "current-freshness-required" 1)
            (rpifc-feature "program-image-walker-required" 1)
            (rpifc-feature "full-9f-identity-match-required" 1)
            (rpifc-feature "nested-capability-revalidated" 1)
            (rpifc-feature "readiness-recomputed-from-capability" 1)
            (rpifc-feature "delegates-to-9h1-after-readiness" 1)
            (rpifc-feature "9h1-refusal-or-investigation-exposed" 1)
            (rpifc-feature "non-ready-readiness-produces-no-attempt" 1)
            (rpifc-feature "forged-readiness-produces-no-attempt" 1)
            (rpifc-feature "hard-and-soft-statuses-preserved" 1)
            (rpifc-feature "no-artifact-open" 1)
            (rpifc-feature "no-byte-hashing" 1)
            (rpifc-feature "no-program-image-load" 1)
            (rpifc-feature "no-native-call" 1)
            (rpifc-feature "no-selector-install" 1)
            (rpifc-feature "no-c-seed-growth" 1)))
    (defn runtime-program-image-fkb-capability-bound-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rpifc-feature-name (head fs)) name)
                     (eq (rpifc-feature-status (head fs)) 1))
                1
                (runtime-program-image-fkb-capability-bound-manifest-has? name (tail fs)))))

    (defn rpifc-status-bound () "capability-bound")
    (defn rpifc-status-unavailable () "unavailable")
    (defn rpifc-status-investigate () "investigate")
    (defn rpifc-status-refused () "refused")

    (defn rpifc-reason-capability-bound () "capability-bound")
    (defn rpifc-reason-malformed-envelope () "malformed-envelope")
    (defn rpifc-reason-non-program-image-envelope () "non-program-image-envelope")
    (defn rpifc-reason-malformed-readiness () "malformed-readiness")
    (defn rpifc-reason-readiness-envelope-identity-mismatch () "readiness-envelope-identity-mismatch")
    (defn rpifc-reason-readiness-field-mismatch () "readiness-field-mismatch")
    (defn rpifc-reason-readiness-ready-fields-forged () "readiness-ready-fields-forged")
    (defn rpifc-reason-malformed-capability () "malformed-capability")
    (defn rpifc-reason-nested-capability-mismatch () "nested-capability-mismatch")
    (defn rpifc-reason-nested-capability-evidence-mismatch () "nested-capability-evidence-mismatch")
    (defn rpifc-reason-recomputed-readiness-mismatch () "recomputed-readiness-mismatch")
    (defn rpifc-reason-manifest ()
        (list
            (rpifc-reason-capability-bound)
            (rpifc-reason-malformed-envelope)
            (rpifc-reason-non-program-image-envelope)
            (rpifc-reason-malformed-readiness)
            (rpifc-reason-readiness-envelope-identity-mismatch)
            (rpifc-reason-readiness-field-mismatch)
            (rpifc-reason-readiness-ready-fields-forged)
            (rpifc-reason-malformed-capability)
            (rpifc-reason-nested-capability-mismatch)
            (rpifc-reason-nested-capability-evidence-mismatch)
            (rpifc-reason-recomputed-readiness-mismatch)
            (raec-reason-no-capability-supplied)
            (raec-reason-capability-unavailable)
            (raec-reason-capability-stale)
            (raec-reason-evidence-inadequate)
            (raec-reason-forbidden-authority)
            (rpifa-reason-malformed-admission)
            (rpifa-reason-non-admitted-admission)
            (rpifa-reason-admission-decode-not-decoded)
            (rpifa-reason-admission-invalid-pif)
            (rpifa-reason-admission-decode-pif-mismatch)
            (rpifa-reason-artifact-identity-mismatch)
            (rpifa-reason-malformed-supplied-run)
            (rpifa-reason-negative-output)
            (rpifa-reason-run-path-mismatch)
            (rpifa-reason-empty-output)))

    (defn rpifc-no-bridge () (list "runtime-program-image-fkb-capability-bound-no-bridge"))
    (defn rpifc-no-bridge? (b)
        (if (eq (len b) 1)
            (str_eq (nth b 0) "runtime-program-image-fkb-capability-bound-no-bridge")
            0))

    ; join = ("runtime-program-image-fkb-capability-bound-join" envelope
    ;         readiness admission run bridge attempt status reason)
    (defn rpifc-join-row (envelope readiness admission run bridge attempt status reason)
        (list "runtime-program-image-fkb-capability-bound-join"
              envelope readiness admission run bridge attempt status reason))
    (defn rpifc-join? (j)
        (if (eq (len j) 9)
            (str_eq (nth j 0) "runtime-program-image-fkb-capability-bound-join")
            0))
    (defn rpifc-join-envelope (j) (nth j 1))
    (defn rpifc-join-readiness (j) (nth j 2))
    (defn rpifc-join-admission (j) (nth j 3))
    (defn rpifc-join-run (j) (nth j 4))
    (defn rpifc-join-bridge (j) (nth j 5))
    (defn rpifc-join-attempt (j) (nth j 6))
    (defn rpifc-join-status (j) (nth j 7))
    (defn rpifc-join-reason (j) (nth j 8))

    (defn rpifc-no-attempt () (rpifa-no-attempt))
    (defn rpifc-no-attempt? (a) (rpifa-no-attempt? a))
    (defn rpifc-investigate (envelope readiness admission run reason)
        (rpifc-join-row envelope readiness admission run (rpifc-no-bridge)
                         (rpifc-no-attempt) (rpifc-status-investigate) reason))
    (defn rpifc-refused (envelope readiness admission run reason)
        (rpifc-join-row envelope readiness admission run (rpifc-no-bridge)
                         (rpifc-no-attempt) (rpifc-status-refused) reason))
    (defn rpifc-unavailable (envelope readiness admission run reason)
        (rpifc-join-row envelope readiness admission run (rpifc-no-bridge)
                         (rpifc-no-attempt) (rpifc-status-unavailable) reason))

    (defn rpifc-readiness-terminal (envelope readiness admission run)
        (if (str_eq (raec-readiness-status readiness) (raec-status-unavailable))
            (rpifc-unavailable envelope readiness admission run (raec-readiness-reason readiness))
            (if (str_eq (raec-readiness-status readiness) (raec-status-refused))
                (rpifc-refused envelope readiness admission run (raec-readiness-reason readiness))
                (rpifc-investigate envelope readiness admission run (raec-readiness-reason readiness)))))

    (defn rpifc-program-image-envelope? (envelope)
        (rpifa-program-image-envelope? envelope))
    (defn rpifc-envelope-identity-matches? (expected actual)
        (if (and (rale-envelope? expected) (rale-envelope? actual))
            (and (str_eq (rale-envelope-action actual) (rale-envelope-action expected))
            (and (eq (rale-envelope-route actual) (rale-envelope-route expected))
            (and (str_eq (rale-envelope-artifact-kind actual) (rale-envelope-artifact-kind expected))
            (and (str_eq (rale-envelope-artifact-path actual) (rale-envelope-artifact-path expected))
            (and (str_eq (rale-envelope-source-hash actual) (rale-envelope-source-hash expected))
                 (str_eq (rale-envelope-content-hash actual) (rale-envelope-content-hash expected)))))))
            0))
    (defn rpifc-readiness-envelope-matches? (envelope readiness)
        (rpifc-envelope-identity-matches? envelope (raec-readiness-envelope readiness)))
    (defn rpifc-readiness-fields-match-envelope? (envelope readiness)
        (and (str_eq (raec-readiness-action readiness) (rale-envelope-action envelope))
        (and (eq (raec-readiness-route readiness) (rale-envelope-route envelope))
        (and (str_eq (raec-readiness-artifact-kind readiness) (rale-envelope-artifact-kind envelope))
             (str_eq (raec-readiness-required-capability readiness) (raec-cap-program-image-walker))))))
    (defn rpifc-readiness-ready-fields? (readiness)
        (and (str_eq (raec-readiness-status readiness) (raec-status-ready))
        (and (str_eq (raec-readiness-reason readiness) (raec-reason-ready))
        (and (str_eq (raec-readiness-evidence-kind readiness) (raec-evidence-supplied-current))
        (and (str_eq (raec-readiness-authority readiness) (raec-authority-attempt-supplier))
             (str_eq (raec-readiness-freshness readiness) (raec-freshness-current)))))))
    (defn rpifc-capability-tuple-matches-envelope? (envelope capability)
        (and (str_eq (raec-capability-name capability) (raec-cap-program-image-walker))
        (and (str_eq (raec-capability-action capability) (rale-envelope-action envelope))
        (and (eq (raec-capability-route capability) (rale-envelope-route envelope))
             (str_eq (raec-capability-artifact-kind capability) (rale-envelope-artifact-kind envelope))))))
    (defn rpifc-capability-evidence-current? (capability)
        (and (str_eq (raec-capability-availability capability) (raec-availability-available))
        (and (str_eq (raec-capability-evidence-kind capability) (raec-evidence-supplied-current))
        (and (str_eq (raec-capability-authority capability) (raec-authority-attempt-supplier))
             (str_eq (raec-capability-freshness capability) (raec-freshness-current))))))
    (defn rpifc-recomputed-readiness-matches? (envelope readiness)
        (do
            (let recomputed (raec-readiness-from-envelope-capability envelope (raec-readiness-capability readiness)))
            (and (raec-readiness? recomputed)
            (and (str_eq (raec-readiness-status recomputed) (raec-status-ready))
            (and (str_eq (raec-readiness-reason recomputed) (raec-reason-ready))
            (and (str_eq (raec-readiness-required-capability recomputed) (raec-cap-program-image-walker))
            (and (str_eq (raec-readiness-evidence-kind recomputed) (raec-evidence-supplied-current))
            (and (str_eq (raec-readiness-authority recomputed) (raec-authority-attempt-supplier))
            (and (str_eq (raec-readiness-freshness recomputed) (raec-freshness-current))
            (and (str_eq (raec-readiness-action recomputed) (raec-readiness-action readiness))
            (and (eq (raec-readiness-route recomputed) (raec-readiness-route readiness))
            (and (str_eq (raec-readiness-artifact-kind recomputed) (raec-readiness-artifact-kind readiness))
                 (str_eq (raec-readiness-detail recomputed) (raec-readiness-detail readiness))))))))))))))

    (defn rpifc-join-from-bridge (envelope readiness admission run bridge)
        (if (str_eq (rpifa-bridge-status bridge) (rpifa-status-attempt-ready))
            (rpifc-join-row envelope readiness admission run bridge
                             (rpifa-bridge-attempt bridge)
                             (rpifc-status-bound)
                             (rpifc-reason-capability-bound))
            (rpifc-join-row envelope readiness admission run bridge
                             (rpifa-bridge-attempt bridge)
                             (rpifa-bridge-status bridge)
                             (rpifa-bridge-reason bridge))))

    (defn rpifc-join-from-run (envelope readiness admission run)
        (if (not (rale-envelope? envelope))
            (rpifc-refused envelope readiness admission run (rpifc-reason-malformed-envelope))
            (if (not (rpifc-program-image-envelope? envelope))
                (rpifc-investigate envelope readiness admission run (rpifc-reason-non-program-image-envelope))
                (if (not (raec-readiness? readiness))
                    (rpifc-refused envelope readiness admission run (rpifc-reason-malformed-readiness))
                    (if (not (rpifc-readiness-envelope-matches? envelope readiness))
                        (rpifc-investigate envelope readiness admission run (rpifc-reason-readiness-envelope-identity-mismatch))
                        (if (not (rpifc-readiness-fields-match-envelope? envelope readiness))
                            (rpifc-investigate envelope readiness admission run (rpifc-reason-readiness-field-mismatch))
                            (if (not (str_eq (raec-readiness-status readiness) (raec-status-ready)))
                                (rpifc-readiness-terminal envelope readiness admission run)
                                (if (not (rpifc-readiness-ready-fields? readiness))
                                    (rpifc-investigate envelope readiness admission run (rpifc-reason-readiness-ready-fields-forged))
                                    (do
                                        (let capability (raec-readiness-capability readiness))
                                        (if (not (raec-capability? capability))
                                            (rpifc-refused envelope readiness admission run (rpifc-reason-malformed-capability))
                                            (if (not (rpifc-capability-tuple-matches-envelope? envelope capability))
                                                (rpifc-investigate envelope readiness admission run (rpifc-reason-nested-capability-mismatch))
                                                (if (not (rpifc-capability-evidence-current? capability))
                                                    (rpifc-investigate envelope readiness admission run (rpifc-reason-nested-capability-evidence-mismatch))
                                                    (if (not (rpifc-recomputed-readiness-matches? envelope readiness))
                                                        (rpifc-investigate envelope readiness admission run (rpifc-reason-recomputed-readiness-mismatch))
                                                        (rpifc-join-from-bridge envelope readiness admission run
                                                            (rpifa-bridge-from-run envelope admission run)))))))))))))))
)
