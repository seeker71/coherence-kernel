; native-training-receipt.fk - receipt rows for Form-native trained artifacts.
;
; The row names the minimum proof for a trained native artifact: recipe source,
; weight/prototype digest, data digest, eval digest, sample counts, heldout
; counts, and native-vs-oracle score. It does not claim model authority by
; configuration; authority starts only when a receipt proves weights, data, and
; eval together.

(do
    (defn ntr-row
        (artifact-id kind recipe-path weights-merkle dataset-merkle eval-merkle
         cycle-count sample-count heldout-count correct-count wrong-count
         native-accuracy-ppm oracle-accuracy-ppm status)
        (list
            "native-training-receipt"
            artifact-id
            kind
            recipe-path
            weights-merkle
            dataset-merkle
            eval-merkle
            cycle-count
            sample-count
            heldout-count
            correct-count
            wrong-count
            native-accuracy-ppm
            oracle-accuracy-ppm
            status))

    (defn ntr-row? (value)
        (if (eq (len value) 15)
            (str_eq (nth value 0) "native-training-receipt")
            0))

    (defn ntr-artifact-id (row) (nth row 1))
    (defn ntr-kind (row) (nth row 2))
    (defn ntr-recipe-path (row) (nth row 3))
    (defn ntr-weights-merkle (row) (nth row 4))
    (defn ntr-dataset-merkle (row) (nth row 5))
    (defn ntr-eval-merkle (row) (nth row 6))
    (defn ntr-cycle-count (row) (nth row 7))
    (defn ntr-sample-count (row) (nth row 8))
    (defn ntr-heldout-count (row) (nth row 9))
    (defn ntr-correct-count (row) (nth row 10))
    (defn ntr-wrong-count (row) (nth row 11))
    (defn ntr-native-accuracy-ppm (row) (nth row 12))
    (defn ntr-oracle-accuracy-ppm (row) (nth row 13))
    (defn ntr-status (row) (nth row 14))

    (defn ntr-text-present? (value) (not (str_eq value "")))
    (defn ntr-counts-close? (row)
        (eq (add (ntr-correct-count row) (ntr-wrong-count row)) (ntr-heldout-count row)))

    (defn ntr-has-digests? (row)
        (if (ntr-text-present? (ntr-weights-merkle row))
            (if (ntr-text-present? (ntr-dataset-merkle row))
                (if (ntr-text-present? (ntr-eval-merkle row)) 1 0)
                0)
            0))

    (defn ntr-trained? (row)
        (if (ntr-row? row)
            (if (str_eq (ntr-status row) "active")
                (if (gt (ntr-cycle-count row) 0)
                    (if (gt (ntr-sample-count row) 0)
                        (if (gt (ntr-heldout-count row) 0)
                            (if (ntr-counts-close? row)
                                (ntr-has-digests? row)
                                0)
                            0)
                        0)
                    0)
                0)
            0))

    (defn ntr-beats-oracle? (row)
        (if (ntr-trained? row)
            (gt (ntr-native-accuracy-ppm row) (ntr-oracle-accuracy-ppm row))
            0))
    (defn ntr-larger-heldout-window? (row min-heldout min-cycles)
        (if (ntr-trained? row)
            (if (ge (ntr-heldout-count row) min-heldout)
                (if (ge (ntr-cycle-count row) min-cycles) 1 0)
                0)
            0))
    (defn ntr-feature-vector (feature)
        (if (str_eq feature "speech-transcribe")
            (list 5 0 0)
            (if (str_eq feature "vision-describe")
                (list 0 5 0)
                (if (str_eq feature "multimodal-align")
                    (list 5 5 5)
                    (if (str_eq feature "gpu-readback-kernel")
                        (list 0 0 5)
                        (empty))))))
    (defn ntr-label-row (cycle-seq feature label privacy)
        (list cycle-seq feature label (ntr-feature-vector feature) privacy))
    (defn ntr-label-cycle-seq (row) (nth row 0))
    (defn ntr-label-feature (row) (nth row 1))
    (defn ntr-label-value (row) (nth row 2))
    (defn ntr-label-vector (row) (nth row 3))
    (defn ntr-label-privacy (row) (nth row 4))
    (defn ntr-label-valid? (row)
        (if (and
                (gt (ntr-label-cycle-seq row) 0)
                (and
                    (not (str_eq (ntr-label-feature row) ""))
                    (and
                        (not (str_eq (ntr-label-value row) ""))
                        (and
                            (gt (len (ntr-label-vector row)) 0)
                            (not (str_eq (ntr-label-privacy row) "raw-media"))))))
            1
            0))
    (defn ntr-labels-valid-count (rows)
        (if (eq (len rows) 0) 0
            (add (ntr-label-valid? (head rows)) (ntr-labels-valid-count (tail rows)))))
    (defn ntr-witness-cycle (sequence export-checksum sample-count labels)
        (list sequence export-checksum sample-count labels))
    (defn ntr-witness-cycle-seq (cycle) (nth cycle 0))
    (defn ntr-witness-cycle-export-checksum (cycle) (nth cycle 1))
    (defn ntr-witness-cycle-sample-count (cycle) (nth cycle 2))
    (defn ntr-witness-cycle-labels (cycle) (nth cycle 3))
    (defn ntr-witness-cycle-valid? (cycle)
        (if (and
                (gt (ntr-witness-cycle-seq cycle) 0)
                (and
                    (not (str_eq (ntr-witness-cycle-export-checksum cycle) ""))
                    (and
                        (gt (ntr-witness-cycle-sample-count cycle) 0)
                        (ge (ntr-labels-valid-count (ntr-witness-cycle-labels cycle)) 4))))
            1
            0))
    (defn ntr-witness-cycle-label-count (cycles)
        (if (eq (len cycles) 0) 0
            (add
                (ntr-labels-valid-count (ntr-witness-cycle-labels (head cycles)))
                (ntr-witness-cycle-label-count (tail cycles)))))
    (defn ntr-witness-cycles-all-valid? (cycles)
        (if (eq (len cycles) 0) 1
            (if (eq (ntr-witness-cycle-valid? (head cycles)) 1)
                (ntr-witness-cycles-all-valid? (tail cycles))
                0)))
    (defn ntr-witness-cycle-next? (previous next)
        (if (and
                (gt (ntr-witness-cycle-seq next) (ntr-witness-cycle-seq previous))
                (ge (ntr-witness-cycle-sample-count next) (ntr-witness-cycle-sample-count previous)))
            1
            0))
    (defn ntr-witness-cycles-increasing? (cycles)
        (if (eq (len cycles) 0) 1
            (if (eq (len (tail cycles)) 0) 1
                (if (eq (ntr-witness-cycle-next? (head cycles) (head (tail cycles))) 1)
                    (ntr-witness-cycles-increasing? (tail cycles))
                    0))))
    (defn ntr-witness-cycle-window-ready? (cycles min-cycles min-heldout)
        (if (and
                (ge (len cycles) min-cycles)
                (and
                    (eq (ntr-witness-cycles-all-valid? cycles) 1)
                    (and
                        (eq (ntr-witness-cycles-increasing? cycles) 1)
                        (ge (ntr-witness-cycle-label-count cycles) min-heldout))))
            1
            0))

    (defn ntr-floor ()
        (list
            "native artifact receipts must name weights, data, eval, and recipe"
            "trained_native_model_count is receipt-derived, never route-derived"
            "continuous cycles append new receipts with comparable eval rows"
            "larger heldout windows gate native authority beyond the first tiny proof"))

    0)
