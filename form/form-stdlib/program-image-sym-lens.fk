; program-image-sym-lens.fk -- locale/domain presentation over program-image symbols.
;
; Layer 8h7 sits over a valid 8h program-image envelope. The executable
; symbol/dependency truth stays inside `.fkb`; this layer only names how a
; locale/domain wants to display a stable symbol id.
;
; It does not parse or persist `.sym` artifacts, mutate `.fkb`, load or run a
; program image, install runtime choices, or grow the C seed.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/program-image-fkb.fk

(do
    (defn pisl-version () "program-image-sym-lens-v1")

    (defn pisl-feature (name status) (list "program-image-sym-lens-feature" name status))
    (defn pisl-feature-name (f) (nth f 1))
    (defn pisl-feature-status (f) (nth f 2))
    (defn program-image-sym-lens-manifest ()
        (list
            (pisl-feature "presentation-lens-only" 1)
            (pisl-feature "consumes-valid-pif-envelope" 1)
            (pisl-feature "locale-domain-display" 1)
            (pisl-feature "aliases-and-docs" 1)
            (pisl-feature "symbol-id-range-check" 1)
            (pisl-feature "duplicate-locale-domain-symbol-refused" 1)
            (pisl-feature "invalid-lens-investigates" 1)
            (pisl-feature "canonical-fallback-only-after-valid-lens" 1)
            (pisl-feature "no-executable-dependency-truth" 1)
            (pisl-feature "no-go-table-authority" 1)
            (pisl-feature "no-sym-artifact-io" 1)
            (pisl-feature "no-sym-parser" 1)
            (pisl-feature "no-fkb-mutation" 1)
            (pisl-feature "no-program-image-load" 1)
            (pisl-feature "no-selector-install" 1)
            (pisl-feature "no-c-seed-growth" 1)))
    (defn program-image-sym-lens-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (pisl-feature-name (head fs)) name)
                     (eq (pisl-feature-status (head fs)) 1))
                1
                (program-image-sym-lens-manifest-has? name (tail fs)))))

    (defn pisl-status-ready () "ready")
    (defn pisl-status-investigate () "investigate")
    (defn pisl-status-refused () "refused")

    (defn pisl-reason-ready () "sym-lens-ready")
    (defn pisl-reason-localized-display () "localized-display")
    (defn pisl-reason-canonical-fallback () "canonical-fallback")
    (defn pisl-reason-invalid-envelope () "invalid-pif-envelope")
    (defn pisl-reason-malformed-lens () "malformed-sym-lens")
    (defn pisl-reason-invalid-lens () "invalid-sym-lens")
    (defn pisl-reason-invalid-query () "invalid-render-query")
    (defn pisl-reason-symbol-out-of-range () "symbol-id-out-of-range")

    (defn pisl-string? (x) (str_eq (value_kind x) "string"))
    (defn pisl-int? (x) (str_eq (value_kind x) "int"))
    (defn pisl-list? (x) (str_eq (value_kind x) "list"))
    (defn pisl-nonempty-string? (x)
        (if (pisl-string? x)
            (gt (str_len x) 0)
            0))
    (defn pisl-zero? (x)
        (if (pisl-int? x)
            (eq x 0)
            0))

    ; sym-row = (tag locale domain symbol-id display aliases doc carries-executable-deps)
    (defn pisl-row (locale domain symbol-id display aliases doc carries-executable-deps)
        (list "program-image-sym-row"
              locale
              domain
              symbol-id
              display
              aliases
              doc
              carries-executable-deps))
    (defn pisl-row? (row)
        (if (pisl-list? row)
            (if (eq (len row) 8)
                (if (pisl-string? (nth row 0))
                    (str_eq (nth row 0) "program-image-sym-row")
                    0)
                0)
            0))
    (defn pisl-row-locale (row) (nth row 1))
    (defn pisl-row-domain (row) (nth row 2))
    (defn pisl-row-symbol-id (row) (nth row 3))
    (defn pisl-row-display (row) (nth row 4))
    (defn pisl-row-aliases (row) (nth row 5))
    (defn pisl-row-doc (row) (nth row 6))
    (defn pisl-row-carries-executable-deps (row) (nth row 7))

    ; sym-lens = (tag version rows)
    (defn pisl-lens (rows)
        (list "program-image-sym-lens" (pisl-version) rows))
    (defn pisl-lens? (lens)
        (if (pisl-list? lens)
            (if (eq (len lens) 3)
                (if (pisl-string? (nth lens 0))
                    (if (str_eq (nth lens 0) "program-image-sym-lens")
                        (str_eq (nth lens 1) (pisl-version))
                        0)
                    0)
                0)
            0))
    (defn pisl-lens-rows (lens) (nth lens 2))

    (defn pisl-aliases-valid-loop? (aliases)
        (if (nil? aliases)
            1
            (if (pisl-nonempty-string? (head aliases))
                (pisl-aliases-valid-loop? (tail aliases))
                0)))
    (defn pisl-aliases-valid? (aliases)
        (if (pisl-list? aliases)
            (if (nil? aliases)
                0
                (pisl-aliases-valid-loop? aliases))
            0))
    (defn pisl-symbol-id-valid-for-envelope? (e symbol-id)
        (if (pif-envelope-valid? e)
            (if (pisl-int? symbol-id)
                (pif-symbol-id-ref? symbol-id
                                    (pif-symbol-image-count (pif-envelope-symbol-image e)))
                0)
            0))
    (defn pisl-row-valid-for-envelope? (e row)
        (if (pif-envelope-valid? e)
            (if (pisl-row? row)
                (if (pisl-nonempty-string? (pisl-row-locale row))
                    (if (pisl-nonempty-string? (pisl-row-domain row))
                        (if (pisl-symbol-id-valid-for-envelope? e (pisl-row-symbol-id row))
                            (if (pisl-nonempty-string? (pisl-row-display row))
                                (if (pisl-aliases-valid? (pisl-row-aliases row))
                                    (if (pisl-nonempty-string? (pisl-row-doc row))
                                        (pisl-zero? (pisl-row-carries-executable-deps row))
                                        0)
                                    0)
                                0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn pisl-rows-valid-for-envelope? (e rows)
        (if (pisl-list? rows)
            (if (nil? rows)
                1
                (if (pisl-row-valid-for-envelope? e (head rows))
                    (pisl-rows-valid-for-envelope? e (tail rows))
                    0))
            0))
    (defn pisl-row-same-key? (a b)
        (if (and (pisl-row? a) (pisl-row? b))
            (if (str_eq (pisl-row-locale a) (pisl-row-locale b))
                (if (str_eq (pisl-row-domain a) (pisl-row-domain b))
                    (eq (pisl-row-symbol-id a) (pisl-row-symbol-id b))
                    0)
                0)
            0))
    (defn pisl-rows-contain-key? (rows row)
        (if (nil? rows)
            0
            (if (pisl-row-same-key? (head rows) row)
                1
                (pisl-rows-contain-key? (tail rows) row))))
    (defn pisl-rows-unique? (rows)
        (if (pisl-list? rows)
            (if (nil? rows)
                1
                (if (pisl-rows-contain-key? (tail rows) (head rows))
                    0
                    (pisl-rows-unique? (tail rows))))
            0))
    (defn pisl-lens-valid-for-envelope? (e lens)
        (if (pif-envelope-valid? e)
            (if (pisl-lens? lens)
                (if (pisl-rows-valid-for-envelope? e (pisl-lens-rows lens))
                    (pisl-rows-unique? (pisl-lens-rows lens))
                    0)
                0)
            0))
    (defn pisl-lens-ready? (e lens)
        (pisl-lens-valid-for-envelope? e lens))

    (defn pisl-admission (e lens)
        (if (not (pif-envelope-valid? e))
            (list "program-image-sym-lens-admission" (pisl-status-refused) (pisl-reason-invalid-envelope))
            (if (not (pisl-lens? lens))
                (list "program-image-sym-lens-admission" (pisl-status-refused) (pisl-reason-malformed-lens))
                (if (pisl-lens-valid-for-envelope? e lens)
                    (list "program-image-sym-lens-admission" (pisl-status-ready) (pisl-reason-ready))
                    (list "program-image-sym-lens-admission" (pisl-status-investigate) (pisl-reason-invalid-lens))))))
    (defn pisl-admission-status (a) (nth a 1))
    (defn pisl-admission-reason (a) (nth a 2))

    (defn pisl-no-row () (list "program-image-sym-no-row"))
    (defn pisl-no-row? (row)
        (if (pisl-list? row)
            (if (eq (len row) 1)
                (if (pisl-string? (nth row 0))
                    (str_eq (nth row 0) "program-image-sym-no-row")
                    0)
                0)
            0))
    (defn pisl-row-key-match? (row locale domain symbol-id)
        (if (pisl-row? row)
            (if (str_eq (pisl-row-locale row) locale)
                (if (str_eq (pisl-row-domain row) domain)
                    (eq (pisl-row-symbol-id row) symbol-id)
                    0)
                0)
            0))
    (defn pisl-find-row (rows locale domain symbol-id)
        (if (nil? rows)
            (pisl-no-row)
            (if (pisl-row-key-match? (head rows) locale domain symbol-id)
                (head rows)
                (pisl-find-row (tail rows) locale domain symbol-id))))

    (defn pisl-canonical-key-for (e symbol-id)
        (if (pisl-symbol-id-valid-for-envelope? e symbol-id)
            (pif-symbol-row-key (nth (pif-symbol-image-rows (pif-envelope-symbol-image e))
                                     symbol-id))
            ""))

    (defn pisl-render (status reason display)
        (list "program-image-sym-render" status reason display))
    (defn pisl-render-status (r) (nth r 1))
    (defn pisl-render-reason (r) (nth r 2))
    (defn pisl-render-display (r) (nth r 3))
    (defn pisl-render-display-for (e lens locale domain symbol-id)
        (if (not (pif-envelope-valid? e))
            (pisl-render (pisl-status-refused) (pisl-reason-invalid-envelope) "")
            (if (not (pisl-symbol-id-valid-for-envelope? e symbol-id))
                (pisl-render (pisl-status-refused) (pisl-reason-symbol-out-of-range) "")
                (if (not (and (pisl-nonempty-string? locale) (pisl-nonempty-string? domain)))
                    (pisl-render (pisl-status-refused) (pisl-reason-invalid-query) "")
                    (if (not (pisl-lens? lens))
                        (pisl-render (pisl-status-refused) (pisl-reason-malformed-lens) "")
                        (if (not (pisl-lens-valid-for-envelope? e lens))
                            (pisl-render (pisl-status-investigate) (pisl-reason-invalid-lens) "")
                            (do
                                (let row (pisl-find-row (pisl-lens-rows lens) locale domain symbol-id))
                                (if (pisl-no-row? row)
                                    (pisl-render (pisl-status-ready)
                                                 (pisl-reason-canonical-fallback)
                                                 (pisl-canonical-key-for e symbol-id))
                                    (pisl-render (pisl-status-ready)
                                                 (pisl-reason-localized-display)
                                                 (pisl-row-display row)))))))))))
