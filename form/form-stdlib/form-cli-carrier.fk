; form-cli-carrier.fk — baked carrier identity and live nonce challenge.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk
;
; Regeneration substitutes FORM_CLI_SOURCE_SHA256_PLACEHOLDER in the flattened
; copy with the canonical source-set SHA-256. The checked-in source remains the stable hash template,
; avoiding a self-referential stamp. carrier-challenge hashes every nonce byte in
; Form; an executable that only echoes input cannot satisfy the contract.

(do
    (defn fcc-schema () "form-cli-carrier-v2")
    (defn fcc-source-stamp () "FORM_CLI_SOURCE_SHA256_PLACEHOLDER")
    (defn fcc-build-id () "coherence-kernel-fkwu-native-v2")
    (defn fcc-challenge-domain () "form-cli-carrier-challenge-v1\n")

    (defn fcc-string-bytes-loop (s i out)
        (if (ge i (str_len s)) out
            (fcc-string-bytes-loop s (add i 1)
                (append-1 out (str_byte_at s i)))))
    (defn fcc-string-bytes (s)
        (fcc-string-bytes-loop s 0 (empty)))

    (defn fcc-nonce-valid? (nonce)
        (if (and (eq (str_len nonce) 64)
                 (and (eq (hex-valid? nonce) 1)
                      (str_eq nonce (hex-encode (hex-decode nonce))))) 1 0))
    (defn fcc-challenge-digest (nonce)
        (hex-encode (sha256 (fcc-string-bytes
            (str_concat (fcc-challenge-domain) nonce)))))

    (defn fcc-carrier-id ()
        (str_concat "carrier-id|"
        (str_concat (fcc-schema)
        (str_concat "|"
        (str_concat (fcc-source-stamp)
        (str_concat "|" (fcc-build-id)))))))

    ; stdout: carrier-challenge-v1|<source-stamp>|<nonce>|<sha256>
    ; digest = SHA256(ASCII "form-cli-carrier-challenge-v1\n" + nonce ASCII).
    (defn fcc-carrier-challenge (nonce)
        (if (eq (fcc-nonce-valid? nonce) 0)
            "carrier-challenge:error:invalid-nonce"
            (str_concat "carrier-challenge-v1|"
            (str_concat (fcc-source-stamp)
            (str_concat "|"
            (str_concat nonce
            (str_concat "|" (fcc-challenge-digest nonce))))))))

    0)
