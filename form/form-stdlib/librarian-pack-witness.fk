; librarian-pack-witness.fk — the second-brain librarian witnesses itself:
; the whole pack-and-retrieve pipeline in the body's own tissue, zero Python.
;
; preludes: form-stdlib/core.fk form-stdlib/record-src-shim.fk form-stdlib/str-byte-at.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk form-stdlib/tensor-quant.fk form-stdlib/turboquant-as-recipe.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-turboquant-lane.fk
;
; The 2026-07-17 real-data witness ran through a Python carrier that had to
; EARN trust via an fkwu parity gate (carrier==cell on sampled vectors). This
; cell retires that whole class of doubt: the body reads its own receipts
; (read_file, shelf via a manifest — see the enumeration floor below),
; embeds them with its own
; sovereign lexical embedder (re-vec, four-way proven), packs them through its
; own lane (rtq-pack-vec), ranks and measures with its own arithmetic. No
; foreign runtime touches a single number, so there is no parity to prove —
; the witness IS the cell.
;
; Two lanes, named honestly: this witness runs the SOVEREIGN embedder
; (re-vec, 64-dim lexical histogram — same text, same vector, every kernel).
; The neural lane (nomic-embed-text over ollama, higher semantic quality, a
; model-door crossing per rag-embed's own header) was witnessed 2026-07-17
; with measured numbers standing in its receipt; re-running THAT lane
; body-natively waits on an http-door cell — a named floor, not a hidden one.
; Agreement numbers between lanes are NOT comparable one-to-one: different
; embedders make differently-dense galleries, and density decides what the
; 2-bit blur costs (row 778, veridical).
;
; The witness is an OBSERVATION main, not a band: its numbers move as the
; receipts shelf grows. What is pinned by law lives in the lane bands
; (rag-turboquant-lane-band, turboquant-as-recipe-band, both 127 four-way).
;
; run (from form/): cat the preludes + this cell + a call line, fkwu --src it;
; librarian-pack-witness-main.fk is that call line as a committed main.

(do
    ; ── floats from the integer histogram ──
    (defn lpw-floats (xs)
        (if (eq (len xs) 0) (empty)
            (cons (mul 1.0 (head xs)) (lpw-floats (tail xs)))))

    ; ── one receipt -> (path title-line embedding-floats) ──
    ; the query line is the first line that carries at least one word:
    ; glyph banners and frontmatter dashes embed to a zero histogram, and a
    ; zero query witnesses nothing (found on the teachings shelf, first run).
    (defn lpw-first-wordful (text i n)
        (if (ge i n) ""
            (do (let nl (str_find text "\n" i))
                (let end (if (lt nl 0) n nl))
                (let line (substring text i end))
                (if (gt (rag-sum (re-vec line)) 0) line
                    (if (lt nl 0) "" (lpw-first-wordful text (add nl 1) n))))))
    (defn lpw-title (text) (lpw-first-wordful text 0 (str_len text)))
    (defn lpw-head-text (text)
        (if (gt (str_len text) 1500) (substring text 0 1500) text))
    (defn lpw-doc (path dim)
        (do (let text (lpw-head-text (read_file path)))
            (list path (lpw-title text) (lpw-floats (re-vec-dim text dim)))))
    (defn lpw-docs (paths dim)
        (if (eq (len paths) 0) (empty)
            (cons (lpw-doc (head paths) dim) (lpw-docs (tail paths) dim))))
    (defn lpw-doc-path (d) (nth d 0))
    (defn lpw-doc-title (d) (nth d 1))
    (defn lpw-doc-vec (d) (nth d 2))

    ; ── pack every doc into the lane's entry shape ──
    (defn lpw-entries (docs)
        (if (eq (len docs) 0) (empty)
            (cons (rtq-entry (lpw-doc-path (head docs)) (lpw-doc-vec (head docs)))
                  (lpw-entries (tail docs)))))

    ; ── full-precision ranking (the baseline the packs are measured against) ──
    (defn lpw-full-best-loop (qu docs best best-s)
        (if (eq (len docs) 0) best
            (do (let s (tqr-dot qu (lpw-doc-vec (head docs))))
                (if (or (str_eq best "") (gt s best-s))
                    (lpw-full-best-loop qu (tail docs) (lpw-doc-path (head docs)) s)
                    (lpw-full-best-loop qu (tail docs) best best-s)))))
    (defn lpw-full-top1 (qv docs)
        (lpw-full-best-loop (tqr-unit qv) docs "" 0.0))

    ; ── deterministic sample of query indices via the cell's own minstd ──
    (defn lpw-sample (state n limit acc)
        (if (eq n 0) acc
            (do (let s (tqr-lcg state))
                (lpw-sample s (sub n 1) limit (cons (tqr-draw s limit) acc)))))

    ; ── the witness walk: for each sampled doc, its TITLE is the query ──
    (defn lpw-agree-loop (idxs docs entries dim agree)
        (if (eq (len idxs) 0) agree
            (do (let d (nth docs (head idxs)))
                (let qv (lpw-floats (re-vec-dim (lpw-doc-title d) dim)))
                (let full (lpw-full-top1 qv docs))
                (let packed (rtq-nearest-id qv entries))
                (lpw-agree-loop (tail idxs) docs entries dim
                    (add agree (if (str_eq full packed) 1 0))))))

    ; ── bytes: floats-at-rest vs pack-at-rest (per the lane's shapes) ──
    (defn lpw-full-bytes (docs dim) (mul (len docs) (mul dim 8)))
    (defn lpw-packed-bytes (docs dim)
        (mul (len docs) (add 8 (div (mul 2 dim) 8))))

    ; ── shelf enumeration ──
    ; The honest floor, witnessed 2026-07-17: fs_list is dim-penumbra on this
    ; surface (circle-recognition.fk names the same floor — no directory scan
    ; is claimed until fs_list earns its band; probed here: it returns
    ; descending ints, not names). Until that band exists, the shelf arrives
    ; as a MANIFEST file (one path per line) read through the body's own
    ; read_file door; producing it is one named `ls` crossing, the last
    ; non-Form step in this witness, with its closure path written down.
    (defn lpw-lines-scan (s i n cur acc)
        (if (ge i n)
            (if (str_eq cur "") acc (cons cur acc))
            (do (let b (str_byte_at s i))
                (if (eq b 10)
                    (lpw-lines-scan s (add i 1) n ""
                        (if (str_eq cur "") acc (cons cur acc)))
                    (lpw-lines-scan s (add i 1) n
                        (str_concat cur (byte_to_str b)) acc)))))
    (defn lpw-rev (xs acc)
        (if (eq (len xs) 0) acc (lpw-rev (tail xs) (cons (head xs) acc))))
    (defn lpw-manifest-paths (manifest-path)
        (do (let text (read_file manifest-path))
            (lpw-rev (lpw-lines-scan text 0 (str_len text) "" (empty)) (empty))))

    ; ── the witness: (docs dim queries agree1 full-bytes packed-bytes) ──
    (defn lpw-run (manifest-path n-queries dim)
        (do (let paths (lpw-manifest-paths manifest-path))
            (let docs (lpw-docs paths dim))
            (let entries (lpw-entries docs))
            (let idxs (lpw-sample 20260717 n-queries (len docs) (empty)))
            (let agree (lpw-agree-loop idxs docs entries dim 0))
            (list (len docs) dim (len idxs) agree
                  (lpw-full-bytes docs dim)
                  (lpw-packed-bytes docs dim))))
    0)
