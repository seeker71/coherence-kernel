; lineage-discounted-vote.fk — witness independence is earned by disjoint
; lineage, not by count: ballots sharing an ancestor fold into ONE effective
; witness before fusion.
;
; Named 2026-07-16 by a real pair on this disk: MiniCPM5-1B (base) and its
; fable5-thinking fine-tune are two models but ONE lineage — the fine-tune's
; weights descend from the base's, so their errors are correlated where the
; blood is shared. confidence-weighted-vote.fk fuses (label weight) ballots by
; summed trust and is lineage-BLIND: two kin agreeing would count as two
; independent witnesses exactly where shared ancestry makes them wrong
; together. The body's own four-way law already knows this — the walkers are
; worth having because they are INDEPENDENT (walkers/README.md: "that
; independence is the whole worth") — but the voting organs had no way to say
; it. This cell says it.
;
; The fold: within one (label, lineage) group the effective weight is the MAX
; of the group (kin agreeing add nothing beyond the strongest kin); ACROSS
; lineages, weights still sum (independent trust accumulates — the cw- law,
; unchanged). Kin who DISAGREE keep their own labels' full weights:
; disagreement between kin is real information (the fine-tune moved), never
; discounted.
;
; COMPOSED, never re-derived: after the fold, cw-winner / cw-score
; (confidence-weighted-vote.fk) do the fusion — this cell only prepares
; honest ballots for the proven spine.
;
; Honest floor: lineage is a declared string, not a measured correlation —
; the cell trusts the declarer to know the ancestry (model cards state base
; models; the walkers' independence is by construction). Measuring residual
; correlation between declared-independent witnesses is a later organ.
;
; Self-contained over core + confidence-weighted-vote. Four-way by
; learn/tests/lineage-discounted-vote-band.fk.
;
; preludes: form-stdlib/core.fk form-stdlib/confidence-weighted-vote.fk

(do
    ; a lineage ballot: (label weight lineage)
    (defn ldv-ballot (label weight lineage) (list label weight lineage))
    (defn ldv-label   (b) (nth b 0))
    (defn ldv-weight  (b) (nth b 1))
    (defn ldv-lineage (b) (nth b 2))

    ; the strongest kin voice for (label, lineage) — max weight in the group
    (defn ldv-kin-max (bs label lin)
        (if (eq (len bs) 0) 0
            (if (and (str_eq (ldv-label (head bs)) label)
                     (str_eq (ldv-lineage (head bs)) lin))
                (if (gt (ldv-weight (head bs)) (ldv-kin-max (tail bs) label lin))
                    (ldv-weight (head bs))
                    (ldv-kin-max (tail bs) label lin))
                (ldv-kin-max (tail bs) label lin))))

    ; has this (label, lineage) group already been folded out?
    (defn ldv-seen? (done label lin)
        (if (eq (len done) 0) 0
            (if (and (str_eq (nth (head done) 0) label)
                     (str_eq (nth (head done) 1) lin)) 1
                (ldv-seen? (tail done) label lin))))

    ; fold: one (label kin-max) cw-ballot per (label, lineage) group
    (defn ldv-fold-loop (bs all done)
        (if (eq (len bs) 0) (list)
            (if (eq (ldv-seen? done (ldv-label (head bs)) (ldv-lineage (head bs))) 1)
                (ldv-fold-loop (tail bs) all done)
                (cons (list (ldv-label (head bs))
                            (ldv-kin-max all (ldv-label (head bs)) (ldv-lineage (head bs))))
                      (ldv-fold-loop (tail bs) all
                          (cons (list (ldv-label (head bs)) (ldv-lineage (head bs))) done))))))
    (defn ldv-fold (bs) (ldv-fold-loop bs bs (list)))

    ; the discounted fusion — the proven cw- spine over honest ballots
    (defn ldv-winner (bs candidates) (cw-winner (ldv-fold bs) candidates))
    (defn ldv-score  (bs candidates) (cw-score  (ldv-fold bs) candidates))

    ; ── self-check ──
    (defn ldvk (cond bit) (if cond bit 0))
    ; kin agreeing fold to the strongest kin, never the sum
    (defn ldv-kin-fold ()
        (ldvk (eq (cw-weight-for (ldv-fold (list (ldv-ballot "a" 3 "m") (ldv-ballot "a" 2 "m"))) "a") 3) 1))
    ; independent same-label trust still accumulates
    (defn ldv-indep-sum ()
        (ldvk (eq (cw-weight-for (ldv-fold (list (ldv-ballot "a" 3 "m") (ldv-ballot "a" 2 "l"))) "a") 5) 10))
    ; kin-inflation is prevented: two kin cannot outvote two independents
    (defn ldv-kin-capped ()
        (ldvk (str_eq (ldv-winner (list (ldv-ballot "a" 2 "m") (ldv-ballot "a" 2 "m")
                                        (ldv-ballot "b" 2 "l") (ldv-ballot "b" 2 "x"))
                                  (list "a" "b")) "b") 100))
    ; kin who DISAGREE keep full weight each — disagreement is information
    (defn ldv-kin-split ()
        (ldvk (and (eq (cw-weight-for (ldv-fold (list (ldv-ballot "a" 2 "m") (ldv-ballot "b" 2 "m"))) "a") 2)
                   (eq (cw-weight-for (ldv-fold (list (ldv-ballot "a" 2 "m") (ldv-ballot "b" 2 "m"))) "b") 2)) 1000))
    ; the discounted score is the folded winning sum, through the cw- spine
    (defn ldv-composes ()
        (ldvk (eq (ldv-score (list (ldv-ballot "a" 2 "m") (ldv-ballot "a" 2 "m")
                                   (ldv-ballot "b" 2 "l") (ldv-ballot "b" 2 "x"))
                             (list "a" "b")) 4) 10000))
    (defn lineage-discounted-vote-check ()
        (add (add (add (add (ldv-kin-fold) (ldv-indep-sum)) (ldv-kin-capped)) (ldv-kin-split)) (ldv-composes)))
)
