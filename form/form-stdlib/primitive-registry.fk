; primitive-registry.fk — every kernel native carries its declared spec:
; (name, Form category, contract line, verification recipe, expected outside, lane).
;
; The kernel-satsang discipline (kernel-satsang.fk ksat-part) applied to the
; primitive surface itself: a native is swappable tissue, and what makes it
; swappable is a declared outside — name, blueprint category, and a runnable
; verification recipe whose expected value any sibling can check. This file IS
; that declaration for the whole sibling-parity native surface of
; form-kernel-go/main.go (and the field-constructor + env-native tables).
;
; lane 1 — the verification walks in-band, three-way, every validate run
;          (tests/primitive-registry-band.fk).
; lane 0 — carrier-gated: the verification recipe is declared and runnable,
;          but its honest run-surface is not this band. Five honest reasons,
;          named per entry in the spec line:
;            panic-contract   the native's contract IS a panic (form_error)
;            socket-carrier   loopback I/O proven in the socket bands
;            sweep-hazard     substrate_gc can sweep band tissue mid-walk
;            host-io          result depends on host command/file authority
;            toolchain        result depends on host compiler availability
;            sibling-gap      absent in rust and/or ts today — the gap a
;                             Hati-OS audit lane and sibling work close
;
; The category tokens mirror main.go's attribution constructors:
;   call access method compare list witness undefined field
; (env natives keep their Go token; native_blueprint cannot see them, the
;  band skips their attestation via prim-env-native?.)
;
; Proven by: tests/primitive-registry-band.fk (three-way at validate.sh).
; Drift gate: form/scripts/validate_primitive_registry.py — registry names ==
; kernel names, tokens == Go attribution, lanes == sibling presence.
; Spec home: docs/coherence-substrate/primitive-registry.form;
; hati-os.form M2/M4 cite this registry as the primitive-by-primitive
; verification source an emitted kernel must answer.
(do
    ; ── the cell: one native's declared outside ──────────────────────────
    (defn prim (name category spec verify expected mode)
        (list "prim" name category spec verify expected mode))
    (defn prim-name     (e) (nth e 1))
    (defn prim-category (e) (nth e 2))
    (defn prim-spec     (e) (nth e 3))
    (defn prim-verify   (e) (nth e 4))
    (defn prim-expected (e) (nth e 5))
    (defn prim-mode     (e) (nth e 6))

    ; verification: run the declared recipe, compare the declared outside.
    (defn prim-call0 (f) (f))
    (defn prim-verified? (e)
        (eq (prim-call0 (prim-verify e)) (prim-expected e)))

    ; shared probe recipe — the smallest walkable composite (add 2 3).
    (defn pv-probe-recipe ()
        (intern_node (bp "add")
            (list (intern_trivial_int 2) (intern_trivial_int 3))))

    ; env-registered natives are invisible to native_blueprint; the band
    ; skips their category attestation through this registry-owned list.
    (defn prim-env-native? (n)
        (or (str_eq n "jit_compile")
            (or (str_eq n "jit_emit_c")
                (or (str_eq n "jit_compile_value")
                    (or (str_eq n "jit_compiled?")
                        (or (str_eq n "jit_install")
                            (str_eq n "walk_recipe_here")))))))

    ; one exemplar native per category token; attestation compares
    ; native_blueprint coordinates against the exemplar's — category
    ; equality without one magic number. Exemplar tokens are themselves
    ; gated against Go source by validate_primitive_registry.py.
    (defn prim-exemplar (token)
        (if (str_eq token "call")    "read_file"
        (if (str_eq token "access")  "str_len"
        (if (str_eq token "method")  "str_concat"
        (if (str_eq token "compare") "str_eq"
        (if (str_eq token "list")    "cons"
        (if (str_eq token "witness") "intern_node"
        (if (str_eq token "undefined") "trace"
            ""))))))))

    ; category attestation for a lane-1 entry: field constructors attest
    ; level-2 placement (each carries its own Field type), env natives are
    ; vacuously attested (skipped), every other token must share its
    ; exemplar's category NodeID exactly.
    (defn prim-category-attested? (e)
        (if (prim-env-native? (prim-name e))
            true
            (if (str_eq (prim-category e) "field")
                (eq (node_level (native_blueprint (prim-name e))) 2)
                (node_eq (native_blueprint (prim-name e))
                         (native_blueprint (prim-exemplar (prim-category e)))))))

    ; ── walk helpers over the registry ───────────────────────────────────
    (defn prim-known-token? (t)
        (or (str_eq t "call")
            (or (str_eq t "access")
                (or (str_eq t "method")
                    (or (str_eq t "compare")
                        (or (str_eq t "list")
                            (or (str_eq t "witness")
                                (or (str_eq t "undefined")
                                    (str_eq t "field")))))))))

    (defn prim-shape-ok? (e)
        (and (eq (len e) 7)
             (and (str_eq (nth e 0) "prim")
                  (and (gt (str_len (prim-name e)) 0)
                       (and (gt (str_len (prim-spec e)) 0)
                            (prim-known-token? (prim-category e)))))))

    (defn prim-shapes-ok-count (entries)
        (if (eq (len entries) 0)
            0
            (add (if (prim-shape-ok? (head entries)) 1 0)
                 (prim-shapes-ok-count (tail entries)))))

    (defn prim-mode-count (entries m)
        (if (eq (len entries) 0)
            0
            (add (if (eq (prim-mode (head entries)) m) 1 0)
                 (prim-mode-count (tail entries) m))))

    ; lane-1 verifications that answer their declared outside.
    (defn prim-verified-count (entries)
        (if (eq (len entries) 0)
            0
            (add (if (eq (prim-mode (head entries)) 1)
                     (if (prim-verified? (head entries)) 1 0)
                     0)
                 (prim-verified-count (tail entries)))))

    ; lane-1 category attestations that hold.
    (defn prim-attested-count (entries)
        (if (eq (len entries) 0)
            0
            (add (if (eq (prim-mode (head entries)) 1)
                     (if (prim-category-attested? (head entries)) 1 0)
                     0)
                 (prim-attested-count (tail entries)))))

    (defn prim-name-in? (entries n)
        (if (eq (len entries) 0)
            false
            (if (str_eq (prim-name (head entries)) n)
                true
                (prim-name-in? (tail entries) n))))

    (defn prim-dup-count (entries)
        (if (eq (len entries) 0)
            0
            (add (if (prim-name-in? (tail entries) (prim-name (head entries))) 1 0)
                 (prim-dup-count (tail entries)))))

    (defn prim-find (entries n)
        (if (eq (len entries) 0)
            0
            (if (str_eq (prim-name (head entries)) n)
                (head entries)
                (prim-find (tail entries) n))))

    ; ── the registry — main.go registration order ────────────────────────
    (defn prim-registry () (list
        (prim "print" "call" "writes args + newline to stdout, returns null; stdout is the contract validate compares"
            (defn pv-print () (do (print "prim-registry-print-probe") 1)) 1 1)
        (prim "str_len" "access" "byte length of a string"
            (defn pv-str-len () (str_len "satsang")) 7 1)
        (prim "substring" "access" "s[a:b) by byte index; out-of-range panics"
            (defn pv-substring () (if (str_eq (substring "satsang" 3 7) "sang") 1 0)) 1 1)
        (prim "char_at" "access" "one-byte string at index; out-of-range panics"
            (defn pv-char-at () (if (str_eq (char_at "form" 0) "f") 1 0)) 1 1)
        (prim "str_concat" "method" "two strings joined"
            (defn pv-str-concat () (str_len (str_concat "sat" "sang"))) 7 1)
        (prim "host-exec" "method" "host-io: executes a host command and returns stdout; carrier receipt owns command authority"
            (defn pv-host-exec () (str_len (host-exec "printf form"))) 4 0)
        (prim "host-read" "method" "host-io: reads a host file as text; carrier receipt owns path authority"
            (defn pv-host-read () (str_len (host-read "/tmp/prim-reg-host-read.txt"))) 0 0)
        (prim "host-write" "method" "host-io: writes host file text and returns byte count; carrier receipt owns path authority"
            (defn pv-host-write () (host-write "/tmp/prim-reg-host-write.txt" "form")) 4 0)
        (prim "form_error" "witness" "panic-contract: panics with the message, never returns; carrier observes exit"
            (defn pv-form-error () (do (form_error "prim-registry-probe") 0)) 0 0)
        (prim "form-error" "witness" "panic-contract: kebab door of form_error"
            (defn pv-form-error-k () (do (form-error "prim-registry-probe") 0)) 0 0)
        (prim "source_scan_file" "call" "scans a file through a (source-lexicon ...) into token cells"
            (defn pv-source-scan-file () (do (write_file_text "/tmp/prim-reg-scan.txt" "form")
                (if (ge (len (source_scan_file "/tmp/prim-reg-scan.txt" (list "source-lexicon" (list) (list) "kw" "prop" "name" "int" "float" "string" "char" "op" (list) "" "" ""))) 1) 1 0))) 1 1)
        (prim "pow" "method" "integer base**exp; negative exp yields 0"
            (defn pv-pow () (pow 2 10)) 1024 1)
        (prim "record_new" "method" "mutable record tagged by blueprint NodeID with k v pairs"
            (defn pv-record-new () (if (record? (record_new (bp "PRIM-REGISTRY-PROBE") "x" 1)) 1 0)) 1 1)
        (prim "record_get" "access" "field value by name, null when absent"
            (defn pv-record-get () (record_get (record_new (bp "PRIM-REGISTRY-PROBE") "x" 41) "x")) 41 1)
        (prim "record_set" "method" "mutates the field in place and returns the record"
            (defn pv-record-set () (record_get (record_set (record_new (bp "PRIM-REGISTRY-PROBE") "x" 1) "x" 8) "x")) 8 1)
        (prim "record_has" "access" "field presence as bool; absent field answers false"
            (defn pv-record-has () (if (record_has (record_new (bp "PRIM-REGISTRY-PROBE") "x" 1) "x")
                (if (record_has (record_new (bp "PRIM-REGISTRY-PROBE")) "y") 0 1) 0)) 1 1)
        (prim "record_blueprint" "access" "the record's blueprint NodeID"
            (defn pv-record-blueprint () (if (node_eq (record_blueprint (record_new (bp "PRIM-REGISTRY-PROBE"))) (bp "PRIM-REGISTRY-PROBE")) 1 0)) 1 1)
        (prim "record_keys" "access" "field names in insertion order"
            (defn pv-record-keys () (len (record_keys (record_new (bp "PRIM-REGISTRY-PROBE") "a" 1 "b" 2)))) 2 1)
        (prim "record?" "access" "record type predicate; non-records answer false"
            (defn pv-record? () (if (record? (record_new (bp "PRIM-REGISTRY-PROBE"))) (if (record? 7) 0 1) 0)) 1 1)
        (prim "method_define" "method" "binds a closure as a named method on a blueprint; first param is the receiver"
            (defn pv-method-define () (do
                (method_define (bp "PRIM-REGISTRY-PROBE") "pv-def" (defn pv-method-define-m (self) 11))
                (method_invoke (record_new (bp "PRIM-REGISTRY-PROBE")) "pv-def"))) 11 1)
        (prim "method_has" "access" "method presence by record's blueprint; absent name answers false"
            (defn pv-method-has () (do
                (method_define (bp "PRIM-REGISTRY-PROBE") "pv-has" (defn pv-method-has-m (self) 1))
                (if (method_has (record_new (bp "PRIM-REGISTRY-PROBE")) "pv-has")
                    (if (method_has (record_new (bp "PRIM-REGISTRY-PROBE")) "pv-absent") 0 1) 0))) 1 1)
        (prim "method_invoke" "method" "dispatches by blueprint, binds receiver then args"
            (defn pv-method-invoke () (do
                (method_define (bp "PRIM-REGISTRY-PROBE") "pv-inv" (defn pv-method-invoke-m (self n) (add n 4)))
                (method_invoke (record_new (bp "PRIM-REGISTRY-PROBE")) "pv-inv" 3))) 7 1)
        (prim "str_find" "access" "index of needle from start index, or -1"
            (defn pv-str-find () (str_find "satsang" "sang" 0)) 3 1)
        (prim "str_line_at" "access" "sibling-gap (go-only): the full line containing byte index, CR trimmed"
            (defn pv-str-line-at () (if (str_eq (str_line_at "ab\ncd" 3) "cd") 1 0)) 1 0)
        (prim "str_ascii_prefix" "access" "sibling-gap (go-only): longest leading pure-ASCII run"
            (defn pv-str-ascii-prefix () (str_len (str_ascii_prefix (str_concat "ab" (byte_to_str 200))))) 2 0)
        (prim "scan_run" "access" "end index of a contiguous byte-class run (0 ws, 1 digit, 2 alpha, 3 ident, 4 nonquote, 5 nonnl, 6 jsonsafe)"
            (defn pv-scan-run () (scan_run "  form" 0 0)) 2 1)
        (prim "string_fold" "call" "host-loop fold of (acc char) closure over a string's bytes"
            (defn pv-string-fold () (string_fold "abc" 0 (defn pv-string-fold-step (acc c) (add acc 1)))) 3 1)
        (prim "str_eq" "compare" "string equality as the 0/1 integer states; integers belong to eq, nodes to node_eq"
            (defn pv-str-eq () (add (str_eq "a" "a") (mul (str_eq "a" "b") 7))) 1 1)
        (prim "int_to_str" "method" "renders any trivial value as text (int, bool, null, float passthrough)"
            (defn pv-int-to-str () (str_len (int_to_str 1024))) 4 1)
        (prim "value_str" "method" "sibling-gap (ts): canonical display string of any value"
            (defn pv-value-str () (if (str_eq (value_str 42) "42") 1 0)) 1 0)
        (prim "value_kind" "witness" "sibling-gap (ts): kind name of a value (int string bool null list closure node_id float record)"
            (defn pv-value-kind () (if (str_eq (value_kind 7) "int") 1 0)) 1 0)
        (prim "value-kind" "witness" "sibling-gap (ts): kebab door of value_kind"
            (defn pv-value-kind-k () (if (str_eq (value-kind 7) "int") 1 0)) 1 0)
        (prim "str_to_int" "method" "decimal parse; unparseable text answers 0"
            (defn pv-str-to-int () (str_to_int "1024")) 1024 1)
        (prim "str_to_float" "method" "sibling-gap (ts): float parse; round half-away pins 2.5 to 3"
            (defn pv-str-to-float () (round (str_to_float "2.5"))) 3 0)
        (prim "float_to_int" "method" "truncate float toward zero exactly like Python int(float); ints pass through, non-numbers answer 0"
            (defn pv-float-to-int () (add (float_to_int 3.9) (float_to_int -2.9))) 1 1)
        (prim "ord" "access" "first byte as int; empty string answers -1"
            (defn pv-ord () (add (ord "A") (ord ""))) 64 1)
        (prim "str_byte_at" "access" "raw UTF-8 byte at index; out-of-range panics"
            (defn pv-str-byte-at () (str_byte_at "AZ" 1)) 90 1)
        (prim "byte_to_str" "access" "one byte (0..255) as a one-char string; out-of-range answers empty"
            (defn pv-byte-to-str () (if (str_eq (byte_to_str 65) "A") 1 0)) 1 1)
        (prim "list" "list" "variadic list literal"
            (defn pv-list () (len (list 1 2 3))) 3 1)
        (prim "cons" "list" "prepends onto a list"
            (defn pv-cons () (head (cons 9 (list 1)))) 9 1)
        (prim "head" "list" "first element; empty answers null"
            (defn pv-head () (head (list 7 8))) 7 1)
        (prim "tail" "list" "list without its head; empty stays empty"
            (defn pv-tail () (len (tail (list 1 2 3)))) 2 1)
        (prim "len" "access" "polymorphic length: list elements, dict PAIRS, string bytes"
            (defn pv-len () (add (len (list 1 2)) (len "abc"))) 5 1)
        (prim "nth" "access" "element by index; out-of-range answers null"
            (defn pv-nth () (nth (list 4 5 6) 2)) 6 1)
        (prim "empty" "list" "constructs the empty list — an absence value, never a predicate"
            (defn pv-empty () (len (empty))) 0 1)
        (prim "_list_append" "list" "functional append: a NEW list xs ++ [x]"
            (defn pv-list-append () (nth (_list_append (list 1) 9) 1)) 9 1)
        (prim "_dict_new" "list" "tagged pair-list dict; len counts PAIRS not slots"
            (defn pv-dict-new () (len (_dict_new "a" 1))) 1 1)
        (prim "_dict_get" "access" "value by key, null when absent"
            (defn pv-dict-get () (_dict_get (_dict_new "a" 1 "b" 2) "b")) 2 1)
        (prim "_dict_set" "method" "functional upsert: existing key overwritten, new key appended"
            (defn pv-dict-set () (_dict_get (_dict_set (_dict_new "a" 1) "a" 5) "a")) 5 1)
        (prim "_dict_has" "compare" "key presence as bool"
            (defn pv-dict-has () (if (_dict_has (_dict_new "a" 1) "a") (if (_dict_has (_dict_new "a" 1) "z") 0 1) 0)) 1 1)
        (prim "_dict_keys" "access" "keys in insertion order"
            (defn pv-dict-keys () (len (_dict_keys (_dict_new "a" 1 "b" 2)))) 2 1)
        (prim "_dict_values" "access" "values in insertion order"
            (defn pv-dict-values () (nth (_dict_values (_dict_new "a" 7)) 0)) 7 1)
        (prim "_get" "access" "polymorphic get: record field, dict key, list index, string byte"
            (defn pv-get () (add (_get (list 4 5) 1) (_get (_dict_new "k" 10) "k"))) 15 1)
        (prim "_iter" "list" "iterable view: dict keys, list itself, string chars"
            (defn pv-iter () (len (_iter "abc"))) 3 1)
        (prim "_in" "compare" "membership: dict key, list element, substring"
            (defn pv-in () (if (_in "an" "satsang") (if (_in 9 (list 1 2)) 0 1) 0)) 1 1)
        (prim "min" "method" "least int of a list, or the single arg itself"
            (defn pv-min () (add (min (list 3 1 2)) (min 9))) 10 1)
        (prim "max" "method" "greatest int of a list, or the single arg itself"
            (defn pv-max () (max (list 3 9 2))) 9 1)
        (prim "abs" "method" "absolute value; pinned on a real -1 from str_find"
            (defn pv-abs () (add (abs (str_find "a" "z" 0)) 1)) 2 1)
        (prim "floor" "method" "float toward negative infinity as int; int passes through"
            (defn pv-floor () (floor 2.7)) 2 1)
        (prim "ceil" "method" "float toward positive infinity as int; int passes through"
            (defn pv-ceil () (ceil 2.1)) 3 1)
        (prim "trunc" "method" "float toward zero as int; int passes through"
            (defn pv-trunc () (trunc 2.9)) 2 1)
        (prim "round" "method" "half-AWAY-from-zero to int: 2.5 lands on 3"
            (defn pv-round () (round 2.5)) 3 1)
        (prim "_plus" "method" "polymorphic +: int add, float promotion, string and list concat"
            (defn pv-plus () (add (_plus 2 3) (str_len (_plus "a" "b")))) 7 1)
        (prim "math_sqrt" "method" "square root as float"
            (defn pv-math-sqrt () (round (math_sqrt 9.0))) 3 1)
        (prim "math_acos" "method" "sibling-gap (go-only): arccosine in radians; acos(0)*2 rounds to 3"
            (defn pv-math-acos () (round (mul (math_acos 0.0) 2.0))) 3 0)
        (prim "math_pi" "method" "the circle constant; *2 rounds to 6"
            (defn pv-math-pi () (round (mul (math_pi) 2.0))) 6 1)
        (prim "math_floor" "method" "CPython math.floor: float toward negative infinity as int"
            (defn pv-math-floor () (math_floor 2.9)) 2 1)
        (prim "math_ceil" "method" "CPython math.ceil: float toward positive infinity as int"
            (defn pv-math-ceil () (math_ceil 2.1)) 3 1)
        (prim "math_pow" "method" "float power"
            (defn pv-math-pow () (round (math_pow 2.0 10.0))) 1024 1)
        (prim "math_log" "method" "natural log; log(e) rounds to 1"
            (defn pv-math-log () (round (math_log (math_exp 1.0)))) 1 1)
        (prim "math_exp" "method" "e**x; exp(0) rounds to 1"
            (defn pv-math-exp () (round (math_exp 0.0))) 1 1)
        (prim "round_ndigits" "method" "CPython round(x, n): half-to-EVEN — 2.5 lands on 2, where round lands on 3"
            (defn pv-round-ndigits () (round (round_ndigits 2.5 0))) 2 1)
        (prim "make_float32" "witness" "interns an f32 trivial NodeID; 0.5 survives the narrowing exactly"
            (defn pv-make-float32 () (round (mul (float_value (make_float32 0.5)) 2.0))) 1 1)
        (prim "make_float64" "witness" "interns an f64 trivial NodeID"
            (defn pv-make-float64 () (round (float_value (make_float64 2.5)))) 3 1)
        (prim "read_file" "call" "whole file as string; missing file answers null"
            (defn pv-read-file () (do (write_file_text "/tmp/prim-reg-rf.txt" "satsang") (str_len (read_file "/tmp/prim-reg-rf.txt")))) 7 1)
        (prim "read_file_bytes" "call" "whole file as int byte list"
            (defn pv-read-file-bytes () (do (write_file_text "/tmp/prim-reg-rb.txt" "satsang") (nth (read_file_bytes "/tmp/prim-reg-rb.txt") 0))) 115 1)
        (prim "source_inventory" "call" "walks a tree, rows of [relative-path, line-count] filtered by suffix"
            (defn pv-source-inventory () (do (fs_mkdir "/tmp/prim-reg-inv")
                (do (write_file_text "/tmp/prim-reg-inv/a.txt" "x")
                    (if (ge (len (source_inventory "/tmp/prim-reg-inv" ".txt" (list))) 1) 1 0)))) 1 1)
        (prim "random_bytes" "call" "n bytes from /dev/urandom — values diverge by design, the length is the deterministic claim"
            (defn pv-random-bytes () (len (random_bytes 8))) 8 1)
        (prim "band" "method" "bitwise and"
            (defn pv-band () (band 12 10)) 8 1)
        (prim "bor" "method" "bitwise or"
            (defn pv-bor () (bor 12 10)) 14 1)
        (prim "bxor" "method" "bitwise xor"
            (defn pv-bxor () (bxor 12 10)) 6 1)
        (prim "bnot_u32" "method" "bitwise not under u32 semantics; ~0 + 1 wraps to 0 (literals stay int32, values are honest u32)"
            (defn pv-bnot-u32 () (add_u32 (bnot_u32 0) 1)) 0 1)
        (prim "shl_u32" "method" "u32 shift left, count masked to 31; the top bit round-trips"
            (defn pv-shl-u32 () (shr_u32 (shl_u32 1 31) 31)) 1 1)
        (prim "shr_u32" "method" "u32 logical shift right, count masked to 31"
            (defn pv-shr-u32 () (shr_u32 1024 10)) 1 1)
        (prim "rotr_u32" "method" "u32 rotate right; 1 rotated through 32 bits comes home"
            (defn pv-rotr-u32 () (rotr_u32 (rotr_u32 1 1) 31)) 1 1)
        (prim "add_u32" "method" "modular u32 addition: 2^31 + 2^31 wraps to 0"
            (defn pv-add-u32 () (add_u32 (shl_u32 1 31) (shl_u32 1 31))) 0 1)
        (prim "register_jit" "witness" "binds form-name to native-name for dispatch; 1 on bind, 0 when the native is unknown"
            (defn pv-register-jit () (do (register_jit "pv-reg-probe" "add_u32") (unregister_jit "pv-reg-probe"))) 1 1)
        (prim "unregister_jit" "witness" "removes a jit alias; 1 removed, 0 when none was bound"
            (defn pv-unregister-jit () (add (unregister_jit "pv-unreg-absent")
                (do (register_jit "pv-unreg-probe" "add_u32") (unregister_jit "pv-unreg-probe")))) 1 1)
        (prim "recipe_to_bytes" "witness" "recipe subtree to .fkb wire bytes as an int list"
            (defn pv-recipe-to-bytes () (if (ge (len (recipe_to_bytes (pv-probe-recipe))) 10) 1 0)) 1 1)
        (prim "bytes_to_recipe" "witness" ".fkb wire bytes back to a walkable recipe — the round-trip keeps the value"
