//////////////////////////////////////////////////////////////////////
//
// host-kernel-interface.bml
//
// OS-independent kernel resource interface in high grammar BML.
// Authority: docs/coherence-substrate/host-kernel.form,
//            docs/coherence-substrate/fkwu-native-host-platform.form,
//            form-stdlib/bml/fkwu-platform-host.bml,
//            form-stdlib/resource-port.fk, storage-port.fk, form-fs.bml,
//            ports-interface-and-structure.md.
//
// RECEIPT PATH: c-bootstrap fkwu on mac/windows/android — NO Go emission.
// Platform impl bindings live in fkwu-platform-host.bml + fkwu-platform-host-carrier.fk.
//
// The body already proves organs and world-ports through per-carrier
// natives (host-kernel-metal-band.fk, verdict 1023). What was missing
// was one named, content-addressable contract that:
//   (1) maps every classic OS duty to a port or organ,
//   (2) binds each duty to a carrier record (not a syscall table in C),
//   (3) names RUNS vs VIA-HOST vs NAMED vs GAP per sibling,
//   (4) receipts the fkwu fourth-arm gaps without pretending parity.
//
// Proven by: form-stdlib/tests/host-kernel-interface-proof.fk
//
//////////////////////////////////////////////////////////////////////

package Form.kernel.host;

import Form.kernel.*;

interface HostResourceObservable [public, witness, port] {
   section [public] {
      String Name() [get];
      String Kind() [get];
      String Status() [get];
      bool RunsOnSibling( String strCarrier ) [witness];
      bool ViaHostOnSibling( String strCarrier ) [witness];
      bool NamedOnly() [get];
      bool GapOnFkwu() [get];
   }
}

enum HostResourceStatus [public] {
   RUNS,
   RUNS_PARTIAL,
   VIA_HOST,
   NAMED,
   GAP
}

enum PortDirection [public] {
   AFFERENT,
   EFFERENT
}

enum PortValueShape [public] {
   BOOL,
   SCALAR,
   BYTES,
   TEXT,
   PIXEL,
   KEY,
   HANDLE
}

template<Object THandle, Object TValue> interface ResourcePort [public, port, reusable] {
   section [public] {
      PortDirection Direction() [get];
      PortValueShape ValueShape() [get];
      TValue Sense( THandle hHandle ) [abstract];
      THandle Act( THandle hHandle, TValue hValue ) [abstract];
   }
}

interface HostCarrierOps [public, carrier, native_floor] {
   section [public] {
      String CarrierName() [get];
      String Platform() [get];
      int OpCount() [get];
      bool FourWayOnValueBands() [witness];
      bool HostIoFenced() [witness];
   }
}

class HostCarrierRecord [public, value, carrier] : HostCarrierOps {
   section [private] {
      String m_strName;
      String m_strPlatform;
      int m_nOpCount;
      bool m_bFourWay;
      bool m_bHostIoFenced;
   }

   section [public] {
      HostCarrierRecord(
         String strName,
         String strPlatform,
         int nOpCount,
         bool bFourWay,
         bool bHostIoFenced ) {
         m_strName = strName;
         m_strPlatform = strPlatform;
         m_nOpCount = nOpCount;
         m_bFourWay = bFourWay;
         m_bHostIoFenced = bHostIoFenced;
      }

      String CarrierName() [get] {
         return m_strName;
      }

      String Platform() [get] {
         return m_strPlatform;
      }

      int OpCount() [get] {
         return m_nOpCount;
      }

      bool FourWayOnValueBands() [witness] {
         return m_bFourWay;
      }

      bool HostIoFenced() [witness] {
         return m_bHostIoFenced;
      }
   }
}

class NativePrimitiveBinding [public, value, native_floor] {
   section [private] {
      String m_strName;
      String m_strCategory;
      String m_strPortFamily;
      bool m_bOsBoundary;
      bool m_bFkwuTag;
      int m_nFkwuTag;
   }

   section [public] {
      const String CatCall = "catCall";
      const String CatWitness = "catWitness";
      const String CatMath = "catMath";

      NativePrimitiveBinding(
         String strName,
         String strCategory,
         String strPortFamily,
         bool bOsBoundary,
         bool bFkwuTag,
         int nFkwuTag ) {
         m_strName = strName;
         m_strCategory = strCategory;
         m_strPortFamily = strPortFamily;
         m_bOsBoundary = bOsBoundary;
         m_bFkwuTag = bFkwuTag;
         m_nFkwuTag = nFkwuTag;
      }

      String Name() [get] {
         return m_strName;
      }

      String Category() [get] {
         return m_strCategory;
      }

      String PortFamily() [get] {
         return m_strPortFamily;
      }

      bool OsBoundary() [get] {
         return m_bOsBoundary;
      }

      bool FkwuEmittedTag() [get] {
         return m_bFkwuTag;
      }

      int FkwuTag() [get] {
         return m_nFkwuTag;
      }
   }
}

class OrganCpu [public, organ, runs] : HostResourceObservable {
   section [public] {
      const String ResourceName = "organ-cpu";
      const String ResourceKind = "organ";
      const String ResourceStatus = "RUNS";

      String Name() [get] {
         return ResourceName;
      }

      String Kind() [get] {
         return ResourceKind;
      }

      String Status() [get] {
         return ResourceStatus;
      }

      bool RunsOnSibling( String strCarrier ) [witness] {
         save;
         choose {
            return strCarrier == "form-kernel-go"
                || strCarrier == "form-kernel-rust"
                || strCarrier == "form-kernel-ts"
                || strCarrier == "fkwu";
         }, {
            discard;
            fail;
         }
      }

      bool ViaHostOnSibling( String strCarrier ) [witness] {
         return false;
      }

      bool NamedOnly() [get] {
         return false;
      }

      bool GapOnFkwu() [get] {
         return false;
      }
   }
}

