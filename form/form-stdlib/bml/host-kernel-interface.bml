class HostKernelInterface [public, selfHosting, hostKernel, observable] {
   section [private] {
      HostCarrierRecord[] m_hCarriers;
      NativePrimitiveBinding[] m_hPrimitives;
      FkwuGapReceipt[] m_hFkwuGaps;
   }

   section [public] {
      const String InterfaceName = "host-kernel-interface";
      const String ImageKind = "HOST-KERNEL-INTERFACE-IMAGE";
      const String ImageExtension = ".fkb";
      const String Authority = "BML source plus Form sibling proof";
      const String PortModel = "resource-port.fk storage-port.fk form-fs.fk";
      const String TrustRule = "same contract same carrier record same verdict across siblings on value bands";
      const String ImagePath = "form/form-stdlib/.cache/host-kernel-interface.fkb";

      HostKernelInterface() {
         m_hCarriers = Array<HostCarrierRecord>();
         m_hPrimitives = Array<NativePrimitiveBinding>();
         m_hFkwuGaps = Array<FkwuGapReceipt>();
      }

      int RequiredOrganCount() [get] {
         return 4;
      }

      int RequiredWorldPortCount() [get] {
         return 6;
      }

      int RequiredOsFeatureCount() [get] {
         return 2;
      }

      int RequiredCarrierCount() [get] {
         return 4;
      }

      int RequiredOsBoundaryPrimitiveCount() [get] {
         return 25;
      }

      int RequiredFkwuGapCount() [get] {
         return 0;
      }

      int RequiredProofCount() [get] {
         return 7;
      }

      bool Minimal() [witness] {
         return true;
      }

      bool Observable() [witness] {
         return true;
      }

      bool OsIndependent() [witness] {
         return true;
      }

      bool MetalNative() [witness] {
         return true;
      }
   }
}

class HostKernelInterfaceImage [public, value, image, hostKernel] {
   section [private] {
      String m_strSourcePath;
      String m_strImagePath;
      String m_strImageKind;
      int m_nOrganCount;
      int m_nWorldPortCount;
      int m_nCarrierCount;
      int m_nPrimitiveCount;
      int m_nFkwuGapCount;
      int m_nProofCount;
   }

   section [public] {
      HostKernelInterfaceImage(
         String strSourcePath,
         String strImagePath,
         int nOrganCount,
         int nWorldPortCount,
         int nCarrierCount,
         int nPrimitiveCount,
         int nFkwuGapCount,
         int nProofCount ) {
         m_strSourcePath = strSourcePath;
         m_strImagePath = strImagePath;
         m_strImageKind = "HOST-KERNEL-INTERFACE-IMAGE";
         m_nOrganCount = nOrganCount;
         m_nWorldPortCount = nWorldPortCount;
         m_nCarrierCount = nCarrierCount;
         m_nPrimitiveCount = nPrimitiveCount;
         m_nFkwuGapCount = nFkwuGapCount;
         m_nProofCount = nProofCount;
      }

      String SourcePath() [get] {
         return m_strSourcePath;
      }

      String ImagePath() [get] {
         return m_strImagePath;
      }

      String Kind() [get] {
         return m_strImageKind;
      }

      int OrganCount() [get] {
         return m_nOrganCount;
      }

      int WorldPortCount() [get] {
         return m_nWorldPortCount;
      }

      int CarrierCount() [get] {
         return m_nCarrierCount;
      }

      int PrimitiveCount() [get] {
         return m_nPrimitiveCount;
      }

      int FkwuGapCount() [get] {
         return m_nFkwuGapCount;
      }

      int ProofCount() [get] {
         return m_nProofCount;
      }
   }
}

class HostKernelInterfaceSelf [public, selfHosting, hostKernel, observable] {
   section [private] {
      HostKernelInterface m_hInterface;
      HostKernelInterfaceImage m_hImage;
   }

   section [public] {
      const String CoreName = "host-kernel-interface-self";
      const String RuntimeFamily = "form-kernel-go form-kernel-rust form-kernel-ts fkwu";

      HostKernelInterfaceSelf() {
         m_hInterface = HostKernelInterface();
      }

      HostKernelInterface Interface() [get] {
         return m_hInterface;
      }

      int RequiredOrganCount() [get] {
         return 4;
      }

      int RequiredWorldPortCount() [get] {
         return 6;
      }

      int RequiredCarrierCount() [get] {
         return 4;
      }

      int RequiredOsBoundaryPrimitiveCount() [get] {
         return 25;
      }

      int RequiredFkwuGapCount() [get] {
         return 0;
      }

      int RequiredProofCount() [get] {
         return 7;
      }

      HostKernelInterfaceImage BuildImage( String strSourcePath ) {
         m_hImage = HostKernelInterfaceImage(
            strSourcePath,
            HostKernelInterface.ImagePath,
            RequiredOrganCount(),
            RequiredWorldPortCount(),
            RequiredCarrierCount(),
            RequiredOsBoundaryPrimitiveCount(),
            RequiredFkwuGapCount(),
            RequiredProofCount() );

         return m_hImage;
      }
   }
}
