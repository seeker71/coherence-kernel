}

class BMLSourceCarrier [public, value, carrier] : CompilerDeclaration<BMLSourceDeclaration> {
   section [public] {
      BMLSourceCarrier(
         String strKind,
         String strName,
         BMLSourceDeclaration hDeclaration ) {
         self(
            strKind,
            strName,
            hDeclaration );
      }
   }
}

class BMLCompilerDeclarationLoweringStage [public, concrete, lowering] : BMLDeclarationLoweringStage<BMLSourceDeclaration,BMLSourceCarrier> {
   section [public] {
      BMLCompilerDeclarationLoweringStage() {
         self();
      }

      String DeclarationKind( BMLSourceDeclaration hDeclaration ) [override] {
         return hDeclaration.Kind();
      }

      String DeclarationName( BMLSourceDeclaration hDeclaration ) [override] {
         return hDeclaration.Name();
      }

      BMLSourceCarrier BuildCarrier(
         String strKind,
         String strName,
         BMLSourceDeclaration hDeclaration ) [override] {
         return BMLSourceCarrier(
            strKind,
            strName,
            hDeclaration );
      }

      BMLSourceDeclaration CarrierSource( BMLSourceCarrier hCarrier ) [override] {
         return hCarrier.Source();
      }
   }
}

class BMLCompilerSourceLoweringFlow [public, concrete, lowering, selfHosting] : BMLSourceLoweringFlow<String,BMLSourceDeclaration,BMLSourceCarrier> {
   section [private] {
      BMLSourceParser m_hParser;
   }

   section [public] {
      BMLCompilerSourceLoweringFlow( BMLSourceParser hParser ) {
         self( BMLCompilerDeclarationLoweringStage() );
         m_hParser = hParser;
      }

      BMLSourceDeclaration[] ParseDeclarations( String strSourcePath ) [override] {
         return m_hParser.ParseDeclarations( strSourcePath );
      }

      bool IsTemplateDeclaration( BMLSourceDeclaration hDeclaration ) [override] {
         return hDeclaration.Kind() == "Template";
      }

      bool IsLanguagePortDeclaration( BMLSourceDeclaration hDeclaration ) [override] {
         return IsKnownLanguagePortName( hDeclaration.Name() );
      }

      bool IsBootstrapBoundaryDeclaration( BMLSourceDeclaration hDeclaration ) [override] {
         return hDeclaration.Name() == "SelfHostingPlan";
      }

      bool IsKnownLanguagePortName( String strName ) {
         if ( strName == "BMLLanguage" ) return true;
         if ( strName == "CSharpLanguage" ) return true;
         if ( strName == "JavaLanguage" ) return true;
         if ( strName == "TypeScriptLanguage" ) return true;
         if ( strName == "GoLanguage" ) return true;
         if ( strName == "RustLanguage" ) return true;

         return false;
      }
   }
}

