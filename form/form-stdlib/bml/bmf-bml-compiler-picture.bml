   section [class, public] {
      const String DefaultImageExtension = ".fkb";
      const String DefaultImagePath = "form/.cache/bml/bml-compiler.fkb";
      const String ImageSource = "BML compiler source";
   }

   section [public] {
      BMLCompilerBootstrapImage BuildImage(
