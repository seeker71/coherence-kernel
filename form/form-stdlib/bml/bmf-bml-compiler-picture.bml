   section [private] {
      BMLSourceDeclaration[] m_hDeclarations;
   }

   section [public] {
      BMLParsedSourceParser( BMLSourceDeclaration[] hDeclarations ) {
         m_hDeclarations = hDeclarations;
      }

      BMLSourceDeclaration[] ParseDeclarations( String strSourcePath ) [override] {
         return m_hDeclarations;
      }
