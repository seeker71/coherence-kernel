class BMLBootstrapRatchet [public, bootstrapBoundary, selfHosting] {
   section [class, public] {
      const String SeedImageExtension = ".fkb";
      const String SourceAuthority = "BML source";
      const String PromotionRule = "promote a new .fkb only after source compile and sibling proof";
      const String RecoveryRule = "compile BML source with the previous proven .fkb until the next image proves itself";
   }

   section [public] {
      bool CanCompileWithSeed( BMLCompilerBootstrapImage hSeedImage ) {
         return true;
      }

      bool CanPromote(
         BMLCompilerBootstrapImage hOldImage,
         BMLCompilerBootstrapImage hNewImage,
         bool bSourceProof,
         bool bSiblingProof ) {
         if ( bSourceProof == false ) return false;
         if ( bSiblingProof == false ) return false;

         return true;
      }

      String Authority() [get] {
         return SourceAuthority;
      }

      String Recovery() [get] {
         return RecoveryRule;
      }
   }
}

