; bml.fk — the BML grammar (the thesis's high-level superset) as cursor rules
; emitting universal Form nodes, over the recursive engine in bmf-grammar.fk.
;
; Built FROM high-level engine constructs — p-chain (field / call / index /
; template-call / ++/-- fold), p-ternary (cond ? a : b), p-infix (precedence
; ladder) — composed with seq/alt/opt/rep/sep/cap. One scannerless pass: cursor
; + matching rules + Form objects; no lexer, no token stream, no Python.
;
; Universal emit: class → UE-CLASS ; interface → UE-INTERFACE ; method/ctor →
; fndef ; section/block → do ; field/local → let ; assignment (= and +=/-=/..) →
; UE-WRITE-ASSIGN ; call / template-call → fncall ; member a.b → UE-ACCESS-MEMBER ;
; index a[i] → UE-ACCESS-INDEX ; if → if-then ; cond?a:b → UE-COND-TERNARY ;
; for/while → UE-LOOP ; switch/select → UE-SWITCH / UE-CASE ; try/catch → UE-TRY /
; UE-CATCH ; throw/fail → UE-THROW ; break/continue/return → UE-JUMP-* ; ++/-- →
; UE-MATH-INC/DEC ; -e → UE-MATH-NEGATE ; binary → add/sub/mul/div/mod, eq/ne/lt/
; le/gt/ge, and/or. Types, generic type-args, property modifiers ([public]/[get]/
; [override]/[class]/...), inheritance bases, and casts are parsed; incidental
; type/modifier detail is erased, the structure it guards is kept.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    (defn bml-grammar () (grammar "unit" (list

        ;; ── compilation unit: (package | import | #include)* topdecl* ─────
        (rule3 "unit" (list "seq" (p-rep (p-ref "prelude")) (p-cap "ds" (p-rep (p-ref "topdecl")))) (t-emit "do" (list (t-splices "ds"))))
        (rule3 "prelude" (p-cap "v" (list "alt" (p-ref "package") (p-ref "import") (p-ref "inc"))) (t-const "prelude"))
        (rule3 "inc" (list "seq" (p-lit "#include") (p-str)) (t-const "include"))
        (rule3 "package" (list "seq" (p-lit "package") (p-ref "dotted") (p-lit ";")) (t-const "package"))
        (rule3 "import" (list "seq" (p-lit "import") (p-ref "importpath") (p-lit ";")) (t-const "import"))
        (rule3 "dotted" (list "seq" (p-run "alnum") (p-rep (list "seq" (p-lit ".") (p-run "alnum")))) (t-const "dotted"))
        (rule3 "importpath" (list "seq" (p-run "alnum") (p-rep (list "seq" (p-lit ".") (list "alt" (p-run "alnum") (p-lit "*"))))) (t-const "import"))
        (rule3 "topdecl" (p-cap "v" (list "alt" (p-ref "iface") (p-ref "gclass") (p-ref "class") (p-ref "gmethod") (p-ref "method") (p-ref "def-block") (p-ref "def-expr") (p-ref "stmt"))) (t-splice "v"))

        ;; ── class / generic class / interface (inheritance via : bases) ───
        (rule3 "class" (list "seq" (p-lit "class") (p-cap "name" (p-run "alnum")) (p-opt (p-ref "props")) (p-opt (p-ref "bases")) (p-lit "{") (p-cap "ms" (p-rep (p-ref "member"))) (p-lit "}")) (t-emit "UE-CLASS" (list (t-splice "name") (t-splices "ms"))))
        (rule3 "gclass" (list "seq" (p-lit "class") (p-cap "name" (p-run "alnum")) (p-lit "<") (p-cap "tps" (p-sep (p-run "alnum") (p-lit ","))) (p-lit ">") (p-opt (p-ref "props")) (p-opt (p-ref "bases")) (p-lit "{") (p-cap "ms" (p-rep (p-ref "member"))) (p-lit "}")) (t-emit "UE-CLASS" (list (t-splice "name") (t-emit "do" (list (t-splices "tps"))) (t-splices "ms"))))
        (rule3 "iface" (list "seq" (p-lit "interface") (p-cap "name" (p-run "alnum")) (p-opt (p-ref "props")) (p-opt (p-ref "bases")) (p-lit "{") (p-cap "ms" (p-rep (p-ref "ifacesig"))) (p-lit "}")) (t-emit "UE-INTERFACE" (list (t-splice "name") (t-splices "ms"))))
        (rule3 "ifacesig" (list "seq" (p-ref "typeref") (p-cap "name" (p-run "alnum")) (p-lit "(") (p-cap "ps" (p-sep (p-ref "param") (p-lit ","))) (p-lit ")") (p-opt (p-ref "props")) (p-lit ";")) (t-emit "fndef" (list (t-splice "name") (t-emit "do" (list (t-splices "ps"))) (t-emit "do" (list)))))
        (rule3 "bases" (list "seq" (p-lit ":") (p-sep (p-ref "typeref") (p-lit ","))) (t-const "bases"))

        ;; ── property modifiers [ a , b=c , ... ] (parsed, erased) ─────────
        (rule3 "props" (list "seq" (p-lit "[") (p-sep (p-ref "propitem") (p-lit ",")) (p-lit "]")) (t-const "props"))
        (rule3 "propitem" (list "seq" (p-run "alnum") (p-opt (list "seq" (p-lit "=") (list "alt" (p-str) (p-ref "typeref") (p-run "alnum"))))) (t-const "prop"))

        ;; ── members ───────────────────────────────────────────────────────
        (rule3 "member" (p-cap "v" (list "alt" (p-ref "section") (p-ref "constfield") (p-ref "opmethod") (p-ref "gmethod") (p-ref "method") (p-ref "ctor") (p-ref "fieldinit") (p-ref "fielddecl"))) (t-splice "v"))
        (rule3 "section" (list "seq" (p-lit "section") (p-opt (p-ref "props")) (p-lit "{") (p-cap "ms" (p-rep (p-ref "member"))) (p-lit "}")) (t-emit "do" (list (t-splices "ms"))))
        (rule3 "constfield" (list "seq" (p-lit "const") (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-opt (p-ref "props")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "let" (list (t-splice "n") (t-splice "e"))))
        (rule3 "opmethod" (list "seq" (p-ref "typeref") (p-lit "operator") (list "alt" (p-lit "==") (p-lit "!=") (p-lit "<=") (p-lit ">=") (p-lit "[]") (p-lit "<") (p-lit ">") (p-lit "+") (p-lit "-") (p-lit "*") (p-lit "/")) (p-lit "(") (p-cap "ps" (p-sep (p-ref "param") (p-lit ","))) (p-lit ")") (p-opt (p-ref "props")) (p-lit "{") (p-cap "body" (p-rep (p-ref "stmt"))) (p-lit "}")) (t-emit "fndef" (list (t-const "operator") (t-emit "do" (list (t-splices "ps"))) (t-emit "do" (list (t-splices "body"))))))
        (rule3 "method" (list "seq" (p-ref "typeref") (p-cap "name" (p-run "alnum")) (p-lit "(") (p-cap "ps" (p-sep (p-ref "param") (p-lit ","))) (p-lit ")") (p-opt (p-ref "props")) (p-lit "{") (p-cap "body" (p-rep (p-ref "stmt"))) (p-lit "}")) (t-emit "fndef" (list (t-splice "name") (t-emit "do" (list (t-splices "ps"))) (t-emit "do" (list (t-splices "body"))))))
        (rule3 "gmethod" (list "seq" (p-ref "typeref") (p-cap "name" (p-run "alnum")) (p-lit "<") (p-cap "tps" (p-sep (p-run "alnum") (p-lit ","))) (p-lit ">") (p-lit "(") (p-cap "ps" (p-sep (p-ref "param") (p-lit ","))) (p-lit ")") (p-opt (p-ref "props")) (p-lit "{") (p-cap "body" (p-rep (p-ref "stmt"))) (p-lit "}")) (t-emit "fndef" (list (t-splice "name") (t-emit "do" (list (t-splices "tps"))) (t-emit "do" (list (t-splices "ps"))) (t-emit "do" (list (t-splices "body"))))))
        (rule3 "ctor" (list "seq" (p-cap "name" (p-run "alnum")) (p-lit "(") (p-cap "ps" (p-sep (p-ref "param") (p-lit ","))) (p-lit ")") (p-opt (p-ref "props")) (p-lit "{") (p-cap "body" (p-rep (p-ref "stmt"))) (p-lit "}")) (t-emit "fndef" (list (t-splice "name") (t-emit "do" (list (t-splices "ps"))) (t-emit "do" (list (t-splices "body"))))))
        (rule3 "fieldinit" (list "seq" (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-opt (p-ref "props")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "let" (list (t-splice "n") (t-splice "e"))))
        (rule3 "fielddecl" (list "seq" (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-opt (p-ref "props")) (p-lit ";")) (t-emit "let" (list (t-splice "n"))))
        (rule3 "param" (list "seq" (p-opt (p-ref "props")) (p-ref "typeref") (p-cap "n" (p-run "alnum"))) (t-splice "n"))

        ;; ── types (generic / dotted, optional [] array) ───────────────────
        (rule3 "typeref" (p-cap "v" (list "alt" (p-ref "gentype") (p-ref "dottedtype"))) (t-splice "v"))
        (rule3 "gentype" (list "seq" (p-cap "n" (p-run "alnum")) (p-lit "<") (p-cap "targs" (p-sep (p-ref "typeref") (p-lit ","))) (p-lit ">") (p-opt (list "seq" (p-lit "[") (p-lit "]")))) (t-emit "fncall" (list (t-splice "n") (t-splices "targs"))))
        (rule3 "dottedtype" (list "seq" (p-cap "v" (p-run "alnum")) (p-rep (list "seq" (p-lit ".") (p-run "alnum"))) (p-opt (list "seq" (p-lit "[") (p-lit "]")))) (t-splice "v"))

        ;; ── statements (keyword-led first, then decls / assigns / exprs) ──
        (rule3 "stmt" (p-cap "v" (list "alt" (p-ref "retv") (p-ref "retz") (p-ref "breakx") (p-ref "continuex") (p-ref "fails") (p-ref "throws") (p-ref "ifs") (p-ref "fors") (p-ref "whiles") (p-ref "switchs") (p-ref "trys") (p-ref "block") (p-ref "constlocal") (p-ref "typedlocal") (p-ref "letlocal") (p-ref "decllocal") (p-ref "compound") (p-ref "assign") (p-ref "exprs"))) (t-splice "v"))
        (rule3 "retv" (list "seq" (p-lit "return") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "UE-JUMP-RETURN" (list (t-splice "e"))))
        (rule3 "retz" (list "seq" (p-lit "return") (p-lit ";")) (t-emit "UE-JUMP-RETURN" (list)))
        (rule3 "breakx" (list "seq" (p-lit "break") (p-lit ";")) (t-emit "UE-JUMP-BREAK" (list)))
        (rule3 "continuex" (list "seq" (p-lit "continue") (p-lit ";")) (t-emit "UE-JUMP-CONTINUE" (list)))
        (rule3 "fails" (list "seq" (p-lit "fail") (p-lit ";")) (t-emit "UE-THROW" (list)))
        (rule3 "throws" (list "seq" (p-lit "throw") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "UE-THROW" (list (t-splice "e"))))
        (rule3 "ifs" (list "seq" (p-lit "if") (p-lit "(") (p-cap "c" (p-ref "expr")) (p-lit ")") (p-cap "t" (p-ref "stmt")) (p-opt (list "seq" (p-lit "else") (p-ref "stmt")))) (t-emit "if-then" (list (t-splice "c") (t-splice "t"))))
        (rule3 "fors" (list "seq" (p-lit "for") (p-lit "(") (p-cap "i" (p-ref "forinit")) (p-lit ";") (p-cap "c" (p-ref "expr")) (p-lit ";") (p-cap "u" (p-ref "expr")) (p-lit ")") (p-cap "b" (p-ref "stmt"))) (t-emit "UE-LOOP" (list (t-splice "i") (t-splice "c") (t-splice "u") (t-splice "b"))))
        (rule3 "forinit" (p-cap "v" (list "alt" (p-ref "fordecl") (p-ref "forassign") (p-ref "expr"))) (t-splice "v"))
        (rule3 "fordecl" (list "seq" (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-lit "=") (p-cap "e" (p-ref "expr"))) (t-emit "let" (list (t-splice "n") (t-splice "e"))))
        (rule3 "forassign" (list "seq" (p-cap "l" (p-ref "postfix")) (p-lit "=") (p-cap "e" (p-ref "expr"))) (t-emit "UE-WRITE-ASSIGN" (list (t-splice "l") (t-splice "e"))))
        (rule3 "whiles" (list "seq" (p-lit "while") (p-lit "(") (p-cap "c" (p-ref "expr")) (p-lit ")") (p-cap "b" (p-ref "stmt"))) (t-emit "UE-LOOP" (list (t-splice "c") (t-splice "b"))))
        (rule3 "switchs" (list "seq" (list "alt" (p-lit "switch") (p-lit "select")) (p-lit "(") (p-cap "e" (p-ref "expr")) (p-lit ")") (p-lit "{") (p-cap "cs" (p-rep (p-ref "caseitem"))) (p-lit "}")) (t-emit "UE-SWITCH" (list (t-splice "e") (t-splices "cs"))))
        (rule3 "caseitem" (p-cap "v" (list "alt" (p-ref "caseclause") (p-ref "defclause"))) (t-splice "v"))
        (rule3 "caseclause" (list "seq" (p-lit "case") (p-cap "vs" (p-sep (p-ref "expr") (p-lit ","))) (p-lit ":") (p-cap "ss" (p-rep (p-ref "stmt")))) (t-emit "UE-CASE" (list (t-emit "do" (list (t-splices "vs"))) (t-emit "do" (list (t-splices "ss"))))))
        (rule3 "defclause" (list "seq" (p-lit "default") (p-lit ":") (p-cap "ss" (p-rep (p-ref "stmt")))) (t-emit "UE-CASE" (list (t-emit "do" (list)) (t-emit "do" (list (t-splices "ss"))))))
        (rule3 "trys" (list "seq" (p-lit "try") (p-cap "b" (p-ref "block")) (p-cap "cs" (p-rep (p-ref "catchclause")))) (t-emit "UE-TRY" (list (t-splice "b") (t-splices "cs"))))
        (rule3 "catchclause" (list "seq" (p-lit "catch") (p-lit "(") (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-lit ")") (p-cap "b" (p-ref "block"))) (t-emit "UE-CATCH" (list (t-splice "n") (t-splice "b"))))
        (rule3 "block" (list "seq" (p-lit "{") (p-cap "ss" (p-rep (p-ref "stmt"))) (p-lit "}")) (t-emit "do" (list (t-splices "ss"))))
        (rule3 "constlocal" (list "seq" (p-lit "const") (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "let" (list (t-splice "n") (t-splice "e"))))
        (rule3 "typedlocal" (list "seq" (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "let" (list (t-splice "n") (t-splice "e"))))
        (rule3 "letlocal" (list "seq" (p-lit "let") (p-cap "n" (p-run "alnum")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "let" (list (t-splice "n") (t-splice "e"))))
        (rule3 "decllocal" (list "seq" (p-ref "typeref") (p-cap "n" (p-run "alnum")) (p-opt (p-ref "props")) (p-lit ";")) (t-emit "let" (list (t-splice "n"))))
        (rule3 "def-expr" (list "seq" (p-lit "def") (p-cap "name" (p-run "alnum")) (p-lit "(") (p-cap "ps" (p-sep (p-run "alnum") (p-lit ","))) (p-lit ")") (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "fndef" (list (t-splice "name") (t-emit "do" (list (t-splices "ps"))) (t-splice "e"))))
        (rule3 "def-block" (list "seq" (p-lit "def") (p-cap "name" (p-run "alnum")) (p-lit "(") (p-cap "ps" (p-sep (p-run "alnum") (p-lit ","))) (p-lit ")") (p-lit "{") (p-cap "body" (p-rep (p-ref "stmt"))) (p-lit "}")) (t-emit "fndef" (list (t-splice "name") (t-emit "do" (list (t-splices "ps"))) (t-emit "do" (list (t-splices "body"))))))
        (rule3 "compound" (list "seq" (p-cap "l" (p-ref "postfix")) (list "alt" (p-lit "+=") (p-lit "-=") (p-lit "*=") (p-lit "/=")) (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "UE-WRITE-ASSIGN" (list (t-splice "l") (t-splice "e"))))
        (rule3 "assign" (list "seq" (p-cap "l" (p-ref "postfix")) (p-lit "=") (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-emit "UE-WRITE-ASSIGN" (list (t-splice "l") (t-splice "e"))))
        (rule3 "exprs" (list "seq" (p-cap "e" (p-ref "expr")) (p-lit ";")) (t-splice "e"))

        ;; ── expression: ternary over the precedence ladder over unary ─────
        ;; expr = ternary over the precedence ladder over unary — the orexpr
        ;; wrapper is inlined (one fewer rule-dispatch per operand).
        (rule3 "expr" (p-cap "v" (p-ternary (p-infix (p-ref "unary") (list
            (list "||" "or" 1) (list "&&" "and" 2)
            (list "==" "eq" 3) (list "!=" "ne" 3)
            (list "instanceof" "eq" 4)
            (list "<=" "le" 4) (list ">=" "ge" 4) (list "<" "lt" 4) (list ">" "gt" 4)
            (list "+" "add" 5) (list "-" "sub" 5) (list "*" "mul" 6) (list "/" "div" 6) (list "%" "mod" 6))) (p-ref "expr"))) (t-splice "v"))

        ;; ── unary prefix: ++ -- ! - and cast (Type)e (type erased) ────────
        (rule3 "unary" (p-cap "v" (list "alt" (p-ref "preinc") (p-ref "predec") (p-ref "notx") (p-ref "negx") (p-ref "castx") (p-ref "postfix"))) (t-splice "v"))
        (rule3 "preinc" (list "seq" (p-lit "++") (p-cap "e" (p-ref "unary"))) (t-emit "UE-MATH-INC" (list (t-splice "e"))))
        (rule3 "predec" (list "seq" (p-lit "--") (p-cap "e" (p-ref "unary"))) (t-emit "UE-MATH-DEC" (list (t-splice "e"))))
        (rule3 "notx" (list "seq" (p-lit "!") (p-cap "e" (p-ref "unary"))) (t-emit "not" (list (t-splice "e"))))
        (rule3 "negx" (list "seq" (p-lit "-") (p-cap "e" (p-ref "unary"))) (t-emit "sub" (list (t-const-int 0) (t-splice "e"))))
        (rule3 "castx" (list "seq" (p-lit "(") (p-ref "typeref") (p-lit ")") (p-cap "e" (p-ref "unary"))) (t-splice "e"))

        ;; ── postfix: the chain fold — member / call / index / generic call / ++/-- ──
        (rule3 "postfix" (p-cap "v" (p-chain (p-ref "primary") (p-ref "expr"))) (t-splice "v"))

        ;; ── primary: ( expr ) | string | char | number | identifier ───────
        ;; primary order: litnum BEFORE ident (ident's alnum-run also matches
        ;; digits, so numbers must be tried first), then ident (the common case)
        ;; — idents now match in 2 tries instead of 5, numbers in 1, safely.
        (rule3 "primary" (p-cap "v" (list "alt" (p-ref "choiceReceipt") (p-ref "protocol") (p-ref "capability") (p-ref "ifexpr") (p-ref "litempty") (p-ref "littrue") (p-ref "litfalse") (p-ref "litnum") (p-ref "ident") (p-ref "litstr") (p-ref "paren") (p-ref "litchr"))) (t-splice "v"))
        (rule3 "choiceReceipt" (list "seq" (p-lit "choiceReceipt") (p-lit "(") (p-cap "args" (p-sep (p-ref "expr") (p-lit ","))) (p-lit ")")) (t-emit "fncall" (list (t-emit "ident" (list (t-const "choiceReceipt"))) (t-splices "args"))))
        (rule3 "protocol" (list "seq" (p-lit "protocol") (p-lit "(") (p-cap "args" (p-sep (p-ref "expr") (p-lit ","))) (p-lit ")")) (t-emit "fncall" (list (t-emit "ident" (list (t-const "protocol"))) (t-splices "args"))))
        (rule3 "capability" (list "seq" (p-lit "capability") (p-lit "(") (p-cap "args" (p-sep (p-ref "expr") (p-lit ","))) (p-lit ")")) (t-emit "fncall" (list (t-emit "ident" (list (t-const "capability"))) (t-splices "args"))))
        (rule3 "ifexpr" (list "seq" (p-lit "if") (p-cap "c" (p-ref "expr")) (p-lit "then") (p-cap "t" (p-ref "expr")) (p-lit "else") (p-cap "e" (p-ref "expr"))) (t-emit "if" (list (t-splice "c") (t-splice "t") (t-splice "e"))))
        (rule3 "litempty" (p-lit "empty") (t-emit "fncall" (list (t-emit "ident" (list (t-const "empty"))))))
        (rule3 "littrue" (p-lit "true") (t-const-bool 1))
        (rule3 "litfalse" (p-lit "false") (t-const-bool 0))
        (rule3 "paren" (list "seq" (p-lit "(") (p-cap "e" (p-ref "expr")) (p-lit ")")) (t-splice "e"))
        (rule3 "litstr" (p-cap "v" (p-str)) (t-splice "v"))
        (rule3 "litchr" (p-cap "v" (p-char)) (t-splice "v"))
        (rule3 "litnum" (p-cap "v" (p-num)) (t-splice-int "v"))
        (rule3 "ident" (p-cap "v" (p-run "alnum")) (t-emit "ident" (list (t-splice "v"))))
        )))
)
