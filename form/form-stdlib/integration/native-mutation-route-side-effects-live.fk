; integration/native-mutation-route-side-effects-live.fk -- live Postgres proof
; that native mutation route runners bind app graph writes to side effects.
;
; preludes: form-stdlib/core.fk form-stdlib/application-graph-node-port.fk
;           form-stdlib/native-mutation-side-effects.fk
;           form-stdlib/native-mutation-route-side-effects.fk
;
; Verdict: 1111111 when every step holds against live Postgres:
;   connect                                -> 1
;   create rollback-safe fixture schema    -> 10
;   idea create route runner readback       -> 100
;   spec update route runner readback       -> 1000
;   side-effect receipts + key audit        -> 10000
;   drop fixture tables                     -> 100000
;   close connection                        -> 1000000

(do
    (let DSN "PG_DSN_PLACEHOLDER")

    (let conn (pg_connect DSN))
    (let connect-ok (if (ge conn 0) 1 0))

    (pg_exec conn "DROP TABLE IF EXISTS native_mutation_side_effect_receipts")
    (pg_exec conn "DROP TABLE IF EXISTS graph_edges")
    (pg_exec conn "DROP TABLE IF EXISTS graph_node_revisions")
    (pg_exec conn "DROP TABLE IF EXISTS graph_nodes")
    (pg_exec conn "DROP TABLE IF EXISTS contributor_api_keys")

    (let nodes-ddl
        "CREATE TABLE graph_nodes (
            id VARCHAR(255) PRIMARY KEY,
            type VARCHAR(50) NOT NULL,
            name TEXT NOT NULL DEFAULT '',
            description TEXT NOT NULL DEFAULT '',
            properties JSONB NOT NULL DEFAULT '{}'::jsonb,
            phase VARCHAR(20) NOT NULL DEFAULT 'water',
            created_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP
        )")
    (let revisions-ddl
        "CREATE TABLE graph_node_revisions (
            id VARCHAR(255) PRIMARY KEY,
            node_id VARCHAR(255) NOT NULL,
            revision_number INTEGER NOT NULL,
            captured_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
            source VARCHAR(32) NOT NULL DEFAULT 'api',
            author VARCHAR(255) NOT NULL DEFAULT '',
            fields_changed JSONB NOT NULL DEFAULT '[]'::jsonb,
            snapshot JSONB NOT NULL DEFAULT '{}'::jsonb,
            CONSTRAINT uq_node_revisions_node_rev UNIQUE (node_id, revision_number)
        )")
    (let edges-ddl
        "CREATE TABLE graph_edges (
            id VARCHAR(255) PRIMARY KEY,
            from_id VARCHAR(255) NOT NULL,
            to_id VARCHAR(255) NOT NULL,
            type VARCHAR(100) NOT NULL,
            properties JSONB NOT NULL DEFAULT '{}'::jsonb,
            strength DOUBLE PRECISION NOT NULL DEFAULT 1.0,
            created_by VARCHAR(255) NOT NULL DEFAULT 'system',
            created_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP
        )")
    (let edge-index-ddl "CREATE UNIQUE INDEX ix_graph_edges_pair ON graph_edges (from_id, to_id, type)")
    (let keys-ddl
        "CREATE TABLE contributor_api_keys (
            id VARCHAR(255) PRIMARY KEY,
            contributor_id VARCHAR(255) NOT NULL,
            label VARCHAR(255),
            provider VARCHAR(255),
            provider_id VARCHAR(255),
            scopes_json TEXT NOT NULL DEFAULT '[]',
            created_at VARCHAR(255) NOT NULL,
            last_used_at VARCHAR(255),
            revoked_at VARCHAR(255)
        )")
    (let schema-ok (if (eq (nms-and4
        (if (ge (pg_exec conn nodes-ddl) 0) 1 0)
        (if (ge (pg_exec conn revisions-ddl) 0) 1 0)
        (if (ge (pg_exec conn edges-ddl) 0) 1 0)
        (if (ge (pg_exec conn edge-index-ddl) 0) 1 0)) 1) 10 0))
    (pg_exec conn keys-ddl)
    (nms-create-receipts-table conn)

    (pg_exec conn "INSERT INTO graph_nodes (id, type, name, properties, phase) VALUES ('idea-route-parent', 'idea', 'Route Parent', '{\"stage\":\"validated\"}'::jsonb, 'ice')")
    (pg_exec conn "INSERT INTO contributor_api_keys (id, contributor_id, scopes_json, created_at) VALUES ('key-route-native', 'urs-muff', '[\"own:write\"]', '2026-06-08T00:00:00Z')")

    (nmrs-run-idea-create-with-side-effects
        conn
        "mut-route-idea"
        "rev-route-idea-create"
        "idea-route-child"
        "Route Child"
        "Created through native route runner"
        "water"
        "{\"manifestation_status\":\"partial\",\"workspace_id\":\"coherence-network\"}"
        "idea-route-parent"
        "key-route-native"
        "form-native")
    (let idea-row (pg_query conn "SELECT type || ':' || name || ':' || phase || ':' || (properties->>'manifestation_status') FROM graph_nodes WHERE id = 'idea-route-child'"))
    (let idea-rev (pg_query conn "SELECT revision_number::text || ':' || source || ':' || author || ':' || (fields_changed->>0) FROM graph_node_revisions WHERE node_id = 'idea-route-child'"))
    (let edge-row (pg_query conn "SELECT type || ':' || created_by || ':' || (properties->>'effect') || ':' || (properties->>'mutation_id') FROM graph_edges WHERE from_id = 'idea-route-parent' AND to_id = 'idea-route-child'"))
    (let idea-ok (if (eq (nms-and3
        (if (str_eq idea-row "idea:Route Child:water:partial") 1 0)
        (if (str_eq idea-rev "1:kernel-route-runner:form-native:__create__") 1 0)
        (if (str_eq edge-row "parent-of:form-native:parent-edge-repair:mut-route-idea") 1 0)) 1) 100 0))

    (agn-create-node
        conn
        "rev-route-spec-create"
        "spec-route-native"
        "spec"
        "Route Spec"
        "Created before route update"
        "water"
        "{\"status\":\"draft\",\"workspace_id\":\"coherence-network\"}"
        "kernel-route-runner"
        "form-native")
    (nmrs-run-spec-update-with-side-effects
        conn
        "mut-route-spec"
        "rev-route-spec-update"
        "spec-route-native"
        "Route Spec Updated"
        "Updated through native route runner"
        "{\"status\":\"validated\",\"workspace_id\":\"coherence-network\"}"
        "key-route-native"
        "form-native")
    (let spec-row (pg_query conn "SELECT name || ':' || phase || ':' || (properties->>'status') FROM graph_nodes WHERE id = 'spec-route-native'"))
    (let spec-rev-count (pg_query conn "SELECT count(*) FROM graph_node_revisions WHERE node_id = 'spec-route-native'"))
    (let spec-last-rev (pg_query conn "SELECT revision_number::text || ':' || source || ':' || (fields_changed->>0) FROM graph_node_revisions WHERE node_id = 'spec-route-native' ORDER BY revision_number DESC LIMIT 1"))
    (let spec-ok (if (eq (nms-and3
        (if (str_eq spec-row "Route Spec Updated:ice:validated") 1 0)
        (if (str_eq spec-rev-count "2") 1 0)
        (if (str_eq spec-last-rev "2:kernel-route-runner:title") 1 0)) 1) 1000 0))

    (let receipt-count (pg_query conn "SELECT count(*) FROM native_mutation_side_effect_receipts"))
    (let receipt-effects (pg_query conn "SELECT count(DISTINCT effect_name)::text FROM native_mutation_side_effect_receipts"))
    (let key-row (pg_query conn "SELECT CASE WHEN last_used_at IS NOT NULL AND last_used_at <> '' THEN 'used' ELSE 'missing' END FROM contributor_api_keys WHERE id = 'key-route-native'"))
    (let side-effects-ok (if (eq (nms-and3
        (if (str_eq receipt-count "4") 1 0)
        (if (str_eq receipt-effects "2") 1 0)
        (if (str_eq key-row "used") 1 0)) 1) 10000 0))

    (pg_exec conn "DROP TABLE IF EXISTS native_mutation_side_effect_receipts")
    (pg_exec conn "DROP TABLE IF EXISTS graph_edges")
    (pg_exec conn "DROP TABLE IF EXISTS graph_node_revisions")
    (pg_exec conn "DROP TABLE IF EXISTS graph_nodes")
    (pg_exec conn "DROP TABLE IF EXISTS contributor_api_keys")
    (let cleanup-read (pg_query conn "SELECT COALESCE(to_regclass('public.native_mutation_side_effect_receipts')::text, '')"))
    (let cleanup-ok (if (str_eq cleanup-read "") 100000 0))

    (let close-ok (if (eq (pg_close conn) 0) 1000000 0))

    (sum (list connect-ok schema-ok idea-ok spec-ok side-effects-ok cleanup-ok close-ok)))
