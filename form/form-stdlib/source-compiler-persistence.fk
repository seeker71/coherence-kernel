; source-compiler-persistence.fk -- post-write observation attestation.
;
; This layer binds an emitted source-compiler receipt to a supplied
; source-artifact-probe bundle. It says only that the supplied observations
; match the emission closely enough for the cache/probe lane to consume the
; resulting descriptor triple. It does not assert durable filesystem truth,
; perform IO, hash bytes, verify seals/proofs, load artifacts, install a
; selector, or grow the C seed.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/source-artifact-probe.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-tbl-emit.fk
;           form-stdlib/source-compiler-emission.fk

(do
    (defn scp-feature (name status) (list "source-compiler-persistence-feature" name status))
    (defn scp-feature-name (f) (nth f 1))
    (defn scp-feature-status (f) (nth f 2))
    (defn source-compiler-persistence-manifest ()
        (list
            (scp-feature "post-write-observation-attestation" 1)
            (scp-feature "emission-bound-to-sap-bundle" 1)
            (scp-feature "descriptor-triple-handoff" 1)
            (scp-feature "source-observation-required" 1)
            (scp-feature "program-image-fkb-observation-required" 1)
            (scp-feature "optional-native-observation" 1)
            (scp-feature "route-policy-delegated-to-sad" 1)
            (scp-feature "currency-delegated-not-mtime-bound-locally" 1)
            (scp-feature "reason-manifest-covered" 1)
            (scp-feature "no-disk-io" 1)
            (scp-feature "no-byte-hashing" 1)
            (scp-feature "no-seal-proof-verification" 1)
            (scp-feature "no-artifact-load-walk-call" 1)
            (scp-feature "no-selector-install" 1)
            (scp-feature "no-c-seed-growth" 1)))
    (defn source-compiler-persistence-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (scp-feature-name (head fs)) name)
                     (eq (scp-feature-status (head fs)) 1))
                1
                (source-compiler-persistence-manifest-has? name (tail fs)))))

    (defn scp-status-persistence-ready () "persistence-ready")
    (defn scp-status-investigate () "investigate")
    (defn scp-status-refused () "refused")

    (defn scp-reason-persistence-ready-fkb () "persistence-ready-fkb")
    (defn scp-reason-persistence-ready-fkb-dylib () "persistence-ready-fkb-dylib")
    (defn scp-reason-malformed-emission () "malformed-emission")
    (defn scp-reason-non-emitted-emission () "non-emitted-emission")
    (defn scp-reason-malformed-probe-bundle () "malformed-probe-bundle")
    (defn scp-reason-malformed-source-observation () "malformed-source-observation")
    (defn scp-reason-source-observation-absent () "source-observation-absent")
    (defn scp-reason-source-observation-mismatch () "source-observation-mismatch")
    (defn scp-reason-malformed-fkb-observation () "malformed-fkb-observation")
    (defn scp-reason-fkb-observation-absent () "fkb-observation-absent")
    (defn scp-reason-fkb-observation-identity-mismatch () "fkb-observation-identity-mismatch")
    (defn scp-reason-fkb-observation-seal-missing () "fkb-observation-seal-missing")
    (defn scp-reason-fkb-observation-missing-tbl () "fkb-observation-missing-tbl")
    (defn scp-reason-fkb-route-not-current () "fkb-route-not-current")
    (defn scp-reason-dylib-not-expected-but-observed () "dylib-not-expected-but-observed")
    (defn scp-reason-dylib-expected-missing () "dylib-expected-missing")
    (defn scp-reason-malformed-dylib-observation () "malformed-dylib-observation")
    (defn scp-reason-dylib-observation-identity-mismatch () "dylib-observation-identity-mismatch")
    (defn scp-reason-dylib-observation-policy-unsatisfied () "dylib-observation-policy-unsatisfied")
    (defn scp-reason-dylib-route-not-current () "dylib-route-not-current")

    (defn scp-reason-manifest ()
        (list
            (scp-reason-persistence-ready-fkb)
            (scp-reason-persistence-ready-fkb-dylib)
            (scp-reason-malformed-emission)
            (scp-reason-non-emitted-emission)
            (scp-reason-malformed-probe-bundle)
            (scp-reason-malformed-source-observation)
            (scp-reason-source-observation-absent)
            (scp-reason-source-observation-mismatch)
            (scp-reason-malformed-fkb-observation)
            (scp-reason-fkb-observation-absent)
            (scp-reason-fkb-observation-identity-mismatch)
            (scp-reason-fkb-observation-seal-missing)
            (scp-reason-fkb-observation-missing-tbl)
            (scp-reason-fkb-route-not-current)
            (scp-reason-dylib-not-expected-but-observed)
            (scp-reason-dylib-expected-missing)
            (scp-reason-malformed-dylib-observation)
            (scp-reason-dylib-observation-identity-mismatch)
            (scp-reason-dylib-observation-policy-unsatisfied)
            (scp-reason-dylib-route-not-current)))

    (defn scp-empty-triple ()
        (list (sad-source "" "" 0) (sad-no-artifact) (sad-no-artifact)))
    (defn scp-observation-row? (o)
        (if (eq (len o) 13)
            (str_eq (nth o 0) "source-artifact-probe-observation")
            0))
    (defn scp-bundle-row? (b)
        (if (eq (len b) 4)
            (str_eq (nth b 0) "source-artifact-probe-bundle")
            0))
    (defn scp-source-observation-valid? (o)
        (if (scp-observation-row? o)
            (if (sap-role? o (sap-role-source))
                (sap-observation-shape-valid? o)
                0)
            0))
    (defn scp-fkb-observation-valid? (o)
        (if (scp-observation-row? o)
            (if (sap-role? o (sap-role-program-image-fkb))
                (sap-observation-shape-valid? o)
                0)
            0))
    (defn scp-dylib-observation-valid? (o)
        (if (scp-observation-row? o)
            (if (sap-role? o (sap-role-native-dylib))
                (sap-observation-shape-valid? o)
                0)
            0))
    (defn scp-bundle-observations-valid? (b)
        (if (scp-bundle-row? b)
            (if (scp-source-observation-valid? (sap-bundle-source b))
                (if (scp-fkb-observation-valid? (sap-bundle-fkb b))
                    (scp-dylib-observation-valid? (sap-bundle-dylib b))
                    0)
                0)
            0))
    (defn scp-triple-from-bundle (b)
        (if (scp-bundle-observations-valid? b)
            (sap-descriptor-triple b)
            (scp-empty-triple)))

    (defn scp-source-from-emission (e)
        (rale-envelope-source (sce-emission-compile-envelope e)))
    (defn scp-fkb-from-emission (e)
        (sce-emission-fkb-descriptor e))
    (defn scp-dylib-from-emission (e)
        (sce-emission-dylib e))
    (defn scp-dylib-expected? (e)
        (if (sce-no-dylib? (scp-dylib-from-emission e)) 0 1))

    (defn scp-source-observation-match? (source o)
        (if (sap-observation-present? o)
            (if (str_eq (sad-source-path source) (sap-observation-path o))
                (str_eq (sad-source-hash source) (sap-observation-source-hash o))
                0)
            0))
    (defn scp-fkb-observation-match? (fkb o)
        (if (sap-observation-present? o)
            (if (str_eq (sad-artifact-path fkb) (sap-observation-path o))
                (if (str_eq (sad-artifact-source-hash fkb) (sap-observation-source-hash o))
                    (str_eq (sad-artifact-content-hash fkb) (sap-observation-content-hash o))
                    0)
                0)
            0))
    (defn scp-fkb-route-current? (source fkb)
        (eq (sad-route source fkb (sad-no-artifact)) (sac-run-fkb)))
    (defn scp-dylib-observation-match? (dylib o)
        (if (sap-observation-present? o)
            (if (str_eq (sad-artifact-path dylib) (sap-observation-path o))
                (if (str_eq (sad-artifact-source-hash dylib) (sap-observation-source-hash o))
                    (str_eq (sad-artifact-content-hash dylib) (sap-observation-content-hash o))
                    0)
                0)
            0))
    (defn scp-dylib-policy-fields-match? (dylib o)
        (if (eq (sap-observation-seal-ok o) (sad-artifact-seal-ok dylib))
            (if (eq (sap-observation-proof o) (sad-artifact-proof dylib))
                (if (eq (sap-observation-callable o) (sad-artifact-callable dylib))
                    (eq (sap-observation-lowerable o) (sad-artifact-lowerable dylib))
                    0)
                0)
            0))
    (defn scp-dylib-route-current? (source fkb dylib)
        (eq (sad-route source fkb dylib) (sac-run-dylib)))

    ; persistence = ("source-compiler-persistence" emission bundle
    ;                descriptor-triple status reason)
    (defn scp-persistence (emission bundle triple status reason)
        (list "source-compiler-persistence" emission bundle triple status reason))
    (defn scp-persistence? (p)
        (if (eq (len p) 6)
            (str_eq (nth p 0) "source-compiler-persistence")
            0))
    (defn scp-persistence-emission (p) (nth p 1))
    (defn scp-persistence-bundle (p) (nth p 2))
    (defn scp-persistence-descriptor-triple (p) (nth p 3))
    (defn scp-persistence-status (p) (nth p 4))
    (defn scp-persistence-reason (p) (nth p 5))
    (defn scp-persistence-ready? (p)
        (if (scp-persistence? p)
            (str_eq (scp-persistence-status p) (scp-status-persistence-ready))
            0))
    (defn scp-investigate? (p)
        (if (scp-persistence? p)
            (str_eq (scp-persistence-status p) (scp-status-investigate))
            0))
    (defn scp-refused? (p)
        (if (scp-persistence? p)
            (str_eq (scp-persistence-status p) (scp-status-refused))
            0))
    (defn scp-ready-row (emission bundle reason)
        (scp-persistence emission bundle (scp-triple-from-bundle bundle) (scp-status-persistence-ready) reason))
    (defn scp-investigate-row (emission bundle reason)
        (scp-persistence emission bundle (scp-empty-triple) (scp-status-investigate) reason))
    (defn scp-refused-row (emission bundle reason)
        (scp-persistence emission bundle (scp-empty-triple) (scp-status-refused) reason))

    (defn scp-after-fkb-ready (emission bundle source fkb dylib-observation)
        (if (eq (scp-dylib-expected? emission) 0)
            (if (sap-observation-present? dylib-observation)
                (scp-investigate-row emission bundle (scp-reason-dylib-not-expected-but-observed))
                (scp-ready-row emission bundle (scp-reason-persistence-ready-fkb)))
            (do
                (let expected-dylib (scp-dylib-from-emission emission))
                (let observed-dylib (sap-dylib-descriptor dylib-observation))
                (if (not (sap-observation-present? dylib-observation))
                    (scp-investigate-row emission bundle (scp-reason-dylib-expected-missing))
                    (if (not (scp-dylib-observation-match? expected-dylib dylib-observation))
                        (scp-investigate-row emission bundle (scp-reason-dylib-observation-identity-mismatch))
                        (if (not (scp-dylib-policy-fields-match? expected-dylib dylib-observation))
                            (scp-investigate-row emission bundle (scp-reason-dylib-observation-policy-unsatisfied))
                            (if (not (scp-dylib-route-current? source fkb observed-dylib))
                                (scp-investigate-row emission bundle (scp-reason-dylib-route-not-current))
                                (scp-ready-row emission bundle (scp-reason-persistence-ready-fkb-dylib)))))))))

    (defn scp-after-source-ready (emission bundle source-observation fkb-observation dylib-observation)
        (do
            (let source (sap-source-descriptor source-observation))
            (let expected-fkb (scp-fkb-from-emission emission))
            (if (not (scp-fkb-observation-valid? fkb-observation))
                (scp-refused-row emission bundle (scp-reason-malformed-fkb-observation))
                (if (not (sap-observation-present? fkb-observation))
                    (scp-investigate-row emission bundle (scp-reason-fkb-observation-absent))
                    (if (not (scp-fkb-observation-match? expected-fkb fkb-observation))
                        (scp-investigate-row emission bundle (scp-reason-fkb-observation-identity-mismatch))
                        (if (not (eq (sap-observation-seal-ok fkb-observation) 1))
                            (scp-investigate-row emission bundle (scp-reason-fkb-observation-seal-missing))
                            (if (not (eq (sap-observation-includes-tbl fkb-observation) 1))
                                (scp-investigate-row emission bundle (scp-reason-fkb-observation-missing-tbl))
                                (do
                                    (let observed-fkb (sap-fkb-descriptor fkb-observation))
                                    (if (not (scp-fkb-route-current? source observed-fkb))
                                        (scp-investigate-row emission bundle (scp-reason-fkb-route-not-current))
                                        (if (not (scp-dylib-observation-valid? dylib-observation))
                                            (scp-refused-row emission bundle (scp-reason-malformed-dylib-observation))
                                            (scp-after-fkb-ready emission bundle source observed-fkb dylib-observation)))))))))))

    (defn scp-persistence-from-probe (emission bundle)
        (if (not (sce-emission? emission))
            (scp-refused-row emission bundle (scp-reason-malformed-emission))
            (if (not (sce-emitted? emission))
                (scp-investigate-row emission bundle (scp-reason-non-emitted-emission))
                (if (not (scp-bundle-row? bundle))
                    (scp-refused-row emission bundle (scp-reason-malformed-probe-bundle))
                    (do
                        (let source-observation (sap-bundle-source bundle))
                        (let fkb-observation (sap-bundle-fkb bundle))
                        (let dylib-observation (sap-bundle-dylib bundle))
                        (if (not (scp-source-observation-valid? source-observation))
                            (scp-refused-row emission bundle (scp-reason-malformed-source-observation))
                            (if (not (sap-observation-present? source-observation))
                                (scp-investigate-row emission bundle (scp-reason-source-observation-absent))
                                (if (not (scp-source-observation-match? (scp-source-from-emission emission) source-observation))
                                    (scp-investigate-row emission bundle (scp-reason-source-observation-mismatch))
                                    (scp-after-source-ready emission bundle source-observation fkb-observation dylib-observation)))))))))
)
