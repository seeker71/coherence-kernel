; native-model-daily-form.fk — Form-owned daily plan, closure, and progress.
;
; Host facts (fresh binary checks, power, thermals, free space, local-process
; identity, Git state) enter as observations.  This cell owns the decisions:
; whether work is admitted, whether an actual bounded training run closed its
; plan, whether a byte-copy deployment still serves the exact trained artifact,
; and how daily local ownership changed.  The equality check is not a LoRA ->
; fuse -> quantize lineage proof; canonical transformation edges live in
; native-model-lineage-form.fk and must still be wired into this promotion plan.
; This cell composes the registry/control-plane and live-loop schemas rather
; than inventing another occurrence format.
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/native-model-control-plane.fk form-stdlib/native-model-live-loop.fk form-stdlib/native-model-evidence.fk form-stdlib/native-model-eval-form.fk form-stdlib/native-model-seal-form.fk

(do
    ; integrity = tag fresh-compile ground recursive freshness native-way
    ;             live-band artifact-clean sibling-parity
    (defn nmfd-integrity
        (fresh-compile ground recursive freshness native-way live-band
         artifact-clean sibling-parity)
        (list "native-model-integrity-v1" fresh-compile ground recursive freshness
              native-way live-band artifact-clean sibling-parity))
    (defn nmfd-integrity? (r)
        (if (and (eq (len r) 9)
                 (str_eq (nth r 0) "native-model-integrity-v1")) 1 0))
    (defn nmfd-integrity-ready? (r)
        (if (eq (nmfd-integrity? r) 1)
            (if (and (eq (nth r 1) 1) (eq (nth r 2) 42))
                (if (and (eq (nth r 3) 55) (eq (nth r 4) 15))
                    (if (and (eq (nth r 5) 11111) (eq (nth r 6) 1))
                        (if (and (eq (nth r 7) 1) (eq (nth r 8) 1)) 1 0)
                        0)
                    0)
                0)
            0))

    ; host = tag power thermal toolchain destination free-gb.  Each bit is a
    ; measured fact; this row does not infer them from process names.
    (defn nmfd-host (power thermal toolchain destination free-gb)
        (list "native-model-host-readiness-v1" power thermal toolchain
              destination free-gb))
    (defn nmfd-host? (r)
        (if (and (eq (len r) 6)
                 (str_eq (nth r 0) "native-model-host-readiness-v1")) 1 0))
    (defn nmfd-host-valid? (r)
        (if (eq (nmfd-host? r) 1)
            (if (and (eq (nmcp-bit? (nth r 1)) 1)
                     (and (eq (nmcp-bit? (nth r 2)) 1)
                          (and (eq (nmcp-bit? (nth r 3)) 1)
                               (eq (nmcp-bit? (nth r 4)) 1))))
                (if (ge (nth r 5) 0) 1 0) 0)
            0))
    (defn nmfd-host-power (r) (nth r 1))
    (defn nmfd-host-thermal (r) (nth r 2))
    (defn nmfd-host-toolchain (r) (nth r 3))
    (defn nmfd-host-destination (r) (nth r 4))
    (defn nmfd-host-free-gb (r) (nth r 5))

    (defn nmfd-policy-rows (rows)
        (if (eq (len rows) 0) (list)
            (cons (nmfv-policy-row (head rows))
                  (nmfd-policy-rows (tail rows)))))
    (defn nmfd-evals-clean? (rows)
        (if (eq (len rows) 0) 1
            (if (eq (nmfv-clean? (head rows)) 1)
                (nmfd-evals-clean? (tail rows)) 0)))

    ; plan = tag day weekday lane scheduled decision integrity host seal eval
    ;        canary promote new-verified job
    (defn nmfd-plan
        (day weekday integrity host seal anchor candidate-file authorization
         build-attestation candidate-today incumbent-today challenger-series
         incumbent-series new-verified)
        (do
            (let job (nmcp-job-for-day (nmcp-weekly-schedule) weekday))
            (let integrity-ready (nmfd-integrity-ready? integrity))
            (let host-valid (nmfd-host-valid? host))
            (let host-ready
                (if (eq host-valid 1)
                    (nmcp-job-common-ready? job integrity-ready
                        (nmfd-host-power host) (nmfd-host-thermal host)
                        (nmfd-host-toolchain host) (nmfd-host-destination host)
                        (nmfd-host-free-gb host)) 0))
            (let seal-ready (nmfs-seal-valid? seal))
            (let promotion-seal-ready
                (nmfs-promotion-ready? seal anchor candidate-file authorization
                                       build-attestation))
            ; Paired diagnostics may admit another bounded training attempt
            ; before owner authorization exists.  Authorization is circular if
            ; required to create the challenger it is meant to review.
            (let paired-eval-ready
                (if (and (eq (nmfv-clean? candidate-today) 1)
                         (and (eq (nmfv-clean? incumbent-today) 1)
                              (eq (nmfv-paired? candidate-today incumbent-today) 1))) 1 0))
            (let authority-eval-ready
                (nmfv-authority-input? candidate-today incumbent-today
                    promotion-seal-ready (nmfs-git-row-valid? authorization)))
            (let training-ready
                (if (eq host-valid 1)
                    (nmcp-training-ready? job new-verified paired-eval-ready
                        seal-ready seal-ready integrity-ready
                        (nmfd-host-power host) (nmfd-host-thermal host)
                        (nmfd-host-toolchain host) (nmfd-host-destination host)
                        (nmfd-host-free-gb host)) 0))
            (let canary
                (if (and (eq paired-eval-ready 1)
                         (and (eq seal-ready 1)
                         (and (eq (nmfd-evals-clean? challenger-series) 1)
                              (eq (nmfd-evals-clean? incumbent-series) 1))))
                    (nmcp-canary? (nmfd-policy-rows challenger-series)
                                  (nmfd-policy-rows incumbent-series)
                                  32 10000 60000) 0))
            (let promote
                (if (and (eq authority-eval-ready 1) (eq promotion-seal-ready 1))
                    (nmcp-promote? (nmfd-policy-rows challenger-series)
                                   (nmfd-policy-rows incumbent-series)
                                   day 32 10000 60000) 0))
            (let decision
                (if (eq integrity-ready 0) "blocked-integrity"
                    (if (str_eq (nmcp-job-promotion job) "strict-promotion")
                        (if (eq promote 1) "promote-authority"
                            "hold-authority")
                        (if (or (str_eq (nmcp-job-promotion job) "shadow-only")
                                (str_eq (nmcp-job-promotion job) "component-proof"))
                            (if (eq training-ready 1) "execute-bounded-job"
                                "blocked-evidence-or-resource")
                            (if (eq host-ready 1) "measure-only"
                                "blocked-resource")))))
            (list "native-model-daily-plan-v1" day weekday
                  (nmcp-job-lane job) (nmcp-job-action job) decision
                  integrity-ready host-ready seal-ready paired-eval-ready canary
                  promote new-verified job)))
    (defn nmfd-plan? (r)
        (if (and (eq (len r) 14)
                 (str_eq (nth r 0) "native-model-daily-plan-v1")) 1 0))
    (defn nmfd-plan-day (r) (nth r 1))
    (defn nmfd-plan-weekday (r) (nth r 2))
    (defn nmfd-plan-lane (r) (nth r 3))
    (defn nmfd-plan-action (r) (nth r 4))
    (defn nmfd-plan-decision (r) (nth r 5))
    (defn nmfd-plan-job (r) (nth r 13))

    ; An actual training closure.  The result is evidence only when duration,
    ; cycles, and sample use stay inside the Form schedule and the resulting
    ; content identity differs from the input artifact.
    (defn nmfd-training-result
        (day lane action started ended samples cycles artifact-before
         artifact-after receipt success)
        (list "native-model-training-result-v1" day lane action started ended
              samples cycles artifact-before artifact-after receipt success))
    (defn nmfd-training-result? (r)
        (if (and (eq (len r) 12)
                 (str_eq (nth r 0) "native-model-training-result-v1")) 1 0))
    (defn nmfd-training-result-valid-for? (r job)
        (if (and (eq (nmfd-training-result? r) 1)
                 (eq (nmcp-job-valid? job) 1))
            (if (and (gt (nth r 1) 0)
                     (and (str_eq (nth r 2) (nmcp-job-lane job))
                          (str_eq (nth r 3) (nmcp-job-action job))))
                (if (and (gt (nth r 4) 0) (ge (nth r 5) (nth r 4)))
                    (if (and (ge (nth r 6) 0)
                             (and (gt (nth r 7) 0)
                                  (le (nth r 7) (nmcp-job-max-cycles job))))
                        (if (and
                                (le (sub (nth r 5) (nth r 4))
                                    (mul (nmcp-job-max-minutes job) 60000))
                                (and (nmcp-sha256? (nth r 8))
                                     (and (nmcp-sha256? (nth r 9))
                                          (nmcp-sha256? (nth r 10)))))
                            (if (eq (nmcp-bit? (nth r 11)) 1)
                                (if (eq (nth r 11) 1)
                                    (if (and (eq (str_eq (nth r 8) (nth r 9)) 0)
                                             (ge (nth r 6) (nmcp-job-min-new job))) 1 0)
                                    1)
                                0)
                            0)
                        0)
                    0)
                0)
            0))
    (defn nmfd-training-closes-plan? (plan result)
        (if (and (eq (nmfd-plan? plan) 1)
                 (str_eq (nmfd-plan-decision plan) "execute-bounded-job"))
            (if (and (eq (nmfd-training-result-valid-for?
                            result (nmfd-plan-job plan)) 1)
                     (eq (nth result 11) 1))
                (if (eq (nth result 1) (nmfd-plan-day plan)) 1 0)
                0)
            0))

    ; Served integration proves that the local process is actually serving the
    ; trained artifact, not merely that a directory exists on disk.
    (defn nmfd-integration
        (model class trained-artifact served-artifact registered inference
         event-digest evaluation-clean)
        (list "native-model-integration-result-v1" model class trained-artifact
              served-artifact registered inference event-digest evaluation-clean))
    (defn nmfd-integration-valid? (r)
        (if (and (eq (len r) 9)
                 (str_eq (nth r 0) "native-model-integration-result-v1"))
            (if (and (gt (str_len (nth r 1)) 0)
                     (eq (nmll-class? (nth r 2)) 1))
                (if (and (nmcp-sha256? (nth r 3))
                         (and (str_eq (nth r 3) (nth r 4))
                              (nmcp-sha256? (nth r 7))))
                    (if (and (eq (nth r 5) 1)
                             (and (eq (nth r 6) 1) (eq (nth r 8) 1))) 1 0)
                    0)
                0)
            0))

    (defn nmfd-final-class-count (rows class)
        (if (eq (len rows) 0) 0
            (add
                (if (and (eq (nmll-accepted-final? (head rows)) 1)
                         (str_eq (nmll-occ-class (head rows)) class)) 1 0)
                (nmfd-final-class-count (tail rows) class))))
    (defn nmfd-teacher-count (rows class)
        (if (eq (len rows) 0) 0
            (add
                (if (and (eq (nmll-occurrence-valid? (head rows)) 1)
                         (and (eq (nmll-occ-success (head rows)) 1)
                              (and (str_eq (nmll-occ-purpose (head rows)) "training")
                                   (str_eq (nmll-occ-class (head rows)) class)))) 1 0)
                (nmfd-teacher-count (tail rows) class))))
    (defn nmfd-eval-pass-count (rows)
        (if (eq (len rows) 0) 0
            (add (nmfv-clean? (head rows)) (nmfd-eval-pass-count (tail rows)))))
    (defn nmfd-occurrence-message (rows)
        (if (eq (len rows) 0) ""
            (str_concat
                (nmfe-field
                    (nmfe-fields
                        (list (int_to_str (nmll-occ-day (head rows)))
                              (int_to_str (nmll-occ-tick (head rows)))
                              (nmll-occ-class (head rows))
                              (nmll-occ-model (head rows))
                              (nmll-occ-purpose (head rows))
                              (int_to_str (nmll-occ-success (head rows)))
                              (nmll-occ-artifact (head rows))
                              (nmll-occ-input (head rows))
                              (nmll-occ-output (head rows))
                              (int_to_str (nmll-occ-latency-ms (head rows))))))
                (nmfd-occurrence-message (tail rows)))))
    (defn nmfd-snapshot-message
        (day clean registry-count fresh-count form finetuned native local-oracle
         remote local-teacher remote-teacher eval-pass eval-total train-samples
         heldout-samples occurrence-message)
        (nmfe-fields
            (list "native-model-daily-snapshot-v1" (int_to_str day)
                  (int_to_str clean) (int_to_str registry-count)
                  (int_to_str fresh-count) (int_to_str form)
                  (int_to_str finetuned) (int_to_str native)
                  (int_to_str local-oracle) (int_to_str remote)
                  (int_to_str local-teacher) (int_to_str remote-teacher)
                  (int_to_str eval-pass) (int_to_str eval-total)
                  (int_to_str train-samples) (int_to_str heldout-samples)
                  occurrence-message)))

    ; Produces the existing nmcp snapshot shape so all prior trend/promotion
    ; tooling remains one ledger rather than a parallel reporting universe.
    (defn nmfd-snapshot
        (day integrity registry occurrences evaluations train-samples heldout-samples)
        (do
            (let clean
                (if (and (eq (nmfd-integrity-ready? integrity) 1)
                         (and (eq (nmcp-models-valid? registry) 1)
                              (and (eq (nmcp-unique? registry) 1)
                                   (eq (nmll-occurrences-valid? occurrences) 1)))) 1 0))
            (let registry-count (len registry))
            (let fresh-count (nmcp-fresh-count registry day))
            (let form (nmfd-final-class-count occurrences "form-native"))
            (let finetuned (nmfd-final-class-count occurrences "local-finetuned"))
            (let native (nmfd-final-class-count occurrences "local-native"))
            (let local-oracle (nmfd-final-class-count occurrences "local-oracle"))
            (let remote (nmfd-final-class-count occurrences "remote-oracle"))
            (let local-teacher (nmfd-teacher-count occurrences "local-oracle"))
            (let remote-teacher (nmfd-teacher-count occurrences "remote-oracle"))
            (let eval-pass (nmfd-eval-pass-count evaluations))
            (let occurrence-message (nmfd-occurrence-message occurrences))
            (let digest
                (nmfe-sha256
                    (nmfd-snapshot-message day clean registry-count fresh-count
                        form finetuned native local-oracle remote local-teacher
                        remote-teacher eval-pass (len evaluations) train-samples
                        heldout-samples occurrence-message)))
            (nmcp-snapshot day clean registry-count fresh-count form finetuned
                native local-oracle remote local-teacher remote-teacher eval-pass
                (len evaluations) train-samples heldout-samples digest)))

    ; progress = tag owned-delta on-device-delta remote-delta finetuned-calls
    ;            eval-pass-delta.  Deltas are integers in parts-per-million or
    ; counts and therefore remain exact across days.
    (defn nmfd-progress (today yesterday)
        (list "native-model-daily-progress-v1"
              (nmcp-owned-delta-ppm today yesterday)
              (sub (nmcp-on-device-share-ppm today)
                   (nmcp-on-device-share-ppm yesterday))
              (sub (nmcp-remote-share-ppm today)
                   (nmcp-remote-share-ppm yesterday))
              (sub (nmcp-day-finetuned today) (nmcp-day-finetuned yesterday))
              (sub (nmcp-day-eval-pass-ppm today)
                   (nmcp-day-eval-pass-ppm yesterday))))

    ; Executable accounting of the replacement seam.  "form" means decision
    ; and encoding live in the named cell; "host-observation" is a fact the
    ; OS/local process must supply. No host language owns model-control meaning.
    (defn nmfd-replacement-map ()
        (list
            (list "event-validate-encode-append-tally" "form"
                  "native-model-event-form.fk + native-model-ledger-form.fk")
            (list "event-clock" "host-observation" "epoch-ms")
            (list "eval-normalize-score-hash-rotate-pair" "form"
                  "native-model-evidence.fk")
            (list "eval-model-call-timeout-identity" "host-observation"
                  "local-process")
            (list "eval-authority-gate" "form" "native-model-eval-form.fk")
            (list "seal-overlap-consent-license-anchor" "form"
                  "native-model-seal-form.fk")
            (list "seal-mode-symlink-git-stat" "host-observation" "host-filesystem")
            (list "daily-schedule-training-closure-progress" "form"
                  "native-model-daily-form.fk")
            (list "daily-power-thermal-space-compile-probe" "host-observation"
                  "host-kernel")))

    0)
