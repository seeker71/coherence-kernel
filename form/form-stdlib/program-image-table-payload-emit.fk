; program-image-table-payload-emit.fk -- render a validated program-image table as table payload.
;
; This layer renders the Layer 8h program-image envelope's embedded table
; payload as a verified numeric text artifact through form-fs. It does not
; claim binary artifact loading, runtime selection, native calls, or C-seed
; growth.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/form-fs.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/program-image-fkb.fk

(do
    (defn pite-version () "program-image-table-payload-emit-v1")

    (defn pite-feature (name status) (list "program-image-table-payload-emit-feature" name status))
    (defn pite-feature-name (f) (nth f 1))
    (defn pite-feature-status (f) (nth f 2))
    (defn program-image-table-payload-emit-manifest ()
        (list
            (pite-feature "valid-envelope-to-table-payload" 1)
            (pite-feature "executor-order-nf-fns-nr-nodes-ns-strings" 1)
            (pite-feature "single-space-between-integers" 1)
            (pite-feature "one-trailing-newline" 1)
            (pite-feature "exact-golden-text" 1)
            (pite-feature "negative-integer-rendering" 1)
            (pite-feature "string-byte-row-rendering" 1)
            (pite-feature "invalid-envelope-empty-text" 1)
            (pite-feature "numeric-stream-integers-required" 1)
            (pite-feature "invalid-write-nondestructive" 1)
            (pite-feature "write-text-only" 1)
            (pite-feature "write-return-observed" 1)
            (pite-feature "no-binary-artifact-io" 1)
            (pite-feature "no-program-image-load" 1)
            (pite-feature "no-native-call" 1)
            (pite-feature "no-selector-install" 1)
            (pite-feature "no-c-seed-growth" 1)
            (pite-feature "runtime-consumes-table-payload-or-live-binary-io" 1)))
    (defn program-image-table-payload-emit-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (pite-feature-name (head fs)) name)
                     (eq (pite-feature-status (head fs)) 1))
                1
                (program-image-table-payload-emit-manifest-has? name (tail fs)))))

    (defn pite-int? (x) (str_eq (value_kind x) "int"))
    (defn pite-int-list? (xs)
        (if (nil? xs)
            1
            (if (pite-int? (head xs))
                (pite-int-list? (tail xs))
                0)))

    (defn pite-int-list-text-loop (xs)
        (if (nil? xs)
            "\n"
            (if (nil? (tail xs))
                (str_concat (int_to_str (head xs)) "\n")
                (str_concat (int_to_str (head xs))
                            (str_concat " " (pite-int-list-text-loop (tail xs)))))))

    (defn pite-table-payload (table)
        (if (pif-table-valid? table)
            (do
                (let stream (pif-table-numeric-stream table))
                (if (pite-int-list? stream)
                    (pite-int-list-text-loop stream)
                    ""))
            ""))

    (defn pite-table-payload-from-envelope (envelope)
        (if (pif-envelope-valid? envelope)
            (pite-table-payload (pif-envelope-table envelope))
            ""))

    (defn pite-write-table-payload (path envelope)
        (do
            (let text (pite-table-payload-from-envelope envelope))
            (if (eq (str_len text) 0)
                0
                (do
                    (let wrote (fs-write-text path text))
                    (if (and (eq wrote (str_len text))
                             (str_eq (fs-read-text path) text))
                        1
                        0)))))
)
