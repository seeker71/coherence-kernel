; runtime-program-image-fkb-traced-capability-bound.fk -- trace-backed 9g/9h2 join.
;
; Layer 9h4 is the terminal supplied-evidence join for the current
; program-image route. It proves that the exposed capability-bound attempt is
; trace-backed: the structured 9h3 trace path and the 9g/9h2 readiness path
; must independently reach the same nested 9h1 bridge before any top-level
; attempt is exposed.
;
; This is not a program-image walker or loader. It does not open artifacts,
; hash bytes, run an image, call native code, install a selector, or grow the C
; seed. After this layer, another supplied-evidence wrapper without new
; runtime evidence should be rejected.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/runtime-artifact-executor-capability.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/runtime-program-image-fkb-attempt.fk form-stdlib/runtime-program-image-fkb-capability-bound.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk

(do
    (defn rpiftc-version () "runtime-program-image-fkb-traced-capability-bound-v1")

    (defn rpiftc-feature (name status) (list "runtime-program-image-fkb-traced-capability-bound-feature" name status))
    (defn rpiftc-feature-name (f) (nth f 1))
    (defn rpiftc-feature-status (f) (nth f 2))
    (defn runtime-program-image-fkb-traced-capability-bound-manifest ()
        (list
            (rpiftc-feature "traced-capability-bound-join-not-loader" 1)
            (rpiftc-feature "terminal-supplied-evidence-join" 1)
            (rpiftc-feature "wraps-9h3-and-9h2-without-mutating-them" 1)
            (rpiftc-feature "trace-first-before-capability-join" 1)
            (rpiftc-feature "no-independent-supplied-run-input" 1)
            (rpiftc-feature "invalid-trace-produces-no-capability-join" 1)
            (rpiftc-feature "capability-join-uses-trace-derived-run" 1)
            (rpiftc-feature "nested-9h1-bridges-must-agree" 1)
            (rpiftc-feature "top-attempt-only-after-trace-and-capability-bound" 1)
            (rpiftc-feature "non-ready-readiness-preserved-without-top-attempt" 1)
            (rpiftc-feature "hard-soft-and-unknown-statuses-preserved" 1)
            (rpiftc-feature "trace-evidence-attempt-is-not-capability-bound-attempt" 1)
            (rpiftc-feature "no-direct-attempt-construction" 1)
            (rpiftc-feature "no-artifact-open" 1)
            (rpiftc-feature "no-byte-hashing" 1)
            (rpiftc-feature "no-program-image-load" 1)
            (rpiftc-feature "no-native-call" 1)
            (rpiftc-feature "no-selector-install" 1)
            (rpiftc-feature "no-c-seed-growth" 1)))
    (defn runtime-program-image-fkb-traced-capability-bound-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rpiftc-feature-name (head fs)) name)
                     (eq (rpiftc-feature-status (head fs)) 1))
                1
                (runtime-program-image-fkb-traced-capability-bound-manifest-has? name (tail fs)))))

    (defn rpiftc-status-bound () "traced-capability-bound")
    (defn rpiftc-status-unavailable () (rpifc-status-unavailable))
    (defn rpiftc-status-investigate () (rpifc-status-investigate))
    (defn rpiftc-status-refused () (rpifc-status-refused))

    (defn rpiftc-reason-bound () "traced-capability-bound")
    (defn rpiftc-reason-trace-not-ready () "trace-not-ready")
    (defn rpiftc-reason-malformed-trace-bridge () "malformed-trace-bridge")
    (defn rpiftc-reason-malformed-capability-join () "malformed-capability-join")
    (defn rpiftc-reason-run-mismatch () "trace-run-capability-run-mismatch")
    (defn rpiftc-reason-bridge-mismatch () "nested-9h1-bridge-mismatch")
    (defn rpiftc-reason-attempt-mismatch () "nested-attempt-mismatch")
    (defn rpiftc-reason-manifest ()
        (list
            (rpiftc-reason-bound)
            (rpiftc-reason-trace-not-ready)
            (rpiftc-reason-malformed-trace-bridge)
            (rpiftc-reason-malformed-capability-join)
            (rpiftc-reason-run-mismatch)
            (rpiftc-reason-bridge-mismatch)
            (rpiftc-reason-attempt-mismatch)
            (raec-reason-no-capability-supplied)
            (raec-reason-capability-unavailable)
            (raec-reason-capability-stale)
            (raec-reason-evidence-inadequate)
            (raec-reason-forbidden-authority)
            (rpifc-reason-readiness-ready-fields-forged)
            (rpifc-reason-nested-capability-evidence-mismatch)
            (rpifc-reason-recomputed-readiness-mismatch)
            (rpifc-reason-malformed-readiness)))

    (defn rpiftc-no-capability-join () (list "runtime-program-image-fkb-traced-capability-bound-no-capability-join"))
    (defn rpiftc-no-capability-join? (j)
        (if (eq (len j) 1)
            (str_eq (nth j 0) "runtime-program-image-fkb-traced-capability-bound-no-capability-join")
            0))
    (defn rpiftc-no-attempt () (rpifc-no-attempt))
    (defn rpiftc-no-attempt? (a) (rpifc-no-attempt? a))

    ; join = ("runtime-program-image-fkb-traced-capability-bound-join"
    ;         envelope readiness admission trace trace-bridge capability-join
    ;         attempt status reason)
    (defn rpiftc-join-row (envelope readiness admission trace trace-bridge capability-join attempt status reason)
        (list "runtime-program-image-fkb-traced-capability-bound-join"
              envelope readiness admission trace trace-bridge capability-join
              attempt status reason))
    (defn rpiftc-join? (j)
        (if (eq (len j) 10)
            (str_eq (nth j 0) "runtime-program-image-fkb-traced-capability-bound-join")
            0))
    (defn rpiftc-join-envelope (j) (nth j 1))
    (defn rpiftc-join-readiness (j) (nth j 2))
    (defn rpiftc-join-admission (j) (nth j 3))
    (defn rpiftc-join-trace (j) (nth j 4))
    (defn rpiftc-join-trace-bridge (j) (nth j 5))
    (defn rpiftc-join-capability-join (j) (nth j 6))
    (defn rpiftc-join-attempt (j) (nth j 7))
    (defn rpiftc-join-status (j) (nth j 8))
    (defn rpiftc-join-reason (j) (nth j 9))

    (defn rpiftc-investigate (envelope readiness admission trace trace-bridge capability-join reason)
        (rpiftc-join-row envelope readiness admission trace trace-bridge capability-join
                          (rpiftc-no-attempt) (rpiftc-status-investigate) reason))
    (defn rpiftc-refused (envelope readiness admission trace trace-bridge capability-join reason)
        (rpiftc-join-row envelope readiness admission trace trace-bridge capability-join
                          (rpiftc-no-attempt) (rpiftc-status-refused) reason))
    (defn rpiftc-terminal-trace (envelope readiness admission trace trace-bridge)
        (if (rpiwt-bridge? trace-bridge)
            (rpiftc-join-row envelope readiness admission trace trace-bridge
                              (rpiftc-no-capability-join)
                              (rpiftc-no-attempt)
                              (if (str_eq (rpiwt-bridge-status trace-bridge) (rpiwt-status-refused))
                                  (rpiftc-status-refused)
                                  (rpiftc-status-investigate))
                              (rpiftc-reason-trace-not-ready))
            (rpiftc-refused envelope readiness admission trace trace-bridge
                            (rpiftc-no-capability-join)
                            (rpiftc-reason-malformed-trace-bridge))))
    (defn rpiftc-terminal-capability (envelope readiness admission trace trace-bridge capability-join)
        (rpiftc-join-row envelope readiness admission trace trace-bridge capability-join
                          (rpiftc-no-attempt)
                          (rpifc-join-status capability-join)
                          (rpifc-join-reason capability-join)))
    (defn rpiftc-bound (envelope readiness admission trace trace-bridge capability-join)
        (rpiftc-join-row envelope readiness admission trace trace-bridge capability-join
                          (rpifc-join-attempt capability-join)
                          (rpiftc-status-bound)
                          (rpiftc-reason-bound)))

    (defn rpiftc-run-agrees? (a b)
        (and (str_eq (rpifa-run-path a) (rpifa-run-path b))
        (and (eq (rpifa-run-first-value a) (rpifa-run-first-value b))
        (and (eq (rpifa-run-output-count a) (rpifa-run-output-count b))
        (and (eq (rpifa-run-exit-code a) (rpifa-run-exit-code b))
        (and (str_eq (rpifa-run-status a) (rpifa-run-status b))
             (str_eq (rpifa-run-detail a) (rpifa-run-detail b))))))))
    (defn rpiftc-bridge-status-reason-agrees? (a b)
        (and (rpifa-bridge? a)
        (and (rpifa-bridge? b)
        (and (str_eq (rpifa-bridge-status a) (rpifa-bridge-status b))
             (str_eq (rpifa-bridge-reason a) (rpifa-bridge-reason b))))))
    (defn rpiftc-attempt-agrees? (a b)
        (and (str_eq (raar-attempt-action a) (raar-attempt-action b))
        (and (eq (raar-attempt-route a) (raar-attempt-route b))
        (and (str_eq (raar-attempt-artifact-kind a) (raar-attempt-artifact-kind b))
        (and (str_eq (raar-attempt-artifact-path a) (raar-attempt-artifact-path b))
        (and (str_eq (raar-attempt-source-hash a) (raar-attempt-source-hash b))
        (and (str_eq (raar-attempt-content-hash a) (raar-attempt-content-hash b))
        (and (str_eq (raar-attempt-status a) (raar-attempt-status b))
        (and (str_eq (raar-attempt-detail a) (raar-attempt-detail b))
             (eq (raar-attempt-code a) (raar-attempt-code b)))))))))))
    (defn rpiftc-attempts-agree? (trace-bridge capability-join)
        (rpiftc-attempt-agrees? (rpifa-bridge-attempt (rpiwt-bridge-9h1 trace-bridge))
                                (rpifc-join-attempt capability-join)))
    (defn rpiftc-nested-bridge-attempts-agree? (trace-bridge capability-join)
        (rpiftc-attempt-agrees? (rpifa-bridge-attempt (rpiwt-bridge-9h1 trace-bridge))
                                (rpifa-bridge-attempt (rpifc-join-bridge capability-join))))
    (defn rpiftc-bridge-run-agrees? (trace-bridge capability-join)
        (rpiftc-run-agrees? (rpiwt-bridge-run trace-bridge)
                            (rpifc-join-run capability-join)))
    (defn rpiftc-nested-bridge-run-agrees? (trace-bridge capability-join)
        (rpiftc-run-agrees? (rpifa-bridge-run (rpiwt-bridge-9h1 trace-bridge))
                            (rpifa-bridge-run (rpifc-join-bridge capability-join))))
    (defn rpiftc-nested-bridge-agrees? (trace-bridge capability-join)
        (do
            (let trace-9h1 (rpiwt-bridge-9h1 trace-bridge))
            (let cap-9h1 (rpifc-join-bridge capability-join))
            (and (rpiftc-bridge-status-reason-agrees? trace-9h1 cap-9h1)
            (and (rpiftc-bridge-run-agrees? trace-bridge capability-join)
            (and (rpiftc-nested-bridge-run-agrees? trace-bridge capability-join)
            (and (rpiftc-nested-bridge-attempts-agree? trace-bridge capability-join)
                 (rpiftc-attempts-agree? trace-bridge capability-join)))))))
    (defn rpiftc-mismatch-reason (trace-bridge capability-join)
        (if (not (rpiftc-bridge-run-agrees? trace-bridge capability-join))
            (rpiftc-reason-run-mismatch)
            (if (not (rpiftc-nested-bridge-run-agrees? trace-bridge capability-join))
                (rpiftc-reason-run-mismatch)
                (if (not (rpiftc-bridge-status-reason-agrees? (rpiwt-bridge-9h1 trace-bridge)
                                                              (rpifc-join-bridge capability-join)))
                    (rpiftc-reason-bridge-mismatch)
                    (rpiftc-reason-attempt-mismatch)))))

    (defn rpiftc-join-from-bridges (envelope readiness admission trace trace-bridge capability-join)
        (if (not (rpiwt-bridge? trace-bridge))
            (rpiftc-refused envelope readiness admission trace trace-bridge capability-join
                            (rpiftc-reason-malformed-trace-bridge))
            (if (not (str_eq (rpiwt-bridge-status trace-bridge) (rpiwt-status-trace-ready)))
                (rpiftc-terminal-trace envelope readiness admission trace trace-bridge)
                (if (not (rpifc-join? capability-join))
                    (rpiftc-refused envelope readiness admission trace trace-bridge capability-join
                                    (rpiftc-reason-malformed-capability-join))
                    (if (not (str_eq (rpifc-join-status capability-join) (rpifc-status-bound)))
                        (rpiftc-terminal-capability envelope readiness admission trace trace-bridge capability-join)
                        (if (rpiftc-nested-bridge-agrees? trace-bridge capability-join)
                            (rpiftc-bound envelope readiness admission trace trace-bridge capability-join)
                            (rpiftc-investigate envelope readiness admission trace trace-bridge capability-join
                                                (rpiftc-mismatch-reason trace-bridge capability-join))))))))

    (defn rpiftc-join-from-trace (envelope readiness admission trace)
        (do
            (let trace-bridge (rpiwt-bridge-from-trace envelope admission trace))
            (if (not (str_eq (rpiwt-bridge-status trace-bridge) (rpiwt-status-trace-ready)))
                (rpiftc-terminal-trace envelope readiness admission trace trace-bridge)
                (rpiftc-join-from-bridges
                    envelope
                    readiness
                    admission
                    trace
                    trace-bridge
                    (rpifc-join-from-run envelope readiness admission (rpiwt-bridge-run trace-bridge))))))
)
