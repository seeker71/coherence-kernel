; channel-protocol-choice-floor.fk - shared floor for channel/interface/protocol choice.
;
; This recipe does not replace channel-interface, channel-flow, channel-loopback,
; runtime-grammar, or choice-receipt. It names their current shared floor and
; the north star that asks BML/Form to expose the same shape as first-class
; grammar expressions with inspectable receipts.
;
; preludes: form-stdlib/core.fk

(do
    (defn cpcf-record (kind value)
        (list kind value))
    (defn cpcf-record-kind (record) (nth record 0))
    (defn cpcf-record-value (record) (nth record 1))

    (defn cpcf-source (kind path proof status)
        (list kind path proof status))
    (defn cpcf-source-kind (source) (nth source 0))
    (defn cpcf-source-path (source) (nth source 1))
    (defn cpcf-source-proof (source) (nth source 2))
    (defn cpcf-source-status (source) (nth source 3))

    (defn cpcf-floor ()
        "channel/interface/protocol/dynamic-choice floor: a cell can offer an interface, a flow can be received by the receiver offer, channel-loopback protocol rows can name codec/capability/status/refusal witness, BML route source objects can be parsed, BML protocol/capability source rows parse, witness compatibility, and lower into route-choice runtime across four-way, BML choiceReceipt routing metadata crosses four-way, kernel-http route choice crosses four-way, BML metadata can select a real kernel route candidate, recipe registry choices can carry receipts into route-choice realization, typed choiceReceipt rows lower into choice receipts that feed learned ordering across four-way, and BranchOutcome values carry ok/reject/condition with learnable rejected evidence.")

    (defn cpcf-north-star ()
        "north star: channel, interface, protocol, capability, route choice, receipt, and learning become first-class Form/BML grammar expressions that lower to native recipes, execute across supported lanes, and always return inspectable receipts before any route, protocol, model, or JIT choice is trusted.")

    (defn cpcf-next-step ()
        "next step: carry BML protocol/capability runtime lowering from route choice into model and protocol choices, carry the recipe-choice runtime wrapper through host CLI callers, and persist returned route-choice signatures where recipe choices execute.")

    (defn cpcf-related-sources ()
        (list
            (cpcf-source "form-recipe" "form/form-stdlib/channel-interface.fk" "form/form-stdlib/tests/channel-interface-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/channel-flow.fk" "form/form-stdlib/tests/channel-flow-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/channel-loopback.fk" "form/form-stdlib/tests/channel-loopback-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/tool-channel.fk" "form/form-stdlib/tests/tool-channel-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/runtime-grammar.fk" "form/form-stdlib/tests/runtime-dynamic-capability-registry-band.fk" "proven")
            (cpcf-source "form-recipe" "form/form-stdlib/kernel-http.fk" "form/form-stdlib/tests/kernel-http-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/choice-receipt.fk" "form/form-stdlib/tests/choice-receipt-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/choice-receipt-learning.fk" "form/form-stdlib/tests/choice-receipt-learning-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/branch-choice-order.fk" "form/form-stdlib/tests/branch-choice-order-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/choice-outcome-learning.fk" "form/form-stdlib/tests/choice-outcome-learning-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/bml-route-choice-runtime.fk" "form/form-stdlib/tests/bml-route-choice-runtime-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/bml-route-choice-runtime.fk" "form/form-stdlib/tests/bml-protocol-runtime-choice-band.fk" "proven-four-way")
            (cpcf-source "form-recipe" "form/form-stdlib/recipe-choice-runtime.fk" "form/form-stdlib/tests/recipe-choice-runtime-band.fk" "proven-four-way")
            (cpcf-source "bml-source" "form/form-stdlib/bml-source.fk" "form/form-stdlib/tests/bml-route-source-object-band.fk" "proven-four-way")
            (cpcf-source "bml-source" "form/form-stdlib/bml-source.fk" "form/form-stdlib/tests/bml-protocol-capability-row-band.fk" "proven-four-way")
            (cpcf-source "bml-source" "form/form-stdlib/bml-source.fk" "form/form-stdlib/tests/bml-choice-routing-metadata-band.fk" "proven-four-way")
            (cpcf-source "bml-source" "form/form-stdlib/bml-source.fk" "form/form-stdlib/tests/bml-choice-receipt-row-band.fk" "proven-four-way")
            (cpcf-source "bml-grammar" "form/form-stdlib/bml.fk" "form/form-stdlib/tests/bml-generics-band.fk" "proven")
            (cpcf-source "bml-model" "form/form-stdlib/grammars/bml.fk" "form/form-stdlib/tests/bml-full-class-model-proof.fk" "proven")
            (cpcf-source "spec" "specs/canonical-route-registry-and-runtime-mapping.md" "api/tests/test_runtime_api.py" "related")
            (cpcf-source "spec" "specs/bml-typed-recipes.md" "form/form-stdlib/tests/bml-generics-band.fk" "related")
            (cpcf-source "spec" "specs/agent-question-sse-channel.md" "api/tests/test_agent_question_sse.py" "related")))

    (defn cpcf-proven-source-count (sources)
        (if (nil? sources)
            0
            (add
                (if (or (str_eq (cpcf-source-status (head sources)) "proven")
                        (str_eq (cpcf-source-status (head sources)) "proven-four-way")) 1 0)
                (cpcf-proven-source-count (tail sources)))))

    (defn cpcf-source-find-kind (sources kind)
        (if (nil? sources)
            (empty)
            (if (str_eq (cpcf-source-kind (head sources)) kind)
                (head sources)
                (cpcf-source-find-kind (tail sources) kind))))

    (defn cpcf-source-find-path (sources path)
        (if (nil? sources)
            (empty)
            (if (str_eq (cpcf-source-path (head sources)) path)
                (head sources)
                (cpcf-source-find-path (tail sources) path))))

    (defn cpcf-source-find-proof (sources proof)
        (if (nil? sources)
            (empty)
            (if (str_eq (cpcf-source-proof (head sources)) proof)
                (head sources)
                (cpcf-source-find-proof (tail sources) proof))))

    (defn cpcf-validation-round (round agent focus result)
        (list "validation-round" round agent focus result))
    (defn cpcf-validation-round-round (round) (nth round 1))
    (defn cpcf-validation-round-agent (round) (nth round 2))
    (defn cpcf-validation-round-focus (round) (nth round 3))
    (defn cpcf-validation-round-result (round) (nth round 4))

    (defn cpcf-validation-rounds ()
        (list
            (cpcf-validation-round 1 "claude-cli" "proof floor and overclaim review" "soften unified protocol-plan and route/call wording; name three-kernel and fourth-arm gaps")
            (cpcf-validation-round 2 "gemini-cli" "component citations and next-step scope" "add branch-choice-order and tool-channel citations; narrow next step to one vertical BML slice")
            (cpcf-validation-round 3 "grok-cli" "recorded artifact and runtime gap review" "cite canonical .fk/.form/band records; name receipts-before-trust and production routing as not-yet-proven")))

    (defn cpcf-current-gaps ()
        (list
            "BML protocol/capability rows lower through route-choice runtime; model and protocol runtime choice lowering remains open"
            "runtime dynamic capability registry remains host-IO-shaped and is outside the fourth-arm manifest"
            "receipts-before-trust is an invariant, not yet carried through every runtime choice"
            "host CLI recipe-library callers are not yet using the recipe-choice runtime wrapper"))

    (defn cpcf-floor-recipe ()
        (list
            (cpcf-record "floor" (cpcf-floor))
            (cpcf-record "north-star" (cpcf-north-star))
            (cpcf-record "next-step" (cpcf-next-step))
            (cpcf-record "related-sources" (cpcf-related-sources))
            (cpcf-record "validation-rounds" (cpcf-validation-rounds))
            (cpcf-record "current-gaps" (cpcf-current-gaps))))

    0)
