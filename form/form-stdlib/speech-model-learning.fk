; speech-model-learning.fk — native floor for racing speech learner candidates.
;
; This is not a full neural TTS/STT stack. It is the smallest Form-native
; training/evaluation surface for speech lanes:
;   - STT floor: audio feature rows learn a label through exemplar matching.
;   - TTS floor: text feature rows retrieve a learned audio/text exemplar label.
;   - Mesh floor: paired TTS/STT candidates only pass when they agree on the
;     same expected label.
; Candidate scores are ordinary branch-choice-order candidates, so learning can
; route toward the observed winner without hiding failed candidates.
; Metadata is carried as native data: confidence, conviction, mood, expression,
; and active-learning need can lower trust/alignment, choose a feedback kernel,
; and travel with the output channel.
; Oracle receipts are native training data too: a local LLM can add labels,
; confidence, meaning vectors, and impact vectors so human teaching becomes
; optional instead of required.
; Speech teacher receipts are physical local training data: macOS say can
; render text to inspectable PCM, whisper-cli can transcribe it locally, and the
; receipt can train Form rows while native STT/TTS candidates remain teacher-led
; until heldout receipts prove otherwise.
; Corpus receipts group several real teacher rows into one training window so
; the next native candidate races against a heldout corpus, not a single phrase.
;
; Proven by: form-stdlib/tests/speech-model-learning-band.fk
;            form-stdlib/tests/speech-teacher-receipt-band.fk
;            form-stdlib/tests/speech-teacher-corpus-band.fk

(do
    (defn sml-sample (label feature lane)
        (list label feature lane))
    (defn sml-label (sample) (nth sample 0))
    (defn sml-feature (sample) (nth sample 1))
    (defn sml-lane (sample) (nth sample 2))
    (defn sml-exemplar (sample)
        (list (sml-label sample) (sml-feature sample)))

    (defn sml-learn-sample (sample model)
        (cons (sml-exemplar sample) model))
    (defn sml-learn-stream (samples model)
        (if (eq (len samples) 0) model
            (sml-learn-stream
                (tail samples)
                (sml-learn-sample (head samples) model))))
    (defn sml-device (samples)
        (sml-learn-stream samples (empty)))

    (defn sml-test-row (feature label)
        (list feature label))
    (defn sml-test-feature (row) (nth row 0))
    (defn sml-test-label (row) (nth row 1))

    (defn sml-exact-pair (model row)
        (list
            (ns-label (sml-test-feature row) model)
            (sml-test-label row)))
    (defn sml-exact-eval (model tests)
        (if (eq (len tests) 0) (empty)
            (cons
                (sml-exact-pair model (head tests))
                (sml-exact-eval model (tail tests)))))
    (defn sml-exact-correct (model tests)
        (ce-correct (sml-exact-eval model tests)))

    (defn sml-abs (n)
        (if (lt n 0) (sub 0 n) n))
    (defn sml-l1 (a b)
        (if (eq (len a) 0) 0
            (if (eq (len b) 0) 0
                (add
                    (sml-abs (sub (head a) (head b)))
                    (sml-l1 (tail a) (tail b))))))
    (defn sml-l1-best-loop (query prototypes best best-dist)
        (if (eq (len prototypes) 0) best
            (if (eq (len best) 0)
                (sml-l1-best-loop
                    query
                    (tail prototypes)
                    (head prototypes)
                    (sml-l1 query (ns-vec-of (head prototypes))))
                (if (lt (sml-l1 query (ns-vec-of (head prototypes))) best-dist)
                    (sml-l1-best-loop
                        query
                        (tail prototypes)
                        (head prototypes)
                        (sml-l1 query (ns-vec-of (head prototypes))))
                    (sml-l1-best-loop query (tail prototypes) best best-dist)))))
    (defn sml-l1-nearest (query prototypes)
        (sml-l1-best-loop query prototypes (empty) 0))
    (defn sml-l1-label (query prototypes)
        (ns-label-of (sml-l1-nearest query prototypes)))
    (defn sml-l1-pair (model row)
        (list
            (sml-l1-label (sml-test-feature row) model)
            (sml-test-label row)))
    (defn sml-l1-eval (model tests)
        (if (eq (len tests) 0) (empty)
            (cons
                (sml-l1-pair model (head tests))
                (sml-l1-eval model (tail tests)))))
    (defn sml-l1-correct (model tests)
        (ce-correct (sml-l1-eval model tests)))

    (defn sml-wrong (correct total)
        (sub total correct))
    (defn sml-score-card (path correct total alignment trust)
        (bco-candidate
            path
            correct
            (sml-wrong correct total)
            0
            0
            alignment
            trust))
    (defn sml-best-candidate-path (score-cards)
        (bco-choose-best-path score-cards))

    (defn sml-min (a b)
        (if (gt a b) b a))
    (defn sml-meta (confidence conviction mood expression active-need)
        (list confidence conviction mood expression active-need))
    (defn sml-meta-confidence (meta) (nth meta 0))
    (defn sml-meta-conviction (meta) (nth meta 1))
    (defn sml-meta-mood (meta) (nth meta 2))
    (defn sml-meta-expression (meta) (nth meta 3))
    (defn sml-meta-active-need (meta) (nth meta 4))
    (defn sml-meta-ready? (meta)
        (if (and
                (ge (sml-meta-confidence meta) 70)
                (and
                    (ge (sml-meta-conviction meta) 70)
                    (lt (sml-meta-active-need meta) 70)))
            1
            0))
    (defn sml-active-learning-needed? (meta)
        (if (eq (sml-meta-ready? meta) 1) 0 1))
    (defn sml-meta-score-card (path correct total alignment trust meta)
        (bco-candidate
            path
            correct
            (sml-wrong correct total)
            0
            0
            (sml-min alignment (sml-meta-conviction meta))
            (sml-min trust (sml-meta-confidence meta))))
    (defn sml-output-kernel (native-kernel meta)
        (if (str_eq (sml-meta-expression meta) "ask-human")
            "kernel:human-feedback"
            (if (eq (sml-active-learning-needed? meta) 1)
                "kernel:local-llm-oracle"
                native-kernel)))
    (defn sml-channel-output (label candidate-path channel native-kernel meta)
        (list
            label
            candidate-path
            channel
            (sml-output-kernel native-kernel meta)
            meta))
    (defn sml-output-label (output) (nth output 0))
    (defn sml-output-candidate (output) (nth output 1))
    (defn sml-output-channel (output) (nth output 2))
    (defn sml-output-kernel-path (output) (nth output 3))
    (defn sml-output-meta (output) (nth output 4))

    (defn sml-meta-channel
        (agreement margin novelty noise energy cadence arousal valence expression-force social-risk route-pressure word-frequency meaning-alignment impact-intensity)
        (list
            agreement
            margin
            novelty
            noise
            energy
            cadence
            arousal
            valence
            expression-force
            social-risk
            route-pressure
            word-frequency
            meaning-alignment
            impact-intensity))
    (defn sml-mc-agreement (channel) (nth channel 0))
    (defn sml-mc-margin (channel) (nth channel 1))
    (defn sml-mc-novelty (channel) (nth channel 2))
    (defn sml-mc-noise (channel) (nth channel 3))
    (defn sml-mc-energy (channel) (nth channel 4))
    (defn sml-mc-cadence (channel) (nth channel 5))
    (defn sml-mc-arousal (channel) (nth channel 6))
    (defn sml-mc-valence (channel) (nth channel 7))
    (defn sml-mc-expression-force (channel) (nth channel 8))
    (defn sml-mc-social-risk (channel) (nth channel 9))
    (defn sml-mc-route-pressure (channel) (nth channel 10))
    (defn sml-mc-word-frequency (channel) (nth channel 11))
    (defn sml-mc-meaning-alignment (channel) (nth channel 12))
    (defn sml-mc-impact-intensity (channel) (nth channel 13))
    (defn sml-invert100 (n) (sub 100 n))
    (defn sml-lift-confidence (channel)
        (sml-min
            (sml-mc-agreement channel)
            (sml-min
                (sml-mc-margin channel)
                (sml-min
                    (sml-invert100 (sml-mc-noise channel))
                    (sml-mc-meaning-alignment channel)))))
    (defn sml-lift-conviction (channel)
        (sml-min
            (sml-min
                (sml-mc-margin channel)
                (sml-invert100 (sml-mc-novelty channel)))
            (sml-mc-impact-intensity channel)))
    (defn sml-lift-mood (channel)
        (if (ge (sml-mc-arousal channel) 70)
            (if (ge (sml-mc-valence channel) 50) "bright" "tense")
            (if (lt (sml-mc-valence channel) 40) "low" "steady")))
    (defn sml-lift-expression (channel)
        (if (ge (sml-mc-social-risk channel) 70)
            "ask-human"
            (if (or
                    (ge (sml-mc-expression-force channel) 70)
                    (ge (sml-mc-impact-intensity channel) 80))
                "emphatic"
                (if (lt (sml-mc-energy channel) 35) "soft" "plain"))))
    (defn sml-lift-active-need (channel)
        (if (or
                (lt (sml-lift-confidence channel) 70)
                (or
                    (lt (sml-lift-conviction channel) 70)
                    (or
                        (ge (sml-mc-novelty channel) 70)
                        (or
                            (ge (sml-mc-route-pressure channel) 70)
                            (lt (sml-mc-word-frequency channel) 30)))))
            90
            20))
    (defn sml-meta-from-channel (channel)
        (sml-meta
            (sml-lift-confidence channel)
            (sml-lift-conviction channel)
            (sml-lift-mood channel)
            (sml-lift-expression channel)
            (sml-lift-active-need channel)))

    (defn sml-oracle-model-card (name role locality rank footprint)
        (list name role locality rank footprint))
    (defn sml-om-name (card) (nth card 0))
    (defn sml-om-role (card) (nth card 1))
    (defn sml-om-locality (card) (nth card 2))
    (defn sml-om-rank (card) (nth card 3))
    (defn sml-om-footprint (card) (nth card 4))
    (defn sml-oracle-model-catalog ()
        (list
            (sml-oracle-model-card
                "llama3.3:70b"
                "receipt-generator"
                "local"
                10
                "42GB")
            (sml-oracle-model-card
                "deepseek-r1:32b"
                "reasoning-receipt-generator"
                "local"
                20
                "19GB")
            (sml-oracle-model-card
                "dolphin-mixtral:8x22b-v2.9-q6_K"
                "large-local-committee"
                "local"
                30
                "115GB")
            (sml-oracle-model-card
                "llama3.2:3b"
                "fast-receipt-generator"
                "local"
                40
                "2GB")))
    (defn sml-best-local-oracle-loop (cards best best-rank)
        (if (eq (len cards) 0) best
            (if (eq (len best) 0)
                (sml-best-local-oracle-loop
                    (tail cards)
                    (head cards)
                    (sml-om-rank (head cards)))
                (if (lt (sml-om-rank (head cards)) best-rank)
                    (sml-best-local-oracle-loop
                        (tail cards)
                        (head cards)
                        (sml-om-rank (head cards)))
                    (sml-best-local-oracle-loop
                        (tail cards)
                        best
                        best-rank)))))
    (defn sml-best-local-oracle-card ()
        (sml-best-local-oracle-loop
            (sml-oracle-model-catalog)
            (empty)
            0))
    (defn sml-best-local-oracle-model ()
        (sml-om-name (sml-best-local-oracle-card)))

    (defn sml-oracle-receipt (provider model label confidence meaning-vector impact-vector)
        (list provider model label confidence meaning-vector impact-vector))
    (defn sml-oracle-provider (receipt) (nth receipt 0))
    (defn sml-oracle-model (receipt) (nth receipt 1))
    (defn sml-oracle-label (receipt) (nth receipt 2))
    (defn sml-oracle-confidence (receipt) (nth receipt 3))
    (defn sml-oracle-meaning (receipt) (nth receipt 4))
    (defn sml-oracle-impact (receipt) (nth receipt 5))
    (defn sml-oracle-valid? (receipt)
        (if (and
                (str_eq (sml-oracle-provider receipt) "local-llm")
                (and
                    (ge (sml-oracle-confidence receipt) 70)
                    (and
                        (gt (len (sml-oracle-meaning receipt)) 0)
                        (gt (len (sml-oracle-impact receipt)) 0))))
            1
            0))
    (defn sml-oracle-sample (receipt lane)
        (sml-sample
            (sml-oracle-label receipt)
            (sml-oracle-meaning receipt)
            lane))
    (defn sml-oracle-receipt-from-best (label confidence meaning-vector impact-vector)
        (sml-oracle-receipt
            "local-llm"
            (sml-best-local-oracle-model)
            label
            confidence
            meaning-vector
            impact-vector))
    (defn sml-oracle-feedback-kernel (meta)
        (if (str_eq (sml-meta-expression meta) "ask-human")
            "kernel:human-feedback"
            "kernel:local-llm-oracle"))

    (defn sml-speech-teacher-floor ()
        (list
            "local TTS audio must be generated and retained as a hashed training slice"
            "local STT transcript must overlap expected text before becoming a teacher row"
            "native STT/TTS candidates remain teacher-led until heldout receipts pass"))
    (defn sml-speech-teacher-north-star ()
        (list
            "Whisper, macOS say, and open TTS/STT models teach native recipes through receipts"
            "native speech candidates retire teachers only after accuracy, trust, sovereignty, vitality, and lower-cost floors"
            "speech metadata becomes numeric channel data for confidence, conviction, expression, and active learning"))
    (defn sml-speech-teacher-receipt
        (status tts-provider stt-provider stt-model expected transcript overlap wav-bytes samples duration-ms rms-ppm rough-hz audio-sha transcript-sha raw-audio-retained floor north-star)
        (list status tts-provider stt-provider stt-model expected transcript overlap wav-bytes samples duration-ms rms-ppm rough-hz audio-sha transcript-sha raw-audio-retained floor north-star))
    (defn sml-str-nonempty? (value) (gt (str_len value) 0))
    (defn sml-str-sha? (value) (gt (str_len value) 16))
    (defn sml-str-status (receipt) (nth receipt 0))
    (defn sml-str-tts-provider (receipt) (nth receipt 1))
    (defn sml-str-stt-provider (receipt) (nth receipt 2))
    (defn sml-str-stt-model (receipt) (nth receipt 3))
    (defn sml-str-expected (receipt) (nth receipt 4))
    (defn sml-str-transcript (receipt) (nth receipt 5))
    (defn sml-str-overlap (receipt) (nth receipt 6))
    (defn sml-str-wav-bytes (receipt) (nth receipt 7))
    (defn sml-str-samples (receipt) (nth receipt 8))
    (defn sml-str-duration-ms (receipt) (nth receipt 9))
    (defn sml-str-rms-ppm (receipt) (nth receipt 10))
    (defn sml-str-rough-hz (receipt) (nth receipt 11))
    (defn sml-str-audio-sha (receipt) (nth receipt 12))
    (defn sml-str-transcript-sha (receipt) (nth receipt 13))
    (defn sml-str-raw-audio-retained (receipt) (nth receipt 14))
    (defn sml-str-floor (receipt) (nth receipt 15))
    (defn sml-str-north-star (receipt) (nth receipt 16))
    (defn sml-speech-teacher-receipt-valid? (receipt)
        (if (and
                (str_eq (sml-str-status receipt) "pass")
                (and
                    (str_eq (sml-str-tts-provider receipt) "macos-say")
                    (and
                        (str_eq (sml-str-stt-provider receipt) "whisper-cli")
                        (and
                            (sml-str-nonempty? (sml-str-stt-model receipt))
                            (and
                                (sml-str-nonempty? (sml-str-expected receipt))
                                (and
                                    (sml-str-nonempty? (sml-str-transcript receipt))
                                    (and
                                        (ge (sml-str-overlap receipt) 80)
                                        (and
                                            (gt (sml-str-wav-bytes receipt) 0)
                                            (and
                                                (gt (sml-str-samples receipt) 0)
                                                (and
                                                    (gt (sml-str-duration-ms receipt) 0)
                                                    (and
                                                        (gt (sml-str-rms-ppm receipt) 0)
                                                        (and
                                                            (gt (sml-str-rough-hz receipt) 0)
                                                            (and
                                                                (sml-str-sha? (sml-str-audio-sha receipt))
                                                                (and
                                                                    (sml-str-sha? (sml-str-transcript-sha receipt))
                                                                    (and
                                                                        (eq (sml-str-raw-audio-retained receipt) 1)
                                                                        (and
                                                                            (gt (len (sml-str-floor receipt)) 0)
                                                                            (gt (len (sml-str-north-star receipt)) 0)))))))))))))))))
            1
            0))
    (defn sml-speech-teacher-feature (receipt)
        (list
            (sml-str-overlap receipt)
            (sml-str-rms-ppm receipt)
            (sml-str-duration-ms receipt)
            (sml-str-rough-hz receipt)
            (sml-str-wav-bytes receipt)
            (sml-str-samples receipt)))
    (defn sml-speech-teacher-sample (label receipt)
        (sml-sample
            label
            (sml-speech-teacher-feature receipt)
            "speech:teacher-receipt"))
    (defn sml-speech-teacher-score-card (path receipt trust)
        (sml-score-card
            path
            (if (eq (sml-speech-teacher-receipt-valid? receipt) 1) 1 0)
            1
            95
            trust))
    (defn sml-speech-teacher-corpus-floor ()
        (list
            "at least three real local speech teacher receipts form one corpus window"
            "every receipt must pass the single-receipt floor before training authority increases"
            "aggregate hashes, totals, and retained audio keep the corpus replayable"))
    (defn sml-speech-teacher-corpus-north-star ()
        (list
            "speech corpora are native channel training windows, not shell transcript dumps"
            "heldout corpus wins retire teacher authority only when native STT/TTS candidates clear accuracy, trust, sovereignty, vitality, and lower-cost floors"
            "macOS, Android, and mesh organs emit the same corpus row through native OS audio APIs"))
    (defn sml-receipts-valid-count (receipts)
        (if (eq (len receipts) 0) 0
            (add
                (sml-speech-teacher-receipt-valid? (head receipts))
                (sml-receipts-valid-count (tail receipts)))))
    (defn sml-receipts-min-overlap-loop (receipts current)
        (if (eq (len receipts) 0) current
            (sml-receipts-min-overlap-loop
                (tail receipts)
                (sml-min current (sml-str-overlap (head receipts))))))
    (defn sml-receipts-min-overlap (receipts)
        (if (eq (len receipts) 0) 0
            (sml-receipts-min-overlap-loop
                (tail receipts)
                (sml-str-overlap (head receipts)))))
    (defn sml-receipts-sum-wav (receipts)
        (if (eq (len receipts) 0) 0
            (add (sml-str-wav-bytes (head receipts)) (sml-receipts-sum-wav (tail receipts)))))
    (defn sml-receipts-sum-samples (receipts)
        (if (eq (len receipts) 0) 0
            (add (sml-str-samples (head receipts)) (sml-receipts-sum-samples (tail receipts)))))
    (defn sml-receipts-sum-duration (receipts)
        (if (eq (len receipts) 0) 0
            (add (sml-str-duration-ms (head receipts)) (sml-receipts-sum-duration (tail receipts)))))
    (defn sml-speech-teacher-corpus
        (status receipts count pass-count min-overlap total-wav total-samples total-duration corpus-sha raw-audio-retained floor north-star)
        (list status receipts count pass-count min-overlap total-wav total-samples total-duration corpus-sha raw-audio-retained floor north-star))
    (defn sml-stc-status (corpus) (nth corpus 0))
    (defn sml-stc-receipts (corpus) (nth corpus 1))
    (defn sml-stc-count (corpus) (nth corpus 2))
    (defn sml-stc-pass-count (corpus) (nth corpus 3))
    (defn sml-stc-min-overlap (corpus) (nth corpus 4))
    (defn sml-stc-total-wav (corpus) (nth corpus 5))
    (defn sml-stc-total-samples (corpus) (nth corpus 6))
    (defn sml-stc-total-duration (corpus) (nth corpus 7))
    (defn sml-stc-corpus-sha (corpus) (nth corpus 8))
    (defn sml-stc-raw-audio-retained (corpus) (nth corpus 9))
    (defn sml-stc-floor (corpus) (nth corpus 10))
    (defn sml-stc-north-star (corpus) (nth corpus 11))
    (defn sml-speech-teacher-corpus-from-receipts (receipts corpus-sha)
        (do
            (let count (len receipts))
            (let pass-count (sml-receipts-valid-count receipts))
            (let min-overlap (sml-receipts-min-overlap receipts))
            (sml-speech-teacher-corpus
                (if (and
                        (ge count 3)
                        (and
                            (eq pass-count count)
                            (sml-str-sha? corpus-sha)))
                    "pass"
                    "blocked")
                receipts
                count
                pass-count
                min-overlap
                (sml-receipts-sum-wav receipts)
                (sml-receipts-sum-samples receipts)
                (sml-receipts-sum-duration receipts)
                corpus-sha
                1
                (sml-speech-teacher-corpus-floor)
                (sml-speech-teacher-corpus-north-star))))
    (defn sml-speech-teacher-corpus-valid? (corpus)
        (if (and
                (str_eq (sml-stc-status corpus) "pass")
                (and
                    (ge (sml-stc-count corpus) 3)
                    (and
                        (eq (sml-stc-pass-count corpus) (sml-stc-count corpus))
                        (and
                            (ge (sml-stc-min-overlap corpus) 80)
                            (and
                                (gt (sml-stc-total-wav corpus) 0)
                                (and
                                    (gt (sml-stc-total-samples corpus) 0)
                                    (and
                                        (gt (sml-stc-total-duration corpus) 0)
                                        (and
                                            (sml-str-sha? (sml-stc-corpus-sha corpus))
                                            (and
                                                (eq (sml-stc-raw-audio-retained corpus) 1)
                                                (and
                                                    (gt (len (sml-stc-floor corpus)) 0)
                                                    (gt (len (sml-stc-north-star corpus)) 0)))))))))))
            1
            0))
    (defn sml-speech-teacher-sample-from-receipt (receipt)
        (sml-speech-teacher-sample (sml-str-expected receipt) receipt))
    (defn sml-speech-teacher-corpus-samples (receipts)
        (if (eq (len receipts) 0) (empty)
            (cons
                (sml-speech-teacher-sample-from-receipt (head receipts))
                (sml-speech-teacher-corpus-samples (tail receipts)))))
    (defn sml-speech-teacher-receipts-to-tests (receipts)
        (if (eq (len receipts) 0) (empty)
            (cons
                (sml-test-row
                    (sml-speech-teacher-feature (head receipts))
                    (sml-str-expected (head receipts)))
                (sml-speech-teacher-receipts-to-tests (tail receipts)))))
    (defn sml-speech-teacher-corpus-score-card (path corpus trust)
        (sml-score-card
            path
            (if (eq (sml-speech-teacher-corpus-valid? corpus) 1)
                (sml-stc-pass-count corpus)
                0)
            (sml-stc-count corpus)
            95
            trust))
    (defn sml-speech-teacher-corpus-retire-teacher? (corpus native-correct native-total native-trust native-sovereignty)
        (if (and
                (eq (sml-speech-teacher-corpus-valid? corpus) 1)
                (and
                    (ge native-total (sml-stc-count corpus))
                    (and
                        (eq native-correct native-total)
                        (and
                            (ge native-trust 90)
                            (ge native-sovereignty 90)))))
            1
            0))

    (defn sml-live-speech-loop-floor ()
        (list
            "known text is played through a real speaker into the room"
            "Mac microphone audio is retained, hashed, and transcribed by local STT"
            "Android microphone telemetry co-witnesses the same speech window"))
    (defn sml-live-speech-loop-north-star ()
        (list
            "speech training windows carry multi-device mic paths as native data"
            "TTS/STT teachers retire only after native candidates win heldout dual-mic receipts"
            "Android raw PCM, Mac raw PCM, and future mesh mics lower into the same receipt family"))
    (defn sml-live-speech-loop-receipt
        (teacher-receipt speaker-channel mac-mic-channel android-mic-samples android-min-rms android-max-rms android-avg-rms android-present floor north-star)
        (list teacher-receipt speaker-channel mac-mic-channel android-mic-samples android-min-rms android-max-rms android-avg-rms android-present floor north-star))
    (defn sml-lsl-teacher (receipt) (nth receipt 0))
    (defn sml-lsl-speaker (receipt) (nth receipt 1))
    (defn sml-lsl-mac-mic (receipt) (nth receipt 2))
    (defn sml-lsl-android-samples (receipt) (nth receipt 3))
    (defn sml-lsl-android-min-rms (receipt) (nth receipt 4))
    (defn sml-lsl-android-max-rms (receipt) (nth receipt 5))
    (defn sml-lsl-android-avg-rms (receipt) (nth receipt 6))
    (defn sml-lsl-android-present (receipt) (nth receipt 7))
    (defn sml-lsl-floor (receipt) (nth receipt 8))
    (defn sml-lsl-north-star (receipt) (nth receipt 9))
    (defn sml-live-speech-loop-valid? (receipt)
        (if (and
                (eq (sml-speech-teacher-receipt-valid? (sml-lsl-teacher receipt)) 1)
                (and
                    (str_eq (sml-lsl-speaker receipt) "mac-speaker")
                    (and
                        (str_eq (sml-lsl-mac-mic receipt) "mac-microphone")
                        (and
                            (ge (sml-lsl-android-samples receipt) 3)
                            (and
                                (ge (sml-lsl-android-present receipt) 1)
                                (and
                                    (gt (sml-lsl-android-avg-rms receipt) 0)
                                    (and
                                        (ge (sml-lsl-android-max-rms receipt) (sml-lsl-android-min-rms receipt))
                                        (and
                                            (gt (len (sml-lsl-floor receipt)) 0)
                                            (gt (len (sml-lsl-north-star receipt)) 0)))))))))
            1
            0))
    (defn sml-live-speech-loop-feature (receipt)
        (list
            (sml-str-overlap (sml-lsl-teacher receipt))
            (sml-str-rms-ppm (sml-lsl-teacher receipt))
            (sml-lsl-android-avg-rms receipt)
            (sml-lsl-android-max-rms receipt)
            (sml-lsl-android-samples receipt)
            (sml-str-duration-ms (sml-lsl-teacher receipt))))
    (defn sml-live-speech-loop-sample (label receipt)
        (sml-sample
            label
            (sml-live-speech-loop-feature receipt)
            "speech:live-dual-mic"))

    (defn sml-mesh-row (tts-label stt-label expected)
        (list tts-label stt-label expected))
    (defn sml-mesh-tts (row) (nth row 0))
    (defn sml-mesh-stt (row) (nth row 1))
    (defn sml-mesh-expected (row) (nth row 2))
    (defn sml-mesh-hit? (row)
        (if (and
                (str_eq (sml-mesh-tts row) (sml-mesh-expected row))
                (str_eq (sml-mesh-stt row) (sml-mesh-expected row)))
            1
            0))
    (defn sml-mesh-correct (rows)
        (if (eq (len rows) 0) 0
            (add
                (sml-mesh-hit? (head rows))
                (sml-mesh-correct (tail rows)))))

    0)
