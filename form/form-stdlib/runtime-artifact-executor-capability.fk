; runtime-artifact-executor-capability.fk -- Layer 9g executor capability contract.
;
; This layer names which supplied host capability would be required to attempt a
; Layer 9e runtime artifact envelope. It is not the executor and it does not
; produce 9f attempts or 9c observations. A `ready` row means only that a
; supplied capability row matches the envelope's action/route/artifact kind and
; carries current allowed evidence. It does not mean the artifact loaded, walked,
; called, compiled, or succeeded.
;
; Real load/walk/call belongs to future 9h, which may consume `ready` rows from
; this layer and then supply 9f attempt rows. This layer stays pure over supplied
; rows: it does not read disk, hash bytes, reverify seals/proofs/callability,
; walk `.fkb`, call `.dylib`, run source, choose fallback, retry, decide
; admission, install a selector, or grow the C seed.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/runtime-artifact-plan.fk
;           form-stdlib/runtime-artifact-selector.fk
;           form-stdlib/runtime-artifact-outcome.fk
;           form-stdlib/runtime-artifact-retry.fk
;           form-stdlib/runtime-artifact-load-envelope.fk

(do
    (defn raec-feature (name status) (list "runtime-artifact-executor-capability-feature" name status))
    (defn raec-feature-name (f) (nth f 1))
    (defn raec-feature-status (f) (nth f 2))
    (defn runtime-artifact-executor-capability-manifest ()
        (list
            (raec-feature "executor-capability-not-execution" 1)
            (raec-feature "supplied-capability-rows-only" 1)
            (raec-feature "ready-is-not-execution-success" 1)
            (raec-feature "closed-action-route-kind-table" 1)
            (raec-feature "future-9h-consumes-ready" 1)
            (raec-feature "no-9f-attempt-or-rao-observation" 1)
            (raec-feature "unavailable-for-no-matching-capability" 1)
            (raec-feature "investigate-for-stale-or-inadequate-evidence" 1)
            (raec-feature "refused-for-malformed-or-forbidden-authority" 1)
            (raec-feature "current-floor-fkb-dylib-unavailable" 1)
            (raec-feature "no-disk-io" 1)
            (raec-feature "no-byte-hashing" 1)
            (raec-feature "no-seal-proof-callable-reverify" 1)
            (raec-feature "no-fkb-walk-or-dylib-call" 1)
            (raec-feature "no-admission-policy-or-selector-install" 1)
            (raec-feature "no-c-seed-growth" 1)))
    (defn runtime-artifact-executor-capability-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (raec-feature-name (head fs)) name)
                     (eq (raec-feature-status (head fs)) 1))
                1
                (runtime-artifact-executor-capability-manifest-has? name (tail fs)))))

    (defn raec-cap-native-dylib-caller () "native-dylib-caller")
    (defn raec-cap-program-image-walker () "program-image-walker")
    (defn raec-cap-source-compiler-front-door () "source-compiler-front-door")

    (defn raec-availability-available () "available")
    (defn raec-availability-unavailable () "unavailable")
    (defn raec-availability-stale () "stale")
    (defn raec-availability-unknown () "unknown")

    (defn raec-evidence-supplied-current () "supplied-current")
    (defn raec-evidence-supplied-stale () "supplied-stale")
    (defn raec-evidence-current-floor-unavailable () "current-floor-unavailable")
    (defn raec-evidence-inadequate () "inadequate")
    (defn raec-evidence-none () "none")

    (defn raec-authority-attempt-supplier () "attempt-supplier")
    (defn raec-authority-forbidden-execution () "forbidden-execution")
    (defn raec-authority-forbidden-admission () "forbidden-admission")

    (defn raec-freshness-current () "current")
    (defn raec-freshness-stale () "stale")
    (defn raec-freshness-unknown () "unknown")

    (defn raec-status-ready () "ready")
    (defn raec-status-unavailable () "unavailable")
    (defn raec-status-investigate () "investigate")
    (defn raec-status-refused () "refused")

    (defn raec-reason-ready () "capability-ready")
    (defn raec-reason-no-capability-supplied () "no-capability-supplied")
    (defn raec-reason-capability-name-mismatch () "capability-name-mismatch")
    (defn raec-reason-capability-action-mismatch () "capability-action-mismatch")
    (defn raec-reason-capability-route-mismatch () "capability-route-mismatch")
    (defn raec-reason-capability-kind-mismatch () "capability-kind-mismatch")
    (defn raec-reason-capability-unavailable () "capability-unavailable")
    (defn raec-reason-capability-stale () "capability-stale")
    (defn raec-reason-evidence-inadequate () "evidence-inadequate")
    (defn raec-reason-forbidden-authority () "forbidden-authority")
    (defn raec-reason-envelope-investigates () "envelope-investigates")
    (defn raec-reason-envelope-refused () "envelope-refused")
    (defn raec-reason-non-ready-envelope () "non-ready-envelope")
    (defn raec-reason-malformed-envelope () "malformed-envelope")
    (defn raec-reason-malformed-capability () "malformed-capability")
    (defn raec-reason-unsupported-envelope () "unsupported-envelope")

    (defn raec-no-capability () (list "runtime-artifact-executor-no-capability"))
    (defn raec-no-capability? (c)
        (if (eq (len c) 1)
            (str_eq (nth c 0) "runtime-artifact-executor-no-capability")
            0))

    ; capability = ("runtime-artifact-executor-capability" name action route
    ;               artifact-kind availability evidence-kind authority freshness detail)
    (defn raec-capability (name action route artifact-kind availability evidence-kind authority freshness detail)
        (list "runtime-artifact-executor-capability" name action route
              artifact-kind availability evidence-kind authority freshness detail))
    (defn raec-capability? (c)
        (if (eq (len c) 10)
            (str_eq (nth c 0) "runtime-artifact-executor-capability")
            0))
    (defn raec-capability-name (c) (nth c 1))
    (defn raec-capability-action (c) (nth c 2))
    (defn raec-capability-route (c) (nth c 3))
    (defn raec-capability-artifact-kind (c) (nth c 4))
    (defn raec-capability-availability (c) (nth c 5))
    (defn raec-capability-evidence-kind (c) (nth c 6))
    (defn raec-capability-authority (c) (nth c 7))
    (defn raec-capability-freshness (c) (nth c 8))
    (defn raec-capability-detail (c) (nth c 9))

    ; readiness = ("runtime-artifact-executor-readiness" envelope capability
    ;              action route artifact-kind required-capability status reason
    ;              evidence-kind authority freshness detail)
    (defn raec-readiness (envelope capability action route artifact-kind required-capability status reason evidence-kind authority freshness detail)
        (list "runtime-artifact-executor-readiness" envelope capability
              action route artifact-kind required-capability status reason
              evidence-kind authority freshness detail))
    (defn raec-readiness? (r)
        (if (eq (len r) 13)
            (str_eq (nth r 0) "runtime-artifact-executor-readiness")
            0))
    (defn raec-readiness-envelope (r) (nth r 1))
    (defn raec-readiness-capability (r) (nth r 2))
    (defn raec-readiness-action (r) (nth r 3))
    (defn raec-readiness-route (r) (nth r 4))
    (defn raec-readiness-artifact-kind (r) (nth r 5))
    (defn raec-readiness-required-capability (r) (nth r 6))
    (defn raec-readiness-status (r) (nth r 7))
    (defn raec-readiness-reason (r) (nth r 8))
    (defn raec-readiness-evidence-kind (r) (nth r 9))
    (defn raec-readiness-authority (r) (nth r 10))
    (defn raec-readiness-freshness (r) (nth r 11))
    (defn raec-readiness-detail (r) (nth r 12))

    (defn raec-required-capability-for (action route artifact-kind)
        (if (and (str_eq action (rap-act-run-native))
                 (and (eq route (sac-run-dylib))
                      (str_eq artifact-kind (sad-kind-native-dylib))))
            (raec-cap-native-dylib-caller)
            (if (and (str_eq action (rap-act-run-program-image))
                     (and (eq route (sac-run-fkb))
                          (str_eq artifact-kind (sad-kind-program-image-fkb))))
                (raec-cap-program-image-walker)
                (if (and (str_eq action (rap-act-compile-source))
                         (and (eq route (sac-run-source-compile))
                              (str_eq artifact-kind (rale-kind-source))))
                    (raec-cap-source-compiler-front-door)
                    ""))))
    (defn raec-supported-envelope? (envelope)
        (gt (str_len (raec-required-capability-for
                        (rale-envelope-action envelope)
                        (rale-envelope-route envelope)
                        (rale-envelope-artifact-kind envelope)))
            0))
    (defn raec-envelope-action (envelope)
        (if (rale-envelope? envelope) (rale-envelope-action envelope) (rap-act-none)))
    (defn raec-envelope-route (envelope)
        (if (rale-envelope? envelope) (rale-envelope-route envelope) (sad-route-invalid)))
    (defn raec-envelope-kind (envelope)
        (if (rale-envelope? envelope) (rale-envelope-artifact-kind envelope) (rale-kind-none)))
    (defn raec-envelope-required (envelope)
        (if (rale-envelope? envelope)
            (raec-required-capability-for
                (rale-envelope-action envelope)
                (rale-envelope-route envelope)
                (rale-envelope-artifact-kind envelope))
            ""))

    (defn raec-empty-readiness (envelope capability status reason)
        (raec-readiness envelope capability
                        (raec-envelope-action envelope)
                        (raec-envelope-route envelope)
                        (raec-envelope-kind envelope)
                        (raec-envelope-required envelope)
                        status reason
                        (raec-evidence-none)
                        (raec-authority-attempt-supplier)
                        (raec-freshness-unknown)
                        ""))
    (defn raec-readiness-from-capability (envelope capability status reason)
        (raec-readiness envelope capability
                        (rale-envelope-action envelope)
                        (rale-envelope-route envelope)
                        (rale-envelope-artifact-kind envelope)
                        (raec-envelope-required envelope)
                        status reason
                        (raec-capability-evidence-kind capability)
                        (raec-capability-authority capability)
                        (raec-capability-freshness capability)
                        (raec-capability-detail capability)))

    (defn raec-envelope-request-ready? (envelope)
        (if (rale-envelope? envelope)
            (str_eq (rale-envelope-status envelope) (rale-status-request-ready))
            0))
    (defn raec-terminal-envelope-readiness (envelope)
        (if (rale-envelope? envelope)
            (if (str_eq (rale-envelope-status envelope) (rale-status-investigate))
                (raec-empty-readiness envelope (raec-no-capability) (raec-status-investigate) (raec-reason-envelope-investigates))
                (if (str_eq (rale-envelope-status envelope) (rale-status-refused))
                    (raec-empty-readiness envelope (raec-no-capability) (raec-status-refused) (raec-reason-envelope-refused))
                    (raec-empty-readiness envelope (raec-no-capability) (raec-status-investigate) (raec-reason-non-ready-envelope))))
            (raec-empty-readiness envelope (raec-no-capability) (raec-status-refused) (raec-reason-malformed-envelope))))

    (defn raec-allowed-authority? (capability)
        (str_eq (raec-capability-authority capability) (raec-authority-attempt-supplier)))
    (defn raec-capability-current? (capability)
        (and (str_eq (raec-capability-availability capability) (raec-availability-available))
             (and (str_eq (raec-capability-evidence-kind capability) (raec-evidence-supplied-current))
                  (str_eq (raec-capability-freshness capability) (raec-freshness-current)))))
    (defn raec-capability-stale? (capability)
        (if (str_eq (raec-capability-availability capability) (raec-availability-stale))
            1
            (if (str_eq (raec-capability-evidence-kind capability) (raec-evidence-supplied-stale))
                1
                (if (str_eq (raec-capability-freshness capability) (raec-freshness-stale)) 1 0))))
    (defn raec-capability-unavailable? (capability)
        (str_eq (raec-capability-availability capability) (raec-availability-unavailable)))

    (defn raec-matched-capability-readiness (envelope capability)
        (if (eq (raec-allowed-authority? capability) 1)
            (if (eq (raec-capability-current? capability) 1)
                (raec-readiness-from-capability envelope capability (raec-status-ready) (raec-reason-ready))
                (if (eq (raec-capability-unavailable? capability) 1)
                    (raec-readiness-from-capability envelope capability (raec-status-unavailable) (raec-reason-capability-unavailable))
                    (if (eq (raec-capability-stale? capability) 1)
                        (raec-readiness-from-capability envelope capability (raec-status-investigate) (raec-reason-capability-stale))
                        (raec-readiness-from-capability envelope capability (raec-status-investigate) (raec-reason-evidence-inadequate)))))
            (raec-readiness-from-capability envelope capability (raec-status-refused) (raec-reason-forbidden-authority))))

    (defn raec-readiness-from-envelope-no-capability (envelope)
        (if (eq (raec-envelope-request-ready? envelope) 1)
            (if (eq (raec-supported-envelope? envelope) 1)
                (raec-empty-readiness envelope (raec-no-capability) (raec-status-unavailable) (raec-reason-no-capability-supplied))
                (raec-empty-readiness envelope (raec-no-capability) (raec-status-investigate) (raec-reason-unsupported-envelope)))
            (raec-terminal-envelope-readiness envelope)))
    (defn raec-readiness-from-envelope-capability (envelope capability)
        (if (eq (raec-envelope-request-ready? envelope) 1)
            (if (eq (raec-supported-envelope? envelope) 1)
                (if (eq (raec-capability? capability) 1)
                    (if (str_eq (raec-capability-name capability) (raec-envelope-required envelope))
                        (if (str_eq (raec-capability-action capability) (rale-envelope-action envelope))
                            (if (eq (raec-capability-route capability) (rale-envelope-route envelope))
                                (if (str_eq (raec-capability-artifact-kind capability) (rale-envelope-artifact-kind envelope))
                                    (raec-matched-capability-readiness envelope capability)
                                    (raec-readiness-from-capability envelope capability (raec-status-unavailable) (raec-reason-capability-kind-mismatch)))
                                (raec-readiness-from-capability envelope capability (raec-status-unavailable) (raec-reason-capability-route-mismatch)))
                            (raec-readiness-from-capability envelope capability (raec-status-unavailable) (raec-reason-capability-action-mismatch)))
                        (raec-readiness-from-capability envelope capability (raec-status-unavailable) (raec-reason-capability-name-mismatch)))
                    (if (eq (raec-no-capability? capability) 1)
                        (raec-empty-readiness envelope capability (raec-status-unavailable) (raec-reason-no-capability-supplied))
                        (raec-empty-readiness envelope capability (raec-status-refused) (raec-reason-malformed-capability))))
                (raec-empty-readiness envelope capability (raec-status-investigate) (raec-reason-unsupported-envelope)))
            (raec-terminal-envelope-readiness envelope)))

    (defn raec-current-floor-native-unavailable ()
        (raec-capability (raec-cap-native-dylib-caller)
                         (rap-act-run-native)
                         (sac-run-dylib)
                         (sad-kind-native-dylib)
                         (raec-availability-unavailable)
                         (raec-evidence-current-floor-unavailable)
                         (raec-authority-attempt-supplier)
                         (raec-freshness-current)
                         "2026-07-03-form-fs-read-bytes-canary-0"))
    (defn raec-current-floor-program-image-unavailable ()
        (raec-capability (raec-cap-program-image-walker)
                         (rap-act-run-program-image)
                         (sac-run-fkb)
                         (sad-kind-program-image-fkb)
                         (raec-availability-unavailable)
                         (raec-evidence-current-floor-unavailable)
                         (raec-authority-attempt-supplier)
                         (raec-freshness-current)
                         "2026-07-03-form-fs-read-bytes-canary-0"))
)
