; form-cli-inquiry-edge-ledger.fk — one persistent validated learned-edge slot.
;
; This is the smallest vertical replacement path for source-authored inquiry rows:
; `fciel-learn` validates an observed edge, persists structured state, and a later
; process reloads it through `fciel-augment`. The slot can be replaced by the next
; validated observation; static rows remain as the bootstrap while this grows.
; State schema: edge-v1\nSS,RR,TT\n (two decimal digits per field).
; witnessed: 2026-07-22 -> learned 08,01,05; 10->11 edges; reload changed 0 to node

(do
  (defn fciel-path () ".form-native-inquiry-edges.tsv")
  (defn fciel-two (n)
    (str_concat (byte_to_str (add 48 (div n 10)))
                (byte_to_str (add 48 (mod n 10)))))
  (defn fciel-number (text pos)
    (add (mul (sub (str_byte_at text pos) 48) 10)
         (sub (str_byte_at text (add pos 1)) 48)))
  (defn fciel-edge (s r t) (list s r t 3))
  (defn fciel-valid-fields? (s r t)
    (if (and (ge s 1) (le s 12))
      (if (eq r 1) (if (and (ge t 1) (le t 12)) 1 0) 0) 0))
  (defn fciel-valid-state? (text)
    (if (eq (str_len text) 17)
      (if (eq (str_byte_at text 0) 101)
        (fciel-valid-fields? (fciel-number text 8)
          (fciel-number text 11) (fciel-number text 14)) 0) 0))
  (defn fciel-load ()
    (do (let text (read_file (fciel-path)))
      (if (eq (fciel-valid-state? text) 1)
        (fciel-edge (fciel-number text 8) (fciel-number text 11)
          (fciel-number text 14))
        (nothing))))
  (defn fciel-augment (bootstrap)
    (do (let learned (fciel-load))
      (if (nothing? learned) bootstrap (cons learned bootstrap))))
  (defn fciel-learn (s r t)
    (if (eq (fciel-valid-fields? s r t) 0) (nothing)
      (do (let row (str_concat "edge-v1\n"
            (str_concat (fciel-two s) (str_concat ","
            (str_concat (fciel-two r) (str_concat ","
            (str_concat (fciel-two t) "\n")))))))
          (let wrote (write_file (fciel-path) row))
          (if (eq wrote (str_len row)) 1 0))))
  (defn fciel-reset () (write_file (fciel-path) ""))
)
