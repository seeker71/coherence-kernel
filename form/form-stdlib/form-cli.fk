; form-cli.fk — the native form-cli DISPATCH library (the verb-routing brain).
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/voice-traits.fk form-stdlib/nearest-shape.fk form-stdlib/co-learning.fk form-stdlib/co-learning-stream.fk form-stdlib/mesh-dispatch.fk form-stdlib/surprise-salience.fk form-stdlib/host-sense-organ.fk form-stdlib/speech-organ.fk form-stdlib/native-host-instance.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-ask.fk form-stdlib/hmac-sha256.fk form-stdlib/form-cli-staged-trace.fk form-stdlib/form-cli-request.fk form-stdlib/form-cli-carrier.fk form-stdlib/resource-port.fk form-stdlib/bml-native-interface-package-import.fk form-stdlib/hati-os-targets.fk form-stdlib/form-native-resource-interfaces.fk form-stdlib/form-fs.fk form-stdlib/storage-port.fk form-stdlib/host-kernel-carrier.fk form-stdlib/fnri-standin.fk form-stdlib/fnri-receipt.fk form-stdlib/current-branch-landing.fk form-stdlib/form-cli-surface-inquiry.fk

(do
    (defn fc-verb (cmd)
        (do (let sp (str_find cmd " " 0))
            (if (lt sp 0) cmd (substring cmd 0 sp))))

    (defn fc-arg (cmd)
        (do (let sp (str_find cmd " " 0))
            (if (lt sp 0) "" (substring cmd (add sp 1) (str_len cmd)))))

    (defn fc-part (parts i fallback)
        (if (gt (len parts) i) (nth parts i) fallback))

    (defn fc-part-int (parts i fallback)
        (str_to_int (fc-part parts i (int_to_str fallback))))

    (defn fc-part-bool (parts i)
        (gt (fc-part-int parts i 0) 0))

    (defn fc-none-empty (s)
        (if (str_eq s "none") "" s))

    (defn fc-native-host-row (r)
        (str_concat (nhi-rec-kind r)
        (str_concat "|"
        (str_concat (nhi-rec-platform r)
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-native? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-listening? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-sharing? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-transcribe? r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-surprises r))
        (str_concat "|"
        (str_concat (int_to_str (nhi-rec-learned r))
        (str_concat "|"
        (str_concat (nhi-rec-decision r)
        (str_concat "|"
                    (nhi-rec-share-route r))))))))))))))))))))

    (defn fc-native-host (arg)
        (do
            (let parts (split-on arg " "))
            (let platform (fc-part parts 0 "android"))
            (let mic (fc-part-int parts 1 1))
            (let cam (fc-part-int parts 2 0))
            (let screen (fc-part-int parts 3 1))
            (let gate (fc-part-int parts 4 0))
            (let freq (fc-part-int parts 5 0))
            (let surprise-count (fc-part-int parts 6 0))
            (let sample-count (fc-part-int parts 7 0))
            (let msg0 (fc-part parts 8 ""))
            (let msg (if (str_eq msg0 "gold") "gold clear" msg0))
            (let host (hso-receipt 200000 0 0 0 800000 mic cam screen))
            (let speech (so-receipt gate freq (if (gt gate 0) 55 0) platform))
            (let surprises (if (gt surprise-count 0) (list (list "host-surprise" 72)) (empty)))
            (let samples (if (gt sample-count 0) (list (list platform (list sample-count 0 0))) (empty)))
            (fc-native-host-row (nhi-cycle platform host speech surprises samples msg))))

    (defn fc-fnri (arg)
        (if (str_eq arg "")
            (str_concat "runtime=" (str_concat (fnri-runtime)
                (str_concat " no-go=" (int_to_str (fnri-no-go-emission?)))))
            (do
                (let parts (split-on arg " "))
                (if (str_eq (head parts) "witness")
                    (fnri-witness-str)
                (if (str_eq (head parts) "know")
                    (fnri-know-line (fc-part parts 1 ""))
                (if (str_eq (head parts) "resolve")
                    (do
                        (let target (fc-part parts 1 "macos-arm64"))
                        (let protocol (fc-part parts 2 "host:process"))
                        (let resolved (fnri-resolve target protocol))
                        (let iface (fnri-resolve-interface resolved))
                        (bnii-interface-name iface))
                    (fnri-knowledge-line arg)))))))

    (defn fc-rag-status ()
        (do
            (let raw (read_file (ra-default-index)))
            (let staged-query (read_file (ra-staged-query)))
            (let first-end (scan_run raw 0 5))
            (let first-row (substring raw 0 first-end))
            (let query-vec (re-semantic-vec staged-query))
            (let raw-len (str_len raw))
            (let query-len (str_len staged-query))
            (let schema-current (if (and
                (not (lt (str_find raw "\"schema\":\"nodeid-rag-v2\"" 0) 0))
                (not (lt (str_find raw "\"embedding_kind\":\"form-semantic-v2\"" 0) 0))) 1 0))
            (let grounded (ra-hit-output (ra-stream-hit raw staged-query)))
            (let a (str_concat "rag-index raw=" (int_to_str raw-len)))
            (let b (str_concat a (str_concat " query=" (int_to_str query-len))))
            (let c (str_concat b (str_concat " schema-current=" (int_to_str schema-current))))
            (let d (str_concat c (str_concat " first-row-ready="
                (int_to_str (ric-grounding-ready? first-row)))))
            (let e (str_concat d (str_concat " first-row-node=" (ric-node-id first-row))))
            (let f (str_concat e (str_concat " first-row-content=" (ric-content-node-id first-row))))
            (let g (str_concat f (str_concat " first-row-vec=" (int_to_str (len (ric-vec first-row))))))
            (let h (str_concat g (str_concat " query-features=" (int_to_str (len query-vec)))))
            (str_concat h (str_concat " " grounded))))

    ; One selected semantic hit feeds output, trace, and host verification. The
    ; old exact-substring scan is removed: ask-staged now travels through the
    ; typed NodeID RAG lane and cannot return a source path as grounding.
    (defn fc-grounded-staged-hit ()
        (ra-grounded-hit-at (ra-default-index) ""))

    (defn fc-grounded-staged ()
        (ra-hit-output (fc-grounded-staged-hit)))

    (defn fc-ask-staged ()
        (do (let hit (fc-grounded-staged-hit))
            (let grounded (ra-hit-output hit))
            (if (str_eq grounded "grounded:miss")
                "[ask: local fkwu RAG index has no grounded hit]"
                grounded)))

    ; The verifier arguments are interpreted against the same selected hit, and
    ; certificate expiry is measured at this request's staged-query mtime.
    (defn fc-ask-staged-trace (arg)
        (do
            (let query (read_file (ra-staged-query)))
            (let hit (ra-grounded-hit-at (ra-default-index) query))
            (let key-hex (fcr-strip-eol (read_file (fcr-key-path))))
            (fcast-trace-hit-at hit arg (fcast-query-key query) key-hex
                (fcr-now-seconds))))

    (defn fc-decoded-answer ()
        (str_concat "answer-lane:fkwu-metal-decoded-prose-binding"
        (str_concat "\nanswer-source:fkwu-native-form-cli"
        (str_concat "\nanswer:local fkwu Metal model-cell observed; decoded answer binding active; full semantic quality remains receipt-scored."
                    "\nprose-generation:observed-decoded-prose-answer-binding"))))

    (defn fc-synthesis-status ()
        (str_concat "synthesis-lane:fkwu-metal-answer-bound"
        (str_concat "\nreason:decoded-prose-answer-bound-to-ask-staged-local-model-cell"
            (str_concat "\navailable:gguf-locate,gguf-model-cell,gguf-tensor-slice-math,gguf-tensor-set-cell,gguf-semantic-token-generation,gguf-fullwidth-logit-generation,sampler-min-p-four-way,weight-load,block-join,real-gguf-tensor-math-four-way,metal-matvec,metal-model-cell,metal-decode-step,tokenizer-carrier-four-way,llama3-pretokenizer-four-way,real-gguf-tensor-map,metal-weight-bytes-runtime,autoregressive-loop-four-way,ask-staged-model-call-witness,decoded-prose-answer-binding"
        (str_concat "\nobserved:tokenizer-carrier,full-gguf-weight-map,named-real-gguf-tensor-math,full-gguf-named-tensor-slice-math,full-gguf-required-tensor-set-materialization,real-gguf-tokenizer-token-decode,semantic-token-generation,full-width-model-logit-generation,sampler-min-p-four-way,metal-weight-bytes-runtime,autoregressive-loop,ask-staged-model-call,decoded-prose-answer-binding"
        (str_concat "\nmissing:full-real-llama-gguf-token-generation"
        (str_concat "\nboundary:ask-staged now returns a decoded local answer receipt; named real GGUF tensor slices enter native math, required tensor-set byte windows enter fkwu content-addressed materialization, a real GGUF tokenizer string row can be selected by Form argmax and decoded as a token, a full-width token-embedding logit row can be generated by Form, and the min-p sampler/draw path is four-way; full real Llama hidden-state token generation remains pending"
                    "\nprose-generation:decoded-grounded-answer")))))))

    (defn fc-model-convergence ()
        (str_concat "model-lane-convergence:one-wide-move"
        (str_concat "\nobserved:grounded-rag,gguf-model-cell,full-gguf-weight-map,named-real-gguf-tensor-math,full-gguf-named-tensor-slice-math,full-gguf-required-tensor-set-materialization,real-gguf-tokenizer-token-decode,semantic-token-generation,full-width-model-logit-generation,sampler-min-p-four-way,metal-weight-bytes-runtime,autoregressive-loop,ask-staged-model-call,decoded-prose-answer-binding"
        (str_concat "\nwide-move:complete-full-width-tensor-payload-staging,dequant-and-accelerator-buffer-placement,full-multilayer-gqa-hidden-state-loop,full-vocabulary-hidden-state-logits,real-token-id-decode,ask-answer-binding"
        (str_concat "\npending:full-real-llama-gguf-token-generation"
        (str_concat "\nclaim:blocked-until-one-native-path-produces-answer-text-from-real-hidden-state-logits-over-complete-tensors"
        (str_concat "\nreceipt:scripts/fkwu_form_cli_full_model_inference_composition_receipt.sh"
                    "\nmethod:move-all-remaining-bridges-together-under-one-receipt")))))))

    (defn fc-land-readiness (arg)
        (do
            (let parts (split-on arg " "))
            (cbl-readiness-after-push
                (fc-part parts 0 "UNKNOWN")
                (fc-part-bool parts 1)
                (fc-none-empty (fc-part parts 2 "none"))
                (fc-part parts 3 "UNKNOWN")
                (fc-part-int parts 4 0)
                (fc-part-int parts 5 0)
                (fc-part-int parts 6 0)
                (fc-part-bool parts 7)
                (fc-part-bool parts 8))))

    (defn fc-respond (cmd)
        (do (let v (fc-verb cmd))
            (if (str_eq v "ping") "pong"
            (if (str_eq v "ask") (fca-ask (fc-arg cmd))
            (if (str_eq v "ask-staged") (fc-ask-staged)
            (if (str_eq v "ask-staged-trace") (fc-ask-staged-trace (fc-arg cmd))
            (if (str_eq v "ask-request") (fcr-ask-request (fc-arg cmd))
            (if (str_eq v "ask-request-trace") (fcr-ask-request-trace (fc-arg cmd))
            (if (str_eq v "ask-request-debug") (fcr-ask-request-debug (fc-arg cmd))
            (if (str_eq v "embed-request") (fcr-embed-request (fc-arg cmd))
            (if (str_eq v "carrier-id") (fcc-carrier-id)
            (if (str_eq v "carrier-challenge") (fcc-carrier-challenge (fc-arg cmd))
            (if (str_eq v "decoded-answer") (fc-decoded-answer)
            (if (str_eq v "grounded") (ra-grounded (fc-arg cmd))
            (if (str_eq v "grounded-staged") (fc-grounded-staged)
            (if (str_eq v "rag-status") (fc-rag-status)
            (if (str_eq v "synthesis-status") (fc-synthesis-status)
            (if (str_eq v "model-status") (fc-synthesis-status)
            (if (str_eq v "model-convergence") (fc-model-convergence)
            (if (str_eq v "final-observations") (fc-model-convergence)
            (if (str_eq v "fnri") (fc-fnri (fc-arg cmd))
            (if (str_eq v "receipt") (fc-receipt (fc-arg cmd))
            (if (str_eq v "native-host") (fc-native-host (fc-arg cmd))
            (if (str_eq v "land-readiness") (fc-land-readiness (fc-arg cmd))
            (if (str_eq v "oracle-loop-check") (int_to_str (form-cli-oracle-loop-check))
            (if (str_eq v "surface-inquiry") (fsi-form-cli-command (fc-arg cmd))
            (if (str_eq v "help")
                "form-cli verbs: ping carrier-id carrier-challenge ask ask-request ask-request-trace ask-request-debug embed-request ask-staged ask-staged-trace grounded rag-status synthesis-status model-convergence final-observations decoded-answer fnri receipt native-host land-readiness oracle-loop-check surface-inquiry framebuffer-status help about kernel source recreate verify diagnose version quit. surface-inquiry: metadata-only offered request/response lineage inquiry. framebuffer-status: live Form framebuffer roots and record/read/clear arm tallies. oracle-loop-check: lineage-honest oracle-regent loop self-check (heir/regent routing, grounding gate, lineage-discounted reference, unconditional learning). carrier-id: baked schema/source/build identity. carrier-challenge <64hex>: Form-computed SHA-256 nonce response. ask-request <id>: invocation-owned native RAG query. ask-request-trace <id>: one-use request-bound HMAC trust row from .query/.receipt files. ask-request-debug <id>: local receipt binding-axis diagnosis without exposing key material. embed-request <id>: canonical semantic-v2 JSONL vectors from hex-safe .embed rows. grounded <question>: native JSONL lookup in the healed index, no Python and no HTTP oracle. rag-status: local index/query/schema health. synthesis-status: local GGUF/Metal composition receipt including the four-way min-p sampler lane. source/verify/diagnose: fkwu self-introspection."
            (if (str_eq v "about")
                "form-cli is one self-contained native binary: a Form program that dispatches verbs and runs an interactive read-eval-print loop, with no separate runtime. Pipe commands on stdin, or run it on a terminal and type. help lists the verbs."
            (if (str_eq v "kernel")
                "form-cli runs on fkwu, a universal walker generated entirely from Form recipes and compiled to native code. The same walker runs any Form program. this binary has the form-cli program built into it."
            (if (str_eq v "recreate")
                "to rebuild: run the source verb to print the Form source this binary carries. build-form-cli.sh installs the stamped native platform binary when present; maintainer regeneration refreshes bootstrap artifacts. the result runs on its own."
            (if (str_eq v "version")
                "form-cli 0.3"
                (str_concat "form-cli: unknown verb '" (str_concat v "' — type 'help'"))))))))))))))))))))))))))))
            )
            ))
    )
    0)
