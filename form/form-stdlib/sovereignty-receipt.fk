; sovereignty-receipt.fk — per-response honesty: how much was native body, how much rented oracle.
;
; preludes: form-stdlib/core.fk
;
; Urs, 2026-06-21: "we shall return how much of any response was native and how much was 3rd-party
; oracle-based — which oracle, which model, how much payload, which native contenders have been trained,
; how close to use the native models." This recipe is the GATE that keeps that receipt honest. It composes
; the sovereignty machinery already proven: form-first-router.fk (body vs rented per query),
; form-cli-membrane.fk (the crossing ledger), oracle-distillation-learning.fk (the native contenders +
; their floors), champion-challenger / colearning-retire (a lane comes home only when native earns it),
; borrowed-oracle-dividend.fk (who paid). The hard floor it refuses to hide: an agentic response today is
; GENERATED by a rented frontier mind; the native body verifies (four-way proof) and looks up, it does not
; yet generate. The receipt says so — and never reports rented generation as native.
;
; A response accounting (each a count or 0/1, except scores 0..100):
;   native-gen   — generation units produced by the native body (0 for an agentic response today)
;   oracle-gen   — generation units produced by the rented oracle
;   native-proof — verification/execution units that ran native (four-way proofs, kernel exec)
;   native-score — the native contender's held-out score for this lane (0..100)
;   oracle-score — the oracle's score for this lane (0..100)
;   floor-met    — did the native contender clear quality/trust/sovereignty/vitality floors? (0/1)
;
; Proven by: form-stdlib/tests/sovereignty-receipt-band.fk (four-way at validate.sh)

(do
    (defn rp-native-gen   (r) (nth r 0))
    (defn rp-oracle-gen   (r) (nth r 1))
    (defn rp-native-proof (r) (nth r 2))
    (defn rp-native-score (r) (nth r 3))
    (defn rp-oracle-score (r) (nth r 4))
    (defn rp-floor-met    (r) (nth r 5))

    ; the honest floor: generation is RENTED when the oracle generated and the body generated nothing
    (defn rp-gen-rented? (r)
        (if (and (ge (rp-oracle-gen r) 1) (eq (rp-native-gen r) 0)) 1 0))

    ; ...yet the proof/verification ran native even so (four-way), which is real and worth naming
    (defn rp-proof-native? (r) (if (ge (rp-native-proof r) 1) 1 0))

    ; champion-challenger: is the native contender READY to take this lane? (>= oracle AND floor cleared)
    (defn rp-native-ready? (r)
        (if (and (ge (rp-native-score r) (rp-oracle-score r)) (eq (rp-floor-met r) 1)) 1 0))

    ; use native NOW only when ready — never before; this gate is what keeps the receipt from lying
    (defn rp-use-native? (r) (rp-native-ready? r))

    ; the honesty invariant: a rented generation must NEVER be reported as native
    (defn rp-honest? (r)
        (if (eq (rp-gen-rented? r) 1)
            (if (eq (rp-native-gen r) 0) 1 0)   ; rented => the reported native-gen is zero
            1))

    0)
