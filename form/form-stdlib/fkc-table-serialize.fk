; fkc-table-serialize.fk — flatten a Hati-OS program tree to the integer table
; format fkwu loads (fkc-table-file / fks-table-file). Split from
; hati-os-kernel-emit.fk so T_flat bootstrap and self-host flatten never
; parse the C-emission string literals (~160KB). Fkwu build still cats the
; full emit file via FOURTH_CHAIN.
;
; preludes: form-stdlib/minimal-surface.fk form-stdlib/hati-os-kernel.fk

(defn fkc-flat (n acc)
    (if (eq (fk-tag n) 1) (cons (list 1 (ms-value (fk-body n)) 0 0) acc)
    (if (eq (fk-tag n) 2) (cons (list 2 0 0 0) acc)
    (if (eq (fk-tag n) 7) (fkc-un2 7 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 9) (fkc-un2 9 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 14) (fkc-un2 14 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 17) (fkc-un2 17 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 15) (cons (list 15 0 0 0) acc)
    (if (eq (fk-tag n) 16) (cons (list 16 0 0 0) acc)
    (if (eq (fk-tag n) 18) (cons (list 18 0 0 0) acc)
    ; 101 temp_dir — nullary host-io leaf: the walker arm reads no operands, so
    ; the row carries the tag alone (fk_tempdir resolves $TMPDIR at walk time).
    (if (eq (fk-tag n) 101) (cons (list 101 0 0 0) acc)
    ; 110 FARG — frame-relative read: unary, single child is the offset LIT the
    ; walker adds to fp. 109 LETF (offset, value, body) is tri: writes the value
    ; to reserved slot fp+offset, then walks the body. 111 RESERVE (k, body) is
    ; binary and rides the fallback. Together: recursion-safe let on a reserved
    ; per-call frame block, immune to argument-position scratch.
    (if (eq (fk-tag n) 110) (fkc-un2 110 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 109) (fkc-tri2 109 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 20) (fkc-un2 20 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 21) (fkc-un2 21 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 22) (fkc-un2 22 (fkc-flat (fk-body n) acc))
    ; 24 SLIT — a leaf row carrying the POOL INDEX (the string's bytes travel
    ; in the table file's string section, not in the row); 25/31/32/33 unary;
    ; SEQ/SCAT/SCHAR (26..28) are pair-bodied; SSUB/SFIND (29/30) are tri-bodied;
    ; 41 BNOT_U32 and 43 INTERN_TRIVIAL_INT are unary; 45/46/48/49 unary,
    ; 47/80/84/86 binary; http_get rides tag 105 as a three-arg host channel;
    ; file_mtime rides tag 107 and scan_run rides tag 108;
    ; lowered JIT lane uses 70..79 and the
    ; value-native/JIT-offer/numeric lane uses 81..90 above the Hati/BML carriers.
    (if (eq (fk-tag n) 24) (cons (list 24 (ms-value (ms-child (fk-body n) 0)) 0 0) acc)
    (if (eq (fk-tag n) 50) (cons (list 50 (ms-value (ms-child (fk-body n) 0)) 0 0) acc)
    (if (eq (fk-tag n) 25) (fkc-un2 25 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 31) (fkc-un2 31 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 32) (fkc-un2 32 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 33) (fkc-un2 33 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 51) (fkc-un2 51 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 53) (fkc-un2 53 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 54) (fkc-un2 54 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 55) (fkc-un2 55 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 56) (fkc-un2 56 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 57) (fkc-un2 57 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 58) (fkc-un2 58 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 60) (fkc-un2 60 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 107) (fkc-un2 107 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 63) (fkc-un2 63 (fkc-flat (fk-body n) acc))
    ; 132 fs_list — unary host-io: the single child is the directory-path string;
    ; the walker arm opendir/readdir's it into a name-sorted list of entry strings.
    (if (eq (fk-tag n) 132) (fkc-un2 132 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 64) (fkc-un2 64 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 68) (fkc-un2 68 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 99) (fkc-un2 99 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 100) (fkc-un2 100 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 43) (fkc-un2 43 (fkc-flat (fk-body n) acc))
    ; 112 INTERN_TRIVIAL_BOOL / 113 INTERN_TRIVIAL_FLOAT — unary trivial leaves,
    ; the same single-child serialization as 43: the lone child (the bool lit /
    ; the float's source-text SLIT) flattens first, then the typed-leaf row.
    (if (eq (fk-tag n) 112) (fkc-un2 112 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 113) (fkc-un2 113 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 72) (fkc-un2 72 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 73) (cons (list 73 (ms-value (fk-body n)) 0 0) acc)
    (if (eq (fk-tag n) 74) (fkc-un2 74 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 75) (fkc-un2 75 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 76) (fkc-un2 76 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 77) (fkc-lift2 (ms-value (ms-child (fk-body n) 0))
                                      (fkc-flat (ms-child (fk-body n) 1) acc))
    (if (eq (fk-tag n) 78) (fkc-un2 78 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 41) (fkc-un2 41 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 45) (fkc-un2 45 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 46) (fkc-un2 46 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 48) (fkc-un2 48 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 49) (fkc-un2 49 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 91) (fkc-un2 91 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 92) (fkc-un2 92 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 93) (fkc-un2 93 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 94) (fkc-un2 94 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 95) (fkc-un2 95 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 96) (fkc-un2 96 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 12) (fkc-call2 (ms-value (ms-child (fk-body n) 0)) (fkc-flat (ms-child (fk-body n) 1) acc))
    (if (eq (fk-tag n) 6) (fkc-if2 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 29) (fkc-tri2 29 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 30) (fkc-tri2 30 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 79) (fkc-if-tag2 79 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 52) (fkc-bin2 52 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 62) (fkc-tri2 62 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 105) (fkc-tri2 105 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 118) (fkc-tri2 118 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 119) (fkc-tri2 119 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (or (eq (fk-tag n) 120) (or (eq (fk-tag n) 121) (or (eq (fk-tag n) 122) (eq (fk-tag n) 126))))
        (fkc-un2 (fk-tag n) (fkc-flat (fk-body n) acc))
    (if (or (eq (fk-tag n) 123) (or (eq (fk-tag n) 124) (eq (fk-tag n) 125)))
        (fkc-bin2 (fk-tag n) (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 108) (fkc-tri2 108 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 66) (fkc-tri2 66 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 67) (fkc-bin2 67 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 97) (fkc-bin2 97 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 98) (fkc-tri2 98 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    ; 128 fb_record — tri (nid, file, packed-line-col): the framebuffer attribution
    ; carrier the shim's intern_node_at lowers to; args ride the row slots.
    (if (eq (fk-tag n) 128) (fkc-tri2 128 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    ; 114 read_line / 116 isatty — nullary host-io leaves: the walker arm reads no
    ; operands, so the row carries the tag alone (like 101 temp_dir, 18 empty).
    ; 115 print_str — unary: the single child is the string value to write.
    (if (eq (fk-tag n) 114) (cons (list 114 0 0 0) acc)
    (if (eq (fk-tag n) 116) (cons (list 116 0 0 0) acc)
    (if (eq (fk-tag n) 117) (cons (list 117 0 0 0) acc)
    ; 129 framebuffer-events / 131 framebuffer-clear — nullary framebuffer leaves.
    (if (eq (fk-tag n) 129) (cons (list 129 0 0 0) acc)
    (if (eq (fk-tag n) 131) (cons (list 131 0 0 0) acc)
    (if (eq (fk-tag n) 115) (fkc-un2 115 (fkc-flat (fk-body n) acc))
    ; 133 file_open / 135 file_close — unary streaming-handle host-io leaves
    ; (path->fd, fd->status); 134 file_read is binary (fd, max). Without the
    ; explicit rows the new tags fall to the binary fallback and a unary op reads
    ; a non-existent second child (node_value: null).
    (if (eq (fk-tag n) 133) (fkc-un2 133 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 135) (fkc-un2 135 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 134) (fkc-bin2 134 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    ; 200 fs_is_dir / 202 source_inventory — form-fs stdlib (form-fs.fk)
    ; 203 metal_matvec_fixture — nullary fkwu-only proof carrier.
    ; 204 metal_matvec_f32 — tri carrier (msl bytes, kernel name, model bytes).
    (if (eq (fk-tag n) 200) (fkc-un2 200 (fkc-flat (fk-body n) acc))
    (if (eq (fk-tag n) 202) (fkc-tri2 202 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (eq (fk-tag n) 203) (cons (list 203 0 0 0) acc)
    (if (eq (fk-tag n) 204) (fkc-tri2 204 (fkc-flat (ms-child (fk-body n) 0) acc) n)
    (if (or (eq (fk-tag n) 81) (or (eq (fk-tag n) 82) (or (eq (fk-tag n) 83) (or (eq (fk-tag n) 85) (or (eq (fk-tag n) 87) (or (eq (fk-tag n) 88) (or (eq (fk-tag n) 89) (or (eq (fk-tag n) 90) (or (eq (fk-tag n) 127) (eq (fk-tag n) 130))))))))))
        (fkc-un2 (fk-tag n) (fkc-flat (fk-body n) acc))
        (fkc-bin2 (fk-tag n) (fkc-flat (ms-child (fk-body n) 0) acc) n)))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))

(defn fkc-call2 (fidx acc1) (cons (list 12 fidx (sub (len acc1) 1) 0) acc1))

(defn fkc-un2 (tag acc1) (cons (list tag (sub (len acc1) 1) 0 0) acc1))
(defn fkc-lift2 (idx acc1) (cons (list 77 idx (sub (len acc1) 1) 0) acc1))

(defn fkc-bin2 (tag acc1 n) (fkc-bin3 tag (sub (len acc1) 1) (fkc-flat (ms-child (fk-body n) 1) acc1)))
(defn fkc-bin3 (tag ia acc2) (cons (list tag ia (sub (len acc2) 1) 0) acc2))

(defn fkc-tri2 (tag acc1 n) (fkc-tri3 tag (sub (len acc1) 1) (fkc-flat (ms-child (ms-child (fk-body n) 1) 0) acc1) n))
(defn fkc-tri3 (tag ia acc2 n) (fkc-tri4 tag ia (sub (len acc2) 1) (fkc-flat (ms-child (ms-child (fk-body n) 1) 1) acc2)))
(defn fkc-tri4 (tag ia ib acc3) (cons (list tag ia ib (sub (len acc3) 1)) acc3))

(defn fkc-if2 (acc1 n) (fkc-if-tag2 6 acc1 n))
(defn fkc-if-tag2 (tag acc1 n) (fkc-if-tag3 tag acc1 (sub (len acc1) 1) n))
(defn fkc-if-tag3 (tag acc1 ic n) (fkc-if-tag4 tag (fkc-flat (ms-child (ms-child (fk-body n) 1) 0) acc1) ic n))
(defn fkc-if-tag4 (tag acc2 ic n) (fkc-if-tag5 tag acc2 (sub (len acc2) 1) ic n))
(defn fkc-if-tag5 (tag acc2 it ic n) (fkc-if-tag6 tag (fkc-flat (ms-child (ms-child (fk-body n) 1) 1) acc2) it ic))
(defn fkc-if-tag6 (tag acc3 it ic) (cons (list tag ic it (sub (len acc3) 1)) acc3))

(defn fkc-flatten (prog) (fkc-flat prog (empty)))

(defn fkc-row-text (r)
    (str_concat "{"
    (str_concat (int_to_str (nth r 0))
    (str_concat ","
    (str_concat (int_to_str (nth r 1))
    (str_concat ","
    (str_concat (int_to_str (nth r 2))
    (str_concat ","
    (str_concat (int_to_str (nth r 3)) "},")))))))))

(defn fkc-rows-text (rows)
    (if (eq (len rows) 1) (fkc-row-text (head rows))
        (str_concat (fkc-rows-text (tail rows)) (fkc-row-text (head rows)))))

(defn fkc-pr-text ()
    "extern int putchar(int); extern int printf(const char *, ...); extern void *malloc(unsigned long); extern void *realloc(void *, unsigned long); extern long long read(int, void *, unsigned long); extern int isatty(int); static const unsigned char *fk_gen = 0; static long long fk_gen_len = 0; static double *fk_fv; static long long fk_fcap; static long long fk_fp; static const long long fk_fbase = -9000000000000000000LL; static long long fk_fidx(long long v) { return (fk_fbase - v) >> 1; } static long long fk_isf(long long v) { long long fi = fk_fidx(v); return v <= fk_fbase - 2 && fi > 0 && fi <= fk_fp; } static double fk_num(long long v) { if (fk_isf(v)) { return fk_fv[fk_fidx(v)]; } return (double)(v >> 1); } static long long fk_fbox(double d) { if (fk_fv == 0) { fk_fcap = 65536; fk_fv = malloc(fk_fcap * 8); } fk_fp = fk_fp + 1; if (fk_fp >= fk_fcap) { fk_fcap = fk_fcap * 2; fk_fv = realloc(fk_fv, fk_fcap * 8); } fk_fv[fk_fp] = d; return fk_fbase - (fk_fp << 1); } static void fk_pr(long long v) { char b[32]; int n = 0; if (v < 0) { putchar(45); v = 0 - v; } if (v == 0) { putchar(48); } while (v > 0) { b[n] = 48 + v % 10; v = v / 10; n = n + 1; } while (n > 0) { n = n - 1; putchar(b[n]); } putchar(10); } static void fk_pv(long long v) { if (fk_isf(v)) { printf(\"%.15g\\n\", fk_num(v)); } else { if ((v & 1) == 0) { fk_pr(v >> 1); } else { fk_pr(v); } } } ")

(defn fkc-decl-text (rows)
    (str_concat "static long long fk_arms[12]; static const long long fk_node["
    (str_concat (int_to_str (len rows))
    (str_concat "][4] = { "
    (str_concat (fkc-rows-text rows) " }; ")))))

(defn fkc-walk-text (root)
    (str_concat "static long long fk_walk(long long i, long long a) { long long t = fk_node[i][0]; fk_arms[t] = fk_arms[t] + 1; if (t == 1) { return fk_node[i][1]; } if (t == 2) { return a; } if (t == 3) { return fk_walk(fk_node[i][1], a) + fk_walk(fk_node[i][2], a); } if (t == 4) { return fk_walk(fk_node[i][1], a) - fk_walk(fk_node[i][2], a); } if (t == 5) { if (fk_walk(fk_node[i][1], a) <= fk_walk(fk_node[i][2], a)) { return 1; } return 0; } if (t == 6) { if (fk_walk(fk_node[i][1], a) == 0) { return fk_walk(fk_node[i][3], a); } return fk_walk(fk_node[i][2], a); } if (t == 7) { return fk_walk("
    (str_concat (int_to_str root)
                ", fk_walk(fk_node[i][1], a)); } if (t == 8) { return fk_node[fk_walk(fk_node[i][1], a)][fk_walk(fk_node[i][2], a)]; } if (t == 9) { putchar((int)fk_walk(fk_node[i][1], a)); return 0; } if (t == 10) { return fk_walk(fk_node[i][1], a) / fk_walk(fk_node[i][2], a); } if (t == 11) { return fk_walk(fk_node[i][1], a) % fk_walk(fk_node[i][2], a); } return 0; } ")))

(defn fkc-main-text (root)
    (str_concat "extern int atoi(const char *); int main(int argc, char **argv) { long long a = 0; if (argc > 1) { a = atoi(argv[1]); } fk_pr(fk_walk("
    (str_concat (int_to_str root)
                ", a)); long long t = 1; while (t <= 11) { fk_pr(fk_arms[t]); t = t + 1; } return 0; }")))

(defn fkc-emit2 (rows)
    (str_concat (fkc-pr-text)
    (str_concat (fkc-decl-text rows)
    (str_concat (fkc-walk-text (sub (len rows) 1))
                (fkc-main-text (sub (len rows) 1))))))

(defn fkc-emit (prog) (fkc-emit2 (fkc-flatten prog)))

; ── m4d first move — the quine seed ──────────────────────────────────────
; Four new ops, each a named axiom-face in the emitted sibling:
;   8 NODE a b   read fk_node[a][b] — the binary OBSERVES ITSELF (axiom 4 inward)
;   9 PUTC e     emit one char, return 0 — the efferent PORT (axiom 4 outward)
;   10 DIV, 11 MOD — figure leaves the digit printer needs
; PUTC returning 0 makes ADD a sequencing door (values stay 0). The
; self-printer walks its OWN node table row by row (ARG is the row index,
; SELF advances it) and emits exactly the text fkc-rows-text computes from
; the same flatten — the data half of self-emission. The quine knot — the
; program containing its own true length — closes by fixpoint authoring:
; the row COUNT of fkd-printer-with is independent of the literal inside,
; so one rebuild with the measured length lands exactly.

(defn fkd-node (a b) (fk-node 8 (ms-intern a b)))
(defn fkd-putc (e)   (fk-node 9 e))
(defn fkd-div (a b)  (fk-node 10 (ms-intern a b)))
(defn fkd-mod (a b)  (fk-node 11 (ms-intern a b)))
(defn fkd-seq (a b)  (fk-add a b))
(defn fkd-ch (c)     (fkd-putc (fk-lit c)))
(defn fkd-d1 (v)     (fkd-putc (fk-add (fk-lit 48) v)))

(defn fkd-num (v)
    (fk-if (fk-le v (fk-lit 9))
           (fkd-d1 v)
           (fk-if (fk-le v (fk-lit 99))
                  (fkd-seq (fkd-d1 (fkd-div v (fk-lit 10)))
                           (fkd-d1 (fkd-mod v (fk-lit 10))))
                  (fkd-seq (fkd-d1 (fkd-div v (fk-lit 100)))
                  (fkd-seq (fkd-d1 (fkd-mod (fkd-div v (fk-lit 10)) (fk-lit 10)))
                           (fkd-d1 (fkd-mod v (fk-lit 10))))))))

(defn fkd-cell (j) (fkd-num (fkd-node (fk-arg) (fk-lit j))))

(defn fkd-row ()
    (fkd-seq (fkd-ch 123)
    (fkd-seq (fkd-cell 0)
    (fkd-seq (fkd-ch 44)
    (fkd-seq (fkd-cell 1)
    (fkd-seq (fkd-ch 44)
    (fkd-seq (fkd-cell 2)
    (fkd-seq (fkd-ch 44)
    (fkd-seq (fkd-cell 3)
    (fkd-seq (fkd-ch 125) (fkd-ch 44)))))))))))

(defn fkd-printer-with (nminus1)
    (fk-if (fk-le (fk-arg) (fk-lit nminus1))
           (fkd-seq (fkd-row) (fk-self (fk-add (fk-arg) (fk-lit 1))))
           (fkd-putc (fk-lit 10))))

(defn fkd-self-printer ()
    (fkd-printer-with (sub (len (fkc-flatten (fkd-printer-with 0))) 1)))

; ── m4e1 — CALL + the function table, emitted ────────────────────────────
; A program is a LIST of one-param functions flattened into ONE table; the
; emitted C gains fk_fn[] (each function's root index), CALL dispatches
; through it, and SELF re-enters fk_fn[0] — the single-program emission is
; the one-function special case. This is the stone that unblocks the
; emitter-as-program (the full m4d fixpoint's named blocker): the emitter
; wants several functions, and now programs may have them.

(defn fkc-fm (fns acc roots)
    (if (eq (len fns) 0) (list acc roots)
        (fkc-fm2 (fkc-flat (head fns) acc) (tail fns) roots)))
(defn fkc-fm2 (acc1 rest roots)
    (fkc-fm rest acc1 (cons (sub (len acc1) 1) roots)))
(defn fkc-flatten-many (fns) (fkc-fm fns (empty) (empty)))

(defn fkc-fn-text (roots)
    (if (eq (len roots) 1) (int_to_str (head roots))
        (str_concat (fkc-fn-text (tail roots)) (str_concat "," (int_to_str (head roots))))))

; ── m4e2 arena + the melt door (melt-on-cool, activated) ─────────────────
; Round 1 measured the bump-only carrier: holds to exactly 4095 cells, the
; 4096th wraps the root onto the null sentinel, 4200 tears the chain at the
; wrap. The activation: the arena is a grown carrier (malloc — an allowed
; host carrier, like time/arc4random/open) and the CONS door melts at the
; high-water line. The melt tissue mirrors arena-melt.fk's proven walk,
; piece by piece: fk_mlive IS am-live (ONE reachability walk from named
; roots, each slot once), fk_mcopy IS am-melt (figures and the null carry
; as-is; tail, then head, then cons into the fresh space; forwarding =
; same-old-cell -> same-new-cell, the slot face of am-intern's same-
; composition-same-cell), the stderr readout IS am-measure at 16 bytes a
; cell. The melt's root set is the VALUE STACK (fk_vs — every live value
; the walker holds, see below) plus the RAM organ (fk_mem); the melt walks
; both, marks each slot once, and REWRITES each root in place to its
; relocated pointer. Thresholds are DATA from these named cells, never
; magic in the C.
;
; ── the walker-managed value stack (the melt-root wall, down) ────────────
; BMF's stack-not-tokenize discipline (bmf-architecture.form) pointed inward
; at the emitted walker: call args used to ride suspended C frames — slots
; the copying melt could neither root nor relocate, so band-scale allocation
; mid-call went stale (feature-vector's wall, named in m4e4). Now every live
; value the walker holds is visible to the walker: fk_walk's second
; parameter is a FRAME POINTER into fk_vs, ARG reads fk_vs[fp], CALL/SELF
; push the evaluated argument and re-enter at the new frame, and CONS/NTH
; park their in-flight refs on the same stack across allocating child
; walks. fk_vs is a dedicated rooted region like fk_mem — static, outside
; the arena, melt-rooted and melt-relocated like any cells. The capacity is
; a named cell; a breach is observable (vs! on stderr, exit 9 — axiom-4),
; and the host C stack exhausts far earlier in honest walks (each walker
; frame nests many C frames). This is also the ground floats and strings
; will stand on, and the depth future-proofing for deeper recursion.

(defn fkc-arena-capacity () 4096)
(defn fkc-melt-water-pct () 90)
(defn fkc-vstack-capacity () 65536)
(defn fkc-needs-melt (hp cap) (if (ge (mul hp 100) (mul cap (fkc-melt-water-pct))) 1 0))
(defn fkc-next-capacity (live cap) (if (gt (mul live 2) cap) (mul cap 2) cap))

(defn fkc-arena-init-text ()
    (str_concat "static void fk_arena(void) { fk_cap = "
    (str_concat (int_to_str (fkc-arena-capacity))
                "; fk_hh = malloc(fk_cap * 8); fk_ht = malloc(fk_cap * 8); fk_hh[0] = 1; fk_ht[0] = 1; } ")))

(defn fkc-melt-walk-text ()
    "static long long *fk_fw; static long long *fk_nh; static long long *fk_nt; static long long fk_nhp; static void fk_mw(long long v) { char b[32]; long long n = 0; if (v == 0) { b[0] = 48; n = 1; } while (v > 0) { b[n] = 48 + v % 10; v = v / 10; n = n + 1; } while (n > 0) { n = n - 1; write(2, b + n, 1); } } static void fk_mc(long long c) { char b = c; write(2, &b, 1); } static long long fk_mlive(long long b) { if ((b & 1) == 0) { return 0; } long long p = b >> 1; if (p < 1 || p > fk_hp) { return 0; } if (fk_fw[p] != 0) { return 0; } fk_fw[p] = 0 - 1; return 1 + fk_mlive(fk_ht[p]) + fk_mlive(fk_hh[p]); } static long long fk_mcopy(long long b) { if ((b & 1) == 0) { return b; } long long p = b >> 1; if (p < 1 || p > fk_hp) { return b; } if (fk_fw[p] > 0) { return (fk_fw[p] << 1) | 1; } long long t2 = fk_mcopy(fk_ht[p]); long long h2 = fk_mcopy(fk_hh[p]); fk_nhp = fk_nhp + 1; fk_nh[fk_nhp] = h2; fk_nt[fk_nhp] = t2; fk_fw[p] = fk_nhp; return (fk_nhp << 1) | 1; } ")

; the melt's root walk: EVERY value-stack slot below fk_vsp plus the RAM
; organ — mark each reachable cell once (fk_mlive IS am-live), then rewrite
; each root in place to its relocated pointer (fk_mcopy IS am-melt with
; forwarding). No value the walker holds can hide from this walk: that is
; the value stack's whole reason to exist.
(defn fkc-melt-run-text ()
    "static void fk_melt(void) { fk_fw = calloc(fk_hp + 1, 8); if (fk_fw == 0) { return; } long long nlive = 0; long long k = 0; while (k < fk_vsp) { nlive = nlive + fk_mlive(fk_vs[k]); k = k + 1; } k = 0; while (k < 4096) { nlive = nlive + fk_mlive(fk_mem[k]); k = k + 1; } k = 1; while (k <= fk_np) { nlive = nlive + fk_mlive(fk_ncat[k]); nlive = nlive + fk_mlive(fk_nkids[k]); nlive = nlive + fk_mlive(fk_nval[k]); k = k + 1; } long long ncap = fk_cap; if (nlive * 2 > fk_cap) { ncap = fk_cap * 2; } fk_nh = malloc(ncap * 8); fk_nt = malloc(ncap * 8); if (fk_nh == 0 || fk_nt == 0) { free(fk_nh); free(fk_nt); free(fk_fw); return; } fk_nhp = 0; fk_nh[0] = 1; fk_nt[0] = 1; k = 0; while (k < fk_vsp) { fk_vs[k] = fk_mcopy(fk_vs[k]); k = k + 1; } k = 0; while (k < 4096) { fk_mem[k] = fk_mcopy(fk_mem[k]); k = k + 1; } k = 1; while (k <= fk_np) { fk_ncat[k] = fk_mcopy(fk_ncat[k]); fk_nkids[k] = fk_mcopy(fk_nkids[k]); fk_nval[k] = fk_mcopy(fk_nval[k]); k = k + 1; } free(fk_hh); free(fk_ht); free(fk_fw); fk_hh = fk_nh; fk_ht = fk_nt; fk_hp = fk_nhp; fk_cap = ncap; } ")

; the push door: capacity from the named cell; a breach writes vs! and
; exits 9 — observable (axiom-4), never silent corruption. Pops are plain
; fk_vsp decrements at each site (balance is the walker's own discipline).
(defn fkc-vp-text ()
    (str_concat "extern void _exit(int); static void fk_vp(long long v) { if (fk_vsp >= "
    (str_concat (int_to_str (fkc-vstack-capacity))
                ") { fk_mc(118); fk_mc(115); fk_mc(33); fk_mc(10); _exit(9); } fk_vs[fk_vsp] = v; fk_vsp = fk_vsp + 1; } ")))

(defn fkc-melt-text ()
    (str_concat (fkc-arena-init-text)
    (str_concat (fkc-melt-walk-text)
    (str_concat (fkc-melt-run-text) (fkc-vp-text)))))

; the door at CONS: lazy carrier birth, then the high-water decision
; (the same algebra as fkc-needs-melt, pct spliced from the cell), then
; the hard boundary made OBSERVABLE — a refused allocation pops its two
; stack-parked operands and answers the null sentinel instead of silently
; wrapping (axiom-4: breach observable). The in-flight pair rides fk_vs,
; so the melt sees it as roots like everything else.
(defn fkc-melt-door-text ()
    (str_concat "if (fk_cap == 0) { fk_arena(); } if (fk_hp * 100 >= fk_cap * "
    (str_concat (int_to_str (fkc-melt-water-pct))
                ") { fk_melt(); } if (fk_hp + 1 >= fk_cap) { fk_vsp = fk_vsp - 2; return 1; } ")))

; ── the string POOL (tags 24..33 claimed by the string lane) — its own rooted
;    region beside the cons arena: interned byte-sequences addressed by id.
;    fk_sintern is axiom 3 in C — same bytes answer the same slot, so the SEQ
;    arm compares IDS and means content. The pool is append-only and never
;    moved, so the copying melt has nothing to root here; string values ride
;    as plain ints (pool ids) through packed args, lists, and RAM. A refused
;    intern (slots or bytes exhausted) answers id -1 — observable, never a
;    silent wrap (axiom 4). Sizes are recipe cells, no magic in the C.
(defn fkc-spool-slots () 16384)   ; max distinct strings in one program image
(defn fkc-spool-bytes () 1048576) ; pool byte store, the fk_src discipline
(defn fkc-node-slots () 65536)    ; transient substrate node carrier
(defn fkc-universal-fn-slots () 2048)
(defn fkc-universal-node-slots () 65536)
(defn fkc-arm-slots ()  256)      ; dispatch counters cover tags 0..255 (host-io-fs 200,202; streaming 133..135; fs_list 132; kernel_stat 127; framebuffer 128..131)

(defn fkc-spool-decl-text ()
    (str_concat "static char *fk_sb; static long long *fk_so; static long long *fk_sl; static long long fk_scap_b; static long long fk_scap_s; static long long fk_sp; static long long fk_sbp; static void fk_sinit(void) { if (fk_sb == 0) { fk_scap_b = "
    (str_concat (int_to_str (fkc-spool-bytes))
    (str_concat "; fk_scap_s = "
    (str_concat (int_to_str (fkc-spool-slots))
                "; fk_sb = malloc(fk_scap_b); fk_so = malloc(fk_scap_s * 8); fk_sl = malloc(fk_scap_s * 8); } } static long long fk_sintern(long long off, long long len) { fk_sinit(); long long i = 0; while (i < fk_sp) { if (fk_sl[i] == len) { long long j = 0; while (j < len && fk_sb[fk_so[i] + j] == fk_sb[off + j]) { j = j + 1; } if (j == len) { return i; } } i = i + 1; } if (i >= fk_scap_s) { fk_scap_s = fk_scap_s * 2; fk_so = realloc(fk_so, fk_scap_s * 8); fk_sl = realloc(fk_sl, fk_scap_s * 8); } fk_so[i] = off; fk_sl[i] = len; fk_sp = i + 1; fk_sbp = off + len; return i; } ")))))

(defn fkc-node-decl-text ()
    (str_concat "static long long fk_nkind["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_ncat["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_nkids["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_nval["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_nid["
    (str_concat (int_to_str (fkc-node-slots))
                "][4]; static long long fk_np; static long long fk_nbox(long long i) { return 0 - (((long long)i << 1) | 1); } static long long fk_nidx(long long v) { return (((0 - v) - 1) >> 1); } static long long fk_veq(long long a, long long b); static long long fk_neq(long long a, long long b) { if (a == b) { return 1; } if (a >= 0 || b >= 0) { return 0; } long long ia = fk_nidx(a); long long ib = fk_nidx(b); if (ia < 1 || ia > fk_np || ib < 1 || ib > fk_np) { return 0; } if (fk_nkind[ia] != fk_nkind[ib]) { return 0; } if (fk_nkind[ia] == 1) { if (fk_nid[ia][2] != fk_nid[ib][2]) { return 0; } if (fk_nid[ia][2] == 7 || fk_nid[ia][2] == 6) { double fna = fk_num(fk_nval[ia]); double fnb = fk_num(fk_nval[ib]); return ((fna == fnb) || (fna != fna && fnb != fnb)) ? 1 : 0; } return fk_nval[ia] == fk_nval[ib]; } if (fk_nkind[ia] == 3) { return fk_nid[ia][0] == fk_nid[ib][0] && fk_nid[ia][1] == fk_nid[ib][1] && fk_nid[ia][2] == fk_nid[ib][2] && fk_nid[ia][3] == fk_nid[ib][3]; } if (fk_veq(fk_ncat[ia], fk_ncat[ib]) == 0) { return 0; } return fk_veq(fk_nkids[ia], fk_nkids[ib]); } static long long fk_veq(long long a, long long b) { if (a == b) { return 1; } if (a < 0 || b < 0) { return fk_neq(a, b); } if ((a & 1) && (b & 1)) { long long pa = a >> 1; long long pb = b >> 1; if (pa < 1 || pa > fk_hp || pb < 1 || pb > fk_hp) { return 0; } if (fk_veq(fk_hh[pa], fk_hh[pb]) == 0) { return 0; } return fk_veq(fk_ht[pa], fk_ht[pb]); } return 0; } ")))))))))))

; ── framebuffer/source-attribution carriers (the sibling's sourceAttr +
; framebufferRoots, on the fourth arm). Per-node (file line col) attribution
; parallel to fk_nid — node-indexed plain ints, never arena cells, so the melt
; leaves them untouched; fk_nsfile holds the file STRING VALUE (a pool id,
; melt-stable like every string value). fk_fbroots is the insertion-ordered
; append list of attributed node boxes (negative sentinels, also melt-stable),
; matching the siblings' framebufferRoots: intern_node_at (through fb_record,
; tag 128) appends, framebuffer-events (129) walks it, node_source (130) reads
; the per-node map, framebuffer-clear (131) resets both. fkwu's framebuffer is
; now the sibling's framebuffer, not a dropped side-map.
(defn fkc-framebuffer-decl-text ()
    (str_concat "static long long fk_nsfile["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_nsline["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_nscol["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_nsattr["
    (str_concat (int_to_str (fkc-node-slots))
    (str_concat "]; static long long fk_fbroots["
    (str_concat (int_to_str (fkc-node-slots))
                "]; static long long fk_fbn; ")))))))))))

(defn fkc-carrier-decl-text ()
    "
#if defined(__has_include)
#if __has_include(<sys/stat.h>)
#include <sys/stat.h>
#define FK_HAVE_STAT_HEADER 1
#endif
#endif
#ifndef FK_HAVE_STAT_HEADER
extern int mkdir(const char *, unsigned int); extern int stat(const char *, void *);
#endif
#if defined(__has_include)
#if __has_include(<fcntl.h>)
#include <fcntl.h>
#define FK_HAVE_FCNTL_HEADER 1
#endif
#endif
#if defined(__has_include)
#if __has_include(<dirent.h>)
#include <dirent.h>
#define FK_HAVE_DIRENT_HEADER 1
#endif
#endif
#ifndef FK_HAVE_FCNTL_HEADER
#define O_WRONLY 1
#define O_CREAT 0x200
#define O_TRUNC 0x400
#define O_APPEND 8
#endif
extern int open(const char *, int, ...); extern long long read(int, void *, unsigned long); extern int close(int); extern long lseek(int,long,int); extern int rmdir(const char *); extern int unlink(const char *); extern int rename(const char *, const char *); extern int sprintf(char *, const char *, ...); extern char *getenv(const char *); static long long fk_rkey[256][128]; static long long fk_rval[256][128]; static long long fk_rcnt[256]; static long long fk_rbp[256]; static long long fk_rp; static long long fk_rbox(long long r) { return 0 - (r << 1); } static long long fk_ridx(long long v) { if (v >= 0 || ((0 - v) & 1) != 0) { return 0; } return (0 - v) >> 1; } static long long fk_isrec(long long v) { long long r = fk_ridx(v); return r >= 1 && r <= fk_rp; } static long long fk_cstrlen(const char *s) { long long n = 0; while (s[n] != 0) { n = n + 1; } return n; } static void fk_cstr(long long sv, char *out, long long cap) { long long sa = sv >> 1; long long n = 0; if (sa >= 0 && sa < fk_sp) { n = fk_sl[sa]; if (n > cap - 1) { n = cap - 1; } long long j = 0; while (j < n) { out[j] = fk_sb[fk_so[sa] + j]; j = j + 1; } } out[n] = 0; } static long long fk_sbuf(const char *buf, long long n) { if (n < 0) { n = 0; } fk_sinit(); while (fk_sbp + n > fk_scap_b) { fk_scap_b = fk_scap_b * 2; fk_sb = realloc(fk_sb, fk_scap_b); } long long j = 0; while (j < n) { fk_sb[fk_sbp + j] = buf[j]; j = j + 1; } return fk_sintern(fk_sbp, n) << 1; }
#define FK_METAL_FIXTURE_UNLINKED (0 - 4611686018427387903LL)
#define FK_METAL_MATVEC_UNLINKED (0 - 4611686018427387902LL)
#if defined(__GNUC__) || defined(__clang__)
__attribute__((weak)) long long fk_metal_matvec_fixture_external(char *out, long long cap) { (void)out; (void)cap; return FK_METAL_FIXTURE_UNLINKED; }
__attribute__((weak)) long long fk_metal_matvec_f32_external(const char *msl, long long msl_len, const char *kernel, long long kernel_len, const char *model, long long model_len, char *out, long long cap) { (void)msl; (void)msl_len; (void)kernel; (void)kernel_len; (void)model; (void)model_len; (void)out; (void)cap; return FK_METAL_MATVEC_UNLINKED; }
#else
static long long fk_metal_matvec_fixture_external(char *out, long long cap) { (void)out; (void)cap; return FK_METAL_FIXTURE_UNLINKED; }
static long long fk_metal_matvec_f32_external(const char *msl, long long msl_len, const char *kernel, long long kernel_len, const char *model, long long model_len, char *out, long long cap) { (void)msl; (void)msl_len; (void)kernel; (void)kernel_len; (void)model; (void)model_len; (void)out; (void)cap; return FK_METAL_MATVEC_UNLINKED; }
#endif
static long long fk_srange(long long sv, const char **ptr, long long *len) { long long sa = sv >> 1; if (sa < 0 || sa >= fk_sp) { *ptr = \"\"; *len = 0; return 0; } *ptr = fk_sb + fk_so[sa]; *len = fk_sl[sa]; return 1; } static long long fk_metal_matvec_fixture_native(void) { static char out[4096]; long long n = fk_metal_matvec_fixture_external(out, 4096); if (n == FK_METAL_FIXTURE_UNLINKED) { const char *m = \"SKIP fkwu-form-cli-metal-direct: no linked Metal carrier\\nmetal_owner=fkwu-form-cli\\nmetal_linked=false\\n\"; return fk_sbuf(m, fk_cstrlen(m)); } if (n < 0) { const char *m = \"FAIL fkwu-form-cli-metal-direct external carrier returned error\\n\"; return fk_sbuf(m, fk_cstrlen(m)); } if (n > 4096) { n = 4096; } return fk_sbuf(out, n); } static long long fk_metal_matvec_f32_native(long long mslv, long long kernelv, long long modelv) { const char *msl; const char *kernel; const char *model; long long msl_len; long long kernel_len; long long model_len; if (fk_srange(mslv, &msl, &msl_len) == 0 || fk_srange(kernelv, &kernel, &kernel_len) == 0 || fk_srange(modelv, &model, &model_len) == 0) { const char *m = \"FAIL fkwu-form-cli-metal-matvec-f32 invalid string input\\n\"; return fk_sbuf(m, fk_cstrlen(m)); } static char out[8192]; long long n = fk_metal_matvec_f32_external(msl, msl_len, kernel, kernel_len, model, model_len, out, 8192); if (n == FK_METAL_MATVEC_UNLINKED) { const char *m = \"SKIP fkwu-form-cli-metal-matvec-f32: no linked Metal carrier\\nmetal_owner=fkwu-form-cli\\nmetal_linked=false\\n\"; return fk_sbuf(m, fk_cstrlen(m)); } if (n < 0) { const char *m = \"FAIL fkwu-form-cli-metal-matvec-f32 external carrier returned error\\n\"; return fk_sbuf(m, fk_cstrlen(m)); } if (n > 8192) { n = 8192; } return fk_sbuf(out, n); } static long long fk_tempdir() { char *e = getenv(\"TMPDIR\"); static char d[4096]; long long n = 0; if (e != 0) { while (e[n] != 0 && n < 4095) { d[n] = e[n]; n = n + 1; } } if (n == 0) { d[0] = 47; d[1] = 116; d[2] = 109; d[3] = 112; n = 4; } while (n > 1 && d[n - 1] == 47) { n = n - 1; } d[n] = 0; mkdir(d, 0777); return fk_sbuf(d, n); } static long long fk_keyeq(long long a, long long b) { if (a == b) { return 1; } if (a < 0 || b < 0 || a >= fk_sp || b >= fk_sp || fk_sl[a] != fk_sl[b]) { return 0; } long long j = 0; while (j < fk_sl[a]) { if (fk_sb[fk_so[a] + j] != fk_sb[fk_so[b] + j]) { return 0; } j = j + 1; } return 1; } static long long fk_file_mtime(long long pv) { static char p[4096]; fk_cstr(pv, p, 4096);
#ifdef FK_HAVE_STAT_HEADER
 struct stat st; if (stat(p, &st) != 0) { return -2; } return ((long long)st.st_mtime) << 1;
#else
 char st[512]; if (stat(p, st) != 0) { return -2; } return 2;
#endif
 } static int fk_scan_match(unsigned char c, long long cls) { if (cls == 0) { return c == 32 || c == 9 || c == 10 || c == 13; } if (cls == 1) { return c >= 48 && c <= 57; } if (cls == 2) { return (c >= 65 && c <= 90) || (c >= 97 && c <= 122); } if (cls == 3) { return (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 || c == 45; } if (cls == 4) { return c != 34 && c != 92; } if (cls == 5) { return c != 10; } if (cls == 6) { return c >= 32 && c != 34 && c != 92; } return 0; } static long long fk_scan_run(long long sv, long long fromv, long long clsv) { long long sa = sv >> 1; long long from = fromv >> 1; long long cls = clsv >> 1; if (from < 0) { from = 0; } if (sa < 0 || sa >= fk_sp) { return from << 1; } long long end = from; long long n = fk_sl[sa]; while (end < n && fk_scan_match((unsigned char)fk_sb[fk_so[sa] + end], cls)) { end = end + 1; } return end << 1; } static void fk_unlink_segments(char *p) { char q[4096]; long long s = 0; while (s < 2048) { sprintf(q, \"%s/seg-%06lld.log\", p, s); unlink(q); s = s + 1; } } ")

(defn fkc-socket-decl-text ()
    "
#if defined(_WIN32)
typedef unsigned long long fk_os_socket_t;
struct fk_wsadata { unsigned short wVersion; unsigned short wHighVersion; char szDescription[257]; char szSystemStatus[129]; unsigned short iMaxSockets; unsigned short iMaxUdpDg; char *lpVendorInfo; };
extern int WSAStartup(unsigned short, struct fk_wsadata *);
extern fk_os_socket_t socket(int,int,int);
extern int bind(fk_os_socket_t,const void*,int);
extern int listen(fk_os_socket_t,int);
extern fk_os_socket_t accept(fk_os_socket_t,void*,void*);
extern int connect(fk_os_socket_t,const void*,int);
extern int getsockname(fk_os_socket_t,void*,int*);
extern int setsockopt(fk_os_socket_t,int,int,const char*,int);
extern int closesocket(fk_os_socket_t);
extern int recv(fk_os_socket_t,char*,int,int);
extern int send(fk_os_socket_t,const char*,int,int);
#define FK_INVALID_SOCKET ((fk_os_socket_t)(~0ULL))
