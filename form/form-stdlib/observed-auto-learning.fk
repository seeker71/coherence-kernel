; observed-auto-learning.fk -- live observation changes the learning controller.
;
; This is the bridge between the somatic coherence loop, form-cli routing,
; posterior sufficiency, and champion/challenger recipe testing. Static AutoML
; searches for the best arm. Observed auto-learning runs a reversible experiment:
; ground first, honor choice/cut/fail/undo/timeout, then promote only on witnessed
; A/B evidence.
;
; preludes:
;   form-stdlib/somatic-coherence-loop.fk
;   form-stdlib/form-cli-router.fk
;   form-stdlib/form-cli-sufficiency.fk
;
; A/B lineage: learn/champion-challenger.fk. This direct-source cell consumes
; the live A/B window already lowered to integer counts so it stays inside the
; bounded source-runner surface.

(do
    (defn oal-on? (x) (if (eq x 1) 1 0))

    ; control flags are the live offer/ack carrier lowered to a source-runner row.
    (defn oal-controls (choice-open fail cut undo timeout)
        (list choice-open fail cut undo timeout))
    (defn oal-choice-open (c) (nth c 0))
    (defn oal-fail        (c) (nth c 1))
    (defn oal-cut         (c) (nth c 2))
    (defn oal-undo        (c) (nth c 3))
    (defn oal-timeout     (c) (nth c 4))

    (defn oal-control-action (controls)
        (if (eq (oal-on? (oal-fail controls)) 1) "fail-stop"
            (if (eq (oal-on? (oal-undo controls)) 1) "undo-last-change"
                (if (eq (oal-on? (oal-cut controls)) 1) "cut-branch"
                    (if (eq (oal-on? (oal-timeout controls)) 1) "timeout-as-nothing"
                        (if (eq (oal-on? (oal-choice-open controls)) 0) "hold-choice" "continue"))))))

    (defn oal-any-live-control? (controls ab-enabled)
        (if (gt (add (add (add (add (add (oal-on? (oal-choice-open controls))
                                          (oal-on? (oal-fail controls)))
                                     (oal-on? (oal-cut controls)))
                                (oal-on? (oal-undo controls)))
                           (oal-on? (oal-timeout controls)))
                      (oal-on? ab-enabled))
                0)
            1
            0))

    (defn oal-mode (live-observation controls ab-enabled)
        (if (eq (oal-on? live-observation) 0) "batch-search"
            (if (eq (oal-any-live-control? controls ab-enabled) 1)
                "online-reversible-ab"
                "online-observed")))

    (defn oal-route-action (route suff-verdict)
        (if (eq suff-verdict 1) "retry-local"
            (if (eq suff-verdict 2) "ask-oracle"
                (if (str_eq route "agent-cli") "ask-oracle" "run-local"))))

    (defn oal-ab-authority (champ-score chall-score samples min-samples margin)
        (if (and (ge samples min-samples)
                 (ge (add chall-score margin) champ-score))
            "challenger"
            "champion"))

    (defn oal-next (grounded attuned consent small-move integrated witnessed
                    controls route suff-verdict ab-authority)
        (do
            (let soma (scl-next grounded attuned consent small-move integrated witnessed))
            (if (str_eq soma "complete")
                (do
                    (let control (oal-control-action controls))
                    (if (str_eq control "continue")
                        (if (str_eq ab-authority "challenger")
                            "ab-promote-challenger"
                            (oal-route-action route suff-verdict))
                        control))
                soma)))

    (defn oal-receipt (live-observation grounded attuned consent small-move integrated witnessed
                       controls route suff-verdict ab-authority ab-enabled)
        (list "observed-auto-learning"
              (oal-mode live-observation controls ab-enabled)
              (scl-next grounded attuned consent small-move integrated witnessed)
              (oal-control-action controls)
              route
              suff-verdict
              ab-authority
              (oal-next grounded attuned consent small-move integrated witnessed
                        controls route suff-verdict ab-authority)))

    (defn oal-rec-kind    (r) (nth r 0))
    (defn oal-rec-mode    (r) (nth r 1))
    (defn oal-rec-soma    (r) (nth r 2))
    (defn oal-rec-control (r) (nth r 3))
    (defn oal-rec-route   (r) (nth r 4))
    (defn oal-rec-suff    (r) (nth r 5))
    (defn oal-rec-ab      (r) (nth r 6))
    (defn oal-rec-next    (r) (nth r 7))

    0)
