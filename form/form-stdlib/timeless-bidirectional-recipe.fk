; timeless-bidirectional-recipe.fk — reversible flow correlated by composition,
; not time. A recipe earns admission only when both round trips hold.
; preludes: form-stdlib/core.fk
; witnessed: 2026-07-22 -> both round trips restore held-out values; tampered proof refused
(do
  ; A step [index,delta] adds delta at one position. Its inverse subtracts the
  ; same delta. A recipe is [recipe-node,steps]; steps may compose freely.
  (defn tbr-step (index delta) (list index delta))
  (defn tbr-recipe (node steps) (list node steps))
  (defn tbr-node (r) (nth r 0)) (defn tbr-steps (r) (nth r 1))
  (defn tbr-set (values index value)
    (if (eq index 0) (cons value (tail values))
      (cons (head values) (tbr-set (tail values) (sub index 1) value))))
  (defn tbr-apply-step (values step direction)
    (do (let index (nth step 0)) (let delta (nth step 1))
      (tbr-set values index
        (if (eq direction 0) (add (nth values index) delta)
          (sub (nth values index) delta)))))
  (defn tbr-forward-steps (values steps)
    (if (eq (len steps) 0) values
      (tbr-forward-steps (tbr-apply-step values (head steps) 0) (tail steps))))
  (defn tbr-reverse (values)
    (if (eq (len values) 0) (list)
      (tbr-append (tbr-reverse (tail values)) (head values))))
  (defn tbr-append (values value)
    (if (eq (len values) 0) (list value)
      (cons (head values) (tbr-append (tail values) value))))
  (defn tbr-backward-steps (values reversed-steps)
    (if (eq (len reversed-steps) 0) values
      (tbr-backward-steps (tbr-apply-step values (head reversed-steps) 1)
        (tail reversed-steps))))
  (defn tbr-forward (recipe values) (tbr-forward-steps values (tbr-steps recipe)))
  (defn tbr-backward (recipe values)
    (tbr-backward-steps values (tbr-reverse (tbr-steps recipe))))

  (defn tbr-same? (a b)
    (if (not (eq (len a) (len b))) 0
      (if (eq (len a) 0) 1
        (if (eq (head a) (head b)) (tbr-same? (tail a) (tail b)) 0))))
  (defn tbr-proven? (recipe forward-origin backward-origin)
    (if (and
      (eq (tbr-same? (tbr-backward recipe (tbr-forward recipe forward-origin)) forward-origin) 1)
      (eq (tbr-same? (tbr-forward recipe (tbr-backward recipe backward-origin)) backward-origin) 1)) 1 0))

  ; Content correlation is independent of arrival order. The envelope retains
  ; recipe identity, direction, origin fingerprint, value, and proof state.
  (defn tbr-fingerprint-loop (values weight)
    (if (eq (len values) 0) 0
      (add (mul (head values) weight)
        (tbr-fingerprint-loop (tail values) (add weight 1)))))
  (defn tbr-fingerprint (values) (tbr-fingerprint-loop values 1))
  (defn tbr-envelope (recipe direction origin value proven)
    (list (tbr-node recipe) direction (tbr-fingerprint origin) value proven))
  (defn tbr-send-forward (recipe origin backward-origin)
    (tbr-envelope recipe 0 origin (tbr-forward recipe origin)
      (tbr-proven? recipe origin backward-origin)))
  (defn tbr-send-backward (recipe origin forward-origin)
    (tbr-envelope recipe 1 origin (tbr-backward recipe origin)
      (tbr-proven? recipe forward-origin origin)))
  (defn tbr-correlated? (outbound inbound)
    (if (and (eq (nth outbound 0) (nth inbound 0))
      (and (not (eq (nth outbound 1) (nth inbound 1)))
      (and (eq (nth outbound 4) 1) (eq (nth inbound 4) 1)))) 1 0))
  (defn tbr-record (envelope line)
    (fb_record (intern_trivial_int
      (add (mul (nth envelope 0) 10) (nth envelope 1)))
      "form/form-stdlib/timeless-bidirectional-recipe.fk" line))
  (defn tbr-exchange (recipe a b)
    (do (let forward (tbr-send-forward recipe a b))
      (let backward (tbr-send-backward recipe b a))
      (let out-event (tbr-record forward 72))
      (let in-event (tbr-record backward 73))
      (list forward backward (tbr-correlated? forward backward))))
  0)
