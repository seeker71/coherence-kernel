; lifecycle-fitness-receipt.fk - proof receipt for whole-lifecycle health claims.
;
; A machine, nutrition, robot, or therapeutic substance may be generated freely as
; a hypothesis. It may claim whole-life fitness or human benefit only when the
; receipt names every lifecycle phase, every component/substance boundary, the
; source traces, measured effects, safety/stop boundaries, and third-party
; witness. Missing proof returns a refusal reason instead of a health claim.

(do
    (defn lfr-bool-score (ok score)
        (if ok score 0))
    (defn lfr-tagged? (value tag arity)
        (if (eq (len value) arity) (str_eq (nth value 0) tag) false))
    (defn lfr-nonempty-string? (value)
        (gt (str_len value) 0))
    (defn lfr-bit-1? (value)
        (eq value 1))

    (defn lfr-phase (name source-trace measured within-budget contained-or-reversible)
        (list "LifecycleFitnessPhase" name source-trace measured within-budget contained-or-reversible))
    (defn lfr-phase? (phase)
        (lfr-tagged? phase "LifecycleFitnessPhase" 6))
    (defn lfr-phase-name (phase) (nth phase 1))
    (defn lfr-phase-source-trace (phase) (nth phase 2))
    (defn lfr-phase-measured (phase) (nth phase 3))
    (defn lfr-phase-within-budget (phase) (nth phase 4))
    (defn lfr-phase-contained-or-reversible (phase) (nth phase 5))
    (defn lfr-phase-valid? (phase)
        (if (lfr-phase? phase)
            (and (lfr-nonempty-string? (lfr-phase-name phase))
            (and (lfr-nonempty-string? (lfr-phase-source-trace phase))
            (and (lfr-bit-1? (lfr-phase-measured phase))
            (and (lfr-bit-1? (lfr-phase-within-budget phase))
                 (lfr-bit-1? (lfr-phase-contained-or-reversible phase))))))
            false))

    (defn lfr-component (name material-trace source-trace repairable reusable recyclable toxicity-contained)
        (list "LifecycleFitnessComponent" name material-trace source-trace repairable reusable recyclable toxicity-contained))
    (defn lfr-component? (component)
        (lfr-tagged? component "LifecycleFitnessComponent" 8))
    (defn lfr-component-name (component) (nth component 1))
    (defn lfr-component-material-trace (component) (nth component 2))
    (defn lfr-component-source-trace (component) (nth component 3))
    (defn lfr-component-repairable (component) (nth component 4))
    (defn lfr-component-reusable (component) (nth component 5))
    (defn lfr-component-recyclable (component) (nth component 6))
    (defn lfr-component-toxicity-contained (component) (nth component 7))
    (defn lfr-component-valid? (component)
        (if (lfr-component? component)
            (and (lfr-nonempty-string? (lfr-component-name component))
            (and (lfr-nonempty-string? (lfr-component-material-trace component))
            (and (lfr-nonempty-string? (lfr-component-source-trace component))
            (and (lfr-bit-1? (lfr-component-repairable component))
            (and (lfr-bit-1? (lfr-component-reusable component))
            (and (lfr-bit-1? (lfr-component-recyclable component))
                 (lfr-bit-1? (lfr-component-toxicity-contained component))))))))
            false))
    (defn lfr-components-valid? (components)
        (if (eq (len components) 0)
            true
            (and (lfr-component-valid? (head components))
                 (lfr-components-valid? (tail components)))))

    (defn lfr-lifecycle (materials manufacturing transport energy-production operation maintenance end-of-life components all-parts-declared)
        (list "LifecycleFitnessLifecycle" materials manufacturing transport energy-production operation maintenance end-of-life components all-parts-declared))
    (defn lfr-lifecycle? (lifecycle)
        (lfr-tagged? lifecycle "LifecycleFitnessLifecycle" 10))
    (defn lfr-lifecycle-materials (lifecycle) (nth lifecycle 1))
    (defn lfr-lifecycle-manufacturing (lifecycle) (nth lifecycle 2))
    (defn lfr-lifecycle-transport (lifecycle) (nth lifecycle 3))
    (defn lfr-lifecycle-energy-production (lifecycle) (nth lifecycle 4))
    (defn lfr-lifecycle-operation (lifecycle) (nth lifecycle 5))
    (defn lfr-lifecycle-maintenance (lifecycle) (nth lifecycle 6))
    (defn lfr-lifecycle-end-of-life (lifecycle) (nth lifecycle 7))
    (defn lfr-lifecycle-components (lifecycle) (nth lifecycle 8))
    (defn lfr-lifecycle-all-parts-declared (lifecycle) (nth lifecycle 9))
    (defn lfr-lifecycle-all-parts? (lifecycle)
        (if (lfr-lifecycle? lifecycle)
            (lfr-bit-1? (lfr-lifecycle-all-parts-declared lifecycle))
            false))
    (defn lfr-lifecycle-phases-valid? (lifecycle)
        (if (lfr-lifecycle? lifecycle)
            (and (lfr-phase-valid? (lfr-lifecycle-materials lifecycle))
            (and (lfr-phase-valid? (lfr-lifecycle-manufacturing lifecycle))
            (and (lfr-phase-valid? (lfr-lifecycle-transport lifecycle))
            (and (lfr-phase-valid? (lfr-lifecycle-energy-production lifecycle))
            (and (lfr-phase-valid? (lfr-lifecycle-operation lifecycle))
            (and (lfr-phase-valid? (lfr-lifecycle-maintenance lifecycle))
                 (lfr-phase-valid? (lfr-lifecycle-end-of-life lifecycle))))))))
            false))
    (defn lfr-lifecycle-components-valid? (lifecycle)
        (if (lfr-lifecycle? lifecycle)
            (lfr-components-valid? (lfr-lifecycle-components lifecycle))
            false))
    (defn lfr-lifecycle-valid? (lifecycle)
        (if (lfr-lifecycle? lifecycle)
            (and (lfr-lifecycle-all-parts? lifecycle)
            (and (lfr-lifecycle-phases-valid? lifecycle)
                 (lfr-lifecycle-components-valid? lifecycle)))
            false))

    (defn lfr-ingestion (ingredient-trace dose-known contaminant-safe bioavailable digestion-metabolism-excretion-traced population-boundary stop-boundary)
        (list "LifecycleFitnessIngestion" ingredient-trace dose-known contaminant-safe bioavailable digestion-metabolism-excretion-traced population-boundary stop-boundary))
    (defn lfr-ingestion? (ingestion)
        (lfr-tagged? ingestion "LifecycleFitnessIngestion" 8))
    (defn lfr-ingestion-ingredient-trace (ingestion) (nth ingestion 1))
    (defn lfr-ingestion-dose-known (ingestion) (nth ingestion 2))
    (defn lfr-ingestion-contaminant-safe (ingestion) (nth ingestion 3))
    (defn lfr-ingestion-bioavailable (ingestion) (nth ingestion 4))
    (defn lfr-ingestion-dme-traced (ingestion) (nth ingestion 5))
    (defn lfr-ingestion-population-boundary (ingestion) (nth ingestion 6))
    (defn lfr-ingestion-stop-boundary (ingestion) (nth ingestion 7))
    (defn lfr-ingestion-valid? (ingestion)
        (if (lfr-ingestion? ingestion)
            (and (lfr-nonempty-string? (lfr-ingestion-ingredient-trace ingestion))
            (and (lfr-bit-1? (lfr-ingestion-dose-known ingestion))
            (and (lfr-bit-1? (lfr-ingestion-contaminant-safe ingestion))
            (and (lfr-bit-1? (lfr-ingestion-bioavailable ingestion))
            (and (lfr-bit-1? (lfr-ingestion-dme-traced ingestion))
            (and (lfr-nonempty-string? (lfr-ingestion-population-boundary ingestion))
                 (lfr-nonempty-string? (lfr-ingestion-stop-boundary ingestion))))))))
            false))

    (defn lfr-human-benefit (level outcome evidence-trace molecular-marker measured-pre-post cellular-effect-traced organism-effect-traced third-party-witness safety-monitor exposure-boundary reversible-stop positive-effect)
        (list "LifecycleFitnessHumanBenefit" level outcome evidence-trace molecular-marker measured-pre-post cellular-effect-traced organism-effect-traced third-party-witness safety-monitor exposure-boundary reversible-stop positive-effect))
    (defn lfr-human-benefit? (benefit)
        (lfr-tagged? benefit "LifecycleFitnessHumanBenefit" 13))
    (defn lfr-benefit-level (benefit) (nth benefit 1))
    (defn lfr-benefit-outcome (benefit) (nth benefit 2))
    (defn lfr-benefit-evidence-trace (benefit) (nth benefit 3))
    (defn lfr-benefit-molecular-marker (benefit) (nth benefit 4))
    (defn lfr-benefit-measured-pre-post (benefit) (nth benefit 5))
    (defn lfr-benefit-cellular-effect-traced (benefit) (nth benefit 6))
    (defn lfr-benefit-organism-effect-traced (benefit) (nth benefit 7))
    (defn lfr-benefit-third-party-witness (benefit) (nth benefit 8))
    (defn lfr-benefit-safety-monitor (benefit) (nth benefit 9))
    (defn lfr-benefit-exposure-boundary (benefit) (nth benefit 10))
    (defn lfr-benefit-reversible-stop (benefit) (nth benefit 11))
    (defn lfr-benefit-positive-effect (benefit) (nth benefit 12))
    (defn lfr-benefit-level-molecular? (benefit)
        (if (lfr-human-benefit? benefit)
            (str_eq (lfr-benefit-level benefit) "molecular")
            false))
    (defn lfr-benefit-valid? (benefit)
        (if (lfr-human-benefit? benefit)
            (eq (sum (list
                (lfr-bool-score (lfr-nonempty-string? (lfr-benefit-level benefit)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-benefit-outcome benefit)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-benefit-evidence-trace benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-measured-pre-post benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-cellular-effect-traced benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-organism-effect-traced benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-third-party-witness benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-safety-monitor benefit)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-benefit-exposure-boundary benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-reversible-stop benefit)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-benefit-positive-effect benefit)) 1))) 11)
            false))
    (defn lfr-benefit-molecular-valid? (benefit)
        (and (lfr-benefit-valid? benefit)
        (and (lfr-benefit-level-molecular? benefit)
             (lfr-nonempty-string? (lfr-benefit-molecular-marker benefit)))))

    (defn lfr-substance-effect (substance-id organism-scope condition-scope mechanism-trace molecular-marker cellular-evidence organism-evidence dose-response toxicity-window third-party-witness reversible-stop benefit-observed)
        (list "LifecycleFitnessSubstanceEffect" substance-id organism-scope condition-scope mechanism-trace molecular-marker cellular-evidence organism-evidence dose-response toxicity-window third-party-witness reversible-stop benefit-observed))
    (defn lfr-substance-effect? (effect)
        (lfr-tagged? effect "LifecycleFitnessSubstanceEffect" 13))
    (defn lfr-substance-id (effect) (nth effect 1))
    (defn lfr-substance-organism-scope (effect) (nth effect 2))
    (defn lfr-substance-condition-scope (effect) (nth effect 3))
    (defn lfr-substance-mechanism-trace (effect) (nth effect 4))
    (defn lfr-substance-molecular-marker (effect) (nth effect 5))
    (defn lfr-substance-cellular-evidence (effect) (nth effect 6))
    (defn lfr-substance-organism-evidence (effect) (nth effect 7))
    (defn lfr-substance-dose-response (effect) (nth effect 8))
    (defn lfr-substance-toxicity-window (effect) (nth effect 9))
    (defn lfr-substance-third-party-witness (effect) (nth effect 10))
    (defn lfr-substance-reversible-stop (effect) (nth effect 11))
    (defn lfr-substance-benefit-observed (effect) (nth effect 12))
    (defn lfr-substance-effect-valid? (effect)
        (if (lfr-substance-effect? effect)
            (eq (sum (list
                (lfr-bool-score (lfr-nonempty-string? (lfr-substance-id effect)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-substance-organism-scope effect)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-substance-condition-scope effect)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-substance-mechanism-trace effect)) 1)
                (lfr-bool-score (lfr-nonempty-string? (lfr-substance-molecular-marker effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-cellular-evidence effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-organism-evidence effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-dose-response effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-toxicity-window effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-third-party-witness effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-reversible-stop effect)) 1)
                (lfr-bool-score (lfr-bit-1? (lfr-substance-benefit-observed effect)) 1))) 12)
            false))

    (defn lfr-system-receipt (kind lifecycle ingestion benefit substance-effect claim)
        (list "LifecycleFitnessSystemReceipt" kind lifecycle ingestion benefit substance-effect claim))
    (defn lfr-system-receipt? (receipt)
        (lfr-tagged? receipt "LifecycleFitnessSystemReceipt" 7))
    (defn lfr-receipt-kind (receipt) (nth receipt 1))
    (defn lfr-receipt-lifecycle (receipt) (nth receipt 2))
    (defn lfr-receipt-ingestion (receipt) (nth receipt 3))
    (defn lfr-receipt-benefit (receipt) (nth receipt 4))
    (defn lfr-receipt-substance-effect (receipt) (nth receipt 5))
    (defn lfr-receipt-claim (receipt) (nth receipt 6))

    (defn lfr-claim-machine? (claim)
        (str_eq claim "machine-whole-lifecycle"))
    (defn lfr-claim-nutrition? (claim)
        (str_eq claim "ingestible-nutrition-whole-lifecycle"))
    (defn lfr-claim-robot-molecular? (claim)
        (str_eq claim "robot-molecular-human-benefit"))
    (defn lfr-claim-condition-substance? (claim)
        (str_eq claim "condition-specific-therapeutic-substance"))
    (defn lfr-claim-universal-cure? (claim)
        (str_eq claim "universal-cure-any-condition"))
    (defn lfr-supported-claim? (claim)
        (or (lfr-claim-machine? claim)
        (or (lfr-claim-nutrition? claim)
        (or (lfr-claim-robot-molecular? claim)
            (lfr-claim-condition-substance? claim)))))

    (defn lfr-system-fit? (receipt)
        (if (lfr-system-receipt? receipt)
            (if (not (lfr-lifecycle-valid? (lfr-receipt-lifecycle receipt))) false
            (if (lfr-claim-machine? (lfr-receipt-claim receipt)) true
            (if (lfr-claim-nutrition? (lfr-receipt-claim receipt))
                (lfr-ingestion-valid? (lfr-receipt-ingestion receipt))
            (if (lfr-claim-robot-molecular? (lfr-receipt-claim receipt))
                (lfr-benefit-molecular-valid? (lfr-receipt-benefit receipt))
            (if (lfr-claim-condition-substance? (lfr-receipt-claim receipt))
                (lfr-substance-effect-valid? (lfr-receipt-substance-effect receipt))
                false)))))
            false))

    (defn lfr-refusal-reason (receipt)
        (if (not (lfr-system-receipt? receipt)) "malformed-receipt"
        (if (lfr-claim-universal-cure? (lfr-receipt-claim receipt)) "overbroad-cure-claim"
        (if (not (lfr-supported-claim? (lfr-receipt-claim receipt))) "unsupported-claim"
        (if (not (lfr-lifecycle? (lfr-receipt-lifecycle receipt))) "lifecycle-missing"
        (if (not (lfr-lifecycle-all-parts? (lfr-receipt-lifecycle receipt))) "all-parts-not-declared"
        (if (not (lfr-lifecycle-phases-valid? (lfr-receipt-lifecycle receipt))) "lifecycle-phase-proof-missing"
        (if (not (lfr-lifecycle-components-valid? (lfr-receipt-lifecycle receipt))) "component-trace-missing"
        (if (and (lfr-claim-nutrition? (lfr-receipt-claim receipt)) (not (lfr-ingestion-valid? (lfr-receipt-ingestion receipt)))) "ingestion-proof-missing"
        (if (and (lfr-claim-robot-molecular? (lfr-receipt-claim receipt)) (not (lfr-benefit-molecular-valid? (lfr-receipt-benefit receipt)))) "molecular-benefit-proof-missing"
        (if (and (lfr-claim-condition-substance? (lfr-receipt-claim receipt)) (not (lfr-substance-effect-valid? (lfr-receipt-substance-effect receipt)))) "substance-proof-missing"
            "fit")))))))))))

    0)
