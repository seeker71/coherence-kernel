; sibling-ref-authoring-language.fk -- fixed two-rule sibling-ref authoring rung.
;
; Layer 5 authoring above grammar-authoring-language: one scannerless surface
; writes a domain descriptor and exactly two rules. The first rule has a fixed
; sibling-ref shape; the second rule is leaf-only:
;
;   domain programming family programming-language semantic semantic-stdlib
;     evidence compiler-proof residue syntax-semantic-residue lower form-recipe {
;       pair left number right number -> pair
;       number value digit -> number
;     }
;
; This lowers structurally to `dgcore-domain` plus one BMF grammar value:
; `pair` captures two internally-built refs to the leaf rule `number`.
; The authoring text does not expose `ref`, `alt`, `rep`, or `sep`.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk
;           form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk
;           form-stdlib/domain-grammar-core.fk
;           form-stdlib/grammar-authoring-language.fk

(do
    (defn sral-feature (name status) (list "sibling-ref-authoring-language-feature" name status))
    (defn sral-feature-name (f) (nth f 1))
    (defn sral-feature-status (f) (nth f 2))
    (defn sibling-ref-authoring-language-manifest ()
        (list
            (sral-feature "scannerless" 1)
            (sral-feature "bmf-cursor-grammar" 1)
            (sral-feature "no-line-grammar" 1)
            (sral-feature "no-tokenizer" 1)
            (sral-feature "not-s-expression-surface" 1)
            (sral-feature "not-form-cell-authoring" 1)
            (sral-feature "exactly-two-rules" 1)
            (sral-feature "fixed-sibling-pattern" 1)
            (sral-feature "leaf-second-rule" 1)
            (sral-feature "internal-ref-only" 1)
            (sral-feature "no-general-ref-surface" 1)
            (sral-feature "metadata-only-lanes" 1)
            (sral-feature "grammar-value-lowering" 1)))
    (defn sibling-ref-authoring-language-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (sral-feature-name (head fs)) name)
                     (eq (sral-feature-status (head fs)) 1))
                1
                (sibling-ref-authoring-language-manifest-has? name (tail fs)))))

    (defn sibling-ref-authoring-language-grammar ()
        (grammar "decl" (list
            (rule3 "decl"
                (list "seq"
                    (p-lit "domain")
                    (p-cap "name" (p-ref "token"))
                    (p-lit "family")
                    (p-cap "family" (p-ref "token"))
                    (p-lit "semantic")
                    (p-cap "semantic" (p-ref "token"))
                    (p-lit "evidence")
                    (p-cap "evidence" (p-ref "token"))
                    (p-lit "residue")
                    (p-cap "residue" (p-ref "token"))
                    (p-lit "lower")
                    (p-cap "lower" (p-ref "token"))
                    (p-lit "{")
                    (p-cap "startlit" (p-ref "simple"))
                    (p-cap "leftcap" (p-ref "simple"))
                    (p-cap "leftleaf" (p-ref "simple"))
                    (p-cap "rightcap" (p-ref "simple"))
                    (p-cap "rightleaf" (p-ref "simple"))
                    (p-lit "->")
                    (p-cap "startemit" (p-ref "token"))
                    (p-cap "leaflit" (p-ref "simple"))
                    (p-cap "leafcap" (p-ref "simple"))
                    (p-cap "leafclass" (p-ref "token"))
                    (p-lit "->")
                    (p-cap "leafemit" (p-ref "token"))
                    (p-lit "}"))
                (t-emit "fncall"
                    (list (t-const "__sral_decl__")
                          (t-splice "name")
                          (t-splice "family")
                          (t-splice "semantic")
                          (t-splice "evidence")
                          (t-splice "residue")
                          (t-splice "lower")
                          (t-splice "startlit")
                          (t-splice "leftcap")
                          (t-splice "leftleaf")
                          (t-splice "rightcap")
                          (t-splice "rightleaf")
                          (t-splice "startemit")
                          (t-splice "leaflit")
                          (t-splice "leafcap")
                          (t-splice "leafclass")
                          (t-splice "leafemit"))))
            (rule3 "token"
                (p-cap "v" (p-run "alnum"))
                (t-splice "v"))
            (rule3 "simple"
                (p-cap "v" (p-run "alpha"))
                (t-splice "v")))))

    (defn sral-parse-fail () (intern_trivial_string "PARSE-FAIL"))
    (defn sral-lower-fail () (intern_trivial_string "LOWER-FAIL"))
    (defn sral-ok? (node) (not (value_eq node (sral-parse-fail))))
    (defn sral-lower-ok? (node) (not (value_eq node (sral-lower-fail))))

    (defn sral-parse (src)
        (do
            (let rr (g-match-rule (sibling-ref-authoring-language-grammar) "decl" (cursor-str src)))
            (if (and (rok? rr) (cur-eof? (skip-ws (rok-cur rr))))
                (rok-node rr)
                (sral-parse-fail))))

    (defn sral-child-text (decl i)
        (node_value (nth (node_children decl) i)))
    (defn sral-domain-name (decl) (sral-child-text decl 1))
    (defn sral-family (decl) (sral-child-text decl 2))
    (defn sral-semantic-lane (decl) (sral-child-text decl 3))
    (defn sral-evidence-lane (decl) (sral-child-text decl 4))
    (defn sral-residue-policy (decl) (sral-child-text decl 5))
    (defn sral-lower-target (decl) (sral-child-text decl 6))
    (defn sral-start-literal (decl) (sral-child-text decl 7))
    (defn sral-left-capture (decl) (sral-child-text decl 8))
    (defn sral-left-leaf (decl) (sral-child-text decl 9))
    (defn sral-right-capture (decl) (sral-child-text decl 10))
    (defn sral-right-leaf (decl) (sral-child-text decl 11))
    (defn sral-start-emit (decl) (sral-child-text decl 12))
    (defn sral-leaf-literal (decl) (sral-child-text decl 13))
    (defn sral-leaf-capture (decl) (sral-child-text decl 14))
    (defn sral-leaf-class (decl) (sral-child-text decl 15))
    (defn sral-leaf-emit (decl) (sral-child-text decl 16))

    (defn sral-sibling-refs-match? (decl)
        (and (str_eq (sral-left-leaf decl) (sral-leaf-literal decl))
             (str_eq (sral-right-leaf decl) (sral-leaf-literal decl))))
    (defn sral-rule-names-distinct? (decl)
        (not (str_eq (sral-start-literal decl) (sral-leaf-literal decl))))
    (defn sral-valid? (decl)
        (and (sral-ok? decl)
             (and (sral-sibling-refs-match? decl)
                  (sral-rule-names-distinct? decl))))

    (defn sral-lower-grammar (decl)
        (if (sral-valid? decl)
            (grammar (sral-start-literal decl) (list
                (rule3 (sral-start-literal decl)
                    (list "seq"
                        (p-lit (sral-start-literal decl))
                        (p-cap (sral-left-capture decl) (p-ref (sral-leaf-literal decl)))
                        (p-cap (sral-right-capture decl) (p-ref (sral-leaf-literal decl))))
                    (t-emit "fncall"
                        (list (t-const (gal-emit-tag (sral-start-emit decl)))
                              (t-splice (sral-left-capture decl))
                              (t-splice (sral-right-capture decl)))))
                (rule3 (sral-leaf-literal decl)
                    (list "seq"
                        (p-lit (sral-leaf-literal decl))
                        (p-cap (sral-leaf-capture decl) (p-run (sral-leaf-class decl))))
                    (t-emit "fncall"
                        (list (t-const (gal-emit-tag (sral-leaf-emit decl)))
                              (t-splice (sral-leaf-capture decl)))))))
            (sral-lower-fail)))

    (defn sral-lower-domain (decl)
        (if (sral-valid? decl)
            (dgcore-domain
                (sral-domain-name decl)
                (sral-family decl)
                (sral-lower-grammar decl)
                (sral-semantic-lane decl)
                (sral-evidence-lane decl)
                (sral-residue-policy decl)
                (sral-lower-target decl))
            (sral-lower-fail)))

    (defn sral-register-lowered (decl)
        (if (sral-valid? decl)
            (dgcore-register-domain (gl-empty) (sral-lower-domain decl))
            (gl-empty)))
)
