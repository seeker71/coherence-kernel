; domain-semantic-bridge.fk -- bridge parsed domain ASTs into semantic stdlib.
;
; Layer 6 bridge adjunct: consume a parsed domain AST plus its dgcore-domain
; descriptor, guard on the descriptor's semantic lane, then delegate identified
; surface translation to semantic-stdlib.
;
; This file does not parse raw source text, register grammars, load ontology,
; invoke the source compiler, write artifacts, or grow the C seed.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk
;           form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk
;           form-stdlib/domain-grammar-core.fk form-stdlib/semantic-stdlib.fk

(do
    (defn dsb-feature (name status) (list "domain-semantic-bridge-feature" name status))
    (defn dsb-feature-name (f) (nth f 1))
    (defn dsb-feature-status (f) (nth f 2))
    (defn domain-semantic-bridge-manifest ()
        (list
            (dsb-feature "consumes-parsed-ast" 1)
            (dsb-feature "no-raw-source-parse" 1)
            (dsb-feature "no-tokenizer" 1)
            (dsb-feature "lane-gate-before-ssl" 1)
            (dsb-feature "ssl-delegate-only" 1)
            (dsb-feature "bridge-row-table" 1)
            (dsb-feature "single-row-table-v1" 1)
            (dsb-feature "preserves-domain-metadata" 1)
            (dsb-feature "preserves-node-args" 1)
            (dsb-feature "residue-fidelity-pass-through" 1)
            (dsb-feature "no-ontology" 1)
            (dsb-feature "no-artifact-route" 1)))
    (defn domain-semantic-bridge-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (dsb-feature-name (head fs)) name)
                     (eq (dsb-feature-status (head fs)) 1))
                1
                (domain-semantic-bridge-manifest-has? name (tail fs)))))

    (defn dsb-row (domain-name ast-tag from-lang surface sem-id)
        (list "domain-semantic-row" domain-name ast-tag from-lang surface sem-id))
    (defn dsb-row-domain-name (r) (nth r 1))
    (defn dsb-row-ast-tag (r) (nth r 2))
    (defn dsb-row-from-lang (r) (nth r 3))
    (defn dsb-row-surface (r) (nth r 4))
    (defn dsb-row-sem (r) (nth r 5))
    (defn dsb-missing-row ()
        (dsb-row "missing" "missing" "missing" "missing" 0))
    (defn dsb-row-missing? (r)
        (eq (dsb-row-sem r) 0))

    (defn dsb-rows ()
        (list
            (dsb-row "programming" "__prog_return__" "form" "return" (ssl-return))))

    (defn dsb-find-row (rows domain-name ast-tag)
        (if (nil? rows)
            (dsb-missing-row)
            (if (and (str_eq (dsb-row-domain-name (head rows)) domain-name)
                     (str_eq (dsb-row-ast-tag (head rows)) ast-tag))
                (head rows)
                (dsb-find-row (tail rows) domain-name ast-tag))))

    (defn dsb-node-tag (node) (dgcore-node-tag node))
    (defn dsb-node-args (node) (tail (node_children node)))

    (defn dsb-result
        (domain family semantic-lane evidence-lane residue-policy lower-target
         node-tag args to-lang from-lang source-surface status target-surface
         sem-id fidelity residue)
        (list "domain-semantic-bridge"
              domain
              family
              semantic-lane
              evidence-lane
              residue-policy
              lower-target
              node-tag
              args
              to-lang
              from-lang
              source-surface
              status
              target-surface
              sem-id
              fidelity
              residue))
    (defn dsb-result-kind (r) (nth r 0))
    (defn dsb-result-domain (r) (nth r 1))
    (defn dsb-result-family (r) (nth r 2))
    (defn dsb-result-semantic-lane (r) (nth r 3))
    (defn dsb-result-evidence-lane (r) (nth r 4))
    (defn dsb-result-residue-policy (r) (nth r 5))
    (defn dsb-result-lower-target (r) (nth r 6))
    (defn dsb-result-node-tag (r) (nth r 7))
    (defn dsb-result-args (r) (nth r 8))
    (defn dsb-result-to-lang (r) (nth r 9))
    (defn dsb-result-from-lang (r) (nth r 10))
    (defn dsb-result-source-surface (r) (nth r 11))
    (defn dsb-result-status (r) (nth r 12))
    (defn dsb-result-target-surface (r) (nth r 13))
    (defn dsb-result-sem (r) (nth r 14))
    (defn dsb-result-fidelity (r) (nth r 15))
    (defn dsb-result-residue (r) (nth r 16))
    (defn dsb-result-arg-value (r i)
        (node_value (nth (dsb-result-args r) i)))

    (defn dsb-domain-result (domain node to-lang from-lang source-surface status target-surface sem-id fidelity residue)
        (dsb-result
            (dgcore-domain-name domain)
            (dgcore-domain-family domain)
            (dgcore-domain-semantic-lane domain)
            (dgcore-domain-evidence-lane domain)
            (dgcore-domain-residue-policy domain)
            (dgcore-domain-lower-target domain)
            (dsb-node-tag node)
            (dsb-node-args node)
            to-lang
            from-lang
            source-surface
            status
            target-surface
            sem-id
            fidelity
            residue))

    (defn dsb-semantic-stdlib-lane? (domain)
        (str_eq (dgcore-domain-semantic-lane domain) "semantic-stdlib"))

    (defn dsb-bridge-with-rows (rows domain node to-lang)
        (if (not (dsb-semantic-stdlib-lane? domain))
            (dsb-domain-result domain node to-lang "missing" "missing"
                "semantic-lane-not-stdlib" "missing" 0 0
                (list "semantic-lane-not-stdlib"))
            (do
                (let row (dsb-find-row rows (dgcore-domain-name domain) (dsb-node-tag node)))
                (if (dsb-row-missing? row)
                    (dsb-domain-result domain node to-lang "missing" "missing"
                        "missing-domain-semantic-row" "missing" 0 0
                        (list "missing-domain-semantic-row"))
                    (do
                        (let tr (ssl-translate-result
                                    (dsb-row-from-lang row)
                                    (dsb-row-surface row)
                                    to-lang))
                        (dsb-domain-result domain node to-lang
                            (dsb-row-from-lang row)
                            (dsb-row-surface row)
                            (ssl-result-status tr)
                            (ssl-result-surface tr)
                            (ssl-result-sem tr)
                            (ssl-result-fidelity tr)
                            (ssl-result-residue tr)))))))

    (defn dsb-bridge (domain node to-lang)
        (dsb-bridge-with-rows (dsb-rows) domain node to-lang))
)
