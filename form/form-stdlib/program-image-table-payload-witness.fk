; program-image-table-payload-witness.fk -- file-backed witness for table payload.
;
; This layer packages the Layer 8i table-payload write/readback result as an
; observable witness carrier. It emits the exact table-payload witness row shape
; consumed by the current 9h0 table-payload attempt adapter, but it does not
; import or call 9h0. The shared row tag is data; the band owns the handshake
; proof that the producer and consumer still agree.
;
; `write-readback-failed` deliberately collapses write failure and readback
; mismatch because `pite-write-table-payload` currently returns only 1/0. A future
; 8i return-value enrichment can split that seam.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/form-fs.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/program-image-fkb.fk
;           form-stdlib/program-image-table-payload-emit.fk

(do
    (defn pitw-version () "program-image-table-payload-witness-v1")

    (defn pitw-feature (name status) (list "program-image-table-payload-witness-feature" name status))
    (defn pitw-feature-name (f) (nth f 1))
    (defn pitw-feature-status (f) (nth f 2))
    (defn program-image-table-payload-witness-manifest ()
        (list
            (pitw-feature "table-payload-file-witness-carrier" 1)
            (pitw-feature "uses-pite-write-table-payload" 1)
            (pitw-feature "readback-text-becomes-witness" 1)
            (pitw-feature "witness-row-compatible-with-9h0" 1)
            (pitw-feature "no-witness-sentinel" 1)
            (pitw-feature "invalid-pif-nondestructive" 1)
            (pitw-feature "write-readback-failure-observable" 1)
            (pitw-feature "no-9h0-code-dependency" 1)
            (pitw-feature "no-binary-artifact-io" 1)
            (pitw-feature "no-program-image-load" 1)
            (pitw-feature "no-table-execution" 1)
            (pitw-feature "no-9f-attempt" 1)
            (pitw-feature "no-9c-observation" 1)
            (pitw-feature "no-selector-install" 1)
            (pitw-feature "no-c-seed-growth" 1)))
    (defn program-image-table-payload-witness-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (pitw-feature-name (head fs)) name)
                     (eq (pitw-feature-status (head fs)) 1))
                1
                (program-image-table-payload-witness-manifest-has? name (tail fs)))))

    (defn pitw-status-witness-ready () "witness-ready")
    (defn pitw-status-investigate () "investigate")
    (defn pitw-status-refused () "refused")

    (defn pitw-reason-table-payload-file-witness-ready () "table-payload-file-witness-ready")
    (defn pitw-reason-malformed-pif-envelope () "malformed-pif-envelope")
    (defn pitw-reason-invalid-pif-envelope () "invalid-pif-envelope")
    (defn pitw-reason-empty-table-payload () "empty-table-payload")
    (defn pitw-reason-write-readback-failed () "write-readback-failed")

    (defn pitw-no-witness () (list "program-image-table-payload-no-witness"))
    (defn pitw-no-witness? (w)
        (if (eq (len w) 1)
            (str_eq (nth w 0) "program-image-table-payload-no-witness")
            0))

    ; This is intentionally the same data shape consumed by 9h0.
    (defn pitw-table-payload-witness (table-path table-payload)
        (list "runtime-table-payload-witness" table-path table-payload))
    (defn pitw-table-payload-witness? (w)
        (if (eq (len w) 3)
            (str_eq (nth w 0) "runtime-table-payload-witness")
            0))
    (defn pitw-witness-path (w) (nth w 1))
    (defn pitw-witness-text (w) (nth w 2))

    ; witness = ("program-image-table-payload-file-witness" path pif-envelope
    ;            rendered-table-payload wrote witness status reason)
    (defn pitw-row (path pif-envelope table-payload wrote witness status reason)
        (list "program-image-table-payload-file-witness"
              path pif-envelope table-payload wrote witness status reason))
    (defn pitw-row? (r)
        (if (eq (len r) 8)
            (str_eq (nth r 0) "program-image-table-payload-file-witness")
            0))
    (defn pitw-row-path (r) (nth r 1))
    (defn pitw-row-pif-envelope (r) (nth r 2))
    (defn pitw-row-table-payload (r) (nth r 3))
    (defn pitw-row-wrote (r) (nth r 4))
    (defn pitw-row-witness (r) (nth r 5))
    (defn pitw-row-status (r) (nth r 6))
    (defn pitw-row-reason (r) (nth r 7))

    (defn pitw-ready-row (path pif-envelope rendered readback)
        (pitw-row path
                  pif-envelope
                  rendered
                  1
                  (pitw-table-payload-witness path readback)
                  (pitw-status-witness-ready)
                  (pitw-reason-table-payload-file-witness-ready)))
    (defn pitw-not-ready-row (path pif-envelope table-payload wrote status reason)
        (pitw-row path pif-envelope table-payload wrote (pitw-no-witness) status reason))

    (defn pitw-file-witness-from-envelope (path pif-envelope)
        (if (not (pif-envelope? pif-envelope))
            (pitw-not-ready-row path pif-envelope "" 0 (pitw-status-refused) (pitw-reason-malformed-pif-envelope))
            (if (not (pif-envelope-valid? pif-envelope))
                (pitw-not-ready-row path pif-envelope "" 0 (pitw-status-refused) (pitw-reason-invalid-pif-envelope))
                (do
                    (let rendered (pite-table-payload-from-envelope pif-envelope))
                    (if (eq (str_len rendered) 0)
                        (pitw-not-ready-row path pif-envelope rendered 0 (pitw-status-refused) (pitw-reason-empty-table-payload))
                        (do
                            (let wrote (pite-write-table-payload path pif-envelope))
                            (if (eq wrote 1)
                                (pitw-ready-row path pif-envelope rendered (fs-read-text path))
                                (pitw-not-ready-row path pif-envelope rendered 0 (pitw-status-investigate) (pitw-reason-write-readback-failed)))))))))
)
