; form-cli-ask-gate.fk — the ask verb's POSTERIOR gate: turn THIS run's local
; answer-signals into the accept / retry / escalate decision, composing the
; four-way-proven form-cli-sufficiency.fk.
;
; preludes: form-stdlib/core.fk form-stdlib/form-cli-router.fk form-stdlib/form-cli-judge.fk form-stdlib/form-cli-sufficiency.fk form-stdlib/form-freq-check.fk form-stdlib/trust-row.fk
;
; form-cli-sufficiency.fk reads six signals and returns accept / retry / escalate.
; This is the ask lane's adapter onto it. The old adapter copied one bit into
; path, grounding, and sufficiency and hardcoded frequency to zero. That made the
; row a restatement of the route verdict, not an observation. The current result
; composes four INDEPENDENT readings: who answered, whether the returned NodeID
; resolves and binds this answer, what the frequency sensor actually read, and
; whether the final answer passed the posterior sufficiency gate.
;
; `fca-ask-result` is the carrier boundary. It accepts:
;   native-selected     actual final answer path (1 native / 0 rented)
;   grounding           (valid NodeID shape, typed-export resolution,
;                        query-time persistence binding, answer-content binding)
;   frequency-reading   form-freq-check's measured clear/fear/unknown reading
;   sufficiency-signals six independent posterior quality signals
;
; Proven by: form-stdlib/tests/form-cli-ask-band.fk (four-way at validate.sh)

; ── read the local answer into signals (pure; the carrier hands over the text) ──
; the local lane returns its "[ask: ..." marker when the oracle did not answer.
(defn fca-error-marker? (answer)
    (if (eq (str_find answer "[ask:" 0) 0) 1 0))

; usable: a real answer — non-empty and not the error marker. This is okp.
(defn fca-usable? (answer)
    (if (eq (str_len answer) 0) 0
        (if (eq (fca-error-marker? answer) 1) 0 1)))

; Absence of a content measurement is zero. Merely emitting non-empty text is not
; evidence of substance and must not clear the sufficiency gate by itself.
(defn fca-content-intrinsic (answer)
    0)

; Assemble six independent sufficiency readings. In particular, answer presence
; does not prove shape, and lane confidence does not prove content trust.
(defn fca-ask-signals (has-output shape-ok content confidence trust retries)
    (fsuf-signals has-output shape-ok content confidence trust retries))

; the posterior verdict for this turn: 0 accept (local stands) / 1 retry / 2 escalate
(defn fca-ask-verdict (signals) (fsuf-verdict signals))

; why it ruled that way (0 ok / 1 empty / 2 bad-shape / 3 weak / 4 low-conf / 5 low-trust)
(defn fca-ask-reason (signals) (fsuf-reason signals))

; the three carrier gates over a verdict
(defn fca-ask-accept?   (v) (if (eq v 0) 1 0))
(defn fca-ask-retry?    (v) (if (eq v 1) 1 0))
(defn fca-ask-escalate? (v) (if (eq v 2) 1 0))

; Path is read from the terminal carrier branch, never inferred from sufficiency.
(defn fca-ask-path (native-selected) (if (eq native-selected 1) 1 0))

; Grounding is not a string prefix. The carrier validates an @p.l.t.i shape,
; proves the row was admitted from a substrate-resolved typed export, confirms a
; query-time persistence binding (REF resolves AND current CTOR/source/key match),
; and binds the returned answer to that cell. All four must independently hold.
(defn fca-grounding (nodeid-valid export-resolves persistence-bound answer-bound)
    (list nodeid-valid export-resolves persistence-bound answer-bound))
(defn fca-grounding-nodeid-valid (g) (nth g 0))
(defn fca-grounding-export-resolves (g) (nth g 1))
(defn fca-grounding-persistence-bound (g) (nth g 2))
(defn fca-grounding-answer-bound    (g) (nth g 3))
(defn fca-grounded? (g)
    (if (and (eq (fca-grounding-nodeid-valid g) 1)
             (and (eq (fca-grounding-export-resolves g) 1)
                  (and (eq (fca-grounding-persistence-bound g) 1)
                       (eq (fca-grounding-answer-bound g) 1)))) 1 0))

; result = (path grounded freq suffic observed freq-source verdict reason)
; Every trust signal is computed from its own carrier measurement. `observed` is
; the exact conjunction over those independent results; it cannot be asserted by
; a caller or reconstructed by the shell.
(defn fca-ask-result (native-selected grounding frequency-reading sufficiency-signals)
    (list
        (fca-ask-path native-selected)
        (fca-grounded? grounding)
        (fc-trust-signal frequency-reading)
        (fsuf-sufficient? sufficiency-signals)
        (tr-observed?
            (fca-ask-path native-selected)
            (fca-grounded? grounding)
            (fc-trust-signal frequency-reading)
            (fsuf-sufficient? sufficiency-signals))
        (fc-reading-source-name frequency-reading)
        (fsuf-verdict sufficiency-signals)
        (fsuf-reason sufficiency-signals)))

(defn fca-result-path        (r) (nth r 0))
(defn fca-result-grounded    (r) (nth r 1))
(defn fca-result-frequency   (r) (nth r 2))
(defn fca-result-sufficient  (r) (nth r 3))
(defn fca-result-observed    (r) (nth r 4))
(defn fca-result-freq-source (r) (nth r 5))
(defn fca-result-verdict     (r) (nth r 6))
(defn fca-result-reason      (r) (nth r 7))

; Stable first line emitted by the native ask verb. Consumer wrappers relay this
; row unchanged; they do not infer or overwrite any trust field.
(defn fca-ask-trace-row (result)
    (str_concat
        (tr-row-with-source
            (fca-result-path result)
            (fca-result-grounded result)
            (fca-result-frequency result)
            (fca-result-freq-source result)
            (fca-result-sufficient result))
        (str_concat "  decision:"
        (str_concat (fsuf-verdict-name (fca-result-verdict result))
        (str_concat "  reason:" (fsuf-reason-name (fca-result-reason result)))))))
0
