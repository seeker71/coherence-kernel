; fnri-grammar.fk — fnri command surface as BMF data (cursor, no tokenizer).
;
; witness | resolve <target> <protocol> | know <slug>
; Parses with g-parse / cur-* from bmf-core.fk — not split-on or word lists.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk

(do
    (defn fnri-grammar ()
        (grammar "cmd" (list
            (rule3 "cmd"
                (p-cap "v" (list "alt" (p-ref "witness") (p-ref "resolve") (p-ref "know")))
                (t-splice "v"))
            (rule3 "witness"
                (p-lit "witness")
                (t-emit "fncall" (list (t-const "witness"))))
            (rule3 "resolve"
                (list "seq"
                    (p-lit "resolve")
                    (p-cap "target" (p-ref "word"))
                    (p-cap "proto" (p-ref "word")))
                (t-emit "fncall" (list (t-const "resolve") (t-splice "target") (t-splice "proto"))))
            (rule3 "know"
                (list "seq"
                    (p-lit "know")
                    (p-cap "slug" (p-ref "word")))
                (t-emit "fncall" (list (t-const "know") (t-splice "slug"))))
            (rule3 "word"
                (p-cap "w" (p-run "word"))
                (t-splice "w")))))

    (defn fnri-parse (src) (g-parse (fnri-grammar) src))

    0)
