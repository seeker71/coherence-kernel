; channel-flow.fk — walk consented flow and name channel protocol shape.
;
; preludes: form-stdlib/core.fk form-stdlib/channel-interface.fk form-stdlib/kernel-http.fk
;
; A channel is not "HTTP plus adapters". It is a flow whose offered interfaces,
; invasions, receipts, OSI layers, phase counts, and application policy are all
; visible cells. The flow walker below freezes each request against the receiver's
; current offer. The BML channel profile below names HTTP as one L7 application
; policy carried by a seven-layer channel shape.

(do
    ; --- utterance tags (an act is (list tag payload); a flow is a list of acts) ---
    (defn act-shift   () 0)   ; the other side shifts its offered interface — payload = new offer
    (defn act-request () 1)   ; this side requests a mode — payload = a mode value

    (defn act-tag     (a) (head a))
    (defn act-payload (a) (head (tail a)))

    ; --- walk: thread the other's current offer; count honored vs invasion (witnessed) ---
    ; the receipt is (list honored invasion final-offer) — observable to all who witness.
    (defn cf-walk (flow offer honored invasion)
        (if (eq (len flow) 0)
            (list honored invasion offer)
            (if (eq (act-tag (head flow)) (act-shift))
                (cf-walk (tail flow) (act-payload (head flow)) honored invasion)
                (if (ci-honors? (act-payload (head flow)) offer)
                    (cf-walk (tail flow) offer (add honored 1) invasion)
                    (cf-walk (tail flow) offer honored (add invasion 1))))))

    ; --- the surface: walk a flow from an initial offered interface ---
    (defn channel-flow (flow initial-offer)
        (cf-walk flow initial-offer 0 0))

    ; --- read the receipt ---
    (defn cf-honored     (receipt) (head receipt))
    (defn cf-invasions   (receipt) (head (tail receipt)))
    (defn cf-final-offer (receipt) (head (tail (tail receipt))))

    ; --- bilateral: both sides offer, both request; each direction is gated by the receiver ---
    ; A bilateral act is (list side tag payload); side: A=0, B=1.
    (defn side-a () 0)
    (defn side-b () 1)
    (defn bact-side    (a) (head a))
    (defn bact-tag     (a) (head (tail a)))
    (defn bact-payload (a) (head (tail (tail a))))

    ; receipt = (list honored invasion offer-a offer-b) — totals across both directions.
    (defn cf-walk-bi (flow offer-a offer-b honored invasion)
        (if (eq (len flow) 0)
            (list honored invasion offer-a offer-b)
            (if (eq (bact-side (head flow)) (side-a))
                ; A acts: shift updates A's offer; request is gated by B's offer (A reaches B)
                (if (eq (bact-tag (head flow)) (act-shift))
                    (cf-walk-bi (tail flow) (bact-payload (head flow)) offer-b honored invasion)
                    (if (ci-honors? (bact-payload (head flow)) offer-b)
                        (cf-walk-bi (tail flow) offer-a offer-b (add honored 1) invasion)
                        (cf-walk-bi (tail flow) offer-a offer-b honored (add invasion 1))))
                ; B acts: shift updates B's offer; request is gated by A's offer (B reaches A)
                (if (eq (bact-tag (head flow)) (act-shift))
                    (cf-walk-bi (tail flow) offer-a (bact-payload (head flow)) honored invasion)
                    (if (ci-honors? (bact-payload (head flow)) offer-a)
                        (cf-walk-bi (tail flow) offer-a offer-b (add honored 1) invasion)
                        (cf-walk-bi (tail flow) offer-a offer-b honored (add invasion 1)))))))

    (defn channel-flow-bilateral (flow offer-a offer-b)
        (cf-walk-bi flow offer-a offer-b 0 0))

    (defn cf-bi-offer-a (receipt) (head (tail (tail receipt))))
    (defn cf-bi-offer-b (receipt) (head (tail (tail (tail receipt)))))

    ; Registered Blueprint coordinates from form/user-blueprint-registry.md.
    ; These share one block with the helpers so the fourth-kernel flattener sees
    ; the whole channel-flow function family together.
    (let cf_tag_channel_osi_layer 1702)
    (let cf_tag_channel_flow 1703)

    (defn cf-bool-score (ok score) (if ok score 0))
    (defn cf-tagged? (value tag arity)
        (if (eq (len value) arity) (eq (nth value 0) tag) false))

    (defn cf-phase-gas () "gas")
    (defn cf-phase-water () "water")
    (defn cf-phase-ice () "ice")

    (defn cf-osi-layer (index name phase carrier policy recipe)
        (list cf_tag_channel_osi_layer index name phase carrier policy recipe))
    (defn cf-osi-layer? (layer) (cf-tagged? layer cf_tag_channel_osi_layer 7))
    (defn cf-osi-layer-index (layer) (nth layer 1))
    (defn cf-osi-layer-name (layer) (nth layer 2))
    (defn cf-osi-layer-phase (layer) (nth layer 3))
    (defn cf-osi-layer-carrier (layer) (nth layer 4))
    (defn cf-osi-layer-policy (layer) (nth layer 5))
    (defn cf-osi-layer-recipe (layer) (nth layer 6))
    (defn cf-osi-layer-valid? (layer)
        (if (cf-osi-layer? layer)
            (and (and (ge (cf-osi-layer-index layer) 1)
                      (le (cf-osi-layer-index layer) 7))
                 (and (gt (str_len (cf-osi-layer-name layer)) 0)
                      (gt (str_len (cf-osi-layer-phase layer)) 0)))
            false))

    (defn cf-channel-flow (carrier protocol layers channel-policy)
        (list cf_tag_channel_flow carrier protocol layers channel-policy))
    (defn cf-channel-flow? (flow) (cf-tagged? flow cf_tag_channel_flow 5))
    (defn cf-flow-carrier (flow) (nth flow 1))
    (defn cf-flow-protocol (flow) (nth flow 2))
    (defn cf-flow-layers (flow) (nth flow 3))
    (defn cf-flow-channel-policy (flow) (nth flow 4))

    (defn cf-layers-valid? (layers)
        (if (nil? layers)
            true
            (if (cf-osi-layer-valid? (head layers))
                (cf-layers-valid? (tail layers))
                false)))
    (defn cf-layer-order-valid-from? (layers expected)
        (if (nil? layers)
            (eq expected 8)
            (if (eq (cf-osi-layer-index (head layers)) expected)
                (cf-layer-order-valid-from? (tail layers) (add expected 1))
                false)))
    (defn cf-osi-complete? (flow)
        (if (cf-channel-flow? flow)
            (and (eq (len (cf-flow-layers flow)) 7)
                 (and (cf-layers-valid? (cf-flow-layers flow))
                      (cf-layer-order-valid-from? (cf-flow-layers flow) 1)))
            false))
    (defn cf-channel-flow-valid? (flow)
        (if (cf-channel-flow? flow)
            (and (and (gt (str_len (cf-flow-carrier flow)) 0)
                      (gt (str_len (cf-flow-protocol flow)) 0))
                 (cf-osi-complete? flow))
            false))

    (defn cf-layer-by-index-from (layers index)
        (if (nil? layers)
            (empty)
            (if (eq (cf-osi-layer-index (head layers)) index)
                (head layers)
                (cf-layer-by-index-from (tail layers) index))))
    (defn cf-layer-by-index (flow index)
        (cf-layer-by-index-from (cf-flow-layers flow) index))
    (defn cf-flow-physical-layer (flow) (cf-layer-by-index flow 1))
    (defn cf-flow-data-link-layer (flow) (cf-layer-by-index flow 2))
    (defn cf-flow-network-layer (flow) (cf-layer-by-index flow 3))
    (defn cf-flow-transport-layer (flow) (cf-layer-by-index flow 4))
    (defn cf-flow-session-layer (flow) (cf-layer-by-index flow 5))
    (defn cf-flow-presentation-layer (flow) (cf-layer-by-index flow 6))
    (defn cf-flow-application-layer (flow) (cf-layer-by-index flow 7))

    (defn cf-layer-count-phase (layers phase)
        (if (nil? layers)
            0
            (add
                (if (str_eq (cf-osi-layer-phase (head layers)) phase) 1 0)
                (cf-layer-count-phase (tail layers) phase))))
    (defn cf-flow-gas-count (flow)
        (cf-layer-count-phase (cf-flow-layers flow) (cf-phase-gas)))
    (defn cf-flow-water-count (flow)
        (cf-layer-count-phase (cf-flow-layers flow) (cf-phase-water)))
    (defn cf-flow-ice-count (flow)
        (cf-layer-count-phase (cf-flow-layers flow) (cf-phase-ice)))

    (defn cf-layer-phase-code (layer)
        (if (str_eq (cf-osi-layer-phase layer) (cf-phase-ice))
            3
            (if (str_eq (cf-osi-layer-phase layer) (cf-phase-water))
                2
                (if (str_eq (cf-osi-layer-phase layer) (cf-phase-gas)) 1 0))))
    (defn cf-flow-phase-signature-from (layers)
        (if (nil? layers)
            ""
            (str_concat
                (int_to_str (cf-layer-phase-code (head layers)))
                (cf-flow-phase-signature-from (tail layers)))))
    (defn cf-flow-phase-signature (flow)
        (cf-flow-phase-signature-from (cf-flow-layers flow)))

    (defn cf-http-osi-layers ()
        (list
            (cf-osi-layer 1 "physical" (cf-phase-gas) "tcp-socket" "socket-open" "socket-listen-accept-recv-send-close")
            (cf-osi-layer 2 "data-link" (cf-phase-ice) ".fkb-frame" "content-addressed-frame" "read-form-binary-write-form-binary")
            (cf-osi-layer 3 "network" (cf-phase-water) "nodeid-address" "blueprint-coordinate-routing" "route-by-blueprint")
            (cf-osi-layer 4 "transport" (cf-phase-water) "tcp" "delivery-policy" "recv-send-loop")
            (cf-osi-layer 5 "session" (cf-phase-water) "session-cell" "session-policy" "session-state")
            (cf-osi-layer 6 "presentation" (cf-phase-ice) "bmf-codec" "grammar-lens-policy" "parse-render-codec")
            (cf-osi-layer 7 "application" (cf-phase-water) "http/1.1" "kh-channel-policy" "kh-serve")))

    (defn cf-http-channel-flow ()
        (cf-channel-flow
            "tcp"
            "http/1.1"
            (cf-http-osi-layers)
            (kh-default-channel-policy)))
    (defn cf-flow-http-policy-valid? (flow)
        (if (cf-channel-flow-valid? flow)
            (kh-channel-policy-valid? (cf-flow-channel-policy flow))
            false))
    (defn cf-flow-allow-header (flow)
        (kh-policy-allow-header-value (cf-flow-channel-policy flow)))

    0)
