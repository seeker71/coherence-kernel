; mesh-parallel-life.fk - parallel executable life-mesh lanes.
;
; The previous physical mesh layers made cells, organisms, hardware profiles,
; organs, substrate layers, and node exchange executable. This layer binds the
; remaining missing concepts into parallel lanes: power/nutrient leases,
; delivery lifecycle, role contracts, activation, recognition, care, vitality
; impact, retention policy, and Earth-scale rollup. Each lane can prove alone;
; the parallel state proves they can all run together through the same membrane.

(do
    (defn mpl-all3 (a b c)
        (and a (and b c)))
    (defn mpl-all4 (a b c d)
        (and (and a b) (and c d)))
    (defn mpl-all5 (a b c d e)
        (and (and a b) (and c (and d e))))
    (defn mpl-all6 (a b c d e f)
        (and (and a b) (and c (and d (and e f)))))
    (defn mpl-all9 (a b c d e f g h i)
        (and (and (and a b) (and c d)) (and (and e f) (and g (and h i)))))
    (defn mpl-all10 (a b c d e f g h i j)
        (and (mpl-all5 a b c d e) (mpl-all5 f g h i j)))

    ; --- power / nutrient economy -----------------------------------------
    ; harvested/offered/requested/delivered are integer energy units.
    (defn mpl-power-lease (lease-id provider requester source harvested offered requested delivered remote consent lease-active proximity thermal-ok harvest-consent receipt)
        (list lease-id provider requester source harvested offered requested delivered remote consent lease-active proximity thermal-ok harvest-consent receipt))
    (defn mpl-power-id       (p) (nth p 0))
    (defn mpl-power-provider (p) (nth p 1))
    (defn mpl-power-requester (p) (nth p 2))
    (defn mpl-power-source   (p) (nth p 3))
    (defn mpl-power-harvested (p) (nth p 4))
    (defn mpl-power-offered  (p) (nth p 5))
    (defn mpl-power-requested (p) (nth p 6))
    (defn mpl-power-delivered (p) (nth p 7))
    (defn mpl-power-remote   (p) (nth p 8))
    (defn mpl-power-consent  (p) (nth p 9))
    (defn mpl-power-active   (p) (nth p 10))
    (defn mpl-power-proximity (p) (nth p 11))
    (defn mpl-power-thermal  (p) (nth p 12))
    (defn mpl-power-harvest-consent (p) (nth p 13))
    (defn mpl-power-receipt  (p) (nth p 14))

    (defn mpl-remote-power-consented? (p)
        (if (eq (mpl-power-remote p) 1) (mpl-power-consent p) 1))
    (defn mpl-harvest-consented? (p)
        (if (str_eq (mpl-power-source p) "environment") (mpl-power-harvest-consent p) 1))
    (defn mpl-power-deliverable? (p)
        (if (mpl-all9
                (eq (mpl-power-receipt p) 1)
                (eq (mpl-power-active p) 1)
                (eq (mpl-remote-power-consented? p) 1)
                (eq (mpl-harvest-consented? p) 1)
                (eq (mpl-power-proximity p) 1)
                (eq (mpl-power-thermal p) 1)
                (ge (mpl-power-harvested p) (mpl-power-delivered p))
                (ge (mpl-power-offered p) (mpl-power-requested p))
                (ge (mpl-power-delivered p) (mpl-power-requested p)))
            1 0))

    ; --- physical delivery lifecycle --------------------------------------
    (defn mpl-delivery-cycle (cycle-id organism cell phase consent entered sensed exit-path retrieved biodegraded receipt)
        (list cycle-id organism cell phase consent entered sensed exit-path retrieved biodegraded receipt))
    (defn mpl-delivery-id       (d) (nth d 0))
    (defn mpl-delivery-organism (d) (nth d 1))
    (defn mpl-delivery-cell     (d) (nth d 2))
    (defn mpl-delivery-phase    (d) (nth d 3))
    (defn mpl-delivery-consent  (d) (nth d 4))
    (defn mpl-delivery-entered  (d) (nth d 5))
    (defn mpl-delivery-sensed   (d) (nth d 6))
    (defn mpl-delivery-exit     (d) (nth d 7))
    (defn mpl-delivery-retrieved (d) (nth d 8))
    (defn mpl-delivery-biodegraded (d) (nth d 9))
    (defn mpl-delivery-receipt  (d) (nth d 10))
    (defn mpl-delivery-closed? (d)
        (if (str_eq (mpl-delivery-phase d) "closed")
            (if (eq (mpl-delivery-exit d) 1)
                1
                (if (eq (mpl-delivery-retrieved d) 1) 1 (mpl-delivery-biodegraded d)))
            0))
    (defn mpl-delivery-complete? (d)
        (if (mpl-all6
                (eq (mpl-delivery-receipt d) 1)
                (eq (mpl-delivery-consent d) 1)
                (eq (om-admissible? (mpl-delivery-organism d) (mpl-delivery-cell d)) 1)
                (eq (mpl-delivery-entered d) 1)
                (eq (mpl-delivery-sensed d) 1)
                (eq (mpl-delivery-closed? d) 1))
            1 0))

    ; --- role-specific cell contracts -------------------------------------
    (defn mpl-known-roles ()
        (list "sensor" "nutrient" "memory" "predictor" "reporter" "researcher" "explorer" "scout" "caregiver" "sage" "wizard" "shepherd"))
    (defn mpl-string-member? (needle xs)
        (if (eq (len xs) 0)
            0
            (if (str_eq needle (head xs)) 1 (mpl-string-member? needle (tail xs)))))
    (defn mpl-role-known? (role)
        (mpl-string-member? role (mpl-known-roles)))

    (defn mpl-role-contract (role offers requests refuses contributes privacy-ceiling power-budget receipt)
        (list role offers requests refuses contributes privacy-ceiling power-budget receipt))
    (defn mpl-role-name      (r) (nth r 0))
    (defn mpl-role-offers    (r) (nth r 1))
    (defn mpl-role-requests  (r) (nth r 2))
    (defn mpl-role-refuses   (r) (nth r 3))
    (defn mpl-role-contributes (r) (nth r 4))
    (defn mpl-role-privacy   (r) (nth r 5))
    (defn mpl-role-power     (r) (nth r 6))
    (defn mpl-role-receipt   (r) (nth r 7))
    (defn mpl-role-executable? (r)
        (if (mpl-all5
                (eq (mpl-role-receipt r) 1)
                (eq (mpl-role-known? (mpl-role-name r)) 1)
                (gt (len (mpl-role-offers r)) 0)
                (gt (len (mpl-role-contributes r)) 0)
                (not (gt (mpl-role-privacy r) 2)))
            1 0))

    ; --- recognition by multiple means ------------------------------------
    (defn mpl-recognition (proximity internal-known shared-history shared-shape shared-offerings challenge-ok receipt)
        (list proximity internal-known shared-history shared-shape shared-offerings challenge-ok receipt))
    (defn mpl-rec-proximity (r) (nth r 0))
    (defn mpl-rec-internal  (r) (nth r 1))
    (defn mpl-rec-history   (r) (nth r 2))
    (defn mpl-rec-shape     (r) (nth r 3))
    (defn mpl-rec-offerings (r) (nth r 4))
    (defn mpl-rec-challenge (r) (nth r 5))
    (defn mpl-rec-receipt   (r) (nth r 6))
    (defn mpl-recognition-score (r)
        (add (mpl-rec-proximity r)
             (add (mpl-rec-internal r)
                  (add (mpl-rec-history r)
                       (add (mpl-rec-shape r) (mpl-rec-offerings r))))))
    (defn mpl-recognized? (r floor)
        (if (and (eq (mpl-rec-receipt r) 1)
                 (and (eq (mpl-rec-challenge r) 1)
                      (ge (mpl-recognition-score r) floor)))
            1 0))

    ; --- activation loop ---------------------------------------------------
    (defn mpl-activation (ask-id offer-id status offer-fit ask-fit confidence consent vitality trusted-cells quorum shared-goal open-channels receipt)
        (list ask-id offer-id status offer-fit ask-fit confidence consent vitality trusted-cells quorum shared-goal open-channels receipt))
    (defn mpl-act-status      (a) (nth a 2))
    (defn mpl-act-offer-fit   (a) (nth a 3))
    (defn mpl-act-ask-fit     (a) (nth a 4))
    (defn mpl-act-confidence  (a) (nth a 5))
    (defn mpl-act-consent     (a) (nth a 6))
    (defn mpl-act-vitality    (a) (nth a 7))
    (defn mpl-act-trusted     (a) (nth a 8))
    (defn mpl-act-quorum      (a) (nth a 9))
    (defn mpl-act-goal        (a) (nth a 10))
    (defn mpl-act-channels    (a) (nth a 11))
    (defn mpl-act-receipt     (a) (nth a 12))
    (defn mpl-activation-ready? (a recognition recognition-floor)
        (if (mpl-all5
                (eq (mpl-act-receipt a) 1)
                (str_eq (mpl-act-status a) "ready")
                (eq (mpl-recognized? recognition recognition-floor) 1)
                (eq (mcd-resonance-active? (mpl-act-offer-fit a) (mpl-act-ask-fit a) (mpl-act-confidence a) (mpl-act-consent a) (mpl-act-vitality a)) 1)
                (eq (mcd-cohesion-active? (mpl-act-trusted a) (mpl-act-quorum a) (mpl-act-goal a) (mpl-act-channels a)) 1))
            1 0))

    ; --- care / action workflow -------------------------------------------
    (defn mpl-care-loop (observed predicted consent recommended acted verified learned reported receipt)
        (list observed predicted consent recommended acted verified learned reported receipt))
    (defn mpl-care-observed    (c) (nth c 0))
    (defn mpl-care-predicted   (c) (nth c 1))
    (defn mpl-care-consent     (c) (nth c 2))
    (defn mpl-care-recommended (c) (nth c 3))
    (defn mpl-care-acted       (c) (nth c 4))
    (defn mpl-care-verified    (c) (nth c 5))
    (defn mpl-care-learned     (c) (nth c 6))
    (defn mpl-care-reported    (c) (nth c 7))
    (defn mpl-care-receipt     (c) (nth c 8))
    (defn mpl-care-complete? (c)
        (if (mpl-all9
                (eq (mpl-care-receipt c) 1)
                (eq (mpl-care-observed c) 1)
                (eq (mpl-care-predicted c) 1)
                (eq (mpl-care-consent c) 1)
                (eq (mpl-care-recommended c) 1)
                (eq (mpl-care-acted c) 1)
                (eq (mpl-care-verified c) 1)
                (eq (mpl-care-learned c) 1)
                (eq (mpl-care-reported c) 1))
            1 0))

    ; --- vitality impact feedback -----------------------------------------
    (defn mpl-vitality-impact (subject before after confidence receipt)
        (list subject before after confidence receipt))
    (defn mpl-vit-before     (v) (nth v 1))
    (defn mpl-vit-after      (v) (nth v 2))
    (defn mpl-vit-confidence (v) (nth v 3))
    (defn mpl-vit-receipt    (v) (nth v 4))
    (defn mpl-vitality-improved? (v)
        (if (and (eq (mpl-vit-receipt v) 1)
                 (and (gt (mpl-vit-after v) (mpl-vit-before v))
                      (ge (mpl-vit-confidence v) 70)))
            1 0))

    ; --- substrate retention and promotion policy -------------------------
    (defn mpl-retention-policy (policy-id layer ttl revocable deidentified steward-scoped aggregate max-privacy content receipt)
        (list policy-id layer ttl revocable deidentified steward-scoped aggregate max-privacy content receipt))
    (defn mpl-ret-layer      (p) (nth p 1))
    (defn mpl-ret-ttl        (p) (nth p 2))
    (defn mpl-ret-revocable  (p) (nth p 3))
    (defn mpl-ret-deidentified (p) (nth p 4))
    (defn mpl-ret-steward    (p) (nth p 5))
    (defn mpl-ret-aggregate  (p) (nth p 6))
    (defn mpl-ret-privacy    (p) (nth p 7))
    (defn mpl-ret-content    (p) (nth p 8))
    (defn mpl-ret-receipt    (p) (nth p 9))
    (defn mpl-research-policy? (p)
        (if (str_eq (col-layer-name (mpl-ret-layer p)) "research")
            (if (and (eq (mpl-ret-deidentified p) 1)
                     (eq (mpl-ret-aggregate p) 1))
                1 0)
            1))
    (defn mpl-retention-safe? (p)
        (if (and (eq (mpl-ret-receipt p) 1)
                 (and (gt (mpl-ret-ttl p) 0)
                      (and (eq (mpl-ret-revocable p) 1)
                           (and (eq (mpl-ret-steward p) 1)
                                (and (eq (col-layer-valid? (mpl-ret-layer p)) 1)
                                     (and (eq (col-content-safe? (mpl-ret-content p) (mpl-ret-privacy p) 4096) 1)
                                          (eq (mpl-research-policy? p) 1)))))))
            1 0))

    ; --- Earth-awareness aggregation --------------------------------------
    (defn mpl-earth-rollup (rollup-id field local-receipts priority open-request receipt)
        (list rollup-id field local-receipts priority open-request receipt))
    (defn mpl-earth-field    (e) (nth e 1))
    (defn mpl-earth-local    (e) (nth e 2))
    (defn mpl-earth-priority (e) (nth e 3))
    (defn mpl-earth-open     (e) (nth e 4))
    (defn mpl-earth-receipt  (e) (nth e 5))
    (defn mpl-earth-actionable? (e)
        (if (and (eq (mpl-earth-receipt e) 1)
                 (and (eq (om-earth-awareness-surface? (mpl-earth-field e)) 1)
                      (and (ge (mpl-earth-local e) 10)
                           (and (ge (mpl-earth-priority e) 60)
                                (eq (mpl-earth-open e) 1)))))
            1 0))

    ; --- parallel state ----------------------------------------------------
    (defn mpl-parallel-state (power delivery role recognition activation care vitality retention earth offer request channel min-bps)
        (list power delivery role recognition activation care vitality retention earth offer request channel min-bps))
    (defn mpl-ps-power      (s) (nth s 0))
    (defn mpl-ps-delivery   (s) (nth s 1))
    (defn mpl-ps-role       (s) (nth s 2))
    (defn mpl-ps-recognition (s) (nth s 3))
    (defn mpl-ps-activation (s) (nth s 4))
    (defn mpl-ps-care       (s) (nth s 5))
    (defn mpl-ps-vitality   (s) (nth s 6))
    (defn mpl-ps-retention  (s) (nth s 7))
    (defn mpl-ps-earth      (s) (nth s 8))
    (defn mpl-ps-offer      (s) (nth s 9))
    (defn mpl-ps-request    (s) (nth s 10))
    (defn mpl-ps-channel    (s) (nth s 11))
    (defn mpl-ps-min-bps    (s) (nth s 12))

    (defn mpl-parallel-executable? (s recognition-floor)
        (if (mpl-all10
                (eq (mpl-power-deliverable? (mpl-ps-power s)) 1)
                (eq (mpl-delivery-complete? (mpl-ps-delivery s)) 1)
                (eq (mpl-role-executable? (mpl-ps-role s)) 1)
                (eq (mpl-recognized? (mpl-ps-recognition s) recognition-floor) 1)
                (eq (mpl-activation-ready? (mpl-ps-activation s) (mpl-ps-recognition s) recognition-floor) 1)
                (eq (mpl-care-complete? (mpl-ps-care s)) 1)
                (eq (mpl-vitality-improved? (mpl-ps-vitality s)) 1)
                (eq (mpl-retention-safe? (mpl-ps-retention s)) 1)
                (eq (mpl-earth-actionable? (mpl-ps-earth s)) 1)
                (eq (nx-deliverable? (mpl-ps-offer s) (mpl-ps-request s) (mpl-ps-channel s) (mpl-ps-min-bps s)) 1))
            1 0))

    0)
