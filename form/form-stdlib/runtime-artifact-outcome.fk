; runtime-artifact-outcome.fk -- Layer 9c outcome observation face.
;
; This layer consumes Layer 9b `ras-selection` rows and synthetic future
; runner observation rows. It normalizes outcomes, but it does not load or walk
; `.fkb`, load or call `.dylib`, bind symbols, execute native bytes, generate
; real observations, run fallbacks, reselect retries, reverify proof/callable
; receipts, decide source-runner admission, or grow the C seed.
;
; Outcome matrix:
;   selected, no observation        -> pending-observation
;   selected + ok                   -> complete
;   selected + loader-missing/error -> fallback-available only if fallback exists
;   selected + hard status          -> investigate
;   selected + unknown status       -> investigate
;   action mismatch                 -> investigate
;   selector investigate/refused    -> propagate terminal status
;   malformed selection             -> refused
;   selected + malformed observation -> refused
;
; Hard statuses are oom-killed, killed, stalled, timeout, and wrong-value.
; `fallback-available` records a possible fallback; it is not fallback
; execution or proof that the fallback succeeded.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/runtime-artifact-selector.fk

(do
    (defn rao-feature (name status) (list "runtime-artifact-outcome-feature" name status))
    (defn rao-feature-name (f) (nth f 1))
    (defn rao-feature-status (f) (nth f 2))
    (defn runtime-artifact-outcome-manifest ()
        (list
            (rao-feature "outcome-face-not-execution" 1)
            (rao-feature "consumes-ras-selection-only" 1)
            (rao-feature "consumes-synthetic-observations-only" 1)
            (rao-feature "total-outcome-row" 1)
            (rao-feature "terminal-selection-propagates" 1)
            (rao-feature "selected-pending-without-observation" 1)
            (rao-feature "soft-failure-fallback-available-only" 1)
            (rao-feature "hard-observation-investigates" 1)
            (rao-feature "unknown-observation-investigates" 1)
            (rao-feature "action-mismatch-investigates" 1)
            (rao-feature "no-automatic-fallback-execution" 1)
            (rao-feature "no-rap-plan-or-descriptor-consumption" 1)
            (rao-feature "no-runtime-load-walk-call-exec" 1)
            (rao-feature "no-seal-proof-callable-admission" 1)
            (rao-feature "no-c-seed-growth-or-selector-install" 1)
            (rao-feature "no-reselection-retry-or-real-observation-generation" 1)))
    (defn runtime-artifact-outcome-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (rao-feature-name (head fs)) name)
                     (eq (rao-feature-status (head fs)) 1))
                1
                (runtime-artifact-outcome-manifest-has? name (tail fs)))))

    (defn rao-action-none () "none")
    (defn rao-route-unknown () "unknown-route")
    (defn rao-detail-none () "")
    (defn rao-code-none () 0)

    (defn rao-obs-none () "none")
    (defn rao-obs-ok () "ok")
    (defn rao-obs-loader-missing () "loader-missing")
    (defn rao-obs-error () "error")
    (defn rao-obs-oom-killed () "oom-killed")
    (defn rao-obs-killed () "killed")
    (defn rao-obs-stalled () "stalled")
    (defn rao-obs-timeout () "timeout")
    (defn rao-obs-wrong-value () "wrong-value")

    (defn rao-status-complete () "complete")
    (defn rao-status-fallback-available () "fallback-available")
    (defn rao-status-investigate () "investigate")
    (defn rao-status-refused () "refused")
    (defn rao-status-pending-observation () "pending-observation")

    (defn rao-reason-pending-observation () "pending-observation")
    (defn rao-reason-observation-ok () "observation-ok")
    (defn rao-reason-soft-failure-fallback-available () "soft-failure-fallback-available")
    (defn rao-reason-soft-failure-no-fallback () "soft-failure-no-fallback")
    (defn rao-reason-hard-observation-investigates () "hard-observation-investigates")
    (defn rao-reason-unknown-observation-status () "unknown-observation-status")
    (defn rao-reason-observation-action-mismatch () "observation-action-mismatch")
    (defn rao-reason-selector-investigate () "selector-investigate")
    (defn rao-reason-selector-refused () "selector-refused")
    (defn rao-reason-terminal-observation-ignored () "terminal-observation-ignored")
    (defn rao-reason-unknown-selection-status () "unknown-selection-status")
    (defn rao-reason-malformed-selection () "malformed-selection")
    (defn rao-reason-malformed-observation () "malformed-observation")

    ; observation = ("runtime-artifact-run-observation" action status detail code)
    (defn rao-run-observation (action status detail code)
        (list "runtime-artifact-run-observation" action status detail code))
    (defn rao-run-observation? (o)
        (if (eq (len o) 5)
            (str_eq (nth o 0) "runtime-artifact-run-observation")
            0))
    (defn rao-observation-action (o) (nth o 1))
    (defn rao-observation-status (o) (nth o 2))
    (defn rao-observation-detail (o) (nth o 3))
    (defn rao-observation-code (o) (nth o 4))

    ; outcome = ("runtime-artifact-outcome" route attempted fallback
    ;            selection-status outcome-status observation-status
    ;            selection-reason outcome-reason detail code)
    (defn rao-outcome (route attempted fallback selection-status outcome-status observation-status selection-reason outcome-reason detail code)
        (list "runtime-artifact-outcome" route attempted fallback
              selection-status outcome-status observation-status
              selection-reason outcome-reason detail code))
    (defn rao-outcome? (o)
        (if (eq (len o) 11)
            (str_eq (nth o 0) "runtime-artifact-outcome")
            0))
    (defn rao-outcome-route (o) (nth o 1))
    (defn rao-outcome-attempted (o) (nth o 2))
    (defn rao-outcome-fallback (o) (nth o 3))
    (defn rao-outcome-selection-status (o) (nth o 4))
    (defn rao-outcome-status (o) (nth o 5))
    (defn rao-outcome-observation-status (o) (nth o 6))
    (defn rao-outcome-selection-reason (o) (nth o 7))
    (defn rao-outcome-reason (o) (nth o 8))
    (defn rao-outcome-detail (o) (nth o 9))
    (defn rao-outcome-code (o) (nth o 10))

    (defn rao-selection-row? (s)
        (if (eq (len s) 8)
            (str_eq (nth s 0) "runtime-artifact-selection")
            0))
    (defn rao-selection-status-known? (s)
        (if (str_eq (ras-selection-status s) (ras-status-selected))
            1
            (if (str_eq (ras-selection-status s) (ras-status-investigate))
                1
                (if (str_eq (ras-selection-status s) (ras-status-refused)) 1 0))))
    (defn rao-selection-readable? (s)
        (if (rao-selection-row? s)
            (rao-selection-status-known? s)
            0))
    (defn rao-selection-selected? (s)
        (if (rao-selection-row? s)
            (str_eq (ras-selection-status s) (ras-status-selected))
            0))
    (defn rao-selection-investigate? (s)
        (if (rao-selection-row? s)
            (str_eq (ras-selection-status s) (ras-status-investigate))
            0))
    (defn rao-selection-refused? (s)
        (if (rao-selection-row? s)
            (str_eq (ras-selection-status s) (ras-status-refused))
            0))
    (defn rao-fallback-present? (s)
        (if (str_eq (ras-selection-fallback s) (rao-action-none)) 0 1))
    (defn rao-hard-status? (status)
        (if (str_eq status (rao-obs-oom-killed))
            1
            (if (str_eq status (rao-obs-killed))
                1
                (if (str_eq status (rao-obs-stalled))
                    1
                    (if (str_eq status (rao-obs-timeout))
                        1
                        (if (str_eq status (rao-obs-wrong-value)) 1 0))))))
    (defn rao-soft-status? (status)
        (if (str_eq status (rao-obs-loader-missing))
            1
            (if (str_eq status (rao-obs-error)) 1 0)))

    (defn rao-refused-selection-row ()
        (rao-outcome (rao-route-unknown)
                     (rao-action-none)
                     (rao-action-none)
                     (ras-status-refused)
                     (rao-status-refused)
                     (rao-obs-none)
                     (rao-reason-malformed-selection)
                     (rao-reason-malformed-selection)
                     (rao-detail-none)
                     (rao-code-none)))
    (defn rao-refused-observation-row (s)
        (rao-outcome (ras-selection-route s)
                     (ras-selection-selected s)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (rao-status-refused)
                     (rao-obs-none)
                     (ras-selection-reason s)
                     (rao-reason-malformed-observation)
                     (rao-detail-none)
                     (rao-code-none)))
    (defn rao-pending-row (s)
        (rao-outcome (ras-selection-route s)
                     (ras-selection-selected s)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (rao-status-pending-observation)
                     (rao-obs-none)
                     (ras-selection-reason s)
                     (rao-reason-pending-observation)
                     (rao-detail-none)
                     (rao-code-none)))
    (defn rao-terminal-row (s reason observation-status)
        (rao-outcome (ras-selection-route s)
                     (ras-selection-selected s)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (if (rao-selection-investigate? s)
                         (rao-status-investigate)
                         (rao-status-refused))
                     observation-status
                     (ras-selection-reason s)
                     reason
                     (rao-detail-none)
                     (rao-code-none)))
    (defn rao-complete-row (s o)
        (rao-outcome (ras-selection-route s)
                     (rao-observation-action o)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (rao-status-complete)
                     (rao-observation-status o)
                     (ras-selection-reason s)
                     (rao-reason-observation-ok)
                     (rao-observation-detail o)
                     (rao-observation-code o)))
    (defn rao-fallback-row (s o)
        (rao-outcome (ras-selection-route s)
                     (rao-observation-action o)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (rao-status-fallback-available)
                     (rao-observation-status o)
                     (ras-selection-reason s)
                     (rao-reason-soft-failure-fallback-available)
                     (rao-observation-detail o)
                     (rao-observation-code o)))
    (defn rao-investigate-row (s o reason)
        (rao-outcome (ras-selection-route s)
                     (rao-observation-action o)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (rao-status-investigate)
                     (rao-observation-status o)
                     (ras-selection-reason s)
                     reason
                     (rao-observation-detail o)
                     (rao-observation-code o)))
    (defn rao-investigate-selection-row (s reason)
        (rao-outcome (ras-selection-route s)
                     (ras-selection-selected s)
                     (ras-selection-fallback s)
                     (ras-selection-status s)
                     (rao-status-investigate)
                     (rao-obs-none)
                     (ras-selection-reason s)
                     reason
                     (rao-detail-none)
                     (rao-code-none)))

    (defn rao-outcome-from-selected-observation (s o)
        (if (eq (rao-run-observation? o) 1)
            (if (str_eq (rao-observation-action o) (ras-selection-selected s))
                (if (str_eq (rao-observation-status o) (rao-obs-ok))
                    (rao-complete-row s o)
                    (if (eq (rao-hard-status? (rao-observation-status o)) 1)
                        (rao-investigate-row s o (rao-reason-hard-observation-investigates))
                        (if (eq (rao-soft-status? (rao-observation-status o)) 1)
                            (if (eq (rao-fallback-present? s) 1)
                                (rao-fallback-row s o)
                                (rao-investigate-row s o (rao-reason-soft-failure-no-fallback)))
                            (rao-investigate-row s o (rao-reason-unknown-observation-status)))))
                (rao-investigate-row s o (rao-reason-observation-action-mismatch)))
            (rao-refused-observation-row s)))

    (defn rao-outcome-from-selection (s)
        (if (eq (rao-selection-readable? s) 1)
            (if (rao-selection-selected? s)
                (rao-pending-row s)
                (if (rao-selection-investigate? s)
                    (rao-terminal-row s (rao-reason-selector-investigate) (rao-obs-none))
                    (rao-terminal-row s (rao-reason-selector-refused) (rao-obs-none))))
            (if (eq (rao-selection-row? s) 1)
                (rao-investigate-selection-row s (rao-reason-unknown-selection-status))
                (rao-refused-selection-row))))

    (defn rao-outcome-from-selection-observation (s o)
        (if (eq (rao-selection-readable? s) 1)
            (if (rao-selection-selected? s)
                (rao-outcome-from-selected-observation s o)
                (if (eq (rao-run-observation? o) 1)
                    (rao-terminal-row s (rao-reason-terminal-observation-ignored) (rao-observation-status o))
                    (rao-terminal-row s (rao-reason-terminal-observation-ignored) (rao-obs-none))))
            (if (eq (rao-selection-row? s) 1)
                (rao-investigate-selection-row s (rao-reason-unknown-selection-status))
                (rao-refused-selection-row))))
)
