; program-image-sym-lens-band.fk -- 8h7 presentation lens over PIF symbols.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-sym-lens.fk
;
; Expected: 1048575

(do
    (defn pislb-score (ok bit) (if ok bit 0))
    (defn pislb-manifest-has (name)
        (program-image-sym-lens-manifest-has? name (program-image-sym-lens-manifest)))
    (defn pislb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn pislb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn pislb-table ()
        (pif-table-image 1
                         (list 0)
                         2
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 12 0 0 0))
                         1
                         (list (list 65 66))))
    (defn pislb-symbol-image ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/helper"))
                          2
                          (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 1)))
                                (pif-node-symbol-row 1 1 (empty)))))
    (defn pislb-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   1
                                   (pislb-table)
                                   (pislb-symbol-image)))
    (defn pislb-invalid-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src" 100
                                   "src/kernel.fkb" "sha:fkb" 101
                                   0
                                   (pislb-table)
                                   (pislb-symbol-image)))

    (defn pislb-row-main-en ()
        (pisl-row "en-US" "form" 0 "main" (list "entry" "start") "entry point" 0))
    (defn pislb-row-main-id ()
        (pisl-row "id-ID" "form" 0 "utama" (list "mulai") "titik masuk" 0))
    (defn pislb-row-helper-en ()
        (pisl-row "en-US" "form" 1 "helper" (list "assist") "helper symbol" 0))
    (defn pislb-lens ()
        (pisl-lens (list (pislb-row-main-en)
                         (pislb-row-main-id)
                         (pislb-row-helper-en))))
    (defn pislb-empty-lens ()
        (pisl-lens (empty)))
    (defn pislb-duplicate-lens ()
        (pisl-lens (list (pislb-row-main-en)
                         (pisl-row "en-US" "form" 0 "main-alt" (list "entry-alt") "dup" 0))))
    (defn pislb-count-row-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 2 "past-end" (list "bad") "past count" 0))))
    (defn pislb-minus-one-row-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" (sub 0 1) "neg" (list "bad") "negative" 0))))
    (defn pislb-empty-display-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 0 "" (list "entry") "entry point" 0))))
    (defn pislb-empty-doc-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 0 "main" (list "entry") "" 0))))
    (defn pislb-empty-locale-lens ()
        (pisl-lens (list (pisl-row "" "form" 0 "main" (list "entry") "entry point" 0))))
    (defn pislb-empty-domain-lens ()
        (pisl-lens (list (pisl-row "en-US" "" 0 "main" (list "entry") "entry point" 0))))
    (defn pislb-empty-alias-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 0 "main" (empty) "entry point" 0))))
    (defn pislb-malformed-alias-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 0 "main" (list "entry" "") "entry point" 0))))
    (defn pislb-string-alias-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 0 "main" "entry" "entry point" 0))))
    (defn pislb-exec-deps-lens ()
        (pisl-lens (list (pisl-row "en-US" "form" 0 "main" (list "entry") "entry point" 1))))
    (defn pislb-extra-field-lens ()
        (pisl-lens (list (append (pislb-row-main-en)
                                 (list (pif-symbol-dependency-target 1 1))))))

    (defn pislb-bit-manifest ()
        (pislb-score
            (and (eq (pislb-manifest-has "presentation-lens-only") 1)
            (and (eq (pislb-manifest-has "consumes-valid-pif-envelope") 1)
            (and (eq (pislb-manifest-has "locale-domain-display") 1)
            (and (eq (pislb-manifest-has "aliases-and-docs") 1)
            (and (eq (pislb-manifest-has "symbol-id-range-check") 1)
            (and (eq (pislb-manifest-has "duplicate-locale-domain-symbol-refused") 1)
            (and (eq (pislb-manifest-has "invalid-lens-investigates") 1)
            (and (eq (pislb-manifest-has "canonical-fallback-only-after-valid-lens") 1)
            (and (eq (pislb-manifest-has "no-executable-dependency-truth") 1)
            (and (eq (pislb-manifest-has "no-go-table-authority") 1)
            (and (eq (pislb-manifest-has "no-sym-artifact-io") 1)
            (and (eq (pislb-manifest-has "no-sym-parser") 1)
            (and (eq (pislb-manifest-has "no-fkb-mutation") 1)
            (and (eq (pislb-manifest-has "no-program-image-load") 1)
            (and (eq (pislb-manifest-has "no-selector-install") 1)
                 (eq (pislb-manifest-has "no-c-seed-growth") 1))))))))))))))))
            1))
    (defn pislb-bit-valid-lens ()
        (pislb-score
            (and (pif-envelope-valid? (pislb-envelope))
            (and (pisl-lens-ready? (pislb-envelope) (pislb-lens))
            (and (str_eq (pisl-admission-status (pisl-admission (pislb-envelope) (pislb-lens)))
                         (pisl-status-ready))
                 (str_eq (pisl-admission-reason (pisl-admission (pislb-envelope) (pislb-lens)))
                         (pisl-reason-ready)))))
            2))
    (defn pislb-bit-localized-display ()
        (do
            (let r (pisl-render-display-for (pislb-envelope) (pislb-lens) "id-ID" "form" 0))
            (pislb-score
                (and (str_eq (pisl-render-status r) (pisl-status-ready))
                (and (str_eq (pisl-render-reason r) (pisl-reason-localized-display))
                     (str_eq (pisl-render-display r) "utama")))
                4)))
    (defn pislb-bit-canonical-fallback ()
        (do
            (let r (pisl-render-display-for (pislb-envelope) (pislb-empty-lens) "fr-FR" "form" 1))
            (pislb-score
                (and (str_eq (pisl-render-status r) (pisl-status-ready))
                (and (str_eq (pisl-render-reason r) (pisl-reason-canonical-fallback))
                     (str_eq (pisl-render-display r) "core/helper")))
                8)))
    (defn pislb-bit-invalid-lens-no-fallback ()
        (do
            (let r (pisl-render-display-for (pislb-envelope) (pislb-duplicate-lens) "fr-FR" "form" 1))
            (pislb-score
                (and (str_eq (pisl-render-status r) (pisl-status-investigate))
                (and (str_eq (pisl-render-reason r) (pisl-reason-invalid-lens))
                     (str_eq (pisl-render-display r) "")))
                16)))
    (defn pislb-bit-out-of-range-rows ()
        (pislb-score
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-count-row-lens)))
                 (not (pisl-lens-ready? (pislb-envelope) (pislb-minus-one-row-lens))))
            32))
    (defn pislb-bit-out-of-range-query ()
        (do
            (let a (pisl-render-display-for (pislb-envelope) (pislb-empty-lens) "en-US" "form" 2))
            (let b (pisl-render-display-for (pislb-envelope) (pislb-empty-lens) "en-US" "form" (sub 0 1)))
            (pislb-score
                (and (str_eq (pisl-render-status a) (pisl-status-refused))
                (and (str_eq (pisl-render-reason a) (pisl-reason-symbol-out-of-range))
                (and (str_eq (pisl-render-display a) "")
                (and (str_eq (pisl-render-status b) (pisl-status-refused))
                     (str_eq (pisl-render-display b) "")))))
                64)))
    (defn pislb-bit-empty-fields ()
        (pislb-score
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-empty-display-lens)))
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-empty-doc-lens)))
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-empty-locale-lens)))
                 (not (pisl-lens-ready? (pislb-envelope) (pislb-empty-domain-lens))))))
            128))
    (defn pislb-bit-duplicate ()
        (pislb-score
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-duplicate-lens)))
                 (str_eq (pisl-admission-status (pisl-admission (pislb-envelope) (pislb-duplicate-lens)))
                         (pisl-status-investigate)))
            256))
    (defn pislb-bit-exec-and-extra ()
        (pislb-score
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-exec-deps-lens)))
                 (not (pisl-lens-ready? (pislb-envelope) (pislb-extra-field-lens))))
            512))
    (defn pislb-bit-aliases ()
        (pislb-score
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-empty-alias-lens)))
            (and (not (pisl-lens-ready? (pislb-envelope) (pislb-malformed-alias-lens)))
                 (not (pisl-lens-ready? (pislb-envelope) (pislb-string-alias-lens)))))
            1024))
    (defn pislb-bit-different-locale ()
        (do
            (let a (pisl-render-display-for (pislb-envelope) (pislb-lens) "en-US" "form" 0))
            (let b (pisl-render-display-for (pislb-envelope) (pislb-lens) "id-ID" "form" 0))
            (pislb-score
                (and (pisl-lens-ready? (pislb-envelope) (pislb-lens))
                (and (str_eq (pisl-render-display a) "main")
                     (str_eq (pisl-render-display b) "utama")))
                2048)))
    (defn pislb-bit-invalid-pif ()
        (do
            (let a (pisl-admission (pislb-invalid-envelope) (pislb-lens)))
            (let r (pisl-render-display-for (pislb-invalid-envelope) (pislb-lens) "en-US" "form" 0))
            (pislb-score
                (and (str_eq (pisl-admission-status a) (pisl-status-refused))
                (and (str_eq (pisl-admission-reason a) (pisl-reason-invalid-envelope))
                (and (str_eq (pisl-render-status r) (pisl-status-refused))
                     (str_eq (pisl-render-reason r) (pisl-reason-invalid-envelope)))))
                4096)))
    (defn pislb-bit-row-shape ()
        (pislb-score
            (and (not (pisl-row? (append (pislb-row-main-en) (list "extra"))))
            (and (not (pisl-row-valid-for-envelope? (pislb-envelope) (append (pislb-row-main-en) (list "extra"))))
                 (not (pisl-row-valid-for-envelope? (pislb-envelope)
                                                    (pisl-row "en-US" "form" (sub 0 1) "main" (list "entry") "entry point" 0)))))
            8192))
    (defn pislb-bit-static-source ()
        (do
            (let text (pislb-read-file-any "form/form-stdlib/program-image-sym-lens.fk"
                                           "../form/form-stdlib/program-image-sym-lens.fk"))
            (pislb-score
                (and (not (pislb-has? text "read_file"))
                (and (not (pislb-has? text "write_file"))
                (and (not (pislb-has? text "file_append_bytes"))
                (and (not (pislb-has? text "file_size"))
                (and (not (pislb-has? text "write_form_binary"))
                (and (not (pislb-has? text "read_form_binary"))
                (and (not (pislb-has? text "recipe_to_bytes"))
                (and (not (pislb-has? text "bytes_to_recipe"))
                (and (not (pislb-has? text "pif-table-numeric-stream"))
                (and (not (pislb-has? text "pite-"))
                (and (not (pislb-has? text "runtime-table-text"))
                (and (not (pislb-has? text "fk_run"))
                (and (not (pislb-has? text "walk_recipe"))
                (and (not (pislb-has? text "dlopen"))
                (and (not (pislb-has? text "dlsym"))
                (and (not (pislb-has? text "runtime/fkwu-uni.c"))
                (and (not (pislb-has? text "bp_table"))
                (and (not (pislb-has? text "bpTable"))
                     (not (pislb-has? text "BP_TABLE"))))))))))))))))))))
                16384)))
    (defn pislb-bit-mirror ()
        (do
            (let text (pislb-read-file-any "form/form-stdlib/program-image-sym-lens.fk"
                                           "../form/form-stdlib/program-image-sym-lens.fk"))
            (let grammar (pislb-read-file-any "grammars/program-image-sym-lens.fk"
                                              "../grammars/program-image-sym-lens.fk"))
            (pislb-score (str_eq text grammar) 32768)))
    (defn pislb-bit-architecture ()
        (do
            (let arch (pislb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (pislb-score
                (and (pislb-has? arch "8h7. Program-image `.sym` lens")
                (and (pislb-has? arch "canonical fallback only after lens validation")
                (and (pislb-has? arch "generated proof-sibling bp tables as projections")
                     (pislb-has? arch "version `2`"))))
                65536)))
    (defn pislb-bit-version ()
        (pislb-score (str_eq (pisl-version) "program-image-sym-lens-v1") 131072))
    (defn pislb-bit-malformed-total ()
        (do
            (let a (pisl-admission (pislb-envelope) (list "not-a-lens")))
            (let b (pisl-render-display-for (pislb-envelope) (list "not-a-lens") "en-US" "form" 0))
            (let c (pisl-render-display-for (pislb-envelope) (pislb-lens) "" "form" 0))
            (pislb-score
                (and (str_eq (pisl-admission-status a) (pisl-status-refused))
                (and (str_eq (pisl-admission-reason a) (pisl-reason-malformed-lens))
                (and (str_eq (pisl-render-status b) (pisl-status-refused))
                (and (str_eq (pisl-render-reason b) (pisl-reason-malformed-lens))
                     (str_eq (pisl-render-reason c) (pisl-reason-invalid-query))))))
                262144)))
    (defn pislb-bit-go-table-boundary ()
        (do
            (let doc (pislb-read-file-any "user-blueprint-registry.md"
                                          "../form/user-blueprint-registry.md"))
            (let arch (pislb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (pislb-score
                (and (pislb-has? doc "proof-sibling projections")
                (and (pislb-has? arch "generated proof-sibling bp tables as projections")
                (and (not (pislb-has? doc "generated tables as authority"))
                     (not (pislb-has? arch "Go table authority")))))
                524288)))

    (defn program-image-sym-lens-band ()
        (sum (list
            (pislb-bit-manifest)
            (pislb-bit-valid-lens)
            (pislb-bit-localized-display)
            (pislb-bit-canonical-fallback)
            (pislb-bit-invalid-lens-no-fallback)
            (pislb-bit-out-of-range-rows)
            (pislb-bit-out-of-range-query)
            (pislb-bit-empty-fields)
            (pislb-bit-duplicate)
            (pislb-bit-exec-and-extra)
            (pislb-bit-aliases)
            (pislb-bit-different-locale)
            (pislb-bit-invalid-pif)
            (pislb-bit-row-shape)
            (pislb-bit-static-source)
            (pislb-bit-mirror)
            (pislb-bit-architecture)
            (pislb-bit-version)
            (pislb-bit-malformed-total)
            (pislb-bit-go-table-boundary))))

    (program-image-sym-lens-band))
