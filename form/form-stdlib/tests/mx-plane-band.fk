; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/equireach.fk form-stdlib/format-arith.fk form-stdlib/f16-decode.fk form-stdlib/mxfp4-plane-dequant.fk form-stdlib/mxfp8-plane-dequant.fk
;
; mx-plane-band — GGUF type 40 (mxfp4-plane) and type 41 (mxfp8-plane) carved from REAL bytes of
; DeepSeek-V4-Flash-REAP25-DSpark-ds4-GGUF, the model whose own engine (ds4, origin/main efdadd4)
; refuses both types with "unsupported GGUF type".
;
; PROOF LEVEL: TWO-ARM (fkwu + go), for exactly the reason equireach-band.fk carries: the fixtures are
; BINARY and read_file_slice is UTF-8-lossy on the rust and ts arms, which hand back a different file.
; The arithmetic travels four ways (fd-value and fq-pow2 are four-way proven already); the byte door
; does not, and this band will not launder that into a four-way row.
;
; --- THE RADIUS THIS BAND SPEAKS FOR (aporon), stated before the gates, not after ---
; THERE IS NO ORACLE. Nothing outside this body decodes these two types: not ds4, not llama.cpp/ggml,
; not MLX. So this band CANNOT and DOES NOT claim bit-exactness against an independent implementation.
; What it does claim, and the class of each claim:
;
;   (a) GEOMETRY — the plane split, the plane boundary at n/2 (type 40) and n (type 41), and the
;       32-element scale group. Evidence class: STRUCTURAL, from the file's own tensor offsets (an
;       instrument validated on f32/f16/i32/iq2_xxs, which it recovers exactly), from a nibble-alphabet
;       argument that is a counting fact rather than an inference (225 = 15x15 byte values occur, the
;       31 absent ones are exactly those containing E2M1's negative-zero nibble), and from a scale-
;       plane transition measured 512 times at a constant period. Gate 32 re-derives the group size
;       inside the band from the fixture's own bytes rather than trusting the header.
;
;   (b) VALUE MAP — E2M1 = (fd-value c 2 1), E4M3 = (fd-value b 4 3), E8M0 = 2^(e-127). Evidence class:
;       BIT-EXACT AGAINST AN INDEPENDENT TRANSCRIPTION. The pinned milli-values below were computed
;       from a separate transcription written from the FORMAT SPECIFICATIONS (an explicit E2M1 value
;       table, and E4M3 bit-field arithmetic with its subnormal case) — not from these recipes, which
;       instead route both formats through f16-decode.fk's general (eb, mb) decoder. Two independent
;       derivations, same bytes, same answers to six digits. That is a real oracle for the value map,
;       and it is the ONLY thing in this band that earns the word exact.
;
;   (c) PLAUSIBILITY — the decoded weights look like trained weights. Evidence class: STATISTICAL, and
;       it is corroboration, not proof. Named here because gate 256 pins it: 1024 weights, |max| at
;       the format ceiling, no specials.
;
;   WHAT IS NOT PROVEN, and is named as uncertainty in mxfp4-plane-dequant.fk itself: the type-40
;   NIBBLE ORDER. Even-low/odd-high vs the alternatives permutes elements only within one 16-byte
;   span, which lies entirely inside one 32-element scale group, so every statistic this body can
;   compute is identical for both. No gate here tests it, and no gate here pretends to.
;
; THE FIXTURES are real slices, transcribed from the real file, small enough to commit:
;   mxfp4-plane-1024.bin  544 bytes  sha256 6d5bfbb88faa7925b5ba1407f89f371cfd8f77bd13f4455f9ebf73e89b0b591c
;       = elements 0..1023 of blk.0.ffn_gate_exps.weight (GGUF type 40, dims 4096x2048x256, tensor at
;         absolute 14647904): its first 512 payload bytes followed by its first 32 scale bytes, taken
;         from the scale plane at tensor+4194304. A faithful n=1024 slice of the file's own layout.
;   mxfp8-plane-1024.bin  1056 bytes sha256 ff50b5d1d220236d42ef329a20ca13df3fa0098c40388d956c1a3b5b6ad8c63d
;       = elements 0..1023 of blk.0.attn_kv.weight (GGUF type 41, dims 4096x512, tensor at absolute
;         72766954336 — a region the local download had not yet reached, fetched as a byte range from
;         the same URL): its first 1024 payload bytes followed by its first 32 scale bytes, taken from
;         the scale plane at tensor+2097152.
;
; Verdict 511 when both carvers are honest:
;   1    the windows ARE the fixtures            (lengths 544 and 1056, and the plane geometry agrees)
;   2    both edges are named, not guessed       (eqr-in? at the last byte, one past, and -1)
;   4    the E8M0 scale plane holds exponents    (type 40: {120,121}; type 41: {115,116} — the file's)
;   8    type 40 weight 0 is the pinned value    (-0.015625, from the independent transcription)
;   16   type 40 crosses a scale-group boundary  (i=1,32,512,1023 — 32 and 512 change the scale byte)
;   32   the 32-element group size, re-derived   (all 32 groups saturate to code 6 or 7, in-band)
;   64   type 41 weight 0 is the pinned value    (-0.002685546875)
;   128  type 41 crosses its boundaries too      (i=1,32,512,1023; 512 changes the scale byte)
;   256  both walls refuse, and the run is sane  (index n rejected; 1024 weights materialize; no NaN
;                                                 codes; sign split 526/1024 — the zero-mean tell)
(do
    (defn mxb-pin (x lo hi) (if (gt x lo) (if (lt x hi) 1 0) 0))

    ; fixture paths resolve from the repo root AND from form/ (the dual-path pattern)
    (let s4 (do (let __a (eqr-of-file "form/form-stdlib/tests/fixtures/mxfp4-plane-1024.bin" 0 544))
                  (if (eq (eqr-len __a) 544) __a
                      (eqr-of-file "form-stdlib/tests/fixtures/mxfp4-plane-1024.bin" 0 544))))
    (let s8 (do (let __b (eqr-of-file "form/form-stdlib/tests/fixtures/mxfp8-plane-1024.bin" 0 1056))
                  (if (eq (eqr-len __b) 1056) __b
                      (eqr-of-file "form-stdlib/tests/fixtures/mxfp8-plane-1024.bin" 0 1056))))

    ; --- 1: the windows are the fixtures, and the geometry recipes agree with their sizes ---
    (let c0 (if (eq (eqr-len s4) 544)
            (if (eq (eqr-len s8) 1056)
            (if (eq (mxp4-slice-bytes 1024) 544)
            (if (eq (mxp8-slice-bytes 1024) 1056)
            (if (eq (mxp4-payload-bytes 1024) 512)
            (if (eq (mxp8-payload-bytes 1024) 1024)
            (if (eq (mxp4-scale-bytes 1024) 32)
            (if (eq (mxp8-scale-bytes 1024) 32) 1 0) 0) 0) 0) 0) 0) 0) 0))

    ; --- 2: the edges are named, not guessed ---
    (let c1 (if (eq (eqr-in? s4 543) 1)
            (if (eq (eqr-in? s4 544) 0)
            (if (eq (eqr-in? s4 (sub 0 1)) 0)
            (if (eq (eqr-in? s8 1055) 1)
            (if (eq (eqr-in? s8 1056) 0) 2 0) 0) 0) 0) 0))

    ; --- 4: the scale PLANE holds E8M0 exponents, at the offsets the geometry names ---
    (let c2 (if (eq (mxp4-scale-byte s4 0 1024 0) 120)
            (if (eq (mxp4-scale-byte s4 0 1024 32) 121)
            (if (eq (mxp4-scale-byte s4 0 1024 1023) 120)
            (if (eq (mxp8-scale-byte s8 0 1024 0) 115)
            (if (eq (mxp8-scale-byte s8 0 1024 512) 116) 4 0) 0) 0) 0) 0))

    ; --- 8: type 40, weight 0, pinned to the independent transcription (-0.015625) ---
    (let m40a (mxp4-milli s4 0 1024 0))
    (let c3 (if (eq (mxb-pin m40a (sub 0 15625.001) (sub 0 15624.999)) 1) 8 0))

    ; --- 16: type 40 across the payload AND scale-group boundaries (i=32 and i=512 change the byte) ---
    (let c4 (if (eq (mxb-pin (mxp4-milli s4 0 1024 1)    (sub 0 7812.501) (sub 0 7812.499)) 1)
            (if (eq (mxb-pin (mxp4-milli s4 0 1024 32)   (sub 0 7812.501) (sub 0 7812.499)) 1)
            (if (eq (mxb-pin (mxp4-milli s4 0 1024 512)  15624.999 15625.001) 1)
            (if (eq (mxb-pin (mxp4-milli s4 0 1024 1023) (sub 0 31250.001) (sub 0 31249.999)) 1) 16 0) 0) 0) 0))

    ; --- 32: the 32-element group size, re-derived IN-BAND from the fixture's own codes.
    ; MX picks the shared exponent from the group max, so every 32-group must saturate to code 6 or 7.
    ; The band also pins the payload-plane code sum, so a wrong nibble unpack cannot pass by luck. ---
    (let c5 (if (eq (mxp4-sat? s4 0 0 32) 1)
            (if (eq (mxp4-codesum s4 0 1024) 3294)
            (if (eq (mxp4-groupmax s4 0 0) 7)
            (if (eq (mxp4-groupmax s4 0 1) 6) 32 0) 0) 0) 0))

    ; --- 64: type 41, weight 0, pinned to the independent transcription (-0.002685546875) ---
    (let m41a (mxp8-milli s8 0 1024 0))
    (let c6 (if (eq (mxb-pin m41a (sub 0 2685.5469) (sub 0 2685.5468)) 1) 64 0))

    ; --- 128: type 41 across its boundaries (i=512 changes the scale byte 115 -> 116) ---
    (let c7 (if (eq (mxb-pin (mxp8-milli s8 0 1024 1)    39062.499 39062.501) 1)
            (if (eq (mxb-pin (mxp8-milli s8 0 1024 32)   (sub 0 17578.126) (sub 0 17578.124)) 1)
            (if (eq (mxb-pin (mxp8-milli s8 0 1024 512)  (sub 0 5859.376) (sub 0 5859.374)) 1)
            (if (eq (mxb-pin (mxp8-milli s8 0 1024 1023) 2197.2655 2197.2657) 1) 128 0) 0) 0) 0))

    ; --- 256: both walls refuse at index n, the full runs materialize, and the sanity tells hold.
    ; 526 of 1024 type-41 codes carry the sign bit — the near-half split a zero-mean tensor gives and
    ; a two's-complement reading would not explain. No code is one of E4M3's two NaN encodings. ---
    (let ws4 (mxp4-weights s4 0 1024 1024))
    (let ws8 (mxp8-weights s8 0 1024 1024))
    (let c8 (if (eq (mxp4-index-ok? 1024 1024) 0)
            (if (eq (mxp8-index-ok? 1024 1024) 0)
            (if (eq (mxp4-index-ok? 1024 1023) 1)
            (if (eq (len ws4) 1024)
            (if (eq (len ws8) 1024)
            (if (eq (mxp8-nanfree? s8 0 0 1024) 1)
            (if (eq (mxp8-negcount s8 0 1024) 526) 256 0) 0) 0) 0) 0) 0) 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 c8)))))))))
