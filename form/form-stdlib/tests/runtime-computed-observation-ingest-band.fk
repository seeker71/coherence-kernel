; runtime-computed-observation-ingest-band.fk -- Layer 10d computed observation guide proof.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-executor-capability.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/program-image-symbol-entry.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-program-image-fkb-micro-walker.fk form-stdlib/runtime-program-image-fkb-symbol-walk.fk form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk form-stdlib/runtime-program-image-fkb-symbol-observation.fk form-stdlib/runtime-computed-observation-ingest.fk
;
; Expected: 262143

(do
    (defn rcoib-score (ok bit) (if ok bit 0))
    (defn rcoib-manifest-has (name)
        (runtime-computed-observation-ingest-manifest-has? name
            (runtime-computed-observation-ingest-manifest)))
    (defn rcoib-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rcoib-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))
    (defn rcoib-none-of? (text needles)
        (if (nil? needles)
            1
            (if (rcoib-has? text (head needles))
                0
                (rcoib-none-of? text (tail needles)))))

    (defn rcoib-source-hash () "sha:src-computed-observation")
    (defn rcoib-content-hash () "sha:content-computed-observation")
    (defn rcoib-artifact-path () "cache/computed-observation.fkb")

    (defn rcoib-nodes ()
        (list
            (pif-node-row 1 42 0 0)
            (pif-node-row 1 40 0 0)
            (pif-node-row 1 2 0 0)
            (pif-node-row 3 1 2 0)
            (pif-node-row 99 0 0 0)))
    (defn rcoib-roots () (list 0 3 4))
    (defn rcoib-table ()
        (pif-table-image (len (rcoib-roots))
                         (rcoib-roots)
                         (len (rcoib-nodes))
                         (rcoib-nodes)
                         0
                         (empty)))
    (defn rcoib-symbol-rows ()
        (list (pif-symbol-row 0 "core/lit42")
              (pif-symbol-row 1 "core/add42")
              (pif-symbol-row 2 "core/bad-tag")))
    (defn rcoib-node-symbol-rows ()
        (list
            (pif-node-symbol-row 0 0 (empty))
            (pif-node-symbol-row 3 1 (empty))
            (pif-node-symbol-row 4 2 (empty))))
    (defn rcoib-symbol-image ()
        (pif-symbol-image 3 (rcoib-symbol-rows) 3 (rcoib-node-symbol-rows)))
    (defn rcoib-pif ()
        (pif-envelope-with-symbols "src/computed-observation.fk"
                                   (rcoib-source-hash)
                                   100
                                   (rcoib-artifact-path)
                                   (rcoib-content-hash)
                                   101
                                   1
                                   (rcoib-table)
                                   (rcoib-symbol-image)))
    (defn rcoib-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rcoib-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rcoib-envelope ()
        (do
            (let pif (rcoib-pif))
            (let src (rcoib-source-for-pif pif))
            (let fkb (rcoib-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rcoib-envelope-with-selection (selection reason)
        (do
            (let pif (rcoib-pif))
            (rale-envelope (rcoib-source-for-pif pif)
                           (rcoib-fkb-for-pif pif)
                           (rap-act-run-program-image)
                           (sac-run-fkb)
                           (sad-kind-program-image-fkb)
                           (rcoib-artifact-path)
                           (rcoib-source-hash)
                           (rcoib-content-hash)
                           selection
                           (rale-no-retry)
                           (rale-no-compile-output)
                           (rale-status-request-ready)
                           reason)))
    (defn rcoib-malformed-selection-envelope ()
        (rcoib-envelope-with-selection (list "bad-selection") "malformed-selection-fixture"))
    (defn rcoib-action-mismatch-envelope ()
        (rcoib-envelope-with-selection
            (ras-selection (sac-run-fkb)
                           "different-action"
                           (rao-action-none)
                           (ras-status-selected)
                           1
                           1
                           "action-mismatch-fixture")
            "action-mismatch-fixture"))
    (defn rcoib-fallback-envelope ()
        (rcoib-envelope-with-selection
            (ras-selection (sac-run-fkb)
                           (rap-act-run-program-image)
                           "fallback-run-fkb"
                           (ras-status-selected)
                           1
                           1
                           "fallback-fixture")
            "fallback-fixture"))

    (defn rcoib-payload ()
        (do
            (let pif (rcoib-pif))
            (pifbd-payload (pif-envelope-source-path pif)
                           (pif-envelope-source-hash pif)
                           (pif-envelope-source-mtime pif)
                           (pif-envelope-artifact-path pif)
                           (pif-envelope-seal-ok pif)
                           (pif-envelope-table pif)
                           (pif-envelope-symbol-image pif))))
    (defn rcoib-decode () (pifbd-decoded-row (rcoib-payload) 123))
    (defn rcoib-admission ()
        (pifbd-admission (list "runtime-computed-observation-ingest-synthetic-admission")
                         (rcoib-decode)
                         (rcoib-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))

    (defn rcoib-cap-for-envelope (e availability evidence authority freshness detail)
        (raec-capability (raec-cap-program-image-walker)
                         (rale-envelope-action e)
                         (rale-envelope-route e)
                         (rale-envelope-artifact-kind e)
                         availability evidence authority freshness detail))
    (defn rcoib-ready-cap-for (e)
        (rcoib-cap-for-envelope e
                                (raec-availability-available)
                                (raec-evidence-supplied-current)
                                (raec-authority-attempt-supplier)
                                (raec-freshness-current)
                                "supplied-current-program-image-walker"))
    (defn rcoib-readiness-for (e)
        (raec-readiness-from-envelope-capability e (rcoib-ready-cap-for e)))
    (defn rcoib-readiness () (rcoib-readiness-for (rcoib-envelope)))
    (defn rcoib-no-capability-readiness ()
        (raec-readiness-from-envelope-no-capability (rcoib-envelope)))
    (defn rcoib-stale-readiness ()
        (raec-readiness-from-envelope-capability
            (rcoib-envelope)
            (rcoib-cap-for-envelope (rcoib-envelope)
                                    (raec-availability-available)
                                    (raec-evidence-supplied-stale)
                                    (raec-authority-attempt-supplier)
                                    (raec-freshness-current)
                                    "stale-program-image-walker")))

    (defn rcoib-adapt-key (key budget input)
        (rpswo-adapt (rcoib-envelope)
                     (rcoib-readiness)
                     (rcoib-admission)
                     (pise-request-by-canonical-key key)
                     budget
                     input))
    (defn rcoib-good () (rcoib-adapt-key "core/lit42" 10 0))
    (defn rcoib-timeout () (rcoib-adapt-key "core/add42" 2 0))
    (defn rcoib-missing () (rcoib-adapt-key "core/missing" 10 0))
    (defn rcoib-with-readiness (readiness)
        (rpswo-adapt (rcoib-envelope) readiness (rcoib-admission)
                     (pise-request-by-canonical-key "core/lit42") 10 0))
    (defn rcoib-with-envelope (e)
        (rpswo-adapt e (rcoib-readiness-for e) (rcoib-admission)
                     (pise-request-by-canonical-key "core/lit42") 10 0))
    (defn rcoib-with-envelope-key (e key budget input)
        (rpswo-adapt e (rcoib-readiness-for e) (rcoib-admission)
                     (pise-request-by-canonical-key key) budget input))

    (defn rcoib-base-trace (row)
        (rpswc-join-bound-trace (rpswo-row-9h7-bind row)))
    (defn rcoib-trace-like (row status stop code detail)
        (do
            (let trace (rcoib-base-trace row))
            (rpiwt-trace (rpiwt-trace-artifact-path trace)
                         (rpiwt-trace-source-hash trace)
                         (rpiwt-trace-content-hash trace)
                         (rpiwt-trace-entry-kind trace)
                         (rpiwt-trace-entry-index trace)
                         (rpiwt-trace-root-node trace)
                         (rpiwt-trace-step-budget trace)
                         (rpiwt-trace-steps-used trace)
                         0
                         0
                         code
                         status
                         stop
                         detail)))
    (defn rcoib-bind-with-trace (bind trace)
        (list "runtime-program-image-fkb-symbol-capability-bound"
              (rpswc-join-envelope bind)
              (rpswc-join-readiness bind)
              (rpswc-join-admission bind)
              (rpswc-join-symbol-request bind)
              (rpswc-join-step-budget bind)
              (rpswc-join-input-value bind)
              (rpswc-join-symbol-walk bind)
              trace
              (rpswc-status-bound)
              (rpswc-join-reason bind)))
    (defn rcoib-bind-with-readiness (bind readiness)
        (list "runtime-program-image-fkb-symbol-capability-bound"
              (rpswc-join-envelope bind)
              readiness
              (rpswc-join-admission bind)
              (rpswc-join-symbol-request bind)
              (rpswc-join-step-budget bind)
              (rpswc-join-input-value bind)
              (rpswc-join-symbol-walk bind)
              (rpswc-join-bound-trace bind)
              (rpswc-join-status bind)
              (rpswc-join-reason bind)))
    (defn rcoib-symbol-walk-with-reason (walk reason)
        (list "runtime-program-image-fkb-symbol-walk"
              (rpsw-receipt-envelope walk)
              (rpsw-receipt-admission walk)
              (rpsw-receipt-symbol-request walk)
              (rpsw-receipt-step-budget walk)
              (rpsw-receipt-input-value walk)
              (rpsw-receipt-symbol-resolution walk)
              (rpsw-receipt-micro-walk walk)
              (rpsw-receipt-trace walk)
              (rpsw-receipt-status walk)
              reason))
    (defn rcoib-bind-with-symbol-walk (bind walk)
        (list "runtime-program-image-fkb-symbol-capability-bound"
              (rpswc-join-envelope bind)
              (rpswc-join-readiness bind)
              (rpswc-join-admission bind)
              (rpswc-join-symbol-request bind)
              (rpswc-join-step-budget bind)
              (rpswc-join-input-value bind)
              walk
              (rpswc-join-bound-trace bind)
              (rpswc-join-status bind)
              (rpswc-join-reason bind)))
    (defn rcoib-observation-from-trace (e trace)
        (rao-run-observation
            (rale-envelope-action e)
            (rpiwt-trace-status trace)
            (str_concat "synthetic-computed-trace-observation: "
                        (rpiwt-trace-detail trace))
            (rpiwt-trace-exit-code trace)))
    (defn rcoib-row-with-trace (row trace)
        (do
            (let e (rpswo-row-envelope row))
            (let bind (rcoib-bind-with-trace (rpswo-row-9h7-bind row) trace))
            (let observation (rcoib-observation-from-trace e trace))
            (let outcome (rao-outcome-from-selection-observation
                            (rale-envelope-selection e)
                            observation))
            (list "runtime-program-image-fkb-symbol-observation"
                  (rpswo-row-envelope row)
                  (rpswo-row-readiness row)
                  (rpswo-row-admission row)
                  (rpswo-row-symbol-request row)
                  (rpswo-row-step-budget row)
                  (rpswo-row-input-value row)
                  bind observation outcome
                  (rao-outcome-status outcome)
                  (rao-outcome-reason outcome))))
    (defn rcoib-hard-row (status stop reason)
        (rcoib-row-with-trace
            (rcoib-good)
            (rcoib-trace-like (rcoib-good) status stop 137 reason)))
    (defn rcoib-soft-row (status stop reason)
        (rcoib-row-with-trace
            (rcoib-good)
            (rcoib-trace-like (rcoib-good) status stop 1 reason)))
    (defn rcoib-soft-fallback-row ()
        (rcoib-with-envelope-key (rcoib-fallback-envelope) "core/bad-tag" 10 0))
    (defn rcoib-row-with-observation (row observation)
        (list "runtime-program-image-fkb-symbol-observation"
              (rpswo-row-envelope row)
              (rpswo-row-readiness row)
              (rpswo-row-admission row)
              (rpswo-row-symbol-request row)
              (rpswo-row-step-budget row)
              (rpswo-row-input-value row)
              (rpswo-row-9h7-bind row)
              observation
              (rpswo-row-outcome row)
              (rpswo-row-status row)
              (rpswo-row-reason row)))
    (defn rcoib-row-with-outcome (row outcome)
        (list "runtime-program-image-fkb-symbol-observation"
              (rpswo-row-envelope row)
              (rpswo-row-readiness row)
              (rpswo-row-admission row)
              (rpswo-row-symbol-request row)
              (rpswo-row-step-budget row)
              (rpswo-row-input-value row)
              (rpswo-row-9h7-bind row)
              (rpswo-row-observation row)
              outcome
              (rpswo-row-status row)
              (rpswo-row-reason row)))
    (defn rcoib-row-with-status-reason (row status reason)
        (list "runtime-program-image-fkb-symbol-observation"
              (rpswo-row-envelope row)
              (rpswo-row-readiness row)
              (rpswo-row-admission row)
              (rpswo-row-symbol-request row)
              (rpswo-row-step-budget row)
              (rpswo-row-input-value row)
              (rpswo-row-9h7-bind row)
              (rpswo-row-observation row)
              (rpswo-row-outcome row)
              status
              reason))
    (defn rcoib-row-with-pieces (row bind observation outcome status reason)
        (list "runtime-program-image-fkb-symbol-observation"
              (rpswo-row-envelope row)
              (rpswo-row-readiness row)
              (rpswo-row-admission row)
              (rpswo-row-symbol-request row)
              (rpswo-row-step-budget row)
              (rpswo-row-input-value row)
              bind
              observation
              outcome
              status
              reason))
    (defn rcoib-non-bound-forged-raw ()
        (do
            (let base (rcoib-with-readiness (rcoib-stale-readiness)))
            (let good (rcoib-good))
            (rcoib-row-with-pieces base
                                   (rpswo-row-9h7-bind base)
                                   (rpswo-row-observation good)
                                   (rpswo-row-outcome good)
                                   (rpswo-row-status base)
                                   (rpswo-row-reason base))))
    (defn rcoib-forged-ok-bound-row ()
        (rcoib-row-with-trace
            (rcoib-good)
            (rcoib-trace-like (rcoib-good)
                              (rao-obs-ok)
                              (rpiwt-stop-completed)
                              0
                              "forged-ok-trace")))
    (defn rcoib-forged-readiness-bound-row ()
        (do
            (let row (rcoib-good))
            (let bind (rcoib-bind-with-readiness
                         (rpswo-row-9h7-bind row)
                         (rcoib-no-capability-readiness)))
            (rcoib-row-with-pieces row bind
                                   (rpswo-row-observation row)
                                   (rpswo-row-outcome row)
                                   (rpswo-row-status row)
                                   (rpswo-row-reason row))))
    (defn rcoib-forged-symbol-walk-bound-row ()
        (do
            (let row (rcoib-good))
            (let bind (rpswo-row-9h7-bind row))
            (let walk (rcoib-symbol-walk-with-reason
                         (rpswc-join-symbol-walk bind)
                         "forged-symbol-walk-reason"))
            (let forged-bind (rcoib-bind-with-symbol-walk bind walk))
            (rcoib-row-with-pieces row forged-bind
                                   (rpswo-row-observation row)
                                   (rpswo-row-outcome row)
                                   (rpswo-row-status row)
                                   (rpswo-row-reason row))))

    (defn rcoib-guide (row) (rcoi-ingest row))
    (defn rcoib-bit-manifest-core ()
        (rcoib-score
            (and (eq (rcoib-manifest-has "layer-10d-computed-observation-guide") 1)
            (and (eq (rcoib-manifest-has "consumes-9h8-row-only") 1)
            (and (eq (rcoib-manifest-has "single-public-guide-entrypoint") 1)
            (and (eq (rcoib-manifest-has "no-raw-trace-input") 1)
            (and (eq (rcoib-manifest-has "no-raw-observation-input") 1)
            (and (eq (rcoib-manifest-has "no-raw-outcome-input") 1)
            (and (eq (rcoib-manifest-has "no-raw-9h7-join-input") 1)
                 (eq (rcoib-manifest-has "does-not-reuse-10b-record-shape") 1))))))))
            1))
    (defn rcoib-bit-manifest-guide-safety ()
        (rcoib-score
            (and (eq (rcoib-manifest-has "nested-agreement-reread-required") 1)
            (and (eq (rcoib-manifest-has "body-freeze-candidate-requires-full-ok-agreement") 1)
            (and (eq (rcoib-manifest-has "hard-statuses-become-exact-investigation-work") 1)
            (and (eq (rcoib-manifest-has "oom-killed-must-never-be-ignored") 1)
            (and (eq (rcoib-manifest-has "soft-statuses-become-repair-work") 1)
            (and (eq (rcoib-manifest-has "fallback-available-is-not-success") 1)
            (and (eq (rcoib-manifest-has "non-bound-rows-stay-held-or-refused") 1)
            (and (eq (rcoib-manifest-has "no-storage-mutation") 1)
            (and (eq (rcoib-manifest-has "no-artifact-load") 1)
            (and (eq (rcoib-manifest-has "no-native-call") 1)
            (and (eq (rcoib-manifest-has "no-selector-install") 1)
            (and (eq (rcoib-manifest-has "no-table-payload-authority") 1)
            (and (eq (rcoib-manifest-has "no-symbol-lens-authority") 1)
            (and (eq (rcoib-manifest-has "no-generated-table-authority") 1)
                 (eq (rcoib-manifest-has "no-c-seed-growth") 1)))))))))))))))
            2))
    (defn rcoib-bit-version-row ()
        (do
            (let g (rcoib-guide (rcoib-good)))
            (rcoib-score
                (and (str_eq (rcoi-version) "runtime-computed-observation-ingest-v1")
                     (rcoi-guide? g))
                4)))
    (defn rcoib-bit-happy-freeze ()
        (do
            (let g (rcoib-guide (rcoib-good)))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane g) (rcoi-lane-body))
                (and (str_eq (rcoi-guide-work-kind g) (rcoi-work-freeze-candidate))
                (and (eq (rcoi-guide-freeze-candidate g) 1)
                (and (str_eq (rcoi-guide-trace-status g) (rao-obs-ok))
                (and (str_eq (rcoi-guide-stop-reason g) (rpiwt-stop-completed))
                     (str_eq (rcoi-guide-reason g) (rcoi-reason-freeze-candidate)))))))
                8)))
    (defn rcoib-bit-agreement-reread ()
        (do
            (let g (rcoib-guide (rcoib-good)))
            (rcoib-score
                (and (str_eq (rcoi-guide-9h7-status g) (rpswc-status-bound))
                (and (str_eq (rcoi-guide-observation-status g) (rao-obs-ok))
                (and (str_eq (rcoi-guide-outcome-status g) (rao-status-complete))
                (and (str_eq (rcoi-guide-artifact-path g) (rcoib-artifact-path))
                     (eq (rcoi-guide-trace-exit-code g) 0)))))
                16)))
    (defn rcoib-bit-timeout-exact ()
        (do
            (let g (rcoib-guide (rcoib-timeout)))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane g) (rcoi-lane-investigation))
                (and (str_eq (rcoi-guide-work-kind g) (rcoi-work-investigation))
                (and (str_eq (rcoi-guide-attention g) (rcoi-attention-timeout))
                (and (str_eq (rcoi-guide-trace-status g) (rao-obs-timeout))
                     (str_eq (rcoi-guide-reason g) (rcoi-reason-timeout-investigation))))))
                32)))
    (defn rcoib-hard-guide (status stop reason)
        (rcoib-guide (rcoib-hard-row status stop reason)))
    (defn rcoib-bit-hard-exact-forged ()
        (do
            (let oom (rcoib-hard-guide (rao-obs-oom-killed) (rpiwt-stop-oom-killed) "oom-fixture"))
            (let killed (rcoib-hard-guide (rao-obs-killed) (rpiwt-stop-killed) "killed-fixture"))
            (let stalled (rcoib-hard-guide (rao-obs-stalled) (rpiwt-stop-stalled) "stalled-fixture"))
            (let wrong (rcoib-hard-guide (rao-obs-wrong-value) (rpiwt-stop-wrong-value) "wrong-fixture"))
            (rcoib-score
                (and (str_eq (rcoi-guide-reason oom) (rcoi-reason-oom-killed-investigation))
                (and (str_eq (rcoi-guide-attention killed) (rcoi-attention-killed))
                (and (str_eq (rcoi-guide-attention stalled) (rcoi-attention-stalled))
                (and (str_eq (rcoi-guide-reason wrong) (rcoi-reason-wrong-value-investigation))
                (and (eq (rcoi-guide-priority oom) 100)
                     (eq (rcoi-guide-freeze-candidate wrong) 0))))))
                64)))
    (defn rcoib-bit-soft-repair ()
        (do
            (let err (rcoib-guide (rcoib-adapt-key "core/bad-tag" 10 0)))
            (let fallback (rcoib-guide (rcoib-soft-fallback-row)))
            (rcoib-score
                (and (str_eq (rcoi-guide-work-kind err) (rcoi-work-repair))
                (and (str_eq (rcoi-guide-reason err) (rcoi-reason-error-repair))
                (and (str_eq (rcoi-guide-outcome-status fallback) (rao-status-fallback-available))
                (and (str_eq (rcoi-guide-work-kind fallback) (rcoi-work-repair))
                     (eq (rcoi-guide-freeze-candidate fallback) 0)))))
                128)))
    (defn rcoib-bit-non-bound-held-refused ()
        (do
            (let held (rcoib-guide (rcoib-with-readiness (rcoib-no-capability-readiness))))
            (let held-investigate (rcoib-guide (rcoib-with-readiness (rcoib-stale-readiness))))
            (let refused (rcoib-guide (rcoib-missing)))
            (let forged (rcoib-guide (rcoib-non-bound-forged-raw)))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane held) (rcoi-lane-held))
                (and (str_eq (rcoi-guide-reason held) (rcoi-reason-non-bound-held))
                (and (str_eq (rcoi-guide-lane held-investigate) (rcoi-lane-held))
                (and (str_eq (rcoi-guide-work-kind held-investigate) (rcoi-work-held))
                (and (rpswo-no-derived-observation? (rcoi-guide-observation held))
                (and (str_eq (rcoi-guide-lane refused) (rcoi-lane-refused))
                (and (rpswo-no-derived-outcome? (rcoi-guide-outcome refused))
                (and (str_eq (rcoi-guide-lane forged) (rcoi-lane-investigation))
                     (str_eq (rcoi-guide-reason forged) (rcoi-reason-nested-observation-mismatch))))))))))
                256)))
    (defn rcoib-bit-no-outcome-selection-cases ()
        (do
            (let malformed (rcoib-guide (rcoib-with-envelope (rcoib-malformed-selection-envelope))))
            (let mismatch (rcoib-guide (rcoib-with-envelope (rcoib-action-mismatch-envelope))))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane malformed) (rcoi-lane-refused))
                (and (str_eq (rcoi-guide-reason malformed) (rao-reason-malformed-selection))
                (and (str_eq (rcoi-guide-lane mismatch) (rcoi-lane-investigation))
                (and (str_eq (rcoi-guide-reason mismatch) (rao-reason-observation-action-mismatch))
                     (str_eq (rcoi-guide-outcome-status mismatch) (rcoi-status-none))))))
                512)))
    (defn rcoib-bit-forged-observation-mismatch ()
        (do
            (let row (rcoib-good))
            (let bad (rao-run-observation (rale-envelope-action (rpswo-row-envelope row))
                                          (rao-obs-error)
                                          "bad-observation"
                                          1))
            (let g (rcoib-guide (rcoib-row-with-observation row bad)))
            (let forged-ok (rcoib-guide (rcoib-forged-ok-bound-row)))
            (let forged-readiness (rcoib-guide (rcoib-forged-readiness-bound-row)))
            (let forged-walk (rcoib-guide (rcoib-forged-symbol-walk-bound-row)))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane g) (rcoi-lane-investigation))
                (and (str_eq (rcoi-guide-attention g) (rcoi-attention-nested-agreement))
                (and (str_eq (rcoi-guide-reason g) (rcoi-reason-nested-observation-mismatch))
                (and (str_eq (rcoi-guide-lane forged-ok) (rcoi-lane-investigation))
                (and (eq (rcoi-guide-freeze-candidate forged-ok) 0)
                (and (str_eq (rcoi-guide-lane forged-readiness) (rcoi-lane-investigation))
                (and (eq (rcoi-guide-freeze-candidate forged-readiness) 0)
                (and (str_eq (rcoi-guide-lane forged-walk) (rcoi-lane-investigation))
                     (eq (rcoi-guide-freeze-candidate forged-walk) 0)))))))))
                1024)))
    (defn rcoib-bit-forged-outcome-mismatch ()
        (do
            (let row (rcoib-good))
            (let outcome (rao-outcome (rao-outcome-route (rpswo-row-outcome row))
                                      (rao-outcome-attempted (rpswo-row-outcome row))
                                      (rao-outcome-fallback (rpswo-row-outcome row))
                                      (rao-outcome-selection-status (rpswo-row-outcome row))
                                      (rao-outcome-status (rpswo-row-outcome row))
                                      (rao-outcome-observation-status (rpswo-row-outcome row))
                                      (rao-outcome-selection-reason (rpswo-row-outcome row))
                                      (rao-outcome-reason (rpswo-row-outcome row))
                                      "forged-detail"
                                      (rao-outcome-code (rpswo-row-outcome row))))
            (let g (rcoib-guide (rcoib-row-with-outcome row outcome)))
            (let forged-row (rcoib-guide
                                (rcoib-row-with-status-reason
                                    row
                                    (rao-status-investigate)
                                    "forged-row-status")))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane g) (rcoi-lane-investigation))
                (and (str_eq (rcoi-guide-reason g) (rcoi-reason-nested-outcome-mismatch))
                     (str_eq (rcoi-guide-reason forged-row) (rcoi-reason-nested-outcome-mismatch))))
                2048)))
    (defn rcoib-bit-malformed-input ()
        (do
            (let g (rcoib-guide (list "not-a-9h8-row")))
            (rcoib-score
                (and (str_eq (rcoi-guide-lane g) (rcoi-lane-refused))
                (and (rcoi-no-9h7-bind? (rcoi-guide-9h7-bind g))
                     (str_eq (rcoi-guide-reason g) (rcoi-reason-malformed-9h8-row))))
                4096)))
    (defn rcoib-forbidden-needles ()
        (list "rti-" "runtime-trace-ingest-record"
              "raar-" "rpifa-" "rpifc-" "rpiftc-" "rpiwt-bridge"
              "rtta-" ".payload" ".sym" "read_file" "read_file_slice"
              "write_file" "append_file" "remove_file" "fk_run"
              "form-eval" "dlopen" "bp_table" "bpTable" "BP_TABLE"
              "runtime/fkwu-uni.c"))
    (defn rcoib-bit-static-source ()
        (do
            (let text (rcoib-read-file-any "form/form-stdlib/runtime-computed-observation-ingest.fk"
                                           "../form/form-stdlib/runtime-computed-observation-ingest.fk"))
            (rcoib-score (rcoib-none-of? text (rcoib-forbidden-needles)) 8192)))
    (defn rcoib-bit-single-input-no-helper ()
        (do
            (let text (rcoib-read-file-any "form/form-stdlib/runtime-computed-observation-ingest.fk"
                                           "../form/form-stdlib/runtime-computed-observation-ingest.fk"))
            (rcoib-score
                (and (rcoib-has? text "(defn rcoi-ingest (row)")
                (and (not (rcoib-has? text "(defn rcoi-ingest (row trace"))
                (and (not (rcoib-has? text "rcoi-ingest-from"))
                (and (not (rcoib-has? text "rcoi-from-trace"))
                (and (not (rcoib-has? text "rcoi-from-observation"))
                (and (not (rcoib-has? text "rcoi-from-outcome"))
                (and (not (rcoib-has? text "rcoi-from-9h7"))
                     (not (rcoib-has? text "(defn rcoi-guide-row")))))))))
                16384)))
    (defn rcoib-bit-guide-language ()
        (do
            (let text (rcoib-read-file-any "form/form-stdlib/runtime-computed-observation-ingest.fk"
                                           "../form/form-stdlib/runtime-computed-observation-ingest.fk"))
            (let old-word (str_concat "bound" "ary"))
            (rcoib-score
                (and (rcoib-has? text "guide")
                     (not (rcoib-has? text old-word)))
                32768)))
    (defn rcoib-bit-mirror ()
        (do
            (let text (rcoib-read-file-any "form/form-stdlib/runtime-computed-observation-ingest.fk"
                                           "../form/form-stdlib/runtime-computed-observation-ingest.fk"))
            (let grammar (rcoib-read-file-any "grammars/runtime-computed-observation-ingest.fk"
                                              "../grammars/runtime-computed-observation-ingest.fk"))
            (rcoib-score (str_eq text grammar) 65536)))
    (defn rcoib-bit-architecture-receipt ()
        (do
            (let arch (rcoib-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rcoib-read-file-any "../receipts/2026-07-04-runtime-computed-observation-ingest-layer-review.md"
                                              "receipts/2026-07-04-runtime-computed-observation-ingest-layer-review.md"))
            (rcoib-score
                (and (rcoib-has? arch "10d. Runtime computed observation ingest guide")
                (and (rcoib-has? receipt "Layer: 10d")
                (and (rcoib-has? receipt "shared work ledger")
                     (rcoib-has? receipt "10d is a guide."))))
                131072)))

    (defn runtime-computed-observation-ingest-band ()
        (sum (list
            (rcoib-bit-manifest-core)
            (rcoib-bit-manifest-guide-safety)
            (rcoib-bit-version-row)
            (rcoib-bit-happy-freeze)
            (rcoib-bit-agreement-reread)
            (rcoib-bit-timeout-exact)
            (rcoib-bit-hard-exact-forged)
            (rcoib-bit-soft-repair)
            (rcoib-bit-non-bound-held-refused)
            (rcoib-bit-no-outcome-selection-cases)
            (rcoib-bit-forged-observation-mismatch)
            (rcoib-bit-forged-outcome-mismatch)
            (rcoib-bit-malformed-input)
            (rcoib-bit-static-source)
            (rcoib-bit-single-input-no-helper)
            (rcoib-bit-guide-language)
            (rcoib-bit-mirror)
            (rcoib-bit-architecture-receipt))))

    (runtime-computed-observation-ingest-band))
