; preludes: form-stdlib/text-tokenize.fk model/rag-embed.fk
;
; rag-embed-band -- rag-embed.fk's own header already claimed this band existed
; ("Proven by: form-stdlib/tests/rag-embed-band.fk") but it never did, and re-vec
; itself was silently broken: its declared prelude form-stdlib/text-tokenize.fk
; didn't exist either, so tk-words/ord resolved to the canonical "nothing" instead
; of erroring, and every embedding came out all-zero (right length, empty content).
; See receipts/2026-07-01-rag-embed-tokenize-fix.md. This band is the real, checked-in
; proof now that both are fixed.
;
; SCOPE: fkwu --src only, not four-way. str_byte_at/byte_to_str aren't registered in
; any of the three minimal walkers, and str_len isn't in Rust's or TS's either --
; verified directly against walkers/go/main.go, walkers/rust/src/main.rs,
; walkers/ts/main.ts. Named honestly rather than left as an inherited, untested claim.
;
; Verdict 31:
;   1   the embedding has the requested length
;   2   the embedding is not all-zero (real content, not the old silent-failure vector)
;   4   the same text embeds to the same vector twice (determinism)
;   8   case/punctuation/extra-whitespace variants of the same words embed IDENTICALLY
;       (the exact normalization tk-words was always supposed to do)
;   16  genuinely different words embed to a DIFFERENT vector (real distinguishing power,
;       not a constant/degenerate output)

(do
    (defn reb-band-score (cond bit) (if cond bit 0))
    (defn reb-vsum (xs) (if (eq (len xs) 0) 0 (add (head xs) (reb-vsum (tail xs)))))
    (defn reb-veq? (a b)
        (if (eq (len a) 0) 1
            (if (eq (head a) (head b)) (reb-veq? (tail a) (tail b)) 0)))

    (defn rag-embed-band ()
        (do
            (let v1 (re-vec-dim "The Choice Point Becomes Visible." 24))
            (let v2 (re-vec-dim "the   choice, point... becomes VISIBLE" 24))
            (let v3 (re-vec-dim "completely different unrelated words here" 24))
            (let v1b (re-vec-dim "The Choice Point Becomes Visible." 24))

            (let c0 (reb-band-score (eq (len v1) 24) 1))
            (let c1 (reb-band-score (gt (reb-vsum v1) 0) 2))
            (let c2 (reb-band-score (eq (reb-veq? v1 v1b) 1) 4))
            (let c3 (reb-band-score (eq (reb-veq? v1 v2) 1) 8))
            (let c4 (reb-band-score (eq (reb-veq? v1 v3) 0) 16))

            (add (add c0 c1) (add c2 (add c3 c4)))))

    (rag-embed-band))
