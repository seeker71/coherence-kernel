; preludes: form-stdlib/core.fk form-stdlib/shared-heart.fk
;
; shared-heart-band — the shared shape of the wisdom traditions, proven three-way:
; one binary carries five teachings x six traditions as a NUMERIC model; every
; word arrives as a symbol pack; the COMPLETENESS of the lattice (every teaching
; witnessed in every tradition) is the structural claim, proven from the model
; data. (docs/coherence-substrate/shared-heart.form; live witness:
; scripts/shared_heart_demo.sh — English, Spanish, German from one model.)
;
; Verdict 31 when the shared heart holds:
;   1   THE MODEL RIDES — the 30-row numeric lattice is in the emission
;   2   THE CORE IS TRADITION-FREE — no tradition or teaching word is baked in
;       the C: not Hindu, Buddh, Jud, Christ, Islam, Tao, golden, compassion,
;       unity — every word is pack; a community authors its own voice
;   4   THE PACK DOOR — open(argv[1])/read load the chosen tongue at runtime
;   8   THE LATTICE IS COMPLETE — from the model data: every teaching 1..5
;       carries exactly one expression in every tradition 1..6 (count = 6 per
;       teaching, 5 per tradition, 30 total) — completeness IS the shared shape
;   16  DETERMINISTIC + ORDERED — two emissions byte-identical; the first model
;       row is (12,1,1): teaching 1, tradition 1, pack line 12
(do
    (let c (fsh-emit))

    (let c0 (if (ge (str_find c "static const long long model[30][3]" 0) 0) 1 0))

    (let c1 (if (eq (str_find c "Hindu" 0) (sub 0 1))
            (if (eq (str_find c "Buddh" 0) (sub 0 1))
            (if (eq (str_find c "Christ" 0) (sub 0 1))
            (if (eq (str_find c "Islam" 0) (sub 0 1))
            (if (eq (str_find c "Tao" 0) (sub 0 1))
            (if (eq (str_find c "golden" 0) (sub 0 1))
            (if (eq (str_find c "compassion" 0) (sub 0 1))
            (if (eq (str_find c "unity" 0) (sub 0 1)) 2 0) 0) 0) 0) 0) 0) 0) 0))

    (let c2 (if (ge (str_find c "open(argv[1]" 0) 0)
            (if (ge (str_find c "read(fd, pack" 0) 0) 4 0) 0))

    ; completeness from the data: 6 expressions per teaching, 5 per tradition
    (defn fsh-count-t (rows t)
        (if (eq (len rows) 0) 0
            (add (if (eq (nth (head rows) 1) t) 1 0) (fsh-count-t (tail rows) t))))
    (defn fsh-count-d (rows d)
        (if (eq (len rows) 0) 0
            (add (if (eq (nth (head rows) 2) d) 1 0) (fsh-count-d (tail rows) d))))
    (let m (fsh-model))
    (let c3 (if (eq (len m) 30)
            (if (eq (fsh-count-t m 1) 6)
            (if (eq (fsh-count-t m 5) 6)
            (if (eq (fsh-count-d m 1) 5)
            (if (eq (fsh-count-d m 6) 5) 8 0) 0) 0) 0) 0))

    (let c4 (if (str_eq c (fsh-emit))
            (if (eq (nth (head m) 0) 12)
            (if (eq (nth (head m) 1) 1)
            (if (eq (nth (head m) 2) 1) 16 0) 0) 0) 0))

    (add c0 (add c1 (add c2 (add c3 c4)))))
