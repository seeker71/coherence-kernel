; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk
;
; fsh-fresh-probe — word-freshness asked with the body's own grep, not bash.
; Returns 10000*(corpus rows) + 1000*a + 100*b + 10*c + d for four candidates.
; A live nonzero row count is what makes any zero here an attested absence.

(do
    (let src (read_file "../learn/homecoming-distillation-corpus.fk"))
    (let rows (str_to_int (head (sh-bi-grep (list "-c" "(hdc-row ") src))))
    (let a (str_to_int (head (sh-bi-grep (list "-ci" "reflexdebt") src))))
    (let b (str_to_int (head (sh-bi-grep (list "-ci" "proofidle") src))))
    (let c (str_to_int (head (sh-bi-grep (list "-ci" "handolder") src))))
    (let d (str_to_int (head (sh-bi-grep (list "-ci" "unreached") src))))
    (add (mul rows 10000) (add (mul a 1000) (add (mul b 100) (add (mul c 10) d)))))
