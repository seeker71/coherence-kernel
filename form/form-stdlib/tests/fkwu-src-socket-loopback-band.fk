; fkwu-src-socket-loopback-band.fk -- direct-source runner socket smoke.
;
; This is not a replacement for tests/socket-loopback-band.fk's historical
; three-kernel proof. It is the narrow fresh-checkout witness for this repo's
; current `fkwu --src` lane: wrap lets inside a defn and use explicit add
; chains instead of the stdlib `sum` helper.
;
; Verdict: 111111111 when listen, port, connect, accept, client->server bytes,
; server->client bytes, and all closes pass over real 127.0.0.1 TCP.

(do
    (defn fsrc-score (cond bit) (if cond bit 0))
    (defn fsrc-socket-loopback-check ()
        (do
            (let srv (socket_listen 0))
            (let port (socket_port srv))
            (let cli (socket_connect "127.0.0.1" port))
            (let conn (socket_accept srv))
            (let sent1 (socket_send cli "PING"))
            (let got1 (socket_recv conn 4))
            (let sent2 (socket_send conn "PONG"))
            (let got2 (socket_recv cli 4))
            (let close1 (socket_close conn))
            (let close2 (socket_close cli))
            (let close3 (socket_close srv))
            (add
                (add
                    (add (fsrc-score (ge srv 1) 1)
                         (fsrc-score (gt port 0) 10))
                    (add (fsrc-score (ge cli 1) 100)
                         (fsrc-score (ge conn 1) 1000)))
                (add
                    (add (fsrc-score (str_eq got1 "PING") 10000)
                         (fsrc-score (str_eq got2 "PONG") 100000))
                    (add (fsrc-score (eq close1 0) 1000000)
                         (add (fsrc-score (eq close2 0) 10000000)
                              (fsrc-score (eq close3 0) 100000000)))))))
    (fsrc-socket-loopback-check))
