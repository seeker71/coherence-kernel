; runtime-trace-feedback-band.fk -- Layer 10c feedback agenda proof.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/runtime-artifact-executor-capability.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/runtime-program-image-fkb-attempt.fk form-stdlib/runtime-program-image-fkb-capability-bound.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/runtime-program-image-fkb-traced-capability-bound.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-trace-ingest.fk form-stdlib/runtime-trace-feedback.fk
;
; Expected: 16777215

(do
    (defn rtfb-score (ok bit) (if ok bit 0))
    (defn rtfb-manifest-has (name)
        (runtime-trace-feedback-manifest-has? name (runtime-trace-feedback-manifest)))
    (defn rtfb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rtfb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn rtfb-ready-path () "cache/min42.fkb")
    (defn rtfb-source-hash () "sha:src-42")
    (defn rtfb-content-hash () "sha:content-42")

    (defn rtfb-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn rtfb-pif ()
        (pif-envelope "src/min42.fk" (rtfb-source-hash) 100
                      (rtfb-ready-path) (rtfb-content-hash) 101
                      1
                      (rtfb-table)))
    (defn rtfb-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rtfb-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rtfb-envelope ()
        (do
            (let pif (rtfb-pif))
            (let src (rtfb-source-for-pif pif))
            (let fkb (rtfb-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rtfb-payload ()
        (do
            (let pif (rtfb-pif))
            (pifbd-payload (pif-envelope-source-path pif)
                           (pif-envelope-source-hash pif)
                           (pif-envelope-source-mtime pif)
                           (pif-envelope-artifact-path pif)
                           (pif-envelope-seal-ok pif)
                           (pif-envelope-table pif)
                           (pif-envelope-symbol-image pif))))
    (defn rtfb-decode () (pifbd-decoded-row (rtfb-payload) 123))
    (defn rtfb-admission ()
        (pifbd-admission (list "runtime-trace-feedback-synthetic-admission")
                         (rtfb-decode)
                         (rtfb-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))

    (defn rtfb-cap-for-envelope (e availability evidence authority freshness detail)
        (raec-capability (raec-cap-program-image-walker)
                         (rale-envelope-action e)
                         (rale-envelope-route e)
                         (rale-envelope-artifact-kind e)
                         availability evidence authority freshness detail))
    (defn rtfb-ready-cap ()
        (rtfb-cap-for-envelope (rtfb-envelope)
                               (raec-availability-available)
                               (raec-evidence-supplied-current)
                               (raec-authority-attempt-supplier)
                               (raec-freshness-current)
                               "supplied-current-program-image-walker"))
    (defn rtfb-readiness ()
        (raec-readiness-from-envelope-capability (rtfb-envelope) (rtfb-ready-cap)))
    (defn rtfb-no-capability-readiness ()
        (raec-readiness-from-envelope-no-capability (rtfb-envelope)))

    (defn rtfb-trace-with (status outputs first code stop detail)
        (rpiwt-trace (rtfb-ready-path)
                     (rtfb-source-hash)
                     (rtfb-content-hash)
                     (rpiwt-entry-kind-function-root)
                     0
                     0
                     1000
                     12
                     outputs
                     first
                     code
                     status
                     stop
                     detail))
    (defn rtfb-trace (status outputs first code stop)
        (rtfb-trace-with status outputs first code stop "synthetic-runtime-trace-feedback"))
    (defn rtfb-ok-trace () (rtfb-trace (rao-obs-ok) 1 42 0 (rpiwt-stop-completed)))
    (defn rtfb-invalid-trace ()
        (rpiwt-trace (rtfb-ready-path)
                     (rtfb-source-hash)
                     (rtfb-content-hash)
                     (rpiwt-entry-kind-function-root)
                     0
                     0
                     10
                     11
                     1
                     42
                     1
                     (rao-obs-timeout)
                     (rpiwt-stop-timeout)
                     "over-budget"))
    (defn rtfb-ok-stop-drift-trace ()
        (rtfb-trace-with (rao-obs-ok) 1 42 0 (rpiwt-stop-timeout) "ok-stop-drift"))

    (defn rtfb-join-from (readiness trace)
        (rpiftc-join-from-trace (rtfb-envelope) readiness (rtfb-admission) trace))
    (defn rtfb-join (status outputs first code stop)
        (rtfb-join-from (rtfb-readiness) (rtfb-trace status outputs first code stop)))
    (defn rtfb-ok-join () (rtfb-join-from (rtfb-readiness) (rtfb-ok-trace)))
    (defn rtfb-nonbound-ok-join () (rtfb-join-from (rtfb-no-capability-readiness) (rtfb-ok-trace)))
    (defn rtfb-record-from (readiness trace)
        (rti-record-from-join (rtfb-join-from readiness trace)))
    (defn rtfb-record (status outputs first code stop)
        (rti-record-from-join (rtfb-join status outputs first code stop)))
    (defn rtfb-ok-record () (rti-record-from-join (rtfb-ok-join)))
    (defn rtfb-nonbound-ok-record () (rti-record-from-join (rtfb-nonbound-ok-join)))
    (defn rtfb-ok-stop-drift-record ()
        (do
            (let ok (rtfb-ok-join))
            (rti-record-from-join
                (rpiftc-join-row (rtfb-envelope)
                                  (rtfb-readiness)
                                  (rtfb-admission)
                                  (rtfb-ok-stop-drift-trace)
                                  (rpiftc-join-trace-bridge ok)
                                  (rpiftc-join-capability-join ok)
                                  (rpiftc-join-attempt ok)
                                  (rpiftc-status-bound)
                                  (rpiftc-reason-bound)))))
    (defn rtfb-refused-record ()
        (rti-record-from-join (rtfb-join-from (rtfb-readiness) (rtfb-invalid-trace))))

    (defn rtfb-feedback (record) (rtf-feedback-from-record record))
    (defn rtfb-kind-of (record) (rtf-feedback-kind (rtfb-feedback record)))
    (defn rtfb-action-of (record) (rtf-feedback-agenda-action (rtfb-feedback record)))
    (defn rtfb-reason-of (record) (rtf-feedback-reason (rtfb-feedback record)))

    (defn rtfb-bit-manifest-1 ()
        (rtfb-score
            (and (eq (rtfb-manifest-has "layer-10c-feedback-agenda-not-runtime") 1)
            (and (eq (rtfb-manifest-has "consumes-10b-ingest-records-only") 1)
            (and (eq (rtfb-manifest-has "no-raw-trace-or-join-input") 1)
            (and (eq (rtfb-manifest-has "preserves-10b-fields") 1)
            (and (eq (rtfb-manifest-has "emits-work-items-not-state-changes") 1)
                 (eq (rtfb-manifest-has "propose-freeze-only") 1))))))
            1))
    (defn rtfb-bit-manifest-2 ()
        (rtfb-score
            (and (eq (rtfb-manifest-has "retain-liquid-witnesses") 1)
            (and (eq (rtfb-manifest-has "hard-statuses-become-investigation-work") 1)
            (and (eq (rtfb-manifest-has "oom-must-never-be-ignored") 1)
            (and (eq (rtfb-manifest-has "soft-statuses-become-repair-work") 1)
            (and (eq (rtfb-manifest-has "quarantine-stays-review-work") 1)
            (and (eq (rtfb-manifest-has "refused-evidence-stays-rejected") 1)
            (and (eq (rtfb-manifest-has "pure-agenda-selector") 1)
            (and (eq (rtfb-manifest-has "stable-first-tie-selection") 1)
            (and (eq (rtfb-manifest-has "no-storage-mutation") 1)
            (and (eq (rtfb-manifest-has "no-champion-update") 1)
            (and (eq (rtfb-manifest-has "no-artifact-load") 1)
            (and (eq (rtfb-manifest-has "no-native-call") 1)
            (and (eq (rtfb-manifest-has "no-selector-install") 1)
                 (eq (rtfb-manifest-has "no-c-seed-growth") 1))))))))))))))
            2))
    (defn rtfb-bit-version-feedback ()
        (do
            (let f (rtfb-feedback (rtfb-ok-record)))
            (rtfb-score
                (and (str_eq (rtf-version) "runtime-trace-feedback-v1")
                     (rtf-feedback? f))
                4)))
    (defn rtfb-bit-body-freeze-candidate ()
        (do
            (let f (rtfb-feedback (rtfb-ok-record)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-freeze-candidate))
                (and (str_eq (rtf-feedback-agenda-action f) (rtf-action-propose-freeze))
                (and (eq (rtf-feedback-freeze-eligible f) 1)
                (and (eq (rtf-feedback-priority f) 20)
                     (str_eq (rtf-feedback-reason f) (rtf-reason-freeze-candidate))))))
                8)))
    (defn rtfb-bit-nonbound-retain ()
        (do
            (let f (rtfb-feedback (rtfb-nonbound-ok-record)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-witness-retain))
                (and (str_eq (rtf-feedback-agenda-action f) (rtf-action-retain-liquid))
                (and (str_eq (rtf-feedback-memory-lane f) (rti-memory-liquid))
                (and (eq (rtf-feedback-freeze-eligible f) 0)
                     (str_eq (rtf-feedback-reason f) (rtf-reason-retain-liquid-witness))))))
                16)))
    (defn rtfb-bit-oom-investigation ()
        (do
            (let f (rtfb-feedback (rtfb-record (rao-obs-oom-killed) 0 0 137 (rpiwt-stop-oom-killed))))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-investigation-work-item))
                (and (str_eq (rtf-feedback-agenda-action f) (rtf-action-investigate-runtime-failure))
                (and (str_eq (rtf-feedback-prompt-class f) (rti-prompt-oom))
                (and (eq (rtf-feedback-priority f) 100)
                     (str_eq (rtf-feedback-reason f) (rtf-reason-hard-runtime-investigation))))))
                32)))
    (defn rtfb-bit-hard-statuses ()
        (do
            (let killed (rtfb-feedback (rtfb-record (rao-obs-killed) 0 0 137 (rpiwt-stop-killed))))
            (let stalled (rtfb-feedback (rtfb-record (rao-obs-stalled) 0 0 137 (rpiwt-stop-stalled))))
            (let timeout (rtfb-feedback (rtfb-record (rao-obs-timeout) 0 0 137 (rpiwt-stop-timeout))))
            (let wrong (rtfb-feedback (rtfb-record (rao-obs-wrong-value) 1 41 0 (rpiwt-stop-wrong-value))))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind killed) (rtf-kind-investigation-work-item))
                (and (str_eq (rtf-feedback-prompt-class killed) (rti-prompt-killed))
                (and (str_eq (rtf-feedback-prompt-class stalled) (rti-prompt-stalled))
                (and (str_eq (rtf-feedback-prompt-class timeout) (rti-prompt-timeout))
                (and (str_eq (rtf-feedback-prompt-class wrong) (rti-prompt-wrong-value))
                     (str_eq (rtf-feedback-agenda-action wrong) (rtf-action-investigate-runtime-failure)))))))
                64)))
    (defn rtfb-bit-soft-repair ()
        (do
            (let loader (rtfb-feedback (rtfb-record (rao-obs-loader-missing) 0 0 1 (rpiwt-stop-loader-missing))))
            (let err (rtfb-feedback (rtfb-record (rao-obs-error) 0 0 2 (rpiwt-stop-error))))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind loader) (rtf-kind-repair-work-item))
                (and (str_eq (rtf-feedback-agenda-action loader) (rtf-action-repair-runtime-route))
                (and (str_eq (rtf-feedback-prompt-class loader) (rti-prompt-loader-repair))
                (and (eq (rtf-feedback-priority loader) 60)
                (and (str_eq (rtf-feedback-prompt-class err) (rti-prompt-error-repair))
                     (str_eq (rtf-feedback-reason err) (rtf-reason-repair-runtime-route)))))))
                128)))
    (defn rtfb-bit-quarantine ()
        (do
            (let unknown (rtfb-feedback (rtfb-record "surprise-status" 0 0 1 (rpiwt-stop-unknown))))
            (let drift (rtfb-feedback (rtfb-ok-stop-drift-record)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind unknown) (rtf-kind-quarantine-work-item))
                (and (str_eq (rtf-feedback-agenda-action unknown) (rtf-action-hold-for-review))
                (and (str_eq (rtf-feedback-prompt-class unknown) (rti-prompt-unknown))
                (and (str_eq (rtf-feedback-kind drift) (rtf-kind-quarantine-work-item))
                     (str_eq (rtf-feedback-reason drift) (rtf-reason-quarantine-runtime-trace))))))
                256)))
    (defn rtfb-bit-refused-evidence ()
        (do
            (let f (rtfb-feedback (rtfb-refused-record)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-refused-evidence))
                (and (str_eq (rtf-feedback-agenda-action f) (rtf-action-reject-evidence))
                (and (str_eq (rtf-feedback-ingest-action f) (rti-action-refused))
                     (str_eq (rtf-feedback-reason f) (rtf-reason-refused-runtime-evidence)))))
                512)))
    (defn rtfb-bit-malformed-input ()
        (do
            (let f (rtf-feedback-from-record (list "not-ingest")))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-refused-evidence))
                (and (str_eq (rtf-feedback-agenda-action f) (rtf-action-reject-evidence))
                (and (eq (rtf-feedback-priority f) 0)
                     (str_eq (rtf-feedback-reason f) (rtf-reason-malformed-ingest-record)))))
                1024)))
    (defn rtfb-bit-raw-join-rejected ()
        (do
            (let f (rtf-feedback-from-record (rtfb-ok-join)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-refused-evidence))
                     (str_eq (rtf-feedback-reason f) (rtf-reason-malformed-ingest-record)))
                2048)))
    (defn rtfb-bit-preserved-fields ()
        (do
            (let f (rtfb-feedback (rtfb-ok-record)))
            (rtfb-score
                (and (str_eq (rtf-feedback-artifact-path f) (rtfb-ready-path))
                (and (str_eq (rtf-feedback-source-hash f) (rtfb-source-hash))
                (and (str_eq (rtf-feedback-content-hash f) (rtfb-content-hash))
                (and (str_eq (rtf-feedback-trace-status f) (rao-obs-ok))
                (and (str_eq (rtf-feedback-stop-reason f) (rpiwt-stop-completed))
                (and (str_eq (rtf-feedback-detail f) "synthetic-runtime-trace-feedback")
                (and (str_eq (rtf-feedback-prompt-class f) (rti-prompt-body-freeze))
                (and (eq (rtf-feedback-ingest-priority f) 10)
                     (str_eq (rtf-feedback-ingest-reason f) (rti-reason-body-freeze-eligible))))))))))
                4096)))
    (defn rtfb-bit-no-work-agenda ()
        (do
            (let f (rtf-agenda-best-feedback (empty)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-no-work))
                (and (str_eq (rtf-feedback-agenda-action f) (rtf-action-no-work))
                     (str_eq (rtf-feedback-reason f) (rtf-reason-empty-agenda))))
                8192)))
    (defn rtfb-bit-highest-priority-agenda ()
        (do
            (let body (rtfb-feedback (rtfb-ok-record)))
            (let repair (rtfb-feedback (rtfb-record (rao-obs-error) 0 0 2 (rpiwt-stop-error))))
            (let hard (rtfb-feedback (rtfb-record (rao-obs-timeout) 0 0 137 (rpiwt-stop-timeout))))
            (let best (rtf-agenda-best-feedback (list body repair hard)))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind best) (rtf-kind-investigation-work-item))
                     (str_eq (rtf-feedback-prompt-class best) (rti-prompt-timeout)))
                16384)))
    (defn rtfb-bit-first-tie-agenda ()
        (do
            (let killed (rtfb-feedback (rtfb-record (rao-obs-killed) 0 0 137 (rpiwt-stop-killed))))
            (let timeout (rtfb-feedback (rtfb-record (rao-obs-timeout) 0 0 137 (rpiwt-stop-timeout))))
            (let best (rtf-agenda-best-feedback (list killed timeout)))
            (rtfb-score
                (and (str_eq (rtf-feedback-prompt-class best) (rti-prompt-killed))
                     (eq (rtf-feedback-priority best) 100))
                32768)))
    (defn rtfb-observed-reasons ()
        (list
            (rtf-feedback-reason (rtfb-feedback (rtfb-ok-record)))
            (rtf-feedback-reason (rtfb-feedback (rtfb-nonbound-ok-record)))
            (rtf-feedback-reason (rtfb-feedback (rtfb-record (rao-obs-oom-killed) 0 0 137 (rpiwt-stop-oom-killed))))
            (rtf-feedback-reason (rtfb-feedback (rtfb-record (rao-obs-loader-missing) 0 0 1 (rpiwt-stop-loader-missing))))
            (rtf-feedback-reason (rtfb-feedback (rtfb-record "surprise-status" 0 0 1 (rpiwt-stop-unknown))))
            (rtf-feedback-reason (rtfb-feedback (rtfb-refused-record)))
            (rtf-feedback-reason (rtf-feedback-from-record (list "not-ingest")))))
    (defn rtfb-bit-reason-coverage ()
        (do
            (let coverage (rcov-coverage (rtf-reason-manifest) (rtfb-observed-reasons)))
            (rtfb-score (rcov-covered? coverage) 65536)))
    (defn rtfb-none-of? (text needles)
        (if (nil? needles)
            1
            (if (rtfb-has? text (head needles))
                0
                (rtfb-none-of? text (tail needles)))))
    (defn rtfb-forbidden-needles ()
        (list "rpiftc-" "rpiwt-" "rpifc-" "rpifa-" "raar-" "raec-"
              "rtta-" "rti-record-from-join" "rti-record-row"
              "rti-empty-record" "read_file" "read_file_slice"
              "write_file" "append_file" "remove_file" "fs-" ".tbl"
              "table-text" "program-image-tbl-emit" "write_form_binary"
              "read_form_binary" "recipe_to_bytes" "bytes_to_recipe"
              "form-eval" "fk_run" "dlopen" "bp_table" "bpTable"
              "BP_TABLE" "storage mutation" "champion update"
              "selector install"))
    (defn rtfb-bit-static-mirror ()
        (do
            (let text (rtfb-read-file-any "form/form-stdlib/runtime-trace-feedback.fk"
                                          "../form/form-stdlib/runtime-trace-feedback.fk"))
            (let grammar (rtfb-read-file-any "grammars/runtime-trace-feedback.fk"
                                             "../grammars/runtime-trace-feedback.fk"))
            (rtfb-score
                (and (str_eq text grammar)
                     (eq (rtfb-none-of? text (rtfb-forbidden-needles)) 1))
                131072)))
    (defn rtfb-bit-architecture-receipt ()
        (do
            (let arch (rtfb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                          "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rtfb-read-file-any "../receipts/2026-07-04-runtime-trace-feedback-layer-review.md"
                                             "receipts/2026-07-04-runtime-trace-feedback-layer-review.md"))
            (rtfb-score
                (and (rtfb-has? arch "10c. Runtime trace feedback")
                (and (rtfb-has? receipt "Layer 10c")
                (and (rtfb-has? receipt "not runtime progress")
                (and (rtfb-has? receipt "consumes 10b ingest records")
                (and (rtfb-has? receipt "does not execute")
                (and (rtfb-has? receipt "propose-freeze only")
                (and (rtfb-has? receipt "OOM must never be ignored")
                     (rtfb-has? receipt "pure agenda selector"))))))))
                262144)))
    (defn rtfb-bit-feedbacks-from-records ()
        (do
            (let fs (rtf-feedbacks-from-records
                        (list (rtfb-nonbound-ok-record)
                              (rtfb-record (rao-obs-error) 0 0 2 (rpiwt-stop-error)))))
            (let best (rtf-agenda-best-feedback fs))
            (rtfb-score
                (and (eq (len fs) 2)
                     (str_eq (rtf-feedback-kind best) (rtf-kind-repair-work-item)))
                524288)))
    (defn rtfb-bit-priority-order ()
        (do
            (let hard (rtfb-feedback (rtfb-record (rao-obs-timeout) 0 0 137 (rpiwt-stop-timeout))))
            (let soft (rtfb-feedback (rtfb-record (rao-obs-error) 0 0 2 (rpiwt-stop-error))))
            (let unknown (rtfb-feedback (rtfb-record "surprise-status" 0 0 1 (rpiwt-stop-unknown))))
            (let body (rtfb-feedback (rtfb-ok-record)))
            (let liquid (rtfb-feedback (rtfb-nonbound-ok-record)))
            (rtfb-score
                (and (gt (rtf-feedback-priority hard) (rtf-feedback-priority soft))
                (and (gt (rtf-feedback-priority soft) (rtf-feedback-priority unknown))
                (and (gt (rtf-feedback-priority unknown) (rtf-feedback-priority body))
                     (gt (rtf-feedback-priority body) (rtf-feedback-priority liquid)))))
                1048576)))
    (defn rtfb-bit-row-accessors ()
        (do
            (let f (rtfb-feedback (rtfb-ok-record)))
            (rtfb-score
                (and (rti-record? (rtf-feedback-ingest-record f))
                (and (str_eq (rtf-feedback-memory-lane f) (rti-memory-body))
                (and (str_eq (rtf-feedback-ingest-action f) (rti-action-witness))
                (and (str_eq (rtf-feedback-kind f) (rtf-kind-freeze-candidate))
                     (str_eq (rtf-feedback-agenda-action f) (rtf-action-propose-freeze))))))
                2097152)))
    (defn rtfb-bit-best-from-records ()
        (do
            (let best (rtf-agenda-best-from-records
                        (list (rtfb-ok-record)
                              (rtfb-record (rao-obs-loader-missing) 0 0 1 (rpiwt-stop-loader-missing))
                              (rtfb-record (rao-obs-oom-killed) 0 0 137 (rpiwt-stop-oom-killed)))))
            (rtfb-score
                (and (str_eq (rtf-feedback-kind best) (rtf-kind-investigation-work-item))
                     (str_eq (rtf-feedback-prompt-class best) (rti-prompt-oom)))
                4194304)))
    (defn rtfb-bit-upstream-10b-neighbor ()
        (do
            (let r (rtfb-ok-record))
            (rtfb-score
                (and (rti-record? r)
                (and (str_eq (rti-record-memory-lane r) (rti-memory-body))
                     (str_eq (rti-record-reason r) (rti-reason-body-freeze-eligible))))
                8388608)))

    (defn runtime-trace-feedback-band ()
        (sum (list
            (rtfb-bit-manifest-1)
