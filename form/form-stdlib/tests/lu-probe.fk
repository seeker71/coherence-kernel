; preludes: form-stdlib/core.fk form-stdlib/transformer-numerics.fk form-stdlib/loss.fk
(do
    (let a -1.0e30)
    (let b (loss-ln 32.0))
    (let c (tn-softmax (list 1.0 2.0 3.0)))
    (let d (nth c 2))
    (if (lt a -1.0)
        (if (gt b 3.46) (if (lt b 3.47) (if (gt d 0.66) (if (lt d 0.67) 7 0) 0) 0) 0) 0))
