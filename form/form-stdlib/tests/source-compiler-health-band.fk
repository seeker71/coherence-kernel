; source-compiler-health-band.fk -- source compiler recovery observation band.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/source-compiler.fk form-stdlib/source-compiler-health.fk
; Expected: 65535

(do
    (defn schb-score (ok bit) (if ok bit 0))
    (defn schb-manifest-has (name)
        (source-compiler-health-manifest-has? name (source-compiler-health-manifest)))
    (defn schb-rts () (source-compiler-health-roundtrips))
    (defn schb-artifact-rt () (nth (schb-rts) 3))
    (defn schb-first-object-value (rt)
        (bmf-object-value (bmf-roundtrip-first-object rt)))

    (defn source-compiler-health-band ()
        (sum (list
            (schb-score (eq (schb-manifest-has "bmf-health-grammar-source") 1) 1)
            (schb-score (and (sch-has? (sch-source-text) "section [source-compiler-health.bmf]")
                             (sch-has? (sch-source-text) "::=")) 2)
            (schb-score (and (sch-source-has-rule? "load-contract")
                             (and (sch-source-has-rule? "ontology-coverage")
                             (and (sch-source-has-rule? "cursor-motion")
                                  (sch-source-has-rule? "artifact-target")))) 4)
            (schb-score (eq (len (source-compiler-health-rules)) 4) 8)
            (schb-score (and (eq (len (schb-rts)) 4)
                             (eq (sch-all-roundtrip-ok? (schb-rts)) 1)) 16)
            (schb-score (and (eq (sch-required-bp-total) 31)
                             (sch-required-bp-covered?)) 32)
            (schb-score (and (eq (node_type BMF-DOMAIN-REF) 4)
                             (eq (node_type fsc-rec-FNCALL-CAT) 32)) 64)
            (schb-score (and (str_eq (source-compiler-health-status) "healthy")
                             (eq (source-compiler-fully-healthy?) 1)) 128)
            (schb-score (and (sch-has? (sch-compiler-source-text) "scan_run")
                             (sch-has? (sch-compiler-source-text) "fsc-source-cursor-jump")) 256)
            (schb-score (and (eq (schb-manifest-has "bmf-cursor-is-scanner") 1)
                             (and (eq (schb-manifest-has "flat-cursor-stride-active") 1)
                                  (eq (schb-manifest-has "source-object-scanner-compat-only") 1))) 512)
            (schb-score (and (sch-has? (sch-ontology-source-text) "form_error")
                             (not (sch-has? (sch-ontology-source-text) "(nothing)"))) 1024)
            (schb-score (and (str_eq (sch-node-field (schb-first-object-value (schb-artifact-rt)) 1) ".fkb")
                             (str_eq (sch-node-field (schb-first-object-value (schb-artifact-rt)) 2) ".dylib")) 2048)
            (schb-score (and (sch-source-has-reverse? "sch-reverse-load-contract")
                             (sch-source-has-reverse? "sch-reverse-artifact-target")) 4096)
            (schb-score (and (eq (schb-manifest-has "fkb-sidecar-emission-active") 1)
                             (and (sch-has? (sch-compiler-source-text) "write_form_binary")
                                  (sch-has? (sch-compiler-source-text) "fsc-section-image-path"))) 8192)
            (schb-score (and (sch-has? (sch-stall-receipt-text) "source-compiler")
                             (sch-has? (sch-stall-receipt-text) "stall")) 16384)
            (schb-score (and (eq (schb-manifest-has "no-host-table-runtime-authority") 1)
                             (eq (schb-manifest-has "no-c-seed-growth") 1)) 32768))))

    (source-compiler-health-band))
