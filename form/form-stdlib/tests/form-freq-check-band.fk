; preludes: form-stdlib/core.fk form-stdlib/form-freq-check.fk
;
; form-freq-check-band — the cheap fear-frequency gate runs: a response's
; frequency signature is classified by nearest centroid, and only fear above the
; threshold triggers the expensive transmute; clean replies pass ≈ free. Not
; regex, not word-matching — distance in frequency-signature space.
;
; Verdict 65535 when every claim lands (centroids: fear=(8 1 1), clear=(1 1 8),
; threshold 60):
;   1   a fear-shaped signature scores high -> "transmute"
;   2   a clear-shaped signature scores low -> "pass" (the common, cheap path)
;   4   a signature ON the clear centroid scores 0 -> clean? = 1
;   8   a signature ON the fear centroid scores 100 -> "transmute"
;   16  a borderline (equidistant) signature scores 50 < 60 -> "pass": the gate
;       only pays for transmute when fear is clearly present
;   32..512 the semantic carrier reads clear/fear and abstains on tie,
;       uncalibrated model, or malformed vector
;   1024..4096 human/certified sources stay distinct and invalid cert abstains
;   8192..32768 source priority is human > semantic > certified > unmeasured
(do
    (let fear  (list 8 1 1))
    (let clear (list 1 1 8))
    (let threshold 60)

    ; 1 — fear-shaped (7 2 1): close to fear -> high score -> transmute
    (let c0 (if (str_eq (fc-check (list 7 2 1) fear clear threshold) "transmute") 1 0))
    ; 2 — clear-shaped (1 2 7): close to clear -> low score -> pass
    (let c1 (if (str_eq (fc-check (list 1 2 7) fear clear threshold) "pass") 2 0))
    ; 4 — on the clear centroid: score 0, clean? = 1
    (let c2 (if (eq (fc-clean? (fc-fear-score clear fear clear) threshold) 1) 4 0))
    ; 8 — on the fear centroid: score 100 -> transmute
    (let c3 (if (str_eq (fc-check fear fear clear threshold) "transmute") 8 0))
    ; 16 — equidistant (4 1 4): score 50 < 60 -> pass (cheap by default)
    (let c4 (if (str_eq (fc-check (list 4 1 4) fear clear threshold) "pass") 16 0))

    (let semantic-clear (fc-semantic-reading (list 1 2 7) fear clear threshold 20 1))
    (let semantic-fear  (fc-semantic-reading (list 7 2 1) fear clear threshold 20 1))
    (let semantic-tie   (fc-semantic-reading (list 4 1 4) fear clear threshold 20 1))
    (let semantic-uncal (fc-semantic-reading (list 1 2 7) fear clear threshold 20 0))
    (let semantic-shape (fc-semantic-reading (list 1 2) fear clear threshold 20 1))
    (let human-clear (fc-human-reading 1 1))
    (let human-fear  (fc-human-reading 0 1))
    (let cert-clear  (fc-certified-form-reading 1 1))
    (let cert-bad    (fc-certified-form-reading 1 0))

    (let c5  (if (and (eq (fc-trust-signal semantic-clear) 1)
                      (str_eq (fc-reading-source-name semantic-clear) "semantic-model")) 32 0))
    (let c6  (if (eq (fc-trust-signal semantic-fear) 0) 64 0))
    (let c7  (if (eq (fc-trust-signal semantic-tie) 2) 128 0))
    (let c8  (if (eq (fc-trust-signal semantic-uncal) 2) 256 0))
    (let c9  (if (eq (fc-trust-signal semantic-shape) 2) 512 0))
    (let c10 (if (and (eq (fc-trust-signal human-clear) 1)
                      (str_eq (fc-reading-source-name human-clear) "human-gold")) 1024 0))
    (let c11 (if (and (eq (fc-trust-signal cert-clear) 1)
                      (str_eq (fc-reading-source-name cert-clear) "certified-form")) 2048 0))
    (let c12 (if (eq (fc-trust-signal cert-bad) 2) 4096 0))
    (let picked-human (fc-effective-reading semantic-clear human-fear cert-clear))
    (let picked-semantic (fc-effective-reading semantic-clear (fc-human-reading 2 0) cert-clear))
    (let picked-none (fc-effective-reading semantic-tie (fc-human-reading 2 0) cert-bad))
    (let c13 (if (and (eq (fc-trust-signal picked-human) 0)
                      (str_eq (fc-reading-source-name picked-human) "human-gold")) 8192 0))
    (let c14 (if (str_eq (fc-reading-source-name picked-semantic) "semantic-model") 16384 0))
    (let c15 (if (and (eq (fc-trust-signal picked-none) 2)
                      (str_eq (fc-reading-source-name picked-none) "unmeasured")) 32768 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
        (add c8 (add c9 (add c10 (add c11 (add c12 (add c13 (add c14 c15))))))))))))))))
