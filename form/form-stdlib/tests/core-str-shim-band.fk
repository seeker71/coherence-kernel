; core-str-shim-band.fk — regression guard for char_at/ord on fkwu --src.
;
; preludes: form-stdlib/core.fk
;
; Before this shim landed (form-stdlib/core.fk), `(ord (char_at "hello" 0))`
; on `fkwu --src` silently returned `nothing` instead of `104` — no error,
; just a wrong answer that corrupted anything built on it (see
; receipts/2026-07-01-tier0-ord-char-at-shim.md). This band exists so that
; regression can never again pass silently: if char_at/ord drift, this file
; fails loudly instead of some downstream file quietly writing null bytes.
;
; Verdict 15 when every assertion holds on fkwu --src.

(do
    (defn cssb-score (ok bit) (if ok bit 0))
    (defn core-str-shim-band ()
        (do
    (let c0 (cssb-score (eq (ord (char_at "hello" 0)) 104) 1))     ; 'h'
    (let c1 (cssb-score (eq (ord (char_at "hello" 4)) 111) 2))     ; 'o', not just index 0
    (let c2 (cssb-score (str_eq (char_at "hello" 1) "e") 4))
    (let c3 (cssb-score (eq (ord (char_at "a" 0)) 97) 8))
    (add c0 (add c1 (add c2 c3))))
    )
    (core-str-shim-band))
