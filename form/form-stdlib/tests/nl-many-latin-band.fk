; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/string-case.fk form-stdlib/nl-lexicon-data.fk form-stdlib/nl-translate.fk form-stdlib/nl-tongues.fk
;
; nl-many-latin-band.fk — the tongue shelf's FOUR-WAY floor: six tongues, one node.
;
; The ASCII-surface slice of the shelf (es fr pt sw from nl-tongues; en id from
; nl-translate): every parse of "the body is cell" in any of the six interns to
; the identical pivot node, every decode round-trips to the same node, and a
; chain es -> fr -> pt -> sw holds it fixed. This is the slice ALL FOUR kernels
; agree on today. The full shelf (13 tongues, 6 scripts) is fourth-arm-proven in
; nl-many-band.fk (16777215) and blocked from four-way by the cross-kernel
; string-unit seam: fkwu's char_at walks bytes while go/rust/ts return the whole
; char at a start and nothing inside it, so byte-stepped runs break inside any
; multibyte char on those legs. Named, not hidden — cursor unit parity is the
; tongue shelf's next door.
;
; Bits: 4 tongues x (parse ≡ pivot, round-trip ≡ pivot) = 8; bit 8: elder id
; agrees; bit 9: the es->fr->pt->sw chain holds. Verdict 1023.
(do
    (let pivot (norm-en (g-parse (nl-en) "the body is cell")))

    (defn pair (enc-node rt-node pv bit-lo)
        (add (if (node_eq enc-node pv) bit-lo 0)
             (if (node_eq rt-node pv) (mul bit-lo 2) 0)))

    (let c-es (pair (nlm-enc-es "el cuerpo es celula") (nlm-enc-es (nlm-dec-es pivot)) pivot 1))
    (let c-fr (pair (nlm-enc-fr "le corps est cellule") (nlm-enc-fr (nlm-dec-fr pivot)) pivot 4))
    (let c-pt (pair (nlm-enc-pt "o corpo e celula") (nlm-enc-pt (nlm-dec-pt pivot)) pivot 16))
    (let c-sw (pair (nlm-enc-sw "mwili ni seli") (nlm-enc-sw (nlm-dec-sw pivot)) pivot 64))

    (let c-elder (if (node_eq (norm-id (g-parse (nl-id) "tubuh adalah sel")) pivot) 256 0))
    (let c-chain (if (node_eq
        (nlm-enc-sw (nlm-dec-sw (nlm-enc-pt (nlm-dec-pt (nlm-enc-fr (nlm-dec-fr (nlm-enc-es (nlm-dec-es pivot))))))))
        pivot) 512 0))

    (add c-es (add c-fr (add c-pt (add c-sw (add c-elder c-chain))))))
