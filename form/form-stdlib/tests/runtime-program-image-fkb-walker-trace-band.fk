            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-non-admitted-admission) (rpiwtb-ok-trace)))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-nondecoded-admission) (rpiwtb-ok-trace)))
