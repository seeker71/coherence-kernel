    (defn rpiwtb-bit-no-laundering ()
        (do
            (let b (rpiwtb-ok-bridge))
            (let r (rpiwtb-receipt-from-bridge b))
            (rpiwtb-score
                (and (rpiwtb-has? (rpifa-run-detail (rpiwt-bridge-run b)) (rpiwt-marker))
                (and (rpiwtb-has? (raar-receipt-detail r) (rpiwt-marker))
                (and (not (rpiwtb-has? (raar-receipt-detail r) "native-dylib"))
                     (not (rpiwtb-has? (raar-receipt-detail r) "legacy-table")))))
                1073741824)))

    (defn runtime-program-image-fkb-walker-trace-band ()
        (sum (list
            (rpiwtb-bit-manifest-1)
            (rpiwtb-bit-manifest-2)
            (rpiwtb-bit-version)
            (rpiwtb-bit-happy-trace-ready)
            (rpiwtb-bit-9h1-attempt-visible)
            (rpiwtb-bit-attempt-tuple-matches-envelope)
            (rpiwtb-bit-9f-9c-ok-complete)
            (rpiwtb-bit-structured-fields-survive)
            (rpiwtb-bit-hard-statuses-preserved)
            (rpiwtb-bit-soft-and-unknown-preserved)
            (rpiwtb-bit-ok-zero-output)
            (rpiwtb-bit-negative-counters)
            (rpiwtb-bit-over-budget)
            (rpiwtb-bit-negative-output)
            (rpiwtb-bit-entry-invalid)
            (rpiwtb-bit-root-invalid)
            (rpiwtb-bit-trace-identity-mismatch)
            (rpiwtb-bit-pif-identity-mismatch)
            (rpiwtb-bit-envelope-kind)
            (rpiwtb-bit-admission-failures)
            (rpiwtb-bit-decode-invalid-failures)
            (rpiwtb-bit-malformed-trace)
            (rpiwtb-bit-stop-mismatch)
            (rpiwtb-bit-reason-coverage)
            (rpiwtb-bit-static-mirror)
            (rpiwtb-bit-architecture-receipt)
            (rpiwtb-bit-no-invalid-trace-attempt)
            (rpiwtb-bit-unknown-status-lowered)
            (rpiwtb-bit-nested-9h1-reason-visible)
            (rpiwtb-bit-current-floor-honesty)
            (rpiwtb-bit-no-laundering))))

    (runtime-program-image-fkb-walker-trace-band))
