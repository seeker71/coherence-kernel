; runtime-program-image-fkb-walker-trace-band.fk -- 9h3 structured walker trace adapter.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/runtime-program-image-fkb-attempt.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk
;
; Expected: 2147483647

(do
    (defn rpiwtb-score (ok bit) (if ok bit 0))
    (defn rpiwtb-manifest-has (name)
        (runtime-program-image-fkb-walker-trace-manifest-has? name (runtime-program-image-fkb-walker-trace-manifest)))
    (defn rpiwtb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rpiwtb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn rpiwtb-ready-path () "cache/min42.fkb")
    (defn rpiwtb-other-path () "cache/other.fkb")
    (defn rpiwtb-source-hash () "sha:src-42")
    (defn rpiwtb-other-source-hash () "sha:other-src")
    (defn rpiwtb-content-hash () "sha:content-42")
    (defn rpiwtb-other-content-hash () "sha:other-content")

    (defn rpiwtb-table ()
        (pif-table-image 2
                         (list 0 1)
                         2
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 1 7 0 0))
                         0
                         (empty)))
    (defn rpiwtb-pif-with (path source-hash content-hash seal-ok)
        (pif-envelope "src/min42.fk" source-hash 100
                      path content-hash 101
                      seal-ok
                      (rpiwtb-table)))
    (defn rpiwtb-pif ()
        (rpiwtb-pif-with (rpiwtb-ready-path)
                         (rpiwtb-source-hash)
                         (rpiwtb-content-hash)
                         1))
    (defn rpiwtb-pif-path-other ()
        (rpiwtb-pif-with (rpiwtb-other-path)
                         (rpiwtb-source-hash)
                         (rpiwtb-content-hash)
                         1))
    (defn rpiwtb-pif-source-other ()
        (rpiwtb-pif-with (rpiwtb-ready-path)
                         (rpiwtb-other-source-hash)
                         (rpiwtb-content-hash)
                         1))
    (defn rpiwtb-pif-content-other ()
        (rpiwtb-pif-with (rpiwtb-ready-path)
                         (rpiwtb-source-hash)
                         (rpiwtb-other-content-hash)
                         1))
    (defn rpiwtb-pif-invalid ()
        (rpiwtb-pif-with (rpiwtb-ready-path)
                         (rpiwtb-source-hash)
                         (rpiwtb-content-hash)
                         0))

    (defn rpiwtb-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rpiwtb-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rpiwtb-envelope-for-pif (pif)
        (do
            (let src (rpiwtb-source-for-pif pif))
            (let fkb (rpiwtb-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rpiwtb-envelope () (rpiwtb-envelope-for-pif (rpiwtb-pif)))
    (defn rpiwtb-compile-envelope ()
        (do
            (let src (sad-source "src/min42.fk" (rpiwtb-source-hash) 100))
            (let sel (ras-selection-from-plan
                        (rap-plan-from-descriptors src (sad-no-artifact) (sad-no-artifact))))
            (rale-envelope-from-selection src (sad-no-artifact) (sad-no-artifact) sel)))

    (defn rpiwtb-payload-for-pif (pif)
        (pifbd-payload (pif-envelope-source-path pif)
                       (pif-envelope-source-hash pif)
                       (pif-envelope-source-mtime pif)
                       (pif-envelope-artifact-path pif)
                       (pif-envelope-seal-ok pif)
                       (pif-envelope-table pif)
                       (pif-envelope-symbol-image pif)))
    (defn rpiwtb-decode-for-pif (pif)
        (pifbd-decoded-row (rpiwtb-payload-for-pif pif) 123))
    (defn rpiwtb-admission-for-pif (pif)
        (pifbd-admission (list "runtime-program-image-fkb-walker-trace-synthetic-admission")
                         (rpiwtb-decode-for-pif pif)
                         pif
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpiwtb-admission () (rpiwtb-admission-for-pif (rpiwtb-pif)))
    (defn rpiwtb-non-admitted-admission ()
        (pifbd-investigate-row (list "runtime-program-image-fkb-walker-trace-non-admitted")
                               (rpiwtb-decode-for-pif (rpiwtb-pif))
                               (rpiwtb-pif)
                               (pifbd-reason-non-ready-witness)))
    (defn rpiwtb-refused-admission ()
        (pifbd-refused-row (list "runtime-program-image-fkb-walker-trace-refused")
                           (pifbd-reason-malformed-witness)))
    (defn rpiwtb-nondecoded-admission ()
        (pifbd-admission (list "runtime-program-image-fkb-walker-trace-nondecoded")
                         (pifbd-decode-row (pifbd-no-payload) 0 (pifbd-status-refused) (pifbd-reason-bad-magic))
                         (rpiwtb-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpiwtb-invalid-pif-admission ()
        (pifbd-admission (list "runtime-program-image-fkb-walker-trace-invalid-pif")
                         (rpiwtb-decode-for-pif (rpiwtb-pif))
                         (rpiwtb-pif-invalid)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpiwtb-decode-pif-mismatch-admission ()
        (pifbd-admission (list "runtime-program-image-fkb-walker-trace-decode-mismatch")
                         (rpiwtb-decode-for-pif (rpiwtb-pif-path-other))
                         (rpiwtb-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))

    (defn rpiwtb-trace-with (path source-hash content-hash entry-kind entry-index root-node step-budget steps-used outputs first code status stop detail)
        (rpiwt-trace path source-hash content-hash entry-kind entry-index root-node
                     step-budget steps-used outputs first code status stop detail))
    (defn rpiwtb-trace (status first outputs code stop)
        (rpiwtb-trace-with (rpiwtb-ready-path)
                           (rpiwtb-source-hash)
                           (rpiwtb-content-hash)
                           (rpiwt-entry-kind-function-root)
                           0
                           0
                           1000
                           12
                           outputs
                           first
                           code
                           status
                           stop
                           "synthetic-structured-trace"))
    (defn rpiwtb-ok-trace () (rpiwtb-trace (rao-obs-ok) 42 1 0 (rpiwt-stop-completed)))
    (defn rpiwtb-bridge-from (envelope admission trace)
        (rpiwt-bridge-from-trace envelope admission trace))
    (defn rpiwtb-bridge (status first outputs code stop)
        (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace status first outputs code stop)))
    (defn rpiwtb-ok-bridge () (rpiwtb-bridge (rao-obs-ok) 42 1 0 (rpiwt-stop-completed)))
    (defn rpiwtb-ready? (b) (str_eq (rpiwt-bridge-status b) (rpiwt-status-trace-ready)))
    (defn rpiwtb-investigate? (b) (str_eq (rpiwt-bridge-status b) (rpiwt-status-investigate)))
    (defn rpiwtb-refused? (b) (str_eq (rpiwt-bridge-status b) (rpiwt-status-refused)))
    (defn rpiwtb-reason? (b reason) (str_eq (rpiwt-bridge-reason b) reason))
    (defn rpiwtb-no-run? (b) (rpiwt-no-run? (rpiwt-bridge-run b)))
    (defn rpiwtb-no-9h1? (b) (rpiwt-no-9h1-bridge? (rpiwt-bridge-9h1 b)))
    (defn rpiwtb-9h1-ready? (b)
        (if (rpifa-bridge? (rpiwt-bridge-9h1 b))
            (str_eq (rpifa-bridge-status (rpiwt-bridge-9h1 b)) (rpifa-status-attempt-ready))
            0))
    (defn rpiwtb-receipt-from-bridge (b)
        (raar-receipt-from-envelope-attempt
            (rpifa-bridge-envelope (rpiwt-bridge-9h1 b))
            (rpifa-bridge-attempt (rpiwt-bridge-9h1 b))))
    (defn rpiwtb-outcome-from-bridge (b)
        (do
            (let r (rpiwtb-receipt-from-bridge b))
            (rao-outcome-from-selection-observation
                (raar-receipt-selection r)
                (raar-receipt-derived-observation r))))

    (defn rpiwtb-bit-manifest-1 ()
        (rpiwtb-score
            (and (eq (rpiwtb-manifest-has "walker-trace-adapter-not-loader") 1)
            (and (eq (rpiwtb-manifest-has "structured-resource-facts") 1)
            (and (eq (rpiwtb-manifest-has "trace-identity-bound-to-envelope-and-admission") 1)
            (and (eq (rpiwtb-manifest-has "function-root-entry-only") 1)
            (and (eq (rpiwtb-manifest-has "entry-root-validated") 1)
            (and (eq (rpiwtb-manifest-has "resource-counters-sane") 1)
            (and (eq (rpiwtb-manifest-has "ok-requires-completed-output") 1)
            (and (eq (rpiwtb-manifest-has "hard-statuses-preserved") 1)
                 (eq (rpiwtb-manifest-has "soft-and-unknown-statuses-preserved") 1)))))))))
            1))
    (defn rpiwtb-bit-manifest-2 ()
        (rpiwtb-score
            (and (eq (rpiwtb-manifest-has "lowers-to-9h1-supplied-run") 1)
            (and (eq (rpiwtb-manifest-has "9h1-bridge-visible") 1)
            (and (eq (rpiwtb-manifest-has "no-executor-capability-consumption") 1)
            (and (eq (rpiwtb-manifest-has "no-artifact-io") 1)
            (and (eq (rpiwtb-manifest-has "no-program-image-walk") 1)
            (and (eq (rpiwtb-manifest-has "no-native-call") 1)
            (and (eq (rpiwtb-manifest-has "no-selector-install") 1)
            (and (eq (rpiwtb-manifest-has "no-c-seed-growth") 1)
                 (eq (rpiwtb-manifest-has "future-real-9h-walker-still-pending") 1)))))))))
            2))
    (defn rpiwtb-bit-version ()
        (rpiwtb-score (str_eq (rpiwt-version) "runtime-program-image-fkb-walker-trace-v1") 4))
    (defn rpiwtb-bit-happy-trace-ready ()
        (do
            (let b (rpiwtb-ok-bridge))
            (rpiwtb-score
                (and (rpiwtb-ready? b)
                (and (rpiwtb-reason? b (rpiwt-reason-trace-lowered))
                (and (rpifa-supplied-run? (rpiwt-bridge-run b))
                     (rpiwtb-9h1-ready? b))))
                8)))
    (defn rpiwtb-bit-9h1-attempt-visible ()
        (do
            (let b (rpiwtb-ok-bridge))
            (rpiwtb-score
                (and (rpiwtb-ready? b)
                (and (rpifa-bridge? (rpiwt-bridge-9h1 b))
                     (raar-supplied-attempt? (rpifa-bridge-attempt (rpiwt-bridge-9h1 b)))))
                16)))
    (defn rpiwtb-bit-attempt-tuple-matches-envelope ()
        (do
            (let e (rpiwtb-envelope))
            (let a (rpifa-bridge-attempt (rpiwt-bridge-9h1 (rpiwtb-ok-bridge))))
            (rpiwtb-score
                (and (str_eq (raar-attempt-action a) (rale-envelope-action e))
                (and (eq (raar-attempt-route a) (rale-envelope-route e))
                (and (str_eq (raar-attempt-artifact-kind a) (rale-envelope-artifact-kind e))
                (and (str_eq (raar-attempt-artifact-path a) (rale-envelope-artifact-path e))
                (and (str_eq (raar-attempt-source-hash a) (rale-envelope-source-hash e))
                     (str_eq (raar-attempt-content-hash a) (rale-envelope-content-hash e)))))))
                32)))
    (defn rpiwtb-bit-9f-9c-ok-complete ()
        (do
            (let b (rpiwtb-ok-bridge))
            (let r (rpiwtb-receipt-from-bridge b))
            (let o (rpiwtb-outcome-from-bridge b))
            (rpiwtb-score
                (and (str_eq (raar-receipt-status r) (raar-status-observed))
                (and (str_eq (raar-receipt-attempt-status r) (rao-obs-ok))
                (and (str_eq (rao-outcome-status o) (rao-status-complete))
                     (str_eq (rao-outcome-reason o) (rao-reason-observation-ok)))))
                64)))
    (defn rpiwtb-bit-structured-fields-survive ()
        (do
            (let b (rpiwtb-ok-bridge))
            (let t (rpiwt-bridge-trace b))
            (let run (rpiwt-bridge-run b))
            (rpiwtb-score
                (and (eq (rpiwt-trace-step-budget t) 1000)
                (and (eq (rpiwt-trace-steps-used t) 12)
                (and (eq (rpiwt-trace-entry-index t) 0)
                (and (eq (rpiwt-trace-root-node t) 0)
                (and (rpiwtb-has? (rpifa-run-detail run) (rpiwt-marker))
                     (rpiwtb-has? (rpifa-run-detail run) "stop=completed"))))))
                128)))
    (defn rpiwtb-hard-ready? (status stop)
        (do
            (let b (rpiwtb-bridge status 0 0 137 stop))
            (let r (rpiwtb-receipt-from-bridge b))
            (let o (rpiwtb-outcome-from-bridge b))
            (and (rpiwtb-ready? b)
            (and (str_eq (raar-receipt-attempt-status r) status)
                 (str_eq (rao-outcome-reason o) (rao-reason-hard-observation-investigates))))))
    (defn rpiwtb-bit-hard-statuses-preserved ()
        (rpiwtb-score
            (and (rpiwtb-hard-ready? (rao-obs-oom-killed) (rpiwt-stop-oom-killed))
            (and (rpiwtb-hard-ready? (rao-obs-killed) (rpiwt-stop-killed))
            (and (rpiwtb-hard-ready? (rao-obs-stalled) (rpiwt-stop-stalled))
            (and (rpiwtb-hard-ready? (rao-obs-timeout) (rpiwt-stop-timeout))
                 (rpiwtb-hard-ready? (rao-obs-wrong-value) (rpiwt-stop-wrong-value))))))
            256))
    (defn rpiwtb-bit-soft-and-unknown-preserved ()
        (do
            (let loader (rpiwtb-bridge (rao-obs-loader-missing) 0 0 1 (rpiwt-stop-loader-missing)))
            (let err (rpiwtb-bridge (rao-obs-error) 0 0 1 (rpiwt-stop-error)))
            (let unk (rpiwtb-bridge "surprise-status" 0 0 1 (rpiwt-stop-unknown)))
            (rpiwtb-score
                (and (rpiwtb-ready? loader)
                (and (rpiwtb-ready? err)
                (and (rpiwtb-ready? unk)
                     (str_eq (rpifa-run-status (rpiwt-bridge-run unk)) "surprise-status"))))
                512)))
    (defn rpiwtb-bit-ok-zero-output ()
        (do
            (let b (rpiwtb-bridge (rao-obs-ok) 42 0 0 (rpiwt-stop-completed)))
            (rpiwtb-score
                (and (rpiwtb-refused? b)
                (and (rpiwtb-no-9h1? b)
                     (rpiwtb-reason? b (rpiwt-reason-empty-ok-output))))
