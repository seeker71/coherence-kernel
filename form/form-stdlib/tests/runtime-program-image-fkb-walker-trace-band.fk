    (defn rpiwtb-bit-envelope-kind ()
        (do
            (let non (rpiwtb-bridge-from (rpiwtb-compile-envelope) (rpiwtb-admission) (rpiwtb-ok-trace)))
            (let mal (rpiwtb-bridge-from (list "runtime-artifact-load-envelope" 1) (rpiwtb-admission) (rpiwtb-ok-trace)))
            (rpiwtb-score
                (and (rpiwtb-investigate? non)
                (and (rpiwtb-reason? non (rpiwt-reason-non-program-image-envelope))
                (and (rpiwtb-refused? mal)
                     (rpiwtb-reason? mal (rpiwt-reason-malformed-envelope)))))
                262144)))
    (defn rpiwtb-bit-admission-failures ()
        (do
            (let mal (rpiwtb-bridge-from (rpiwtb-envelope) (list "program-image-fkb-byte-admission" 1) (rpiwtb-ok-trace)))
            (let inv (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-non-admitted-admission) (rpiwtb-ok-trace)))
            (let ref (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-refused-admission) (rpiwtb-ok-trace)))
