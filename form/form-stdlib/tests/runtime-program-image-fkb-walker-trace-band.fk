    (defn rpiwtb-bit-negative-counters ()
        (do
            (let budget (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 0 0 (sub 0 1) 0 1 42 1 (rao-obs-error) (rpiwt-stop-error) "negative-budget")))
            (let steps (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 0 0 10 (sub 0 1) 1 42 1 (rao-obs-error) (rpiwt-stop-error) "negative-steps")))
            (rpiwtb-score
                (and (rpiwtb-refused? budget)
                (and (rpiwtb-reason? budget (rpiwt-reason-negative-step-budget))
                (and (rpiwtb-refused? steps)
                     (rpiwtb-reason? steps (rpiwt-reason-negative-steps-used)))))
                2048)))
    (defn rpiwtb-bit-over-budget ()
        (do
            (let b (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                        (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                           (rpiwt-entry-kind-function-root) 0 0 10 11 1 42 1 (rao-obs-timeout) (rpiwt-stop-timeout) "over-budget")))
            (rpiwtb-score
