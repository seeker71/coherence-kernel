                                               (rpiwt-entry-kind-function-root) 2 0 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "entry-oor")))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 0 7 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "root-oor")))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 0 1 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "root-mismatch")))
