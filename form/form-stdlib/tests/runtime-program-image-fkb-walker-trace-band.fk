    (defn rpiwtb-bit-stop-mismatch ()
        (do
            (let ok (rpiwtb-bridge (rao-obs-ok) 42 1 0 (rpiwt-stop-error)))
            (let hard (rpiwtb-bridge (rao-obs-oom-killed) 0 0 137 (rpiwt-stop-completed)))
            (let unk (rpiwtb-bridge "surprise-status" 0 0 1 ""))
            (rpiwtb-score
                (and (rpiwtb-reason? ok (rpiwt-reason-ok-stop-reason-mismatch))
                (and (rpiwtb-reason? hard (rpiwt-reason-status-stop-reason-mismatch))
                     (rpiwtb-reason? unk (rpiwt-reason-empty-unknown-stop-reason))))
                4194304)))
    (defn rpiwtb-observed-reasons ()
        (list
