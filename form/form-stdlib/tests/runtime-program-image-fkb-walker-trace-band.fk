            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-decode-pif-mismatch-admission) (rpiwtb-ok-trace)))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission-for-pif (rpiwtb-pif-path-other)) (rpiwtb-ok-trace)))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                                                     (list "runtime-program-image-fkb-walker-trace" (rpiwtb-ready-path))))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-other-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 0 0 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "path-mismatch")))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               "symbol-root" 0 0 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "bad-kind")))
