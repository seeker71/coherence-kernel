                (and (rpiwtb-reason? b (rpiwt-reason-admission-decode-not-decoded))
                (and (str_eq (rpifa-bridge-reason nested) (rpifa-reason-admission-decode-not-decoded))
                     (rpifa-no-attempt? (rpifa-bridge-attempt nested)))))
