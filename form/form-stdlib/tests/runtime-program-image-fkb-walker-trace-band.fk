    (defn rpiwtb-bit-reason-coverage ()
        (do
            (let coverage (rcov-coverage (rpiwt-reason-manifest)
                                         (rpiwtb-observed-reasons)))
            (rpiwtb-score (rcov-covered? coverage) 8388608)))
    (defn rpiwtb-none-of? (text needles)
        (if (nil? needles)
            1
            (if (rpiwtb-has? text (head needles))
                0
                (rpiwtb-none-of? text (tail needles)))))
    (defn rpiwtb-forbidden-needles ()
        (list ".tbl"
              "table-text"
              "runtime-table-text"
              "rtta-"
              "program-image-tbl-emit"
              "read_file"
              "read_file_slice"
              "fs-"
              "write_form_binary"
              "read_form_binary"
              "recipe_to_bytes"
              "bytes_to_recipe"
              "form-eval"
              "fk_run"
              "dlopen"
              "bp_table"
              "bpTable"
              "BP_TABLE"
              "raec-"
              "rpifc-"
              "runtime-artifact-executor-capability"
              "runtime-program-image-fkb-capability-bound"
              "raar-supplied-attempt"
              "rpifa-attempt-from-run"))
    (defn rpiwtb-bit-static-mirror ()
        (do
            (let text (rpiwtb-read-file-any "form/form-stdlib/runtime-program-image-fkb-walker-trace.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-walker-trace.fk"))
            (let grammar (rpiwtb-read-file-any "grammars/runtime-program-image-fkb-walker-trace.fk"
                                               "../grammars/runtime-program-image-fkb-walker-trace.fk"))
            (rpiwtb-score
                (and (str_eq text grammar)
                     (eq (rpiwtb-none-of? text (rpiwtb-forbidden-needles)) 1))
                16777216)))
    (defn rpiwtb-bit-architecture-receipt ()
        (do
            (let arch (rpiwtb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rpiwtb-read-file-any "../receipts/2026-07-04-runtime-program-image-fkb-walker-trace-layer-review.md"
                                              "receipts/2026-07-04-runtime-program-image-fkb-walker-trace-layer-review.md"))
            (rpiwtb-score
                (and (rpiwtb-has? arch "9h3. Runtime program-image `.fkb` walker trace adapter")
                (and (rpiwtb-has? arch "structured walker/resource facts")
                (and (rpiwtb-has? receipt "PASS_WITH_CHANGES")
                (and (rpiwtb-has? receipt "Why 9h3 is not 9h1")
                     (rpiwtb-has? receipt "OOM, killed, stalled")))))
                33554432)))
    (defn rpiwtb-bit-no-invalid-trace-attempt ()
        (do
            (let entry (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 2 0 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "entry-oor")))
            (let counter (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
                                               (rpiwt-entry-kind-function-root) 0 0 10 11 1 42 1 (rao-obs-timeout) (rpiwt-stop-timeout) "over-budget")))
            (rpiwtb-score
                (and (rpiwtb-no-9h1? entry)
                (and (rpiwtb-no-9h1? counter)
                (and (rpiwtb-refused? entry)
                     (rpiwtb-refused? counter))))
                67108864)))
