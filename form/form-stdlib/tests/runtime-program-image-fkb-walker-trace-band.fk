                                               (rpiwt-entry-kind-function-root) (sub 0 1) 0 10 1 1 42 0 (rao-obs-ok) (rpiwt-stop-completed) "negative-entry")))
            (rpiwt-bridge-reason (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
