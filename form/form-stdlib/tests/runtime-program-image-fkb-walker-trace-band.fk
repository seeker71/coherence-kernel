                (and (rpiwtb-refused? mal)
                (and (rpiwtb-reason? mal (rpiwt-reason-malformed-admission))
                (and (rpiwtb-investigate? inv)
                (and (rpiwtb-refused? ref)
                     (rpiwtb-reason? ref (rpiwt-reason-non-admitted-admission))))))
                524288)))
