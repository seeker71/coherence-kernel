    (defn rpiwtb-bit-entry-invalid ()
        (do
            (let kind (rpiwtb-bridge-from (rpiwtb-envelope) (rpiwtb-admission)
                            (rpiwtb-trace-with (rpiwtb-ready-path) (rpiwtb-source-hash) (rpiwtb-content-hash)
