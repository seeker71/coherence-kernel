; fnri-receipt-band.fk — staged receipt arg -> fc-receipt.
; PROOF LEVEL: FKWU-STAGED — input_byte (walker tag 17) reads a staged arg;
; never registered in the three host walkers (see PR #231's removed drivers),
; and the staging carrier did not travel in the CN→CK consolidation.
; preludes: form-stdlib/core.fk form-stdlib/resource-port.fk form-stdlib/bml-native-interface-package-import.fk form-stdlib/hati-os-targets.fk form-stdlib/form-native-resource-interfaces.fk form-stdlib/form-fs.fk form-stdlib/storage-port.fk form-stdlib/host-kernel-carrier.fk form-stdlib/fnri-standin.fk form-stdlib/fnri-receipt.fk

(do
    (defn fnri-read-line (i acc)
        (do (let b (input_byte i))
            (if (eq b 0) acc
                (if (eq b 10) acc
                    (fnri-read-line (add i 1) (str_concat acc (byte_to_str b)))))))
    (fc-receipt (fnri-read-line 0 "")))
