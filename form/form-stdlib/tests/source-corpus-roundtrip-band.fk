; source-corpus-roundtrip-band.fk - active source sections through target lenses
;
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/bml.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/go-bmf.fk form-stdlib/grammars/typescript-bmf.fk

(do
    (let ACTIVE-CORPUS-ADD (make_nodeid 8 44 2 1))

    (defn active-add-binary (name a atype b btype rtype left right)
        (intern_node ACTIVE-CORPUS-ADD
            (list (intern_trivial_string name)
                  (intern_trivial_string a)
                  (intern_trivial_string atype)
                  (intern_trivial_string b)
                  (intern_trivial_string btype)
                  (intern_trivial_string rtype)
                  (intern_trivial_string left)
                  (intern_trivial_string right))))

    (defn active-add-kid (node index)
        (node_value (nth (node_children node) index)))

    (defn corpus-type-to-ts (value)
        (if (str_eq value "int") "number" value))

    (defn corpus-type-from-ts (value)
        (if (str_eq value "number") "int" value))

    (defn emit-active-add-go (node anchor ctx)
        (list (go-src-keyword "func")
              (go-src-name (bmf-symbol-name ctx anchor (active-add-kid node 0)))
              (go-src-op "(")
              (go-src-name (active-add-kid node 1))
              (go-src-name (active-add-kid node 2))
              (go-src-op ",")
              (go-src-name (active-add-kid node 3))
              (go-src-name (active-add-kid node 4))
              (go-src-op ")")
              (go-src-name (active-add-kid node 5))
              (go-src-op "{")
              (go-src-keyword "return")
              (go-src-name (active-add-kid node 6))
              (go-src-op "+")
              (go-src-name (active-add-kid node 7))
              (go-src-op "}")))

    (defn parse-active-add-go (source ctx)
        (do
            (let node
                (fsc-bmf-lower-node
                    (go-bmf-find-rule "func-return-add" go-bmf-rules)
                    source))
            (let kids (node_children node))
            (let name (node_value (nth kids 0)))
            (list (bmf-anchor-resolve ctx name name)
                  (active-add-binary
                      name
                      (node_value (nth kids 1))
                      (node_value (nth kids 2))
                      (node_value (nth kids 3))
                      (node_value (nth kids 4))
                      (node_value (nth kids 5))
                      (node_value (nth kids 6))
                      (node_value (nth kids 7))))))

    (defn emit-active-add-typescript (node anchor ctx)
        (list (ts-src-keyword "function")
              (ts-src-name (bmf-symbol-name ctx anchor (active-add-kid node 0)))
              (ts-src-op "(")
              (ts-src-name (active-add-kid node 1))
              (ts-src-op ":")
              (ts-src-name (corpus-type-to-ts (active-add-kid node 2)))
              (ts-src-op ",")
              (ts-src-name (active-add-kid node 3))
              (ts-src-op ":")
              (ts-src-name (corpus-type-to-ts (active-add-kid node 4)))
              (ts-src-op ")")
              (ts-src-op ":")
              (ts-src-name (corpus-type-to-ts (active-add-kid node 5)))
              (ts-src-op "{")
              (ts-src-keyword "return")
              (ts-src-name (active-add-kid node 6))
              (ts-src-op "+")
              (ts-src-name (active-add-kid node 7))
              (ts-src-op ";")
              (ts-src-op "}")))

    (defn parse-active-add-typescript (source ctx)
        (do
            (let node
                (fsc-bmf-lower-node
                    (typescript-bmf-find-rule "function-return-add" typescript-bmf-rules)
                    source))
            (let kids (node_children node))
            (let name (node_value (nth kids 0)))
            (list (bmf-anchor-resolve ctx name name)
                  (active-add-binary
                      name
                      (node_value (nth kids 1))
                      (corpus-type-from-ts (node_value (nth kids 2)))
                      (node_value (nth kids 3))
                      (corpus-type-from-ts (node_value (nth kids 4)))
                      (corpus-type-from-ts (node_value (nth kids 5)))
                      (node_value (nth kids 6))
                      (node_value (nth kids 7))))))

    (let active-source
        (str_concat
        (str_concat "section " "[form.bml] {
  def add(a, b) {
    add(a, b)
  }
}
")
        (str_concat
        (str_concat "section " "[go.bmf] {
  func-return-add ::= \"func\" $name:name \"(\" $a:name $atype:name \",\" $b:name $btype:name \")\" $rtype:name \"{\" \"return\" $left:name \"+\" $right:name \"}\" => gobmf-emit-func-return-add <= gobmf-source-func-return-add;
}
")
        (str_concat "section " "[typescript.bmf] {
  function-return-add ::= \"function\" $name:name \"(\" $a:name \":\" $atype:name \",\" $b:name \":\" $btype:name \")\" \":\" $rtype:name \"{\" \"return\" $left:name \"+\" $right:name \";\" \"}\" => tsbmf-emit-function-return-add <= tsbmf-source-function-return-add;
}
"))))

    ;; Recipe-first path: form-source-compile-text builds section Recipe objects
    ;; first, then emits executable Form source only as this test's observation
    ;; lens. Runtime carriers can use recipe_to_bytes directly.
    (let compiled-out-path (str_concat (temp_dir) "/form-test-source-corpus-roundtrip"))
    (let compiled-source (form-source-compile-text active-source compiled-out-path))
    (let anchor "active-corpus/add")
    (let binary (active-add-binary "add" "a" "int" "b" "int" "int" "a" "b"))

    (let fk-source-section
        (fsc-source-section-binary
            "form.bml"
            "active-add"
            (list "form.bml" "def add(a, b)")
            binary))

    (let form-source-section
        (fsc-source-section-binary
            "form.objects"
            "active-add"
            (bmf-collection (list (bmf-atom "name" "add")
                                  (bmf-atom "type" "int")))
            binary))

    (let corpus
        (fsc-source-corpus
            "active-fk-form-corpus"
            (list
                (fsc-source-file
                    "form-stdlib/tests/source-compiler-multi-dialect-band.fk"
                    "fk"
                    (list fk-source-section))
                (fsc-source-file
                    "form-stdlib/tests/language-bmf-source-sections.form"
                    "form"
                    (list form-source-section)))))

    ;; bmf-reverse-lens-node-from calls intern_node BMF-REVERSE-LENS (list domain lens) —
    ;; kernel intern_node requires NodeID children, so promote the domain/lens labels to
    ;; interned-string NodeIDs once. bmf-reverse-lens-matches? uses kind-strict value_eq,
    ;; so every lookup must reuse the same NodeID-form the targets were built with.
    (let DOM-GO (intern_trivial_string "go"))
    (let DOM-TYPESCRIPT (intern_trivial_string "typescript"))
    (let LENS-SOURCE (intern_trivial_string "source"))

    (let go-ctx
        (bmf-symbol-context DOM-GO LENS-SOURCE
            (list (bmf-symbol-binding anchor DOM-GO LENS-SOURCE
                                      "active.add"
                                      (list "add" "Add")))))
    (let ts-ctx
        (bmf-symbol-context DOM-TYPESCRIPT LENS-SOURCE
            (list (bmf-symbol-binding anchor DOM-TYPESCRIPT LENS-SOURCE
                                      "active.add"
                                      (list "add" "addFn")))))
    (let targets
        (list
            (bmf-reverse-lens DOM-GO LENS-SOURCE
                              emit-active-add-go
                              parse-active-add-go
                              (go-bmf-find-rule "func-return-add" go-bmf-rules))
            (bmf-reverse-lens DOM-TYPESCRIPT LENS-SOURCE
                              emit-active-add-typescript
                              parse-active-add-typescript
                              (typescript-bmf-find-rule "function-return-add" typescript-bmf-rules))))

    (let go-rt (bmf-lens-roundtrip targets DOM-GO LENS-SOURCE binary anchor go-ctx (empty)))
    (let ts-rt (bmf-lens-roundtrip targets DOM-TYPESCRIPT LENS-SOURCE binary anchor ts-ctx (empty)))
    (let go-source (bmf-lens-roundtrip-source go-rt))
    (let ts-source (bmf-lens-roundtrip-source ts-rt))

    (sum
        (list
            ;; The compiled observation lens contains real section bindings
            ;; directly and no old sidecar driver.
            (if (fsc-contains? compiled-source "walk_recipe_here") 0 10)
            (if (fsc-contains? compiled-source "go-bmf-rules") 20 0)
            (if (fsc-contains? compiled-source "(defn add") 30 0)
            (if (str_eq (fsc-source-corpus-name corpus) "active-fk-form-corpus") 40 0)
            (if (eq (len (fsc-source-corpus-files corpus)) 2) 50 0)
            (if (str_eq (fsc-source-file-kind (head (fsc-source-corpus-files corpus))) "fk") 60 0)
            (if (str_eq (fsc-source-file-kind (nth (fsc-source-corpus-files corpus) 1)) "form") 70 0)
            (if (fsc-source-section-node-eq? fk-source-section binary) 80 0)
            (if (fsc-source-section-node-eq? form-source-section binary) 90 0)
            (if (fsc-lens-roundtrip-anchor-eq? go-rt anchor) 100 0)
            (if (fsc-lens-roundtrip-node-eq? go-rt binary) 110 0)
            (if (fsc-lens-roundtrip-anchor-eq? ts-rt anchor) 120 0)
            (if (fsc-lens-roundtrip-node-eq? ts-rt binary) 130 0)
            (if (fsc-bmf-roundtrip-node-eq?
                    (go-bmf-find-rule "func-return-add" go-bmf-rules)
                    go-source) 140 0)
            (if (fsc-bmf-roundtrip-node-eq?
                    (typescript-bmf-find-rule "function-return-add" typescript-bmf-rules)
                    ts-source) 150 0)
            (len go-source)
            (len ts-source)
            (if (str_eq (bmf-symbol-name go-ctx anchor "") "add") 160 0)
            (if (str_eq (bmf-symbol-name ts-ctx anchor "") "add") 170 0))))
