; rag-index-codec-band.fk — NodeID-grounded JSONL admission and compatibility.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/hex.fk form-stdlib/rag-index-codec.fk
;
; verdict 8191:
;   1   grounded emit round-trips NodeID + source path
;   2   canonical nodeid-rag-v2 row is grounding-ready with persisted source binding
;   4   legacy path-id row preserves its lens but is refused as grounding
;   8   malformed/missing-coordinate NodeIDs are refused
;   16  ordinary spaced JSON vectors and signed ints parse
;   32  explicit node_id remains authoritative for legacy reads, but mismatched
;       id/node_id cannot enter the grounded schema
;   64  authored schema claims outside nodeid-rag-v2 are refused
;   128 a typed-schema row missing explicit node_id is refused
;   256 two individually valid but unequal id/node_id coordinates are refused
;   512 odd semantic-v2 code vectors are refused
;   1024 codes outside their respective dual-hash domains are refused
;   2048 duplicate semantic feature pairs are refused
;   4096 the stale nodeid-rag-v1 schema is refused

(do
    (let digest "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    (let vec (list 12 1000040 56 1000090))
    (let line (ric-emit-grounded "@8.3.4.91" "@8.4.4.12" "docs/coherence-substrate/trust.form"
        "cell" digest "answer-key" "74727573742067726f756e64696e67" "trust grounding" vec))
    (let legacy (ric-emit "form/form-stdlib/core.fk" "recipe" "42" "hello" (list 7 8)))
    (let spaced "{\"id\": \"@1.2.3.4\", \"node_id\": \"@1.2.3.4\", \"content_node_id\": \"@1.3.3.5\", \"source_path\": \"docs/a.form\", \"schema\": \"nodeid-rag-v2\", \"embedding_kind\": \"form-semantic-v2\", \"key\": \"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\", \"persisted_source_sha256\": \"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\", \"answer_key\": \"ak\", \"answer_hex\": \"61\", \"vec\": [7, -8, 9]}")
    (let explicit "{\"id\":\"not-an-id\",\"node_id\":\"@9.8.7.6\",\"content_node_id\":\"@9.9.7.1\",\"source_path\":\"x\",\"schema\":\"nodeid-rag-v2\",\"embedding_kind\":\"form-semantic-v2\",\"key\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"persisted_source_sha256\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"answer_key\":\"ak\",\"answer_hex\":\"61\",\"vec\":[1]}")
    (let wrong-schema "{\"id\":\"@1.2.3.4\",\"content_node_id\":\"@1.3.3.5\",\"source_path\":\"x\",\"schema\":\"path-rag-v0\",\"embedding_kind\":\"form-semantic-v2\",\"key\":\"k\",\"answer_key\":\"ak\",\"answer_hex\":\"61\",\"vec\":[1]}")
    (let migrated "{\"id\":\"@1.2.3.4\",\"content_node_id\":\"@1.3.3.5\",\"source_path\":\"x\",\"schema\":\"nodeid-rag-v2\",\"embedding_kind\":\"form-semantic-v2\",\"key\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"persisted_source_sha256\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"answer_key\":\"ak\",\"answer_hex\":\"61\",\"vec\":[1]}")
    (let split-identity "{\"id\":\"@1.2.3.4\",\"node_id\":\"@1.2.3.5\",\"content_node_id\":\"@1.3.3.5\",\"source_path\":\"x\",\"schema\":\"nodeid-rag-v2\",\"embedding_kind\":\"form-semantic-v2\",\"key\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"persisted_source_sha256\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"answer_key\":\"ak\",\"answer_hex\":\"61\",\"vec\":[1]}")
    (let odd (ric-emit-grounded "@1.1.9.1" "@8.4.4.1" "x" "cell" digest "ak" "61" "a" (list 7)))
    (let wrong-domains (ric-emit-grounded "@1.1.9.1" "@8.4.4.1" "x" "cell" digest "ak" "61" "a" (list 7 8)))
    (let duplicate-pair (ric-emit-grounded "@1.1.9.1" "@8.4.4.1" "x" "cell" digest "ak" "61" "a" (list 7 1000010 7 1000010)))
    (let retired-v1 "{\"id\":\"@1.1.9.1\",\"node_id\":\"@1.1.9.1\",\"content_node_id\":\"@8.4.4.1\",\"source_path\":\"x\",\"schema\":\"nodeid-rag-v1\",\"embedding_kind\":\"form-semantic-v2\",\"key\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"persisted_source_sha256\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"answer_key\":\"ak\",\"answer_hex\":\"61\",\"vec\":[7,1000010]}")

    (let b1 (if (and (str_eq (ric-node-id line) "@8.3.4.91")
                     (str_eq (ric-source-path line) "docs/coherence-substrate/trust.form")) 1 0))
    (let b2 (if (eq (ric-grounding-ready? line) 1) 2 0))
    (let b4 (if (and (str_eq (ric-source-path legacy) "form/form-stdlib/core.fk")
                     (eq (ric-grounding-ready? legacy) 0)) 4 0))
    (let b8 (if (and
                    (and (eq (ric-node-id-valid? "@1.2.3") 0)
                         (eq (ric-node-id-valid? "@1..3.4") 0))
                    (and (eq (ric-node-id-valid? "1.2.3.4") 0)
                         (eq (ric-node-id-valid? "@1.2.3.4.5") 0))) 8 0))
    (let parsed (ric-vec spaced))
    (let b16 (if (and (eq (nth parsed 0) 7)
                      (and (eq (nth parsed 1) -8) (eq (nth parsed 2) 9))) 16 0))
    (let b32 (if (and (str_eq (ric-node-id explicit) "@9.8.7.6")
                       (eq (ric-grounding-ready? explicit) 0)) 32 0))
    (let b64 (if (eq (ric-grounding-ready? wrong-schema) 0) 64 0))
    (let b128 (if (and (str_eq (ric-node-id migrated) "@1.2.3.4")
                       (eq (ric-grounding-ready? migrated) 0)) 128 0))
    (let b256 (if (and (str_eq (ric-node-id split-identity) "@1.2.3.5")
                       (eq (ric-grounding-ready? split-identity) 0)) 256 0))
    (let b512 (if (eq (ric-grounding-ready? odd) 0) 512 0))
    (let b1024 (if (eq (ric-grounding-ready? wrong-domains) 0) 1024 0))
    (let b2048 (if (eq (ric-grounding-ready? duplicate-pair) 0) 2048 0))
    (let b4096 (if (eq (ric-grounding-ready? retired-v1) 0) 4096 0))

    (add b1 (add b2 (add b4 (add b8 (add b16
        (add b32 (add b64 (add b128 (add b256 (add b512
        (add b1024 (add b2048 b4096)))))))))))))
