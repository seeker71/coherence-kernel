; preludes: form-stdlib/jit-tensor-emit.fk
;
; attn-train-emit-band — the architect's ATTENTION layer training-step emitter as recipe, three-way.
; jte-attn-train-msl authors the Metal kernel for one SGD step over h = x + Wo*attend(Wq*LN(x), ks, vs, scale)
; for a fixed (keys, values) context — tbp-layer-step on an "attn" layer, updating Wq and Wo. It composes
; every attention-core gradient (softmax-back, the dv partition, the dq weighted-key sum) plus the pre-LN and
; the residual highway, running the whole step in one thread with the recipe's exact folds (tb-dot downward,
; tb-weighted-acc / tbp-attn-dq-acc forward, tn-max-subtract softmax over the recipe's own fexp). The emitted
; source is byte-identical across the three kernels, parameterizes on the name, and is deterministic. It
; COMPILES and TRAINS on the M4 Max GPU (scripts/metal_attn_audit.sh): the type axis now trains on the silicon
; alongside the FFN-core and residual blocks.
;
; Verdict 7 when the emission lands:
;   1   the full emitted f32 MSL for form_attn_train_f32 equals the canonical text
;   2   a different name lands in the same frame (emission is a function of the name)
;   4   two emissions of the same name are str_eq (deterministic text — same emission, same cell)
(do
    (let pre "float fexp_small(float x){ float n = 1.0f; float term = 1.0f; float acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } float fexp(float x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } float v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } float ftanh(float x){ float e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } float fgelu(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } float fgelud(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); float th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } kernel void ")
    (let post "(device float* wq [[buffer(0)]], device float* wo [[buffer(1)]], device const float* x [[buffer(2)]], device const float* t [[buffer(3)]], device const float* ks [[buffer(4)]], device const float* vs [[buffer(5)]], device float* loss [[buffer(6)]], device float* n [[buffer(7)]], device float* q [[buffer(8)]], device float* alpha [[buffer(9)]], device float* att [[buffer(10)]], device float* gy [[buffer(11)]], device float* datt [[buffer(12)]], device float* dqg [[buffer(13)]], device float* es [[buffer(14)]], constant uint& dmodel [[buffer(15)]], constant uint& dq [[buffer(16)]], constant uint& dv [[buffer(17)]], constant uint& nk [[buffer(18)]], constant float& scale [[buffer(19)]], constant float& lr [[buffer(20)]], constant float& eps [[buffer(21)]], uint gid [[thread_position_in_grid]]) { if (gid != 0u) return; float sm = 0.0f; uint j = 0; while (j < dmodel) { sm = sm + float(x[j]); j += 1; } float mean = sm / float(dmodel); float va = 0.0f; j = 0; while (j < dmodel) { float dm = float(x[j]) - mean; va = va + dm * dm; j += 1; } float varv = va / float(dmodel); float sd = varv + eps; float gg = sd; uint it = 50; while (it > 0) { it -= 1; gg = 0.5f * (gg + sd / gg); } float inv = 1.0f / gg; j = 0; while (j < dmodel) { n[j] = (float(x[j]) - mean) * inv; j += 1; } uint r = 0; while (r < dq) { float acc = 0.0f; uint c = dmodel; while (c > 0) { c -= 1; acc = float(wq[r * dmodel + c]) * n[c] + acc; } q[r] = acc; r += 1; } uint kk = 0; while (kk < nk) { float acc = 0.0f; uint c = dq; while (c > 0) { c -= 1; acc = q[c] * float(ks[kk * dq + c]) + acc; } alpha[kk] = acc * scale; kk += 1; } float mx = alpha[0]; kk = 1; while (kk < nk) { if (alpha[kk] > mx) { mx = alpha[kk]; } kk += 1; } float sumes = 0.0f; kk = 0; while (kk < nk) { float e = fexp(alpha[kk] - mx); es[kk] = e; sumes = sumes + e; kk += 1; } float invs = 1.0f / sumes; kk = 0; while (kk < nk) { alpha[kk] = es[kk] * invs; kk += 1; } uint vi = 0; while (vi < dv) { att[vi] = 0.0f; vi += 1; } kk = 0; while (kk < nk) { vi = 0; while (vi < dv) { att[vi] = att[vi] + float(vs[kk * dv + vi]) * alpha[kk]; vi += 1; } kk += 1; } loss[0] = 0.0f; uint oi = 0; while (oi < dmodel) { float acc = 0.0f; uint c = dv; while (c > 0) { c -= 1; acc = float(wo[oi * dv + c]) * att[c] + acc; } float hh = float(x[oi]) + acc; float df = hh - float(t[oi]); loss[0] = loss[0] + df * df; gy[oi] = 2.0f * df; oi += 1; } uint dj = 0; while (dj < dv) { datt[dj] = 0.0f; dj += 1; } oi = 0; while (oi < dmodel) { dj = 0; while (dj < dv) { datt[dj] = datt[dj] + gy[oi] * float(wo[oi * dv + dj]); dj += 1; } oi += 1; } kk = 0; while (kk < nk) { float acc = 0.0f; uint c = dv; while (c > 0) { c -= 1; acc = datt[c] * float(vs[kk * dv + c]) + acc; } es[kk] = acc; kk += 1; } float gdot = 0.0f; { uint c = nk; while (c > 0) { c -= 1; gdot = es[c] * alpha[c] + gdot; } } kk = 0; while (kk < nk) { es[kk] = alpha[kk] * (es[kk] - gdot); kk += 1; } uint qr = 0; while (qr < dq) { dqg[qr] = 0.0f; qr += 1; } kk = 0; while (kk < nk) { qr = 0; while (qr < dq) { dqg[qr] = dqg[qr] + es[kk] * float(ks[kk * dq + qr]); qr += 1; } kk += 1; } qr = 0; while (qr < dq) { dqg[qr] = dqg[qr] * scale; qr += 1; } qr = 0; while (qr < dq) { uint c = 0; while (c < dmodel) { wq[qr * dmodel + c] = float(float(wq[qr * dmodel + c]) - lr * dqg[qr] * n[c]); c += 1; } qr += 1; } oi = 0; while (oi < dmodel) { uint c = 0; while (c < dv) { wo[oi * dv + c] = float(float(wo[oi * dv + c]) - lr * gy[oi] * att[c]); c += 1; } oi += 1; } }")
    (let want (str_concat pre (str_concat "form_attn_train_f32" post)))
    (let got (jte-attn-train-msl "form_attn_train_f32"))
    (let other (jte-attn-train-msl "a2"))
    (let c0 (if (str_eq got want) 1 0))
    (let c1 (if (str_eq other (str_concat pre (str_concat "a2" post))) 2 0))
    (let c2 (if (str_eq (jte-attn-train-msl "form_attn_train_f32") got) 4 0))
    (add c0 (add c1 c2)))
