; world-model-lingbot-map-band.fk — point-cloud rows genuinely traverse the
; existing generic world-model observation and orientation paths.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/speaker-embed.fk
; form/form-stdlib/champion-challenger.fk form/form-stdlib/identity-match.fk
; form/form-stdlib/face-embed.fk form/form-stdlib/spatial-fusion.fk
; form/form-stdlib/world-model.fk form/form-stdlib/world-model-lingbot-map.fk

(do
  (defn world-model-lingbot-map-band ()
    (do
      (let visual (list 0.1 0.2 0.3 0.4))
      (let cloud
        (list
          (list (list -1.0 0.0 2.0) 0.75)
          (list (list 1.0 0.5 3.0) 0.5)
          (list (list 0.0 -0.5 4.0) 0.25)))
      (let entities (wmlm-observe-cloud cloud visual))
      (let world (wmlm-world-from-cloud cloud visual))
      (sum (list
        (if (eq (len entities) 3) 1 0)
        (if (eq (wmlm-object-count cloud visual) 3) 2 0)
        (if (str_eq (wm-ent-kind (head entities)) "object") 4 0)
        (if (and (eq (nth (wm-ent-position (head entities)) 0) -1.0)
              (and (eq (nth (wm-ent-position (head entities)) 1) 0.0)
                   (eq (nth (wm-ent-position (head entities)) 2) 2.0))) 8 0)
        (if (eq (wm-ent-persistence (head entities)) 1) 16 0)
        (if (str_eq (wm-ent-id (head entities)) "new") 32 0)
        (if (eq (len world) 3) 64 0)))))

  (world-model-lingbot-map-band))
