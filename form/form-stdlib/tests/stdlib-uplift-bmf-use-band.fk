; stdlib-uplift-bmf-use-band.fk -- BMF-authored uplift grammars in actual use.
;
; preludes: form-stdlib/core.fk form-stdlib/engine.fk form-stdlib/stdlib-uplift-bmf-use.fk
;
; Expected: 131071

(do
    (defn subub-score (ok bit) (if ok bit 0))
    (defn subub-manifest-has (name)
        (stdlib-uplift-bmf-use-manifest-has?
            name
            (stdlib-uplift-bmf-use-manifest)))
    (defn subub-rts () (subu-roundtrips))
    (defn subub-protocol-rt () (nth (subub-rts) 2))
    (defn subub-artifact-rt () (nth (subub-rts) 5))
    (defn subub-proof-rt () (nth (subub-rts) 11))
    (defn subub-first-object-value (rt)
        (bmf-object-value (bmf-roundtrip-first-object rt)))

    (defn stdlib-uplift-bmf-use-band ()
        (add
            (subub-score (eq (subub-manifest-has "bmf-source-file-required") 1) 1)
        (add
            (subub-score (eq (subub-manifest-has "actual-bmf-object-rules") 1) 2)
        (add
            (subub-score (eq (subub-manifest-has "reverse-emit") 1) 4)
        (add
            (subub-score (eq (len (subu-rules)) 12) 8)
        (add
            (subub-score (eq (len (subu-sources)) 12) 16)
        (add
            (subub-score (eq (len (subub-rts)) 12) 32)
        (add
            (subub-score (eq (subu-all-roundtrip-ok? (subub-rts)) 1) 64)
        (add
            (subub-score (eq (subu-all-source-families-present? (subu-family-names)) 1) 128)
        (add
            (subub-score (eq (len (bmf-roundtrip-source (subub-protocol-rt))) 13) 256)
        (add
            (subub-score (str_eq (subu-node-field (subub-first-object-value (subub-protocol-rt)) 1) "GET") 512)
        (add
            (subub-score (str_eq (subu-node-field (subub-first-object-value (subub-artifact-rt)) 2) "calc.fkb") 1024)
        (add
            (subub-score (str_eq (subu-node-field (subub-first-object-value (subub-proof-rt)) 1) "32767") 2048)
        (add
            (subub-score (subu-source-has-family? "protocol-codec-language") 4096)
        (add
            (subub-score (subu-source-has-family? "proof-manifest-language") 8192)
        (add
            (subub-score (eq (subub-manifest-has "bmf-section-source-observed") 1) 16384)
        (add
            (subub-score (and (subu-source-has-rule? "protocol-codec")
                              (subu-source-has-reverse? "subu-reverse-protocol")) 32768)
            (subub-score (and (subu-source-has-rule? "proof-manifest")
                              (subu-source-has-reverse? "subu-reverse-proof")) 65536))))))))))))))))))

    (stdlib-uplift-bmf-use-band))
