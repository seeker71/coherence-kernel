; bmf-grammar-sugar-chain-band.fk -- call/member/index/postfix chain sugar.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk
;
; Expected: 15

(do
  (defn s (ok bit) (if ok bit 0))
  (defn kid (n i) (nth (node_children n) i))
  (defn cat? (n name) (node_eq (node_category n) (bmf-bp name)))
  (let g (grammar "e" (list
    (rule3 "e" (p-cap "v" (p-chain (p-ref "p") (p-ref "e"))) (t-splice "v"))
    (rule3 "p" (p-cap "v" (list "alt" (p-ref "n") (p-ref "id"))) (t-splice "v"))
    (rule3 "n" (p-cap "v" (p-num)) (t-splice-int "v"))
    (rule3 "id" (p-cap "v" (p-run "alnum")) (t-emit "ident" (list (t-splice "v")))))))
  (let c (g-parse-full g "f(1,2)"))
  (let i (g-parse-full g "a.b[2]++"))
  (sum (list
    (s (cat? c "fncall") 1)
    (s (eq (len (node_children c)) 3) 2)
    (s (cat? i "UE-MATH-INC") 4)
    (s (cat? (kid i 0) "UE-ACCESS-INDEX") 8))))
