; preludes: form-stdlib/satsang-host-boundary.fk
;
; satsang-host-boundary-band — shared Form body, minimal host ABI, no app
; boundary Python/Go/Rust/TypeScript.
;
; Verdict 2097151:
;   1   Form is an allowed app runtime
;   2   Swift is only the minimal host carrier
;   4   Python is forbidden at the app boundary
;   8   Go is forbidden at the app boundary
;   16  Rust is forbidden at the app boundary
;   32  TypeScript is forbidden at the app boundary
;   64  generic file/process resources are allowed
;   128 macOS is a target platform
;   256 Windows is a target platform
;   512 Android is a target platform
;   131072 iPhone/iOS is a target platform
;   1024 detected audio-input door is valid
;   2048 unknown resource kind is rejected as a detected door
;   4096 macOS carrier matrix resolves every resource door
;   8192 Windows carrier matrix resolves every resource door
;   16384 Android carrier matrix resolves every resource door
;   32768 Android speech carrier is the native speech recognizer door
;   65536 Windows process door is CreateProcess stdin/stdout
;   262144 iPhone/iOS carrier matrix resolves every resource door
;   524288 iPhone speech carrier is the native Speech side channel
;   1048576 iPhone health samples use HealthKit
(do
    (defn satsang-host-boundary-band ()
        (do
    (let rec (shb-receipt "swift-minimal-host-carrier" "process-stdin-stdout" "macos"))
    (let audio-door (shb-door-receipt "audio-input" "open" "macos-avfoundation"))

    (let c0 (if (eq (shb-app-runtime-allowed? "form") 1) 1 0))
    (let c1 (if (eq (shb-app-runtime-allowed? "swift-minimal-host-carrier") 1) 2 0))
    (let c2 (if (eq (shb-runtime-forbidden? "python") 1) 4 0))
    (let c3 (if (eq (shb-runtime-forbidden? "go") 1) 8 0))
    (let c4 (if (eq (shb-runtime-forbidden? "rust") 1) 16 0))
    (let c5 (if (eq (shb-runtime-forbidden? "typescript") 1) 32 0))
    (let c6 (if (and (eq (shb-resource-kind? "file-read") 1)
                     (and (eq (shb-resource-kind? "file-append") 1)
                          (eq (shb-resource-kind? "process-stdin-stdout") 1))) 64 0))
    (let c7 (if (eq (shb-platform-target? "macos") 1) 128 0))
    (let c8 (if (eq (shb-platform-target? "windows") 1) 256 0))
    (let c9 (if (and (eq (shb-platform-target? "android") 1)
                     (and (eq (shb-rec-ok? rec) 1)
                          (eq (shb-rec-forbidden? rec) 0))) 512 0))
    (let c10 (if (eq (shb-door-rec-ok? audio-door) 1) 1024 0))
    (let c11 (if (eq (shb-door-ok? "platform-private-api" "open") 0) 2048 0))
    (let c12 (if (eq (shb-platform-carriers-complete? "macos") 1) 4096 0))
    (let c13 (if (eq (shb-platform-carriers-complete? "windows") 1) 8192 0))
    (let c14 (if (eq (shb-platform-carriers-complete? "android") 1) 16384 0))
    (let c15 (if (str_eq (shb-carrier-for "android" "speech-transcript") "android-speechrecognizer") 32768 0))
    (let c16 (if (str_eq (shb-carrier-for "windows" "process-stdin-stdout") "windows-createprocess-stdin-stdout") 65536 0))
    (let c17 (if (eq (shb-platform-target? "ios") 1) 131072 0))
    (let c18 (if (eq (shb-platform-carriers-complete? "ios") 1) 262144 0))
    (let c19 (if (str_eq (shb-carrier-for "ios" "speech-transcript") "ios-speech") 524288 0))
    (let c20 (if (str_eq (shb-carrier-for "ios" "health-samples") "ios-healthkit") 1048576 0))

    (add
        (add
            (add
                (add (add c0 c1) (add c2 c3))
                (add (add c4 c5) (add c6 c7)))
            (add
                (add (add c8 c9) (add c10 c11))
                (add (add c12 c13) (add c14 c15))))
        (add (add c16 c17) (add (add c18 c19) c20))))
    )
    (satsang-host-boundary-band))
