; rag-heal-grounding-band.fk — native healing never degrades a grounded index.
;
; preludes: form-stdlib/core.fk form-stdlib/adler32.fk form-stdlib/rag-key.fk
; preludes: form-stdlib/rag-freshness.fk form-stdlib/text-tokenize.fk
; preludes: form-stdlib/rag-embed.fk form-stdlib/rag-index-codec.fk
; preludes: form-stdlib/rag-heal.fk
;
; verdict 63:
;   1  native REF+CTOR resolution is explicitly unavailable
;   2  direct cold build refuses
;   4  direct delta heal refuses
;   8  merge cold build refuses
;   16 merge delta heal refuses
;   32 every refused operation leaves the exact grounded bytes untouched
;
; The shell carrier maps resolver refusal to exit 73 and unavailable native
; setup to exit 74; neither path reports a healthy no-op.

(do
    (let path (str_concat (temp_dir) "/rag-heal-grounding-band.jsonl"))
    (let grounded "{\"id\":\"@1.1.9.41\",\"node_id\":\"@1.1.9.41\",\"content_node_id\":\"@8.4.4.12\",\"source_path\":\"docs/a.form\",\"schema\":\"nodeid-rag-v2\",\"embedding_kind\":\"form-semantic-v2\",\"kind\":\"cell\",\"key\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"persisted_source_sha256\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"answer_key\":\"ak\",\"answer_hex\":\"61\",\"snippet\":\"a\",\"vec\":[7,1000010]}")
    (let wrote (write_file path grounded))
    (let cold (rh-build "missing" ".fk" path))
    (let delta (rh-heal "missing" ".fk" path))
    (let merge-cold (rh-cold-build-merge-at path "missing"))
    (let merge-delta (rh-heal-merge-at path "missing"))
    (let after (read_file path))
    (let cleaned (fs_remove path))

    (let b1 (if (eq (rh-native-resolver-ready?) 0) 1 0))
    (let b2 (if (eq cold (rh-refusal-code)) 2 0))
    (let b4 (if (eq delta (rh-refusal-code)) 4 0))
    (let b8 (if (eq merge-cold (rh-refusal-code)) 8 0))
    (let b16 (if (eq merge-delta (rh-refusal-code)) 16 0))
    (let b32 (if (str_eq after grounded) 32 0))
    (add b1 (add b2 (add b4 (add b8 (add b16 b32))))))
