; native-model-lineage-band.fk -- canonical model DAG and honesty semantics.
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/native-model-evidence.fk form-stdlib/native-model-lineage-form.fk
;
; Verdict 33554431.

(do
    (let d1 "d75e1ee0ea653cc5b76191ec934c7c0d568e94d4e47846619f1f4bc715b7b265")
    (let d2 "b5e7e6a75847cdcaf9f33433411d45ba603ece794a58940357d5213954aa363e")
    (let d3 "0673b5bbf0b3bb82a05854705874cc7b1bebd1b7ae6a6748be442971eeb29698")
    (let d4 "23c6f7b02696b18e6f9956ba6913423cc0f7ad0b5fe48cab85fe3e254a83eacf")
    (let q4 "871071a269d0df9630fa0e14038bb9687052c656f27f27bdcd31f2556165e451")
    (let op "710732eb527587359eee7cc2c5f603f80d20cea358f082f140e8aaf4d366c970")
    (let ev "9e1126e3f0b6584ea7a19ca7abf51b99811071550b7a3cc8627978dacf5911fb")

    (let base-components
        (list (nmli-component "config" 10 d2)
              (nmli-component "model" 100 d1)
              (nmli-component "model-index" 20 d3)
              (nmli-component "tokenizer" 30 d4)
              (nmli-component "tokenizer-config" 40 op)))
    (let adapter-components
        (list (nmli-component "adapter-config" 10 d1)
              (nmli-component "adapter-weights" 20 d2)))
    (let fused-components
        (list (nmli-component "config" 10 d1)
              (nmli-component "model-index" 20 d2)
              (nmli-component "model-shard-00001" 100 d3)
              (nmli-component "model-shard-00002" 50 d4)
              (nmli-component "tokenizer" 30 op)
              (nmli-component "tokenizer-config" 40 ev)))
    (let quantized-components (list (nmli-component "model" 60 q4)))
    (let served-components
        (list (nmli-component "manifest" 10 d1)
              (nmli-component "model" 60 q4)
              (nmli-component "ollama-config" 5 d2)
              (nmli-component "show" 20 d3)
              (nmli-component "show-model-info" 10 d4)))

    (let base (nmli-node "base" "base" "mlx" "semantic-base" base-components))
    (let adapter (nmli-node "adapter" "adapter" "lora" "semantic-adapter" adapter-components))
    (let fused (nmli-node "fused" "fused" "safetensors" "semantic-fused" fused-components))
    (let quantized (nmli-node "q4" "quantized" "gguf" "semantic-q4" quantized-components))
    (let served (nmli-node "served" "served" "ollama" "semantic-served" served-components))
    (let nodes (list base adapter fused quantized served))

    (let train (nmli-edge "train" "train" (list (nmli-node-sha base))
        (nmli-node-sha adapter) d1 op ev 20260622 0 0 0 0 1))
    (let fuse (nmli-edge "fuse" "fuse"
        (list (nmli-node-sha base) (nmli-node-sha adapter))
        (nmli-node-sha fused) d2 op ev 20260622 0 0 0 0 1))
    (let quant (nmli-edge "quant" "quantize" (list (nmli-node-sha fused))
        (nmli-node-sha quantized) "" op ev 20260622 0 0 0 0 1))
    (let serve (nmli-edge "serve" "serve" (list (nmli-node-sha quantized))
        (nmli-node-sha served) d3 op ev 20260715 1 0 0 0 1))
    (let edges (list train fuse quant serve))

    ; Authority is deliberately stronger than lineage validity. Every edge
    ; must be valid, fresh, reproduced, reviewed, authorized, and successful.
    (let attested-train (nmli-edge "attested-train" "train"
        (list (nmli-node-sha base)) (nmli-node-sha adapter)
        d1 op ev 20260715 1 1 1 1 1))
    (let attested-fuse (nmli-edge "attested-fuse" "fuse"
        (list (nmli-node-sha base) (nmli-node-sha adapter))
        (nmli-node-sha fused) d2 op ev 20260715 1 1 1 1 1))
    (let attested-quant (nmli-edge "attested-quant" "quantize"
        (list (nmli-node-sha fused)) (nmli-node-sha quantized)
        d3 op ev 20260715 1 1 1 1 1))
    (let attested-serve (nmli-edge "attested-serve" "serve"
        (list (nmli-node-sha quantized)) (nmli-node-sha served)
        d4 op ev 20260715 1 1 1 1 1))
    (let attested-edges
        (list attested-train attested-fuse attested-quant attested-serve))
    (let not-fresh (nmli-edge "not-fresh" "train"
        (list (nmli-node-sha base)) (nmli-node-sha adapter)
        d1 op ev 20260715 0 1 1 1 1))
    (let not-reproduced (nmli-edge "not-reproduced" "fuse"
        (list (nmli-node-sha base) (nmli-node-sha adapter))
        (nmli-node-sha fused) d2 op ev 20260715 1 0 1 1 1))
    (let not-reviewed (nmli-edge "not-reviewed" "quantize"
        (list (nmli-node-sha fused)) (nmli-node-sha quantized)
        d3 op ev 20260715 1 1 0 0 1))
    (let not-authorized (nmli-edge "not-authorized" "serve"
        (list (nmli-node-sha quantized)) (nmli-node-sha served)
        d4 op ev 20260715 1 1 1 0 1))
    (let not-successful (nmli-edge "not-successful" "serve"
        (list (nmli-node-sha quantized)) (nmli-node-sha served)
        d4 op ev 20260715 1 1 1 1 0))
    (let invalid-attested (nmli-edge "invalid-attested" "serve"
        (list (nmli-node-sha quantized)) (nmli-node-sha served)
        "" op ev 20260715 1 1 1 1 1))

    (let reversed-components
        (list (nmli-component "model" 100 d1)
              (nmli-component "config" 10 d2)))
    (let tampered-node
        (list "native-model-lineage-node-v1" "base" "base" "mlx"
              "semantic-base" base-components d2))
    (let reviewed-without-tool
        (nmli-edge "reviewed" "quantize" (list (nmli-node-sha fused))
            (nmli-node-sha quantized) "" op ev 20260715 1 1 1 0 1))
    (let authorized-without-review
        (nmli-edge "authorized" "serve" (list (nmli-node-sha quantized))
            (nmli-node-sha served) d3 op ev 20260715 1 0 0 1 1))
    (let current
        (list (nmli-node-sha base) (nmli-node-sha adapter)
              (nmli-node-sha fused) (nmli-node-sha quantized)
              (nmli-node-sha served)))
    (let one-changed
        (list d1 (nmli-node-sha adapter) (nmli-node-sha fused)
              (nmli-node-sha quantized) (nmli-node-sha served)))

    (let c1 (if (eq (nmli-component-valid? (head base-components)) 1) 1 0))
    (let c2 (if (eq (nmli-components-valid? reversed-components) 0) 2 0))
    (let c3 (if (eq (nmli-nodes-valid? nodes) 1) 4 0))
    (let c4 (if (eq (nmli-node-valid? tampered-node) 0) 8 0))
    (let c5 (if (str_eq (nmli-node-sha base)
                        (nmli-node-sha
                            (nmli-node "renamed" "base" "mlx"
                                "semantic-base" base-components))) 16 0))
    (let c6 (if (eq (nmli-edges-valid-for? edges nodes) 1) 32 0))
    (let c7 (if (eq (nmli-chain-valid? base adapter fused quantized served
                        train fuse quant serve) 1) 64 0))
    (let c8 (if (eq (nmli-served-binds-quantized? quantized served) 1) 128 0))
    (let c9 (if (eq (nmli-copy3? q4 q4 q4) 1) 256 0))
    (let c10 (if (eq (nmli-copy3? q4 d1 q4) 0) 512 0))
    (let c11 (if (eq (nmli-edge-valid? reviewed-without-tool) 0) 1024 0))
    (let c12 (if (eq (nmli-edge-valid? authorized-without-review) 0) 2048 0))
    (let c13 (if (eq (nmli-count-edge-field edges 9) 1) 4096 0))
    (let c14 (if (eq (nmli-count-edge-field edges 11) 0) 8192 0))
    (let c15 (if (eq (nmli-node-drift-ppm current current) 0) 16384 0))
    (let c16 (if (eq (nmli-node-drift-ppm current one-changed) 200000) 32768 0))
    (let c17 (if (eq (nmli-authority-ready? edges nodes 4) 0) 65536 0))
    (let c18 (if (eq (nmli-authority-ready? attested-edges nodes 4) 1) 131072 0))
    (let c19 (if (eq (nmli-authority-ready?
                        (list not-fresh attested-fuse attested-quant attested-serve)
                        nodes 4) 0) 262144 0))
    (let c20 (if (eq (nmli-authority-ready?
                        (list attested-train not-reproduced attested-quant attested-serve)
                        nodes 4) 0) 524288 0))
    (let c21 (if (eq (nmli-authority-ready?
                        (list attested-train attested-fuse not-reviewed attested-serve)
                        nodes 4) 0) 1048576 0))
    (let c22 (if (eq (nmli-authority-ready?
                        (list attested-train attested-fuse attested-quant not-authorized)
                        nodes 4) 0) 2097152 0))
    (let c23 (if (eq (nmli-authority-ready?
                        (list attested-train attested-fuse attested-quant not-successful)
                        nodes 4) 0) 4194304 0))
    (let c24 (if (eq (nmli-authority-ready?
                        (list attested-train attested-fuse attested-quant invalid-attested)
                        nodes 4) 0) 8388608 0))
    (let c25 (if (eq (nmli-authority-ready?
                        (list attested-train attested-fuse attested-quant)
                        nodes 4) 0) 16777216 0))
    (sum (list c1 c2 c3 c4 c5 c6 c7 c8
               c9 c10 c11 c12 c13 c14 c15 c16
               c17 c18 c19 c20 c21 c22 c23 c24 c25)))
