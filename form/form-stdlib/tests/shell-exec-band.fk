; shell-exec-band.fk — proves the form-native executor: native builtins compute
; real output, pipes/sequences/variables thread, and host tools dispatch to
; passthrough. Verdict = 511 (all pass), asserted byte-identical on the 4th kernel.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk

(do
    (let e1 (if (str_eq (sh-out "echo hi") "hi\n") 1 0))
    (let e2 (if (str_eq (sh-out "seq 3 | wc -l") "3\n") 2 0))
    (let e3 (if (str_eq (sh-out "echo abc | rev") "cba\n") 4 0))
    (let e4 (if (str_eq (sh-out "x=hi ; echo $x") "hi\n") 8 0))
    (let e5 (if (str_eq (sh-out "seq 5 | grep 3") "3\n") 16 0))
    ; dispatch: a non-builtin command is labelled passthrough (host tool until native)
    (let e6 (if (str_eq (sh-step-kind (head (sh-plan (sh-parse "git status")))) "passthrough") 32 0))
    (let e7 (if (str_eq (sh-out "for w in a b c ; do echo $w ; done") "a\nb\nc\n") 64 0))
    (let e8 (if (str_eq (sh-out "i=1 ; while test $i -le 3 ; do echo $i ; i=4 ; done") "1\n") 128 0))
    (let e9 (if (str_eq (sh-out "for x in a ; do ; done") "") 256 0))

    ; expected total: 511
    (add e1 (add e2 (add e3 (add e4 (add e5 (add e6 (add e7 (add e8 e9)))))))))
