; bml-protocol-capability-row-band.fk - BML protocol/capability rows.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/bml.fk form-stdlib/bml-source.fk
;
; Band verdict: 65535 when BML has explicit protocol(...) and capability(...)
; grammar hooks as data, source rows can parse both expressions, and a protocol
; can witness whether a capability fits its surface/channel/capability shape.

(do
    (defn bpc-score (ok bit) (if ok bit 0))

    (let g (bml-grammar))
    (let protocol-rule (g-rule g "protocol"))
    (let capability-rule (g-rule g "capability"))

    (let protocol-row
        (bml-source-protocol-row-from-expr
            "protocol(sensorFlow,sensor:signal,bodySensor,cap:sensor-read,json,ready,receipt:offer,4);"))
    (let capability-row
        (bml-source-capability-row-from-expr
            "capability(cap:sensor-read,sensor:signal,bodySensor,vector,80,device-local,receipt:offer);"))
    (let assigned-protocol
        (bml-source-protocol-row-from-assignment
            "sensorProtocol = protocol(sensorFlow,sensor:signal,bodySensor,cap:sensor-read,json,ready,receipt:offer,4);"))
    (let assigned-capability
        (bml-source-capability-row-from-assignment
            "sensorCapability = capability(cap:sensor-read,sensor:signal,bodySensor,vector,80,device-local,receipt:offer);"))
    (let mismatch-capability
        (bml-source-capability-row-from-expr
            "capability(cap:remote-write,http:request,bodySensor,json,70,remote,receipt:slow);"))

    (sum
        (list
            (bpc-score (not (nil? protocol-rule)) 1)
            (bpc-score (not (nil? capability-rule)) 2)
            (bpc-score (str_eq (head protocol-rule) "protocol") 4)
            (bpc-score (str_eq (head capability-rule) "capability") 8)
            (bpc-score (eq (len protocol-rule) 3) 16)
            (bpc-score (bml-source-protocol-row? protocol-row) 32)
            (bpc-score (str_eq (bml-source-protocol-row-name protocol-row) "sensorFlow") 64)
            (bpc-score (str_eq (bml-source-protocol-row-capability protocol-row) "cap:sensor-read") 128)
            (bpc-score (eq (bml-source-protocol-row-cost protocol-row) 4) 256)
            (bpc-score (bml-source-capability-row? capability-row) 512)
            (bpc-score (str_eq (bml-source-capability-row-name capability-row) "cap:sensor-read") 1024)
            (bpc-score (eq (bml-source-capability-row-trust-floor capability-row) 80) 2048)
            (bpc-score (bml-source-protocol-accepts-capability? protocol-row capability-row) 4096)
            (bpc-score (not (bml-source-protocol-accepts-capability? protocol-row mismatch-capability)) 8192)
            (bpc-score (bml-source-protocol-row? assigned-protocol) 16384)
            (bpc-score (bml-source-capability-row? assigned-capability) 32768))))
