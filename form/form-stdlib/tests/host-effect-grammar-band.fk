; host-effect-grammar-band.fk -- host-effect vocabulary is a BMF grammar in use.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/host-effect-grammar.fk
;
; Expected: 65535

(do
    (defn hegb-score (ok bit) (if ok bit 0))
    (defn hegb-manifest-has? (name)
        (host-effect-manifest-has? name (host-effect-language-manifest)))
    (defn hegb-canonical-row ()
        (host-effect-row "host_file_read_text" "host-file" 1 "afferent" "text" 63 "canonical"))
    (defn hegb-source ()
        "effect host-file op host_file_read_text arity 1 direction afferent shape text tag 63 compat canonical")
    (defn hegb-loose-source ()
        "effect   host-file   op   host_file_write_text   arity   2   direction   efferent   shape   text   tag   104   compat   canonical")
    (defn hegb-node () (host-effect-parse (hegb-source)))
    (defn hegb-row () (host-effect-parse-row (hegb-source)))
    (defn host-effect-grammar-band ()
        (sum (list
            (hegb-score (eq (hegb-manifest-has? "scannerless") 1) 1)
            (hegb-score (eq (hegb-manifest-has? "bmf-cursor-grammar") 1) 2)
            (hegb-score (eq (hegb-manifest-has? "no-line-grammar") 1) 4)
            (hegb-score (eq (hegb-manifest-has? "not-s-expression-surface") 1) 8)
            (hegb-score (eq (hegb-manifest-has? "bidirectional-source") 1) 16)
            (hegb-score (eq (hegb-manifest-has? "effect-vocabulary-data") 1) 32)
            (hegb-score (eq (hegb-manifest-has? "flattener-consumes-vocabulary") 1) 64)
            (hegb-score (host-effect-ok? (hegb-node)) 128)
            (hegb-score (host-effect-row-eq? (hegb-row) (hegb-canonical-row)) 256)
            (hegb-score (host-effect-roundtrip? (hegb-canonical-row)) 512)
            (hegb-score (eq (host-effect-op? "host_file_read_text") 1) 1024)
            (hegb-score (eq (host-effect-op? "add") 0) 2048)
            (hegb-score (eq (host-effect-op? "write_file_text") 1) 4096)
            (hegb-score (eq (host-effect-root-op? "sense_mic_capture") 1) 8192)
            (hegb-score (host-effect-ok? (host-effect-parse (hegb-loose-source))) 16384)
            (hegb-score (eq (host-effect-op? "host_source_inventory_page") 1) 32768))))

    (host-effect-grammar-band))
