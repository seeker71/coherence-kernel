; generic-reverse-emitter-band.fk - one binary node through target lenses
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/source-compiler.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/grammars/python-bmf.fk form-stdlib/grammars/go-bmf.fk form-stdlib/grammars/typescript-bmf.fk form-stdlib/grammars/image-bmf.fk form-stdlib/grammars/natural-bmf.fk

(do
    (let GENERIC-LENS-COUNT (make_nodeid 1 2 101 9))

    (defn lens-count-recipe (value)
        (intern_node GENERIC-LENS-COUNT
            (list (intern_trivial_int value))))

    (defn lens-count-value (node)
        (node_value (head (node_children node))))

    (defn lens-count-parse-int (source pos ctx)
        (list (bmf-anchor-resolve ctx (bmf-object-value (nth source 0)) "")
              (lens-count-recipe (str_to_int (bmf-object-value (nth source pos))))))

    (defn emit-lens-python (node anchor ctx)
        (list (py-name (bmf-symbol-name ctx anchor anchor))
              (py-op "=")
              (py-int (int_to_str (lens-count-value node)))))

    (defn parse-lens-python (source ctx)
        (lens-count-parse-int source 2 ctx))

    (defn emit-lens-go (node anchor ctx)
        (list (go-src-keyword "var")
              (go-src-name (bmf-symbol-name ctx anchor anchor))
              (go-src-op "=")
              (go-src-int (int_to_str (lens-count-value node)))))

    (defn parse-lens-go (source ctx)
        (list (bmf-anchor-resolve ctx (bmf-object-value (nth source 1)) "")
              (lens-count-recipe (str_to_int (bmf-object-value (nth source 3))))))

    (defn emit-lens-typescript (node anchor ctx)
        (list (ts-src-name (bmf-symbol-name ctx anchor anchor))
              (ts-src-op "=")
              (ts-src-int (int_to_str (lens-count-value node)))
              (ts-src-op ";")))

    (defn parse-lens-typescript (source ctx)
        (lens-count-parse-int source 2 ctx))

    (defn emit-lens-image (node anchor ctx)
        (list (image-src-keyword "svg")
              (image-src-int (int_to_str (lens-count-value node)))
              (image-src-keyword "x")
              (image-src-int (int_to_str (mul (lens-count-value node) 2)))
              (image-src-keyword "viewBox")
              (image-src-string (bmf-symbol-name ctx anchor anchor))))

    (defn parse-lens-image (source ctx)
        (list (bmf-anchor-resolve ctx (bmf-object-value (nth source 5)) "")
              (lens-count-recipe (str_to_int (bmf-object-value (nth source 1))))))

    (defn emit-lens-natural (node anchor ctx)
        (natural-fact-source-for-context
            (bmf-symbol-name ctx anchor anchor)
            (lens-count-value node)
            ctx))

    (defn parse-lens-natural (source ctx)
        (do
            (let node
                (fsc-bmf-lower-node
                    (natural-fact-rule-for-context ctx)
                    source))
            (let kids (node_children node))
            (let subject (node_value (nth kids 0)))
            (list (bmf-anchor-resolve ctx subject subject)
                  (lens-count-recipe (node_value (nth kids 1))))))

    (defn lens-score (rt node anchor)
        (add (if (str_eq (bmf-lens-roundtrip-anchor rt) anchor) 1 0)
             (if (node_eq (bmf-lens-roundtrip-node rt) node) 1 0)))

    (let node (lens-count-recipe 13))
    (let anchor "binary/lens/count")

    ;; bmf-reverse-lens-node-from calls intern_node BMF-REVERSE-LENS (list domain lens) —
    ;; kernel intern_node requires children to be NodeIDs, so we promote the domain/lens
    ;; labels from raw strings to interned-string NodeIDs once and reuse them at every
    ;; call site. bmf-reverse-lens-matches? compares with value_eq, which is kind-strict;
    ;; the lookups must use the same kind the targets were constructed with.
    (let DOM-PYTHON (intern_trivial_string "python"))
    (let DOM-GO (intern_trivial_string "go"))
    (let DOM-TYPESCRIPT (intern_trivial_string "typescript"))
    (let DOM-IMAGE (intern_trivial_string "image"))
    (let DOM-NATURAL (intern_trivial_string "natural"))
    (let LENS-ASSIGN (intern_trivial_string "assign"))
    (let LENS-VAR (intern_trivial_string "var"))
    (let LENS-SVG-META (intern_trivial_string "svg-meta"))
    (let LENS-ASSERTION (intern_trivial_string "assertion"))

    (let python-ctx
        (bmf-symbol-context DOM-PYTHON LENS-ASSIGN
            (list (bmf-symbol-binding anchor DOM-PYTHON LENS-ASSIGN
                                      "py.count" (list "count_py" "py_count")))))
    (let go-ctx
        (bmf-symbol-context DOM-GO LENS-VAR
            (list (bmf-symbol-binding anchor DOM-GO LENS-VAR
                                      "go.count" (list "countGo")))))
    (let typescript-ctx
        (bmf-symbol-context DOM-TYPESCRIPT LENS-ASSIGN
            (list (bmf-symbol-binding anchor DOM-TYPESCRIPT LENS-ASSIGN
                                      "ts.count" (list "countTs")))))
    (let image-ctx
        (bmf-symbol-context DOM-IMAGE LENS-SVG-META
            (list (bmf-symbol-binding anchor DOM-IMAGE LENS-SVG-META
                                      "image.count" (list "count-viewbox")))))
    (let natural-ctx
        (natural-symbol-context "en-US" "plain" "general" LENS-ASSERTION
            (list (bmf-symbol-binding anchor DOM-NATURAL LENS-ASSERTION
                                      "natural.count" (list "count" "number")))))
    (let natural-id-ctx
        (natural-symbol-context "id-ID" "plain" "general" LENS-ASSERTION
            (list (bmf-symbol-binding anchor DOM-NATURAL LENS-ASSERTION
                                      "natural.jumlah" (list "jumlah" "bilangan")))))

    (let targets
        (list
            (bmf-reverse-lens DOM-PYTHON LENS-ASSIGN emit-lens-python parse-lens-python
                              (python-bmf-find-rule "assign-int" python-bmf-rules))
            (bmf-reverse-lens DOM-GO LENS-VAR emit-lens-go parse-lens-go
                              (go-bmf-find-rule "var-int" go-bmf-rules))
            (bmf-reverse-lens DOM-TYPESCRIPT LENS-ASSIGN emit-lens-typescript parse-lens-typescript
                              (typescript-bmf-find-rule "assign-int" typescript-bmf-rules))
            (bmf-reverse-lens DOM-IMAGE LENS-SVG-META emit-lens-image parse-lens-image
                              (image-bmf-find-rule "svg-viewbox" image-bmf-rules))
            (bmf-reverse-lens DOM-NATURAL LENS-ASSERTION emit-lens-natural parse-lens-natural
                              (natural-bmf-find-rule "fact-the-is" natural-bmf-rules))))

    (let py-rt (bmf-lens-roundtrip targets DOM-PYTHON LENS-ASSIGN node anchor python-ctx (empty)))
    (let go-rt (bmf-lens-roundtrip targets DOM-GO LENS-VAR node anchor go-ctx (empty)))
    (let ts-rt (bmf-lens-roundtrip targets DOM-TYPESCRIPT LENS-ASSIGN node anchor typescript-ctx (empty)))
    (let image-rt (bmf-lens-roundtrip targets DOM-IMAGE LENS-SVG-META node anchor image-ctx (empty)))
    (let natural-rt (bmf-lens-roundtrip targets DOM-NATURAL LENS-ASSERTION node anchor natural-ctx (empty)))
    (let natural-id-rt (bmf-lens-roundtrip targets DOM-NATURAL LENS-ASSERTION node anchor natural-id-ctx (empty)))

    (let py-bmf-rt
        (bmf-roundtrip
            (bmf-reverse-lens-rule (bmf-reverse-lens-find targets DOM-PYTHON LENS-ASSIGN (empty)))
            (bmf-lens-roundtrip-source py-rt)))
    (let go-bmf-rt
        (bmf-roundtrip
            (bmf-reverse-lens-rule (bmf-reverse-lens-find targets DOM-GO LENS-VAR (empty)))
            (bmf-lens-roundtrip-source go-rt)))
    (let ts-bmf-rt
        (bmf-roundtrip
            (bmf-reverse-lens-rule (bmf-reverse-lens-find targets DOM-TYPESCRIPT LENS-ASSIGN (empty)))
            (bmf-lens-roundtrip-source ts-rt)))
    (let image-bmf-rt
        (bmf-roundtrip
            (bmf-reverse-lens-rule (bmf-reverse-lens-find targets DOM-IMAGE LENS-SVG-META (empty)))
            (bmf-lens-roundtrip-source image-rt)))
    (let natural-bmf-rt
        (bmf-roundtrip
            (natural-fact-rule-for-context natural-ctx)
            (bmf-lens-roundtrip-source natural-rt)))
    (let natural-id-bmf-rt
        (bmf-roundtrip
            (natural-fact-rule-for-context natural-id-ctx)
            (bmf-lens-roundtrip-source natural-id-rt)))

    (sum
        (list
            (lens-score py-rt node anchor)
            (lens-score go-rt node anchor)
            (lens-score ts-rt node anchor)
            (lens-score image-rt node anchor)
            (lens-score natural-rt node anchor)
            (lens-score natural-id-rt node anchor)
            (if (bmf-roundtrip-node-eq? py-bmf-rt) 10 0)
            (if (bmf-roundtrip-node-eq? go-bmf-rt) 20 0)
            (if (bmf-roundtrip-node-eq? ts-bmf-rt) 30 0)
            (if (bmf-roundtrip-node-eq? image-bmf-rt) 40 0)
            (if (bmf-roundtrip-node-eq? natural-bmf-rt) 50 0)
            (if (bmf-roundtrip-node-eq? natural-id-bmf-rt) 60 0)
            (len (bmf-lens-roundtrip-source py-rt))
            (len (bmf-lens-roundtrip-source go-rt))
            (len (bmf-lens-roundtrip-source ts-rt))
            (len (bmf-lens-roundtrip-source image-rt))
            (len (bmf-lens-roundtrip-source natural-rt))
            (len (bmf-lens-roundtrip-source natural-id-rt)))))
