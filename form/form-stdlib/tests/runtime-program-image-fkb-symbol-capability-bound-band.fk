; runtime-program-image-fkb-symbol-capability-bound-band.fk -- Layer 9h7 capability-bound computed symbol walk proof.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-executor-capability.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/program-image-symbol-entry.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-program-image-fkb-micro-walker.fk form-stdlib/runtime-program-image-fkb-symbol-walk.fk form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk
;
; Expected: 262143

(do
    (defn rpswcb-score (ok bit) (if ok bit 0))
    (defn rpswcb-manifest-has (name)
        (runtime-program-image-fkb-symbol-capability-bound-manifest-has? name
            (runtime-program-image-fkb-symbol-capability-bound-manifest)))
    (defn rpswcb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rpswcb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))
    (defn rpswcb-none-of? (text needles)
        (if (nil? needles)
            1
            (if (rpswcb-has? text (head needles))
                0
                (rpswcb-none-of? text (tail needles)))))

    (defn rpswcb-source-hash () "sha:src-cap-symbol")
    (defn rpswcb-content-hash () "sha:content-cap-symbol")
    (defn rpswcb-artifact-path () "cache/cap-symbol.fkb")
    (defn rpswcb-other-artifact-path () "cache/other-cap-symbol.fkb")

    (defn rpswcb-nodes ()
        (list
            (pif-node-row 1 42 0 0)
            (pif-node-row 1 40 0 0)
            (pif-node-row 1 2 0 0)
            (pif-node-row 3 1 2 0)
            (pif-node-row 99 0 0 0)
            (pif-node-row 3 0 99 0)))
    (defn rpswcb-roots () (list 0 3 4 5))
    (defn rpswcb-table ()
        (pif-table-image (len (rpswcb-roots))
                         (rpswcb-roots)
                         (len (rpswcb-nodes))
                         (rpswcb-nodes)
                         0
                         (empty)))
    (defn rpswcb-symbol-rows ()
        (list (pif-symbol-row 0 "core/lit42")
              (pif-symbol-row 1 "core/add42")
              (pif-symbol-row 2 "core/bad-tag")
              (pif-symbol-row 3 "core/bad-child")))
    (defn rpswcb-node-symbol-rows ()
        (list
            (pif-node-symbol-row 0 0 (empty))
            (pif-node-symbol-row 3 1 (empty))
            (pif-node-symbol-row 4 2 (empty))
            (pif-node-symbol-row 5 3 (empty))))
    (defn rpswcb-symbol-image ()
        (pif-symbol-image 4 (rpswcb-symbol-rows) 4 (rpswcb-node-symbol-rows)))
    (defn rpswcb-pif-with (artifact-path content-hash seal-ok)
        (pif-envelope-with-symbols "src/cap-symbol.fk" (rpswcb-source-hash) 100
                                   artifact-path content-hash 101
                                   seal-ok (rpswcb-table) (rpswcb-symbol-image)))
    (defn rpswcb-pif ()
        (rpswcb-pif-with (rpswcb-artifact-path) (rpswcb-content-hash) 1))
    (defn rpswcb-other-pif ()
        (rpswcb-pif-with (rpswcb-other-artifact-path) "sha:other-cap-symbol" 1))

    (defn rpswcb-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rpswcb-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rpswcb-envelope-for-pif (pif)
        (do
            (let src (rpswcb-source-for-pif pif))
            (let fkb (rpswcb-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rpswcb-envelope () (rpswcb-envelope-for-pif (rpswcb-pif)))
    (defn rpswcb-other-envelope () (rpswcb-envelope-for-pif (rpswcb-other-pif)))
    (defn rpswcb-non-program-envelope ()
        (rale-envelope (pif-source-from-envelope (rpswcb-pif))
                       (sad-no-artifact)
                       (rap-act-compile-source)
                       (sac-run-source-compile)
                       "none"
                       ""
                       (rpswcb-source-hash)
                       ""
                       (list "selection")
                       (rale-no-retry)
                       (rale-no-compile-output)
                       (rale-status-request-ready)
                       "synthetic-non-program-envelope"))
    (defn rpswcb-payload-for-pif (pif)
        (pifbd-payload (pif-envelope-source-path pif)
                       (pif-envelope-source-hash pif)
                       (pif-envelope-source-mtime pif)
                       (pif-envelope-artifact-path pif)
                       (pif-envelope-seal-ok pif)
                       (pif-envelope-table pif)
                       (pif-envelope-symbol-image pif)))
    (defn rpswcb-decode-for-pif (pif)
        (pifbd-decoded-row (rpswcb-payload-for-pif pif) 123))
    (defn rpswcb-admission-for-pif (pif)
        (pifbd-admission (list "runtime-program-image-fkb-symbol-capability-bound-synthetic-admission")
                         (rpswcb-decode-for-pif pif)
                         pif
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpswcb-admission () (rpswcb-admission-for-pif (rpswcb-pif)))

    (defn rpswcb-cap-for-envelope (e availability evidence authority freshness detail)
        (raec-capability (raec-cap-program-image-walker)
                         (rale-envelope-action e)
                         (rale-envelope-route e)
                         (rale-envelope-artifact-kind e)
                         availability evidence authority freshness detail))
    (defn rpswcb-ready-cap-for (e)
        (rpswcb-cap-for-envelope e
                                 (raec-availability-available)
                                 (raec-evidence-supplied-current)
                                 (raec-authority-attempt-supplier)
                                 (raec-freshness-current)
                                 "supplied-current-program-image-walker"))
    (defn rpswcb-ready-cap () (rpswcb-ready-cap-for (rpswcb-envelope)))
    (defn rpswcb-readiness-for (e)
        (raec-readiness-from-envelope-capability e (rpswcb-ready-cap-for e)))
    (defn rpswcb-readiness () (rpswcb-readiness-for (rpswcb-envelope)))
    (defn rpswcb-no-capability-readiness ()
        (raec-readiness-from-envelope-no-capability (rpswcb-envelope)))
    (defn rpswcb-current-floor-readiness ()
        (raec-readiness-from-envelope-capability (rpswcb-envelope)
            (raec-current-floor-program-image-unavailable)))
    (defn rpswcb-stale-readiness ()
        (raec-readiness-from-envelope-capability
            (rpswcb-envelope)
            (rpswcb-cap-for-envelope (rpswcb-envelope)
                                     (raec-availability-available)
                                     (raec-evidence-supplied-stale)
                                     (raec-authority-attempt-supplier)
                                     (raec-freshness-current)
                                     "stale-program-image-walker")))
    (defn rpswcb-inadequate-readiness ()
        (raec-readiness-from-envelope-capability
            (rpswcb-envelope)
            (rpswcb-cap-for-envelope (rpswcb-envelope)
                                     (raec-availability-unknown)
                                     (raec-evidence-inadequate)
                                     (raec-authority-attempt-supplier)
                                     (raec-freshness-unknown)
                                     "inadequate-program-image-walker")))
    (defn rpswcb-forbidden-readiness ()
        (raec-readiness-from-envelope-capability
            (rpswcb-envelope)
            (rpswcb-cap-for-envelope (rpswcb-envelope)
                                     (raec-availability-available)
                                     (raec-evidence-supplied-current)
                                     (raec-authority-forbidden-execution)
                                     (raec-freshness-current)
                                     "forbidden-program-image-walker")))
    (defn rpswcb-forged-readiness (cap reason evidence authority freshness detail)
        (raec-readiness (rpswcb-envelope)
                        cap
                        (rap-act-run-program-image)
                        (sac-run-fkb)
                        (sad-kind-program-image-fkb)
                        (raec-cap-program-image-walker)
                        (raec-status-ready)
                        reason
                        evidence
                        authority
                        freshness
                        detail))
    (defn rpswcb-forged-reason-readiness ()
        (rpswcb-forged-readiness (rpswcb-ready-cap)
                                 "forged-ready"
                                 (raec-evidence-supplied-current)
                                 (raec-authority-attempt-supplier)
                                 (raec-freshness-current)
                                 "supplied-current-program-image-walker"))
    (defn rpswcb-forged-unavailable-cap-readiness ()
        (rpswcb-forged-readiness
            (rpswcb-cap-for-envelope (rpswcb-envelope)
                                     (raec-availability-unavailable)
                                     (raec-evidence-supplied-current)
                                     (raec-authority-attempt-supplier)
                                     (raec-freshness-current)
                                     "unavailable-hidden-in-ready")
            (raec-reason-ready)
            (raec-evidence-supplied-current)
            (raec-authority-attempt-supplier)
            (raec-freshness-current)
            "unavailable-hidden-in-ready"))
    (defn rpswcb-forged-detail-readiness ()
        (rpswcb-forged-readiness (rpswcb-ready-cap)
                                 (raec-reason-ready)
                                 (raec-evidence-supplied-current)
                                 (raec-authority-attempt-supplier)
                                 (raec-freshness-current)
                                 "wrong-recomputed-detail"))
    (defn rpswcb-forged-malformed-cap-readiness ()
        (rpswcb-forged-readiness
            (list "runtime-artifact-executor-capability" 1)
            (raec-reason-ready)
            (raec-evidence-supplied-current)
            (raec-authority-attempt-supplier)
            (raec-freshness-current)
            "malformed-capability-hidden-in-ready"))
    (defn rpswcb-forged-wrong-cap-readiness ()
        (rpswcb-forged-readiness
            (raec-capability (raec-cap-native-dylib-caller)
                             (rap-act-run-program-image)
                             (sac-run-fkb)
                             (sad-kind-program-image-fkb)
                             (raec-availability-available)
                             (raec-evidence-supplied-current)
                             (raec-authority-attempt-supplier)
                             (raec-freshness-current)
                             "wrong-capability-name")
            (raec-reason-ready)
            (raec-evidence-supplied-current)
            (raec-authority-attempt-supplier)
            (raec-freshness-current)
            "wrong-capability-name"))
    (defn rpswcb-wrong-required-readiness ()
        (raec-readiness (rpswcb-envelope)
                        (rpswcb-ready-cap)
                        (rap-act-run-program-image)
                        (sac-run-fkb)
                        (sad-kind-program-image-fkb)
                        (raec-cap-native-dylib-caller)
                        (raec-status-ready)
                        (raec-reason-ready)
                        (raec-evidence-supplied-current)
                        (raec-authority-attempt-supplier)
                        (raec-freshness-current)
                        "wrong-required-capability"))

    (defn rpswcb-bind-key (key budget input)
        (rpswc-bind (rpswcb-envelope)
                    (rpswcb-readiness)
                    (rpswcb-admission)
                    (pise-request-by-canonical-key key)
                    budget
                    input))
    (defn rpswcb-good () (rpswcb-bind-key "core/lit42" 10 0))
    (defn rpswcb-add () (rpswcb-bind-key "core/add42" 10 0))
    (defn rpswcb-timeout () (rpswcb-bind-key "core/add42" 2 0))
    (defn rpswcb-unsupported () (rpswcb-bind-key "core/bad-tag" 10 0))
    (defn rpswcb-negative-budget () (rpswcb-bind-key "core/lit42" (sub 0 1) 0))
    (defn rpswcb-with-readiness (readiness)
        (rpswc-bind (rpswcb-envelope) readiness (rpswcb-admission)
                    (pise-request-by-canonical-key "core/lit42") 10 0))
    (defn rpswcb-recomputed-symbol-walk ()
        (rpsw-walk-symbol (rpswcb-envelope) (rpswcb-admission)
                          (pise-request-by-canonical-key "core/lit42") 10 0))
    (defn rpswcb-symbol-walk-matches? (a b)
        (and (rpsw-receipt? a)
        (and (rpsw-receipt? b)
        (and (eq (rpsw-receipt-step-budget a) (rpsw-receipt-step-budget b))
        (and (eq (rpsw-receipt-input-value a) (rpsw-receipt-input-value b))
        (and (str_eq (rpsw-receipt-status a) (rpsw-receipt-status b))
        (and (str_eq (rpsw-receipt-reason a) (rpsw-receipt-reason b))
             (rpsw-trace-fields-match? (rpsw-receipt-trace a)
                                       (rpsw-receipt-trace b)))))))))

    (defn rpswcb-bit-manifest-1 ()
        (rpswcb-score
            (and (eq (rpswcb-manifest-has "layer-9h7-capability-bound-computed-symbol-walk") 1)
            (and (eq (rpswcb-manifest-has "binds-9g-readiness-to-computed-9h6-symbol-walk") 1)
            (and (eq (rpswcb-manifest-has "single-public-bind-entry-recomputes-9h6") 1)
            (and (eq (rpswcb-manifest-has "no-supplied-rpsw-receipt-authority") 1)
                 (eq (rpswcb-manifest-has "no-independent-trace-input") 1)))))
            1))
    (defn rpswcb-bit-manifest-2 ()
        (rpswcb-score
            (and (eq (rpswcb-manifest-has "program-image-walker-required") 1)
            (and (eq (rpswcb-manifest-has "readiness-recomputed-from-capability") 1)
            (and (eq (rpswcb-manifest-has "trace-exposed-only-after-capability-and-computed-walk") 1)
            (and (eq (rpswcb-manifest-has "non-produced-symbol-walk-preserved") 1)
            (and (eq (rpswcb-manifest-has "no-9h1-9h2-9h3-9h4-consumption") 1)
            (and (eq (rpswcb-manifest-has "no-attempt-or-observation-production") 1)
            (and (eq (rpswcb-manifest-has "no-table-payload-authority") 1)
            (and (eq (rpswcb-manifest-has "no-generated-table-authority") 1)
                 (eq (rpswcb-manifest-has "no-c-seed-growth") 1)))))))))
            2))
    (defn rpswcb-bit-version ()
        (rpswcb-score (str_eq (rpswc-version) "runtime-program-image-fkb-symbol-capability-bound-v1") 4))
    (defn rpswcb-bit-happy-bound ()
        (do
            (let j (rpswcb-good))
            (rpswcb-score
                (and (rpswc-join? j)
                (and (str_eq (rpswc-join-status j) (rpswc-status-bound))
                (and (str_eq (rpswc-join-reason j) (rpmw-reason-walk-completed))
                (and (rpiwt-trace? (rpswc-join-bound-trace j))
                     (eq (rpiwt-trace-first-value (rpswc-join-bound-trace j)) 42)))))
                8)))
    (defn rpswcb-bit-recomputed-only ()
        (do
            (let j (rpswcb-good))
            (let recomputed (rpswcb-recomputed-symbol-walk))
            (rpswcb-score
                (and (rpswcb-symbol-walk-matches? (rpswc-join-symbol-walk j) recomputed)
                     (rpsw-trace-fields-match? (rpswc-join-bound-trace j)
                                               (rpsw-receipt-trace recomputed)))
                16)))
    (defn rpswcb-bit-unavailable-readiness ()
        (do
            (let no-cap (rpswcb-with-readiness (rpswcb-no-capability-readiness)))
            (let floor (rpswcb-with-readiness (rpswcb-current-floor-readiness)))
            (rpswcb-score
                (and (str_eq (rpswc-join-status no-cap) (rpswc-status-unavailable))
                (and (str_eq (rpswc-join-reason no-cap) (raec-reason-no-capability-supplied))
                (and (rpswc-no-symbol-walk? (rpswc-join-symbol-walk no-cap))
                (and (rpswc-no-bound-trace? (rpswc-join-bound-trace no-cap))
                (and (str_eq (rpswc-join-status floor) (rpswc-status-unavailable))
                     (str_eq (rpswc-join-reason floor) (raec-reason-capability-unavailable)))))))
                32)))
    (defn rpswcb-bit-stale-inadequate-forbidden ()
        (do
            (let stale (rpswcb-with-readiness (rpswcb-stale-readiness)))
            (let weak (rpswcb-with-readiness (rpswcb-inadequate-readiness)))
            (let forbidden (rpswcb-with-readiness (rpswcb-forbidden-readiness)))
            (rpswcb-score
                (and (str_eq (rpswc-join-status stale) (rpswc-status-investigate))
                (and (str_eq (rpswc-join-reason stale) (raec-reason-capability-stale))
                (and (str_eq (rpswc-join-status weak) (rpswc-status-investigate))
                (and (str_eq (rpswc-join-reason weak) (raec-reason-evidence-inadequate))
                (and (str_eq (rpswc-join-status forbidden) (rpswc-status-refused))
                     (str_eq (rpswc-join-reason forbidden) (raec-reason-forbidden-authority)))))))
                64)))
    (defn rpswcb-bit-forged-ready ()
        (do
            (let reason-bad (rpswcb-with-readiness (rpswcb-forged-reason-readiness)))
            (let cap-bad (rpswcb-with-readiness (rpswcb-forged-unavailable-cap-readiness)))
            (let detail-bad (rpswcb-with-readiness (rpswcb-forged-detail-readiness)))
            (rpswcb-score
                (and (str_eq (rpswc-join-reason reason-bad) (rpswc-reason-readiness-ready-fields-forged))
                (and (str_eq (rpswc-join-reason cap-bad) (rpswc-reason-nested-capability-evidence-mismatch))
                (and (str_eq (rpswc-join-reason detail-bad) (rpswc-reason-recomputed-readiness-mismatch))
                (and (rpswc-no-bound-trace? (rpswc-join-bound-trace reason-bad))
                     (rpswc-no-bound-trace? (rpswc-join-bound-trace cap-bad))))))
                128)))
    (defn rpswcb-bit-identity-mismatch ()
        (do
            (let j (rpswc-bind (rpswcb-envelope)
                               (rpswcb-readiness-for (rpswcb-other-envelope))
                               (rpswcb-admission)
                               (pise-request-by-canonical-key "core/lit42")
                               10 0))
            (rpswcb-score
                (and (str_eq (rpswc-join-status j) (rpswc-status-investigate))
                     (str_eq (rpswc-join-reason j) (rpswc-reason-readiness-envelope-identity-mismatch)))
                256)))
    (defn rpswcb-bit-field-and-capability-mismatch ()
        (do
            (let req (rpswcb-with-readiness (rpswcb-wrong-required-readiness)))
            (let cap (rpswcb-with-readiness (rpswcb-forged-wrong-cap-readiness)))
            (rpswcb-score
                (and (str_eq (rpswc-join-reason req) (rpswc-reason-readiness-field-mismatch))
                     (str_eq (rpswc-join-reason cap) (rpswc-reason-nested-capability-mismatch)))
                512)))
    (defn rpswcb-bit-malformed ()
        (do
            (let env (rpswc-bind (list "bad-envelope") (rpswcb-readiness) (rpswcb-admission)
                                 (pise-request-by-canonical-key "core/lit42") 10 0))
            (let nonprogram (rpswc-bind (rpswcb-non-program-envelope) (rpswcb-readiness) (rpswcb-admission)
                                        (pise-request-by-canonical-key "core/lit42") 10 0))
            (let ready (rpswc-bind (rpswcb-envelope) (list "bad-readiness") (rpswcb-admission)
                                   (pise-request-by-canonical-key "core/lit42") 10 0))
            (let cap (rpswcb-with-readiness (rpswcb-forged-malformed-cap-readiness)))
            (rpswcb-score
                (and (str_eq (rpswc-join-reason env) (rpswc-reason-malformed-envelope))
                (and (str_eq (rpswc-join-reason nonprogram) (rpswc-reason-non-program-image-envelope))
                (and (str_eq (rpswc-join-reason ready) (rpswc-reason-malformed-readiness))
                     (str_eq (rpswc-join-reason cap) (rpswc-reason-malformed-capability)))))
                1024)))
    (defn rpswcb-bit-symbol-failure-preserved ()
        (do
            (let missing (rpswcb-bind-key "core/missing" 10 0))
            (let diagnostic (rpswc-bind (rpswcb-envelope) (rpswcb-readiness) (rpswcb-admission)
                                        (pise-diagnostic-request-by-node 3) 10 0))
            (let bad-budget (rpswcb-negative-budget))
            (rpswcb-score
                (and (str_eq (rpswc-join-status missing) (rpsw-status-refused))
                (and (str_eq (rpswc-join-reason missing) (pise-reason-canonical-key-not-found))
                (and (str_eq (rpswc-join-status diagnostic) (rpsw-status-refused))
                (and (str_eq (rpswc-join-reason diagnostic) (rpsw-reason-diagnostic-node-not-runtime-request))
                (and (str_eq (rpswc-join-status bad-budget) (rpmw-status-refused))
                     (str_eq (rpswc-join-reason bad-budget) (rpmw-reason-negative-step-budget)))))))
                2048)))
    (defn rpswcb-bit-trace-statuses-bound ()
        (do
            (let timeout (rpswcb-timeout))
            (let unsupported (rpswcb-unsupported))
            (rpswcb-score
                (and (str_eq (rpswc-join-status timeout) (rpswc-status-bound))
                (and (str_eq (rpswc-join-reason timeout) (rpmw-reason-step-budget-exhausted))
                (and (str_eq (rpiwt-trace-status (rpswc-join-bound-trace timeout)) (rao-obs-timeout))
                (and (str_eq (rpswc-join-status unsupported) (rpswc-status-bound))
                (and (str_eq (rpswc-join-reason unsupported) (rpmw-reason-unsupported-tag))
                     (str_eq (rpiwt-trace-status (rpswc-join-bound-trace unsupported)) (rao-obs-error)))))))
                4096)))
    (defn rpswcb-bit-no-bound-trace-on-failure ()
        (do
            (let missing (rpswcb-bind-key "core/missing" 10 0))
            (let no-cap (rpswcb-with-readiness (rpswcb-no-capability-readiness)))
            (rpswcb-score
                (and (rpswc-no-bound-trace? (rpswc-join-bound-trace missing))
                     (rpswc-no-bound-trace? (rpswc-join-bound-trace no-cap)))
                8192)))
    (defn rpswcb-forbidden-needles ()
        (list "rpifa-" "rpifc-" "rpiftc-" "rpiwt-bridge"
              "raar-supplied-attempt" "rtta-" ".payload" ".sym"
              "rpswc-bind-from-receipt" "rpswc-bind-after"
              "(defn rpswc-bound" "(defn rpswc-join-row"
              "(defn rpswc-terminal" "(defn rpswc-refused"
              "(defn rpswc-investigate" "(defn rpswc-unavailable"
              "(defn rpswc-readiness-terminal" "(defn rpswc-symbol-walk-terminal"
              "rpsw-receipt-row" "read_file" "read_file_slice"
              "write_file" "append_file" "remove_file" "fk_run"
              "form-eval" "dlopen" "bp_table" "bpTable" "BP_TABLE"))
    (defn rpswcb-bit-static-source ()
        (do
            (let text (rpswcb-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk"))
            (rpswcb-score (rpswcb-none-of? text (rpswcb-forbidden-needles)) 16384)))
    (defn rpswcb-bit-mirror ()
        (do
            (let text (rpswcb-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk"))
            (let grammar (rpswcb-read-file-any "grammars/runtime-program-image-fkb-symbol-capability-bound.fk"
                                               "../grammars/runtime-program-image-fkb-symbol-capability-bound.fk"))
            (rpswcb-score (str_eq text grammar) 32768)))
    (defn rpswcb-bit-architecture-receipt ()
        (do
            (let arch (rpswcb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                            "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rpswcb-read-file-any "../receipts/2026-07-04-runtime-program-image-fkb-symbol-capability-bound-layer-review.md"
                                               "receipts/2026-07-04-runtime-program-image-fkb-symbol-capability-bound-layer-review.md"))
            (rpswcb-score
                (and (rpswcb-has? arch "9h7. Runtime program-image `.fkb` symbol capability bind")
                (and (rpswcb-has? receipt "Layer 9h7")
                (and (rpswcb-has? receipt "recomputes `rpsw-walk-symbol`")
                     (rpswcb-has? receipt "no supplied 9h6 receipt authority"))))
                65536)))
    (defn rpswcb-bit-single-entry-shape ()
        (do
            (let text (rpswcb-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk"))
            (rpswcb-score
                (and (rpswcb-has? text "(defn rpswc-bind ")
                (and (rpswcb-has? text "(let symbol-walk (rpsw-walk-symbol")
                (and (not (rpswcb-has? text "(defn rpswc-bound"))
                (and (not (rpswcb-has? text "(defn rpswc-terminal"))
                (and (not (rpswcb-has? text "(defn rpswc-symbol-walk-terminal"))
                     (not (rpswcb-has? text "(defn rpswc-bind-after")))))))
                131072)))

    (defn runtime-program-image-fkb-symbol-capability-bound-band ()
        (sum (list
            (rpswcb-bit-manifest-1)
            (rpswcb-bit-manifest-2)
            (rpswcb-bit-version)
            (rpswcb-bit-happy-bound)
            (rpswcb-bit-recomputed-only)
            (rpswcb-bit-unavailable-readiness)
            (rpswcb-bit-stale-inadequate-forbidden)
            (rpswcb-bit-forged-ready)
            (rpswcb-bit-identity-mismatch)
            (rpswcb-bit-field-and-capability-mismatch)
            (rpswcb-bit-malformed)
            (rpswcb-bit-symbol-failure-preserved)
            (rpswcb-bit-trace-statuses-bound)
            (rpswcb-bit-no-bound-trace-on-failure)
            (rpswcb-bit-static-source)
            (rpswcb-bit-mirror)
            (rpswcb-bit-architecture-receipt)
            (rpswcb-bit-single-entry-shape))))

    (runtime-program-image-fkb-symbol-capability-bound-band))
