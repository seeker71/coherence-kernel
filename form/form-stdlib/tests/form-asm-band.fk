; preludes: form-stdlib/core.fk form-stdlib/form-asm.fk
;
; form-asm-band — the Form -> assembly compiler's foundation, proven three-way:
; arm64 instruction encoding is byte-for-byte identical to the ASSEMBLER, and the
; byte-conviction gate (the witness theorem on bytes) opens only on full identity.
; This is what licenses dropping clang: the system rewrites its own toolchain only
; once it can byte-level verify its encoder IS the assembler. (form-to-asm.form.)
;
; The reference bytes are the little-endian image `clang`/`as` actually emitted for
;   movz w0,#42 ; add w0,w0,#1 ; sub w0,w0,#1 ; ret
; words 0x52800540 0x11000400 0x51000400 0xd65f03c0 -> LE bytes:
;   40 05 80 52  00 04 00 11  00 04 00 51  c0 03 5f d6
;
; Verdict 31 when the encoder is byte-accurate and the gate is sound:
;   1   movz encodes EXACTLY the assembler's 4 bytes (the LIT instruction)
;   2   add and sub encode EXACTLY the assembler's bytes (the arithmetic ops)
;   4   ret is the fixed image, and the high-bit byte (0xd6=214) is correct —
;       the case that exposed host int32 wrap; bytes keep it exact
;   8   CONVICTION FULL — the Form image byte-equals the assembler image;
;       conviction=1 and (with full confidence) the gate says clang MAY be dropped
;   16  CONVICTION REFUTED — change ONE operand (movz #43) and the image differs;
;       conviction=0 and the gate REFUSES to drop clang. The gate doesn't merely
;       pass — it refuses on a single byte. Safe self-update: verify or don't swap.
(do
    ; the assembler's reference image (measured from clang -c), 16 little-endian bytes
    (let ref-image (list 64 5 128 82  0 4 0 17  0 4 0 81  192 3 95 214))

    ; the Form encoder's program: movz w0,#42 ; add w0,w0,#1 ; sub w0,w0,#1 ; ret
    (let cand-image (fa-image (list (fa-movz 0 42) (fa-add 0 0 1) (fa-sub 0 0 1) (fa-ret))))

    (let c0 (if (eq (nth (fa-movz 0 42) 0) 64)
            (if (eq (nth (fa-movz 0 42) 1) 5)
            (if (eq (nth (fa-movz 0 42) 2) 128)
            (if (eq (nth (fa-movz 0 42) 3) 82) 1 0) 0) 0) 0))
    (let c1 (if (eq (nth (fa-add 0 0 1) 1) 4)
            (if (eq (nth (fa-add 0 0 1) 3) 17)
            (if (eq (nth (fa-sub 0 0 1) 1) 4)
            (if (eq (nth (fa-sub 0 0 1) 3) 81) 2 0) 0) 0) 0))
    (let c2 (if (eq (nth (fa-ret) 0) 192)
            (if (eq (nth (fa-ret) 3) 214) 4 0) 0))     ; the high-bit byte, exact

    ; full conviction: the Form image IS the assembler image, byte-for-byte
    (let c3 (if (eq (fa-conviction cand-image ref-image) 1)
                (if (eq (fa-may-drop (fa-conviction cand-image ref-image) 1) 1) 8 0) 0))

    ; refuted: a one-operand change breaks byte-identity; the gate refuses to drop
    (let bad-image (fa-image (list (fa-movz 0 43) (fa-add 0 0 1) (fa-sub 0 0 1) (fa-ret))))
    (let c4 (if (eq (fa-conviction bad-image ref-image) 0)
                (if (eq (fa-may-drop (fa-conviction bad-image ref-image) 1) 0) 16 0) 0))

    (add c0 (add c1 (add c2 (add c3 c4)))))
