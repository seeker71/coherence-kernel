; form-action-bmf-node-scope-rewrite.fk - rebuild binary-local-node-scope
; through BMF objects and executable Form recipe nodes.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/source-compiler.fk form-stdlib/engine.fk

(do
    (defn fa-ident (name)
        (form-action-bmf-value "ident"
            (list (fsc-action-src-name name))))

    (defn fa-int (value)
        (form-action-bmf-value "int"
            (list (fsc-action-src-int value))))

    (defn fa-string (value)
        (form-action-bmf-value "string"
            (list (fsc-action-src-string value))))

    (defn fa-call (name args)
        (form-action-bmf-value "call"
            (list
                (fsc-action-src-name name)
                (fsc-action-src-args args))))

    (defn fa-call1 (name a) (fa-call name (list a)))
    (defn fa-call2 (name a b) (fa-call name (list a b)))
    (defn fa-call4 (name a b c d) (fa-call name (list a b c d)))

    (defn fa-if (cond yes no)
        (form-action-bmf-value "if"
            (list
                (fsc-action-src-kw "if")
                (fsc-action-src-expr cond)
                (fsc-action-src-kw "then")
                (fsc-action-src-expr yes)
                (fsc-action-src-kw "else")
                (fsc-action-src-expr no))))

    (defn fa-let (name value)
        (form-action-bmf-value "let"
            (list
                (fsc-action-src-kw "let")
                (fsc-action-src-name name)
                (fsc-action-src-op "=")
                (fsc-action-src-expr value)
                (fsc-action-src-op ";"))))

    (let blueprint-base-name (fa-ident "blueprint-base"))
    (let local-blueprint-name (fa-ident "local-blueprint"))
    (let recipe-name (fa-ident "recipe"))
    (let recovered-blueprint-name (fa-ident "recovered-blueprint"))
    (let recovered-fields-name (fa-ident "recovered-fields"))

    (let blueprint-base-let
        (fa-let "blueprint-base"
            (fa-call4 "make_nodeid"
                (fa-int "1")
                (fa-int "2")
                (fa-int "99")
                (fa-int "2400"))))

    (let local-blueprint-let
        (fa-let "local-blueprint"
            (fa-call2 "intern_node"
                blueprint-base-name
                (fa-call2 "list"
                    (fa-call1 "intern_trivial_string" (fa-string "local-blueprint"))
                    (fa-call1 "intern_trivial_int" (fa-int "7"))))))

    (let recipe-let
        (fa-let "recipe"
            (fa-call2 "intern_node"
                local-blueprint-name
                (fa-call1 "list"
                    (fa-call1 "intern_trivial_int" (fa-int "11"))))))

    (let recovered-blueprint-let
        (fa-let "recovered-blueprint"
            (fa-call1 "node_category" recipe-name)))

    (let recovered-fields-let
        (fa-let "recovered-fields"
            (fa-call1 "node_children" recovered-blueprint-name)))

    (let final-expr
        (fa-if
            (fa-call2 "eq"
                (fa-call1 "len" recovered-fields-name)
                (fa-int "2"))
            (fa-call2 "add"
                (fa-int "600")
                (fa-call1 "node_value"
                    (fa-call1 "head"
                        (fa-call1 "tail" recovered-fields-name))))
            (fa-int "1")))

    (let do-source
        (list
            (fsc-action-src-kw "do")
            (fsc-action-src-items
                (list blueprint-base-let local-blueprint-let recipe-let recovered-blueprint-let recovered-fields-let final-expr))))
    (let do-rt
        (bmf-roundtrip
            (form-action-bmf-find-rule "do" (form-action-bmf-rules 0))
            do-source))
    (let program
        (bmf-object-value (bmf-roundtrip-first-object do-rt)))

    (add (walk_recipe program)
    (add (if (bmf-roundtrip-node-eq? do-rt) 100 0)
    (add (len (form-action-bmf-rules 0))
         (len (node_children program))))))
