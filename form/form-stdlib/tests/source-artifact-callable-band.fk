; source-artifact-callable-band.fk -- Layer 8g callable receipt witness.
;
; Expected: 2147483647
;
; This band proves structural callable receipt admission over a sealed and
; proven native dylib identity. It does not prove dlopen, dlsym, symbol
; resolution, dispatch, invoke/return, memory-envelope execution proof,
; source-map/deopt content proof, native execution, binary file hashing,
; compiler emission, cache writes, route ownership, selector installation,
; source-runner admission, or C seed growth.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/sha256.fk form/form-stdlib/hex.fk form/form-stdlib/hmac-sha256.fk form/form-stdlib/form-fs.fk form/form-stdlib/source-artifact-cache.fk form/form-stdlib/source-artifact-descriptor.fk form/form-stdlib/runtime-artifact-plan.fk form/form-stdlib/source-artifact-probe.fk form/form-stdlib/source-artifact-identity.fk form/form-stdlib/source-artifact-seal.fk form/form-stdlib/source-artifact-proof.fk form/form-stdlib/source-artifact-callable.fk

(do
    (defn saclb-score (ok bit) (if ok bit 0))
    (defn saclb-manifest-has (name)
        (source-artifact-callable-manifest-has? name (source-artifact-callable-manifest)))
    (defn saclb-key () (sai-string-bytes "seal-key"))
    (defn saclb-source-hash ()
        "sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    (defn saclb-fkb-hash ()
        "sha256:573dbb57d6af3d54263620b016da6212869e4aadb8a867ad9d78ba2b15cba1d1")
    (defn saclb-dylib-hash ()
        "sha256:6ca4c50d821f7f130312f82d37d2d8062256f9dcc0db409fd7323651167069b3")
    (defn saclb-dylib-seal ()
        "hmac-sha256:379bc7bcaaa870931e3f60218dfb64e5ad43e26236259141d222a46f7d9269c9")
    (defn saclb-source-vouch ()
        (sai-vouch-source-bytes "src/kernel.fk" (saclb-source-hash) (list 97 98 99)))
    (defn saclb-source-vouch-bad ()
        (sai-vouch-source-bytes "src/kernel.fk" "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" (list 97 98 99)))
    (defn saclb-dylib-vouch ()
        (sai-vouch-content-bytes "src/kernel.dylib" (saclb-dylib-hash) (sai-string-bytes "dylib")))
    (defn saclb-dylib-vouch-bad ()
        (sai-vouch-content-bytes "src/kernel.dylib" (saclb-fkb-hash) (sai-string-bytes "dylib")))
    (defn saclb-fkb-vouch ()
        (sai-vouch-content-bytes "src/kernel.fkb" (saclb-fkb-hash) (sai-string-bytes "fkb")))
    (defn saclb-seal-row ()
        (sas-native-dylib-seal "src/kernel.dylib" (saclb-source-vouch) (saclb-dylib-vouch) 1 (saclb-key) (saclb-dylib-seal)))
    (defn saclb-seal-bad ()
        (sas-native-dylib-seal "src/kernel.dylib" (saclb-source-vouch) (saclb-dylib-vouch) 1 (sai-string-bytes "other-key") (saclb-dylib-seal)))
    (defn saclb-seal-paired-to-other-hash ()
        (sas-seal-row (sad-kind-native-dylib)
                      (sad-version-native-dylib)
                      "src/kernel.dylib"
                      (sas-key-evidence-supplied-bytes)
                      (sai-status-match)
                      (sai-status-match)
                      "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
                      (saclb-dylib-hash)
                      (saclb-dylib-seal)
                      (saclb-dylib-seal)
                      (sas-status-match)
                      1))
    (defn saclb-proof-receipt ()
        (sapr-proof-receipt (sad-kind-native-dylib)
                            (sad-version-native-dylib)
                            "src/kernel.dylib"
                            (saclb-source-hash)
                            (saclb-dylib-hash)
                            (saclb-dylib-seal)
                            1
                            "lowering-parity"
                            "receipt-band"
                            "recipe-dylib-band:pass"
                            "recipe-dylib-band:pass"
                            1
                            1))
    (defn saclb-proof ()
        (sapr-admit-proof (saclb-proof-receipt) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row)))
    (defn saclb-receipt ()
        (sacl-callable-receipt (sad-kind-native-dylib)
                               (sad-version-native-dylib)
                               "src/kernel.dylib"
                               (saclb-source-hash)
                               (saclb-dylib-hash)
                               (saclb-dylib-seal)
                               1
                               (sapr-proof-message (saclb-proof))
                               "fk_entry"
                               "sysv"
                               2
                               "i64-i64"
                               "i64"
                               1
                               1
                               (sacl-memory-status-match)
                               1
                               1))
    (defn saclb-callable ()
        (sacl-admit-callable (saclb-receipt) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))

    (defn saclb-bit-manifest-1 ()
        (sum (list
            (saclb-score (eq (saclb-manifest-has "callable-receipt-validation") 1) 1)
            (saclb-score (eq (saclb-manifest-has "callable-is-receipt-not-dispatch") 1) 2)
            (saclb-score (eq (saclb-manifest-has "consumes-sai-vouch-status") 1) 4)
            (saclb-score (eq (saclb-manifest-has "consumes-sas-seal-status") 1) 8)
            (saclb-score (eq (saclb-manifest-has "consumes-sapr-proof-status") 1) 16)
            (saclb-score (eq (saclb-manifest-has "native-dylib-callable-only") 1) 32)
            (saclb-score (eq (saclb-manifest-has "callable-receipt-validated-sets-callable") 1) 64)
            (saclb-score (eq (saclb-manifest-has "seal-left-unchanged-by-callable") 1) 128)
            (saclb-score (eq (saclb-manifest-has "proof-left-unchanged-by-callable") 1) 256)
            (saclb-score (eq (saclb-manifest-has "lowerable-left-untouched") 1) 512)
            (saclb-score (eq (saclb-manifest-has "length-prefixed-callable-message-v1") 1) 1024)
            (saclb-score (eq (saclb-manifest-has "structural-not-signature") 1) 2048)
            (saclb-score (eq (saclb-manifest-has "no-native-execution") 1) 4096))))

    (defn saclb-bit-manifest-2 ()
        (sum (list
            (saclb-score (eq (saclb-manifest-has "no-symbol-resolution") 1) 8192)
            (saclb-score (eq (saclb-manifest-has "no-artifact-load") 1) 16384)
            (saclb-score (eq (saclb-manifest-has "no-runtime-selector") 1) 32768)
            (saclb-score (eq (saclb-manifest-has "no-compiler-emission") 1) 65536)
            (saclb-score (eq (saclb-manifest-has "no-cache-write") 1) 131072)
            (saclb-score (eq (saclb-manifest-has "no-sac-route-fork") 1) 262144)
            (saclb-score (eq (saclb-manifest-has "no-source-runner-admission-change") 1) 524288)
            (saclb-score (eq (saclb-manifest-has "no-binary-file-hash") 1) 1048576)
            (saclb-score (eq (saclb-manifest-has "read-file-bytes-not-checkout-witness") 1) 2097152)
            (saclb-score (eq (saclb-manifest-has "no-c-seed-growth") 1) 4194304)
            (saclb-score (eq (saclb-manifest-has "memory-envelope-status-declarative-only") 1) 8388608)
            (saclb-score (eq (saclb-manifest-has "source-map-presence-declarative-only") 1) 16777216))))

    (defn saclb-bit-message ()
        (do
            (let r (saclb-receipt))
            (let base (sacl-receipt-message r))
            (let c1 (sacl-callable-message-v1 "ab" "c" "p" "s" "h" "seal" 1 "proof" "sym" "sysv" 1 "call" "res" 1 1 "match" 1 1))
            (let c2 (sacl-callable-message-v1 "a" "bc" "p" "s" "h" "seal" 1 "proof" "sym" "sysv" 1 "call" "res" 1 1 "match" 1 1))
            (let sym (sacl-callable-message-v1 (sacl-receipt-kind r) (sacl-receipt-version r) (sacl-receipt-path r) (sacl-receipt-source-hash r) (sacl-receipt-content-hash r) (sacl-receipt-seal-value r) (sacl-receipt-artifact-bit r) (sacl-receipt-proof-message r) "other_entry" (sacl-receipt-abi-name r) (sacl-receipt-arity r) (sacl-receipt-calling-convention r) (sacl-receipt-result-convention r) (sacl-receipt-deopt-anchor-present r) (sacl-receipt-source-map-present r) (sacl-receipt-memory-envelope-status r) (sacl-receipt-min-witnesses r) (sacl-receipt-witness-count r)))
            (let proof (sacl-callable-message-v1 (sacl-receipt-kind r) (sacl-receipt-version r) (sacl-receipt-path r) (sacl-receipt-source-hash r) (sacl-receipt-content-hash r) (sacl-receipt-seal-value r) (sacl-receipt-artifact-bit r) "other-proof-message" (sacl-receipt-entry-symbol r) (sacl-receipt-abi-name r) (sacl-receipt-arity r) (sacl-receipt-calling-convention r) (sacl-receipt-result-convention r) (sacl-receipt-deopt-anchor-present r) (sacl-receipt-source-map-present r) (sacl-receipt-memory-envelope-status r) (sacl-receipt-min-witnesses r) (sacl-receipt-witness-count r)))
            (let abi (sacl-callable-message-v1 (sacl-receipt-kind r) (sacl-receipt-version r) (sacl-receipt-path r) (sacl-receipt-source-hash r) (sacl-receipt-content-hash r) (sacl-receipt-seal-value r) (sacl-receipt-artifact-bit r) (sacl-receipt-proof-message r) (sacl-receipt-entry-symbol r) "win64" (sacl-receipt-arity r) (sacl-receipt-calling-convention r) (sacl-receipt-result-convention r) (sacl-receipt-deopt-anchor-present r) (sacl-receipt-source-map-present r) (sacl-receipt-memory-envelope-status r) (sacl-receipt-min-witnesses r) (sacl-receipt-witness-count r)))
            (let arity (sacl-callable-message-v1 (sacl-receipt-kind r) (sacl-receipt-version r) (sacl-receipt-path r) (sacl-receipt-source-hash r) (sacl-receipt-content-hash r) (sacl-receipt-seal-value r) (sacl-receipt-artifact-bit r) (sacl-receipt-proof-message r) (sacl-receipt-entry-symbol r) (sacl-receipt-abi-name r) 3 (sacl-receipt-calling-convention r) (sacl-receipt-result-convention r) (sacl-receipt-deopt-anchor-present r) (sacl-receipt-source-map-present r) (sacl-receipt-memory-envelope-status r) (sacl-receipt-min-witnesses r) (sacl-receipt-witness-count r)))
            (let mem (sacl-callable-message-v1 (sacl-receipt-kind r) (sacl-receipt-version r) (sacl-receipt-path r) (sacl-receipt-source-hash r) (sacl-receipt-content-hash r) (sacl-receipt-seal-value r) (sacl-receipt-artifact-bit r) (sacl-receipt-proof-message r) (sacl-receipt-entry-symbol r) (sacl-receipt-abi-name r) (sacl-receipt-arity r) (sacl-receipt-calling-convention r) (sacl-receipt-result-convention r) (sacl-receipt-deopt-anchor-present r) (sacl-receipt-source-map-present r) (sacl-memory-status-declared) (sacl-receipt-min-witnesses r) (sacl-receipt-witness-count r)))
            (let cnt (sacl-callable-message-v1 (sacl-receipt-kind r) (sacl-receipt-version r) (sacl-receipt-path r) (sacl-receipt-source-hash r) (sacl-receipt-content-hash r) (sacl-receipt-seal-value r) (sacl-receipt-artifact-bit r) (sacl-receipt-proof-message r) (sacl-receipt-entry-symbol r) (sacl-receipt-abi-name r) (sacl-receipt-arity r) (sacl-receipt-calling-convention r) (sacl-receipt-result-convention r) (sacl-receipt-deopt-anchor-present r) (sacl-receipt-source-map-present r) (sacl-receipt-memory-envelope-status r) (sacl-receipt-min-witnesses r) 2))
            (saclb-score
                (and (str_eq (substring base 0 7) "7:sacl-")
                     (and (not (str_eq c1 c2))
                          (and (not (str_eq base sym))
                               (and (not (str_eq base proof))
                                    (and (not (str_eq base abi))
                                         (and (not (str_eq base arity))
                                              (and (not (str_eq base mem))
                                                   (not (str_eq base cnt)))))))))
                33554432)))

    (defn saclb-bit-match ()
        (do
            (let c (saclb-callable))
            (saclb-score
                (and (str_eq (sacl-callable-status c) (sacl-status-match))
                     (and (eq (sacl-callable-ok-bit c) 1)
                          (eq (sacl-known-abi? "aarch64-darwin") 1)))
                67108864)))

    (defn saclb-bit-negatives ()
        (do
            (let unsealed (sacl-admit-callable (saclb-receipt) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-bad) (saclb-proof)))
            (let unvouched-source (sacl-admit-callable (saclb-receipt) (saclb-source-vouch-bad) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))
            (let unvouched-content (sacl-admit-callable (saclb-receipt) (saclb-source-vouch) (saclb-dylib-vouch-bad) (saclb-seal-row) (saclb-proof)))
            (let unproven (sacl-admit-callable (saclb-receipt) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row)
                (sapr-admit-proof (sapr-proof-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saclb-source-hash) (saclb-dylib-hash) (saclb-dylib-seal) 1 "lowering-parity" "receipt-band" "expected" "actual" 1 1) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row))))
            (let malformed (sacl-admit-callable
                (sacl-callable-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" "sha256:ABC" (saclb-dylib-hash) (saclb-dylib-seal) 1 (sapr-proof-message (saclb-proof)) "fk_entry" "sysv" 2 "i64-i64" "i64" 1 1 (sacl-memory-status-match) 1 1)
                (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))
            (let bad-abi (sacl-admit-callable
                (sacl-callable-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saclb-source-hash) (saclb-dylib-hash) (saclb-dylib-seal) 1 (sapr-proof-message (saclb-proof)) "fk_entry" "unknown-abi" 2 "i64-i64" "i64" 1 1 (sacl-memory-status-match) 1 1)
                (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))
            (let insufficient (sacl-admit-callable
                (sacl-callable-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saclb-source-hash) (saclb-dylib-hash) (saclb-dylib-seal) 1 (sapr-proof-message (saclb-proof)) "fk_entry" "sysv" 2 "i64-i64" "i64" 1 1 (sacl-memory-status-match) 2 1)
                (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))
            (let hash-pair (sacl-admit-callable (saclb-receipt) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-paired-to-other-hash) (saclb-proof)))
            (let wrong-proof (sacl-admit-callable
                (sacl-callable-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saclb-source-hash) (saclb-dylib-hash) (saclb-dylib-seal) 1 "other-proof-message" "fk_entry" "sysv" 2 "i64-i64" "i64" 1 1 (sacl-memory-status-match) 1 1)
                (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))
            (let mem-bad (sacl-admit-callable
                (sacl-callable-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saclb-source-hash) (saclb-dylib-hash) (saclb-dylib-seal) 1 (sapr-proof-message (saclb-proof)) "fk_entry" "sysv" 2 "i64-i64" "i64" 1 1 (sacl-memory-status-declared) 1 1)
                (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof)))
            (let refused (sacl-admit-callable
                (sacl-callable-receipt (sad-kind-program-image-fkb) (sad-version-program-image-fkb) "src/kernel.fkb" (saclb-source-hash) (saclb-fkb-hash) (saclb-dylib-seal) 1 (sapr-proof-message (saclb-proof)) "fk_entry" "sysv" 2 "i64-i64" "i64" 1 1 (sacl-memory-status-match) 1 1)
                (saclb-source-vouch) (saclb-fkb-vouch) (saclb-seal-row) (saclb-proof)))
            (saclb-score
                (and (str_eq (sacl-callable-status unsealed) (sacl-status-unsealed))
                     (and (str_eq (sacl-callable-status unvouched-source) (sacl-status-unvouched))
                          (and (str_eq (sacl-callable-status unvouched-content) (sacl-status-unvouched))
                               (and (str_eq (sacl-callable-status unproven) (sacl-status-unproven))
                                    (and (str_eq (sacl-callable-status malformed) (sacl-status-malformed))
                                         (and (str_eq (sacl-callable-status bad-abi) (sacl-status-malformed))
                                              (and (str_eq (sacl-callable-status insufficient) (sacl-status-insufficient-witness))
                                                   (and (str_eq (sacl-callable-status hash-pair) (sacl-status-mismatch))
                                                        (and (str_eq (sacl-callable-status wrong-proof) (sacl-status-mismatch))
                                                             (and (str_eq (sacl-callable-status mem-bad) (sacl-status-mismatch))
                                                                  (str_eq (sacl-callable-status refused) (sacl-status-role-refused))))))))))))
                134217728)))

    (defn saclb-bit-enrichment ()
        (do
            (let ok (saclb-callable))
            (let bad (sacl-admit-callable (saclb-receipt) (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-bad) (saclb-proof)))
            (let obs-ok (sacl-native-dylib-observation-from-callable "src/kernel.dylib" 1 5 102 (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof) ok 1))
            (let obs-bad (sacl-native-dylib-observation-from-callable "src/kernel.dylib" 1 5 102 (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-bad) (saclb-proof) bad 1))
            (saclb-score
                (and (eq (sap-observation-seal-ok obs-ok) 1)
                     (and (eq (sap-observation-proof obs-ok) 1)
                          (and (eq (sap-observation-callable obs-ok) 1)
                               (and (eq (sap-observation-lowerable obs-ok) 1)
                                    (eq (sap-observation-callable obs-bad) 0)))))
                268435456)))

    (defn saclb-bit-proof-not-callable ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (saclb-source-hash)))
            (let fkb (sap-program-image-fkb-observation "src/kernel.fkb" 1 3 101 (saclb-source-hash) (saclb-fkb-hash) 1 1))
            (let proof-only (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof) 0 1))
            (let p (sap-plan-from-probe (sap-bundle source fkb proof-only)))
            (saclb-score
                (and (eq (sap-observation-proof proof-only) 1)
                     (and (eq (sap-observation-callable proof-only) 0)
                          (str_eq (rap-plan-primary p) (rap-act-run-program-image))))
                536870912)))

    (defn saclb-bit-native-route ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (saclb-source-hash)))
            (let fkb-current (sap-program-image-fkb-observation "src/kernel.fkb" 1 3 101 (saclb-source-hash) (saclb-fkb-hash) 1 1))
            (let fkb-stale (sap-program-image-fkb-observation "src/kernel.fkb" 1 3 99 (saclb-source-hash) (saclb-fkb-hash) 1 1))
            (let native (sacl-native-dylib-observation-from-callable "src/kernel.dylib" 1 5 102 (saclb-source-vouch) (saclb-dylib-vouch) (saclb-seal-row) (saclb-proof) (saclb-callable) 1))
            (let p-current (sap-plan-from-probe (sap-bundle source fkb-current native)))
            (let p-stale (sap-plan-from-probe (sap-bundle source fkb-stale native)))
            (saclb-score
                (and (str_eq (rap-plan-primary p-current) (rap-act-run-native))
                     (str_eq (rap-plan-primary p-stale) (rap-act-compile-source)))
                1073741824)))

    (defn source-artifact-callable-band ()
        (sum (list
            (saclb-bit-manifest-1)
            (saclb-bit-manifest-2)
            (saclb-bit-message)
            (saclb-bit-match)
            (saclb-bit-negatives)
            (saclb-bit-enrichment)
            (saclb-bit-proof-not-callable)
            (saclb-bit-native-route))))

    (source-artifact-callable-band))
