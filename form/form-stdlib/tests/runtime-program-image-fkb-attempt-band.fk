    (defn rpifab-witness ()
        (pifbf-file-witness-from-container (rpifab-container)))
    (defn rpifab-real-admission ()
        (pifbd-admit-witness (rpifab-witness)))
    (defn rpifab-payload-for-pif (pif)
        (pifbd-payload (pif-envelope-source-path pif)
                       (pif-envelope-source-hash pif)
                       (pif-envelope-source-mtime pif)
                       (pif-envelope-artifact-path pif)
                       (pif-envelope-seal-ok pif)
                       (pif-envelope-table pif)
                       (pif-envelope-symbol-image pif)))
    (defn rpifab-decode-for-pif (pif)
        (pifbd-decoded-row (rpifab-payload-for-pif pif) 123))
    (defn rpifab-admission-for-pif (pif)
        (pifbd-admission (list "runtime-program-image-fkb-synthetic-admission")
                         (rpifab-decode-for-pif pif)
                         pif
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpifab-admission ()
        (rpifab-admission-for-pif (rpifab-pif)))
    (defn rpifab-non-admitted-admission ()
        (pifbd-investigate-row (list "runtime-program-image-fkb-non-admitted")
                               (rpifab-decode-for-pif (rpifab-pif))
                               (rpifab-pif)
                               (pifbd-reason-non-ready-witness)))
    (defn rpifab-refused-admission ()
