                                                        (rpifab-run (rao-obs-ok) 42 257 0)))
            (rpifa-bridge-reason (rpifa-bridge-from-run (rpifab-envelope) (rpifab-admission)
                                                        (list "runtime-program-image-fkb-supplied-run" 1)))
            (rpifa-bridge-reason (rpifa-bridge-from-run (rpifab-envelope) (rpifab-admission)
                                                        (rpifab-run-negative-output)))
            (rpifa-bridge-reason (rpifa-bridge-from-run (rpifab-envelope) (rpifab-admission)
                                                        (rpifab-run-path-other)))
            (rpifa-bridge-reason (rpifab-bridge (rao-obs-ok) 42 0 0))))
    (defn rpifab-bit-reason-coverage ()
        (do
            (let coverage (rcov-coverage (rpifa-reason-manifest)
                                         (rpifab-observed-reasons)))
            (rpifab-score (rcov-covered? coverage) 67108864)))
    (defn rpifab-bit-static-mirror ()
        (do
            (let text (rpifab-read-file-any "form/form-stdlib/runtime-program-image-fkb-attempt.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-attempt.fk"))
            (let grammar (rpifab-read-file-any "grammars/runtime-program-image-fkb-attempt.fk"
                                               "../grammars/runtime-program-image-fkb-attempt.fk"))
            (rpifab-score
                (and (str_eq text grammar)
                (and (not (rpifab-has? text ".payload"))
                (and (not (rpifab-has? text "runtime-table-payload"))
                (and (not (rpifab-has? text "rtta-"))
                (and (not (rpifab-has? text "pite-"))
                (and (not (rpifab-has? text "program-image-table-payload-emit"))
                (and (not (rpifab-has? text "read_file"))
                (and (not (rpifab-has? text "fs-"))
                (and (not (rpifab-has? text "write_form_binary"))
                (and (not (rpifab-has? text "read_form_binary"))
                (and (not (rpifab-has? text "recipe_to_bytes"))
                (and (not (rpifab-has? text "bytes_to_recipe"))
                (and (not (rpifab-has? text "form-eval"))
                (and (not (rpifab-has? text "fk_run"))
                (and (not (rpifab-has? text "dlopen"))
                (and (not (rpifab-has? text "bp_table"))
                (and (not (rpifab-has? text "bpTable"))
                     (not (rpifab-has? text "BP_TABLE")))))))))))))))))))
                134217728)))
    (defn rpifab-bit-architecture-receipt ()
        (do
            (let arch (rpifab-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rpifab-read-file-any "../receipts/2026-07-04-runtime-program-image-fkb-attempt-layer-review.md"
                                              "receipts/2026-07-04-runtime-program-image-fkb-attempt-layer-review.md"))
            (rpifab-score
                (and (rpifab-has? arch "9h1. Runtime program-image `.fkb` attempt adapter")
                (and (rpifab-has? arch "supplied program-image run")
                (and (rpifab-has? receipt "PASS_WITH_CHANGES")
                (and (rpifab-has? receipt "What does the band prove?")
                     (rpifab-has? receipt "C-seed growth")))))
                268435456)))
    (defn rpifab-bit-current-floor-honesty ()
        (do
            (let arch (rpifab-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (rpifab-score
                (and (rpifab-has? arch "current-floor")
                (and (rpifab-has? arch "supplied-attempt adapter")
                     (rpifab-has? arch "not load success")))
                536870912)))
    (defn rpifab-bit-no-laundering ()
        (do
            (let b (rpifab-bridge (rao-obs-ok) 42 257 0))
            (let r (rpifab-receipt-from-bridge b))
            (rpifab-score
                (and (rpifab-has? (raar-receipt-detail r) (rpifa-marker))
                (and (not (rpifab-has? (raar-receipt-detail r) "table-payload-witness"))
                     (not (rpifab-has? (raar-receipt-detail r) "native-dylib"))))
                1073741824)))

    (defn runtime-program-image-fkb-attempt-band ()
        (do
            (let _setup (rpifab-setup))
            (let total
                (sum (list
                    (rpifab-bit-manifest-1)
                    (rpifab-bit-manifest-2)
                    (rpifab-bit-version)
                    (rpifab-bit-real-admission-ready)
                    (rpifab-bit-valid-bridge-ready)
                    (rpifab-bit-attempt-tuple-matches-envelope)
                    (rpifab-bit-9f-9c-ok-complete)
                    (rpifab-bit-marker-survives)
                    (rpifab-bit-oom-zero-output)
                    (rpifab-bit-killed-zero-output)
                    (rpifab-bit-stalled-zero-output)
                    (rpifab-bit-timeout-zero-output)
                    (rpifab-bit-wrong-value-zero-output)
                    (rpifab-bit-unknown-zero-output)
                    (rpifab-bit-loader-missing-zero-output)
                    (rpifab-bit-error-zero-output)
                    (rpifab-bit-ok-empty-output)
                    (rpifab-bit-run-path-mismatch)
                    (rpifab-bit-envelope-kind)
                    (rpifab-bit-pif-identity-mismatch)
                    (rpifab-bit-malformed-admission)
                    (rpifab-bit-non-admitted-admission)
                    (rpifab-bit-invalid-pif-admission)
                    (rpifab-bit-nondecoded-admission)
                    (rpifab-bit-decode-pif-mismatch)
                    (rpifab-bit-malformed-run-negative-output)
                    (rpifab-bit-reason-coverage)
                    (rpifab-bit-static-mirror)
                    (rpifab-bit-architecture-receipt)
                    (rpifab-bit-current-floor-honesty)
                    (rpifab-bit-no-laundering))))
            (let _cleanup (rpifab-cleanup))
            total))

    (runtime-program-image-fkb-attempt-band))
