        (rpifa-supplied-run (rpifab-ready-path) 42 (sub 0 1) 1 (rao-obs-error) "negative-output"))
    (defn rpifab-bridge-with (admission status first outputs code)
        (rpifa-bridge-from-run (rpifab-envelope) admission (rpifab-run status first outputs code)))
    (defn rpifab-bridge (status first outputs code)
        (rpifab-bridge-with (rpifab-admission) status first outputs code))
    (defn rpifab-ready? (b) (str_eq (rpifa-bridge-status b) (rpifa-status-attempt-ready)))
    (defn rpifab-investigate? (b) (str_eq (rpifa-bridge-status b) (rpifa-status-investigate)))
    (defn rpifab-refused? (b) (str_eq (rpifa-bridge-status b) (rpifa-status-refused)))
    (defn rpifab-reason? (b reason) (str_eq (rpifa-bridge-reason b) reason))
    (defn rpifab-no-attempt? (b) (rpifa-no-attempt? (rpifa-bridge-attempt b)))
    (defn rpifab-receipt-from-bridge (b)
