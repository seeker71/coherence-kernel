; preludes: form-stdlib/satsang-room-memory.fk
;
; satsang-room-memory-band — explicit local room memory, no hidden capture.
;
; Verdict 255:
;   1   explicit Send is the valid capture boundary
;   2   hidden capture is rejected
;   4   local JSON file is a valid storage carrier
;   8   remote silent storage is rejected
;   16  transcript voice-id/speaker-label is a valid continuity carrier
;   32  mic-exclusive biometric speaker-id carriers are rejected
;   64  the same speaker profile matches only under explicit boundary
;   128 prior sessions + speakers make later context ready
(do
    (defn satsang-room-memory-band ()
        (do
    (let rec (srm-receipt "explicit-send" "local-json-file" "transcript-voice-id-or-speaker-label" 0 1 2 1))
    (let c0 (if (eq (srm-capture-boundary? "explicit-send") 1) 1 0))
    (let c1 (if (eq (srm-trust-ok? "explicit-send" "local-json-file" "transcript-voice-id-or-speaker-label" 1 1) 0) 2 0))
    (let c2 (if (eq (srm-storage-carrier? "local-json-file") 1) 4 0))
    (let c3 (if (eq (srm-storage-carrier? "remote-silent-store") 0) 8 0))
    (let c4 (if (eq (srm-voice-match-carrier? "transcript-voice-id-or-speaker-label") 1) 16 0))
    (let c5 (if (and (and (eq (srm-mic-exclusive-carrier? "macos-biometric-voice-id") 1)
                          (eq (srm-voice-match-carrier? "macos-biometric-voice-id") 0))
                     (eq (srm-voice-match-carrier? "voiceprint") 0)) 32 0))
    (let c6 (if (and (eq (srm-speaker-match? "speaker-a" "speaker-a" "explicit-send") 1)
                     (eq (srm-speaker-match? "speaker-a" "speaker-a" "hidden-capture") 0)) 64 0))
    (let c7 (if (eq (srm-rec-ready? rec) 1) 128 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (satsang-room-memory-band))
