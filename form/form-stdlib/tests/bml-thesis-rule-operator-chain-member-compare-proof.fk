; tests/bml-thesis-rule-operator-chain-member-compare-proof.fk
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves chained member comparison in original container-Rule.bml:
; if ( m_hArgs.Count != hOther.Args.Count ) return false;

(do
    (defn bool-score (b bit)
        (if b bit 0))

    (defn int-score (actual expected bit)
        (if (eq actual expected) bit 0))

    (defn str-score (actual expected bit)
        (if (str_eq actual expected) bit 0))

    (let path "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/container-Rule.bml")
    (let parsed (bml-source-file-parse-declarations path))
    (let model (bml-source-declaration-model parsed))
    (let rule-class (bml-model-find-class model "Rule"))
    (let operator-method
        (bml-find-method
            (bml-class-own-methods rule-class)
            "operator=="))
    (let operator-body (bml-method-body operator-method))

    (let ChainRuleBP (make_nodeid 1 2 99 9300))
    (let ChainArgsBP (make_nodeid 1 2 99 9301))
    (let ProcessBP (make_nodeid 1 2 99 9302))
    (let ChainCallEnvBP (bml-constructor-env-blueprint 0))
    (let shared-process (record_new ProcessBP "bmlClass" "Process"))
    (let left-args (record_new ChainArgsBP "Count" 1))
    (let right-args (record_new ChainArgsBP "Count" 2))
    (let rule-instance
        (record_new
            ChainRuleBP
            "bmlClass" "Rule"
            "m_strName" "same-name"
            "m_hProcess" shared-process
            "m_hArgs" left-args))
    (let other-rule
        (record_new
            ChainRuleBP
            "bmlClass" "Rule"
            "Name" "same-name"
            "InternProcess" shared-process
            "Args" right-args))
    (let direct-env (record_new ChainCallEnvBP "hObj" other-rule "hOther" other-rule))
    (let direct-result
        (bml-body-source-exec-if-chain-member-neq-return-false
            operator-body
            rule-instance
            direct-env))

    (let sequence-env (record_new ChainCallEnvBP "hObj" other-rule))
    (let sequence-result
        (bml-body-source-exec
            operator-body
            rule-instance
            sequence-env))

    (defn rule-eq-dispatch (self hObj)
        (bml-body-source-exec
            operator-body
            self
            (record_new ChainCallEnvBP "hObj" hObj)))

    (method_define ChainRuleBP "operator==" rule-eq-dispatch)
    (let method-result (method_invoke rule-instance "operator==" other-rule))

    (sum
        (list
            (bool-score (bml-source-exec-parse-ok? parsed) 1)
            (str-score (bml-method-name operator-method) "operator==" 2)
            (bool-score (bml-body-source-contains? operator-body "m_hArgs") 4)
            (bool-score (bml-body-source-contains? operator-body "Args") 8)
            (int-score
                (bml-body-source-if-chain-member-neq-return-false-count operator-body)
                1
                16)
            (int-score (record_get left-args "Count") 1 32)
            (int-score (record_get right-args "Count") 2 64)
            (bool-score (not direct-result) 128)
            (bool-score (record_has sequence-env "hOther") 256)
            (bool-score (not sequence-result) 512)
            (bool-score (not method-result) 1024)
            (bool-score (bml-body-source-instanceof? other-rule "Rule") 2048))))
