; runtime-program-image-fkb-symbol-observation-band.fk -- Layer 9h8 computed observation proof.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-executor-capability.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/program-image-symbol-entry.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-program-image-fkb-micro-walker.fk form-stdlib/runtime-program-image-fkb-symbol-walk.fk form-stdlib/runtime-program-image-fkb-symbol-capability-bound.fk form-stdlib/runtime-program-image-fkb-symbol-observation.fk
;
; Expected: 262143

(do
    (defn rpswob-score (ok bit) (if ok bit 0))
    (defn rpswob-manifest-has (name)
        (runtime-program-image-fkb-symbol-observation-manifest-has? name
            (runtime-program-image-fkb-symbol-observation-manifest)))
    (defn rpswob-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rpswob-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))
    (defn rpswob-none-of? (text needles)
        (if (nil? needles)
            1
            (if (rpswob-has? text (head needles))
                0
                (rpswob-none-of? text (tail needles)))))

    (defn rpswob-source-hash () "sha:src-symbol-observation")
    (defn rpswob-content-hash () "sha:content-symbol-observation")
    (defn rpswob-artifact-path () "cache/symbol-observation.fkb")
    (defn rpswob-other-artifact-path () "cache/other-symbol-observation.fkb")

    (defn rpswob-nodes ()
        (list
            (pif-node-row 1 42 0 0)
            (pif-node-row 1 40 0 0)
            (pif-node-row 1 2 0 0)
            (pif-node-row 3 1 2 0)
            (pif-node-row 99 0 0 0)
            (pif-node-row 3 0 99 0)))
    (defn rpswob-roots () (list 0 3 4 5))
    (defn rpswob-table ()
        (pif-table-image (len (rpswob-roots))
                         (rpswob-roots)
                         (len (rpswob-nodes))
                         (rpswob-nodes)
                         0
                         (empty)))
    (defn rpswob-symbol-rows ()
        (list (pif-symbol-row 0 "core/lit42")
              (pif-symbol-row 1 "core/add42")
              (pif-symbol-row 2 "core/bad-tag")
              (pif-symbol-row 3 "core/bad-child")))
    (defn rpswob-node-symbol-rows ()
        (list
            (pif-node-symbol-row 0 0 (empty))
            (pif-node-symbol-row 3 1 (empty))
            (pif-node-symbol-row 4 2 (empty))
            (pif-node-symbol-row 5 3 (empty))))
    (defn rpswob-symbol-image ()
        (pif-symbol-image 4 (rpswob-symbol-rows) 4 (rpswob-node-symbol-rows)))
    (defn rpswob-pif-with (artifact-path content-hash seal-ok)
        (pif-envelope-with-symbols "src/symbol-observation.fk" (rpswob-source-hash) 100
                                   artifact-path content-hash 101
                                   seal-ok (rpswob-table) (rpswob-symbol-image)))
    (defn rpswob-pif ()
        (rpswob-pif-with (rpswob-artifact-path) (rpswob-content-hash) 1))
    (defn rpswob-other-pif ()
        (rpswob-pif-with (rpswob-other-artifact-path) "sha:other-symbol-observation" 1))

    (defn rpswob-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rpswob-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rpswob-envelope-for-pif (pif)
        (do
            (let src (rpswob-source-for-pif pif))
            (let fkb (rpswob-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rpswob-envelope () (rpswob-envelope-for-pif (rpswob-pif)))
    (defn rpswob-other-envelope () (rpswob-envelope-for-pif (rpswob-other-pif)))
    (defn rpswob-envelope-with-selection (selection reason)
        (rale-envelope (rpswob-source-for-pif (rpswob-pif))
                       (rpswob-fkb-for-pif (rpswob-pif))
                       (rap-act-run-program-image)
                       (sac-run-fkb)
                       (sad-kind-program-image-fkb)
                       (rpswob-artifact-path)
                       (rpswob-source-hash)
                       (rpswob-content-hash)
                       selection
                       (rale-no-retry)
                       (rale-no-compile-output)
                       (rale-status-request-ready)
                       reason))
    (defn rpswob-malformed-selection-envelope ()
        (rpswob-envelope-with-selection (list "bad-selection") "malformed-selection-fixture"))
    (defn rpswob-action-mismatch-selection ()
        (ras-selection (sac-run-fkb)
                       "different-action"
                       (rao-action-none)
                       (ras-status-selected)
                       1
                       1
                       "selected-action-mismatch-fixture"))
    (defn rpswob-action-mismatch-envelope ()
        (rpswob-envelope-with-selection (rpswob-action-mismatch-selection)
                                        "action-mismatch-selection-fixture"))
    (defn rpswob-investigate-selection-envelope ()
        (rpswob-envelope-with-selection
            (ras-selection (sac-run-fkb)
                           (rap-act-run-program-image)
                           (rao-action-none)
                           (ras-status-investigate)
                           1
                           1
                           "selector-investigates-fixture")
            "selector-investigates-fixture"))

    (defn rpswob-payload-for-pif (pif)
        (pifbd-payload (pif-envelope-source-path pif)
                       (pif-envelope-source-hash pif)
                       (pif-envelope-source-mtime pif)
                       (pif-envelope-artifact-path pif)
                       (pif-envelope-seal-ok pif)
                       (pif-envelope-table pif)
                       (pif-envelope-symbol-image pif)))
    (defn rpswob-decode-for-pif (pif)
        (pifbd-decoded-row (rpswob-payload-for-pif pif) 123))
    (defn rpswob-admission-for-pif (pif)
        (pifbd-admission (list "runtime-program-image-fkb-symbol-observation-synthetic-admission")
                         (rpswob-decode-for-pif pif)
                         pif
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpswob-admission () (rpswob-admission-for-pif (rpswob-pif)))

    (defn rpswob-cap-for-envelope (e availability evidence authority freshness detail)
        (raec-capability (raec-cap-program-image-walker)
                         (rale-envelope-action e)
                         (rale-envelope-route e)
                         (rale-envelope-artifact-kind e)
                         availability evidence authority freshness detail))
    (defn rpswob-ready-cap-for (e)
        (rpswob-cap-for-envelope e
                                 (raec-availability-available)
                                 (raec-evidence-supplied-current)
                                 (raec-authority-attempt-supplier)
                                 (raec-freshness-current)
                                 "supplied-current-program-image-walker"))
    (defn rpswob-readiness-for (e)
        (raec-readiness-from-envelope-capability e (rpswob-ready-cap-for e)))
    (defn rpswob-readiness () (rpswob-readiness-for (rpswob-envelope)))
    (defn rpswob-no-capability-readiness ()
        (raec-readiness-from-envelope-no-capability (rpswob-envelope)))

    (defn rpswob-adapt-key (key budget input)
        (rpswo-adapt (rpswob-envelope)
                     (rpswob-readiness)
                     (rpswob-admission)
                     (pise-request-by-canonical-key key)
                     budget
                     input))
    (defn rpswob-good () (rpswob-adapt-key "core/lit42" 10 0))
    (defn rpswob-timeout () (rpswob-adapt-key "core/add42" 2 0))
    (defn rpswob-unsupported () (rpswob-adapt-key "core/bad-tag" 10 0))
    (defn rpswob-missing () (rpswob-adapt-key "core/missing" 10 0))
    (defn rpswob-with-readiness (readiness)
        (rpswo-adapt (rpswob-envelope) readiness (rpswob-admission)
                     (pise-request-by-canonical-key "core/lit42") 10 0))
    (defn rpswob-with-envelope (e)
        (rpswo-adapt e (rpswob-readiness-for e) (rpswob-admission)
                     (pise-request-by-canonical-key "core/lit42") 10 0))

    (defn rpswob-bit-manifest-core ()
        (rpswob-score
            (and (eq (rpswob-manifest-has "layer-9h8-computed-symbol-trace-observation") 1)
            (and (eq (rpswob-manifest-has "single-public-adapt-entry-recomputes-9h7") 1)
            (and (eq (rpswob-manifest-has "no-supplied-rpswc-row-authority") 1)
            (and (eq (rpswob-manifest-has "no-independent-trace-input") 1)
            (and (eq (rpswob-manifest-has "no-supplied-observation-or-outcome-authority") 1)
                 (eq (rpswob-manifest-has "selection-derived-from-envelope-only") 1))))))
            1))
    (defn rpswob-bit-manifest-safety ()
        (rpswob-score
            (and (eq (rpswob-manifest-has "observation-detail-marks-synthetic-computed-trace") 1)
            (and (eq (rpswob-manifest-has "selection-action-match-required-before-outcome") 1)
            (and (eq (rpswob-manifest-has "trace-stop-reason-coherence-required") 1)
            (and (eq (rpswob-manifest-has "hard-trace-statuses-investigate-through-9c") 1)
            (and (eq (rpswob-manifest-has "non-bound-9h7-produces-no-observation-or-outcome") 1)
            (and (eq (rpswob-manifest-has "no-9f-supplied-attempt-production") 1)
            (and (eq (rpswob-manifest-has "no-9h1-9h2-9h3-9h4-consumption") 1)
            (and (eq (rpswob-manifest-has "no-table-text-authority") 1)
            (and (eq (rpswob-manifest-has "no-symbol-lens-authority") 1)
            (and (eq (rpswob-manifest-has "no-artifact-io-or-selector-mutation") 1)
            (and (eq (rpswob-manifest-has "no-generated-table-authority") 1)
                 (eq (rpswob-manifest-has "no-c-seed-growth") 1))))))))))))
            2))
    (defn rpswob-bit-version ()
        (rpswob-score (str_eq (rpswo-version) "runtime-program-image-fkb-symbol-observation-v1") 4))
    (defn rpswob-bit-happy-complete ()
        (do
            (let row (rpswob-good))
            (rpswob-score
                (and (rpswo-row? row)
                (and (rpswc-join? (rpswo-row-9h7-bind row))
                (and (str_eq (rpswc-join-status (rpswo-row-9h7-bind row)) (rpswc-status-bound))
                (and (rao-run-observation? (rpswo-row-observation row))
                (and (rao-outcome? (rpswo-row-outcome row))
                (and (str_eq (rpswo-row-status row) (rao-status-complete))
                (and (str_eq (rpswo-row-reason row) (rao-reason-observation-ok))
                     (eq (rpiwt-trace-first-value (rpswc-join-bound-trace (rpswo-row-9h7-bind row))) 42))))))))
                8)))
    (defn rpswob-bit-synthetic-detail ()
        (do
            (let row (rpswob-good))
            (rpswob-score
                (and (rpswob-has? (rao-observation-detail (rpswo-row-observation row))
                                  "synthetic-computed-trace-observation")
                     (rpswob-has? (rao-observation-detail (rpswo-row-observation row))
                                  (rpiwt-trace-detail (rpswc-join-bound-trace (rpswo-row-9h7-bind row)))))
                16)))
    (defn rpswob-bit-selection-derived ()
        (do
            (let row (rpswob-good))
            (let selection (rale-envelope-selection (rpswob-envelope)))
            (rpswob-score
                (and (str_eq (rao-observation-action (rpswo-row-observation row))
                             (rale-envelope-action (rpswob-envelope)))
                (and (str_eq (rao-observation-action (rpswo-row-observation row))
                             (ras-selection-selected selection))
                     (eq (rao-outcome-route (rpswo-row-outcome row))
                         (ras-selection-route selection))))
                32)))
    (defn rpswob-bit-timeout-hard-investigates ()
        (do
            (let row (rpswob-timeout))
            (let trace (rpswc-join-bound-trace (rpswo-row-9h7-bind row)))
            (rpswob-score
                (and (str_eq (rpiwt-trace-status trace) (rao-obs-timeout))
                (and (str_eq (rpiwt-trace-stop-reason trace) (rpiwt-stop-timeout))
                (and (str_eq (rao-observation-status (rpswo-row-observation row)) (rao-obs-timeout))
                (and (str_eq (rpswo-row-status row) (rao-status-investigate))
                     (str_eq (rpswo-row-reason row) (rao-reason-hard-observation-investigates))))))
                64)))
    (defn rpswob-bit-error-not-normalized ()
        (do
            (let row (rpswob-unsupported))
            (rpswob-score
                (and (str_eq (rao-observation-status (rpswo-row-observation row)) (rao-obs-error))
                (and (not (str_eq (rpswo-row-status row) (rao-status-complete)))
                     (not (str_eq (rpswo-row-reason row) (rao-reason-observation-ok)))))
                128)))
    (defn rpswob-bit-symbol-refusal-no-observation ()
        (do
            (let row (rpswob-missing))
            (rpswob-score
                (and (str_eq (rpswo-row-status row) (rpsw-status-refused))
                (and (str_eq (rpswo-row-reason row) (pise-reason-canonical-key-not-found))
                (and (rpswo-no-derived-observation? (rpswo-row-observation row))
                     (rpswo-no-derived-outcome? (rpswo-row-outcome row)))))
                256)))
    (defn rpswob-bit-unavailable-no-observation ()
        (do
            (let row (rpswob-with-readiness (rpswob-no-capability-readiness)))
            (rpswob-score
                (and (str_eq (rpswo-row-status row) (rpswc-status-unavailable))
                (and (str_eq (rpswo-row-reason row) (raec-reason-no-capability-supplied))
                (and (rpswo-no-derived-observation? (rpswo-row-observation row))
                     (rpswo-no-derived-outcome? (rpswo-row-outcome row)))))
                512)))
    (defn rpswob-bit-malformed-selection ()
        (do
            (let row (rpswob-with-envelope (rpswob-malformed-selection-envelope)))
            (rpswob-score
                (and (rao-run-observation? (rpswo-row-observation row))
                (and (rpswo-no-derived-outcome? (rpswo-row-outcome row))
                (and (str_eq (rpswo-row-status row) (rpswo-status-refused))
                     (str_eq (rpswo-row-reason row) (rao-reason-malformed-selection)))))
                1024)))
    (defn rpswob-bit-action-mismatch-no-outcome ()
        (do
            (let row (rpswob-with-envelope (rpswob-action-mismatch-envelope)))
            (rpswob-score
                (and (rao-run-observation? (rpswo-row-observation row))
                (and (rpswo-no-derived-outcome? (rpswo-row-outcome row))
                (and (str_eq (rpswo-row-status row) (rpswo-status-investigate))
                     (str_eq (rpswo-row-reason row) (rao-reason-observation-action-mismatch)))))
                2048)))
    (defn rpswob-bit-selector-investigate-no-outcome ()
        (do
            (let row (rpswob-with-envelope (rpswob-investigate-selection-envelope)))
            (rpswob-score
                (and (rao-run-observation? (rpswo-row-observation row))
                (and (rpswo-no-derived-outcome? (rpswo-row-outcome row))
                (and (str_eq (rpswo-row-status row) (rpswo-status-investigate))
                     (str_eq (rpswo-row-reason row) (rao-reason-selector-investigate)))))
                4096)))
    (defn rpswob-forbidden-needles ()
        (list "raar-" "rpifa-" "rpifc-" "rpiftc-" "rpiwt-bridge"
              "rtta-" ".tbl" ".sym" "rpmw-walk-entry" "rpsw-walk-symbol"
              "rpswo-adapt-from" "rpswo-from-bound" "rpswo-from-trace"
              "rpswo-from-observation" "rpswo-from-outcome"
              "(defn rpswo-terminal" "(defn rpswo-observed"
              "(defn rpswo-bind-row" "(defn rpswo-success"
              "read_file" "read_file_slice" "write_file" "append_file"
              "remove_file" "fk_run" "form-eval" "dlopen"
              "bp_table" "bpTable" "BP_TABLE" "runtime/fkwu-uni.c"))
    (defn rpswob-bit-static-source ()
        (do
            (let text (rpswob-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"))
            (rpswob-score (rpswob-none-of? text (rpswob-forbidden-needles)) 8192)))
    (defn rpswob-bit-mirror ()
        (do
            (let text (rpswob-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"))
            (let grammar (rpswob-read-file-any "grammars/runtime-program-image-fkb-symbol-observation.fk"
                                               "../grammars/runtime-program-image-fkb-symbol-observation.fk"))
            (rpswob-score (str_eq text grammar) 16384)))
    (defn rpswob-bit-architecture-receipt ()
        (do
            (let arch (rpswob-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                            "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rpswob-read-file-any "../receipts/2026-07-04-runtime-program-image-fkb-symbol-observation-layer-review.md"
                                               "receipts/2026-07-04-runtime-program-image-fkb-symbol-observation-layer-review.md"))
            (rpswob-score
                (and (rpswob-has? arch "9h8. Runtime program-image `.fkb` symbol observation adapter")
                (and (rpswob-has? receipt "Layer: 9h8")
                (and (rpswob-has? receipt "recomputes `rpswc-bind`")
                     (rpswob-has? receipt "no supplied observation or outcome authority"))))
                32768)))
    (defn rpswob-bit-single-entry-shape ()
        (do
            (let text (rpswob-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"))
            (rpswob-score
                (and (rpswob-has? text "(defn rpswo-adapt ")
                (and (rpswob-has? text "(let bind (rpswc-bind")
                (and (rpswob-has? text "(let observation")
                (and (rpswob-has? text "(let outcome (rao-outcome-from-selection-observation selection observation)")
                (and (not (rpswob-has? text "(defn rpswo-adapt-from"))
                (and (not (rpswob-has? text "(defn rpswo-terminal"))
                     (not (rpswob-has? text "(defn rpswo-observed"))))))))
                65536)))
    (defn rpswob-bit-forged-input-absence ()
        (do
            (let text (rpswob-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"
                                            "../form/form-stdlib/runtime-program-image-fkb-symbol-observation.fk"))
            (rpswob-score
                (and (rpswob-has? text "(defn rpswo-adapt (envelope readiness admission symbol-request step-budget input-value)")
                (and (not (rpswob-has? text "(defn rpswo-adapt-from-rpswc"))
                (and (not (rpswob-has? text "(defn rpswo-adapt-from-trace"))
                (and (not (rpswob-has? text "(defn rpswo-adapt-from-observation"))
                     (not (rpswob-has? text "(defn rpswo-adapt-from-outcome"))))))
                131072)))

    (defn runtime-program-image-fkb-symbol-observation-band ()
        (sum (list
            (rpswob-bit-manifest-core)
            (rpswob-bit-manifest-safety)
            (rpswob-bit-version)
            (rpswob-bit-happy-complete)
            (rpswob-bit-synthetic-detail)
            (rpswob-bit-selection-derived)
            (rpswob-bit-timeout-hard-investigates)
            (rpswob-bit-error-not-normalized)
            (rpswob-bit-symbol-refusal-no-observation)
            (rpswob-bit-unavailable-no-observation)
            (rpswob-bit-malformed-selection)
            (rpswob-bit-action-mismatch-no-outcome)
            (rpswob-bit-selector-investigate-no-outcome)
            (rpswob-bit-static-source)
            (rpswob-bit-mirror)
            (rpswob-bit-architecture-receipt)
            (rpswob-bit-single-entry-shape)
            (rpswob-bit-forged-input-absence))))

    (runtime-program-image-fkb-symbol-observation-band))
