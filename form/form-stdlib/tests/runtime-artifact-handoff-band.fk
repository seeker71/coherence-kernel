                (and (eq (rap-plan-route p) (sac-run-fkb))
                (and (eq (ras-selection-route s) (rap-plan-route p))
                (and (eq (rale-envelope-route e) (ras-selection-route s))
                     (str_eq (rale-envelope-action e) (ras-selection-selected s)))))
                134217728)))
    (defn rahb-bit-expected-kind-helper ()
        (rahb-score
            (and (str_eq (rah-expected-kind-for-route (sac-run-fkb)) (sad-kind-program-image-fkb))
            (and (str_eq (rah-expected-kind-for-route (sac-run-dylib)) (sad-kind-native-dylib))
                 (str_eq (rah-expected-kind-for-route (sac-run-source-compile)) (rale-kind-none))))
            268435456))
    (defn rahb-bit-static-boundary ()
        (do
            (let text (rahb-read-file-any "form/form-stdlib/runtime-artifact-handoff.fk"
                                          "../form/form-stdlib/runtime-artifact-handoff.fk"))
            (rahb-score
                (not (rahb-any-has? text
                    (list "write_form_binary"
                          "read_form_binary"
                          "recipe_to_bytes"
                          "bytes_to_recipe"
                          "dlopen"
                          "dlsym"
                          "fopen"
                          "fwrite"
                          "read_file_slice"
                          "sha256"
                          "fk_run"
                          "rao-run-observation"
                          "rtta-bridge-from-run")))
                536870912)))
    (defn rahb-bit-mirror ()
        (do
            (let text (rahb-read-file-any "form/form-stdlib/runtime-artifact-handoff.fk"
                                          "../form/form-stdlib/runtime-artifact-handoff.fk"))
            (rahb-score
                (str_eq text (rahb-read-file-any "grammars/runtime-artifact-handoff.fk"
                                                 "../grammars/runtime-artifact-handoff.fk"))
                1073741824)))

    (defn runtime-artifact-handoff-band ()
        (sum (list
            (rahb-bit-manifest-1)
            (rahb-bit-manifest-2)
            (rahb-bit-reason-manifest)
            (rahb-bit-ready-fkb)
            (rahb-bit-ready-dylib)
            (rahb-bit-fkb-request-fields)
            (rahb-bit-dylib-request-fields)
            (rahb-bit-accessors)
            (rahb-bit-malformed-persistence)
            (rahb-bit-non-ready-persistence)
            (rahb-bit-non-ready-before-triple)
            (rahb-bit-malformed-descriptor-triple)
            (rahb-bit-descriptor-route-not-artifact)
            (rahb-bit-selection-investigates)
            (rahb-bit-selection-refused)
            (rahb-bit-envelope-investigates)
            (rahb-bit-envelope-refused-malformed)
            (rahb-bit-envelope-refused-status)
            (rahb-bit-envelope-route-action-mismatch)
            (rahb-bit-envelope-kind-mismatch)
            (rahb-bit-reason-coverage)
            (rahb-bit-reason-missing)
            (rahb-bit-helper-classifies-selection-route)
            (rahb-bit-request-ready-not-load-success)
            (rahb-bit-helper-present)
            (rahb-bit-triple-preserved-fkb)
            (rahb-bit-triple-preserved-dylib)
            (rahb-bit-composition-fkb)
            (rahb-bit-expected-kind-helper)
            (rahb-bit-static-boundary)
            (rahb-bit-mirror))))

    (runtime-artifact-handoff-band))
