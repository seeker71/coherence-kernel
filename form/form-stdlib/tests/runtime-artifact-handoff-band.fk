    (defn rahb-read-file-any (primary fallback)
        (if (ge (file_size primary) 0)
            (read_file primary)
            (read_file fallback)))
    (defn rahb-any-has? (text needles)
        (if (nil? needles)
            0
            (if (rahb-has? text (head needles))
                1
                (rahb-any-has? text (tail needles)))))

