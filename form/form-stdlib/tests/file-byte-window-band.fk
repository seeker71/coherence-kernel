; file-byte-window-band.fk -- bounded byte-window witness for current fkwu.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk
;
; Expected: 2147483647

(do
    (defn fbwb-score (ok bit) (if ok bit 0))
    (defn fbwb-manifest-has (name)
        (file-byte-window-manifest-has? name (file-byte-window-manifest)))

    (defn fbwb-repeat-byte-loop (b n acc)
        (if (le n 0)
            acc
            (fbwb-repeat-byte-loop b (sub n 1) (cons b acc))))
    (defn fbwb-repeat-byte (b n)
        (fbwb-repeat-byte-loop b n (list)))

    (defn fbwb-temp-root ()
        (fs-path-join (fs-temp-dir) "file-byte-window-band"))
    (defn fbwb-ascii-path ()
        (fs-path-join (fbwb-temp-root) "ascii.bin"))
    (defn fbwb-binary-path ()
        (fs-path-join (fbwb-temp-root) "binary.bin"))
    (defn fbwb-big-path ()
        (fs-path-join (fbwb-temp-root) "big.bin"))
    (defn fbwb-missing-path ()
        (fs-path-join (fbwb-temp-root) "missing.bin"))

    (defn fbwb-setup ()
        (do
            (let root (fbwb-temp-root))
            (let _pre_ascii_file (fs-remove-file (fbwb-ascii-path)))
            (let _pre_binary_file (fs-remove-file (fbwb-binary-path)))
            (let _pre_big_file (fs-remove-file (fbwb-big-path)))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let _clear_ascii_file (fs-remove-file (fbwb-ascii-path)))
            (let _clear_binary_file (fs-remove-file (fbwb-binary-path)))
            (let _clear_big_file (fs-remove-file (fbwb-big-path)))
            (let _wa (fs-write-text (fbwb-ascii-path) "abZ9"))
            (let _wb (fs-append-bytes (fbwb-binary-path) (list 0 65 10 127 66)))
            (let _wg (fs-append-bytes (fbwb-big-path) (fbwb-repeat-byte 65 (fbw-max-window))))
            0))
    (defn fbwb-cleanup ()
        (do
            (let _ascii_file (fs-remove-file (fbwb-ascii-path)))
            (let _binary_file (fs-remove-file (fbwb-binary-path)))
            (let _big_file (fs-remove-file (fbwb-big-path)))
            (fs-remove-tree (fbwb-temp-root))))

    (defn fbwb-bit-manifest-1 ()
        (sum (list
            (fbwb-score (eq (fbwb-manifest-has "bounded-read-file-slice") 1) 1)
            (fbwb-score (eq (fbwb-manifest-has "form-str-byte-at-decode") 1) 2)
            (fbwb-score (eq (fbwb-manifest-has "nul-ascii-slice-byte-indexed") 1) 4)
            (fbwb-score (eq (fbwb-manifest-has "max-window-4096") 1) 8)
            (fbwb-score (eq (fbwb-manifest-has "byte-at-one-byte-window") 1) 16)
            (fbwb-score (eq (fbwb-manifest-has "window-byte-at-for-cursors") 1) 32)
            (fbwb-score (eq (fbwb-manifest-has "status-vocabulary") 1) 64)
            (fbwb-score (eq (fbwb-manifest-has "too-large-refusal") 1) 128)
            (fbwb-score (eq (fbwb-manifest-has "no-file-byte-at") 1) 256)
            (fbwb-score (eq (fbwb-manifest-has "no-read-file-bytes") 1) 512)
            (fbwb-score (eq (fbwb-manifest-has "no-write-file-bytes") 1) 1024)
            (fbwb-score (eq (fbwb-manifest-has "no-whole-file-materialization") 1) 2048)
            (fbwb-score (eq (fbwb-manifest-has "no-hash-seal-load-selector") 1) 4096)
            (fbwb-score (eq (fbwb-manifest-has "no-c-seed-growth") 1) 8192)
            (fbwb-score (eq (fbwb-manifest-has "no-policy-gate") 1) 16384))))

    (defn fbwb-bit-ascii-ready ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 0 4))
            (fbwb-score
                (and (fbw-window? w)
                     (and (str_eq (fbw-window-status w) (fbw-status-ready))
                          (and (eq (fbw-window-observed-len w) 4)
                               (and (str_eq (fbw-window-slice w) "abZ9")
                                    (str_eq (fbw-window-evidence-route w) (fbw-evidence-route))))))
                32768)))
    (defn fbwb-bit-ascii-bytes ()
        (do
            (let bs (fbw-window-bytes (fbw-read-window (fbwb-ascii-path) 0 4)))
            (fbwb-score
                (and (eq (len bs) 4)
                     (and (eq (nth bs 0) 97)
                     (and (eq (nth bs 1) 98)
                     (and (eq (nth bs 2) 90)
                          (eq (nth bs 3) 57)))))
                65536)))
    (defn fbwb-bit-window-byte-at ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 0 4))
            (fbwb-score
                (and (eq (fbw-window-byte-at w 2) 90)
                     (and (eq (fbw-window-byte-at w 4) (sub 0 1))
                          (eq (fbw-window-byte-at w (sub 0 1)) (sub 0 1))))
                131072)))
    (defn fbwb-bit-byte-at-path ()
        (fbwb-score
            (and (eq (fbw-byte-at (fbwb-ascii-path) 2) 90)
                 (and (eq (fbw-byte-at (fbwb-ascii-path) 4) (sub 0 1))
                      (eq (fbw-byte-at (fbwb-missing-path) 0) (sub 0 1))))
            262144))
    (defn fbwb-bit-short ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 2 4))
            (let bs (fbw-window-bytes w))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-short))
                     (and (eq (fbw-window-observed-len w) 2)
                     (and (str_eq (fbw-window-slice w) "Z9")
                     (and (eq (nth bs 0) 90)
                          (eq (nth bs 1) 57)))))
                524288)))
    (defn fbwb-bit-out-of-range ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 4 1))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-out-of-range))
                     (eq (fbw-window-observed-len w) 0))
                1048576)))
    (defn fbwb-bit-missing ()
        (do
            (let w (fbw-read-window (fbwb-missing-path) 0 1))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-missing))
                     (eq (fbw-window-observed-len w) 0))
                2097152)))
    (defn fbwb-bit-empty ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 0 0))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-empty))
                     (eq (fbw-window-observed-len w) 0))
                4194304)))
    (defn fbwb-bit-malformed-offset ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) (sub 0 1) 1))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-malformed))
                     (eq (fbw-window-observed-len w) 0))
                8388608)))
    (defn fbwb-bit-malformed-len ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 0 (sub 0 1)))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-malformed))
                     (eq (fbw-window-observed-len w) 0))
                16777216)))
    (defn fbwb-bit-too-large ()
        (do
            (let w (fbw-read-window (fbwb-ascii-path) 0 (add (fbw-max-window) 1)))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-too-large))
                     (and (eq (fbw-window-observed-len w) 0)
                          (str_eq (fbw-window-slice w) "")))
                33554432)))
    (defn fbwb-bit-max-boundary ()
        (do
            (let w (fbw-read-window (fbwb-big-path) 0 (fbw-max-window)))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-ready))
                     (and (eq (fbw-window-observed-len w) (fbw-max-window))
                     (and (eq (fbw-window-byte-at w 0) 65)
                          (eq (fbw-window-byte-at w (sub (fbw-max-window) 1)) 65))))
                67108864)))
    (defn fbwb-bit-nul-ascii-transparent ()
        (do
            (let w (fbw-read-window (fbwb-binary-path) 0 5))
            (let bs (fbw-window-bytes w))
            (fbwb-score
                (and (str_eq (fbw-window-status w) (fbw-status-ready))
                     (and (eq (fbw-window-observed-len w) 5)
                     (and (eq (nth bs 0) 0)
                     (and (eq (nth bs 1) 65)
                     (and (eq (nth bs 2) 10)
                     (and (eq (nth bs 3) 127)
                          (eq (nth bs 4) 66)))))))
                134217728)))
    (defn fbwb-bit-byte-list-carrier-deferred ()
        (fbwb-score
            (and (eq (fbwb-manifest-has "no-read-file-bytes") 1)
                 (eq (fbwb-manifest-has "no-write-file-bytes") 1))
            268435456))
    (defn fbwb-text-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn fbwb-module-text ()
        (if (ge (file_size "form/form-stdlib/file-byte-window.fk") 0)
            (read_file "form/form-stdlib/file-byte-window.fk")
            (if (ge (file_size "form-stdlib/file-byte-window.fk") 0)
                (read_file "form-stdlib/file-byte-window.fk")
                "")))
    (defn fbwb-bit-module-route-scan ()
        (do
            (let text (fbwb-module-text))
            (fbwb-score
                (and (fbwb-text-has? text "read_file_slice")
                (and (fbwb-text-has? text "str-byte-at")
                (and (not (fbwb-text-has? text "file_byte_at"))
                (and (not (fbwb-text-has? text "read_file_bytes"))
                (and (not (fbwb-text-has? text "write_file_bytes"))
                (and (not (fbwb-text-has? text "fs-byte-at"))
                (and (not (fbwb-text-has? text "fs-read-bytes"))
                     (not (fbwb-text-has? text "fs-write-bytes")))))))))
                536870912)))
    (defn fbwb-bit-no-size-probe ()
        (do
            (let text (fbwb-module-text))
            (fbwb-score
                (and (not (fbwb-text-has? text "fs-stat-size"))
                     (not (fbwb-text-has? text "file_size")))
                1073741824)))

    (defn file-byte-window-band ()
        (do
            (let _setup (fbwb-setup))
            (let score (sum (list
                (fbwb-bit-manifest-1)
                (fbwb-bit-ascii-ready)
                (fbwb-bit-ascii-bytes)
                (fbwb-bit-window-byte-at)
                (fbwb-bit-byte-at-path)
                (fbwb-bit-short)
                (fbwb-bit-out-of-range)
                (fbwb-bit-missing)
                (fbwb-bit-empty)
                (fbwb-bit-malformed-offset)
                (fbwb-bit-malformed-len)
                (fbwb-bit-too-large)
                (fbwb-bit-max-boundary)
                (fbwb-bit-nul-ascii-transparent)
                (fbwb-bit-byte-list-carrier-deferred)
                (fbwb-bit-module-route-scan)
                (fbwb-bit-no-size-probe))))
            (let _cleanup (fbwb-cleanup))
            score))

    (file-byte-window-band))
