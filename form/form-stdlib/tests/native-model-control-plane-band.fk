; native-model-control-plane-band.fk — registry, exact daily measures,
; resource-bounded schedule, and replay-resistant promotion semantics.
;
; preludes: form-stdlib/core.fk form-stdlib/native-model-control-plane.fk

(do
    ; Real SHA-256 spellings of named fixtures.  The hashes are data, not labels:
    ; each field must be exactly 64 lowercase hexadecimal bytes.
    (let split-a "3d63d708682fd24eea80fc133e0a2b8bff9fe27bde501ad3f955bfdb6453c7aa")
    (let split-b "a17b45dfc60af4084940bde8671afbb2fcc18cd8a51af686c7105e406a350314")
    (let split-c "2a99dbb390402a687491cbc443744bd268cc0b0c1f0a69de104a2aaa93ee5051")
    (let split-d "d7052c372819cafeb8356065ffcf63f4b01030b8771e220631c241ac55c89ba6")
    (let candidate-artifact "0701c0eea5d81bbe9237c2cd20731e0beda291613c420fc1829d187bbc0bee9e")
    (let incumbent-artifact "1a80f9d7eb971b4ab2fd9a8d9fe3dd19605d0db299a1a89dfc20987eb1fb80df")
    (let other-artifact "2b66f183a9d4f8525bbed6e2ae42542f24ac8ca5a669d615c90f287812894d56")
    (let data-v1 "115bb4dea4ccce7c27e93cf17a5f3729b09f6e4799ad2ab86ba150ff5b7ce90c")
    (let evaluator-v1 "89950b1529501c9fb0f9dc3720b09015bfcd2313e1c77da3e0f4b06ec99e8157")
    (let evaluator-v2 "54b79fa214da506420e6124fb1dfaf15ce402bbc577d513d940bfdbd236d51ad")
    (let snapshot-digest "8faa3af9075cc74c901941e66b52b4499d0021833074d4a948898181629eb812")

    (let registry (nmcp-registry))
    (let c1 (if (eq (nmcp-models-valid? registry) 1) 1 0))
    (let c2 (if (eq (nmcp-unique? registry) 1) 2 0))
    (let c3 (if
        (and (eq (len registry) 32)
             (and (eq (nmcp-count-class registry "policy-fixture") 6)
                  (and (eq (nmcp-count-class registry "remote-oracle") 3)
                       (and (eq (nmcp-id-in? "prototype.neural-lm-bigram" registry) 1)
                            (and (eq (nmcp-id-in? "prototype.perception-pipeline" registry) 1)
                                 (and (eq (nmcp-id-in? "oracle.agent-remote" registry) 1)
                                      (and (gt (nmcp-count-class registry "form-native") 0)
                                           (and (gt (nmcp-count-class registry "local-finetuned") 0)
                                                (and (gt (nmcp-count-class registry "local-native") 0)
                                                     (gt (nmcp-count-class registry "local-oracle") 0))))))))))
        4 0))
    (let fresh-count (nmcp-fresh-count registry 20260715))
    (let c4 (if (and (gt fresh-count 0) (lt fresh-count (len registry))) 8 0))

    ; Canonical SHA validation rejects uppercase, punctuation, and wrong length.
    ; A prompt/model name still cannot impersonate a proved adapter.
    (let prompt-only (nmcp-model "prompt" "general" "text" "local-finetuned" "shadow"
        "observed" "local-process" "ollama" "prompt-model" "" "" "probe" "f1"
        0 0 0 1 "prove adapter" 20260715 7 1 1 1 0))
    (let uppercase "3D63D708682FD24EEA80FC133E0A2B8BFF9FE27BDE501AD3F955BFDB6453C7AA")
    (let nonhex "zd63d708682fd24eea80fc133e0a2b8bff9fe27bde501ad3f955bfdb6453c7aa")
    (let c5 (if (and (eq (nmcp-sha256? split-a) 1)
                     (and (eq (nmcp-sha256? uppercase) 0)
                          (and (eq (nmcp-sha256? nonhex) 0)
                               (and (eq (nmcp-sha256? "abcd") 0)
                                    (eq (nmcp-finetune-proven? prompt-only) 0))))) 16 0))
    (let proven-lf (nth registry 14))
    (let bad-duplicate (cons (head registry) registry))
    (let placeholder-authority (nmcp-model "borrowed" "general" "text" "local-native"
        "champion" "observed" "local-process" "ollama" "borrowed:latest"
        "placeholder" "placeholder" "probe" "f1" 0 1 1 1 "hash it" 20260715 7 0 0 1 1))
    (let c6 (if (and (eq (nmcp-finetune-proven? proven-lf) 1)
                     (and (eq (nmcp-authority? proven-lf) 0)
                          (and (eq (nmcp-unique? bad-duplicate) 0)
                               (eq (nmcp-model-valid? placeholder-authority) 0)))) 32 0))

    ; A valid evaluation has positive samples, nonnegative latency, and four
    ; canonical digest fields.
    (let cday (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-a 16 500000 800000 900 0 candidate-artifact data-v1 evaluator-v1 1))
    (let iday (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-a 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let bad-sha (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        uppercase 16 500000 800000 900 0 candidate-artifact data-v1 evaluator-v1 1))
    (let bad-latency (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-a 16 500000 800000 -1 0 candidate-artifact data-v1 evaluator-v1 1))
    (let no-samples (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-a 0 500000 800000 0 0 candidate-artifact data-v1 evaluator-v1 1))
    (let bad-artifact-sha (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-a 16 500000 800000 900 0 nonhex data-v1 evaluator-v1 1))
    (let bad-data-sha (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-a 16 500000 800000 900 0 candidate-artifact "abcd" evaluator-v1 1))
    (let bad-evaluator-sha (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-a 16 500000 800000 900 0 candidate-artifact data-v1 uppercase 1))
    (let c7 (if (and (eq (nmcp-eval-clean? cday) 1)
                     (and (eq (nmcp-eval-valid? bad-sha) 0)
                          (and (eq (nmcp-eval-valid? bad-latency) 0)
                               (and (eq (nmcp-eval-valid? no-samples) 0)
                                    (and (eq (nmcp-eval-valid? bad-artifact-sha) 0)
                                         (and (eq (nmcp-eval-valid? bad-data-sha) 0)
                                              (eq (nmcp-eval-valid? bad-evaluator-sha) 0))))))) 64 0))

    ; A one-day tie may enter canary but can never gain authority.
    (let c8 (if (and (eq (nmcp-canary? (list cday) (list iday) 16 10000 1000) 1)
                     (eq (nmcp-promote? (list cday) (list iday) 20260715 16 10000 1000) 0))
                128 0))

    ; Three paired, strictly increasing days use one immutable data/evaluator
    ; and artifact per model, but a distinct sealed split each day.
    (let c1d (nmcp-eval "candidate" "translation" "local-finetuned" 20260713
        split-a 16 520000 820001 900 0 candidate-artifact data-v1 evaluator-v1 1))
    (let c2d (nmcp-eval "candidate" "translation" "local-finetuned" 20260714
        split-b 16 530000 830001 850 0 candidate-artifact data-v1 evaluator-v1 1))
    (let c3d (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-c 16 540000 840001 820 0 candidate-artifact data-v1 evaluator-v1 1))
    (let i1d (nmcp-eval "incumbent" "translation" "local-native" 20260713
        split-a 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let i2d (nmcp-eval "incumbent" "translation" "local-native" 20260714
        split-b 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let i3d (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-c 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let challengers (list c1d c2d c3d))
    (let incumbents (list i1d i2d i3d))
    (let c9 (if (eq (nmcp-promote? challengers incumbents 20260715 32 10000 1000) 1) 256 0))

    ; Promotion is bound to today and a compact fourteen-day window.
    (let old-c1 (nmcp-eval "candidate" "translation" "local-finetuned" 20260630
        split-a 16 520000 820001 900 0 candidate-artifact data-v1 evaluator-v1 1))
    (let old-i1 (nmcp-eval "incumbent" "translation" "local-native" 20260630
        split-a 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let c10 (if (and
                    (eq (nmcp-promote? challengers incumbents 20260716 32 10000 1000) 0)
                    (eq (nmcp-promote? (list old-c1 c2d c3d) (list old-i1 i2d i3d)
                                       20260715 32 10000 1000) 0))
                 512 0))

    ; Duplicate/reordered days and split reuse are all replay, not evidence.
    (let cdup (nmcp-eval "candidate" "translation" "local-finetuned" 20260714
        split-c 16 540000 840001 820 0 candidate-artifact data-v1 evaluator-v1 1))
    (let idup (nmcp-eval "incumbent" "translation" "local-native" 20260714
        split-c 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let creuse (nmcp-eval "candidate" "translation" "local-finetuned" 20260714
        split-a 16 530000 830001 850 0 candidate-artifact data-v1 evaluator-v1 1))
    (let ireuse (nmcp-eval "incumbent" "translation" "local-native" 20260714
        split-a 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let c11 (if (and
                    (eq (nmcp-promote? (list c1d c3d c2d) (list i1d i3d i2d)
                                       20260714 32 10000 1000) 0)
                    (and
                        (eq (nmcp-promote? (list c1d c2d cdup) (list i1d i2d idup)
                                           20260714 32 10000 1000) 0)
                        (eq (nmcp-promote? (list c1d creuse c3d) (list i1d ireuse i3d)
                                           20260715 32 10000 1000) 0)))
                 1024 0))

    ; Dataset/evaluator/artifact/model stability and pair alignment are roots
    ; of trust, not report decoration.
    (let data-drift (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-c 16 540000 840001 820 0 candidate-artifact split-d evaluator-v1 1))
    (let i-data-drift (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-c 16 500000 800000 700 0 incumbent-artifact split-d evaluator-v1 1))
    (let eval-drift (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-c 16 540000 840001 820 0 candidate-artifact data-v1 evaluator-v2 1))
    (let i-eval-drift (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-c 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v2 1))
    (let artifact-drift (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-c 16 540000 840001 820 0 other-artifact data-v1 evaluator-v1 1))
    (let i-artifact-drift (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-c 16 500000 800000 700 0 other-artifact data-v1 evaluator-v1 1))
    (let model-drift (nmcp-eval "other-candidate" "translation" "local-finetuned" 20260715
        split-c 16 540000 840001 820 0 candidate-artifact data-v1 evaluator-v1 1))
    (let class-drift (nmcp-eval "candidate" "translation" "form-native" 20260715
        split-c 16 540000 840001 820 0 candidate-artifact data-v1 evaluator-v1 1))
    (let pair-split-drift (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-d 16 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let pair-sample-drift (nmcp-eval "incumbent" "translation" "local-native" 20260715
        split-c 15 500000 800000 700 0 incumbent-artifact data-v1 evaluator-v1 1))
    (let reject-data-drift
        (eq (nmcp-promote? (list c1d c2d data-drift) (list i1d i2d i-data-drift)
                           20260715 32 10000 1000) 0))
    (let reject-eval-drift
        (eq (nmcp-promote? (list c1d c2d eval-drift) (list i1d i2d i-eval-drift)
                           20260715 32 10000 1000) 0))
    (let reject-artifact-drift
        (and (eq (nmcp-promote? (list c1d c2d artifact-drift) incumbents
                                20260715 32 10000 1000) 0)
             (eq (nmcp-promote? challengers (list i1d i2d i-artifact-drift)
                                20260715 32 10000 1000) 0)))
    (let reject-identity-drift
        (and (eq (nmcp-promote? (list c1d c2d model-drift) incumbents
                                20260715 32 10000 1000) 0)
             (eq (nmcp-promote? (list c1d c2d class-drift) incumbents
                                20260715 32 10000 1000) 0)))
    (let reject-pair-drift
        (and (eq (nmcp-promote? challengers (list i1d i2d pair-split-drift)
                                20260715 32 10000 1000) 0)
             (eq (nmcp-promote? challengers (list i1d i2d pair-sample-drift)
                                20260715 32 10000 1000) 0)))
    (let c12 (if (and reject-data-drift
                      (and reject-eval-drift
                           (and reject-artifact-drift
                                (and reject-identity-drift reject-pair-drift))))
                 2048 0))

    ; Equality at the requested effect is not decisive: every pair and the
    ; weighted aggregate must be strictly above the margin.
    (let edge-c1 (nmcp-eval "candidate" "translation" "local-finetuned" 20260713
        split-a 16 510000 810000 900 0 candidate-artifact data-v1 evaluator-v1 1))
    (let edge-c2 (nmcp-eval "candidate" "translation" "local-finetuned" 20260714
        split-b 16 510000 810000 850 0 candidate-artifact data-v1 evaluator-v1 1))
    (let edge-c3 (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-c 16 510000 810000 820 0 candidate-artifact data-v1 evaluator-v1 1))
    (let weak-c1 (nmcp-eval "candidate" "translation" "local-finetuned" 20260713
        split-a 16 505000 805000 900 0 candidate-artifact data-v1 evaluator-v1 1))
    (let strong-c2 (nmcp-eval "candidate" "translation" "local-finetuned" 20260714
        split-b 16 550000 850000 850 0 candidate-artifact data-v1 evaluator-v1 1))
    (let strong-c3 (nmcp-eval "candidate" "translation" "local-finetuned" 20260715
        split-c 16 550000 850000 820 0 candidate-artifact data-v1 evaluator-v1 1))
    (let c13 (if (and
                    (eq (nmcp-promote? (list edge-c1 edge-c2 edge-c3) incumbents
                                       20260715 32 10000 1000) 0)
                    (eq (nmcp-promote? (list weak-c1 strong-c2 strong-c3) incumbents
                                       20260715 32 10000 1000) 0))
                 4096 0))

    ; Snapshots validate canonical identity and close the independently counted
    ; final/teacher aggregates exactly.
    (let yesterday (nmcp-snapshot 20260714 1 28 28 2 2 1 2 3 9 9 2 2 1205 136 snapshot-digest))
    (let today (nmcp-snapshot 20260715 1 28 28 3 4 1 1 1 99 99 2 2 1205 136 snapshot-digest))
    (let bad-snapshot-digest (nmcp-snapshot 20260715 1 28 28 3 4 1 1 1 99 99 2 2 1205 136 uppercase))
    (let bad-snapshot-negative (nmcp-snapshot 20260715 1 28 28 3 4 1 1 -1 99 99 2 2 1205 136 snapshot-digest))
    (let bad-snapshot-fresh (nmcp-snapshot 20260715 1 28 29 3 4 1 1 1 99 99 2 2 1205 136 snapshot-digest))
    (let bad-snapshot-eval (nmcp-snapshot 20260715 1 28 28 3 4 1 1 1 99 99 3 2 1205 136 snapshot-digest))
    (let bad-snapshot-clean-bit (nmcp-snapshot 20260715 2 28 28 3 4 1 1 1 99 99 2 2 10 11 snapshot-digest))
    (let c14 (if (and (eq (nmcp-snapshot-valid? today) 1)
                     (and (eq (nmcp-snapshot-aggregates-exact? today 10 198) 1)
                          (and (eq (nmcp-snapshot-aggregates-exact? today 11 198) 0)
                               (and (eq (nmcp-snapshot-valid? bad-snapshot-digest) 0)
                                    (and (eq (nmcp-snapshot-valid? bad-snapshot-negative) 0)
                                         (and (eq (nmcp-snapshot-valid? bad-snapshot-fresh) 0)
                                              (and (eq (nmcp-snapshot-valid? bad-snapshot-eval) 0)
                                                   (eq (nmcp-snapshot-valid? bad-snapshot-clean-bit) 0)))))))) 8192 0))

    ; Teacher calls stay out of route share; ratios and deltas are exact PPM.
    (let c15 (if (and (eq (nmcp-owned-share-ppm today) 700000)
                     (and (eq (nmcp-on-device-share-ppm today) 900000)
                          (and (eq (nmcp-owned-delta-ppm today yesterday) 300000)
                               (eq (nmcp-day-eval-pass-ppm today) 1000000)))) 16384 0))

    ; The schedule carries its own runtime/storage bounds.  Component proof can
    ; run without training data/consent; weight training needs every membrane.
    (let tue (nmcp-job-for-day (nmcp-weekly-schedule) 2))
    (let thu (nmcp-job-for-day (nmcp-weekly-schedule) 4))
    (let fri (nmcp-job-for-day (nmcp-weekly-schedule) 5))
    (let sat (nmcp-job-for-day (nmcp-weekly-schedule) 6))
    (let sun (nmcp-job-for-day (nmcp-weekly-schedule) 7))
    (let training-ready (eq (nmcp-training-ready? tue 64 1 1 1 1 1 1 1 1 16) 1))
    (let training-gates
        (and (eq (nmcp-training-ready? tue 63 1 1 1 1 1 1 1 1 16) 0)
             (and (eq (nmcp-training-ready? tue 64 0 1 1 1 1 1 1 1 16) 0)
                  (and (eq (nmcp-training-ready? tue 64 1 0 1 1 1 1 1 1 16) 0)
                       (and (eq (nmcp-training-ready? tue 64 1 1 0 1 1 1 1 1 16) 0)
                            (and (eq (nmcp-training-ready? tue 64 1 1 1 0 1 1 1 1 16) 0)
                                 (and (eq (nmcp-training-ready? tue 64 1 1 1 1 0 1 1 1 16) 0)
                                      (and (eq (nmcp-training-ready? tue 64 1 1 1 1 1 0 1 1 16) 0)
                                           (and (eq (nmcp-training-ready? tue 64 1 1 1 1 1 1 0 1 16) 0)
                                                (and (eq (nmcp-training-ready? tue 64 1 1 1 1 1 1 1 0 16) 0)
                                                     (eq (nmcp-training-ready? tue 64 1 1 1 1 1 1 1 1 15) 0)))))))))))
    (let component-ready (eq (nmcp-training-ready? thu 0 0 0 0 1 1 1 1 1 20) 1))
    (let component-gates
        (and (eq (nmcp-training-ready? thu 0 0 0 0 0 1 1 1 1 20) 0)
             (and (eq (nmcp-training-ready? thu 0 0 0 0 1 0 1 1 1 20) 0)
                  (and (eq (nmcp-training-ready? thu 0 0 0 0 1 1 0 1 1 20) 0)
                       (and (eq (nmcp-training-ready? thu 0 0 0 0 1 1 1 0 1 20) 0)
                            (and (eq (nmcp-training-ready? thu 0 0 0 0 1 1 1 1 0 20) 0)
                                 (eq (nmcp-training-ready? thu 0 0 0 0 1 1 1 1 1 19) 0)))))))
    (let c16 (if
        (and (eq (nmcp-job-max-minutes tue) 120)
             (and (eq (nmcp-job-min-free-gb tue) 16)
                  (and (str_eq (nmcp-job-lane fri) "world-state")
                       (and (str_eq (nmcp-job-lane sat) "speech-stt")
                            (and training-ready
                                 (and training-gates
                                      (and component-ready
                                           (and component-gates
                                                (eq (nmcp-training-ready? sun 999 1 1 1 1 1 1 1 1 99) 0)))))))))
        32768 0))

    (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8
        (add c9 (add c10 (add c11 (add c12 (add c13 (add c14 (add c15 c16))))))))))))))))
