; preludes: form-stdlib/feature-vector.fk
;
; feature-vector-band — a raw signal window, binned into a histogram feature vector, made falsifiable.
;
; A window of eight raw readings: [5 12 18 25 35 8 95 50]. Ascending thresholds [10 20 30] cut it
; into nbins=4 bins (below 10 · [10,20) · [20,30) · at-or-above 30):
;   5 -> 0   12 -> 1   18 -> 1   25 -> 2   35 -> 3   8 -> 0   95 -> 3   50 -> 3
; histogram (bar per bin) = [2 2 1 3]: two below 10, two in [10,20), one in [20,30), three >= 30.
; Width is fixed at nbins regardless of the window. The bin boundary is meets-or-exceeds: 30 lands
; in bin 3 because (ge 30 30) holds — equal-to-threshold belongs to the higher bin (ge, not gt).
;
; Verdict 127 when every claim lands:
;   1   bar 0 height                     (two readings below the first threshold)
;   2   bar 1 height                     (two readings in [10,20))
;   4   bar 2 height                     (one reading in [20,30))
;   8   bar 3 height                     (three readings at-or-above 30)
;   16  the vector width is fixed        (len histogram == nbins)
;   32  a mid-bin value bins right       (25 -> bin 2)
;   64  the boundary is meets-or-exceeds (30 -> bin 3, proving ge not gt)
(do
    (let thresholds (list 10 20 30))
    (let values (list 5 12 18 25 35 8 95 50))
    (let nbins 4)
    (let hist (fv-histogram values thresholds nbins))
    (let c0 (if (eq (fv-bar hist 0) 2) 1 0))
    (let c1 (if (eq (fv-bar hist 1) 2) 2 0))
    (let c2 (if (eq (fv-bar hist 2) 1) 4 0))
    (let c3 (if (eq (fv-bar hist 3) 3) 8 0))
    (let c4 (if (eq (fv-width hist) nbins) 16 0))
    (let c5 (if (eq (fv-bin 25 thresholds) 2) 32 0))
    (let c6 (if (eq (fv-bin 30 thresholds) 3) 64 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
