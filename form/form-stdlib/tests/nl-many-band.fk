; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/string-case.fk form-stdlib/nl-lexicon-data.fk form-stdlib/nl-translate.fk form-stdlib/nl-tongues.fk
;
; nl-many-band.fk — fourteen tongues, one meaning, one node.
; PROOF LEVEL: FOURTH-ARM ONLY (fkwu). Not rostered four-way: the non-Latin
; scripts are blocked by the cross-kernel string-unit seam (fkwu char_at walks
; bytes; go/rust/ts return the whole char at a start and nothing inside it).
; The four-way slice lives in nl-many-latin-band.fk (1023). Cursor unit parity
; is the next door; when it opens, this band's roster row is the acceptance.
;
; The same sentence — "the body is (a) cell", property(n3, n4) — enters through
; THIRTEEN tongue grammars (en id from nl-translate; es de fr pt ru sw zh ja ar
; hi tr from nl-tongues), each a BMF-style grammar over the one engine, each in
; its own script, and every parse must intern to the IDENTICAL pivot node:
; translation as content-address identity, no tongue favored. Then each tongue's
; decoder projects the pivot back to its surface and the round-trip must return
; the same node again.
;
; Bits: for each of the 12 new tongues (incl. sa संस्कृतम्, the 14th door),
; bit pair (parse ≡ en-pivot, round-trip ≡ pivot); + elder en/id agreement;
; + a chain es -> ja -> hi holding the node fixed. sa rides bits 24-25.
; Verdict 67108863 when every tongue speaks and none is favored.
(do
    (let pivot (norm-en (g-parse (nl-en) "the body is cell")))

    (defn pair (enc-node rt-node pv bit-lo)
        (add (if (node_eq enc-node pv) bit-lo 0)
             (if (node_eq rt-node pv) (mul bit-lo 2) 0)))

    (let p-es (nlm-enc-es "el cuerpo es celula"))
    (let p-de (nlm-enc-de "der körper ist zelle"))
    (let p-fr (nlm-enc-fr "le corps est cellule"))
    (let p-pt (nlm-enc-pt "o corpo e celula"))
    (let p-ru (nlm-enc-ru "тело есть клетка"))
    (let p-sw (nlm-enc-sw "mwili ni seli"))
    (let p-zh (nlm-enc-zh "身体 是 细胞"))
    (let p-ar (nlm-enc-ar "جسم هو خلية"))
    (let p-hi (nlm-enc-hi "शरीर कोशिका है"))
    (let p-tr (nlm-enc-tr "beden hücre dir"))
    (let p-ja (nlm-enc-ja "からだ は さいぼう です"))
    (let p-sa (nlm-enc-sa "शरीरम् कोशिका अस्ति"))

    (let c-es (pair p-es (nlm-enc-es (nlm-dec-es pivot)) pivot 1))
    (let c-de (pair p-de (nlm-enc-de (nlm-dec-de pivot)) pivot 4))
    (let c-fr (pair p-fr (nlm-enc-fr (nlm-dec-fr pivot)) pivot 16))
    (let c-pt (pair p-pt (nlm-enc-pt (nlm-dec-pt pivot)) pivot 64))
    (let c-ru (pair p-ru (nlm-enc-ru (nlm-dec-ru pivot)) pivot 256))
    (let c-sw (pair p-sw (nlm-enc-sw (nlm-dec-sw pivot)) pivot 1024))
    (let c-zh (pair p-zh (nlm-enc-zh (nlm-dec-zh pivot)) pivot 4096))
    (let c-ar (pair p-ar (nlm-enc-ar (nlm-dec-ar pivot)) pivot 16384))
    (let c-hi (pair p-hi (nlm-enc-hi (nlm-dec-hi pivot)) pivot 65536))
    (let c-tr (pair p-tr (nlm-enc-tr (nlm-dec-tr pivot)) pivot 262144))
    (let c-ja (pair p-ja (nlm-enc-ja (nlm-dec-ja pivot)) pivot 1048576))
    (let c-sa (pair p-sa (nlm-enc-sa (nlm-dec-sa pivot)) pivot 16777216))

    ; the elder pair still meets the same node through its own door
    (let c-elder (if (node_eq (norm-id (g-parse (nl-id) "tubuh adalah sel")) pivot) 4194304 0))
    ; a chain across three scripts holds the node fixed
    (let c-chain (if (node_eq (nlm-enc-hi (nlm-dec-hi (nlm-enc-ja (nlm-dec-ja (nlm-enc-es (nlm-dec-es pivot)))))) pivot) 8388608 0))

    (add c-es (add c-de (add c-fr (add c-pt (add c-ru (add c-sw (add c-zh
        (add c-ar (add c-hi (add c-tr (add c-ja (add c-sa (add c-elder c-chain))))))))))))))
