; preludes: form-stdlib/core.fk form-stdlib/introspective-inquiry-simulation.fk
import "../introspective-inquiry-simulation.fk"
(do
  (defn iisb-run ()
    (do (let rows (iis-simulate))
      (let r0 (nth rows 0)) (let r1 (nth rows 1))
      (let r2 (nth rows 2)) (let r3 (nth rows 3)) (let r4 (nth rows 4))
      (list rows
        (if (and (lt (nth r0 4) (nth r1 4))
          (and (lt (nth r1 4) (nth r2 4))
          (and (lt (nth r2 4) (nth r3 4))
          (and (eq (nth r4 4) 1000)
               (eq (nth r4 5) 16))))) 1 0))))
  (iisb-run))
