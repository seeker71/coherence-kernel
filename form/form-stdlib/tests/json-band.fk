; json-band.fk — proof json.fk works on `fkwu --src`.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk
;
; The history of what actually broke json.fk on `--src`, and of what only
; APPEARED to (told across three corrections, each honest about the last):
; receipts/2026-07-01-json-fk-src-scoping-fix.md (root cause #1, the real
; top-level-`let` scoping constraint — still true), receipts/2026-07-01-
; json-fk-actually-fixed.md ("root cause #3" was a paren-placement mistake
; in a rewrite, not an interpreter bug), and receipts/2026-07-01-stale-
; binary-root-cause.md (the forward-reference/mutual-recursion "constraint"
; itself was a stale local ./fkwu binary predating the current runtime
; source — a fresh build resolves both fine; only the top-level-`let`
; constraint survives on current source).
;
; Covers: numbers, nested objects, nested arrays, null, strings, floats,
; TRUE/FALSE round-tripping distinctly through typed NodeID identity
; (`node_eq`, axiom-3), and the parse-json/json-object-get public entry points
; external callers (routers/mesh-sensings-route.fk) actually use.
;
; Verdict 1023 when every assertion holds.

(do
    (defn jsb-score (ok bit) (if ok bit 0))
    (defn json-band ()
        (do
    (let n (json-pair-r (json-parse-value "1" 0 "test")))
    (let c0 (jsb-score (eq (node_value n) 1) 1))                              ; the original failing case
    (let obj (json-pair-r (json-parse-value "{\"a\":1,\"b\":[2,3]}" 0 "test")))
    (let c1 (jsb-score (str_eq (json-emit obj) "{\"a\":1,\"b\":[2,3]}") 2))
    (let c2 (jsb-score (eq (node_value (json-object-get obj "a")) 1) 4))
    (let nested (json-pair-r (json-parse-value "{\"x\":{\"y\":5}}" 0 "test")))
    (let c3 (jsb-score (str_eq (json-emit nested) "{\"x\":{\"y\":5}}") 8))
    (let nul (json-pair-r (json-parse-value "null" 0 "test")))
    (let c4 (jsb-score (str_eq (json-emit nul) "null") 16))
    (let arr (json-pair-r (json-parse-value "[1,2,3]" 0 "test")))
    (let c5 (jsb-score (str_eq (json-emit arr) "[1,2,3]") 32))
    (let deep (parse-json "test" "{\"deep\":{\"nested\":[1,2,3]}}"))
    (let c6 (jsb-score (str_eq (json-emit deep) "{\"deep\":{\"nested\":[1,2,3]}}") 64))
    (let s (json-pair-r (json-parse-value "\"hello\"" 0 "test")))
    (let f (json-pair-r (json-parse-value "3.5" 0 "test")))
    (let c7 (jsb-score (and (str_eq (json-emit s) "\"hello\"") (str_eq (json-emit f) "3.5")) 128))
    (let t-doc (json-pair-r (json-parse-value "true" 0 "test")))
    (let f-doc (json-pair-r (json-parse-value "false" 0 "test")))
    (let c8 (jsb-score (and (str_eq (json-emit t-doc) "true") (str_eq (json-emit f-doc) "false")) 256))
    (let mixed (parse-json "test" "{\"deep\":{\"nested\":[true,false,null]}}"))
    (let c9 (jsb-score (str_eq (json-emit mixed) "{\"deep\":{\"nested\":[true,false,null]}}") 512))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8 c9))))))))))
    )
    (json-band))
