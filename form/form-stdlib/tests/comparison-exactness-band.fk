; comparison-exactness-band.fk — the compare family (eq/lt/le/gt/ge) is
; EXACT over the full 63-bit tagged int range. The compare law (shared with
; the Go/Rust kernels and the JIT's inline int path): float on either side
; forces an IEEE comparison; pure int/int never rounds. Before this band,
; the C seed's walker compared every pair through doubles, whose 53-bit
; mantissa blurred distinct big ints into equality — (eq -2^62 (add -2^62 1))
; answered true while (sub) of the same pair answered -1 exactly.
;
; Big operands are CONSTRUCTED (mul/add over small literals), not written as
; literals: minted while the .fkb value lane was still signed-32 (v3, where a
; big literal could not stage). The v4 64-bit lane now stages them, but the
; construction stays — it keeps this band independent of the literal lane,
; standing only on add/sub/mul, which were already exact.
;
; NAMED SEAM (this band's honest boundary): the claim is exact comparison of
; every word that IS an int when compared. Ints below -(2^62-1)/2 — words at
; or below fk_fbase — sit inside the float-pool band, and once fk_fp floats
; are boxed, fk_isf misreads word (fk_fbase - 2k) as float slot k at EVERY
; float-aware door (add/print/compare alike; witnessed: (add -4.5e18-2 1)
; returned the float 8.0 on v3 and v4 kernels alike — pre-existing value-model
; seam, not a comparison defect). This band's ±2^62 rows stay honest because
; their slot index ≈ 1.1e17 exceeds any real float pool. The heal is the
; float-parity move (floats to odd words, evens all-int); until it lands,
; deep-negative ints below -4.5e18 are unowned by every kind-dispatched door.
;
; Self-contained — kernel verbs only, no preludes. Verdict 4095.
(do
    ; two31 = 2^31; a = -2^62 (the tagged minimum); b = a+1 = -(2^62-1).
    (let two31 (add 2147483647 1))
    (let a (mul two31 (sub 0 two31)))
    (let b (add a 1))
    ; p = 2^62-1 (the tagged maximum); q = p-1. The positive twin.
    (let p (sub 0 b))
    (let q (sub p 1))
    ; x = 2^53, the first int a double cannot count past; y = x+1.
    (let x (mul 67108864 134217728))
    (let y (add x 1))
    ; c0 — ground: sub stays exact where compare used to blur.
    (let c0 (if (eq (sub a b) (sub 0 1)) 1 0))
    ; c1 — adjacent negative giants are NOT equal.
    (let c1 (if (eq a b) 0 2))
    ; c2 — and they order: a < b, a <= b.
    (let c2 (if (and (lt a b) (le a b)) 4 0))
    ; c3 — the reverse orderings refuse: not (ge a b), not (gt a b).
    (let c3 (if (or (ge a b) (gt a b)) 0 8))
    ; c4 — adjacent positive giants are NOT equal.
    (let c4 (if (eq p q) 0 16))
    ; c5 — and they order: p > q, p >= q.
    (let c5 (if (and (gt p q) (ge p q)) 32 0))
    ; c6 — the first blurred pair: 2^53 and 2^53+1 stay distinct.
    (let c6 (if (eq x y) 0 64))
    ; c7 — and ordered: x < y <= y.
    (let c7 (if (and (lt x y) (le y y)) 128 0))
    ; c8 — extremes: min < max across the whole tagged range.
    (let c8 (if (and (lt a p) (gt p a)) 256 0))
    ; c9 — equality still holds where it should: a = a at the minimum.
    (let c9 (if (and (eq a a) (and (le a a) (ge a a))) 512 0))
    ; c10 — the float lane still promotes: 1.5 < 2 through IEEE.
    (let c10 (if (lt 1.5 2) 1024 0))
    ; c11 — mixed int/float equality keeps the IEEE answer: 2.0 = 2.
    (let c11 (if (eq 2.0 2) 2048 0))
    (add (add (add (add c0 c1) (add c2 c3))
              (add (add c4 c5) (add c6 c7)))
         (add (add c8 c9) (add c10 c11))))
