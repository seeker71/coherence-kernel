; form-definition-language-band.fk -- module/data/function authoring surface.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/defdata.fk form-stdlib/form-definition-language.fk
;
; Expected: 65535

(do
    (defn fdlb-score (ok bit) (if ok bit 0))
    (defn fdlb-manifest-has (name)
        (form-definition-language-manifest-has? name (form-definition-language-manifest)))
    (defn fdlb-sample-source ()
        "module calc { data rows = [8,13,21]; fn bump(x) = add(x,1); fn first() = head(rows); }")
    (defn fdlb-comment-source ()
        "module calc { // rows are stable\n data rows=[8,13,21]; /* function */ fn bump(x)=add(x,1); fn first()=head(rows); }")
    (defn fdlb-expected-source ()
        "(let rows (list 8 13 21))\n(defn bump (x) (add x 1))\n(defn first () (head rows))")

    (defn form-definition-language-band ()
        (do
            (let module (fdl-parse (fdlb-sample-source)))
            (let lower (fdl-lowering module))
            (let data-decl (head (fdl-module-decls module)))
            (let bump-decl (nth (fdl-module-decls module) 1))
            (let first-decl (nth (fdl-module-decls module) 2))
            (let comment-module (fdl-parse (fdlb-comment-source)))
            (let bad (fdl-parse (str_concat (fdlb-sample-source) " trailing")))
            (let empty-data (fdl-parse "module z { data empty = []; }"))
            (add
                (fdlb-score (eq (fdlb-manifest-has "scannerless") 1) 1)
            (add
                (fdlb-score (eq (fdlb-manifest-has "no-line-grammar") 1) 2)
            (add
                (fdlb-score (eq (fdlb-manifest-has "not-s-expression-surface") 1) 4)
            (add
                (fdlb-score (fdl-ok? module) 8)
            (add
                (fdlb-score (str_eq (fdl-module-name module) "calc") 16)
            (add
                (fdlb-score (eq (fdl-decl-count module) 3) 32)
            (add
                (fdlb-score (str_eq (fdl-data-name data-decl) "rows") 64)
            (add
                (fdlb-score (eq (fdl-data-value-count data-decl) 3) 128)
            (add
                (fdlb-score (eq (fdl-data-policy data-decl) (dd-inline)) 256)
            (add
                (fdlb-score (str_eq (fdl-fn-name bump-decl) "bump") 512)
            (add
                (fdlb-score (eq (fdl-fn-param-count bump-decl) 1) 1024)
            (add
                (fdlb-score (str_eq (fdl-expr-source (fdl-fn-body bump-decl)) "(add x 1)") 2048)
            (add
                (fdlb-score (str_eq (fdl-lowering-kind lower) "form-top-level-source-floor") 4096)
            (add
                (fdlb-score (str_eq (fdl-lowering-source lower) (fdlb-expected-source)) 8192)
            (add
                (fdlb-score
                    (and (str_eq (fdl-fn-name first-decl) "first")
                         (str_eq (fdl-fn-source first-decl) "(defn first () (head rows))"))
                    16384)
                (fdlb-score
                    (and (fdl-ok? comment-module)
                         (and (not (fdl-ok? bad))
                         (str_eq (fdl-lowering-source (fdl-lowering empty-data))
                                      "(let empty (list))")))
                    32768))))))))))))))))))

    (form-definition-language-band))
