                            (scfpb-source-large-hash)
                            (fs-stat-mtime (scfpb-source-large-path))
                            (scfpb-fkb-path)
                            (scfpb-fkb-hash)
                            (fs-stat-mtime (scfpb-fkb-path))))
    (defn scfpb-emission-source-missing ()
        (scfpb-emission-fkb (scfpb-source-missing-path)
                            (scfpb-source-hash)
                            100
                            (scfpb-fkb-path)
                            (scfpb-fkb-hash)
                            (fs-stat-mtime (scfpb-fkb-path))))
    (defn scfpb-emission-fkb-mismatch ()
        (scfpb-emission-fkb (scfpb-source-path)
                            (scfpb-source-hash)
                            (fs-stat-mtime (scfpb-source-path))
                            (scfpb-fkb-bad-path)
                            (scfpb-fkb-hash)
                            (fs-stat-mtime (scfpb-fkb-bad-path))))
    (defn scfpb-emission-fkb-large ()
        (scfpb-emission-fkb (scfpb-source-path)
                            (scfpb-source-hash)
                            (fs-stat-mtime (scfpb-source-path))
                            (scfpb-fkb-large-path)
                            (scfpb-fkb-large-hash)
                            (fs-stat-mtime (scfpb-fkb-large-path))))
    (defn scfpb-emission-fkb-missing ()
        (scfpb-emission-fkb (scfpb-source-path)
                            (scfpb-source-hash)
                            (fs-stat-mtime (scfpb-source-path))
                            (scfpb-fkb-missing-path)
                            (scfpb-fkb-hash)
                            (add (fs-stat-mtime (scfpb-source-path)) 1)))
    (defn scfpb-emission-non-emitted ()
        (do
            (let e (scfpb-emission-good))
            (sce-emission-from-compile
                (sce-emission-compile-envelope e)
                (sce-emission-compile-output e)
                (sce-emission-pif-envelope e)
                "bad table text\n"
                (sce-no-dylib))))
    (defn scfpb-emission-malformed ()
        (list "source-compiler-emission" 1))
    (defn scfpb-emission-dylib-good ()
        (scfpb-emission-dylib
            (scfpb-dylib-descriptor (scfpb-dylib-path)
                                    (scfpb-dylib-hash)
                                    (fs-stat-mtime (scfpb-dylib-path)))))
    (defn scfpb-emission-dylib-missing ()
        (scfpb-emission-dylib
            (scfpb-dylib-descriptor (scfpb-dylib-missing-path)
                                    (scfpb-dylib-hash)
                                    (add (fs-stat-mtime (scfpb-source-path)) 1))))
    (defn scfpb-emission-dylib-large ()
        (scfpb-emission-dylib
            (scfpb-dylib-descriptor (scfpb-dylib-large-path)
                                    (scfpb-dylib-large-hash)
                                    (fs-stat-mtime (scfpb-dylib-large-path)))))
    (defn scfpb-emission-dylib-malformed-forged ()
        (do
            (let e (scfpb-emission-dylib-good))
            (let malformed (sad-native-dylib (sad-version-native-dylib) "" (scfpb-source-hash) "" 102 1 1 1 1))
            (sce-emission (sce-emission-compile-envelope e)
                          (sce-emission-compile-output e)
                          (sce-emission-pif-envelope e)
                          (sce-emission-table-text e)
                          malformed
                          (sce-emission-fkb-descriptor e)
                          (sce-status-emitted)
                          "synthetic-forged-emitted")))

    (defn scfpb-result-good ()
        (scfp-file-persistence-from-emission (scfpb-emission-good) (scfpb-max)))
    (defn scfpb-replay (row)
        (scp-persistence-from-probe (scfp-row-emission row)
                                    (safp-probe-bundle-sap (scfp-row-probe-bundle row))))
    (defn scfpb-result-reason (row) (scfp-row-reason row))
    (defn scfpb-nested-reason (row) (scp-persistence-reason (scfp-row-persistence row)))
    (defn scfpb-probe-status (row) (safp-probe-bundle-status (scfp-row-probe-bundle row)))
    (defn scfpb-fkb-probe (row) (safp-probe-bundle-fkb-probe (scfp-row-probe-bundle row)))
    (defn scfpb-source-probe (row) (safp-probe-bundle-source-probe (scfp-row-probe-bundle row)))
    (defn scfpb-dylib-probe (row) (safp-probe-bundle-dylib-probe (scfp-row-probe-bundle row)))

    (defn scfpb-bit-manifest-1 ()
        (scfpb-score
            (and (eq (scfpb-manifest-has "emission-to-file-backed-persistence") 1)
            (and (eq (scfpb-manifest-has "uses-source-artifact-file-probe") 1)
            (and (eq (scfpb-manifest-has "delegates-status-reason-to-scp") 1)
            (and (eq (scfpb-manifest-has "nested-scp-persistence-row") 1)
            (and (eq (scfpb-manifest-has "probe-bundle-replayable-to-scp") 1)
            (and (eq (scfpb-manifest-has "no-probe-for-malformed-emission") 1)
            (and (eq (scfpb-manifest-has "no-probe-for-non-emitted-emission") 1)
                 (eq (scfpb-manifest-has "original-emission-preserved") 1))))))))
            1))
    (defn scfpb-bit-manifest-2 ()
        (scfpb-score
            (and (eq (scfpb-manifest-has "uniform-max-byte-cap") 1)
            (and (eq (scfpb-manifest-has "no-dylib-path-sniffing") 1)
            (and (eq (scfpb-manifest-has "dylib-policy-bits-from-emission") 1)
            (and (eq (scfpb-manifest-has "fkb-policy-bits-from-emission") 1)
            (and (eq (scfpb-manifest-has "observed-mtime-owned-by-probe") 1)
            (and (eq (scfpb-manifest-has "no-new-persistence-reasons") 1)
            (and (eq (scfpb-manifest-has "no-compiler-execution") 1)
            (and (eq (scfpb-manifest-has "no-table-text-execution") 1)
            (and (eq (scfpb-manifest-has "no-disk-write") 1)
            (and (eq (scfpb-manifest-has "no-form-binary-io") 1)
            (and (eq (scfpb-manifest-has "no-artifact-load-walk-call") 1)
            (and (eq (scfpb-manifest-has "no-selector-install") 1)
                 (eq (scfpb-manifest-has "no-c-seed-growth") 1)))))))))))))
            2))
    (defn scfpb-bit-ready-fkb ()
        (do
            (let row (scfpb-result-good))
            (scfpb-score
                (and (scp-persistence-ready? (scfp-row-persistence row))
                (and (str_eq (scfpb-result-reason row) (scp-reason-persistence-ready-fkb))
                (and (str_eq (scfpb-probe-status row) (safp-status-ready))
                     (str_eq (safp-artifact-probe-status (scfpb-fkb-probe row)) (sai-status-match)))))
                4)))
    (defn scfpb-bit-status-reason-projection ()
        (do
            (let row (scfpb-result-good))
            (scfpb-score
                (and (str_eq (scfp-row-status row) (scp-persistence-status (scfp-row-persistence row)))
                     (str_eq (scfp-row-reason row) (scp-persistence-reason (scfp-row-persistence row))))
                8)))
    (defn scfpb-bit-replay ()
        (do
            (let row (scfpb-result-good))
            (let replay (scfpb-replay row))
            (scfpb-score
                (and (str_eq (scp-persistence-status replay) (scp-persistence-status (scfp-row-persistence row)))
                     (str_eq (scp-persistence-reason replay) (scp-persistence-reason (scfp-row-persistence row))))
                16)))
    (defn scfpb-bit-descriptor-triple-fields ()
        (do
            (let row (scfpb-result-good))
            (let t (scp-persistence-descriptor-triple (scfp-row-persistence row)))
            (scfpb-score
