; Expected: 2147483647

(do
    (defn scfpb-score (ok bit) (if ok bit 0))
    (defn scfpb-manifest-has (name)
        (source-compiler-file-persistence-manifest-has? name (source-compiler-file-persistence-manifest)))
    (defn scfpb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn scfpb-read-file-any (primary fallback)
        (if (ge (file_size primary) 0)
            (read_file primary)
            (read_file fallback)))

    (defn scfpb-root ()
        (fs-path-join (fs-temp-dir) "source-compiler-file-persistence-band"))
    (defn scfpb-path (name)
        (fs-path-join (scfpb-root) name))
    (defn scfpb-source-path () (scfpb-path "source.fk"))
    (defn scfpb-source-bad-path () (scfpb-path "source-bad.fk"))
    (defn scfpb-source-large-path () (scfpb-path "source-large.fk"))
    (defn scfpb-source-missing-path () (scfpb-path "missing-source.fk"))
    (defn scfpb-fkb-path () (scfpb-path "source.fkb"))
    (defn scfpb-fkb-bad-path () (scfpb-path "source-bad.fkb"))
    (defn scfpb-fkb-large-path () (scfpb-path "source-large.fkb"))
    (defn scfpb-fkb-missing-path () (scfpb-path "missing.fkb"))
    (defn scfpb-dylib-path () (scfpb-path "source.dylib"))
    (defn scfpb-dylib-large-path () (scfpb-path "source-large.dylib"))
    (defn scfpb-dylib-missing-path () (scfpb-path "missing.dylib"))
    (defn scfpb-conventional-dylib-path () (scfpb-path "conventional.dylib"))

    (defn scfpb-repeat-byte-loop (b n acc)
        (if (le n 0)
            acc
            (scfpb-repeat-byte-loop b (sub n 1) (cons b acc))))
    (defn scfpb-repeat-byte (b n)
        (scfpb-repeat-byte-loop b n (list)))
    (defn scfpb-source-bytes () (list 97 98 99))
    (defn scfpb-source-bad-bytes () (list 122 122 122))
    (defn scfpb-fkb-bytes () (list 102 107 98))
    (defn scfpb-fkb-bad-bytes () (list 98 97 100))
    (defn scfpb-dylib-bytes () (list 100 121 110))
    (defn scfpb-large-bytes () (scfpb-repeat-byte 65 129))
    (defn scfpb-hash (bytes) (sai-sha256-hex bytes))
    (defn scfpb-source-hash () (scfpb-hash (scfpb-source-bytes)))
    (defn scfpb-source-large-hash () (scfpb-hash (scfpb-large-bytes)))
    (defn scfpb-fkb-hash () (scfpb-hash (scfpb-fkb-bytes)))
    (defn scfpb-fkb-large-hash () (scfpb-hash (scfpb-large-bytes)))
    (defn scfpb-dylib-hash () (scfpb-hash (scfpb-dylib-bytes)))
    (defn scfpb-dylib-large-hash () (scfpb-hash (scfpb-large-bytes)))
    (defn scfpb-max () 128)

    (defn scfpb-write-bytes (path bytes)
        (do
            (let _rm (fs-remove-file path))
            (if (eq (len bytes) 0)
                (fs-write-text path "")
                (fs-append-bytes path bytes))))
    (defn scfpb-setup ()
        (do
            (let root (scfpb-root))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let _s (scfpb-write-bytes (scfpb-source-path) (scfpb-source-bytes)))
            (let _sb (scfpb-write-bytes (scfpb-source-bad-path) (scfpb-source-bad-bytes)))
            (let _sl (scfpb-write-bytes (scfpb-source-large-path) (scfpb-large-bytes)))
            (let _f (scfpb-write-bytes (scfpb-fkb-path) (scfpb-fkb-bytes)))
            (let _fb (scfpb-write-bytes (scfpb-fkb-bad-path) (scfpb-fkb-bad-bytes)))
            (let _fl (scfpb-write-bytes (scfpb-fkb-large-path) (scfpb-large-bytes)))
            (let _d (scfpb-write-bytes (scfpb-dylib-path) (scfpb-dylib-bytes)))
            (let _dl (scfpb-write-bytes (scfpb-dylib-large-path) (scfpb-large-bytes)))
            (let _dc (scfpb-write-bytes (scfpb-conventional-dylib-path) (scfpb-dylib-bytes)))
            0))
    (defn scfpb-cleanup ()
        (do
            (let _s (fs-remove-file (scfpb-source-path)))
            (let _sb (fs-remove-file (scfpb-source-bad-path)))
            (let _sl (fs-remove-file (scfpb-source-large-path)))
            (let _f (fs-remove-file (scfpb-fkb-path)))
            (let _fb (fs-remove-file (scfpb-fkb-bad-path)))
            (let _fl (fs-remove-file (scfpb-fkb-large-path)))
            (let _d (fs-remove-file (scfpb-dylib-path)))
            (let _dl (fs-remove-file (scfpb-dylib-large-path)))
            (let _dc (fs-remove-file (scfpb-conventional-dylib-path)))
            (fs-remove-tree (scfpb-root))))

    (defn scfpb-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn scfpb-source (path hash mtime)
        (sad-source path hash mtime))
    (defn scfpb-pif (source-path source-hash source-mtime fkb-path fkb-hash fkb-mtime)
        (pif-envelope source-path source-hash source-mtime
                      fkb-path fkb-hash fkb-mtime
                      1
                      (scfpb-table)))
    (defn scfpb-compile-envelope (source)
        (rale-envelope-from-selection
            source
            (sad-no-artifact)
            (sad-no-artifact)
            (ras-selection-from-plan
                (rap-plan-from-descriptors source (sad-no-artifact) (sad-no-artifact)))))
    (defn scfpb-emission-fkb (source-path source-hash source-mtime fkb-path fkb-hash fkb-mtime)
        (do
            (let source (scfpb-source source-path source-hash source-mtime))
            (let pif (scfpb-pif source-path source-hash source-mtime fkb-path fkb-hash fkb-mtime))
            (sce-emission-from-compile
                (scfpb-compile-envelope source)
                (sac-compile-output 0 0)
                pif
                (pite-table-text-from-envelope pif)
                (sce-no-dylib))))
    (defn scfpb-dylib-descriptor (path content-hash mtime)
        (sad-native-dylib (sad-version-native-dylib)
                          path
                          (scfpb-source-hash)
                          content-hash
                          mtime
                          1
                          1
                          1
                          1))
    (defn scfpb-emission-dylib (dylib)
        (do
            (let sm (fs-stat-mtime (scfpb-source-path)))
            (let fm (fs-stat-mtime (scfpb-fkb-path)))
            (let source (scfpb-source (scfpb-source-path) (scfpb-source-hash) sm))
            (let pif (scfpb-pif (scfpb-source-path) (scfpb-source-hash) sm
                                (scfpb-fkb-path) (scfpb-fkb-hash) fm))
            (sce-emission-from-compile
                (scfpb-compile-envelope source)
                (sac-compile-output 1 1)
                pif
                (pite-table-text-from-envelope pif)
                dylib)))
    (defn scfpb-emission-good ()
        (scfpb-emission-fkb (scfpb-source-path)
                            (scfpb-source-hash)
                            (fs-stat-mtime (scfpb-source-path))
                            (scfpb-fkb-path)
                            (scfpb-fkb-hash)
                            (fs-stat-mtime (scfpb-fkb-path))))
    (defn scfpb-emission-source-mismatch ()
        (scfpb-emission-fkb (scfpb-source-bad-path)
                            (scfpb-source-hash)
                            (fs-stat-mtime (scfpb-source-bad-path))
                            (scfpb-fkb-path)
                            (scfpb-fkb-hash)
                            (fs-stat-mtime (scfpb-fkb-path))))
    (defn scfpb-emission-source-large ()
