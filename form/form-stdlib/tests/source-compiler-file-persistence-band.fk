            (let dob (safp-artifact-probe-observation dp))
            (scfpb-score
                (and (scp-investigate? (scfp-row-persistence row))
                (and (str_eq (scfpb-result-reason row) (scp-reason-dylib-expected-missing))
                (and (str_eq (sap-observation-path dob) "")
                     (str_eq (safp-artifact-probe-status dp) (scfp-status-no-probe)))))
                262144)))
    (defn scfpb-bit-original-emission-preserved ()
        (do
            (let e (scfpb-emission-good))
            (let row (scfp-file-persistence-from-emission e (scfpb-max)))
            (scfpb-score (value_eq (scfp-row-emission row) e) 524288)))
    (defn scfpb-bit-no-probe-empty-shape ()
        (do
            (let row (scfp-file-persistence-from-emission (scfpb-emission-malformed) (scfpb-max)))
            (let pb (scfp-row-probe-bundle row))
            (scfpb-score
                (and (str_eq (safp-source-probe-status (safp-probe-bundle-source-probe pb)) (scfp-status-no-probe))
                (and (str_eq (safp-artifact-probe-status (safp-probe-bundle-fkb-probe pb)) (scfp-status-no-probe))
                     (str_eq (safp-artifact-probe-status (safp-probe-bundle-dylib-probe pb)) (scfp-status-no-probe))))
                1048576)))
    (defn scfpb-bit-handoff-fkb ()
        (do
            (let row (scfpb-result-good))
            (let h (rah-handoff-from-persistence (scfp-row-persistence row)))
            (scfpb-score
                (and (rah-handoff-ready? h)
                     (str_eq (rah-handoff-reason h) (rah-reason-handoff-ready-program-image)))
                2097152)))
    (defn scfpb-bit-handoff-dylib ()
        (do
            (let row (scfp-file-persistence-from-emission (scfpb-emission-dylib-good) (scfpb-max)))
            (let h (rah-handoff-from-persistence (scfp-row-persistence row)))
            (scfpb-score
                (and (rah-handoff-ready? h)
                     (str_eq (rah-handoff-reason h) (rah-reason-handoff-ready-native)))
                4194304)))
    (defn scfpb-bit-handoff-independence ()
        (do
            (let row (scfpb-result-good))
            (let direct (scfpb-replay row))
            (let h1 (rah-handoff-from-persistence (scfp-row-persistence row)))
            (let h2 (rah-handoff-from-persistence direct))
            (scfpb-score
                (and (str_eq (rah-handoff-status h1) (rah-handoff-status h2))
                (and (str_eq (rah-handoff-reason h1) (rah-handoff-reason h2))
                     (eq (rap-plan-route (rah-handoff-plan h1)) (rap-plan-route (rah-handoff-plan h2)))))
                8388608)))
    (defn scfpb-bit-dylib-policy-carried ()
        (do
            (let row (scfp-file-persistence-from-emission (scfpb-emission-dylib-good) (scfpb-max)))
            (let obs (safp-artifact-probe-observation (scfpb-dylib-probe row)))
            (scfpb-score
                (and (eq (sap-observation-proof obs) 1)
                (and (eq (sap-observation-callable obs) 1)
                     (eq (sap-observation-lowerable obs) 1)))
                16777216)))
    (defn scfpb-bit-static-boundary ()
        (do
            (let text (scfpb-read-file-any "form/form-stdlib/source-compiler-file-persistence.fk"
                                           "../form/form-stdlib/source-compiler-file-persistence.fk"))
            (scfpb-score
                (and (not (scfpb-has? text "read_file"))
                (and (not (scfpb-has? text "write_file"))
                (and (not (scfpb-has? text "write_form_binary"))
                (and (not (scfpb-has? text "read_form_binary"))
                (and (not (scfpb-has? text "recipe_to_bytes"))
                (and (not (scfpb-has? text "bytes_to_recipe"))
                (and (not (scfpb-has? text "dlopen"))
                (and (not (scfpb-has? text "dlsym"))
                (and (not (scfpb-has? text "fk_run"))
                (and (not (scfpb-has? text "rtta-bridge-from-run"))
                (and (not (scfpb-has? text "raar-supplied-attempt"))
                     (not (scfpb-has? text "rah-handoff-from-persistence")))))))))))))
                33554432)))
    (defn scfpb-bit-mirror ()
        (do
            (let text (scfpb-read-file-any "form/form-stdlib/source-compiler-file-persistence.fk"
                                           "../form/form-stdlib/source-compiler-file-persistence.fk"))
            (scfpb-score
                (str_eq text (scfpb-read-file-any "grammars/source-compiler-file-persistence.fk"
                                                  "../grammars/source-compiler-file-persistence.fk"))
                67108864)))
    (defn scfpb-bit-version ()
        (scfpb-score (str_eq (scfp-version) "source-compiler-file-persistence-v1") 134217728))
    (defn scfpb-bit-carrier-accessors ()
        (do
            (let row (scfpb-result-good))
            (scfpb-score
                (and (scfp-row? row)
                (and (sce-emission? (scfp-row-emission row))
                (and (safp-probe-bundle? (scfp-row-probe-bundle row))
                     (scp-persistence? (scfp-row-persistence row)))))
                268435456)))
    (defn scfpb-bit-nested-row-to-9i-only ()
        (do
            (let row (scfpb-result-good))
            (let h (rah-handoff-from-persistence (scfp-row-persistence row)))
            (scfpb-score
                (and (rah-handoff-ready? h)
                     (scp-persistence? (rah-handoff-persistence h)))
                536870912)))
    (defn scfpb-bit-no-new-reasons ()
        (do
            (let row (scfpb-result-good))
            (scfpb-score
                (str_eq (scfp-row-reason row) (scp-persistence-reason (scfp-row-persistence row)))
                1073741824)))

    (defn source-compiler-file-persistence-band ()
        (do
            (let _setup (scfpb-setup))
            (let score (sum (list
                (scfpb-bit-manifest-1)
                (scfpb-bit-manifest-2)
                (scfpb-bit-ready-fkb)
                (scfpb-bit-status-reason-projection)
                (scfpb-bit-replay)
                (scfpb-bit-descriptor-triple-fields)
                (scfpb-bit-source-mismatch)
                (scfpb-bit-fkb-mismatch)
                (scfpb-bit-missing-source)
                (scfpb-bit-missing-fkb)
                (scfpb-bit-fkb-cap-overflow)
                (scfpb-bit-source-cap-overflow)
                (scfpb-bit-non-emitted-no-probe)
                (scfpb-bit-malformed-no-probe)
                (scfpb-bit-ready-dylib)
                (scfpb-bit-missing-dylib)
                (scfpb-bit-dylib-cap-overflow)
                (scfpb-bit-no-dylib-no-sniff)
                (scfpb-bit-malformed-dylib-no-guess)
                (scfpb-bit-original-emission-preserved)
                (scfpb-bit-no-probe-empty-shape)
                (scfpb-bit-handoff-fkb)
                (scfpb-bit-handoff-dylib)
                (scfpb-bit-handoff-independence)
                (scfpb-bit-dylib-policy-carried)
                (scfpb-bit-static-boundary)
                (scfpb-bit-mirror)
                (scfpb-bit-version)
                (scfpb-bit-carrier-accessors)
                (scfpb-bit-nested-row-to-9i-only)
                (scfpb-bit-no-new-reasons))))
            (let _cleanup (scfpb-cleanup))
            score))

    (source-compiler-file-persistence-band))
