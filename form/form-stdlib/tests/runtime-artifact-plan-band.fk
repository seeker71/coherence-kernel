; runtime-artifact-plan-band.fk -- Layer 9a source-artifact runtime plans.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/source-artifact-cache.fk form/form-stdlib/source-artifact-descriptor.fk form/form-stdlib/runtime-artifact-plan.fk
;
; Expected: 67108863
;
; This band proves plan rows only. It does not read or write disk, load `.fkb`,
; load or call `.dylib`, execute native bytes, verify seals, or prove that
; `fkwu` startup selects artifacts.
;
; The witness is split into small bit functions. A single large local-let/sum
; body stalled the current source runner while individual probes returned
; immediately; this shape keeps the observation evaluable and records that
; source-shape pressure instead of ignoring it.
;
; Bits:
;   1        manifest declares plan-face-not-execution
;   2        manifest declares derives-from-sad-route
;   4        manifest declares routing-owned-by-sac
;   8        manifest declares skips-derived-from-sac
;   16       manifest declares invalid-investigates
;   32       manifest declares fkb-fallback-required-for-native
;   64       manifest declares deopt-anchor-observability
;   128      manifest declares no-disk-io
;   256      manifest declares no-runtime-load
;   512      manifest declares no-admission-policy
;   1024     manifest declares no-c-seed-growth
;   2048     manifest declares no-seal-verification
;   4096     invalid source descriptor investigates, not compile
;   8192     unknown artifact kind investigates
;   16384    source-hash mismatch fkb plans compile-source
;   32768    missing artifacts plan compile-source and do not skip parse
;   65536    stale/equal mtime boundary maps to compile/source image
;   131072   fresh fkb plans run-program-image with compile fallback
;   262144   fresh proven dylib plans native with fkb fallback
;   524288   unproven and non-callable dylibs plan program-image, not native
;   1048576  fresh dylib with stale fkb plans compile-source
;   2097152  seal-bad fkb/dylib quarantine plans compile-source
;   4194304  source newer than artifacts plans compile-source
;   8388608  route and skip fields match sad/sac for representative matrix
;   16777216 compile plan reuses sad/sac compile-output, including nonlowerable
;   33554432 native plan carries a deopt anchor; no-anchor probe routes non-native

(do
    (defn rapb-score (ok bit) (if ok bit 0))
    (defn rapb-manifest-has (name)
        (runtime-artifact-plan-manifest-has? name (runtime-artifact-plan-manifest)))

    (defn rapb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn rapb-source-newer () (sad-source "src/kernel.fk" "sha:src-a" 200))
    (defn rapb-invalid-source () (sad-source "" "sha:src-a" 100))
    (defn rapb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn rapb-fkb-equal ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 100 1 1))
    (defn rapb-fkb-stale ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 99 1 1))
    (defn rapb-fkb-hash-bad ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:old-src" "sha:fkb-a" 101 1 1))
    (defn rapb-fkb-seal-bad ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 0 1))
    (defn rapb-fkb-unknown ()
        (sad-artifact "compiler-image-fkb" "compiler-image-v1" "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 0 0 0 1))
    (defn rapb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn rapb-dylib-unproven ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 0 1 1))
    (defn rapb-dylib-noncallable ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 0 1))
    (defn rapb-dylib-nonlowerable ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 0))
    (defn rapb-dylib-seal-bad ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 0 1 1 1))

    (defn rapb-plan (fkb dylib)
        (rap-plan-from-descriptors (rapb-source) fkb dylib))
    (defn rapb-plan-newer (fkb dylib)
        (rap-plan-from-descriptors (rapb-source-newer) fkb dylib))
    (defn rapb-invalid-source-plan ()
        (rap-plan-from-descriptors (rapb-invalid-source) (rapb-fkb-fresh) (sad-no-artifact)))
    (defn rapb-unknown-kind-plan ()
        (rap-plan-from-descriptors (rapb-source) (rapb-fkb-unknown) (sad-no-artifact)))
    (defn rapb-primary? (p action) (str_eq (rap-plan-primary p) action))
    (defn rapb-fallback? (p action) (str_eq (rap-plan-fallback p) action))

    (defn rapb-valid-route-skip-parity? (source fkb dylib)
        (do
            (let plan (rap-plan-from-descriptors source fkb dylib))
            (let route (sad-route source fkb dylib))
            (let state (sad-derived-state source fkb dylib))
            (and (eq (rap-plan-route plan) route)
                 (and (eq (rap-plan-skip-parse plan) (sac-skips-parse? state))
                      (eq (rap-plan-skip-recompute plan) (sac-skips-recompute? state))))))

    (defn rapb-bit-manifest-1 ()
        (sum (list
            (rapb-score (eq (rapb-manifest-has "plan-face-not-execution") 1) 1)
            (rapb-score (eq (rapb-manifest-has "derives-from-sad-route") 1) 2)
            (rapb-score (eq (rapb-manifest-has "routing-owned-by-sac") 1) 4)
            (rapb-score (eq (rapb-manifest-has "skips-derived-from-sac") 1) 8)
            (rapb-score (eq (rapb-manifest-has "invalid-investigates") 1) 16)
            (rapb-score (eq (rapb-manifest-has "fkb-fallback-required-for-native") 1) 32))))

    (defn rapb-bit-manifest-2 ()
        (sum (list
            (rapb-score (eq (rapb-manifest-has "deopt-anchor-observability") 1) 64)
            (rapb-score (eq (rapb-manifest-has "no-disk-io") 1) 128)
            (rapb-score (eq (rapb-manifest-has "no-runtime-load") 1) 256)
            (rapb-score (eq (rapb-manifest-has "no-admission-policy") 1) 512)
            (rapb-score (eq (rapb-manifest-has "no-c-seed-growth") 1) 1024)
            (rapb-score (eq (rapb-manifest-has "no-seal-verification") 1) 2048))))

    (defn rapb-bit-invalid-source ()
        (do
            (let p (rapb-invalid-source-plan))
            (rapb-score
                (and (rapb-primary? p (rap-act-investigate))
                     (and (rapb-fallback? p (rap-act-none))
                          (and (eq (rap-plan-skip-parse p) 0)
                               (and (eq (rap-plan-skip-recompute p) 0)
                                    (not (rapb-primary? p (rap-act-compile-source)))))))
                4096)))

    (defn rapb-bit-unknown-kind ()
        (rapb-score (rapb-primary? (rapb-unknown-kind-plan) (rap-act-investigate)) 8192))

    (defn rapb-bit-hash-bad ()
        (rapb-score
            (rapb-primary? (rapb-plan (rapb-fkb-hash-bad) (sad-no-artifact)) (rap-act-compile-source))
            16384))

    (defn rapb-bit-missing ()
        (do
            (let p (rapb-plan (sad-no-artifact) (sad-no-artifact)))
            (rapb-score
                (and (rapb-primary? p (rap-act-compile-source))
                     (eq (rap-plan-skip-parse p) 0))
                32768)))

    (defn rapb-bit-mtime-boundary ()
        (rapb-score
            (and (rapb-primary? (rapb-plan (rapb-fkb-stale) (sad-no-artifact)) (rap-act-compile-source))
                 (rapb-primary? (rapb-plan (rapb-fkb-equal) (sad-no-artifact)) (rap-act-run-program-image)))
            65536))

    (defn rapb-bit-fkb-plan ()
        (do
            (let p (rapb-plan (rapb-fkb-fresh) (sad-no-artifact)))
            (rapb-score
                (and (rapb-primary? p (rap-act-run-program-image))
                     (and (rapb-fallback? p (rap-act-compile-source))
                          (and (eq (rap-plan-skip-parse p) 1)
                               (and (eq (rap-plan-skip-recompute p) 0)
                                    (eq (rap-plan-deopt-anchor p) 1)))))
                131072)))

    (defn rapb-bit-native-plan ()
        (do
            (let p (rapb-plan (rapb-fkb-fresh) (rapb-dylib-fresh)))
            (rapb-score
                (and (rapb-primary? p (rap-act-run-native))
                     (and (rapb-fallback? p (rap-act-run-program-image))
                          (and (eq (rap-plan-skip-parse p) 1)
                               (and (eq (rap-plan-skip-recompute p) 1)
                                    (eq (rap-plan-deopt-anchor p) 1)))))
                262144)))

    (defn rapb-bit-dylib-soft-fail ()
        (rapb-score
            (and (rapb-primary? (rapb-plan (rapb-fkb-fresh) (rapb-dylib-unproven)) (rap-act-run-program-image))
                 (and (rapb-primary? (rapb-plan (rapb-fkb-fresh) (rapb-dylib-noncallable)) (rap-act-run-program-image))
                      (not (rapb-primary? (rapb-plan (rapb-fkb-fresh) (rapb-dylib-noncallable)) (rap-act-run-native)))))
            524288))

    (defn rapb-bit-dylib-stale-fkb ()
        (rapb-score
            (rapb-primary? (rapb-plan (rapb-fkb-stale) (rapb-dylib-fresh)) (rap-act-compile-source))
            1048576))

    (defn rapb-bit-quarantine ()
        (rapb-score
            (and (rapb-primary? (rapb-plan (rapb-fkb-seal-bad) (sad-no-artifact)) (rap-act-compile-source))
                 (and (rapb-primary? (rapb-plan (rapb-fkb-fresh) (rapb-dylib-seal-bad)) (rap-act-compile-source))
                      (not (rapb-primary? (rapb-plan (rapb-fkb-fresh) (rapb-dylib-seal-bad)) (rap-act-run-program-image)))))
            2097152))

    (defn rapb-bit-source-newer ()
        (rapb-score
            (rapb-primary? (rapb-plan-newer (rapb-fkb-fresh) (rapb-dylib-fresh)) (rap-act-compile-source))
            4194304))

    (defn rapb-bit-route-skip-parity ()
        (rapb-score
            (and (rapb-valid-route-skip-parity? (rapb-source) (rapb-fkb-fresh) (sad-no-artifact))
                 (and (rapb-valid-route-skip-parity? (rapb-source) (rapb-fkb-stale) (sad-no-artifact))
                      (and (rapb-valid-route-skip-parity? (rapb-source) (rapb-fkb-fresh) (rapb-dylib-fresh))
                           (and (rapb-valid-route-skip-parity? (rapb-source) (rapb-fkb-fresh) (rapb-dylib-unproven))
                                (rapb-valid-route-skip-parity? (rapb-source) (sad-no-artifact) (sad-no-artifact))))))
            8388608))

    (defn rapb-bit-compile-output ()
        (do
            (let p-native-output (rapb-plan (rapb-fkb-hash-bad) (rapb-dylib-fresh)))
            (let p-no-dylib-output (rapb-plan (rapb-fkb-hash-bad) (rapb-dylib-nonlowerable)))
            (rapb-score
                (and (eq (sac-output-writes-fkb (rap-plan-compile-output p-native-output)) 1)
                     (and (eq (sac-output-no-c-growth (rap-plan-compile-output p-native-output)) 1)
                          (eq (sac-output-writes-dylib (rap-plan-compile-output p-no-dylib-output)) 0)))
                16777216)))

    (defn rapb-bit-native-anchor ()
        (do
            (let p-native (rapb-plan (rapb-fkb-fresh) (rapb-dylib-fresh)))
            (let p-no-anchor (rapb-plan (rapb-fkb-stale) (rapb-dylib-fresh)))
            (rapb-score
                (and (eq (rap-plan-deopt-anchor p-native) 1)
                     (not (and (rapb-primary? p-no-anchor (rap-act-run-native))
                               (eq (rap-plan-deopt-anchor p-no-anchor) 0))))
                33554432)))

    (defn runtime-artifact-plan-band ()
        (sum (list
            (rapb-bit-manifest-1)
            (rapb-bit-manifest-2)
            (rapb-bit-invalid-source)
            (rapb-bit-unknown-kind)
            (rapb-bit-hash-bad)
            (rapb-bit-missing)
            (rapb-bit-mtime-boundary)
            (rapb-bit-fkb-plan)
            (rapb-bit-native-plan)
            (rapb-bit-dylib-soft-fail)
            (rapb-bit-dylib-stale-fkb)
            (rapb-bit-quarantine)
            (rapb-bit-source-newer)
            (rapb-bit-route-skip-parity)
            (rapb-bit-compile-output)
            (rapb-bit-native-anchor))))

    (runtime-artifact-plan-band))
