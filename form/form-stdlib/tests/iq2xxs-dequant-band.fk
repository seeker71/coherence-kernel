; preludes: form-stdlib/core.fk form-stdlib/format-arith.fk form-stdlib/f16-decode.fk form-stdlib/iq2xxs-dequant.fk
;
; iq2xxs-dequant-band — GGUF type 16 (IQ2_XXS) dequant made falsifiable against REAL DeepSeek bytes.
;
; RADIUS (`aporon`). CPU dequant of the 66-byte/256-element IQ2_XXS superblock. Three real blocks are
; embedded verbatim from the DeepSeek V4 Flash file (their absolute byte offsets, from gguf-manifest.fk's
; tensor table, are recorded below); a wrong offset or a byte off would falsify the weight values. GPU
; emission is out of radius (the next stone).
;
; UNISPAN (not one sample). Three blocks from TWO tensors and THREE regions of the file:
;   a  blk.0.ffn_down_exps  expert0  block0    off 1155498592   (head, ~1.15 GB in)
;   b  blk.0.ffn_down_exps  expert100 block0   off 1371767392   (distant, +100 experts)
;   c  blk.9.ffn_gate_exps  expert0  block0    off 23628579424   (second tensor, ~23.6 GB in)
; Each block is checked at 9 indices spanning all eight 32-groups and the sign/scale paths,
; plus a full 256-list length+last-element check. Every bit is an independent claim.
;
; GROUND TRUTH is an INDEPENDENT from-spec Python oracle (iq2xxs_oracle.py): it transcribes the same
; published ggml grid/ksigns constants but unpacks with REAL bit-shifts (the recipe uses div/mod
; identities). Expected values are round(w*1e6). Agreement is therefore a cross-check of the arithmetic
; translation, not a re-read of the recipe. Bit-exact: 1073741823 when every claim lands.
;
;        1  block a at i=0 -> -17369
;        2  block a at i=7 -> -17369
;        4  block a at i=8 -> -17369
;        8  block a at i=31 -> -17369
;       16  block a at i=64 -> -26263
;       32  block a at i=96 -> -22762
;       64  block a at i=128 -> -7284
;      128  block a at i=200 -> -39150
;      256  block a at i=255 -> 26263
;      512  block a full i=255 -> 26263
;     1024  block b at i=0 -> -10079
;     2048  block b at i=7 -> -54175
;     4096  block b at i=8 -> 31497
;     8192  block b at i=31 -> 10079
;    16384  block b at i=64 -> -8466
;    32768  block b at i=96 -> -41173
;    65536  block b at i=128 -> 26458
;   131072  block b at i=200 -> 10079
;   262144  block b at i=255 -> -7660
;   524288  block b full i=255 -> -7660
;   1048576  block c at i=0 -> 10890
;   2097152  block c at i=7 -> -10890
;   4194304  block c at i=8 -> 10890
;   8388608  block c at i=31 -> 34031
;   16777216  block c at i=64 -> -8597
;   33554432  block c at i=96 -> 70857
;   67108864  block c at i=128 -> -9744
;   134217728  block c at i=200 -> 17768
;   268435456  block c at i=255 -> -30449
;   536870912  block c full i=255 -> -30449

(do
    ; --- block a: blk.0.ffn_down_exps.weight  expert0  block0 (head)  (abs off 1155498592) ---
    (let a (list
        151 16 0 0 108 0 169 13 41 252 57 175 49 216 199 72 128 64 125 99 230 146
        119 164 34 112 192 244 91 203 127 81 187 97 94 112 226 66 29 154 169 98 9 185
        72 17 132 78 254 144 203 96 175 92 138 202 192 104 167 5 13 171 223 55 133 120
        ))
    ; --- block b: blk.0.ffn_down_exps.weight  expert100 block0 (distant)  (abs off 1371767392) ---
    (let b (list
        155 14 254 149 159 0 117 210 140 193 0 109 32 58 154 59 30 251 62 52 152 250
        43 54 5 160 248 157 193 35 45 224 10 147 24 23 242 165 130 87 222 164 152 113
        126 224 18 252 49 161 133 138 64 133 59 232 129 202 116 170 130 53 199 77 113 158
        ))
    ; --- block c: blk.9.ffn_gate_exps.weight  expert0  block0 (2nd tensor)  (abs off 23628579424) ---
    (let c (list
        178 16 58 82 217 132 26 132 180 147 0 58 21 72 58 16 244 224 12 88 66 6
        57 120 139 121 29 28 138 132 170 206 91 182 234 106 63 248 35 72 85 140 75 235
        8 9 241 245 143 166 0 210 145 0 102 240 102 244 247 65 140 145 88 233 113 142
        ))
    (let full_a (iq2-dequant a 0))
    (let full_b (iq2-dequant b 0))
    (let full_c (iq2-dequant c 0))
    (let k0 (if (eq (round (mul (iq2-at a 0 0) 1000000.0)) -17369) 1 0))
    (let k1 (if (eq (round (mul (iq2-at a 0 7) 1000000.0)) -17369) 2 0))
    (let k2 (if (eq (round (mul (iq2-at a 0 8) 1000000.0)) -17369) 4 0))
    (let k3 (if (eq (round (mul (iq2-at a 0 31) 1000000.0)) -17369) 8 0))
    (let k4 (if (eq (round (mul (iq2-at a 0 64) 1000000.0)) -26263) 16 0))
    (let k5 (if (eq (round (mul (iq2-at a 0 96) 1000000.0)) -22762) 32 0))
    (let k6 (if (eq (round (mul (iq2-at a 0 128) 1000000.0)) -7284) 64 0))
    (let k7 (if (eq (round (mul (iq2-at a 0 200) 1000000.0)) -39150) 128 0))
    (let k8 (if (eq (round (mul (iq2-at a 0 255) 1000000.0)) 26263) 256 0))
    (let k9 (if (and (eq (len full_a) 256) (eq (round (mul (nth full_a 255) 1000000.0)) 26263)) 512 0))
    (let k10 (if (eq (round (mul (iq2-at b 0 0) 1000000.0)) -10079) 1024 0))
    (let k11 (if (eq (round (mul (iq2-at b 0 7) 1000000.0)) -54175) 2048 0))
    (let k12 (if (eq (round (mul (iq2-at b 0 8) 1000000.0)) 31497) 4096 0))
    (let k13 (if (eq (round (mul (iq2-at b 0 31) 1000000.0)) 10079) 8192 0))
    (let k14 (if (eq (round (mul (iq2-at b 0 64) 1000000.0)) -8466) 16384 0))
    (let k15 (if (eq (round (mul (iq2-at b 0 96) 1000000.0)) -41173) 32768 0))
    (let k16 (if (eq (round (mul (iq2-at b 0 128) 1000000.0)) 26458) 65536 0))
    (let k17 (if (eq (round (mul (iq2-at b 0 200) 1000000.0)) 10079) 131072 0))
    (let k18 (if (eq (round (mul (iq2-at b 0 255) 1000000.0)) -7660) 262144 0))
    (let k19 (if (and (eq (len full_b) 256) (eq (round (mul (nth full_b 255) 1000000.0)) -7660)) 524288 0))
    (let k20 (if (eq (round (mul (iq2-at c 0 0) 1000000.0)) 10890) 1048576 0))
    (let k21 (if (eq (round (mul (iq2-at c 0 7) 1000000.0)) -10890) 2097152 0))
    (let k22 (if (eq (round (mul (iq2-at c 0 8) 1000000.0)) 10890) 4194304 0))
    (let k23 (if (eq (round (mul (iq2-at c 0 31) 1000000.0)) 34031) 8388608 0))
    (let k24 (if (eq (round (mul (iq2-at c 0 64) 1000000.0)) -8597) 16777216 0))
    (let k25 (if (eq (round (mul (iq2-at c 0 96) 1000000.0)) 70857) 33554432 0))
    (let k26 (if (eq (round (mul (iq2-at c 0 128) 1000000.0)) -9744) 67108864 0))
    (let k27 (if (eq (round (mul (iq2-at c 0 200) 1000000.0)) 17768) 134217728 0))
    (let k28 (if (eq (round (mul (iq2-at c 0 255) 1000000.0)) -30449) 268435456 0))
    (let k29 (if (and (eq (len full_c) 256) (eq (round (mul (nth full_c 255) 1000000.0)) -30449)) 536870912 0))
    (add k29 (add k28 (add k27 (add k26 (add k25 (add k24 (add k23 (add k22 (add k21 (add k20 (add k19 (add k18 (add k17 (add k16 (add k15 (add k14 (add k13 (add k12 (add k11 (add k10 (add k9 (add k8 (add k7 (add k6 (add k5 (add k4 (add k3 (add k2 (add k1 k0))))))))))))))))))))))))))))))
