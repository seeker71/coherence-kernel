; runtime-artifact-selector-band.fk -- Layer 9b selector coherence witness.
;
; Expected: 2147483647
;
; This band proves plan-row selection only. It does not read or write disk, load
; or run `.fkb`, load or call `.dylib`, execute native bytes, verify seals,
; recheck proof/callable receipts, decide source-runner admission, install a
; `fkwu` selector, or grow the C seed.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/source-artifact-cache.fk form/form-stdlib/source-artifact-descriptor.fk form/form-stdlib/runtime-artifact-plan.fk form/form-stdlib/runtime-artifact-selector.fk

(do
    (defn rasb-score (ok bit) (if ok bit 0))
    (defn rasb-manifest-has (name)
        (runtime-artifact-selector-manifest-has? name (runtime-artifact-selector-manifest)))

    (defn rasb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn rasb-invalid-source () (sad-source "" "sha:src-a" 100))
    (defn rasb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn rasb-fkb-stale ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 99 1 1))
    (defn rasb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn rasb-native-plan ()
        (rap-plan-from-descriptors (rasb-source) (rasb-fkb-fresh) (rasb-dylib-fresh)))
    (defn rasb-fkb-plan ()
        (rap-plan-from-descriptors (rasb-source) (rasb-fkb-fresh) (sad-no-artifact)))
    (defn rasb-compile-plan ()
        (rap-plan-from-descriptors (rasb-source) (sad-no-artifact) (sad-no-artifact)))
    (defn rasb-stale-plan ()
        (rap-plan-from-descriptors (rasb-source) (rasb-fkb-stale) (rasb-dylib-fresh)))
    (defn rasb-investigate-plan ()
        (rap-plan-from-descriptors (rasb-invalid-source) (rasb-fkb-fresh) (sad-no-artifact)))
    (defn rasb-select (p) (ras-selection-from-plan p))

    (defn rasb-status? (s status)
        (str_eq (ras-selection-status s) status))
    (defn rasb-selected-action? (s action)
        (str_eq (ras-selection-selected s) action))
    (defn rasb-fallback? (s action)
        (str_eq (ras-selection-fallback s) action))
    (defn rasb-reason? (s reason)
        (str_eq (ras-selection-reason s) reason))

    (defn rasb-bit-manifest-1 ()
        (sum (list
            (rasb-score (eq (rasb-manifest-has "selection-face-not-execution") 1) 1)
            (rasb-score (eq (rasb-manifest-has "consumes-rap-plan-only") 1) 2)
            (rasb-score (eq (rasb-manifest-has "plan-coherence-gate") 1) 4)
            (rasb-score (eq (rasb-manifest-has "no-descriptor-route-derivation") 1) 8)
            (rasb-score (eq (rasb-manifest-has "total-selection-row") 1) 16)
            (rasb-score (eq (rasb-manifest-has "selected-investigate-refused-statuses") 1) 32)
            (rasb-score (eq (rasb-manifest-has "malformed-refused-incoherent-investigates") 1) 64)
            (rasb-score (eq (rasb-manifest-has "no-disk-io") 1) 128))))

    (defn rasb-bit-manifest-2 ()
        (sum (list
            (rasb-score (eq (rasb-manifest-has "no-runtime-load") 1) 256)
            (rasb-score (eq (rasb-manifest-has "no-native-execution") 1) 512)
            (rasb-score (eq (rasb-manifest-has "no-seal-verification") 1) 1024)
            (rasb-score (eq (rasb-manifest-has "no-proof-callable-reverify") 1) 2048)
            (rasb-score (eq (rasb-manifest-has "no-admission-policy") 1) 4096)
            (rasb-score (eq (rasb-manifest-has "no-c-seed-growth") 1) 8192)
            (rasb-score (eq (rasb-manifest-has "no-fkwu-selector-install") 1) 16384)
            (rasb-score (eq (rasb-manifest-has "no-route-rederivation") 1) 32768))))

    (defn rasb-bit-malformed-refused ()
        (do
            (let s (rasb-select (list "runtime-artifact-plan" (sac-run-dylib) (rap-act-run-native))))
            (rasb-score
                (and (rasb-status? s (ras-status-refused))
                     (and (rasb-selected-action? s (rap-act-none))
                          (rasb-reason? s (ras-reason-malformed-plan))))
                65536)))

    (defn rasb-bit-native-selected ()
        (do
            (let s (rasb-select (rasb-native-plan)))
            (rasb-score
                (and (rasb-status? s (ras-status-selected))
                     (and (rasb-selected-action? s (rap-act-run-native))
                          (and (rasb-fallback? s (rap-act-run-program-image))
                               (and (eq (ras-selection-skip-parse s) 1)
                                    (and (eq (ras-selection-skip-recompute s) 1)
                                         (rasb-reason? s (ras-reason-selected-native)))))))
                131072)))

    (defn rasb-bit-fkb-selected ()
        (do
            (let s (rasb-select (rasb-fkb-plan)))
            (rasb-score
                (and (rasb-status? s (ras-status-selected))
                     (and (rasb-selected-action? s (rap-act-run-program-image))
                          (and (rasb-fallback? s (rap-act-compile-source))
                               (and (eq (ras-selection-skip-parse s) 1)
                                    (and (eq (ras-selection-skip-recompute s) 0)
                                         (rasb-reason? s (ras-reason-selected-program-image)))))))
                262144)))

    (defn rasb-bit-compile-selected ()
        (do
            (let s1 (rasb-select (rasb-compile-plan)))
            (let s2 (rasb-select (rasb-stale-plan)))
            (rasb-score
                (and (rasb-status? s1 (ras-status-selected))
                     (and (rasb-selected-action? s1 (rap-act-compile-source))
                          (and (rasb-fallback? s1 (rap-act-none))
                               (and (eq (ras-selection-skip-parse s1) 0)
                                    (and (eq (ras-selection-skip-recompute s1) 0)
                                         (and (rasb-reason? s1 (ras-reason-selected-compile-source))
                                              (rasb-status? s2 (ras-status-selected))))))))
                524288)))

    (defn rasb-bit-upstream-investigate ()
        (do
            (let s (rasb-select (rasb-investigate-plan)))
            (rasb-score
                (and (rasb-status? s (ras-status-investigate))
                     (and (rasb-selected-action? s (rap-act-investigate))
                          (and (not (rasb-status? s (ras-status-selected)))
                               (rasb-reason? s (ras-reason-upstream-investigate)))))
                1048576)))

    (defn rasb-bit-incoherent-native ()
        (do
            (let p (rap-plan (sac-run-dylib) (rap-act-run-native) (rap-act-run-program-image) 1 0 1 (rap-no-output)))
            (let s (rasb-select p))
            (rasb-score
                (and (rasb-status? s (ras-status-investigate))
                     (and (rasb-selected-action? s (rap-act-investigate))
                          (rasb-reason? s (ras-reason-incoherent-native))))
                2097152)))

    (defn rasb-bit-incoherent-fkb ()
        (do
            (let p (rap-plan (sac-run-fkb) (rap-act-run-program-image) (rap-act-none) 1 0 1 (rap-no-output)))
            (let s (rasb-select p))
            (rasb-score
                (and (rasb-status? s (ras-status-investigate))
                     (rasb-reason? s (ras-reason-incoherent-program-image)))
                4194304)))

    (defn rasb-bit-incoherent-compile ()
        (do
            (let p (rap-plan (sac-run-source-compile) (rap-act-compile-source) (rap-act-none) 0 0 1 (rap-no-output)))
            (let s (rasb-select p))
            (rasb-score
                (and (rasb-status? s (ras-status-investigate))
                     (rasb-reason? s (ras-reason-incoherent-compile-source)))
                8388608)))

    (defn rasb-bit-unknown-primary ()
        (do
            (let p (rap-plan 99 "run-sideways" (rap-act-none) 0 0 0 (rap-no-output)))
            (let s (rasb-select p))
            (rasb-score
                (and (rasb-status? s (ras-status-investigate))
                     (rasb-reason? s (ras-reason-unknown-primary)))
                16777216)))

    (defn rasb-bit-skip-preserved ()
        (do
            (let n (rasb-select (rasb-native-plan)))
            (let f (rasb-select (rasb-fkb-plan)))
            (let c (rasb-select (rasb-compile-plan)))
            (rasb-score
                (and (eq (ras-selection-skip-parse n) (rap-plan-skip-parse (rasb-native-plan)))
                     (and (eq (ras-selection-skip-recompute n) (rap-plan-skip-recompute (rasb-native-plan)))
                          (and (eq (ras-selection-skip-parse f) (rap-plan-skip-parse (rasb-fkb-plan)))
                               (and (eq (ras-selection-skip-recompute f) (rap-plan-skip-recompute (rasb-fkb-plan)))
                                    (and (eq (ras-selection-skip-parse c) 0)
                                         (eq (ras-selection-skip-recompute c) 0))))))
                33554432)))

    (defn rasb-bit-matrix-parity ()
        (do
            (let n (rasb-select (rasb-native-plan)))
            (let f (rasb-select (rasb-fkb-plan)))
            (let c (rasb-select (rasb-compile-plan)))
            (let i (rasb-select (rasb-investigate-plan)))
            (rasb-score
                (and (rasb-selected-action? n (rap-act-run-native))
                     (and (rasb-selected-action? f (rap-act-run-program-image))
                          (and (rasb-selected-action? c (rap-act-compile-source))
                               (and (rasb-status? i (ras-status-investigate))
                                    (not (rasb-status? i (ras-status-selected)))))))
                67108864)))

    (defn rasb-bit-hand-built-plan ()
        (do
            (let p (rap-plan (sac-run-dylib) (rap-act-run-native) (rap-act-run-program-image) 1 1 1 (rap-no-output)))
            (let s (rasb-select p))
            (rasb-score
                (and (rasb-status? s (ras-status-selected))
                     (rasb-selected-action? s (rap-act-run-native)))
                134217728)))

    (defn rasb-bit-route-mismatch ()
        (do
            (let p (rap-plan (sac-run-fkb) (rap-act-run-native) (rap-act-run-program-image) 1 1 1 (rap-no-output)))
            (let s (rasb-select p))
            ; junk route probe: 99 matches no route constant. The old probe was
            ; (list 3) — junk by TYPE — which PR #273's exact comparisons turned
            ; from "eq answers false" into a loud type refusal on all three
            ; kernels (as_int: [3]); a type-junk route is no longer expressible
            ; as data, so the probe now speaks junk by VALUE.
            (let q (rap-plan 99 (rap-act-run-native) (rap-act-run-program-image) 1 1 1 (rap-no-output)))
            (let t (rasb-select q))
            (rasb-score
                (and (rasb-status? s (ras-status-investigate))
                     (and (rasb-reason? s (ras-reason-route-mismatch))
                          (and (rasb-status? t (ras-status-investigate))
                               (rasb-reason? t (ras-reason-route-mismatch)))))
                268435456)))

    (defn rasb-bit-no-two-step-fallback ()
        (do
            (let n (rasb-select (rasb-native-plan)))
            (let f (rasb-select (rasb-fkb-plan)))
            (let c (rasb-select (rasb-compile-plan)))
            (rasb-score
                (and (rasb-fallback? n (rap-act-run-program-image))
                     (and (rasb-fallback? f (rap-act-compile-source))
                          (rasb-fallback? c (rap-act-none))))
                536870912)))

    (defn rasb-bit-selection-row-shape ()
        (do
            (let n (rasb-select (rasb-native-plan)))
            (let f (rasb-select (rasb-fkb-plan)))
            (let c (rasb-select (rasb-compile-plan)))
            (rasb-score
                (and (eq (len n) 8)
                     (and (eq (len f) 8)
                          (and (eq (len c) 8)
                               (and (ras-selection? n)
                                    (and (ras-selection? f)
                                         (ras-selection? c))))))
                1073741824)))

    (defn runtime-artifact-selector-band ()
        (sum (list
            (rasb-bit-manifest-1)
            (rasb-bit-manifest-2)
            (rasb-bit-malformed-refused)
            (rasb-bit-native-selected)
            (rasb-bit-fkb-selected)
            (rasb-bit-compile-selected)
            (rasb-bit-upstream-investigate)
            (rasb-bit-incoherent-native)
            (rasb-bit-incoherent-fkb)
            (rasb-bit-incoherent-compile)
            (rasb-bit-unknown-primary)
            (rasb-bit-skip-preserved)
            (rasb-bit-matrix-parity)
            (rasb-bit-hand-built-plan)
            (rasb-bit-route-mismatch)
            (rasb-bit-no-two-step-fallback)
            (rasb-bit-selection-row-shape))))

    (runtime-artifact-selector-band))
