; source-runtime-release-metrics-band.fk -- source-runtime release path is observable.
;
; preludes: form-stdlib/core.fk form-stdlib/engine.fk form-stdlib/form-fs.fk form-stdlib/source-runtime-release-metrics.fk
;
; Expected: 8388607

(do
    (defn srrmb-score (ok bit) (if ok bit 0))
    (defn srrmb-manifest-has (name)
        (source-runtime-release-metrics-manifest-has?
            name
            (source-runtime-release-metrics-manifest)))
    (defn srrmb-release-metric () (srrm-release-path-metric))
    (defn srrmb-inventory-metric () (srrm-inventory-metric))
    (defn srrmb-release-roundtrip () (srrm-roundtrip-metric (srrmb-release-metric)))

    (defn source-runtime-release-metrics-band ()
        (do
            (let release (srrmb-release-metric))
            (let inventory (srrmb-inventory-metric))
            (let families (srrm-bounded-family-rows))
            (let first-family (head families))
            (let roundtrip (srrm-roundtrip-metric release))
            (add
            (srrmb-score (eq (srrmb-manifest-has "source-inventory-native") 1) 1)
        (add
            (srrmb-score (eq (srrmb-manifest-has "release-path-sample") 1) 2)
        (add
            (srrmb-score (eq (srrmb-manifest-has "bounded-window-pressure") 1) 4)
        (add
            (srrmb-score (eq (srrmb-manifest-has "defn-let-visible") 1) 8)
        (add
            (srrmb-score (srrm-source-has-metric-section?) 16)
        (add
            (srrmb-score (and (srrm-source-has-metric-rule?)
                              (srrm-source-has-metric-reverse?)) 32)
        (add
            (srrmb-score (gt (srrm-metric-files inventory) 100) 64)
        (add
            (srrmb-score (eq (srrm-metric-files release) 8) 128)
        (add
            (srrmb-score (gt (srrm-metric-defn release) 0) 256)
        (add
            (srrmb-score (gt (srrm-metric-let release) 0) 512)
        (add
            (srrmb-score (gt (srrm-metric-sections release) 0) 1024)
        (add
            (srrmb-score (str_eq (srrm-metric-status release)
                                 "guide-not-gate") 2048)
        (add
            (srrmb-score (bmf-roundtrip-node-eq? roundtrip) 4096)
        (add
            (srrmb-score (eq (len (bmf-roundtrip-source roundtrip)) 13) 8192)
        (add
            (srrmb-score (srrm-has? (srrm-source-text) "\"defn\"") 16384)
        (add
            (srrmb-score (gt (add (srrm-metric-defn release)
                                  (srrm-metric-let release)) 0) 32768)
        (add
            (srrmb-score (str_eq (srrm-metric-status inventory)
                                 "paged-source-inventory") 65536)
        (add
            (srrmb-score (eq (srrmb-manifest-has "bounded-family-census") 1) 131072)
        (add
            (srrmb-score (eq (srrmb-manifest-has "full-inventory-paged") 1) 262144)
        (add
            (srrmb-score (eq (len families) 12) 524288)
        (add
            (srrmb-score (eq (srrm-metric-files inventory) 2297) 1048576)
        (add
            (srrmb-score (str_eq (srrm-full-inventory-status)
                                 "paged-source-inventory") 2097152)
            (srrmb-score (and (srrm-source-has-family-rule?)
                              (srrm-roundtrip-family-ok? first-family)) 4194304)))))))))))))))))))))))))

    (source-runtime-release-metrics-band)
)
