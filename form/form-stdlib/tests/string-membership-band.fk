; string-membership-band.fk — proves three-kernel parity on str_find, the
; string-MEMBERSHIP primitive (`needle in haystack` ⟺ str_find(haystack,
; needle, 0) >= 0) that the concept-matching SCORE recipe folds over already-
; tokenized keyword lists (endpoint_concept_match_score_demo, /api/utils/
; concept_match_score). The route's host tokenizes (regex _extract_keywords +
; lowercasing — text preprocessing); the kernel scores via this native.
;
; str_find lives in all three kernels (Rust main.rs, Go main.go, TS kernel.ts),
; each `(s needle from)` returning the byte/codeunit index or -1. For ASCII —
; all the concept tagger deals with (`[a-zA-Z]{3,}` keywords, lowercased) — the
; three byte/UTF-16-codeunit indexings agree exactly. This band drives str_find
; from Form over found / not-found / offset / boundary cases and asserts one
; aggregate number all three kernels must produce identically.

(do
    ;; Found at a known position. "hello world" — "world" begins at index 6.
    (let found-pos (str_find "hello world" "world" 0))          ; 6

    ;; Not found — the membership-fails sentinel. str_find returns -1.
    (let not-found (str_find "abc" "xyz" 0))                    ; -1

    ;; Found from a non-zero offset. "abcabc" — searching for "abc" from index
    ;; 1 skips the first match and finds the second at index 3.
    (let from-offset (str_find "abcabc" "abc" 1))               ; 3

    ;; Match at the very start — index 0, the falsy-looking-but-present case the
    ;; `>= 0` membership test (not truthiness) is built to handle correctly.
    (let at-start (str_find "energy flow" "energy" 0))          ; 0

    ;; Whole-string needle present (the name-bonus shape: a multi-word needle
    ;; found contiguously). "energy flow coherence" contains "energy flow" at 0.
    (let phrase (str_find "energy flow coherence" "energy flow" 0))  ; 0

    ;; Needle longer than a remaining tail — not found, -1 (boundary safety).
    (let overrun (str_find "ab" "abc" 0))                      ; -1

    ;; The membership predicate the recipe actually uses: str_find(...) >= 0.
    ;; Count how many of three needles are members of the haystack — the same
    ;; fold shape the forward/reverse scoring runs. "energy"(yes) "tissue"(no)
    ;; "flow"(yes) → 2.
    (defn member? (hay needle) (if (ge (str_find hay needle 0) 0) 1 0))
    (let membership-count
        (add (add (member? "energy flow field" "energy")
                  (member? "energy flow field" "tissue"))
             (member? "energy flow field" "flow")))             ; 2

    ;; Aggregate so kernel agreement is one number.
    ;;   found-pos        =  6
    ;;   not-found        = -1
    ;;   from-offset      =  3
    ;;   at-start         =  0
    ;;   phrase           =  0
    ;;   overrun          = -1
    ;;   membership-count =  2
    ;;   total = 6 + (-1) + 3 + 0 + 0 + (-1) + 2 = 9
    (add (add (add found-pos not-found) (add from-offset at-start))
         (add (add phrase overrun) membership-count)))
