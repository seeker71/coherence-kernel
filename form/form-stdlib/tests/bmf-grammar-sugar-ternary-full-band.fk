; bmf-grammar-sugar-ternary-full-band.fk -- ternary sugar and full-parse helper.
;
; Expected: 7

(do
  (defn s (ok bit) (if ok bit 0))
  (defn cat? (n name) (node_eq (node_category n) (bp name)))
  (let g (grammar "e" (list
    (rule3 "e" (p-cap "v" (p-ternary (p-ref "id") (p-ref "e"))) (t-splice "v"))
    (rule3 "id" (p-cap "v" (p-run "alnum")) (t-emit "ident" (list (t-splice "v")))))))
  (let n (g-parse-full g "a ? b : c"))
  (let p (g-match-rule g "id" (cursor-str "a trailing")))
  (let f (g-parse-full g "a trailing"))
  (sum (list
    (s (cat? n "UE-COND-TERNARY") 1)
    (s (and (rok? p) (eq (cur-pos (rok-cur p)) 1)) 2)
    (s (str_eq (node_value f) "PARSE-FAIL") 4))))
