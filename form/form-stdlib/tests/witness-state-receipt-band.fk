; preludes: form-stdlib/core.fk form-stdlib/nearest-shape.fk form-stdlib/classifier-eval.fk form-stdlib/co-learning.fk form-stdlib/co-learning-stream.fk form-stdlib/champion-challenger.fk form-stdlib/colearning-retire.fk form-stdlib/choice-receipt.fk form-stdlib/branch-choice-order.fk form-stdlib/choice-receipt-learning.fk form-stdlib/oracle-catalog.fk form-stdlib/text-summary-learning.fk form-stdlib/llm-feature-channel-floor.fk form-stdlib/android-mesh-learning.fk form-stdlib/witness-state-receipt.fk
;
; witness-state-receipt-band - live witness counters as Form-native receipts.
;
; Verdict 67108863 when every claim lands:
;   1    floor and north-star declarations exist
;   2    live witness present with frames
;   4    mic counter and organ are active
;   8    camera counter and samples are active
;   16   GPU readback counter and latency are active
;   32   receipt is summary-only and rejects raw-media privacy
;   64   observed live sample counters clear the count floor
;   128  exporter source is Form-native and not the Python helper
;   256  active samples lower into three valid android-mesh-learning rows
;   512  active media floor requires mic, camera, and GPU
;   1024 speech, vision, and multimodal routes become native-first
;   2048 heldout oracle retirement still requires enough samples
;   4096 witness counters produce valid heldout learner rows
;   8192 heldout rows score a challenger/champion history
;   16384 too few heldout rows keep the oracle teacher
;   32768 enough heldout native wins retire one narrow teacher
;   65536 native witness export rows are valid and summary-only
;   131072 fixture oracle labels are rejected
;   262144 source-backed oracle labels produce valid heldout rows
;   524288 source-backed native wins can retire one narrow teacher
;   1048576 live oracle process rows are valid and reject fixtures
;   2097152 source-backed labels must be covered by their live process rows
;   4194304 one emission cycle carries export, labels, processes, and heldout rows
;   8388608 continuous emission requires increasing export cycles
;   16777216 emission record status is pass for live increasing cycles
;   33554432 emission record status blocks stale cycles
(do
    (let organs (list "accelerometer" "camera" "gps" "gpu" "gyroscope" "light" "magnetometer" "mic" "network" "screen"))
    (let live-state
        (wsr-state
            "form-native-witness-state"
            1
            141
            7045
            28054
            2367
            99
            1412
            5084
            organs
            "summary-only/no-raw-audio-frame-buffer"))
    (let raw-state
        (wsr-state
            "form-native-witness-state"
            1
            141
            7045
            28054
            2367
            99
            1412
            5084
            organs
            "raw-media"))
    (let missing-gpu
        (wsr-state
            "form-native-witness-state"
            1
            141
            7045
            28054
            2367
            0
            0
            5084
            (list "camera" "mic")
            "summary-only/no-raw-audio-frame-buffer"))
    (let few (list (list 0 1) (list 0 1) (list 1 1)))
    (let speech-heldout (wsr-heldout-from-state "speech-transcribe" live-state 83 81 1 1))
    (let vision-heldout (wsr-heldout-from-state "vision-describe" live-state 84 82 1 1))
    (let multimodal-heldout (wsr-heldout-from-state "multimodal-align" live-state 86 80 0 1))
    (let gpu-heldout (wsr-heldout-from-state "gpu-readback-kernel" live-state 88 80 1 1))
    (let heldout-rows (list speech-heldout vision-heldout multimodal-heldout gpu-heldout))
    (let too-few-heldout (list speech-heldout vision-heldout multimodal-heldout))
    (let win-row (wsr-heldout-from-state "speech-transcribe" live-state 85 80 1 1))
    (let reached-heldout
        (list
            win-row win-row win-row win-row
            win-row win-row win-row win-row
            win-row win-row win-row win-row))
    (let native-export
        (wsr-export-row
            "native-witness-export"
            "substrate:receipt-cell"
            42
            141
            5084
            "sha256:live-summary-5084"
            "summary-only/no-raw-audio-frame-buffer"))
    (let raw-export
        (wsr-export-row
            "native-witness-export"
            "substrate:receipt-cell"
            42
            141
            5084
            "sha256:live-summary-5084"
            "raw-media"))
    (let speech-label (wsr-oracle-label "speech-transcribe" "whisper-oracle" "oracle:stt" "speech-present" 84 42 "mic:141" "summary-only/no-raw-audio-frame-buffer"))
    (let vision-label (wsr-oracle-label "vision-describe" "vision-oracle" "oracle:vision" "scene-present" 83 42 "camera:2367" "summary-only/no-frame"))
    (let multimodal-label (wsr-oracle-label "multimodal-align" "multimodal-oracle" "oracle:multimodal" "aligned" 82 42 "body:5084" "summary-only/no-raw-audio-frame-buffer"))
    (let gpu-label (wsr-oracle-label "gpu-readback-kernel" "gpu-oracle" "oracle:gpu" "readback-ok" 88 42 "gpu:99" "summary-only/no-buffer"))
    (let fixture-label (wsr-oracle-label "speech-transcribe" "fixture" "oracle:stt" "speech-present" 84 42 "mic:141" "summary-only/no-raw-audio-frame-buffer"))
    (let oracle-labels (list speech-label vision-label multimodal-label gpu-label))
    (let oracle-speech-row (wsr-heldout-from-oracle-label speech-label live-state 86 1))
    (let oracle-vision-row (wsr-heldout-from-oracle-label vision-label live-state 86 1))
    (let oracle-multimodal-row (wsr-heldout-from-oracle-label multimodal-label live-state 86 1))
    (let oracle-gpu-row (wsr-heldout-from-oracle-label gpu-label live-state 90 1))
    (let oracle-heldout-rows (list oracle-speech-row oracle-vision-row oracle-multimodal-row oracle-gpu-row))
    (let oracle-win-row (wsr-heldout-from-oracle-label speech-label live-state 86 1))
    (let oracle-reached-heldout
        (list
            oracle-win-row oracle-win-row oracle-win-row oracle-win-row
            oracle-win-row oracle-win-row oracle-win-row oracle-win-row
            oracle-win-row oracle-win-row oracle-win-row oracle-win-row))
    (let oracle-reached-labels
        (list
            speech-label speech-label speech-label speech-label
            speech-label speech-label speech-label speech-label
            speech-label speech-label speech-label speech-label))
    (let speech-process (wsr-oracle-process "speech-transcribe" "whisper-oracle" "oracle:stt" "running" 80 "summary-only/no-raw-audio-frame-buffer"))
    (let vision-process (wsr-oracle-process "vision-describe" "vision-oracle" "oracle:vision" "running" 80 "summary-only/no-frame"))
    (let multimodal-process (wsr-oracle-process "multimodal-align" "multimodal-oracle" "oracle:multimodal" "running" 80 "summary-only/no-raw-audio-frame-buffer"))
    (let gpu-process (wsr-oracle-process "gpu-readback-kernel" "gpu-oracle" "oracle:gpu" "running" 80 "summary-only/no-buffer"))
    (let fixture-process (wsr-oracle-process "speech-transcribe" "fixture" "oracle:stt" "running" 80 "summary-only/no-raw-audio-frame-buffer"))
    (let oracle-processes (list speech-process vision-process multimodal-process gpu-process))
    (let emission-cycle
        (wsr-emission-cycle
            42
            native-export
            oracle-labels
            oracle-processes
            oracle-heldout-rows
            "summary-only/no-raw-audio-frame-buffer"))
    (let next-export
        (wsr-export-row
            "native-witness-export"
            "substrate:receipt-cell"
            43
            142
            5100
            "sha256:live-summary-5100"
            "summary-only/no-raw-audio-frame-buffer"))
    (let next-speech-label (wsr-oracle-label "speech-transcribe" "whisper-oracle" "oracle:stt" "speech-present" 84 43 "mic:142" "summary-only/no-raw-audio-frame-buffer"))
    (let next-vision-label (wsr-oracle-label "vision-describe" "vision-oracle" "oracle:vision" "scene-present" 83 43 "camera:2380" "summary-only/no-frame"))
    (let next-multimodal-label (wsr-oracle-label "multimodal-align" "multimodal-oracle" "oracle:multimodal" "aligned" 82 43 "body:5100" "summary-only/no-raw-audio-frame-buffer"))
    (let next-gpu-label (wsr-oracle-label "gpu-readback-kernel" "gpu-oracle" "oracle:gpu" "readback-ok" 88 43 "gpu:100" "summary-only/no-buffer"))
    (let next-labels (list next-speech-label next-vision-label next-multimodal-label next-gpu-label))
    (let next-heldout-rows
        (list
            (wsr-heldout-from-oracle-label next-speech-label live-state 86 1)
            (wsr-heldout-from-oracle-label next-vision-label live-state 86 1)
            (wsr-heldout-from-oracle-label next-multimodal-label live-state 86 1)
            (wsr-heldout-from-oracle-label next-gpu-label live-state 90 1)))
    (let next-emission-cycle
        (wsr-emission-cycle
            43
            next-export
            next-labels
            oracle-processes
            next-heldout-rows
            "summary-only/no-raw-audio-frame-buffer"))
    (let stale-emission-cycle
        (wsr-emission-cycle
            41
            native-export
            oracle-labels
            oracle-processes
            oracle-heldout-rows
            "summary-only/no-raw-audio-frame-buffer"))

    (let c0
        (if (and
                (gt (len (wsr-floor)) 0)
                (gt (len (wsr-north-star)) 0))
            1
            0))
    (let c1
        (if (eq (wsr-live? live-state) 1)
            2
            0))
    (let c2
        (if (eq (wsr-mic-active? live-state) 1)
            4
            0))
    (let c3
        (if (eq (wsr-camera-active? live-state) 1)
            8
            0))
    (let c4
        (if (eq (wsr-gpu-active? live-state) 1)
            16
            0))
    (let c5
        (if (and
                (eq (wsr-summary-only? live-state) 1)
                (eq (wsr-summary-only? raw-state) 0))
            32
            0))
    (let c6
        (if (eq (wsr-count-floor? live-state 141 2367 99 5084) 1)
            64
            0))
    (let c7
        (if (eq (wsr-export-native? live-state) 1)
            128
            0))
    (let c8
        (if (and
                (eq (aml-active-lane-count (wsr-active-samples live-state)) 3)
                (eq (aml-all-summary-only? (wsr-active-samples live-state)) 1))
            256
            0))
    (let c9
        (if (and
                (eq (wsr-active-media-floor? live-state) 1)
                (eq (wsr-active-media-floor? missing-gpu) 0))
            512
            0))
    (let c10
        (if (eq (wsr-routes-native-first? live-state) 1)
            1024
            0))
    (let c11
        (if (and
                (eq (wsr-learning-ready? live-state) 1)
                (eq (wsr-heldout-retirement-ready? few 12 0) 0))
            2048
            0))
    (let c12
        (if (and
                (eq (wsr-heldout-learning-floor? live-state heldout-rows) 1)
                (eq (wsr-heldout-valid-count heldout-rows) 4))
            4096
            0))
    (let c13
        (if (and
                (eq (cc-champ-score (wsr-heldout-history heldout-rows)) 3)
                (eq (cc-chall-score (wsr-heldout-history heldout-rows)) 4))
            8192
            0))
    (let c14
        (if (and
                (eq (wsr-heldout-retire? too-few-heldout 12 0) 0)
                (str_eq (wsr-heldout-authority too-few-heldout 12 0) "third-party"))
            16384
            0))
    (let c15
        (if (eq (wsr-heldout-native-wins? reached-heldout 12 0) 1)
            32768
            0))
    (let c16
        (if (and
                (eq (wsr-export-valid? native-export) 1)
                (eq (wsr-export-valid? raw-export) 0))
            65536
            0))
    (let c17
        (if (and
                (eq (wsr-oracle-label-valid? speech-label native-export) 1)
                (eq (wsr-oracle-label-valid? fixture-label native-export) 0))
            131072
            0))
    (let c18
        (if (and
                (eq (wsr-source-backed-learning-floor? live-state native-export oracle-labels oracle-heldout-rows) 1)
                (and
                    (eq (wsr-oracle-heldout-valid? oracle-speech-row speech-label native-export) 1)
                    (eq (wsr-oracle-label-count oracle-labels native-export) 4)))
            262144
            0))
    (let c19
        (if (eq (wsr-source-backed-native-wins? live-state native-export oracle-reached-labels oracle-reached-heldout 12 0) 1)
            524288
            0))
    (let c20
        (if (and
                (eq (wsr-oracle-process-valid? speech-process) 1)
                (eq (wsr-oracle-process-valid? fixture-process) 0))
            1048576
            0))
    (let c21
        (if (and
                (eq (wsr-labels-covered? oracle-labels native-export oracle-processes) 1)
                (eq (wsr-labels-covered? (list fixture-label) native-export oracle-processes) 0))
            2097152
            0))
    (let c22
        (if (eq (wsr-emission-cycle-valid? live-state emission-cycle) 1)
            4194304
            0))
    (let c23
        (if (and
                (eq (wsr-continuous-emission-floor? live-state (list emission-cycle next-emission-cycle)) 1)
                (eq (wsr-emission-cycles-increasing? (list emission-cycle stale-emission-cycle)) 0))
            8388608
            0))
    (let c24
        (if (eq (wsr-emission-record-pass? live-state (list emission-cycle next-emission-cycle)) 1)
            16777216
            0))
    (let c25
        (if (str_eq (wsr-emission-record-status live-state (list emission-cycle stale-emission-cycle)) "blocked")
            33554432
            0))

    (sum (list c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17 c18 c19 c20 c21 c22 c23 c24 c25)))
