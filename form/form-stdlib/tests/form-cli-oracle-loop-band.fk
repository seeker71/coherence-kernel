; preludes: form-stdlib/confidence-weighted-vote.fk form-stdlib/lineage-discounted-vote.fk
; preludes: form-stdlib/form-cli-judge.fk form-stdlib/form-cli-oracle-loop.fk
;
; form-cli-oracle-loop-band — the oracle-regent loop made falsifiable: the LLM
; answers at least as oracle, the native answers only grounded-and-proven, the
; reference is lineage-honest, and every request trains the non-LLM lane.
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/confidence-weighted-vote.fk \
;          form/form-stdlib/lineage-discounted-vote.fk form/form-stdlib/form-cli-judge.fk \
;          form/form-stdlib/form-cli-oracle-loop.fk \
;          form/form-stdlib/tests/form-cli-oracle-loop-band.fk > /tmp/fcolb.fk
;      ./fkwu --src /tmp/fcolb.fk    ; -> 127
;
; Verdict 127 when the loop is honest.

(do
    (defn fcolb (ok bit) (if ok bit 0))
    (defn form-cli-oracle-loop-band ()
        (do
    ; the heir holds only grounded AND strong (fcj-grade 3 needs score > 75)
    (let c0 (fcolb (and (str_eq (fcol-answer-lane 1 76) "form-native")
                        (str_eq (fcol-answer-lane 1 75) "oracle-regent")) 1))
    ; ungrounded never answers, judged perfect or not — the regent floor stands
    (let c1 (fcolb (and (str_eq (fcol-answer-lane 0 100) "oracle-regent")
                        (str_eq (fcol-answer "n" "r" 0 100) "r")) 2))
    ; the reference fuses lineage-honest: kin fold, independents win
    (let kin-field (list (fcol-oracle-ballot "a" 2 "m") (fcol-oracle-ballot "a" 2 "m")
                         (fcol-oracle-ballot "b" 2 "l") (fcol-oracle-ballot "b" 2 "x")))
    (let c2 (fcolb (and (str_eq (fcol-reference kin-field (list "a" "b")) "b")
                        (eq (fcol-reference-trust kin-field (list "a" "b")) 4)) 4))
    ; the champion-challenger coin: 1 only when the native held the request
    (let c3 (fcolb (and (eq (fcol-coin 1 80) 1)
                        (and (eq (fcol-coin 1 60) 0) (eq (fcol-coin 0 100) 0))) 8))
    ; EVERY request captures the oracle/native pair — both lanes teach
    (let row-n (fcol-capture "q1" "ref" "nat" 1 80))
    (let row-r (fcol-capture "q2" "ref" "nat" 0 30))
    (let c4 (fcolb (and (str_eq (fcol-cap-lane row-n) "form-native")
                        (str_eq (fcol-cap-lane row-r) "oracle-regent")) 16))
    ; the captured row carries the full teacher pair + grade, both lanes
    (let c5 (fcolb (and (and (str_eq (fcol-cap-reference row-r) "ref")
                             (str_eq (fcol-cap-native row-r) "nat"))
                        (and (eq (fcol-cap-grade row-n) 3) (eq (fcol-cap-grade row-r) 1))) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (fcolb (eq (form-cli-oracle-loop-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (form-cli-oracle-loop-band))
