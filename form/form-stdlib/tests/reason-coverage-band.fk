; reason-coverage-band.fk -- witness explicit reason-manifest coverage.
;
; preludes: form-stdlib/core.fk form-stdlib/reason-coverage.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-table-payload-emit.fk form-stdlib/runtime-table-payload-attempt.fk
;
; Expected: 2147483647

(do
    (defn rcovb-score (ok bit) (if ok bit 0))
    (defn rcovb-manifest-has (name)
        (reason-coverage-manifest-has? name (reason-coverage-manifest)))
    (defn rcovb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn rcovb-read-file-any (primary fallback)
        (if (ge (file_size primary) 0)
            (read_file primary)
            (read_file fallback)))

    (defn rcovb-bit-manifest-1 ()
        (sum (list
            (rcovb-score (eq (rcovb-manifest-has "pure-list-coverage") 1) 1)
            (rcovb-score (eq (rcovb-manifest-has "explicit-reason-manifest-not-reflection") 1) 2)
            (rcovb-score (eq (rcovb-manifest-has "missing-reason-detection") 1) 4)
            (rcovb-score (eq (rcovb-manifest-has "unexpected-reason-detection") 1) 8)
            (rcovb-score (eq (rcovb-manifest-has "duplicate-observed-diagnostic") 1) 16)
            (rcovb-score (eq (rcovb-manifest-has "duplicate-expected-failure") 1) 32)
            (rcovb-score (eq (rcovb-manifest-has "deterministic-status-precedence") 1) 64)
            (rcovb-score (eq (rcovb-manifest-has "covered-predicate-no-missing-unexpected") 1) 128))))
    (defn rcovb-bit-manifest-2 ()
        (sum (list
            (rcovb-score (eq (rcovb-manifest-has "duplicate-observed-does-not-fail-covered") 1) 256)
            (rcovb-score (eq (rcovb-manifest-has "self-status-coverage") 1) 512)
            (rcovb-score (eq (rcovb-manifest-has "applies-to-layer-branches") 1) 1024)
            (rcovb-score (eq (rcovb-manifest-has "observed-from-real-invocations") 1) 2048)
            (rcovb-score (eq (rcovb-manifest-has "no-file-io") 1) 4096)
            (rcovb-score (eq (rcovb-manifest-has "no-dynamic-eval") 1) 8192)
            (rcovb-score (eq (rcovb-manifest-has "no-runtime-execution") 1) 16384)
            (rcovb-score (eq (rcovb-manifest-has "no-c-seed-growth") 1) 32768))))

    (defn rcovb-bit-generic-covered ()
        (do
            (let c (rcov-coverage (list "a" "b" "c") (list "a" "b" "c")))
            (rcovb-score
                (and (rcov-covered? c)
                     (str_eq (rcov-status c) (rcov-status-covered)))
                65536)))
    (defn rcovb-bit-missing ()
        (do
            (let c (rcov-coverage (list "a" "b" "c") (list "a" "c")))
            (rcovb-score
                (and (not (rcov-covered? c))
                     (and (str_eq (rcov-status c) (rcov-status-missing))
                          (eq (rcov-count "b" (rcov-missing-list c)) 1)))
                131072)))
    (defn rcovb-bit-unexpected ()
        (do
            (let c (rcov-coverage (list "a" "b") (list "a" "b" "z")))
            (rcovb-score
                (and (not (rcov-covered? c))
                     (and (str_eq (rcov-status c) (rcov-status-unexpected))
                          (eq (rcov-count "z" (rcov-unexpected-list c)) 1)))
                262144)))
    (defn rcovb-bit-duplicate-observed ()
        (do
            (let c (rcov-coverage (list "a" "b") (list "a" "b" "b")))
            (rcovb-score
                (and (rcov-covered? c)
                     (and (str_eq (rcov-status c) (rcov-status-duplicate-observed))
                          (eq (rcov-count "b" (rcov-duplicate-observed-list c)) 1)))
                524288)))
    (defn rcovb-bit-duplicate-expected ()
        (do
            (let c (rcov-coverage (list "a" "a") (list "a")))
            (rcovb-score
                (and (not (rcov-covered? c))
                     (and (str_eq (rcov-status c) (rcov-status-duplicate-expected))
                          (eq (rcov-count "a" (rcov-duplicate-expected-list c)) 1)))
                1048576)))
    (defn rcovb-bit-multi-failure-precedence ()
        (do
            (let c (rcov-coverage (list "a" "b" "b") (list "a" "z" "z")))
            (rcovb-score
                (and (str_eq (rcov-status c) (rcov-status-missing))
                (and (eq (rcov-count "b" (rcov-missing-list c)) 2)
                (and (eq (rcov-count "z" (rcov-unexpected-list c)) 2)
                (and (eq (rcov-count "b" (rcov-duplicate-expected-list c)) 1)
                     (eq (rcov-count "z" (rcov-duplicate-observed-list c)) 1)))))
                2097152)))
    (defn rcovb-bit-empty-covered ()
        (do
            (let c (rcov-coverage (empty) (empty)))
            (rcovb-score
                (and (rcov-covered? c)
                     (str_eq (rcov-status c) (rcov-status-covered)))
                4194304)))
    (defn rcovb-bit-row-accessors ()
        (do
            (let e (list "a"))
            (let o (list "a" "a"))
            (let c (rcov-coverage e o))
            (rcovb-score
                (and (rcov-coverage? c)
                (and (eq (len c) 8)
                (and (eq (len (rcov-expected c)) 1)
                (and (eq (len (rcov-observed c)) 2)
                     (str_eq (rcov-status c) (rcov-status-duplicate-observed))))))
                8388608)))
    (defn rcovb-status-observed ()
        (list
            (rcov-status (rcov-coverage (empty) (empty)))
            (rcov-status (rcov-coverage (list "a") (empty)))
            (rcov-status (rcov-coverage (list "a") (list "a" "z")))
            (rcov-status (rcov-coverage (list "a" "a") (list "a")))
            (rcov-status (rcov-coverage (list "a") (list "a" "a")))))
    (defn rcovb-bit-self-status-coverage ()
        (do
            (let c (rcov-coverage
                    (list (rcov-status-covered)
                          (rcov-status-missing)
                          (rcov-status-unexpected)
                          (rcov-status-duplicate-expected)
                          (rcov-status-duplicate-observed))
                    (rcovb-status-observed)))
            (rcovb-score (rcov-covered? c) 16777216)))

    (defn rcovb-rtta-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn rcovb-rtta-pif ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (rcovb-rtta-table)))
    (defn rcovb-rtta-pif-seal-bad ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      0
                      (rcovb-rtta-table)))
    (defn rcovb-rtta-pif-path-other ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/other.fkb" "sha:fkb-42" 101
                      1
                      (rcovb-rtta-table)))
    (defn rcovb-rtta-source () (pif-source-from-envelope (rcovb-rtta-pif)))
    (defn rcovb-rtta-fkb () (pif-descriptor-from-envelope (rcovb-rtta-pif)))
    (defn rcovb-rtta-selection ()
        (ras-selection-from-plan
            (rap-plan-from-descriptors (rcovb-rtta-source) (rcovb-rtta-fkb) (sad-no-artifact))))
    (defn rcovb-rtta-envelope ()
        (rale-envelope-from-selection (rcovb-rtta-source) (rcovb-rtta-fkb) (sad-no-artifact) (rcovb-rtta-selection)))
    (defn rcovb-rtta-compile-envelope ()
        (do
            (let src (sad-source "src/min42.fk" "sha:src-42" 100))
            (let sel (ras-selection-from-plan
                        (rap-plan-from-descriptors src (sad-no-artifact) (sad-no-artifact))))
            (rale-envelope-from-selection src (sad-no-artifact) (sad-no-artifact) sel)))
    (defn rcovb-rtta-path () "/tmp/program-image-table-payload-emit.payload")
    (defn rcovb-rtta-witness ()
        (rtta-table-payload-witness (rcovb-rtta-path) (pite-table-payload-from-envelope (rcovb-rtta-pif))))
    (defn rcovb-rtta-witness-bad-text ()
        (rtta-table-payload-witness (rcovb-rtta-path) "1 0 1 1 41 0 0 0\n"))
    (defn rcovb-rtta-witness-empty ()
        (rtta-table-payload-witness (rcovb-rtta-path) ""))
    (defn rcovb-rtta-run ()
        (rtta-supplied-table-run (rcovb-rtta-path) 42 257 0 (rao-obs-ok) "run"))
    (defn rcovb-rtta-run-empty-ok ()
        (rtta-supplied-table-run (rcovb-rtta-path) 42 0 0 (rao-obs-ok) "empty-ok"))
    (defn rcovb-rtta-run-path-other ()
        (rtta-supplied-table-run "/tmp/other.payload" 42 257 0 (rao-obs-ok) "wrong-path"))
    (defn rcovb-rtta-observed-reasons ()
        (list
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (list "runtime-artifact-load-envelope" 1) (rcovb-rtta-pif) (rcovb-rtta-witness) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-compile-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (list "program-image-fkb-envelope" 1) (rcovb-rtta-witness) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif-seal-bad) (rcovb-rtta-witness) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif-path-other) (rcovb-rtta-witness) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (list "runtime-table-payload-witness" 1) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness-empty) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness-bad-text) (rcovb-rtta-run)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness) (list "runtime-table-payload-supplied-run" 1)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness) (rcovb-rtta-run-path-other)))
            (rtta-bridge-reason (rtta-bridge-from-run (rcovb-rtta-envelope) (rcovb-rtta-pif) (rcovb-rtta-witness) (rcovb-rtta-run-empty-ok)))))
    (defn rcovb-bit-rtta-reason-coverage ()
        (do
            (let c (rcov-coverage (rtta-reason-manifest) (rcovb-rtta-observed-reasons)))
            (rcovb-score
                (and (rcov-covered? c)
                     (str_eq (rcov-status c) (rcov-status-covered)))
                33554432)))
    (defn rcovb-bit-rtta-incomplete-missing ()
        (do
            (let c (rcov-coverage (rtta-reason-manifest) (tail (rcovb-rtta-observed-reasons))))
            (rcovb-score
                (and (not (rcov-covered? c))
                     (and (str_eq (rcov-status c) (rcov-status-missing))
                          (eq (rcov-count (rtta-reason-table-run-bound) (rcov-missing-list c)) 1)))
                67108864)))
    (defn rcovb-bit-rtta-duplicate-observed-info ()
        (do
            (let c (rcov-coverage (rtta-reason-manifest)
                                  (cons (rtta-reason-empty-output) (rcovb-rtta-observed-reasons))))
            (rcovb-score
                (and (rcov-covered? c)
                     (and (str_eq (rcov-status c) (rcov-status-duplicate-observed))
                          (eq (rcov-count (rtta-reason-empty-output) (rcov-duplicate-observed-list c)) 1)))
                134217728)))
    (defn rcovb-bit-rtta-duplicate-expected-fails ()
        (do
            (let c (rcov-coverage (cons (rtta-reason-empty-output) (rtta-reason-manifest))
                                  (rcovb-rtta-observed-reasons)))
            (rcovb-score
                (and (not (rcov-covered? c))
                     (and (str_eq (rcov-status c) (rcov-status-duplicate-expected))
                          (eq (rcov-count (rtta-reason-empty-output) (rcov-duplicate-expected-list c)) 1)))
                268435456)))
    (defn rcovb-bit-static-boundary ()
        (do
            (let text (rcovb-read-file-any "form/form-stdlib/reason-coverage.fk"
                                            "../form/form-stdlib/reason-coverage.fk"))
            (rcovb-score
                (and (not (rcovb-has? text "read_file"))
                (and (not (rcovb-has? text "write_file"))
                (and (not (rcovb-has? text "write_form_binary"))
                (and (not (rcovb-has? text "read_form_binary"))
                (and (not (rcovb-has? text "recipe_to_bytes"))
                (and (not (rcovb-has? text "bytes_to_recipe"))
                (and (not (rcovb-has? text "dlopen"))
                     (not (rcovb-has? text "fk_run")))))))))
                536870912)))
    (defn rcovb-bit-mirror ()
        (do
            (let text (rcovb-read-file-any "form/form-stdlib/reason-coverage.fk"
                                            "../form/form-stdlib/reason-coverage.fk"))
            (rcovb-score
                (str_eq text (rcovb-read-file-any "grammars/reason-coverage.fk"
                                                   "../grammars/reason-coverage.fk"))
                1073741824)))

    (defn reason-coverage-band ()
        (sum (list
            (rcovb-bit-manifest-1)
            (rcovb-bit-manifest-2)
            (rcovb-bit-generic-covered)
            (rcovb-bit-missing)
            (rcovb-bit-unexpected)
            (rcovb-bit-duplicate-observed)
            (rcovb-bit-duplicate-expected)
            (rcovb-bit-multi-failure-precedence)
            (rcovb-bit-empty-covered)
            (rcovb-bit-row-accessors)
            (rcovb-bit-self-status-coverage)
            (rcovb-bit-rtta-reason-coverage)
            (rcovb-bit-rtta-incomplete-missing)
            (rcovb-bit-rtta-duplicate-observed-info)
            (rcovb-bit-rtta-duplicate-expected-fails)
            (rcovb-bit-static-boundary)
            (rcovb-bit-mirror))))

    (reason-coverage-band))
