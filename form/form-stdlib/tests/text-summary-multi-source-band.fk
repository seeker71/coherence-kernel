; preludes: form-stdlib/core.fk form-stdlib/nearest-shape.fk form-stdlib/classifier-eval.fk form-stdlib/choice-receipt.fk form-stdlib/branch-choice-order.fk form-stdlib/choice-receipt-learning.fk form-stdlib/oracle-catalog.fk form-stdlib/cell-log-store.fk form-stdlib/kernel-http.fk form-stdlib/http-parse.fk form-stdlib/http-request.fk form-stdlib/http-render.fk form-stdlib/http-server.fk form-stdlib/http-socket.fk form-stdlib/channel.fk form-stdlib/text-summary-learning.fk
;
; text-summary-multi-source-band - dynamic source-coordinate summary floor.
;
; Floor: file, file-backed store, socket-served route telemetry trace, production
; front-door telemetry samples, and stream pressure/ack/replay/producer-pacing
; windows all emit the same native source-coordinate receipt shape. The file
; lane reads a real checked-in source byte slice; the store lane writes to a
; temporary segmented cell-log store and reads the value back; the route lane
; sends a real TCP loopback request through kh-serve-listener and reads the
; native-kernel wire response; the stream lane writes and reads a .fkb channel
; cursor window with capacity, deferred-count pressure, ack cursor, replay cursor,
; and a physically delayed producer append after the ack.
;
; North star: file, store, route, and stream sources all feed one summary
; learner through dynamic coordinates: protocol, capability, locator, selector,
; offset, length, codec, carrier, floor, and north star. The current floor still
; names the next pressure honestly: production telemetry is carried as a sampled
; receipt row plus external public probe evidence until live external HTTP lands
; natively in every kernel.
;
; Verdict 65535 when every claim lands:
;   1     expanded floor and north-star declarations name source coordinates
;   2     file coordinate is ready host:file with dynamic slice coordinates
;   4     file receipt is valid and reads the real source prefix
;   8     store coordinate is ready store:query with dynamic key coordinates
;   16    store receipt is read from a real temporary segmented store
;   32    ready receipts are valid and aggregate claims/citations
;   64    route coordinate and receipt are ready from socket-served telemetry trace plus production front-door telemetry
;   128   stream coordinate and receipt are ready from pressure/ack/replay/producer-pacing window
;   256   file/store/route/stream request plans expose protocols and caps
;   512   multi-source summary passes existing summary quality gates
;   1024  summary claim and citation counts equal aggregated receipts
;   2048  multi-source CHOICE-RECEIPT is valid and keeps token cost
;   4096  receipt becomes a native training sample
;   8192  output envelope carries coordinates, receipts, summary, receipt, and metadata
;   16384 proof level names file/store/route/stream physical source floor
;   32768 all four coordinates are ready and none remain planned
(defn tsms-runtime-events-handler (request)
    (kh-response
        200
        (list
            (kh-header "Content-Type" "application/json")
            (kh-header "X-Form-Route" "runtime-events-summary"))
        (str_concat
            "{\"route\":\"runtime-events-summary\",\"handler\":\"tsms-runtime-events-handler\",\"request\":\""
            (str_concat (kh-request-path request) "\"}"))))
(defn tsms-contains (s needle) (ge (str_find s needle 0) 0))
(defn tsms-starts (s prefix)
    (if (lt (str_len s) (str_len prefix)) false (str_eq (substring s 0 (str_len prefix)) prefix)))

(do
    (let meta
        (tsl-meta
            89
            87
            58
            74
            (tsl-spectrum 79 91 75 9 42 97)
            95
            89
            86))

    (let file-coordinate (tsl-file-source-coordinate (tsl-real-source-path) 0 67))
    (let file-value
        (read_file_slice
            (tsl-source-coordinate-locator file-coordinate)
            (tsl-source-coordinate-offset file-coordinate)
            (tsl-source-coordinate-length file-coordinate)))
    (let file-receipt
        (tsl-source-data-receipt
            file-coordinate
            file-value
            (str_len file-value)
            1
            1
            "file byte-slice matched coordinate"))

    (let store-dir (str_concat (temp_dir) "/text-summary-multi-source-store.d"))
    (fs_rmdir store-dir)
    (let store-value
        "Store source receipt carries dynamic coordinate, claim count, citation count, and learning eligibility.")
    (let st0 (cls-open store-dir))
    (let st1 (cls-put st0 "summary/source/multi" store-value))
    (let store-read (cls-value (cls-get st1 "summary/source/multi")))
    (let store-coordinate (tsl-store-source-coordinate store-dir "summary/source/multi"))
    (let store-receipt
        (tsl-source-data-receipt
            store-coordinate
            store-read
            (str_len store-read)
            2
            2
            "cell-log-store cls-get returned the stored source value"))

    (let route-request-wire
        "GET /api/runtime/events HTTP/1.1\r\nHost: 127.0.0.1\r\nAccept: application/json\r\n\r\n")
    (let route-exact
        (kh-route
            "runtime-events-summary"
            "GET"
            "/api/runtime/events"
            9
            "tsms-runtime-events-handler"
            "Accept"
            25))
    (let route-registry (list (list "tsms-runtime-events-handler" tsms-runtime-events-handler)))
    (let srv (socket_listen 0))
    (let port (socket_port srv))
    (let cli (socket_connect "127.0.0.1" port))
    (let route-request-bytes (socket_send cli route-request-wire))
    (let route-start-ms (now_unix_ms))
    (let route-served (kh-serve-listener srv (list route-exact) route-registry 1))
    (let route-end-ms (now_unix_ms))
    (let route-wire (socket_recv cli 65536))
    (socket_close cli)
    (socket_close srv)
    (let route-body (tsl-http-wire-body route-wire))
    (let route-trace
        (tsl-socket-route-trace
            "GET"
            "/api/runtime/events"
            "runtime-events-summary"
            "tsms-runtime-events-handler"
            200
            route-request-bytes
            (str_len route-wire)
            (str_len route-body)
            "native-kernel"))
    (let route-telemetry
        (tsl-route-telemetry
            "loopback-front-door"
            "runtime-events-summary"
            "/api/runtime/events"
            route-start-ms
            route-end-ms
            (sub route-end-ms route-start-ms)
            route-served
            route-request-bytes
            (str_len route-wire)
            (str_len route-body)))
    (let frontdoor-telemetry
        (tsl-frontdoor-telemetry
            "production-front-door"
            "api.coherencycoin.com"
            "GET"
            "/api/runtime/endpoints/summary?limit=5"
            200
            "native-kernel"
            "api_runtime_endpoints_summary"
            "false"
            "absent"
            20260614050447
            70
            2347
            "a0b6cbdb894b4017-SIN"
            "application/json"))
    (let route-coordinate
        (tsl-route-source-coordinate
            "/api/runtime/events"
            "tsms-runtime-events-handler"))
    (let route-receipt
        (tsl-telemetry-route-source-data-receipt
            route-coordinate
            route-body
            route-trace
            route-telemetry
            2
            1
            "socket_listen/connect/send/serve/recv produced a native-kernel route telemetry trace"))

    (let stream-path (str_concat (temp_dir) "/text-summary-multi-source-stream.fkb"))
    (fs_remove stream-path)
    (channel-create stream-path)
    (channel-append stream-path (channel-message (intern_trivial_string "warmup event before cursor")))
    (let stream-pending-count 3)
    (let stream-window-count 2)
    (let stream-capacity 2)
    (let stream-deferred 1)
    (channel-append stream-path (channel-message (intern_trivial_string "runtime route response became summary source")))
    (channel-append stream-path (channel-message (intern_trivial_string "stream cursor window became summary source")))
    (let stream-before-ack-all (channel-read stream-path))
    (let stream-before-ack (channel-read-since stream-path 1))
    (let stream-event-a (node_value (channel-msg-payload (head (tail stream-before-ack-all)))))
    (let stream-event-b (node_value (channel-msg-payload (head (tail (tail stream-before-ack-all))))))
    (let stream-body (str_concat stream-event-a (str_concat "\n" stream-event-b)))
    (let stream-next-cursor (add 1 stream-window-count))
    (channel-append stream-path (channel-message (intern_trivial_string "deferred stream event released only after ack cursor")))
    (let stream-after-ack (channel-read-since stream-path stream-next-cursor))
    (let stream-coordinate (tsl-stream-source-coordinate stream-path "cursor:1"))
    (let stream-pressure
        (tsl-stream-pressure-receipt
            stream-path
            "cursor:1"
            stream-pending-count
            stream-window-count
            stream-capacity
            stream-deferred
            stream-deferred
            "backpressure/defer"
            "defer-over-capacity"))
    (let stream-ack-replay
        (tsl-stream-ack-replay-receipt
            stream-path
            1
            stream-next-cursor
            1
            stream-pending-count
            stream-window-count
            stream-deferred
            "ack-window"
            "replay-from-read-cursor"))
    (let stream-pacing
        (tsl-producer-pacing-receipt
            stream-path
            1
            stream-next-cursor
            stream-pending-count
            stream-window-count
            stream-deferred
            (len stream-after-ack)
            stream-capacity
            (sub (len stream-before-ack-all) 1)
            (len stream-after-ack)
            "paced-with-live-ack"
            "hold-deferred-until-ack-cursor-advances"))
    (let stream-receipt
        (tsl-ack-replay-stream-source-data-receipt
            stream-coordinate
            stream-body
            stream-pressure
            stream-ack-replay
            stream-next-cursor
            2
            2
            "producer accepted two payloads under capacity, held one deferred payload until ack cursor 3, then appended and replay-read the deferred payload"))
    (let coordinates (list file-coordinate store-coordinate route-coordinate stream-coordinate))
    (let ready-receipts (list file-receipt store-receipt route-receipt stream-receipt))
    (let summary (tsl-multi-source-summary ready-receipts meta))
    (let receipt (tsl-multi-source-receipt summary meta))
    (let receipt-sample (tsl-receipt-sample receipt "summary:multi-source-receipt"))
    (let output (tsl-multi-source-output coordinates ready-receipts summary receipt meta))

    (let file-plan (tsl-plan-request "text:summarize-file"))
    (let store-plan (tsl-plan-request "text:summarize-store"))
    (let route-plan (tsl-plan-request "text:summarize-route"))
    (let stream-plan (tsl-plan-request "text:summarize-stream"))
    (let route-frontdoor-ok (tsl-frontdoor-telemetry-valid? frontdoor-telemetry))
    (let stream-pacing-ok (tsl-producer-pacing-ready? stream-pacing))

    (let c0
        (if (and
                (eq (len (tsl-floor)) 5)
                (eq (len (tsl-north-star)) 5))
            1
            0))
    (let c1
        (if (and
                (str_eq (tsl-source-coordinate-protocol file-coordinate) "host:file")
                (and
                    (eq (tsl-source-coordinate-ready? file-coordinate) 1)
                    (and
                        (eq (tsl-source-coordinate-offset file-coordinate) 0)
                        (eq (tsl-source-coordinate-length file-coordinate) 67))))
            2
            0))
    (let c2
        (if (and
                (eq (tsl-source-data-valid? file-receipt) 1)
                (str_eq file-value "# text-summary-learning.form - native text summarizer learning lane"))
            4
            0))
    (let c3
        (if (and
                (str_eq (tsl-source-coordinate-protocol store-coordinate) "store:query")
                (and
                    (eq (tsl-source-coordinate-ready? store-coordinate) 1)
                    (str_eq (tsl-source-coordinate-selector store-coordinate) "summary/source/multi")))
            8
            0))
    (let c4
        (if (and
                (str_eq store-read store-value)
                (eq (tsl-source-data-valid? store-receipt) 1))
            16
            0))
    (let c5
        (if (and
                (eq (tsl-source-data-all-valid? ready-receipts) 1)
                (and
                    (eq (tsl-source-data-claims-total ready-receipts) 7)
                    (eq (tsl-source-data-citations-total ready-receipts) 6)))
            32
            0))
    (let c6
        (if (and
                (str_eq (tsl-source-coordinate-protocol route-coordinate) "kernel:route")
                (and
                    (eq (tsl-source-coordinate-ready? route-coordinate) 1)
                    (and
                        (str_eq (tsl-source-coordinate-carrier route-coordinate) "socket:kh-serve-listener+production-front-door-telemetry-trace")
                        (and
                            (eq route-served 0)
                            (and
                                (tsms-starts route-wire "HTTP/1.1 200 OK\r\n")
                                (and
                                    (tsms-contains route-wire "X-Form-Router: native-kernel\r\n")
                                    (and
                                        (eq (tsl-socket-route-trace-valid? route-trace) 1)
                                        (and
                                            (eq (tsl-route-telemetry-valid? route-telemetry) 1)
                                            (and
                                                (eq route-frontdoor-ok 1)
                                                (eq (tsl-source-data-valid? route-receipt) 1))))))))))
            64
            0))
    (let c7
        (if (and
                (str_eq (tsl-source-coordinate-protocol stream-coordinate) "stream:read")
                (and
                    (eq (tsl-source-coordinate-ready? stream-coordinate) 1)
                    (and
                        (str_eq (tsl-source-coordinate-carrier stream-coordinate) "channel:read-since+pressure-window+ack-replay+producer-pacing")
                        (and
                            (eq (len stream-before-ack-all) 3)
                            (and
                                (eq (len stream-before-ack) 2)
                                (and
                                    (eq (len stream-after-ack) 1)
                                    (and
                                        (eq (tsl-stream-pressure-ready? stream-pressure) 1)
                                        (and
                                            (eq (tsl-stream-pressure-deferred-count stream-pressure) 1)
                                            (and
                                                (eq (tsl-stream-ack-replay-ready? stream-ack-replay) 1)
                                                (and
                                                    (eq stream-pacing-ok 1)
                                                    (eq (tsl-source-data-valid? stream-receipt) 1)))))))))))
            128
            0))
    (let c8
        (if (and
                (str_eq (tsl-plan-protocol file-plan) "host:file")
                (and
                    (str_eq (tsl-plan-capability store-plan) "cap.store.query")
                    (and
                        (str_eq (tsl-plan-carrier route-plan) "socket:kh-serve-listener+production-front-door-telemetry-trace")
                        (str_eq (tsl-plan-carrier stream-plan) "channel:read-since+pressure-window+ack-replay+producer-pacing"))))
            256
            0))
    (let c9
        (if (eq (tsl-summary-pass? summary) 1)
            512
            0))
    (let c10
        (if (and
                (eq (tsl-summary-claims summary) (tsl-source-data-claims-total ready-receipts))
                (eq (tsl-summary-citations summary) (tsl-source-data-citations-total ready-receipts)))
            1024
            0))
    (let c11
        (if (and
                (cr-choice-receipt-valid? receipt)
                (eq (cr-receipt-cost receipt) 120))
            2048
            0))
    (let c12
        (if (and
                (str_eq (tsl-label receipt-sample) "form-native:summary")
                (eq (len (tsl-feature receipt-sample)) 6))
            4096
            0))
    (let c13
        (if (and
                (eq (len (tsl-multi-source-output-coordinates output)) 4)
                (and
                    (eq (len (tsl-multi-source-output-receipts output)) 4)
                    (and
                        (str_eq
                            (tsl-summary-kind (tsl-multi-source-output-summary output))
                            "multi-source-summary")
                        (and
                            (str_eq
                                (cr-receipt-expression (tsl-multi-source-output-receipt output))
                                "summarize-multi-source-receipts")
                            (eq (tsl-meta-trust (tsl-multi-source-output-meta output)) 89)))))
            8192
            0))
    (let c14
        (if (str_eq
                (tsl-multi-source-proof-level)
                "3-kernel-host-io-file-store-socket-production-front-door-telemetry-backpressure-ack-replay-producer-pacing-stream")
            16384
            0))
    (let c15
        (if (and
                (eq (tsl-source-coordinates-ready-count coordinates) 4)
                (eq (tsl-source-coordinates-planned-count coordinates) 0))
            32768
            0))

    (fs_remove stream-path)
    (fs_rmdir store-dir)
    (sum (list c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15)))
