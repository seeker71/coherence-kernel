; core-band.fk - witnessed direct-source core stdlib floor.
; Run:
;   ( cat form/form-stdlib/core.fk form/form-stdlib/tests/core-band.fk ) > /tmp/core-band.fk
;   ./fkwu --src /tmp/core-band.fk

(do
    (defn cb-inc (x) (add x 1))
    (defn cb-add (a b) (add a b))

    (defn cb-num-ok? ()
        (and
            (even? 4)
            (and
                (odd? 5)
                (and
                    (zero? 0)
                    (and
                        (positive? 3)
                        (and
                            (negative? (sub 0 2))
                            (and
                                (eq (plus 2 3) 5)
                                (and
                                    (eq (minus 7 2) 5)
                                    (and
                                        (eq (times 3 4) 12)
                                        (and
                                            (eq (divide 9 3) 3)
                                            (and
                                                (eq (abs (sub 0 9)) 9)
                                                (and
                                                    (eq (min2 3 8) 3)
                                                    (eq (max2 3 8) 8)))))))))))))

    (defn cb-list-shape-ok? ()
        (do
            (let xs (append (list 1 2) (list 3 4)))
            (let rev (reverse xs))
            (and
                (eq (len xs) 4)
                (and
                    (eq (head xs) 1)
                    (and
                        (eq (nth xs 3) 4)
                        (and
                            (eq (len (range 0 4)) 4)
                            (and
                                (eq (len (take 2 xs)) 2)
                                (and
                                    (eq (head (drop 2 xs)) 3)
                                    (and
                                        (eq (head rev) 4)
                                        (eq (nth rev 3) 1))))))))))

    (defn cb-list-agg-ok? ()
        (do
            (let xs (list 1 2 3 4))
            (and
                (eq (sum xs) 10)
                (and
                    (eq (product xs) 24)
                    (and
                        (eq (maximum xs) 4)
                        (eq (minimum xs) 1))))))

    (defn cb-higher-order-ok? ()
        (do
            (let xs (list 1 2 3))
            (let mapped (map cb-inc xs))
            (and
                (eq (head mapped) 2)
                (and
                    (eq (nth mapped 2) 4)
                    (and
                        (eq (foldl cb-add 0 xs) 6)
                        (eq (foldr cb-add 0 xs) 6))))))

    (defn cb-cell-ok? ()
        (do
            (let c (cell "value" 42 "origin" identity))
            (and
                (cell? c)
                (and
                    (str_eq (cell-kind c) "value")
                    (and
                        (eq (cell-value c) 42)
                        (and
                            (str_eq (cell-origin c) "origin")
                            (eq (cell-do c) 42)))))))

    (defn cb-task-ok? ()
        (do
            (let t (task-resolved 42))
            (and
                (task? t)
                (and
                    (task-ready? t)
                    (and
                        (str_eq (task-state t) "resolved")
                        (eq (task-await t) 42))))))

    (defn cb-semantic-ok? ()
        (do
            (let classes (core-classes))
            (let list-class (nth classes 1))
            (and
                (eq (core-check) 31)
                (and
                    (eq (core-class-count) 4)
                    (and
                        (str_eq (core-class-name list-class) "List")
                        (and
                            (str_eq (core-class-type-param list-class) "T")
                            (eq (core-method-count list-class) 16)))))))

    (defn cb-score (pred bit)
        (if pred bit 0))

    (defn core-band-check ()
        (add
            (cb-score (cb-num-ok?) 1)
            (add
                (cb-score (cb-list-shape-ok?) 2)
                (add
                    (cb-score (cb-list-agg-ok?) 4)
                    (add
                        (cb-score (cb-higher-order-ok?) 8)
                        (add
                            (cb-score (cb-cell-ok?) 16)
                            (add
                                (cb-score (cb-task-ok?) 32)
                                (add
                                    (cb-score (cb-semantic-ok?) 64)
                                    (cb-score (eq (assert (eq 1 1) "core assert true") 0) 128)))))))))

    (core-band-check))
