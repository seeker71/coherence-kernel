; preludes: form-stdlib/confidence-weighted-vote.fk form-stdlib/lineage-discounted-vote.fk
;
; lineage-discounted-vote-band — witness independence earned by disjoint lineage, made falsifiable.
;
; The form-stdlib twin of learn/tests/lineage-discounted-vote-band.fk (the twin-copy convention
; confidence-weighted-vote.fk already follows): kin agreeing fold to the strongest kin, independent
; lineages accumulate, kin disagreeing keep their voices, and the discount flips a verdict the
; lineage-blind fusion calls the other way.
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/confidence-weighted-vote.fk \
;          form/form-stdlib/lineage-discounted-vote.fk \
;          form/form-stdlib/tests/lineage-discounted-vote-band.fk > /tmp/ldvb-std.fk
;      ./fkwu --src /tmp/ldvb-std.fk    ; -> 127
;
; Verdict 127 when the fold is honest.

(do
    (defn ldvb (ok bit) (if ok bit 0))
    (defn lineage-discounted-vote-band ()
        (do
    ; kin agreeing fold to max (3), never sum (5)
    (let c0 (ldvb (eq (cw-weight-for (ldv-fold (list (ldv-ballot "a" 3 "m") (ldv-ballot "a" 2 "m"))) "a") 3) 1))
    ; independent lineages still sum (3+2)
    (let c1 (ldvb (eq (cw-weight-for (ldv-fold (list (ldv-ballot "a" 3 "m") (ldv-ballot "a" 2 "l"))) "a") 5) 2))
    ; THE FLIP: two kin (a) vs two independents (b) — lineage-blind cw ties 4-4
    ; and keeps the first candidate "a"; the discounted fusion calls "b"
    (let kin-field (list (ldv-ballot "a" 2 "m") (ldv-ballot "a" 2 "m")
                         (ldv-ballot "b" 2 "l") (ldv-ballot "b" 2 "x")))
    (let blind-field (list (list "a" 2) (list "a" 2) (list "b" 2) (list "b" 2)))
    (let c2 (ldvb (and (str_eq (cw-winner blind-field (list "a" "b")) "a")
                       (str_eq (ldv-winner kin-field (list "a" "b")) "b")) 4))
    ; kin disagreeing keep full weight each — the fine-tune's movement is information
    (let split (ldv-fold (list (ldv-ballot "a" 2 "m") (ldv-ballot "b" 2 "m"))))
    (let c3 (ldvb (and (eq (cw-weight-for split "a") 2) (eq (cw-weight-for split "b") 2)) 8))
    ; the discounted winning score flows through the proven cw- spine (b at 4)
    (let c4 (ldvb (eq (ldv-score kin-field (list "a" "b")) 4) 16))
    ; a single-lineage single-ballot field is untouched by the fold
    (let c5 (ldvb (and (str_eq (ldv-winner (list (ldv-ballot "a" 3 "m")) (list "a" "b")) "a")
                       (eq (ldv-score (list (ldv-ballot "a" 3 "m")) (list "a" "b")) 3)) 32))
    ; the cell's own self-check folds to its digit-place witness
    (let c6 (ldvb (eq (lineage-discounted-vote-check) 11111) 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (lineage-discounted-vote-band))
