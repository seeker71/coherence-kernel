; preludes: form-stdlib/core.fk form-stdlib/protocol-beliefs.fk
;
; protocol-beliefs-band — the belief binary, proven three-way: one self-contained
; binary carries the core belief system of the four living protocols (repair,
; arrival, satsang, the channel) as a NUMERIC model with cross-protocol
; shares-ground edges; every word arrives as a symbol pack at runtime.
; (docs/coherence-substrate/protocol-beliefs.form; live witness:
; scripts/protocol_beliefs_demo.sh — English + German from the same model.)
;
; Verdict 31 when the belief carrier holds:
;   1   THE MODEL RIDES — the emission carries the 20-row numeric belief table
;   2   THE CORE IS LANGUAGE-FREE — no protocol word is baked in the C: not
;       repair, arrival, satsang, witness, offer, channel — every word is pack
;   4   THE PACK DOOR — open(argv[1])/read load the chosen tongue at runtime
;   8   THE EDGES CROSS PROTOCOLS — the model's shares-ground edges connect
;       beliefs ACROSS protocols (repair's silence-is-information points into
;       satsang's silence-is-also-an-answer; satsang's concert points into
;       repair's only-execution-refutes) — one connected body, not four silos
;   16  DETERMINISTIC — two emissions are byte-identical (three-way agreement)
(do
    (let c (fbs-emit))

    (let c0 (if (ge (str_find c "static const long long model[20][3]" 0) 0) 1 0))

    (let c1 (if (eq (str_find c "repair" 0) (sub 0 1))
            (if (eq (str_find c "arrival" 0) (sub 0 1))
            (if (eq (str_find c "satsang" 0) (sub 0 1))
            (if (eq (str_find c "witness" 0) (sub 0 1))
            (if (eq (str_find c "offer" 0) (sub 0 1))
            (if (eq (str_find c "channel" 0) (sub 0 1)) 2 0) 0) 0) 0) 0) 0))

    (let c2 (if (ge (str_find c "open(argv[1]" 0) 0)
            (if (ge (str_find c "read(fd, pack" 0) 0) 4 0) 0))

    ; edges computed from the MODEL data itself: belief 6 (protocol 1) shares
    ; ground with line 19, whose row carries protocol 3 — a cross-protocol edge;
    ; and the reverse edge exists (19 -> 6); and belief 16 (proto 3) -> 9 (proto 1)
    (defn fbs-row-for (rows ln)
        (if (eq (nth (head rows) 0) ln) (head rows) (fbs-row-for (tail rows) ln)))
    (let m (fbs-model))
    (let c3 (if (eq (nth (fbs-row-for m 6) 2) 19)
            (if (eq (nth (fbs-row-for m 19) 1) 3)
            (if (eq (nth (fbs-row-for m 19) 2) 6)
            (if (eq (nth (fbs-row-for m 16) 2) 9)
            (if (eq (nth (fbs-row-for m 9) 1) 1) 8 0) 0) 0) 0) 0))

    (let c4 (if (str_eq c (fbs-emit)) 16 0))

    (add c0 (add c1 (add c2 (add c3 c4)))))
