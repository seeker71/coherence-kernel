; tests/python-bmf-eval-band.fk — G4 first attestation
;
; The closure/scope interpreter at form-stdlib/python-bmf-eval.fk walks
; PY-BMF-* recipes back to Python-runtime values. This band-test builds
; recipes directly (the way python-bmf-arithmetic-band.fk does) and walks
; them to values that CPython would compute for the same shape. No source
; parsing — that's G1+G3's gate. This test exists to prove G4 in isolation.
;
; Each cell builds a recipe whose CPython equivalent is named in a comment
; alongside; the asserted score-value is the expected runtime value plus a
; cell-specific offset to keep the aggregate sensitive to which arm broke.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/python-bmf.fk form-stdlib/python-bmf-eval.fk

(do
    ;; ---- recipe builders (sugar over intern_node) ---------------------

    (defn py-int-lit (n)
        (intern_node PY-BMF-INT (list (intern_trivial_int n))))

    (defn py-ident (name)
        (intern_node PY-BMF-IDENT (list (intern_trivial_string name))))

    (defn py-binop (left op right)
        (intern_node PY-BMF-BINOP
            (list left (intern_trivial_string op) right)))

    (defn py-compare (left op right)
        (intern_node PY-BMF-COMPARE
            (list left (intern_trivial_string op) right)))

    (defn py-return (expr)
        (intern_node PY-BMF-RETURN (list expr)))

    (defn py-assign (name value)
        (intern_node PY-BMF-ASSIGN
            (list (intern_trivial_string name) value)))

    (defn py-def (name params body)
        ;; DEF children: name-leaf, param-leaves..., body-recipe.
        ;; Build param-leaves from the string list, then concat with name + body.
        (do
            (let param-leaves
                (map (defn _mk (p) (intern_trivial_string p))
                     params))
            (intern_node PY-BMF-DEF
                (append
                    (cons (intern_trivial_string name) param-leaves)
                    (list body)))))

    (defn py-call (callee args)
        (intern_node PY-BMF-CALL
            (cons (intern_trivial_string callee) args)))

    (defn py-if (cond then-branch else-branch)
        (intern_node PY-BMF-IF
            (list cond then-branch else-branch)))

    (defn py-module (stmts)
        (intern_node PY-BMF-MODULE stmts))

    (defn mk-py-list (elems)
        (intern_node PY-BMF-LIST elems))

    (defn mk-py-subscript (obj idx)
        (intern_node PY-BMF-SUBSCRIPT (list obj idx)))

    (defn mk-py-aug-assign (name op delta)
        (intern_node PY-BMF-AUG-ASSIGN
            (list (intern_trivial_string name)
                  (intern_trivial_string op)
                  delta)))

    (defn mk-py-while (cond body-stmts)
        ;; WHILE children: cond-recipe, body-stmt-recipes... — flatten the
        ;; body list onto a (cond . body) child stream.
        (intern_node PY-BMF-WHILE (cons cond body-stmts)))

    (defn mk-py-if-stmt (cond body-stmts)
        ;; IF-STMT children: cond-recipe, body-stmt-recipes... — same
        ;; (cond . body) child stream as WHILE. Distinct from PY-BMF-IF,
        ;; the ternary *expression* (cond/then/else) py-if builds: this is
        ;; the statement-level `if cond:` whose body can `return`.
        (intern_node PY-BMF-IF-STMT (cons cond body-stmts)))

    (defn mk-leaf-str (s) (intern_trivial_string s))

    (defn mk-py-lambda (pms body)
        ;; LAMBDA children: param-leaves..., body-recipe (last child).
        ;; Naming note: the parameter is "pms" not "params" because
        ;; `params` is a reserved Form verb (builds a SEQUENCE block);
        ;; using it as a defn parameter silently truncates the arg list
        ;; at parse time.
        (do
            (let param-leaves (map mk-leaf-str pms))
            (intern_node PY-BMF-LAMBDA (append param-leaves (list body)))))

    (defn mk-py-str-lit (s)
        ;; PY-BMF-STRING wraps a trivial-string leaf; py-eval reads
        ;; node_value to recover the runtime string. Same shape as INT.
        (intern_node PY-BMF-STRING (list (intern_trivial_string s))))

    (defn mk-py-for (var iterable body-stmts)
        ;; FOR children: var-name-leaf, iterable-recipe, body-stmt-recipes...
        ;; The eval FOR arm binds var to each element of the evaluated
        ;; iterable and threads env through the body each pass.
        (intern_node PY-BMF-FOR
            (cons (intern_trivial_string var)
                  (cons iterable body-stmts))))

    (defn mk-py-method-call (obj mname args)
        ;; METHOD-CALL children: obj-recipe, method-name-leaf, arg-recipes...
        ;; A LIST receiver + list-method name (`result.append(x)`) lands in
        ;; the statement-level accumulator arm; other receivers route to
        ;; class-method dispatch.
        (intern_node PY-BMF-METHOD-CALL
            (cons obj
                  (cons (intern_trivial_string mname) args))))

    (defn mk-py-dict (pairs)
        ;; pairs is a flat (k1-recipe v1-recipe k2-recipe v2-recipe ...)
        ;; list; the interpreter expects exactly that shape.
        (intern_node PY-BMF-DICT pairs))

    ;; ---- cell 1: bare arithmetic — CPython: 7 + 3 = 10 ---------------

    (let cell1
        (py-binop (py-int-lit 7) "+" (py-int-lit 3)))
    (let cell1-value (py-eval cell1 (py-env-empty)))           ; 10
    (let cell1-score (if (eq cell1-value 10) 1000 0))

    ;; ---- cell 2: subtract, divide, mod — CPython:
    ;;   ((20 - 5) * 3) // 7  =  45 // 7  =  6 -------------------------

    (let cell2
        (py-binop
            (py-binop
                (py-binop (py-int-lit 20) "-" (py-int-lit 5))
                "*"
                (py-int-lit 3))
            "//"
            (py-int-lit 7)))
    (let cell2-value (py-eval cell2 (py-env-empty)))           ; 6
    (let cell2-score (if (eq cell2-value 6) 2000 0))

    ;; ---- cell 3: ident lookup — env says x=11; x*x → 121 ------------

    (let cell3
        (py-binop (py-ident "x") "*" (py-ident "x")))
    (let cell3-env (py-env-extend (py-env-empty) "x" 11))
    (let cell3-value (py-eval cell3 cell3-env))                ; 121
    (let cell3-score (if (eq cell3-value 121) 3000 0))

    ;; ---- cell 4: ASSIGN extends scope; subsequent stmt reads it.
    ;;   x = 6
    ;;   x * 7
    ;; CPython: 42 -------------------------------------------------------

    (let cell4
        (py-module
            (list
                (py-assign "x" (py-int-lit 6))
                (py-binop (py-ident "x") "*" (py-int-lit 7)))))
    (let cell4-value (py-run cell4))                           ; 42
    (let cell4-score (if (eq cell4-value 42) 4000 0))

    ;; ---- cell 5: def + call — closure walks back to value.
    ;;   def add(a, b):
    ;;       return a + b
    ;;   add(10, 20) + 5
    ;; CPython: 35 ------------------------------------------------------

    (let add-body
        (py-return (py-binop (py-ident "a") "+" (py-ident "b"))))

    (let cell5
        (py-module
            (list
                (py-def "add" (list "a" "b") add-body)
                (py-binop
                    (py-call "add" (list (py-int-lit 10) (py-int-lit 20)))
                    "+"
                    (py-int-lit 5)))))
    (let cell5-value (py-run cell5))                           ; 35
    (let cell5-score (if (eq cell5-value 35) 5000 0))

    ;; ---- cell 6: IF + COMPARE — branching on a comparison.
    ;;   def absdiff(a, b):
    ;;       return a - b if a >= b else b - a
    ;;   absdiff(7, 19)
    ;; CPython: 12 ------------------------------------------------------

    (let absdiff-body
        (py-return
            (py-if (py-compare (py-ident "a") ">=" (py-ident "b"))
                   (py-binop (py-ident "a") "-" (py-ident "b"))
                   (py-binop (py-ident "b") "-" (py-ident "a")))))

    (let cell6
        (py-module
            (list
                (py-def "absdiff" (list "a" "b") absdiff-body)
                (py-call "absdiff" (list (py-int-lit 7) (py-int-lit 19))))))
    (let cell6-value (py-run cell6))                           ; 12
    (let cell6-score (if (eq cell6-value 12) 6000 0))

    ;; ---- cell 7: recursive call — factorial.
    ;;   def fact(n):
    ;;       return 1 if n < 2 else n * fact(n - 1)
    ;;   fact(6)
    ;; CPython: 720 -----------------------------------------------------

    (let fact-body
        (py-return
            (py-if (py-compare (py-ident "n") "<" (py-int-lit 2))
                   (py-int-lit 1)
                   (py-binop (py-ident "n")
                             "*"
                             (py-call "fact"
                                 (list (py-binop (py-ident "n") "-" (py-int-lit 1))))))))

    (let cell7
        (py-module
            (list
                (py-def "fact" (list "n") fact-body)
                (py-call "fact" (list (py-int-lit 6))))))
    (let cell7-value (py-run cell7))                           ; 720
    (let cell7-score (if (eq cell7-value 720) 7000 0))

    ;; ---- cell 8: LIST + SUBSCRIPT — indexed access.
    ;;   xs = [10, 20, 30, 40]
    ;;   xs[2] + xs[0]
    ;; CPython: 30 + 10 = 40 ---------------------------------------------

    (let cell8
        (py-module
            (list
                (py-assign "xs"
                    (mk-py-list (list (py-int-lit 10) (py-int-lit 20)
                                   (py-int-lit 30) (py-int-lit 40))))
                (py-binop
                    (mk-py-subscript (py-ident "xs") (py-int-lit 2))
                    "+"
                    (mk-py-subscript (py-ident "xs") (py-int-lit 0))))))
    (let cell8-value (py-run cell8))                           ; 40
    (let cell8-score (if (eq cell8-value 40) 8000 0))

    ;; ---- cell 9: WHILE + AUG-ASSIGN — counted sum.
    ;;   total = 0
    ;;   i = 1
    ;;   while i <= 10:
    ;;       total += i
    ;;       i += 1
    ;;   total
    ;; CPython: 55 -------------------------------------------------------

    (let cell9
        (py-module
            (list
                (py-assign "total" (py-int-lit 0))
                (py-assign "i" (py-int-lit 1))
                (mk-py-while
                    (py-compare (py-ident "i") "<=" (py-int-lit 10))
                    (list
                        (mk-py-aug-assign "total" "+" (py-ident "i"))
                        (mk-py-aug-assign "i" "+" (py-int-lit 1))))
                (py-ident "total"))))
    (let cell9-value (py-run cell9))                           ; 55
    (let cell9-score (if (eq cell9-value 55) 9000 0))

    ;; ---- cell 10: LAMBDA — anonymous closure bound by ASSIGN.
    ;;   square = lambda n: n * n
    ;;   square(7) + square(3)
    ;; CPython: 49 + 9 = 58 ---------------------------------------------

    (let square-body
        (py-binop (py-ident "n") "*" (py-ident "n")))
    (let cell10
        (py-module
            (list
                (py-assign "square" (mk-py-lambda (list "n") square-body))
                (py-binop
                    (py-call "square" (list (py-int-lit 7)))
                    "+"
                    (py-call "square" (list (py-int-lit 3)))))))
    (let cell10-value (py-run cell10))                         ; 58
    (let cell10-score (if (eq cell10-value 58) 10000 0))

    ;; ---- cell 11: DICT + SUBSCRIPT — string-keyed lookup.
    ;;   d = {"a": 11, "b": 22, "c": 33}
    ;;   d["a"] + d["c"]
    ;; CPython: 11 + 33 = 44 --------------------------------------------

    (let cell11
        (py-module
            (list
                (py-assign "d"
                    (mk-py-dict
                        (list (mk-py-str-lit "a") (py-int-lit 11)
                              (mk-py-str-lit "b") (py-int-lit 22)
                              (mk-py-str-lit "c") (py-int-lit 33))))
                (py-binop
                    (mk-py-subscript (py-ident "d") (mk-py-str-lit "a"))
                    "+"
                    (mk-py-subscript (py-ident "d") (mk-py-str-lit "c"))))))
    (let cell11-value (py-run cell11))                         ; 44
    (let cell11-score (if (eq cell11-value 44) 11000 0))

    ;; ---- cell 12: nested LIST + WHILE iteration over indexed access.
    ;;   xs = [3, 5, 7, 9, 11]
    ;;   i = 0
    ;;   acc = 0
    ;;   while i < 5:
    ;;       acc += xs[i]
    ;;       i += 1
    ;;   acc
    ;; CPython: 3+5+7+9+11 = 35 -----------------------------------------

    (let cell12
        (py-module
            (list
                (py-assign "xs"
                    (mk-py-list (list (py-int-lit 3) (py-int-lit 5)
                                   (py-int-lit 7) (py-int-lit 9)
                                   (py-int-lit 11))))
                (py-assign "i" (py-int-lit 0))
                (py-assign "acc" (py-int-lit 0))
                (mk-py-while
                    (py-compare (py-ident "i") "<" (py-int-lit 5))
                    (list
                        (mk-py-aug-assign "acc" "+"
                            (mk-py-subscript (py-ident "xs") (py-ident "i")))
                        (mk-py-aug-assign "i" "+" (py-int-lit 1))))
                (py-ident "acc"))))
    (let cell12-value (py-run cell12))                         ; 35
    (let cell12-score (if (eq cell12-value 35) 12000 0))

    ;; ---- cell 13: return inside a statement-level `if` short-circuits.
    ;; The strange-minimal early-guard the substrate demos lean on, run on
    ;; BOTH its paths in one expression so a single cell pins the whole
    ;; boundary:
    ;;   def g(p):
    ;;       if p == 0:
    ;;           return 100
    ;;       return 10
    ;;   g(0) + g(5)
    ;; CPython: 100 + 10 = 110. If a `return` inside `if cond:` failed to
    ;; short-circuit the enclosing function (the pre-#2264 gap), g(0) would
    ;; fall through to `return 10` and the sum would collapse to 20 — so
    ;; this cell reads exactly the return-signal the IF-STMT arm threads
    ;; through py-eval-body-loop / py-eval-module-loop. The guard-hit path
    ;; (p==0 → return short-circuits) and the guard-miss path (if skipped →
    ;; fallthrough return) are both exercised. A multi-statement body is a
    ;; PY-BMF-MODULE the DEF closure walks via the MODULE arm's module-loop.
    (let g-body
        (py-module
            (list
                (mk-py-if-stmt
                    (py-compare (py-ident "p") "==" (py-int-lit 0))
                    (list (py-return (py-int-lit 100))))
                (py-return (py-int-lit 10)))))
    (let cell13
        (py-module
            (list
                (py-def "g" (list "p") g-body)
                (py-binop
                    (py-call "g" (list (py-int-lit 0)))
                    "+"
                    (py-call "g" (list (py-int-lit 5)))))))
    (let cell13-value (py-run cell13))                         ; 110
    (let cell13-score (if (eq cell13-value 110) 13000 0))

    ;; ---- cell 14: FOR + list `.append` accumulator — the softmax shape.
    ;; This is the strange-minimal cell that pins list-construction inside a
    ;; recipe: `result = []` seeded empty, `for v in [1,2,3]:` builds the list
    ;; element by element via `result.append(v*v)`, and `sum(result)` reduces
    ;; the GROWN list to a scalar the band can compare three-way. Before the
    ;; accumulator arm, `result.append(...)` lowered to a class-method dispatch
    ;; (record_get "__class__") and failed on the plain list; now it rebinds
    ;; `result` to the extended list each pass.
    ;;   result = []
    ;;   for v in [1, 2, 3]:
    ;;       result.append(v * v)
    ;;   sum(result)
    ;; CPython: 1 + 4 + 9 = 14 ------------------------------------------
    (let cell14
        (py-module
            (list
                (py-assign "result" (mk-py-list (empty)))
                (mk-py-for "v"
                    (mk-py-list (list (py-int-lit 1) (py-int-lit 2) (py-int-lit 3)))
                    (list
                        (mk-py-method-call (py-ident "result") "append"
                            (list (py-binop (py-ident "v") "*" (py-ident "v"))))))
                (py-call "sum" (list (py-ident "result"))))))
    (let cell14-value (py-run cell14))                         ; 14
    (let cell14-score (if (eq cell14-value 14) 14000 0))

    ;; ---- aggregate ---------------------------------------------------
    ;; Cell-N awards N*1000 when its value matches CPython. Total when
    ;; every cell agrees: (1+2+...+14)*1000 = 105000.
    ;; Any single cell failing leaves the aggregate sensitive to which
    ;; arm broke — a cell-9 failure shows up as 105000-9000=96000, a
    ;; cell-14 (list-accumulator) regression as 105000-14000=91000.

    (sum (list cell1-score cell2-score cell3-score cell4-score
               cell5-score cell6-score cell7-score
               cell8-score cell9-score cell10-score
               cell11-score cell12-score cell13-score
               cell14-score)))
