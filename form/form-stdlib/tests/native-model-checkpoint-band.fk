; native-model-checkpoint-band.fk -- exact learned-weight persistence,
; reload, content/data binding, generation equivalence, and keep/revert proof.
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/format-arith.fk form-stdlib/f64-bytes.fk form-stdlib/transformer-numerics.fk form-stdlib/transformer-block.fk form-stdlib/transformer-backprop.fk form-stdlib/transformer-corpus-train.fk form-stdlib/neural-lm.fk form-stdlib/native-model-evidence.fk form-stdlib/native-model-live-training.fk form-stdlib/native-model-checkpoint.fk
;
; Verdict 4095.

(do
    (let transformer (nmck-fresh-transformer))
    (let lm (nmck-fresh-lm))
    (let text (nmck-checkpoint-text transformer lm))
    (let decoded (nmck-decode text))
    (let reloaded-transformer (nmck-decoded-transformer decoded))
    (let reloaded-lm (nmck-decoded-lm decoded))
    (let continued-transformer (nmck-continue-transformer reloaded-transformer))
    (let continued-lm (nmck-continue-lm reloaded-lm))
    (let improved (nmck-candidate-improves?
        reloaded-transformer reloaded-lm continued-transformer continued-lm))
    (let selected-transformer
        (if (eq improved 1) continued-transformer reloaded-transformer))
    (let selected-lm (if (eq improved 1) continued-lm reloaded-lm))
    (let embeddings (nmlt-lm-embeddings))
    (let original-generation (nl-gen lm embeddings (nl-emb embeddings 0) 6 0.00001))
    (let reloaded-generation (nl-gen reloaded-lm embeddings (nl-emb embeddings 0) 6 0.00001))

    (let c1 (if (eq (nmck-checkpoint-valid? text) 1) 1 0))
    (let c2 (if (eq (len (nmck-byte-values
                    (nmck-drop (nmck-lines (nmck-checkpoint-payload text)) 9))) 1536) 2 0))
    (let c3 (if (eq (str_len (nmfe-sha256 text)) 64) 4 0))
    (let c4 (if (eq (nmck-decoded-valid? decoded) 1) 8 0))
    (let c5 (if (eq (nmck-canonical-roundtrip? text) 1) 16 0))
    (let c6 (if (eq (nmck-transformer-heldout-loss-micro transformer)
                     (nmck-transformer-heldout-loss-micro reloaded-transformer)) 32 0))
    (let c7 (if (eq (nmck-lm-heldout-correct reloaded-lm) 6) 64 0))
    (let c8 (if (eq (nmck-list-eq? original-generation reloaded-generation) 1) 128 0))
    (let c9 (if (eq (nmck-checkpoint-valid? (str_concat text "0\n")) 0) 256 0))
    (let c10 (if (and
                    (le (nmck-transformer-heldout-loss-micro selected-transformer)
                        (nmck-transformer-heldout-loss-micro reloaded-transformer))
                    (ge (nmck-lm-heldout-correct selected-lm)
                        (nmck-lm-heldout-correct reloaded-lm))) 512 0))
    (let c11 (if (eq (nmck-f64-image-valid?
                        (list 0 0 0 0 0 0 240 127)) 0) 1024 0))
    (let c12 (if (ge (str_find (nmck-scope) "not-useful-generative-llm" 0) 0) 2048 0))

    (sum (list c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12)))
