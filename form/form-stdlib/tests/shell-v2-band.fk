; shell-v2-band.fk — proves the v2 executor: && / ||, $?, exit codes, and the
; expanded native builtin set. Verdict = 511 (all pass), asserted on the 4th kernel.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk

(do
    (let a1 (if (str_eq (sh-out "true && echo yes") "yes\n") 1 0))
    (let a2 (if (str_eq (sh-out "false || echo rec") "rec\n") 2 0))
    (let a3 (if (eq (sh-exit "false") 1) 4 0))
    (let a4 (if (eq (sh-exit "true") 0) 8 0))
    (let a5 (if (str_eq (sh-out "false ; echo $?") "1\n") 16 0))
    (let a6 (if (str_eq (sh-out "seq 3 | sort -r") "3\n2\n1\n") 32 0))
    (let a7 (if (str_eq (sh-out "echo HI | tr HI hi") "hi\n") 64 0))
    (let a8 (if (eq (sh-exit "test 2 -gt 1") 0) 128 0))
    (let a9 (if (str_eq (sh-out "echo 'a b'") "a b\n") 256 0))
    ; expected total: 511
    (add a1 (add a2 (add a3 (add a4 (add a5 (add a6 (add a7 (add a8 a9)))))))))
