; defdata-language-band.fk -- scannerless defdata authoring surface.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/defdata.fk form-stdlib/defdata-language.fk
;
; Expected: 8191

(do
    (defn ddlb-score (ok bit) (if ok bit 0))
    (defn ddlb-manifest-has (name)
        (defdata-language-manifest-has? name (defdata-language-manifest)))

    (defn defdata-language-band ()
        (do
            (let decl (ddl-parse "data rows = [8,13,21]"))
            (let loose (ddl-parse "data rows=[ 8 , 13 , 21 ]"))
            (let empty-decl (ddl-parse "data empty = []"))
            (let bad (ddl-parse "data rows = [8] trailing"))
            (let lower (ddl-lowering decl))
            (let empty-lower (ddl-lowering empty-decl))
            (add
                (ddlb-score (eq (ddlb-manifest-has "scannerless") 1) 1)
            (add
                (ddlb-score (eq (ddlb-manifest-has "no-line-grammar") 1) 2)
            (add
                (ddlb-score (ddl-ok? decl) 4)
            (add
                (ddlb-score (str_eq (ddl-name decl) "rows") 8)
            (add
                (ddlb-score (eq (ddl-value-count decl) 3) 16)
            (add
                (ddlb-score (eq (ddl-value-head decl) 8) 32)
            (add
                (ddlb-score (eq (nth (ddl-values decl) 2) 21) 64)
            (add
                (ddlb-score (eq (ddl-lowering-policy lower) (dd-inline)) 128)
            (add
                (ddlb-score (str_eq (ddl-lowering-kind lower) "module-constant") 256)
            (add
                (ddlb-score (str_eq (ddl-lowering-source lower) "(let rows (list 8 13 21))") 512)
            (add
                (ddlb-score (and (ddl-ok? loose) (eq (ddl-value-count loose) 3)) 1024)
            (add
                (ddlb-score (not (ddl-ok? bad)) 2048)
                (ddlb-score
                    (and (ddl-ok? empty-decl)
                         (and (eq (ddl-value-count empty-decl) 0)
                              (str_eq (ddl-lowering-source empty-lower) "(let empty (list))")))
                    4096)))))))))))))))

    (defdata-language-band))
