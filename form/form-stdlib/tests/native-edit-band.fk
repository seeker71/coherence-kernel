; native-edit-band.fk — four-way proof of native-edit's STRING layer (index,
; count, replace-first, replace-all) on synthetic strings. No host I/O, so the
; walkers (Go/Rust/TS) run it identically to fkwu. The file layer (ne-edit-unique
; / ne-edit-all) is fkwu-carrier and proven live by receipt.
;
; preludes: form-stdlib/core.fk form-stdlib/native-edit.fk
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/native-edit.fk \
;          form/form-stdlib/tests/native-edit-band.fk > /tmp/ne.fk
;      ./fkwu --src /tmp/ne.fk    ; -> 127
;
; Verdict 127 when every assertion holds.
(do
    (defn neb-score (ok bit) (if ok bit 0))
    (defn native-edit-band ()
        (do
            ; index: found mid-string, found-after-`from`, and not-found
            (let c0 (neb-score (eq (ne-index-of "hello world" "world" 0) 6) 1))
            (let c1 (neb-score (eq (ne-index-of "abcabc" "abc" 1) 3) 2))
            (let c2 (neb-score (eq (ne-index-of "abc" "xyz" 0) -1) 4))
            ; count: non-overlapping
            (let c3 (neb-score (eq (ne-count "abababab" "ab") 4) 8))
            ; replace-first vs replace-all
            (let c4 (neb-score (str_eq (ne-replace-first "a.b.c.d" "." "-") "a-b.c.d") 16))
            (let c5 (neb-score (str_eq (ne-replace-all "a.b.c.d" "." "-") "a-b-c-d") 32))
            ; replace-all where `new` contains `old` must NOT loop (rescans only the tail)
            (let c6 (neb-score (str_eq (ne-replace-all "xx" "x" "yy") "yyyy") 64))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6))))))))
    (native-edit-band))
