; preludes: form-stdlib/jit-tensor-emit.fk
;
; block-fwd-emit-band — the TRANSFORMER BLOCK FORWARD emitter as recipe, four-way. jte-block-fwd-msl authors
; the Metal kernel for one whole pre-LN block forward over a sequence — h = xs + Wo*attn(Wq*LN1(xs), Wk*LN1(xs),
; Wv*LN1(xs), scale) + bo ; y = h + W2*gelu(W1*LN2(h)+b1)+b2 — the INFERENCE half of transformer-block.fk's
; tb-block (proven four-way 511) lowered to the GPU. It composes the recipe's own folds: every dot is tb-dot's
; downward right-fold split through a named temporary (no fma contraction), the value-mix is tb-weighted-acc's
; forward fold, softmax is tn-softmax's max-subtract over the recipe's own fexp, each LayerNorm is the
; biased-variance + 50-step Newton tn-sqrt walk, gelu is fgelu. Dims arrive as runtime buffers, so the emitted
; source is one static string parameterized only by the kernel name. It COMPILES and RUNS on the M4 Max GPU
; (scripts/metal_block_audit.sh): GPU fp32 bit-exact vs a CPU fp32 mirror of the same folds, tracking the proven
; fp64 recipe within fp32 epsilon — the whole block now runs forward on the silicon.
;
; Verdict 7 when the emission lands:
;   1   the full emitted f32 MSL for form_block_fwd_f32 equals the canonical text
;   2   a different name lands in the same frame (emission is a function of the name)
;   4   two emissions of the same name are str_eq (deterministic text — same emission, same cell)
(do
    (let pre "float fexp_small(float x){ float n = 1.0f; float term = 1.0f; float acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } float fexp(float x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } float v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } float ftanh(float x){ float e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } float fgelu(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } float fgelud(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); float th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } kernel void ")
    (let post "(device const float* wq [[buffer(0)]], device const float* bq [[buffer(1)]], device const float* wk [[buffer(2)]], device const float* bk [[buffer(3)]], device const float* wv [[buffer(4)]], device const float* bv [[buffer(5)]], device const float* wo [[buffer(6)]], device const float* bo [[buffer(7)]], device const float* g1 [[buffer(8)]], device const float* be1 [[buffer(9)]], device const float* w1 [[buffer(10)]], device const float* b1 [[buffer(11)]], device const float* w2 [[buffer(12)]], device const float* b2 [[buffer(13)]], device const float* g2 [[buffer(14)]], device const float* be2 [[buffer(15)]], device const float* x [[buffer(16)]], device float* y [[buffer(17)]], device float* sc [[buffer(18)]], constant uint& S [[buffer(19)]], constant uint& d [[buffer(20)]], constant uint& dq [[buffer(21)]], constant uint& dv [[buffer(22)]], constant uint& hid [[buffer(23)]], constant float& scale [[buffer(24)]], constant float& eps [[buffer(25)]], uint gid [[thread_position_in_grid]]) { if (gid != 0u) return; uint oLN = 0; uint oQ = oLN + S * d; uint oK = oQ + S * dq; uint oV = oK + S * dq; uint oA = oV + S * dv; uint oH = oA + S * dv; uint oN2 = oH + S * d; uint oSR = oN2 + S * d; uint oE = oSR + S; uint oFA = oE + S; { uint s = 0; while (s < S) { float sm = 0.0f; uint j = 0; while (j < d) { sm = sm + x[s * d + j]; j += 1; } float mean = sm / float(d); float va = 0.0f; j = 0; while (j < d) { float dm = x[s * d + j] - mean; float dd = dm * dm; va = va + dd; j += 1; } float varv = va / float(d); float sdv = varv + eps; float g = sdv; uint it = 50; while (it > 0) { it -= 1; g = 0.5f * (g + sdv / g); } float inv = 1.0f / g; j = 0; while (j < d) { float nm = (x[s * d + j] - mean) * inv; float sg = nm * g1[j]; sc[oLN + s * d + j] = sg + be1[j]; j += 1; } s += 1; } } { uint s = 0; while (s < S) { uint r = 0; while (r < dq) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wq[r * d + c] * sc[oLN + s * d + c]; acc = p + acc; } sc[oQ + s * dq + r] = acc + bq[r]; r += 1; } s += 1; } } { uint s = 0; while (s < S) { uint r = 0; while (r < dq) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wk[r * d + c] * sc[oLN + s * d + c]; acc = p + acc; } sc[oK + s * dq + r] = acc + bk[r]; r += 1; } s += 1; } } { uint s = 0; while (s < S) { uint r = 0; while (r < dv) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = wv[r * d + c] * sc[oLN + s * d + c]; acc = p + acc; } sc[oV + s * dv + r] = acc + bv[r]; r += 1; } s += 1; } } { uint s = 0; while (s < S) { uint t = 0; while (t < S) { float acc = 0.0f; uint c = dq; while (c > 0) { c -= 1; float p = sc[oQ + s * dq + c] * sc[oK + t * dq + c]; acc = p + acc; } sc[oSR + t] = acc * scale; t += 1; } float mx = sc[oSR + 0]; t = 1; while (t < S) { if (sc[oSR + t] > mx) { mx = sc[oSR + t]; } t += 1; } float sumes = 0.0f; t = 0; while (t < S) { float e = fexp(sc[oSR + t] - mx); sc[oE + t] = e; sumes = sumes + e; t += 1; } float invs = 1.0f / sumes; t = 0; while (t < S) { sc[oSR + t] = sc[oE + t] * invs; t += 1; } uint i = 0; while (i < dv) { sc[oA + s * dv + i] = 0.0f; i += 1; } t = 0; while (t < S) { i = 0; while (i < dv) { float pv = sc[oV + t * dv + i] * sc[oSR + t]; sc[oA + s * dv + i] = sc[oA + s * dv + i] + pv; i += 1; } t += 1; } s += 1; } } { uint s = 0; while (s < S) { uint i = 0; while (i < d) { float acc = 0.0f; uint c = dv; while (c > 0) { c -= 1; float p = wo[i * dv + c] * sc[oA + s * dv + c]; acc = p + acc; } float o = acc + bo[i]; sc[oH + s * d + i] = x[s * d + i] + o; i += 1; } s += 1; } } { uint s = 0; while (s < S) { float sm = 0.0f; uint j = 0; while (j < d) { sm = sm + sc[oH + s * d + j]; j += 1; } float mean = sm / float(d); float va = 0.0f; j = 0; while (j < d) { float dm = sc[oH + s * d + j] - mean; float dd = dm * dm; va = va + dd; j += 1; } float varv = va / float(d); float sdv = varv + eps; float g = sdv; uint it = 50; while (it > 0) { it -= 1; g = 0.5f * (g + sdv / g); } float inv = 1.0f / g; j = 0; while (j < d) { float nm = (sc[oH + s * d + j] - mean) * inv; float sg = nm * g2[j]; sc[oN2 + s * d + j] = sg + be2[j]; j += 1; } s += 1; } } { uint s = 0; while (s < S) { uint k = 0; while (k < hid) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float p = w1[k * d + c] * sc[oN2 + s * d + c]; acc = p + acc; } sc[oFA + k] = fgelu(acc + b1[k]); k += 1; } uint i = 0; while (i < d) { float acc2 = 0.0f; uint kk = hid; while (kk > 0) { kk -= 1; float p2 = w2[i * hid + kk] * sc[oFA + kk]; acc2 = p2 + acc2; } float f = acc2 + b2[i]; y[s * d + i] = sc[oH + s * d + i] + f; i += 1; } s += 1; } } }")
    (let want (str_concat pre (str_concat "form_block_fwd_f32" post)))
    (let got (jte-block-fwd-msl "form_block_fwd_f32"))
    (let other (jte-block-fwd-msl "b2"))
    (let c0 (if (str_eq got want) 1 0))
    (let c1 (if (str_eq other (str_concat pre (str_concat "b2" post))) 2 0))
    (let c2 (if (str_eq (jte-block-fwd-msl "form_block_fwd_f32") got) 4 0))
    (add c0 (add c1 c2)))
