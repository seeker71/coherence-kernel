; tests/bml-generic-source-scanner-boundary-proof.fk
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves native file scanning is a generic source boundary. BML token names,
; keywords, properties, operators, and comments come from a Form lexicon; the
; sibling kernels keep only primitive byte scanning.

(do
    (defn score-bool (value bit)
        (if value bit 0))

    (defn score-int (actual expected bit)
        (if (eq actual expected) bit 0))

    (defn score-str (actual expected bit)
        (if (str_eq actual expected) bit 0))

    (let path "form-stdlib/tests/fixtures/bml-thesis-char-escapes.bml")
    (let bml-tokens (bml-source-scan-file path))
    (let alt-lexicon
        (list "source-lexicon"
              (empty)
              (list "return")
              "alt-keyword"
              "alt-property"
              "alt-name"
              "alt-int"
              "alt-float"
              "alt-string"
              "alt-char"
              "alt-op"
              (bml-source-ops 0)
              (bml-line-comment-prefix 0)
              (bml-block-comment-open 0)
              (bml-block-comment-close 0)))
    (let alt-tokens (source_scan_file path alt-lexicon))

    (sum
        (list
            (score-int (len bml-tokens) 24 1)
            (score-int (len alt-tokens) 24 2)
            (score-str (bmf-object-kind (head bml-tokens)) "bml-keyword" 4)
            (score-str (bmf-object-value (head bml-tokens)) "return" 8)
            (score-str (bmf-object-kind (head alt-tokens)) "alt-property" 16)
            (score-str (bmf-object-value (head alt-tokens)) "return" 32)
            (score-str (bmf-object-kind (nth alt-tokens 1)) "alt-char" 64)
            (score-str (bmf-object-kind (nth alt-tokens 2)) "alt-op" 128)
            (score-bool
                (not (str_eq
                        (bmf-object-kind (head bml-tokens))
                        (bmf-object-kind (head alt-tokens))))
                256))))
