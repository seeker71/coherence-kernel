; tests/typescript-bmf-lift-band.fk — TS source → recipe → value attestation
;
; The lifter at form-stdlib/typescript-bmf-lift.fk walks typescript-source-
; scan-text tokens into TS-BMF-EVAL-* / canonical MATH / COMPARE recipes that
; the closure interpreter (typescript-bmf-eval.fk) walks back to a value.
; This band drives the round-trip from real TypeScript expression strings.
;
; Every cell's expected value matches Node on the equivalent source.
; The aggregate is sensitive to which arm broke (per-cell offset).
;
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/typescript-bmf.fk form-stdlib/typescript-bmf-eval.fk form-stdlib/typescript-bmf-lift.fk

(do
    ;; ---- cell 1: bare expression — Node: 7 + 3 = 10 --------------------

    (let cell1-value (ts-bmf-run-expr-text "7 + 3"))
    (let cell1-score (if (eq cell1-value 10) 1000 0))

    ;; ---- cell 2: precedence — Node: 2 + 3 * 4 = 14 ---------------------

    (let cell2-value (ts-bmf-run-expr-text "2 + 3 * 4"))
    (let cell2-score (if (eq cell2-value 14) 2000 0))

    ;; ---- cell 3: parenthesised grouping — Node: (2 + 3) * 4 = 20 -------

    (let cell3-value (ts-bmf-run-expr-text "(2 + 3) * 4"))
    (let cell3-score (if (eq cell3-value 20) 3000 0))

    ;; ---- cell 4: mod + division — Node: 17 % 5 + 9 / 3 = 2 + 3 = 5 -----

    (let cell4-value (ts-bmf-run-expr-text "17 % 5 + 9 / 3"))
    (let cell4-score (if (eq cell4-value 5) 4000 0))

    ;; ---- cell 5: comparison — Node: 5 < 7 → true (walks to 1) ----------

    (let cell5-value (ts-bmf-run-expr-text "5 < 7"))
    (let cell5-score (if (eq cell5-value 1) 5000 0))

    ;; ---- cell 6: strict equality — Node: 2 + 2 === 4 → true (1) --------

    (let cell6-value (ts-bmf-run-expr-text "2 + 2 === 4"))
    (let cell6-score (if (eq cell6-value 1) 6000 0))

    ;; ---- cell 7: strict inequality — Node: 3 !== 3 → false (0) ---------

    (let cell7-value (ts-bmf-run-expr-text "3 !== 3"))
    (let cell7-score (if (eq cell7-value 0) 7000 0))

    ;; ---- cell 8: unary minus — Node: -5 + 8 = 3 ------------------------

    (let cell8-value (ts-bmf-run-expr-text "-5 + 8"))
    (let cell8-score (if (eq cell8-value 3) 8000 0))

    ;; ---- cell 9: CTOR Shape B Blueprint convergence --------------------
    ;; Same substrate-truth claim the python lift band carries (cells
    ;; 10-12 there): same shape → same Blueprint NodeID. A hand-built
    ;; MATH-PLUS recipe with TS-BMF-EVAL-INT-wrapped int leaves AND a
    ;; TypeScript-lifted `7 + 3` must node_eq to 1 — both content-address
    ;; to the canonical RBasic.MATH-12 inst=1 (plus) Blueprint.

    (let MATH-PLUS-REF (make_nodeid 1 2 12 1))
    (let handbuilt-plus
        (intern_node MATH-PLUS-REF
            (list (intern_node TS-BMF-EVAL-INT (list (intern_trivial_int 7)))
                  (intern_node TS-BMF-EVAL-INT (list (intern_trivial_int 3))))))
    (let lifted-plus (ts-lift-expr-text "7 + 3"))
    (let cell9-score (if (node_eq handbuilt-plus lifted-plus) 9000 0))

    ;; ---- cell 10: Blueprint convergence for COMPARE-LT ------------------

    (let COMPARE-LT-REF (make_nodeid 1 2 13 3))
    (let handbuilt-lt
        (intern_node COMPARE-LT-REF
            (list (intern_node TS-BMF-EVAL-INT (list (intern_trivial_int 5)))
                  (intern_node TS-BMF-EVAL-INT (list (intern_trivial_int 7))))))
    (let lifted-lt (ts-lift-expr-text "5 < 7"))
    (let cell10-score (if (node_eq handbuilt-lt lifted-lt) 10000 0))

    ;; ---- aggregate: 1000+...+8000 + 9000 + 10000 = 55000 ---------------

    (sum (list cell1-score cell2-score cell3-score
               cell4-score cell5-score cell6-score
               cell7-score cell8-score cell9-score
               cell10-score)))
