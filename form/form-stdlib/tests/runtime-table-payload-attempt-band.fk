; runtime-table-payload-attempt-band.fk -- witness table-payload runs become 9f attempts.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-table-payload-emit.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-table-payload-attempt.fk
;
; Expected: 2147483647

(do
    (defn rttab-score (ok bit) (if ok bit 0))
    (defn rttab-manifest-has (name)
        (runtime-table-payload-attempt-manifest-has? name (runtime-table-payload-attempt-manifest)))
    (defn rttab-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rttab-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn rttab-table ()
        (pif-table-image 1
                         (list 0)
                         1
                         (list (pif-node-row 1 42 0 0))
                         0
                         (empty)))
    (defn rttab-pif ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (rttab-table)))
    (defn rttab-pif-seal-bad ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      0
                      (rttab-table)))
    (defn rttab-pif-path-other ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/other.fkb" "sha:fkb-42" 101
                      1
                      (rttab-table)))
    (defn rttab-pif-content-other ()
        (pif-envelope "src/min42.fk" "sha:src-42" 100
                      "src/min42.fkb" "sha:other-fkb" 101
                      1
                      (rttab-table)))
    (defn rttab-pif-source-other ()
        (pif-envelope "src/min42.fk" "sha:other-src" 100
                      "src/min42.fkb" "sha:fkb-42" 101
                      1
                      (rttab-table)))
    (defn rttab-source () (pif-source-from-envelope (rttab-pif)))
    (defn rttab-fkb () (pif-descriptor-from-envelope (rttab-pif)))
    (defn rttab-selection ()
        (ras-selection-from-plan
            (rap-plan-from-descriptors (rttab-source) (rttab-fkb) (sad-no-artifact))))
    (defn rttab-envelope ()
        (rale-envelope-from-selection (rttab-source) (rttab-fkb) (sad-no-artifact) (rttab-selection)))
    (defn rttab-compile-envelope ()
        (do
            (let src (sad-source "src/min42.fk" "sha:src-42" 100))
            (let sel (ras-selection-from-plan
                        (rap-plan-from-descriptors src (sad-no-artifact) (sad-no-artifact))))
            (rale-envelope-from-selection src (sad-no-artifact) (sad-no-artifact) sel)))

    (defn rttab-table-path () "/tmp/program-image-table-payload-emit.payload")
    (defn rttab-table-payload () (pite-table-payload-from-envelope (rttab-pif)))
    (defn rttab-witness ()
        (rtta-table-payload-witness (rttab-table-path) (rttab-table-payload)))
    (defn rttab-witness-bad-text ()
        (rtta-table-payload-witness (rttab-table-path) "1 0 1 1 41 0 0 0\n"))
    (defn rttab-witness-empty ()
        (rtta-table-payload-witness (rttab-table-path) ""))
    (defn rttab-run (status first lines code)
        (rtta-supplied-table-run (rttab-table-path) first lines code status "supplied-table-run"))
    (defn rttab-run-path-other ()
        (rtta-supplied-table-run "/tmp/other-table.payload" 42 257 0 (rao-obs-ok) "wrong-path"))
    (defn rttab-bridge (status first lines code)
        (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness)
                              (rttab-run status first lines code)))
    (defn rttab-ready? (b) (str_eq (rtta-bridge-status b) (rtta-status-attempt-ready)))
    (defn rttab-investigate? (b) (str_eq (rtta-bridge-status b) (rtta-status-investigate)))
    (defn rttab-refused? (b) (str_eq (rtta-bridge-status b) (rtta-status-refused)))
    (defn rttab-reason? (b reason) (str_eq (rtta-bridge-reason b) reason))
    (defn rttab-no-attempt? (b) (rtta-no-attempt? (rtta-bridge-attempt b)))

    (defn rttab-receipt-from-bridge (b)
        (raar-receipt-from-envelope-attempt (rtta-bridge-envelope b) (rtta-bridge-attempt b)))
    (defn rttab-outcome-from-bridge (b)
        (do
            (let r (rttab-receipt-from-bridge b))
            (rao-outcome-from-selection-observation
                (raar-receipt-selection r)
                (raar-receipt-derived-observation r))))

    (defn rttab-bit-manifest-1 ()
        (sum (list
            (rttab-score (eq (rttab-manifest-has "table-payload-attempt-adapter-not-execution") 1) 1)
            (rttab-score (eq (rttab-manifest-has "supplied-table-run-only") 1) 2)
            (rttab-score (eq (rttab-manifest-has "binds-9e-8h-8i") 1) 4)
            (rttab-score (eq (rttab-manifest-has "table-payload-witness-marker") 1) 8)
            (rttab-score (eq (rttab-manifest-has "attempt-detail-marks-table-payload") 1) 16)
            (rttab-score (eq (rttab-manifest-has "identity-from-rale-envelope") 1) 32)
            (rttab-score (eq (rttab-manifest-has "text-equality-before-attempt") 1) 64)
            (rttab-score (eq (rttab-manifest-has "table-path-bound-to-witness-path") 1) 128))))
    (defn rttab-bit-manifest-2 ()
        (sum (list
            (rttab-score (eq (rttab-manifest-has "ok-requires-output-line") 1) 256)
            (rttab-score (eq (rttab-manifest-has "hard-and-unknown-status-preserved") 1) 512)
            (rttab-score (eq (rttab-manifest-has "oom-killed-investigates-through-9c") 1) 1024)
            (rttab-score (eq (rttab-manifest-has "no-binary-artifact-io") 1) 2048)
            (rttab-score (eq (rttab-manifest-has "no-program-image-load") 1) 4096)
            (rttab-score (eq (rttab-manifest-has "no-native-call") 1) 8192)
            (rttab-score (eq (rttab-manifest-has "no-selector-install") 1) 16384)
            (rttab-score (eq (rttab-manifest-has "no-c-seed-growth") 1) 32768)
            (rttab-score (eq (rttab-manifest-has "future-9h-still-pending") 1) 65536))))

    (defn rttab-bit-version ()
        (rttab-score (str_eq (rtta-version) "runtime-table-payload-attempt-v1") 131072))
    (defn rttab-bit-valid-bridge-ready ()
        (do
            (let b (rttab-bridge (rao-obs-ok) 42 257 0))
            (rttab-score
                (and (rttab-ready? b)
                     (and (rttab-reason? b (rtta-reason-table-run-bound))
                          (raar-supplied-attempt? (rtta-bridge-attempt b))))
                262144)))
    (defn rttab-bit-attempt-tuple-matches-envelope ()
        (do
            (let e (rttab-envelope))
            (let a (rtta-bridge-attempt (rttab-bridge (rao-obs-ok) 42 257 0)))
            (rttab-score
                (and (str_eq (raar-attempt-action a) (rale-envelope-action e))
                (and (eq (raar-attempt-route a) (rale-envelope-route e))
                (and (str_eq (raar-attempt-artifact-kind a) (rale-envelope-artifact-kind e))
                (and (str_eq (raar-attempt-artifact-path a) (rale-envelope-artifact-path e))
                (and (str_eq (raar-attempt-source-hash a) (rale-envelope-source-hash e))
                     (str_eq (raar-attempt-content-hash a) (rale-envelope-content-hash e)))))))
                524288)))
    (defn rttab-bit-9f-9c-ok-complete ()
        (do
            (let b (rttab-bridge (rao-obs-ok) 42 257 0))
            (let r (rttab-receipt-from-bridge b))
            (let o (rttab-outcome-from-bridge b))
            (rttab-score
                (and (str_eq (raar-receipt-status r) (raar-status-observed))
                (and (str_eq (raar-receipt-attempt-status r) (rao-obs-ok))
                (and (str_eq (rao-outcome-status o) (rao-status-complete))
                     (str_eq (rao-outcome-reason o) (rao-reason-observation-ok)))))
                1048576)))
    (defn rttab-bit-marker-survives ()
        (do
            (let b (rttab-bridge (rao-obs-ok) 42 257 0))
            (let r (rttab-receipt-from-bridge b))
            (let o (rttab-outcome-from-bridge b))
            (rttab-score
                (and (rttab-has? (raar-receipt-detail r) (rtta-table-payload-marker))
                     (rttab-has? (rao-outcome-detail o) (rtta-table-payload-marker)))
                2097152)))
    (defn rttab-bit-hard-zero-line (status bit)
        (do
            (let b (rttab-bridge status 0 0 137))
            (let r (rttab-receipt-from-bridge b))
            (let o (rttab-outcome-from-bridge b))
            (rttab-score
                (and (rttab-ready? b)
                (and (str_eq (raar-receipt-status r) (raar-status-observed))
                (and (str_eq (raar-receipt-attempt-status r) status)
                (and (str_eq (rao-outcome-status o) (rao-status-investigate))
                     (str_eq (rao-outcome-reason o) (rao-reason-hard-observation-investigates))))))
                bit)))
    (defn rttab-bit-oom-zero-line ()
        (rttab-bit-hard-zero-line (rao-obs-oom-killed) 4194304))
    (defn rttab-bit-stalled-zero-line ()
        (rttab-bit-hard-zero-line (rao-obs-stalled) 8388608))
    (defn rttab-bit-wrong-value ()
        (do
            (let b (rttab-bridge (rao-obs-wrong-value) 41 1 0))
            (let o (rttab-outcome-from-bridge b))
            (rttab-score
                (and (rttab-ready? b)
                     (and (str_eq (rao-outcome-status o) (rao-status-investigate))
                          (str_eq (rao-outcome-observation-status o) (rao-obs-wrong-value))))
                16777216)))
    (defn rttab-bit-unknown-zero-line ()
        (do
            (let b (rttab-bridge "surprise-status" 0 0 1))
            (let o (rttab-outcome-from-bridge b))
            (rttab-score
                (and (rttab-ready? b)
                     (and (str_eq (rao-outcome-status o) (rao-status-investigate))
                          (str_eq (rao-outcome-reason o) (rao-reason-unknown-observation-status))))
                33554432)))
    (defn rttab-bit-text-and-path-mismatch ()
        (do
            (let text-bad (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness-bad-text)
                                                (rttab-run (rao-obs-ok) 42 257 0)))
            (let path-bad (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness)
                                                (rttab-run-path-other)))
            (rttab-score
                (and (rttab-investigate? text-bad)
                (and (rttab-no-attempt? text-bad)
                (and (rttab-reason? text-bad (rtta-reason-table-payload-mismatch))
                (and (rttab-investigate? path-bad)
                     (rttab-reason? path-bad (rtta-reason-table-path-mismatch))))))
                67108864)))
    (defn rttab-bit-pif-identity-mismatch ()
        (do
            (let path-b (rtta-bridge-from-run (rttab-envelope) (rttab-pif-path-other) (rttab-witness)
                                              (rttab-run (rao-obs-ok) 42 257 0)))
            (let content-b (rtta-bridge-from-run (rttab-envelope) (rttab-pif-content-other) (rttab-witness)
                                                 (rttab-run (rao-obs-ok) 42 257 0)))
            (let source-b (rtta-bridge-from-run (rttab-envelope) (rttab-pif-source-other) (rttab-witness)
                                                (rttab-run (rao-obs-ok) 42 257 0)))
            (rttab-score
                (and (rttab-investigate? path-b)
                (and (rttab-reason? path-b (rtta-reason-artifact-identity-mismatch))
                (and (rttab-reason? content-b (rtta-reason-artifact-identity-mismatch))
                     (rttab-reason? source-b (rtta-reason-artifact-identity-mismatch)))))
                134217728)))
    (defn rttab-bit-invalid-pif ()
        (do
            (let b (rtta-bridge-from-run (rttab-envelope) (rttab-pif-seal-bad) (rttab-witness)
                                         (rttab-run (rao-obs-ok) 42 257 0)))
            (rttab-score
                (and (rttab-investigate? b)
                     (and (rttab-no-attempt? b)
                          (rttab-reason? b (rtta-reason-invalid-pif-envelope))))
                268435456)))
    (defn rttab-bit-non-program-image-and-malformed-envelope ()
        (do
            (let c (rtta-bridge-from-run (rttab-compile-envelope) (rttab-pif) (rttab-witness)
                                         (rttab-run (rao-obs-ok) 42 257 0)))
            (let m (rtta-bridge-from-run (list "runtime-artifact-load-envelope" 1) (rttab-pif) (rttab-witness)
                                         (rttab-run (rao-obs-ok) 42 257 0)))
            (rttab-score
                (and (rttab-investigate? c)
                (and (rttab-no-attempt? c)
                (and (rttab-reason? c (rtta-reason-non-program-image-envelope))
                (and (rttab-refused? m)
                     (rttab-reason? m (rtta-reason-malformed-envelope))))))
                536870912)))
    (defn rttab-bit-boundary-static-mirror-and-refusals ()
        (do
            (let reason-coverage (rcov-coverage (rtta-reason-manifest)
                                                (rttab-observed-reasons)))
            (let malformed-run (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness)
                                                     (list "runtime-table-payload-supplied-run" 1)))
            (let malformed-pif (rtta-bridge-from-run (rttab-envelope) (list "program-image-fkb-envelope" 1)
                                                     (rttab-witness) (rttab-run (rao-obs-ok) 42 257 0)))
            (let malformed-witness (rtta-bridge-from-run (rttab-envelope) (rttab-pif)
                                                         (list "runtime-table-payload-witness" 1)
                                                         (rttab-run (rao-obs-ok) 42 257 0)))
            (let empty-ok (rttab-bridge (rao-obs-ok) 42 0 0))
            (let empty-witness (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness-empty)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (let text (rttab-read-file-any "form/form-stdlib/runtime-table-payload-attempt.fk"
                                           "../form/form-stdlib/runtime-table-payload-attempt.fk"))
            (let grammar (rttab-read-file-any "grammars/runtime-table-payload-attempt.fk"
                                              "../grammars/runtime-table-payload-attempt.fk"))
            (rttab-score
                (and (rttab-refused? malformed-run)
                (and (rttab-reason? malformed-run (rtta-reason-malformed-table-run))
                (and (rttab-refused? malformed-pif)
                (and (rttab-reason? malformed-pif (rtta-reason-malformed-pif-envelope))
                (and (rttab-refused? malformed-witness)
                (and (rttab-reason? malformed-witness (rtta-reason-malformed-witness))
                (and (rttab-investigate? empty-ok)
                (and (rttab-reason? empty-ok (rtta-reason-empty-output))
                (and (rttab-investigate? empty-witness)
                (and (rttab-reason? empty-witness (rtta-reason-empty-witness-text))
                (and (not (rttab-has? text "write_form_binary"))
                (and (not (rttab-has? text "read_form_binary"))
                (and (not (rttab-has? text "recipe_to_bytes"))
                (and (not (rttab-has? text "bytes_to_recipe"))
                (and (not (rttab-has? text "dlopen"))
                (and (not (rttab-has? text "fk_run"))
                (and (rcov-covered? reason-coverage)
                     (str_eq text grammar))))))))))))))))))
                1073741824)))

    (defn rttab-observed-reasons ()
        (list
            (rtta-bridge-reason (rttab-bridge (rao-obs-ok) 42 257 0))
            (rtta-bridge-reason (rtta-bridge-from-run (list "runtime-artifact-load-envelope" 1) (rttab-pif) (rttab-witness)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-compile-envelope) (rttab-pif) (rttab-witness)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (list "program-image-fkb-envelope" 1) (rttab-witness)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif-seal-bad) (rttab-witness)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif-path-other) (rttab-witness)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (list "runtime-table-payload-witness" 1)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness-empty)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness-bad-text)
                                                     (rttab-run (rao-obs-ok) 42 257 0)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness)
                                                     (list "runtime-table-payload-supplied-run" 1)))
            (rtta-bridge-reason (rtta-bridge-from-run (rttab-envelope) (rttab-pif) (rttab-witness)
                                                     (rttab-run-path-other)))
            (rtta-bridge-reason (rttab-bridge (rao-obs-ok) 42 0 0))))

    (defn runtime-table-payload-attempt-band ()
        (sum (list
            (rttab-bit-manifest-1)
            (rttab-bit-manifest-2)
            (rttab-bit-version)
            (rttab-bit-valid-bridge-ready)
            (rttab-bit-attempt-tuple-matches-envelope)
            (rttab-bit-9f-9c-ok-complete)
            (rttab-bit-marker-survives)
            (rttab-bit-oom-zero-line)
            (rttab-bit-stalled-zero-line)
            (rttab-bit-wrong-value)
            (rttab-bit-unknown-zero-line)
            (rttab-bit-text-and-path-mismatch)
            (rttab-bit-pif-identity-mismatch)
            (rttab-bit-invalid-pif)
            (rttab-bit-non-program-image-and-malformed-envelope)
            (rttab-bit-boundary-static-mirror-and-refusals))))

    (runtime-table-payload-attempt-band))
