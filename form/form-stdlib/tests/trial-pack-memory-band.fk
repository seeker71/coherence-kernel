; trial-pack-memory-band.fk — proof of the packed experiment memory.
;
; preludes: form-stdlib/core.fk form-stdlib/tensor-quant.fk form-stdlib/turboquant-as-recipe.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-turboquant-lane.fk form-stdlib/trial-pack-memory.fk
;
; verdict 127:
;   1   a trial row is deterministic and integer-pure; the outcome reads back
;   2   self-recall: each pinned trial is its own nearest memory
;   4   memory forecasts: the nearest past outcome returns (va -> 10)
;   8   the blur floor is named and non-negative: every self-novelty² lands in
;       [0.0, 2.0) at d=8/2-bit (measured 1.035, 0.0 clamped, 0.776) — finer
;       differences are invisible at this floor, by design and on the record
;   16  separation: a genuinely far query reads far (novelty² > 10.0,
;       measured 18.50)
;   32  near-dedup splits honestly at eps² = 4.0 (above the blur, below the
;       far reading): known?(va)=1, known?(far)=0
;   64  empty memory is honest: novelty² = −1.0 exactly (out-of-band under
;       the clamp), predict returns the caller's default, nearest-id ""
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/tensor-quant.fk \
;          form/form-stdlib/turboquant-as-recipe.fk form/form-stdlib/rag-retrieve.fk \
;          form/form-stdlib/rag-turboquant-lane.fk form/form-stdlib/trial-pack-memory.fk \
;          form/form-stdlib/tests/trial-pack-memory-band.fk > /tmp/tpm.fk
;      ./fkwu --src /tmp/tpm.fk    ; -> 127

(do
    (defn tpb-cell (state) (div (mul 1.0 (sub (tqr-draw state 2001) 1000)) 1000.0))
    (defn tpb-vec-loop (state d acc)
        (if (eq d 0) acc
            (do (let s (tqr-lcg state))
                (tpb-vec-loop s (sub d 1) (cons (tpb-cell s) acc)))))
    (defn tpb-vec (seed d) (tpb-vec-loop seed d (empty)))
    (defn tpb-in? (x lo hi) (if (and (ge x lo) (lt x hi)) 1 0))

    (let d 8)
    (let va (tpb-vec 11 d))
    (let vb (tpb-vec 22 d))
    (let vc (tpb-vec 33 d))
    (let far (tqr-scale (tpb-vec 77 d) 3.0))
    (let ra (tpm-trial "a" va 10))
    (let rows (list ra (tpm-trial "b" vb 20) (tpm-trial "c" vc 30)))

    (let pure (if (and (eq (tq-codes-eq (tpm-pack ra) (tpm-pack (tpm-trial "a" va 10))) 1)
                       (eq (tpm-outcome ra) 10)) 1 0))
    (let self-recall (if (and (str_eq (tpm-nearest-id va rows) "a")
                              (and (str_eq (tpm-nearest-id vb rows) "b")
                                   (str_eq (tpm-nearest-id vc rows) "c"))) 1 0))
    (let forecast (if (eq (tpm-predict va rows -1) 10) 1 0))
    (let blur (if (and (eq (tpb-in? (tpm-novelty2 va rows) 0.0 2.0) 1)
                       (and (eq (tpb-in? (tpm-novelty2 vb rows) 0.0 2.0) 1)
                            (eq (tpb-in? (tpm-novelty2 vc rows) 0.0 2.0) 1))) 1 0))
    (let separation (if (gt (tpm-novelty2 far rows) 10.0) 1 0))
    (let dedup (if (and (eq (tpm-known? va rows 4.0) 1)
                        (eq (tpm-known? far rows 4.0) 0)) 1 0))
    (let empty-honest (if (and (eq (tpm-novelty2 va (empty)) -1.0)
                               (and (eq (tpm-predict va (empty) -1) -1)
                                    (str_eq (tpm-nearest-id va (empty)) ""))) 1 0))

    (add (mul pure 1)
    (add (mul self-recall 2)
    (add (mul forecast 4)
    (add (mul blur 8)
    (add (mul separation 16)
    (add (mul dedup 32)
         (mul empty-honest 64))))))))
