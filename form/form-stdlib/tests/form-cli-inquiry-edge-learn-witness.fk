; import "../form-cli-inquiry.fk"
; Process 1: reset state, witness miss, learn edge 8 requires 5.
; [before-ack, before-reason, learn-ack, invalid-rejected,
;  computed-edge-count, state-bytes]
; witnessed: 2026-07-22 -> [0, 0, 1, nothing, 11, 17]
(do
  (fciel-reset)
  (let before (fci-requires 8 5 100))
  (let learned (fciel-learn 8 1 5))
  (let invalid (fciel-learn 8 2 5))
  (list (fci-ack before) (fci-reason before) learned invalid
        (len (fci-edges)) (str_len (read_file (fciel-path)))))
