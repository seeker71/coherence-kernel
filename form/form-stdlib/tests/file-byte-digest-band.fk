; file-byte-digest-band.fk -- Layer 1b windowed file digest witness.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/file-byte-digest.fk
;
; Expected: 2147483647

(do
    (defn fbdb-score (ok bit) (if ok bit 0))
    (defn fbdb-manifest-has (name)
        (file-byte-digest-manifest-has? name (file-byte-digest-manifest)))

    (defn fbdb-repeat-byte-loop (b n acc)
        (if (le n 0)
            acc
            (fbdb-repeat-byte-loop b (sub n 1) (cons b acc))))
    (defn fbdb-repeat-byte (b n)
        (fbdb-repeat-byte-loop b n (list)))
    (defn fbdb-hash (bytes) (sai-sha256-hex bytes))
    (defn fbdb-192-bytes ()
        (append-list (fbdb-repeat-byte 65 64)
            (append-list (fbdb-repeat-byte 66 64)
                         (fbdb-repeat-byte 67 64))))
    (defn fbdb-4160-bytes ()
        (append-list (fbdb-repeat-byte 65 4096)
                     (fbdb-repeat-byte 66 64)))

    (defn fbdb-temp-root ()
        (fs-path-join (fs-temp-dir) "file-byte-digest-band"))
    (defn fbdb-path (name)
        (fs-path-join (fbdb-temp-root) name))
    (defn fbdb-empty-path () (fbdb-path "empty.bin"))
    (defn fbdb-one-path () (fbdb-path "one.bin"))
    (defn fbdb-55-path () (fbdb-path "s55.bin"))
    (defn fbdb-56-path () (fbdb-path "s56.bin"))
    (defn fbdb-63-path () (fbdb-path "s63.bin"))
    (defn fbdb-64-path () (fbdb-path "s64.bin"))
    (defn fbdb-119-path () (fbdb-path "s119.bin"))
    (defn fbdb-120-path () (fbdb-path "s120.bin"))
    (defn fbdb-128-path () (fbdb-path "s128.bin"))
    (defn fbdb-129-path () (fbdb-path "s129.bin"))
    (defn fbdb-192-path () (fbdb-path "s192.bin"))
    (defn fbdb-4160-path () (fbdb-path "s4160.bin"))
    (defn fbdb-binary-path () (fbdb-path "binary.bin"))
    (defn fbdb-source-path () (fbdb-path "source.fk"))
    (defn fbdb-fkb-path () (fbdb-path "source.fkb"))
    (defn fbdb-missing-path () (fbdb-path "missing.bin"))

    (defn fbdb-write-bytes (path bytes)
        (do
            (let _rm (fs-remove-file path))
            (if (eq (len bytes) 0)
                (fs-write-text path "")
                (fs-append-bytes path bytes))))
    (defn fbdb-setup ()
        (do
            (let root (fbdb-temp-root))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let _empty (fbdb-write-bytes (fbdb-empty-path) (list)))
            (let _one (fbdb-write-bytes (fbdb-one-path) (fbdb-repeat-byte 65 1)))
            (let _55 (fbdb-write-bytes (fbdb-55-path) (fbdb-repeat-byte 65 55)))
            (let _56 (fbdb-write-bytes (fbdb-56-path) (fbdb-repeat-byte 65 56)))
            (let _63 (fbdb-write-bytes (fbdb-63-path) (fbdb-repeat-byte 65 63)))
            (let _64 (fbdb-write-bytes (fbdb-64-path) (fbdb-repeat-byte 65 64)))
            (let _119 (fbdb-write-bytes (fbdb-119-path) (fbdb-repeat-byte 65 119)))
            (let _120 (fbdb-write-bytes (fbdb-120-path) (fbdb-repeat-byte 65 120)))
            (let _128 (fbdb-write-bytes (fbdb-128-path) (fbdb-repeat-byte 65 128)))
            (let _129 (fbdb-write-bytes (fbdb-129-path) (fbdb-repeat-byte 65 129)))
            (let _192 (fbdb-write-bytes (fbdb-192-path) (fbdb-192-bytes)))
            (let _4160 (fbdb-write-bytes (fbdb-4160-path) (fbdb-4160-bytes)))
            (let _binary (fbdb-write-bytes (fbdb-binary-path) (list 0 65 10 127 66)))
            (let _src (fbdb-write-bytes (fbdb-source-path) (list 97 98 99)))
            (let _fkb (fbdb-write-bytes (fbdb-fkb-path) (list 102 107 98)))
            0))
    (defn fbdb-cleanup ()
        (do
            (let _empty (fs-remove-file (fbdb-empty-path)))
            (let _one (fs-remove-file (fbdb-one-path)))
            (let _55 (fs-remove-file (fbdb-55-path)))
            (let _56 (fs-remove-file (fbdb-56-path)))
            (let _63 (fs-remove-file (fbdb-63-path)))
            (let _64 (fs-remove-file (fbdb-64-path)))
            (let _119 (fs-remove-file (fbdb-119-path)))
            (let _120 (fs-remove-file (fbdb-120-path)))
            (let _128 (fs-remove-file (fbdb-128-path)))
            (let _129 (fs-remove-file (fbdb-129-path)))
            (let _192 (fs-remove-file (fbdb-192-path)))
            (let _4160 (fs-remove-file (fbdb-4160-path)))
            (let _binary (fs-remove-file (fbdb-binary-path)))
            (let _src (fs-remove-file (fbdb-source-path)))
            (let _fkb (fs-remove-file (fbdb-fkb-path)))
            (fs-remove-tree (fbdb-temp-root))))

    (defn fbdb-vouch-match? (path bytes max-bytes)
        (do
            (let expected (fbdb-hash bytes))
            (let v (fbd-vouch-content-file-capped path expected max-bytes))
            (and (str_eq (sai-vouch-status v) (sai-status-match))
                 (and (str_eq (sai-vouch-actual-hash v) expected)
                 (and (eq (sai-vouch-observed-size v) (len bytes))
                 (and (eq (sai-vouch-material-size v) (len bytes))
                      (str_eq (sai-vouch-evidence-kind v) (fbd-evidence-kind))))))))

    (defn fbdb-bit-manifest-1 ()
        (sum (list
            (fbdb-score (eq (fbdb-manifest-has "windowed-sha256") 1) 1)
            (fbdb-score (eq (fbdb-manifest-has "uses-file-byte-window") 1) 2)
            (fbdb-score (eq (fbdb-manifest-has "total-file-cap-65536") 1) 4)
            (fbdb-score (eq (fbdb-manifest-has "window-size-4096") 1) 8)
            (fbdb-score (eq (fbdb-manifest-has "window-size-multiple-of-64") 1) 16)
            (fbdb-score (eq (fbdb-manifest-has "cap-multiple-of-64-required") 1) 32)
            (fbdb-score (eq (fbdb-manifest-has "total-length-tail-pad") 1) 64)
            (fbdb-score (eq (fbdb-manifest-has "processes-full-blocks-only") 1) 128)
            (fbdb-score (eq (fbdb-manifest-has "size-cross-check") 1) 256)
            (fbdb-score (eq (fbdb-manifest-has "post-stream-restat-check") 1) 512)
            (fbdb-score (eq (fbdb-manifest-has "sai-compatible-vouch") 1) 1024)
            (fbdb-score (eq (fbdb-manifest-has "nul-ascii-window-transparent") 1) 2048)
            (fbdb-score (eq (fbdb-manifest-has "cap-overflow-refuses") 1) 4096)
            (fbdb-score (eq (fbdb-manifest-has "no-read-file-bytes") 1) 8192))))
    (defn fbdb-bit-manifest-2 ()
        (sum (list
            (fbdb-score (eq (fbdb-manifest-has "no-write-file-bytes") 1) 16384)
            (fbdb-score (eq (fbdb-manifest-has "no-file-byte-at") 1) 32768)
            (fbdb-score (eq (fbdb-manifest-has "no-whole-file-materialization") 1) 65536)
            (fbdb-score (eq (fbdb-manifest-has "no-cache-write") 1) 131072)
            (fbdb-score (eq (fbdb-manifest-has "no-seal-proof-callable") 1) 262144)
            (fbdb-score (eq (fbdb-manifest-has "no-route-derivation") 1) 524288)
            (fbdb-score (eq (fbdb-manifest-has "no-artifact-load") 1) 1048576)
            (fbdb-score (eq (fbdb-manifest-has "no-attempt-observation") 1) 2097152)
            (fbdb-score (eq (fbdb-manifest-has "no-selector-install") 1) 4194304)
            (fbdb-score (eq (fbdb-manifest-has "no-c-seed-growth") 1) 8388608))))

    (defn fbdb-bit-boundary-vectors ()
        (fbdb-score
            (and (fbdb-vouch-match? (fbdb-empty-path) (list) 64)
            (and (fbdb-vouch-match? (fbdb-one-path) (fbdb-repeat-byte 65 1) 64)
            (and (fbdb-vouch-match? (fbdb-55-path) (fbdb-repeat-byte 65 55) 64)
            (and (fbdb-vouch-match? (fbdb-56-path) (fbdb-repeat-byte 65 56) 64)
            (and (fbdb-vouch-match? (fbdb-63-path) (fbdb-repeat-byte 65 63) 64)
            (and (fbdb-vouch-match? (fbdb-64-path) (fbdb-repeat-byte 65 64) 64)
            (and (fbdb-vouch-match? (fbdb-119-path) (fbdb-repeat-byte 65 119) 128)
                 (fbdb-vouch-match? (fbdb-120-path) (fbdb-repeat-byte 65 120) 128))))))))
            16777216))
    (defn fbdb-bit-nul-ascii-transparent ()
        (fbdb-score
            (fbdb-vouch-match? (fbdb-binary-path) (list 0 65 10 127 66) 64)
            33554432))
    (defn fbdb-bit-multi-window ()
        (do
            (let bytes192 (fbdb-192-bytes))
            (let expected192 (fbdb-hash bytes192))
            (let digest192 (fbd-digest-file-capped-window (sai-target-content-hash) (fbdb-192-path) expected192 256 64))
            (let v192 (fbd-vouch-from-digest digest192))
            (let bytes4160 (fbdb-4160-bytes))
            (let expected4160 (fbdb-hash bytes4160))
            (let digest4160 (fbd-digest-file-capped (sai-target-content-hash) (fbdb-4160-path) expected4160 (fbd-default-max-bytes)))
            (let v4160 (fbd-vouch-from-digest digest4160))
            (fbdb-score
                (and (str_eq (sai-vouch-status v192) (sai-status-match))
                (and (str_eq (sai-vouch-actual-hash v192) expected192)
                (and (eq (sai-vouch-observed-size v192) 192)
                (and (eq (sai-vouch-material-size v192) 192)
                (and (eq (fbd-digest-window-size digest192) 64)
                (and (str_eq (sai-vouch-status v4160) (sai-status-match))
                (and (str_eq (sai-vouch-actual-hash v4160) expected4160)
                (and (eq (sai-vouch-observed-size v4160) 4160)
                (and (eq (sai-vouch-material-size v4160) 4160)
                     (eq (fbd-digest-window-size digest4160) (fbd-window-size)))))))))))
                67108864)))
    (defn fbdb-bit-cap-and-missing ()
        (do
            (let exact (fbd-vouch-content-file-capped (fbdb-128-path) (fbdb-hash (fbdb-repeat-byte 65 128)) 128))
            (let large (fbd-vouch-content-file-capped (fbdb-129-path) (fbdb-hash (fbdb-repeat-byte 65 129)) 128))
            (let malformed (fbd-vouch-content-file-capped (fbdb-64-path) (fbdb-hash (fbdb-repeat-byte 65 64)) 65))
            (let bad-window-mod (fbd-vouch-file-capped-window (sai-target-content-hash) (fbdb-64-path) (fbdb-hash (fbdb-repeat-byte 65 64)) 128 65))
            (let bad-window-large (fbd-vouch-file-capped-window (sai-target-content-hash) (fbdb-64-path) (fbdb-hash (fbdb-repeat-byte 65 64)) 128 4160))
            (let missing (fbd-vouch-content-file-capped (fbdb-missing-path) "" 64))
            (fbdb-score
                (and (str_eq (sai-vouch-status exact) (sai-status-match))
                (and (str_eq (sai-vouch-status large) (fbd-status-too-large))
                (and (str_eq (sai-vouch-actual-hash large) "")
                (and (eq (sai-vouch-observed-size large) 129)
                (and (str_eq (sai-vouch-status malformed) (sai-status-malformed))
                (and (str_eq (sai-vouch-status bad-window-mod) (sai-status-malformed))
                (and (str_eq (sai-vouch-status bad-window-large) (sai-status-malformed))
                     (str_eq (sai-vouch-status missing) (sai-status-unobserved)))))))))
                134217728)))
    (defn fbdb-bit-vouch-policy ()
        (do
            (let good (fbd-vouch-content-file-capped (fbdb-one-path) (fbdb-hash (fbdb-repeat-byte 65 1)) 64))
            (let bad (fbd-vouch-content-file-capped (fbdb-one-path) (fbdb-hash (list)) 64))
            (let undeclared (fbd-vouch-content-file-capped (fbdb-one-path) "" 64))
            (fbdb-score
                (and (str_eq (sai-vouch-target good) (sai-target-content-hash))
                (and (str_eq (sai-vouch-evidence-kind good) (fbd-evidence-kind))
                (and (str_eq (sai-vouch-status bad) (sai-status-mismatch))
                (and (str_eq (sai-vouch-status undeclared) (sai-status-undeclared))
                     (str_eq (sai-vouch-hash-if-match bad) "")))))
                268435456)))
    (defn fbdb-bit-source-content-helpers ()
        (do
            (let src-bytes (list 97 98 99))
            (let fkb-bytes (list 102 107 98))
            (let source-v (fbd-vouch-source-file-capped (fbdb-source-path) (fbdb-hash src-bytes) 64))
            (let fkb-v (fbd-vouch-content-file-capped (fbdb-fkb-path) (fbdb-hash fkb-bytes) 64))
            (fbdb-score
                (and (str_eq (sai-vouch-target source-v) (sai-target-source-hash))
                (and (str_eq (sai-vouch-target fkb-v) (sai-target-content-hash))
                (and (str_eq (sai-vouch-status source-v) (sai-status-match))
                (and (str_eq (sai-vouch-status fkb-v) (sai-status-match))
                (and (str_eq (sai-vouch-actual-hash source-v) (fbdb-hash src-bytes))
                     (str_eq (sai-vouch-actual-hash fkb-v) (fbdb-hash fkb-bytes)))))))
                536870912)))
    (defn fbdb-text-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn fbdb-bit-static-and-mirror ()
        (do
            (let text (if (ge (file_size "form/form-stdlib/file-byte-digest.fk") 0)
                          (read_file "form/form-stdlib/file-byte-digest.fk")
                          (read_file "../form/form-stdlib/file-byte-digest.fk")))
            (let grammar (if (ge (file_size "grammars/file-byte-digest.fk") 0)
                             (read_file "grammars/file-byte-digest.fk")
                             (read_file "../grammars/file-byte-digest.fk")))
            (fbdb-score
                (and (fbdb-text-has? text "fbw-read-window")
                (and (not (fbdb-text-has? text "read_file_bytes"))
                (and (not (fbdb-text-has? text "write_file_bytes"))
                (and (not (fbdb-text-has? text "file_byte_at"))
                (and (not (fbdb-text-has? text "fs-read-bytes"))
                (and (not (fbdb-text-has? text "fs-write-bytes"))
                (and (not (fbdb-text-has? text "fs-byte-at"))
                (and (not (fbdb-text-has? text "write_form_binary"))
                (and (not (fbdb-text-has? text "read_form_binary"))
                (and (not (fbdb-text-has? text "recipe_to_bytes"))
                (and (not (fbdb-text-has? text "bytes_to_recipe"))
                (and (not (fbdb-text-has? text "dlopen"))
                (and (not (fbdb-text-has? text "dlsym"))
                (and (not (fbdb-text-has? text "fk_run"))
                (and (not (fbdb-text-has? text "rao-run-observation"))
                     (str_eq text grammar))))))))))))))))
                1073741824)))

    (defn file-byte-digest-band ()
        (do
            (let _setup (fbdb-setup))
            (let score (sum (list
                (fbdb-bit-manifest-1)
                (fbdb-bit-manifest-2)
                (fbdb-bit-boundary-vectors)
                (fbdb-bit-nul-ascii-transparent)
                (fbdb-bit-multi-window)
                (fbdb-bit-cap-and-missing)
                (fbdb-bit-vouch-policy)
                (fbdb-bit-source-content-helpers)
                (fbdb-bit-static-and-mirror))))
            (let _cleanup (fbdb-cleanup))
            score))

    (file-byte-digest-band))
