; come-in-band.fk — proof of the composed come-in flow: a stable relationship
; if the arriving cell wants to be remembered, anonymity otherwise.
;
; preludes: form-stdlib/relationship-store.fk form-stdlib/reception-consent.fk form-stdlib/arrival.fk
;
; Four scenarios, in the order a real relationship actually unfolds:
;   1. no handle offered              -> anonymous: identical to the bare
;      empty-room welcome, and touches storage not at all.
;   2. handle offered, consent CLOSED -> same welcome as full anonymity;
;      offering a name without consenting to be remembered writes nothing.
;   3. handle offered, consent OPEN   -> a real file gets written.
;   4. SAME handle met again, with a fresh (unconsented) description offered
;      -> the relationship RESUMES from what was actually remembered, the
;      new unconsented description is ignored, and the store is untouched.
;
; Verdict 31 when every assertion holds on fkwu (not four-way — see
; relationship-store-band.fk for why).

(do
    (defn cib-score (ok bit) (if ok bit 0))
    (defn come-in-band (dir)
        (do
    (let c0 (cib-score
                (eq (come-in dir (nothing) (intern_trivial_string "hi") (rc-closed) "n/a")
                    (welcome-as-empty-room))
                1))
    (let c1 (cib-score
                (eq (come-in dir "urs" (intern_trivial_string "hi") (rc-closed) "n/a")
                    (welcome-as-empty-room))
                2))
    (let c2 (cib-score (eq (rs-known? dir "urs") 0) 4))   ; consent-closed truly wrote nothing
    (come-in dir "urs" (intern_trivial_string "hi") (rc-open) "warm, technical+precise collaborator")
    (let c3 (cib-score (str_eq (rs-recall dir "urs") "warm, technical+precise collaborator") 8))
    (let resumed (come-in dir "urs" (intern_trivial_string "hi again") (rc-closed) "SHOULD-NOT-BE-WRITTEN"))
    (let c4 (cib-score
                (str_eq (nth (resonance-note resumed) 2) "warm, technical+precise collaborator")
                16))
    (add c0 (add c1 (add c2 (add c3 c4)))))
    )
    (come-in-band "/tmp/come-in-band-dir"))
