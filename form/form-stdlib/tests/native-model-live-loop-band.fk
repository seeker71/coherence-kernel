; native-model-live-loop-band.fk -- privacy-safe occurrence accounting and
; shell-observation gates remain Form-owned.
;
; preludes: form-stdlib/core.fk form-stdlib/native-model-control-plane.fk form-stdlib/native-model-live-loop.fk
;
; Verdict 4095.

(do
    (let a "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    (let b "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb")
    (let c "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc")
    (let d "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd")

    (let form-final
        (nmll-occurrence 20260715 1 "form-native" "fkwu-rag" "production-final"
                         1 a b c 12))
    (let fine-eval
        (nmll-occurrence 20260715 2 "local-finetuned" "form-llama" "evaluation"
                         1 b c d 900))
    (let local-eval
        (nmll-occurrence 20260715 3 "local-native" "llama3.2:3b" "evaluation"
                         1 c d a 500))
    (let oracle-probe
        (nmll-occurrence 20260715 4 "local-oracle" "llama3.2:1b"
                         "integration-probe" 1 d a b 300))
    (let remote-final
        (nmll-occurrence 20260715 5 "remote-oracle" "remote"
                         "production-final" 1 a c b 1200))
    (let rows (list form-final fine-eval local-eval oracle-probe remote-final))
    (let bad
        (nmll-occurrence 20260715 6 "local-native" "bad" "evaluation"
                         1 "not-a-digest" b c 1))

    (let candidate (nmll-eval 4 250000 600000 800 0 0 500000 400 0 1))
    (let incumbent (nmll-eval 4 250000 500000 400 0 0 500000 400 0 1))
    (let drift (nmll-eval 4 250000 600000 800 0 0 500000 400 0 0))

    (let snap (nmll-snapshot 20260715 rows))
    (let c1 (if (eq (nmll-occurrences-valid? rows) 1) 1 0))
    (let c2 (if (eq (nmll-occurrence-valid? bad) 0) 2 0))
    (let c3 (if (and (eq (nmll-final-count rows) 2)
                     (eq (nmll-owned-final-count rows) 1)) 4 0))
    (let c4 (if (eq (nmll-owned-final-ppm rows) 500000) 8 0))
    (let c5 (if (eq (nmll-owned-final-ppm (list fine-eval local-eval)) -1) 16 0))
    (let c6 (if (and (eq (nmll-count-class rows "form-native") 1)
                     (eq (nmll-count-class rows "remote-oracle") 1)) 32 0))
    (let c7 (if (str_eq (nmll-diagnostic-verdict candidate)
                         "candidate-wins-diagnostic") 64 0))
    (let c8 (if (str_eq (nmll-diagnostic-verdict incumbent) "diagnostic-tie") 128 0))
    (let c9 (if (str_eq (nmll-diagnostic-verdict drift) "identity-drift") 256 0))
    (let c10 (if (eq (nmll-seal-ready? 1 1 1 1 1 1 1 1) 1) 512 0))
    (let c11 (if (and (eq (nmll-seal-ready? 1 1 1 1 0 1 1 1) 0)
                       (eq (nmll-seal-ready? 1 1 0 1 1 1 1 1) 0)) 1024 0))
    (let c12 (if (and (eq (nth snap 2) 1)
                       (and (eq (nth snap 3) 1)
                            (and (eq (nth snap 8) 2)
                                 (eq (nth snap 10) 500000)))) 2048 0))

    (sum (list c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12)))
