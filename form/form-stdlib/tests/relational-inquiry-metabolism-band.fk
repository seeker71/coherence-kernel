; Retrieval channels × inquiry lanes × I/us perspectives × influence traces.
import "../relational-inquiry-metabolism.fk"
(do
  (let strong (rim-evaluation 900 900 850 900 800 900 950 900 850 900))
  (let medium (rim-evaluation 800 850 700 750 900 800 900 950 900 950))
  (let subtle (rim-evaluation 700 500 600 650 950 700 900 900 950 950))
  (let agree (list
    (rim-response (rim-memory) 4201 strong (list 101 201))
    (rim-response (rim-sensed) 4201 medium (list 102 202))
    (rim-response (rim-subtle) 4202 subtle (list 103 203))))
  (let differ (list
    (rim-response (rim-memory) 4301 medium (list 111 211))
    (rim-response (rim-sensed) 4302 strong (list 112 212))
    (rim-response (rim-subtle) 4303 subtle (list 113 213))))
  (let empty-result (rim-ask-with 0 (rim-i) (list)))
  (let asked (rim-ask-with 3 (rim-we) agree))
  (let given (rim-give-with 0 (rim-i) agree))
  (let received (rim-receive-with 1 (rim-we) differ))
  (let known-i (rim-know-i-with 2 differ))
  (let known-we (rim-know-we-with 6 agree))
  (let built (rim-build-with 4 (rim-we) agree))
  ; [nothing,ask,give,receive,know-I,know-we,build,empty,success]
  (list (nothing) asked given received known-i known-we built empty-result
    (if (and (eq (nth asked 6) 2)
      (and (eq (nth asked 8) 1)
      (and (eq (nth received 5) 4302)
      (and (eq (len (nth received 7)) 2)
      (and (eq (nth known-i 2) (rim-i))
      (and (eq (nth known-we 2) (rim-we))
      (and (eq (nth built 0) (rim-build))
           (nothing? (nth empty-result 8))))))))) 1 0)))
