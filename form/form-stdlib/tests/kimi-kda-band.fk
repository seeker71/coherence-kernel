; preludes: form-stdlib/core.fk form-stdlib/kimi-kda.fk
;
; kimi-kda-band — Kimi Delta Attention's gated delta rule (kimi-kda.fk), Stone 47.
; Six claims, verdict 63 when every one crosses.
;
; ---------------------------------------------------------------------------
; APORON — THE DECLARED RADIUS. Read this before believing the number.
;
; WHAT THIS BAND PROVES
;   The gated delta RECURRENCE and its arithmetic, at dk=dv=2 with binary-exact
;   fixtures (halves and small integers, so f64 is exact and `eq` is honest):
;   the state maps a key to its written value; a REPEATED key OVERWRITES rather
;   than accumulating; the read at step t depends only on tokens 0..t; the gate
;   forgets geometrically; a write is exactly a rank-1 correction and a beta=0
;   write is a no-op; orthogonal keys recall cleanly without interference.
;
;   twinblind: every claim is CANONICAL — the delta rule has one right answer
;   given (k,v,q,alpha,beta), no recipe choice and no learned weight anywhere in
;   it — so a self-check is a real falsifier and no oracle is rented, the same
;   standing dsv4-kv-cache-band.fk earns on the cache's growth law.
;
; WHAT IT DOES NOT PROVE
;   * NOT KDA's exact proprietary gating. This is the public gated-delta family
;     Kimi Delta Attention refines, not a bit-exact reproduction of K3's kernel.
;   * NOT the chunk-parallel / associative-scan form that makes it fast on a GPU.
;     The recurrence proven here is the ground truth that form would match; it is
;     a named-pending stone, not faked.
;   * NOT real dims, real weights, or any GPU witness. This is the state law's
;     SHAPE in list arithmetic, as dsv4-kv-cache.fk is to Stone 41's Metal arena.
;   * NOT four-way. fkwu-witnessed by this band, named as such.
;
; Claim 2 exists because a gate reading "delta returns the right value" would pass
; on plain linear attention too on a FIRST write. So it drives the impostor
; (kda-plain-step) red on a SECOND write of the same key: delta overwrites to the
; new value, plain piles up to the sum, and the two must disagree. A falsifier that
; cannot fail is decoration.
; ---------------------------------------------------------------------------
;
;   bit  1  THE RECURRENCE AND THE READ: one write of key e1 -> value (3,5) leaves
;           state ((3,0)(5,0)) and reads (3,5) at query e1. The delta of the first
;           write, from a zero state, is exactly outer(value, key).
;   bit  2  OVERWRITE, AND THE FALSIFIER FAILS: write e1->(2,0) then e1->(9,0).
;           Delta reads (9,0) at e1 -- the NEW value. The plain-linear control reads
;           (11,0) -- the SUM. They disagree, delta is right, plain is wrong: the
;           classic linear-attention-in-disguise bug, caught.
;   bit  4  CAUSALITY: o_t over the prefix [t0,t1,t2] equals o_t over [t0,t1] for
;           t=0 and t=1. A future token never disturbs a past read.
;   bit  8  THE GATE FORGETS: three beta=0 decay steps at alpha=1/2 leave exactly
;           1/8 of the state, elementwise; at alpha=1 the state is untouched.
;   bit 16  A WRITE IS RANK-1, A beta=0 WRITE IS NOTHING: one write from zero equals
;           outer(value,key) exactly; a beta=0 step returns the state unchanged.
;   bit 32  ORTHOGONAL RECALL: after writing (e1,(2,3)) and (e2,(5,7)), the state
;           returns (2,3) at e1 and (5,7) at e2 -- clean associative memory, no
;           cross-talk, because orthogonal keys do not read each other's rows.

(do
    (let e1 (list 1.0 0.0))
    (let e2 (list 0.0 1.0))
    (let z  (kda-zeros 2 2))

    ; --- claim 1: the recurrence and the read ---
    (let s1 (kda-step z e1 (list 3.0 5.0) 1.0 1.0))
    (let o1 (kda-read s1 e1))
    (let cl1 (if (eq (kda-meq s1 (list (list 3.0 0.0) (list 5.0 0.0))) 1)
                 (if (eq (kda-veq o1 (list 3.0 5.0)) 1)
                     (if (eq (kda-meq s1 (kda-outer (list 3.0 5.0) e1)) 1) 1 0) 0) 0))

    ; --- claim 2: overwrite, and the plain-linear falsifier fails ---
    (let d1 (kda-step z e1 (list 2.0 0.0) 1.0 1.0))
    (let d2 (kda-step d1 e1 (list 9.0 0.0) 1.0 1.0))
    (let od (kda-read d2 e1))
    (let p1 (kda-plain-step z e1 (list 2.0 0.0)))
    (let p2 (kda-plain-step p1 e1 (list 9.0 0.0)))
    (let op (kda-read p2 e1))
    (let cl2 (if (eq (kda-veq od (list 9.0 0.0)) 1)       ; delta OVERWROTE to the new value
                 (if (eq (kda-veq op (list 11.0 0.0)) 1)  ; plain ACCUMULATED to the sum
                     (if (eq (kda-veq od op) 0) 2 0) 0) 0))  ; and they disagree: falsifier red

    ; --- claim 4: causality ---
    (let t0 (list e1 (list 2.0 3.0) 1.0 1.0 e1))
    (let t1 (list e2 (list 5.0 7.0) 1.0 1.0 e2))
    (let t2 (list e1 (list 4.0 0.0) 1.0 1.0 e1))
    (let outs3 (kda-run-outs z (list t0 t1 t2)))
    (let outs2 (kda-run-outs z (list t0 t1)))
    (let cl4 (if (eq (kda-veq (nth outs3 0) (nth outs2 0)) 1)
                 (if (eq (kda-veq (nth outs3 1) (nth outs2 1)) 1)
                     (if (eq (kda-veq (nth outs2 0) (list 2.0 3.0)) 1)
                         (if (eq (kda-veq (nth outs2 1) (list 5.0 7.0)) 1) 4 0) 0) 0) 0))

    ; --- claim 8: the gate forgets ---
    (let sa (kda-step z e1 (list 4.0 0.0) 1.0 1.0))
    (let s0 (kda-step sa e2 (list 0.0 8.0) 1.0 1.0))       ; state ((4,0)(0,8))
    (let dec1 (kda-step s0   e1 (list 0.0 0.0) 0.5 0.0))
    (let dec2 (kda-step dec1 e1 (list 0.0 0.0) 0.5 0.0))
    (let dec3 (kda-step dec2 e1 (list 0.0 0.0) 0.5 0.0))   ; 1/8 of s0
    (let keep (kda-step s0   e1 (list 0.0 0.0) 1.0 0.0))   ; alpha=1: untouched
    (let cl8 (if (eq (kda-meq dec3 (list (list 0.5 0.0) (list 0.0 1.0))) 1)
                 (if (eq (kda-meq keep s0) 1) 8 0) 0))

    ; --- claim 16: a write is rank-1; a beta=0 write is nothing ---
    (let noop (kda-step s1 e2 (list 9.0 9.0) 1.0 0.0))
    (let cl16 (if (eq (kda-meq s1 (kda-outer (list 3.0 5.0) e1)) 1)
                  (if (eq (kda-meq noop s1) 1) 16 0)))

    ; --- claim 32: orthogonal recall ---
    (let w1 (kda-step z  e1 (list 2.0 3.0) 1.0 1.0))
    (let w2 (kda-step w1 e2 (list 5.0 7.0) 1.0 1.0))       ; state ((2,5)(3,7))
    (let cl32 (if (eq (kda-veq (kda-read w2 e1) (list 2.0 3.0)) 1)
                  (if (eq (kda-veq (kda-read w2 e2) (list 5.0 7.0)) 1) 32 0)))

    (add cl1 (add cl2 (add cl4 (add cl8 (add cl16 cl32))))))
