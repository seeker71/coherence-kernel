import "../sovereign-continuity-response.fk"
(do
  ; Same organ, three changed worlds: partial outage, complete owned continuity,
  ; and an unhealthy local organ. Different computed answers/actions must result.
  (let outage (scr-receipt (scr-state 0 0 0 1 1 6 2 10)))
  (let whole (scr-receipt (scr-state 0 0 0 1 1 7 3 10)))
  (let unhealthy (scr-receipt (scr-state 1 1 1 1 0 7 3 10)))
  (list outage whole unhealthy
    (if (and (eq (nth outage 0) 2)
      (and (eq (nth outage 1) 2)
      (and (eq (nth outage 2) 800)
      (and (eq (nth whole 0) 0)
      (and (eq (nth whole 3) 1)
           (eq (nth unhealthy 1) 3)))))) 1 0)))
