; preludes: form-stdlib/speaker-proj.fk form-stdlib/speaker-net.fk
;
; speaker-net-band — Challenger 3's FLOAT relu embedder + gated backprop, three-way.
;
; Identity W, x=[2,−1] → z=[2,−1] → relu emb=[2,0] (unit1 DEAD). t=[1,1]; loss=2. Dead unit
; passes no gradient; active unit's gradient reaches its off-axis weight. Step lr=0.125: w00→0.5,
; w01→0.25, loss 2→1.0625. All f64-exact.
;
; Verdict 255:
;   1 emb0=2.0   2 emb1=0.0 (relu)   4 gated-err1=0.0 (dead)   8 gated-err0=1.0
;   16 loss-before=2.0   32 loss strictly falls   64 w01=0.25 (off-axis got gradient)   128 loss-after=1.0625
(do
    (let W (list (list 1.0 0.0) (list 0.0 1.0)))
    (let x (list 2.0 -1.0))
    (let t (list 1.0 1.0))
    (let z (sp-matvec W x))
    (let emb (sn-forward W x))
    (let ge (sn-gated-err z t))
    (let before (sn-loss W x t))
    (let W2 (sn-step W x t 0.125))
    (let after (sn-loss W2 x t))
    (let c0 (if (eq (head emb) 2.0) 1 0))
    (let c1 (if (eq (head (tail emb)) 0.0) 2 0))
    (let c2 (if (eq (head (tail ge)) 0.0) 4 0))
    (let c3 (if (eq (head ge) 1.0) 8 0))
    (let c4 (if (eq before 2.0) 16 0))
    (let c5 (if (lt after before) 32 0))
    (let c6 (if (eq (head (tail (head W2))) 0.25) 64 0))
    (let c7 (if (eq after 1.0625) 128 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
