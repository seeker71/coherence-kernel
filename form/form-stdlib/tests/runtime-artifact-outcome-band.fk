; runtime-artifact-outcome-band.fk -- Layer 9c outcome witness.
;
; Expected: 2147483647
;
; This band proves outcome normalization over 9b selection rows and synthetic
; runner observations only. It does not load or walk `.fkb`, load or call
; `.dylib`, bind symbols, execute native bytes, generate real observations,
; run fallbacks, reselect retries, decide source-runner admission, or grow the
; C seed.
;
; preludes: form/form-stdlib/core.fk
;           form/form-stdlib/source-artifact-cache.fk
;           form/form-stdlib/source-artifact-descriptor.fk
;           form/form-stdlib/runtime-artifact-plan.fk
;           form/form-stdlib/runtime-artifact-selector.fk
;           form/form-stdlib/runtime-artifact-outcome.fk

(do
    (defn raob-score (ok bit) (if ok bit 0))
    (defn raob-manifest-has (name)
        (runtime-artifact-outcome-manifest-has? name (runtime-artifact-outcome-manifest)))

    (defn raob-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn raob-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn raob-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn raob-native-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raob-source) (raob-fkb-fresh) (raob-dylib-fresh))))
    (defn raob-fkb-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raob-source) (raob-fkb-fresh) (sad-no-artifact))))
    (defn raob-compile-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raob-source) (sad-no-artifact) (sad-no-artifact))))
    (defn raob-investigate-selection ()
        (ras-selection (sad-route-invalid) (rap-act-investigate) (rap-act-none) (ras-status-investigate) 0 0 (ras-reason-upstream-investigate)))
    (defn raob-refused-selection ()
        (ras-selection (sad-route-invalid) (rap-act-none) (rap-act-none) (ras-status-refused) 0 0 (ras-reason-malformed-plan)))
    (defn raob-status? (o status) (str_eq (rao-outcome-status o) status))
    (defn raob-reason? (o reason) (str_eq (rao-outcome-reason o) reason))
    (defn raob-obs (action status) (rao-run-observation action status "detail" 7))
    (defn raob-native-obs (status) (raob-obs (rap-act-run-native) status))
    (defn raob-compile-obs (status) (raob-obs (rap-act-compile-source) status))
    (defn raob-fallback-obs-ok () (raob-obs (rap-act-run-program-image) (rao-obs-ok)))

    (defn raob-bit-manifest-1 ()
        (sum (list
            (raob-score (eq (raob-manifest-has "outcome-face-not-execution") 1) 1)
            (raob-score (eq (raob-manifest-has "consumes-ras-selection-only") 1) 2)
            (raob-score (eq (raob-manifest-has "consumes-synthetic-observations-only") 1) 4)
            (raob-score (eq (raob-manifest-has "total-outcome-row") 1) 8)
            (raob-score (eq (raob-manifest-has "terminal-selection-propagates") 1) 16)
            (raob-score (eq (raob-manifest-has "selected-pending-without-observation") 1) 32)
            (raob-score (eq (raob-manifest-has "soft-failure-fallback-available-only") 1) 64)
            (raob-score (eq (raob-manifest-has "hard-observation-investigates") 1) 128))))

    (defn raob-bit-manifest-2 ()
        (sum (list
            (raob-score (eq (raob-manifest-has "unknown-observation-investigates") 1) 256)
            (raob-score (eq (raob-manifest-has "action-mismatch-investigates") 1) 512)
            (raob-score (eq (raob-manifest-has "no-automatic-fallback-execution") 1) 1024)
            (raob-score (eq (raob-manifest-has "no-rap-plan-or-descriptor-consumption") 1) 2048)
            (raob-score (eq (raob-manifest-has "no-runtime-load-walk-call-exec") 1) 4096)
            (raob-score (eq (raob-manifest-has "no-seal-proof-callable-admission") 1) 8192)
            (raob-score (eq (raob-manifest-has "no-c-seed-growth-or-selector-install") 1) 16384)
            (raob-score (eq (raob-manifest-has "no-reselection-retry-or-real-observation-generation") 1) 32768))))

    (defn raob-bit-malformed-selection-refused ()
        (do
            (let o (rao-outcome-from-selection (list "runtime-artifact-selection" 1)))
            (let u (rao-outcome-from-selection (ras-selection 7 (rap-act-run-native) (rap-act-run-program-image) "unknown-selection-status" 1 1 (ras-reason-selected-native))))
            (let n (rao-outcome-from-selection 3))
            (raob-score
                (and (raob-status? o (rao-status-refused))
                     (and (raob-reason? o (rao-reason-malformed-selection))
                          (and (raob-status? u (rao-status-investigate))
                               (and (raob-reason? u (rao-reason-unknown-selection-status))
                                    (and (raob-status? n (rao-status-refused))
                                         (raob-reason? n (rao-reason-malformed-selection)))))))
                65536)))

    (defn raob-bit-malformed-observation-refused ()
        (do
            (let o (rao-outcome-from-selection-observation (raob-native-selection) (list "runtime-artifact-run-observation" (rap-act-run-native))))
            (let n (rao-outcome-from-selection-observation (raob-native-selection) "bad-observation"))
            (raob-score
                (and (raob-status? o (rao-status-refused))
                     (and (raob-reason? o (rao-reason-malformed-observation))
                          (and (raob-status? n (rao-status-refused))
                               (raob-reason? n (rao-reason-malformed-observation)))))
                131072)))

    (defn raob-bit-pending-without-observation ()
        (do
            (let o (rao-outcome-from-selection (raob-native-selection)))
            (raob-score
                (and (raob-status? o (rao-status-pending-observation))
                     (and (str_eq (rao-outcome-observation-status o) (rao-obs-none))
                          (raob-reason? o (rao-reason-pending-observation))))
                262144)))

    (defn raob-bit-ok-complete ()
        (do
            (let o (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-ok))))
            (raob-score
                (and (raob-status? o (rao-status-complete))
                     (and (raob-reason? o (rao-reason-observation-ok))
                          (str_eq (rao-outcome-attempted o) (rap-act-run-native))))
                524288)))

    (defn raob-bit-investigate-terminal-propagates ()
        (do
            (let a (rao-outcome-from-selection (raob-investigate-selection)))
            (let b (rao-outcome-from-selection-observation (raob-investigate-selection) (raob-native-obs (rao-obs-ok))))
            (raob-score
                (and (raob-status? a (rao-status-investigate))
                     (and (raob-reason? a (rao-reason-selector-investigate))
                          (and (raob-status? b (rao-status-investigate))
                               (raob-reason? b (rao-reason-terminal-observation-ignored)))))
                1048576)))

    (defn raob-bit-refused-terminal-propagates ()
        (do
            (let a (rao-outcome-from-selection (raob-refused-selection)))
            (let b (rao-outcome-from-selection-observation (raob-refused-selection) (raob-native-obs (rao-obs-ok))))
            (raob-score
                (and (raob-status? a (rao-status-refused))
                     (and (raob-reason? a (rao-reason-selector-refused))
                          (and (raob-status? b (rao-status-refused))
                               (raob-reason? b (rao-reason-terminal-observation-ignored)))))
                2097152)))

    (defn raob-hard-statuses-investigate? ()
        (do
            (let a (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-oom-killed))))
            (let b (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-killed))))
            (let c (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-stalled))))
            (let d (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-timeout))))
            (let e (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-wrong-value))))
            (and (raob-status? a (rao-status-investigate))
                 (and (raob-status? b (rao-status-investigate))
                      (and (raob-status? c (rao-status-investigate))
                           (and (raob-status? d (rao-status-investigate))
                                (and (raob-status? e (rao-status-investigate))
                                     (and (raob-reason? a (rao-reason-hard-observation-investigates))
                                          (raob-reason? e (rao-reason-hard-observation-investigates))))))))))
    (defn raob-bit-hard-statuses-investigate ()
        (raob-score (raob-hard-statuses-investigate?) 4194304))

    (defn raob-bit-soft-fallback-available ()
        (do
            (let a (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-loader-missing))))
            (let b (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-error))))
            (raob-score
                (and (raob-status? a (rao-status-fallback-available))
                     (and (raob-status? b (rao-status-fallback-available))
                          (and (raob-reason? a (rao-reason-soft-failure-fallback-available))
                               (str_eq (rao-outcome-fallback a) (rap-act-run-program-image)))))
                8388608)))

    (defn raob-bit-soft-no-fallback-investigates ()
        (do
            (let a (rao-outcome-from-selection-observation (raob-compile-selection) (raob-compile-obs (rao-obs-loader-missing))))
            (let b (rao-outcome-from-selection-observation (raob-compile-selection) (raob-compile-obs (rao-obs-error))))
            (raob-score
                (and (raob-status? a (rao-status-investigate))
                     (and (raob-status? b (rao-status-investigate))
                          (raob-reason? a (rao-reason-soft-failure-no-fallback))))
                16777216)))

    (defn raob-bit-unknown-observation-investigates ()
        (do
            (let o (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs "surprise-status")))
            (raob-score
                (and (raob-status? o (rao-status-investigate))
                     (raob-reason? o (rao-reason-unknown-observation-status)))
                33554432)))

    (defn raob-bit-action-mismatch-investigates ()
        (do
            (let o (rao-outcome-from-selection-observation (raob-native-selection) (raob-obs (rap-act-compile-source) (rao-obs-error))))
            (raob-score
                (and (raob-status? o (rao-status-investigate))
                     (raob-reason? o (rao-reason-observation-action-mismatch)))
                67108864)))

    (defn raob-bit-fallback-ok-does-not-complete ()
        (do
            (let o (rao-outcome-from-selection-observation (raob-native-selection) (raob-fallback-obs-ok)))
            (raob-score
                (and (raob-status? o (rao-status-investigate))
                     (and (not (raob-status? o (rao-status-complete)))
                          (raob-reason? o (rao-reason-observation-action-mismatch))))
                134217728)))

    (defn raob-bit-hand-built-selection ()
        (do
            (let s (ras-selection 7 (rap-act-run-native) (rap-act-run-program-image) (ras-status-selected) 1 1 (ras-reason-selected-native)))
            (let o (rao-outcome-from-selection-observation s (raob-obs (rap-act-run-native) (rao-obs-ok))))
            (raob-score
                (and (raob-status? o (rao-status-complete))
                     (eq (rao-outcome-route o) 7))
                268435456)))

    (defn raob-bit-selection-outcome-matrix ()
        (do
            (let n (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-ok))))
            (let f (rao-outcome-from-selection-observation (raob-fkb-selection) (raob-obs (rap-act-run-program-image) (rao-obs-ok))))
            (let c (rao-outcome-from-selection-observation (raob-compile-selection) (raob-compile-obs (rao-obs-ok))))
            (raob-score
                (and (raob-status? n (rao-status-complete))
                     (and (raob-status? f (rao-status-complete))
                          (raob-status? c (rao-status-complete))))
                536870912)))

    (defn raob-bit-outcome-shape-no-exec-evidence ()
        (do
            (let o (rao-outcome-from-selection-observation (raob-native-selection) (raob-native-obs (rao-obs-loader-missing))))
            (raob-score
                (and (rao-outcome? o)
                     (and (eq (len o) 11)
                          (and (raob-status? o (rao-status-fallback-available))
                               (and (str_eq (rao-outcome-detail o) "detail")
                                    (eq (rao-outcome-code o) 7)))))
                1073741824)))

    (defn runtime-artifact-outcome-band ()
        (sum (list
            (raob-bit-manifest-1)
            (raob-bit-manifest-2)
            (raob-bit-malformed-selection-refused)
            (raob-bit-malformed-observation-refused)
            (raob-bit-pending-without-observation)
            (raob-bit-ok-complete)
            (raob-bit-investigate-terminal-propagates)
            (raob-bit-refused-terminal-propagates)
            (raob-bit-hard-statuses-investigate)
            (raob-bit-soft-fallback-available)
            (raob-bit-soft-no-fallback-investigates)
            (raob-bit-unknown-observation-investigates)
            (raob-bit-action-mismatch-investigates)
            (raob-bit-fallback-ok-does-not-complete)
            (raob-bit-hand-built-selection)
            (raob-bit-selection-outcome-matrix)
            (raob-bit-outcome-shape-no-exec-evidence))))

    (runtime-artifact-outcome-band))
