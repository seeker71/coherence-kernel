; wire-xml-band.fk — proof of the values+types+identity XML round-trip.
;
; preludes: form-stdlib/core.fk form-stdlib/wire-registry.fk form-stdlib/wire-xml.fk
;
; Same north star as cell-serialize-band.fk (the JSON dialect), same
; registry, same underlying cell — proving the wire-serialization lane's
; core (wire-registry.fk) genuinely generalizes across dialects, not just
; JSON. A nested cell built via intern_node/bp survives a full trip through
; XML TEXT and back to the exact same NodeID (axiom-3), verified via `eq`,
; plus a direct escaping round-trip on a string containing every character
; this dialect must escape.
;
; Verdict 15 when every assertion holds.

(do
    (defn wxb-score (ok bit) (if ok bit 0))
    (defn wire-xml-band ()
        (do
    (let registry (list (wr-entry "OUTER" (bp "OUTER")) (wr-entry "INNER" (bp "INNER"))))
    (let inner (intern_node (bp "INNER") (list (intern_trivial_int 1) (intern_trivial_int 2))))
    (let original (intern_node (bp "OUTER") (list inner (intern_trivial_int 3))))
    (let text (cell-to-xml original registry))
    (let reconstructed (xml-to-cell text registry))
    (let c0 (wxb-score (eq original reconstructed) 1))                      ; THE north-star check
    (let c1 (wxb-score (str_eq text "<OUTER><INNER><i>1</i><i>2</i></INNER><i>3</i></OUTER>") 2))
    (let str-node (intern_trivial_string "a<b>&\"c"))
    (let str-text (cell-to-xml str-node registry))
    (let str-back (xml-to-cell str-text registry))
    (let c2 (wxb-score (eq str-node str-back) 4))
    (let c3 (wxb-score (str_eq str-text "<s>a&lt;b&gt;&amp;\"c</s>") 8))
    (add c0 (add c1 (add c2 c3))))
    )
    (wire-xml-band))
