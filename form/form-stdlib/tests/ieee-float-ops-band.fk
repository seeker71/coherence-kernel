; tests/ieee-float-ops-band.fk — the IEEE float-op surface, proven FOUR-WAY (incl. fkwu).
;
; Float support is core, not a special case to route around. This pins the full float
; surface across Go/Rust/TS AND the emitted walker fkwu: the rounding family, magnitude,
; the transcendentals, float arithmetic incl. remainder, and real (float) power.
;
; The fourth arm reached parity by two moves, both clean — no tag-space expansion:
;   - float mod made float-aware in the walker (hati-os-kernel-emit.fk t==11, mirroring
;     div's fk_isf check; it was integer-only, shifting float-boxes to garbage);
;   - real power as a recipe (trig.fk fpow = exp(e·ln b)) over already-four-way
;     primitives, the same posture as fsin/fcos/fsqrt — no new native tag needed.
; abs (float + int) and the rounding/transcendental natives already crossed.
;
; Verdict 1111111 (127) when every claim holds across all four kernels.
;   floor 3.7->3, ceil -2.7->-2 (toward -inf / +inf)             -> 1
;   trunc -3.7->-3, round -2.5->-3 (toward zero / half-away)     -> 10
;   abs preserves type: |-4.2|->4.2 (x10=42), |-7 int|->7        -> 100
;   sqrt: 2 (x1000)->1414, 16->4                                 -> 1000
;   exp/log: e (x1000)->2718, ln(e^5)->5                         -> 10000
;   float div/mod: 22/7 (x100)=314, 7 mod 3=1                    -> 100000
;   float power (fpow): 2^10=1024, 2^0.5 (x1000)=1414            -> 1000000
;
; preludes: form-stdlib/core.fk form-stdlib/trig.fk
;
(do
    (let c0 (if (eq (floor 3.7) 3) (if (eq (ceil (sub 0.0 2.7)) -2) 1 0) 0))
    (let c1 (if (eq (trunc (sub 0.0 3.7)) -3) (if (eq (round (sub 0.0 2.5)) -3) 10 0) 0))
    (let c2 (if (eq (round (mul 10.0 (abs (sub 0.0 4.2)))) 42) (if (eq (round (abs (sub 0 7))) 7) 100 0) 0))
    (let c3 (if (eq (round (mul 1000.0 (math_sqrt 2.0))) 1414) (if (eq (round (math_sqrt 16.0)) 4) 1000 0) 0))
    (let c4 (if (eq (round (mul 1000.0 (math_exp 1.0))) 2718) (if (eq (round (math_log (math_exp 5.0))) 5) 10000 0) 0))
    (let c5 (if (eq (round (mul 100.0 (div 22.0 7.0))) 314) (if (eq (round (mod 7.0 3.0)) 1) 100000 0) 0))
    (let c6 (if (eq (round (fpow 2.0 10.0)) 1024) (if (eq (round (mul 1000.0 (fpow 2.0 0.5))) 1414) 1000000 0) 0))
    (sum (list c0 c1 c2 c3 c4 c5 c6)))
