; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/str-byte-at.fk
; preludes: form-stdlib/sha256.fk form-stdlib/hmac-sha256.fk form-stdlib/hex.fk
; preludes: form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
; preludes: form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk form-stdlib/rag-ask.fk
; preludes: form-stdlib/form-cli-ask.fk form-stdlib/form-cli-router.fk
; preludes: form-stdlib/form-cli-judge.fk form-stdlib/form-cli-sufficiency.fk
; preludes: form-stdlib/form-freq-check.fk form-stdlib/trust-row.fk
; preludes: form-stdlib/form-cli-ask-gate.fk form-stdlib/form-cli-staged-trace.fk
; preludes: form-stdlib/form-cli-request.fk
; preludes: form-stdlib/form-cli-carrier.fk
; preludes: form-stdlib/voice-traits.fk form-stdlib/nearest-shape.fk
; preludes: form-stdlib/co-learning.fk form-stdlib/co-learning-stream.fk
; preludes: form-stdlib/mesh-dispatch.fk form-stdlib/surprise-salience.fk
; preludes: form-stdlib/host-sense-organ.fk form-stdlib/speech-organ.fk
; preludes: form-stdlib/native-host-instance.fk form-stdlib/resource-port.fk
; preludes: form-stdlib/bml-native-interface-package-import.fk form-stdlib/hati-os-targets.fk
; preludes: form-stdlib/form-native-resource-interfaces.fk form-stdlib/form-fs.fk
; preludes: form-stdlib/storage-port.fk form-stdlib/host-kernel-carrier.fk
; preludes: form-stdlib/fnri-standin.fk form-stdlib/fnri-receipt.fk
; preludes: form-stdlib/current-branch-landing.fk form-stdlib/form-cli.fk
;
; form-cli-band — native form-cli dispatch + fnri catalog on fkwu (source walk).
; Verdict 524287 = 4095 dispatch/fnri + 4096 ask reaches grounded lane
; + 8192 synthesis-status names the observed model-lane pieces and the decoded
; answer binding + 49152 current-branch landing readiness dispatch
; + 65536 final-observations/model-convergence keeps all remaining bridges in one lane
; + 131072 carrier-id dispatch + 262144 full-nonce challenge dispatch.

(do
    (let c0 (if (str_eq (fc-respond "ping") "pong") 1 0))
    (let help (fc-respond "help"))
    (let c1 (if (lt (str_find help "no HTTP oracle" 0) 0) 0 2))
    (let c2 (if (str_eq (fc-respond "version") "form-cli 0.3") 4 0))
    (let c3 (if (str_eq (fc-respond "ping extra") "pong") 8 0))
    (let c4 (if (str_eq (fc-respond "foobar") "form-cli: unknown verb 'foobar' — type 'help'") 16 0))
    (let c5 (if (str_eq (fc-respond "about") "form-cli is one self-contained native binary: a Form program that dispatches verbs and runs an interactive read-eval-print loop, with no separate runtime. Pipe commands on stdin, or run it on a terminal and type. help lists the verbs.") 32 0))
    (let c6 (if (str_eq (fc-respond "kernel") "form-cli runs on fkwu, a universal walker generated entirely from Form recipes and compiled to native code. The same walker runs any Form program. this binary has the form-cli program built into it.") 64 0))
    (let c7 (if (str_eq (fc-respond "recreate") "to rebuild: run the source verb to print the Form source this binary carries. build-form-cli.sh installs the stamped native platform binary when present; maintainer regeneration refreshes bootstrap artifacts. the result runs on its own.") 128 0))
    (let c8 (if (str_eq (fc-respond "") "form-cli: unknown verb '' — type 'help'") 256 0))
    (let c9 (if (str_eq (fc-respond "native-host android 1 1 1 2 690 1 7 gold") "native-host-instance|android|1|1|1|1|1|1|learn-from-surprise|gold") 512 0))
    (let c10 (if (str_eq (fc-respond "fnri witness") "32767") 1024 0))
    (let c11 (if (str_eq (fc-respond "fnri know standard-receipt") "docs/coherence-substrate/standard-receipt.form") 2048 0))
    ; c12 — THE MISS, ITS LANE, AND WHY THIS IS NOT A str_eq ANY MORE.
    ;
    ; It was one: the reply had to EQUAL "[ask: local fkwu RAG index has no grounded hit]". That made
    ; the band's verdict depend on a file outside the band. When a native ASK artifact is staged in
    ; .coherence-network and bound to some OTHER question, the ask verb correctly appends
    ; `declined:native-lane:question-not-bound` — a longer, more honest reply — and str_eq said no.
    ; The band therefore answered 524287 on a host that had never run the model lane and 520191 on
    ; one that had, with nothing in either number saying which world it was measured in. A verdict
    ; that moves with the contents of a directory it does not name is not a verdict.
    ;
    ; So the claim is stated as what it always meant: the reply BEGINS with the miss sentence, and it
    ; NAMES the grounded lane. Anything the native lane appends about why it declined is additional
    ; and welcome. Both halves are asserted, because pinning only the sentence would let the
    ; attribution disappear again silently, and the attribution is the claim.
    (let miss (fc-respond "ask standard receipt"))
    (let c12 (if (and (eq (str_find miss "[ask: local fkwu RAG index has no grounded hit]" 0) 0)
                      (not (lt (str_find miss "local-lane:fkwu-rag-grounded" 0) 0)))
                 4096 0))
    (let synth (fc-respond "synthesis-status"))
    (let c13 (if (and (not (lt (str_find synth "fkwu-metal-answer-bound" 0) 0))
                      (and (not (lt (str_find synth "available:gguf-locate,gguf-model-cell,gguf-tensor-slice-math,gguf-tensor-set-cell,gguf-semantic-token-generation,gguf-fullwidth-logit-generation,sampler-min-p-four-way,weight-load,block-join,real-gguf-tensor-math-four-way,metal-matvec,metal-model-cell,metal-decode-step,tokenizer-carrier-four-way,llama3-pretokenizer-four-way,real-gguf-tensor-map,metal-weight-bytes-runtime,autoregressive-loop-four-way,ask-staged-model-call-witness,decoded-prose-answer-binding" 0) 0))
                      (and (not (lt (str_find synth "observed:tokenizer-carrier,full-gguf-weight-map,named-real-gguf-tensor-math,full-gguf-named-tensor-slice-math,full-gguf-required-tensor-set-materialization,real-gguf-tokenizer-token-decode,semantic-token-generation,full-width-model-logit-generation,sampler-min-p-four-way,metal-weight-bytes-runtime,autoregressive-loop,ask-staged-model-call,decoded-prose-answer-binding" 0) 0))
                      (and (not (lt (str_find synth "missing:full-real-llama-gguf-token-generation" 0) 0))
                           (not (lt (str_find (fc-respond "decoded-answer") "prose-generation:observed-decoded-prose-answer-binding" 0) 0)))))) 8192 0))
    (let c14 (if (str_eq (fc-respond "land-readiness OPEN 0 none CLEAN 3 0 0 0") "ready") 16384 0))
    (let c15 (if (str_eq (fc-respond "land-readiness OPEN 0 none CLEAN 3 1 0 0 1") "waiting") 32768 0))
    (let convergence (fc-respond "final-observations"))
    (let c16 (if (and (not (lt (str_find convergence "model-lane-convergence:one-wide-move" 0) 0))
                      (and (not (lt (str_find convergence "wide-move:complete-full-width-tensor-payload-staging,dequant-and-accelerator-buffer-placement,full-multilayer-gqa-hidden-state-loop,full-vocabulary-hidden-state-logits,real-token-id-decode,ask-answer-binding" 0) 0))
                      (and (not (lt (str_find convergence "pending:full-real-llama-gguf-token-generation" 0) 0))
                           (not (lt (str_find convergence "method:move-all-remaining-bridges-together-under-one-receipt" 0) 0))))) 65536 0))
    (let carrier-id (fc-respond "carrier-id"))
    (let c17 (if (str_eq carrier-id
        "carrier-id|form-cli-carrier-v2|FORM_CLI_SOURCE_SHA256_PLACEHOLDER|coherence-kernel-fkwu-native-v2") 131072 0))
    (let challenge (fc-respond
        "carrier-challenge 000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"))
    (let c18 (if (not (lt (str_find challenge
        "1cb41be978d307c11bf41602cd11bdac834046103d6fc89a6f69cd0c6c4efb21" 0) 0)) 262144 0))
    (sum (list c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17 c18)))
