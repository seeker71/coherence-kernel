; preludes: form-stdlib/core.fk form-stdlib/name-lexicon.fk form-stdlib/locale-registry.fk
;
; locale-registry-band.fk — sixty-four seats, English one among many.
;
; The crystal's proofs: exactly 64 locale rows; the first three are the
; body's OWN surfaces (nsym, sexpr, bml — the structural triad of the
; registry's filtration); English sits THIRTEENTH (index 12, where grammar
; entered the y-space) and holds exactly ONE seat of 64 — 1.6% of the
; locale space, no longer dominant by construction; the kinds partition
; cleanly; every proof stamp is a legal value and the pending count is
; stated exactly (no silent caps: 37 seats are named intentions, not
; claims); and the working face renders: zh render changes source text and
; round-trips identically through the registry door.
;
; Bits: 1 count=64; 2 own-triad first; 4 en at index 12; 8 en holds exactly
; one seat; 16 kinds partition (own+nl+pl=64); 32 proof stamps all legal;
; 64 pending count exact (37); 128 zh render+accept round-trip via the
; registry door. Verdict 255.
(do
    (let c0 (if (eq (lr-count) 64) 1 0))
    (let c1 (if (and (str_eq (lr-code (lr-at 0)) "nsym")
                (and (str_eq (lr-code (lr-at 1)) "sexpr")
                     (str_eq (lr-code (lr-at 2)) "bml"))) 2 0))
    (let c2 (if (str_eq (lr-code (lr-at 12)) "en") 4 0))
    (let c3 (if (eq (lr-count-code "en") 1) 8 0))
    (let c4 (if (eq (add (lr-count-kind "own") (add (lr-count-kind "nl") (lr-count-kind "pl"))) 64) 16 0))
    (let c5 (if (eq (add (lr-count-proof "4way")
                    (add (lr-count-proof "fkwu")
                    (add (lr-count-proof "3kernel") (lr-count-proof "pending")))) 64) 32 0))
    (let c6 (if (eq (lr-count-proof "pending") 37) 64 0))
    (let src "(defn head-or-empty (xs) (if (nil? xs) (empty) (head xs)))")
    (let rendered (lr-render "zh" src))
    (let c7 (if (and (not (str_eq rendered src)) (str_eq (lr-accept "zh" rendered) src)) 128 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
