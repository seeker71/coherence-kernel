; program-image-typed-carrier-band.fk -- Layer 8h3 typed program-image carrier witness.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/program-image-fkb.fk form-stdlib/typed-literal-carrier.fk form-stdlib/program-image-recipe-carrier.fk form-stdlib/program-image-typed-carrier.fk
;
; Expected: 16777215

(do
    (defn pitcb-score (ok bit) (if ok bit 0))
    (defn pitcb-manifest-has (name)
        (program-image-typed-carrier-manifest-has? name (program-image-typed-carrier-manifest)))
    (defn pitcb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn pitcb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn pitcb-roots () (pitc-fn-roots (list 0 3)))
    (defn pitcb-node-rows ()
        (pitc-node-rows
            (list
                (pitc-node-row 1 42 0 0)
                (pitc-node-row 12 0 0 0))))
    (defn pitcb-string-rows ()
        (pitc-string-rows
            (list
                (pitc-string-row (list 65 66))
                (pitc-string-row (list 0 255)))))
    (defn pitcb-table ()
        (pitc-table-from-sections (pitcb-roots) (pitcb-node-rows) (pitcb-string-rows)))
    (defn pitcb-envelope ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            1
                            (pitcb-table)))
    (defn pitcb-carrier ()
        (pitc-carrier-from-typed-envelope (pitcb-envelope)))
    (defn pitcb-raw ()
        (pirc-carrier-pif-envelope (pitcb-carrier)))
    (defn pitcb-recipe ()
        (pirc-carrier-recipe (pitcb-carrier)))
    (defn pitcb-recipe-table ()
        (nth (node_children (pitcb-recipe)) 8))

    (defn pitcb-malformed ()
        (tlit-int 7))
    (defn pitcb-bad-metadata ()
        (intern_node (pitc-envelope-bp)
            (list
                (tlit-string (pif-version))
                (tlit-int 99)
                (tlit-string "sha:src-a")
                (tlit-int 100)
                (tlit-string "src/kernel.fkb")
                (tlit-string "sha:fkb-a")
                (tlit-int 101)
                (tlit-int 1)
                (pitcb-table))))
    (defn pitcb-bad-seal ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            0
                            (pitcb-table)))
    (defn pitcb-bad-table-category ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            1
                            (tlit-list (empty))))
    (defn pitcb-bad-root-cell ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            1
                            (pitc-table-node
                                (tlit-int 1)
                                (intern_node (pitc-fn-roots-bp) (list (tlit-string "0")))
                                (tlit-int 1)
                                (pitc-node-rows (list (pitc-node-row 1 42 0 0)))
                                (tlit-int 1)
                                (pitc-string-rows (list (pitc-string-row (list 65)))))))
    (defn pitcb-bad-count ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            1
                            (pitc-table-node
                                (tlit-int 3)
                                (pitcb-roots)
                                (tlit-int 2)
                                (pitcb-node-rows)
                                (tlit-int 2)
                                (pitcb-string-rows))))
    (defn pitcb-bad-row-arity ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            1
                            (pitc-table-node
                                (tlit-int 1)
                                (pitc-fn-roots (list 0))
                                (tlit-int 1)
                                (pitc-node-rows
                                    (list (intern_node (pitc-node-row-bp)
                                            (list (tlit-int 1) (tlit-int 42) (tlit-int 0)))))
                                (tlit-int 1)
                                (pitc-string-rows (list (pitc-string-row (list 65)))))))
    (defn pitcb-bad-byte ()
        (pitc-envelope-node "src/kernel.fk" "sha:src-a" 100
                            "src/kernel.fkb" "sha:fkb-a" 101
                            1
                            (pitc-table-node
                                (tlit-int 1)
                                (pitc-fn-roots (list 0))
                                (tlit-int 1)
                                (pitc-node-rows (list (pitc-node-row 1 42 0 0)))
                                (tlit-int 1)
                                (pitc-string-rows (list (pitc-string-row (list 300)))))))

    (defn pitcb-malformed-row? (c)
        (and (str_eq (pirc-carrier-status c) (pirc-status-refused))
             (and (str_eq (pirc-carrier-reason c) (pirc-reason-malformed-pif-envelope))
                  (pirc-no-recipe? (pirc-carrier-recipe c)))))
    (defn pitcb-invalid-row? (c)
        (and (str_eq (pirc-carrier-status c) (pirc-status-investigate))
             (and (str_eq (pirc-carrier-reason c) (pirc-reason-invalid-pif-envelope))
                  (pirc-no-recipe? (pirc-carrier-recipe c)))))
    (defn pitcb-non-carrierable-row? (c)
        (and (str_eq (pirc-carrier-status c) (pirc-status-investigate))
             (and (str_eq (pirc-carrier-reason c) (pirc-reason-non-carrierable-table))
                  (pirc-no-recipe? (pirc-carrier-recipe c)))))

    (defn pitcb-bit-manifest ()
        (pitcb-score
            (and (eq (pitcb-manifest-has "typed-program-image-envelope") 1)
            (and (eq (pitcb-manifest-has "typed-table-sections") 1)
            (and (eq (pitcb-manifest-has "typed-literal-input-only") 1)
            (and (eq (pitcb-manifest-has "normalizes-to-raw-pif-envelope") 1)
            (and (eq (pitcb-manifest-has "returns-pirc-carrier-row") 1)
            (and (eq (pitcb-manifest-has "builds-pirc-recipe-directly") 1)
            (and (eq (pitcb-manifest-has "does-not-change-raw-pirc-admission") 1)
            (and (eq (pitcb-manifest-has "direct-fkwu-carrier-ready-for-typed-input") 1)
            (and (eq (pitcb-manifest-has "direct-fkwu-raw-negative-nodeid-alias-floor") 1)
            (and (eq (pitcb-manifest-has "registered-blueprint-categories") 1)
            (and (eq (pitcb-manifest-has "reason-partition-preserved") 1)
            (and (eq (pitcb-manifest-has "no-parser") 1)
            (and (eq (pitcb-manifest-has "no-form-binary-io") 1)
            (and (eq (pitcb-manifest-has "no-runtime-load-call") 1)
            (and (eq (pitcb-manifest-has "no-attempt-or-observation-row") 1)
            (and (eq (pitcb-manifest-has "no-selector-install") 1)
                 (eq (pitcb-manifest-has "no-c-seed-growth") 1)))))))))))))))))
            1))
    (defn pitcb-bit-registered-bp ()
        (pitcb-score
            (and (node_eq (pitc-envelope-bp) (make_nodeid 8 45 6 60))
            (and (node_eq (pitc-table-bp) (make_nodeid 8 45 6 61))
            (and (node_eq (pitc-fn-roots-bp) (make_nodeid 8 45 6 62))
            (and (node_eq (pitc-node-rows-bp) (make_nodeid 8 45 6 63))
            (and (node_eq (pitc-node-row-bp) (make_nodeid 8 45 6 64))
            (and (node_eq (pitc-string-rows-bp) (make_nodeid 8 45 6 65))
                 (node_eq (pitc-string-row-bp) (make_nodeid 8 45 6 66))))))))
            2))
    (defn pitcb-bit-valid-carrier ()
        (pitcb-score
            (and (pirc-carrier? (pitcb-carrier))
            (and (str_eq (pirc-carrier-status (pitcb-carrier)) (pirc-status-carrier-ready))
            (and (str_eq (pirc-carrier-reason (pitcb-carrier)) (pirc-reason-carrier-ready))
                 (not (pirc-no-recipe? (pirc-carrier-recipe (pitcb-carrier)))))))
            4))
    (defn pitcb-bit-raw-envelope-normalized ()
        (pitcb-score
            (and (pif-envelope? (pitcb-raw))
            (and (pif-envelope-valid? (pitcb-raw))
            (and (str_eq (pif-envelope-source-path (pitcb-raw)) "src/kernel.fk")
            (and (eq (pif-table-nf (pif-envelope-table (pitcb-raw))) 2)
            (and (eq (nth (pif-table-fn-roots (pif-envelope-table (pitcb-raw))) 1) 3)
                 (eq (nth (nth (pif-table-string-byte-rows (pif-envelope-table (pitcb-raw))) 1) 1) 255))))))
            8))
    (defn pitcb-bit-recipe-envelope ()
        (do
            (let kids (node_children (pitcb-recipe)))
            (pitcb-score
                (and (node_eq (node_category (pitcb-recipe)) (pirc-envelope-bp))
                (and (eq (len kids) 10)
                (and (str_eq (node_value (nth kids 0)) (pif-version))
                (and (str_eq (node_value (nth kids 1)) "src/kernel.fk")
                (and (eq (node_value (nth kids 7)) 1)
                     (node_eq (node_category (nth kids 9)) (pirc-symbol-image-bp)))))))
                16)))
    (defn pitcb-bit-recipe-table ()
        (do
            (let table (pitcb-recipe-table))
            (let kids (node_children table))
            (pitcb-score
                (and (node_eq (node_category table) (pirc-table-bp))
                (and (eq (node_value (nth kids 0)) 2)
                (and (node_eq (node_category (nth kids 1)) (pirc-fn-roots-bp))
                (and (eq (node_value (nth kids 2)) 2)
                (and (node_eq (node_category (nth kids 3)) (pirc-node-rows-bp))
                (and (eq (node_value (nth kids 4)) 2)
                     (node_eq (node_category (nth kids 5)) (pirc-string-rows-bp))))))))
                32)))
    (defn pitcb-bit-shapes ()
        (pitcb-score
            (and (pitc-envelope-shape? (pitcb-envelope))
            (and (pitc-table-shape? (pitcb-table))
            (and (pitc-fn-roots-carrierable? (pitcb-roots))
            (and (pitc-node-rows-carrierable? (pitcb-node-rows))
                 (pitc-string-rows-carrierable? (pitcb-string-rows))))))
            64))
    (defn pitcb-bit-metadata-and-table ()
        (pitcb-score
            (and (pitc-envelope-metadata-valid? (pitcb-envelope))
            (and (pitc-table-carrierable? (pitcb-table))
                 (pitc-table-semantic-valid? (pitcb-table))))
            128))
    (defn pitcb-bit-raw-extraction ()
        (do
            (let raw-table (pitc-raw-table (pitcb-table)))
            (pitcb-score
                (and (eq (pif-table-nf raw-table) 2)
                (and (eq (nth (pif-table-fn-roots raw-table) 0) 0)
                (and (eq (nth (nth (pif-table-node-rows raw-table) 0) 1) 42)
                     (eq (nth (nth (pif-table-string-byte-rows raw-table) 0) 1) 66))))
                256)))
    (defn pitcb-bit-malformed ()
        (pitcb-score
            (pitcb-malformed-row? (pitc-carrier-from-typed-envelope (pitcb-malformed)))
            512))
    (defn pitcb-bit-invalid-metadata ()
        (pitcb-score
            (and (pitcb-invalid-row? (pitc-carrier-from-typed-envelope (pitcb-bad-metadata)))
                 (pitcb-invalid-row? (pitc-carrier-from-typed-envelope (pitcb-bad-seal))))
            1024))
    (defn pitcb-bit-non-carrierable-table ()
        (pitcb-score
            (and (pitcb-non-carrierable-row? (pitc-carrier-from-typed-envelope (pitcb-bad-table-category)))
                 (pitcb-non-carrierable-row? (pitc-carrier-from-typed-envelope (pitcb-bad-root-cell))))
            2048))
    (defn pitcb-bit-invalid-table-semantics ()
        (pitcb-score
            (and (pitcb-invalid-row? (pitc-carrier-from-typed-envelope (pitcb-bad-count)))
            (and (pitcb-invalid-row? (pitc-carrier-from-typed-envelope (pitcb-bad-row-arity)))
                 (pitcb-invalid-row? (pitc-carrier-from-typed-envelope (pitcb-bad-byte)))))
            4096))
    (defn pitcb-bit-reason-partition ()
        (pitcb-score
            (and (pitcb-malformed-row? (pitc-carrier-from-typed-envelope (pitcb-malformed)))
            (and (pitcb-invalid-row? (pitc-carrier-from-typed-envelope (pitcb-bad-count)))
                 (pitcb-non-carrierable-row? (pitc-carrier-from-typed-envelope (pitcb-bad-root-cell)))))
            8192))
    (defn pitcb-bit-no-raw-admission-call ()
        (do
            (let text (pitcb-read-file-any "form/form-stdlib/program-image-typed-carrier.fk"
                                           "../form/form-stdlib/program-image-typed-carrier.fk"))
            (pitcb-score (not (pitcb-has? text "pirc-carrier-from-envelope")) 16384)))
    (defn pitcb-bit-static-and-mirror ()
        (do
            (let text (pitcb-read-file-any "form/form-stdlib/program-image-typed-carrier.fk"
                                           "../form/form-stdlib/program-image-typed-carrier.fk"))
            (let grammar (pitcb-read-file-any "grammars/program-image-typed-carrier.fk"
                                              "../grammars/program-image-typed-carrier.fk"))
            (let registry (pitcb-read-file-any "form/form-stdlib/blueprint-registry.json"
                                               "../form/form-stdlib/blueprint-registry.json"))
            (pitcb-score
                (and (str_eq text grammar)
                (and (pitcb-has? registry "PROGRAM-IMAGE-TYPED-ENVELOPE")
                (and (pitcb-has? registry "PROGRAM-IMAGE-TYPED-STRING-ROW")
                (and (not (pitcb-has? text "line-grammar"))
                (and (not (pitcb-has? text "g-match-rule"))
                (and (not (pitcb-has? text "cursor-str"))
                (and (not (pitcb-has? text "write_form_binary"))
                (and (not (pitcb-has? text "read_form_binary"))
                (and (not (pitcb-has? text "recipe_to_bytes"))
                (and (not (pitcb-has? text "bytes_to_recipe"))
                (and (not (pitcb-has? text "walk_recipe"))
                (and (not (pitcb-has? text "fk_run"))
                (and (not (pitcb-has? text "runtime-artifact-attempt"))
                (and (not (pitcb-has? text "runtime-table-payload-attempt"))
                (and (not (pitcb-has? text "source-artifact-probe-observation"))
                (and (not (pitcb-has? text "sap-observation"))
                (and (not (pitcb-has? text "rao-obs"))
                (and (not (pitcb-has? text "runtime-artifact-selector"))
                (and (not (pitcb-has? text "ras-selection"))
                (and (not (pitcb-has? text "dlopen"))
                     (not (pitcb-has? text "dlsym"))))))))))))))))))))))
                32768)))
    (defn pitcb-bit-pirc-raw-still-native-floor ()
        (pitcb-score
            (eq (pitcb-manifest-has "does-not-change-raw-pirc-admission") 1)
            65536))
    (defn pitcb-bit-recipe-stable ()
        (pitcb-score
            (node_eq (pitcb-recipe)
                     (pirc-carrier-recipe (pitc-carrier-from-typed-envelope (pitcb-envelope))))
            131072))
    (defn pitcb-bit-normalized-envelope-slot ()
        (pitcb-score
            (and (node_eq (node_category (pitcb-envelope)) (pitc-envelope-bp))
                 (pif-envelope? (pitcb-raw)))
            262144))
    (defn pitcb-bit-table-counts-derived ()
        (do
            (let raw-table (pif-envelope-table (pitcb-raw)))
            (pitcb-score
                (and (eq (pif-table-nf raw-table) (len (pif-table-fn-roots raw-table)))
                (and (eq (pif-table-nr raw-table) (len (pif-table-node-rows raw-table)))
                     (eq (pif-table-ns raw-table) (len (pif-table-string-byte-rows raw-table)))))
                524288)))
    (defn pitcb-bit-helper-version ()
        (pitcb-score (str_eq (pitc-version) "program-image-typed-carrier-v1") 1048576))
    (defn pitcb-bit-value-helpers ()
        (pitcb-score
            (and (eq (pitc-byte-value? 0) 1)
            (and (eq (pitc-byte-value? 255) 1)
            (and (eq (pitc-byte-value? 256) 0)
                 (eq (pitc-byte-value? -1) 0))))
            2097152))
    (defn pitcb-bit-no-runtime-claims ()
        (pitcb-score
            (and (eq (pitcb-manifest-has "no-form-binary-io") 1)
            (and (eq (pitcb-manifest-has "no-runtime-load-call") 1)
            (and (eq (pitcb-manifest-has "no-attempt-or-observation-row") 1)
            (and (eq (pitcb-manifest-has "no-selector-install") 1)
                 (eq (pitcb-manifest-has "no-c-seed-growth") 1)))))
            4194304))
    (defn pitcb-bit-direct-fkwu-feature-named ()
        (pitcb-score
            (and (eq (pitcb-manifest-has "direct-fkwu-carrier-ready-for-typed-input") 1)
                 (eq (pitcb-manifest-has "direct-fkwu-raw-negative-nodeid-alias-floor") 1))
            8388608))

    (defn program-image-typed-carrier-band ()
        (sum (list
            (pitcb-bit-manifest)
            (pitcb-bit-registered-bp)
            (pitcb-bit-valid-carrier)
            (pitcb-bit-raw-envelope-normalized)
            (pitcb-bit-recipe-envelope)
            (pitcb-bit-recipe-table)
            (pitcb-bit-shapes)
            (pitcb-bit-metadata-and-table)
            (pitcb-bit-raw-extraction)
            (pitcb-bit-malformed)
            (pitcb-bit-invalid-metadata)
            (pitcb-bit-non-carrierable-table)
            (pitcb-bit-invalid-table-semantics)
            (pitcb-bit-reason-partition)
            (pitcb-bit-no-raw-admission-call)
            (pitcb-bit-static-and-mirror)
            (pitcb-bit-pirc-raw-still-native-floor)
            (pitcb-bit-recipe-stable)
            (pitcb-bit-normalized-envelope-slot)
            (pitcb-bit-table-counts-derived)
            (pitcb-bit-helper-version)
            (pitcb-bit-value-helpers)
            (pitcb-bit-no-runtime-claims)
            (pitcb-bit-direct-fkwu-feature-named))))

    (program-image-typed-carrier-band))
