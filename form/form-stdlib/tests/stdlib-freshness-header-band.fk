; stdlib-freshness-header-band.fk -- parseable freshness/elevation header witness.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/stdlib-freshness-header.fk
;
; Expected: 8191

(do
    (defn sfhb-score (ok bit) (if ok bit 0))
    (defn sfhb-manifest-has (name)
        (stdlib-freshness-header-manifest-has?
            name
            (stdlib-freshness-header-manifest)))
    (defn sfhb-doc-source ()
        (str_concat
            "freshness file \"form/form-stdlib/form-definition-language.fk\" status \"current\" layer \"5/8j0\" grammar \"form-definition-language\" proof \"form-stdlib/tests/form-definition-language-band.fk=65535\" higher \"source-compiler-grammar-bridge\" action \"used by compiler lane\"\n"
            (str_concat
                "section \"module authoring\" grammar \"form-definition-language\" current \"module data fn surface lowers to Form floor\" higher \"direct program-image fkb emission\" action \"build fkb producer from admitted lowering\"\n"
                "section \"parser mechanics\" grammar \"bmf-grammar\" current \"scannerless BMF rules\" higher \"none-known\" action \"hold at grammar waist\"")))
    (defn sfhb-bad-source ()
        (str_concat (sfhb-doc-source) " trailing"))
    (defn sfhb-review ()
        (sfh-review (sfhb-doc-source)))
    (defn sfhb-bad-review ()
        (sfh-review (sfhb-bad-source)))
    (defn sfhb-file ()
        (sfh-review-file (sfhb-review)))
    (defn sfhb-sections ()
        (sfh-review-sections (sfhb-review)))
    (defn sfhb-first-section ()
        (head (sfhb-sections)))
    (defn sfhb-second-section ()
        (head (tail (sfhb-sections))))

    (defn stdlib-freshness-header-band ()
        (add
            (sfhb-score (eq (sfhb-manifest-has "scannerless") 1) 1)
        (add
            (sfhb-score (eq (sfhb-manifest-has "section-elevation-row") 1) 2)
        (add
            (sfhb-score (eq (sfhb-manifest-has "higher-question-required") 1) 4)
        (add
            (sfhb-score (sfh-review-ready? (sfhb-review)) 8)
        (add
            (sfhb-score (str_eq (sfh-file-row-file (sfhb-file)) "form/form-stdlib/form-definition-language.fk") 16)
        (add
            (sfhb-score (str_eq (sfh-file-row-status (sfhb-file)) "current") 32)
        (add
            (sfhb-score (str_eq (sfh-file-row-grammar (sfhb-file)) "form-definition-language") 64)
        (add
            (sfhb-score (eq (len (sfhb-sections)) 2) 128)
        (add
            (sfhb-score (str_eq (sfh-section-row-higher (sfhb-first-section)) "direct program-image fkb emission") 256)
        (add
            (sfhb-score (eq (sfh-section-row-has-higher? (sfhb-first-section)) 1) 512)
        (add
            (sfhb-score (eq (sfh-section-row-has-higher? (sfhb-second-section)) 0) 1024)
        (add
            (sfhb-score (eq (sfh-review-higher-count (sfhb-review)) 1) 2048)
            (sfhb-score (not (sfh-review-ready? (sfhb-bad-review))) 4096))))))))))))))

    (stdlib-freshness-header-band))
