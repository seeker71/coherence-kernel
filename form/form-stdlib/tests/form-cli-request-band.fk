; form-cli-request-band.fk — request-path safety, canonical batch embedding, and
; query/receipt association before the live filesystem wrapper.
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/str-byte-at.fk
; preludes: form-stdlib/sha256.fk form-stdlib/hmac-sha256.fk form-stdlib/hex.fk
; preludes: form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
; preludes: form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk
; preludes: form-stdlib/rag-ask.fk form-stdlib/form-cli-router.fk
; preludes: form-stdlib/form-cli-judge.fk form-stdlib/form-cli-sufficiency.fk
; preludes: form-stdlib/form-freq-check.fk form-stdlib/trust-row.fk
; preludes: form-stdlib/form-cli-ask-gate.fk form-stdlib/form-cli-staged-trace.fk
; preludes: form-stdlib/form-cli-request.fk
;
; Verdict 2097151 proves 21 independent request/association/embedding claims.

(do
    (defn fcrb-ground (key-hex request-id ref ctor source-key source-path answer-key persisted query-key)
        (do
            (let base (fcast-cat (list ref "|" ctor "|" source-key "|" source-path "|"
                answer-key "|" persisted "|" query-key "|990|1100")))
            (str_concat base (str_concat "|"
                (fcast-grounding-mac-for key-hex request-id base)))))
    (defn fcrb-cert (key-hex request-id ground ref ctor answer-key)
        (do
            (let evidence (fcast-frequency-certificate-key-for
                ref ctor answer-key "success"))
            (let base (fcast-cat (list ground "|" ref "|" ctor "|" answer-key
                "|" evidence "|990|1100|success")))
            (str_concat base (str_concat "|"
                (fcast-frequency-mac-for key-hex request-id base)))))

    (let key-hex "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f")
    (let persisted "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    (let answer-a-hex "41")
    (let answer-b-hex "42")
    (let answer-a-key (ra-answer-key-of-hex answer-a-hex))
    (let answer-b-key (ra-answer-key-of-hex answer-b-hex))
    (let line-a (ric-emit-grounded "@1.1.9.41" "@8.4.4.12" "docs/deploy.form"
        "cell" persisted answer-a-key answer-a-hex "A"
        (re-semantic-vec "deployment evidence kernel production verified witness")))
    (let line-b (ric-emit-grounded "@1.1.9.42" "@8.4.4.13" "docs/garden.form"
        "cell" persisted answer-b-key answer-b-hex "B"
        (re-semantic-vec "garden soil moisture seed planting")))
    (let raw-index (str_concat line-a (str_concat "\n" line-b)))
    (let query-a "deployed proof kernel")
    (let query-b "garden moisture planting")
    (let query-a-key (fcast-query-key query-a))
    (let query-b-key (fcast-query-key query-b))
    (let ground-a (fcrb-ground key-hex "test-request" "@1.1.9.41" "@8.4.4.12" persisted
        "docs/deploy.form" answer-a-key persisted query-a-key))
    (let receipt-a (fcrb-cert key-hex "test-request" ground-a "@1.1.9.41" "@8.4.4.12" answer-a-key))

    (let text-a "deployed proof kernel")
    (let text-b "garden moisture planting")
    (let embed-a (str_concat "6131|" (hex-encode (string_bytes text-a))))
    (let embed-b (str_concat "6232|" (hex-encode (string_bytes text-b))))
    (let embed-a-json (fcast-cat (list
        "{\"id_hex\":\"6131\",\"embedding_kind\":\"form-semantic-v2\",\"vec\":"
        (ric-emit-vec (re-semantic-vec text-a)) "}")))
    (let embed-b-json (fcast-cat (list
        "{\"id_hex\":\"6232\",\"embedding_kind\":\"form-semantic-v2\",\"vec\":"
        (ric-emit-vec (re-semantic-vec text-b)) "}")))

    (let hit-a (ra-stream-hit raw-index query-a))
    (let hit-b (ra-stream-hit raw-index query-b))
    (let trace-a (fcr-query-trace-at raw-index query-a receipt-a key-hex 1000))
    (let trace-b-replay (fcr-query-trace-at raw-index query-b receipt-a key-hex 1000))

    (let c0 (if (eq (fcr-id-valid? "req_A-17") 1) 1 0))
    (let c1 (if (and (eq (fcr-id-valid? "../escape") 0)
                      (eq (fcr-id-valid? "") 0)) 2 0))
    (let c2 (if (and (str_eq (fcr-query-path "abc") ".coherence-network/rag-requests/abc.query")
                      (str_eq (fcr-receipt-path "abc") ".coherence-network/rag-requests/abc.receipt")) 4 0))
    (let c3 (if (str_eq (fcr-embed-output embed-a) embed-a-json) 8 0))
    (let c4 (if (str_eq (fcr-embed-output (str_concat embed-a (str_concat "\n" embed-b)))
                  (str_concat embed-a-json (str_concat "\n" embed-b-json))) 16 0))
    (let c5 (if (str_eq (fcr-embed-output "zz|61") "embed-request:error:invalid-row") 32 0))
    (let c6 (if (str_eq (fcr-embed-output "61|62|63") "embed-request:error:invalid-row") 64 0))
    (let c7 (if (str_eq (fcr-embed-output "") "embed-request:error:invalid-row") 128 0))
    (let c8 (if (str_eq (ra-hit-node-id hit-a) "@1.1.9.41") 256 0))
    (let c9 (if (str_eq (ra-hit-node-id hit-b) "@1.1.9.42") 512 0))
    (let c10 (if (not (lt (str_find trace-a "observed:yes" 0) 0)) 1024 0))
    (let c11 (if (and (not (lt (str_find trace-b-replay "grounded:no" 0) 0))
                       (not (lt (str_find trace-b-replay "observed:no" 0) 0))) 2048 0))
    (let c12 (if (eq (fcr-id-valid? "a/b") 0) 4096 0))
    (let c13 (if (not (lt (str_find embed-a-json "form-semantic-v2" 0) 0)) 8192 0))
    (let c14 (if (not (str_eq query-a-key query-b-key)) 16384 0))
    (let c15 (if (eq (fcast-grounding-attested-for-at? hit-a receipt-a
                       "test-request" query-b-key key-hex 1000) 0) 32768 0))
    ; External canonical fixture, cross-checked byte-for-byte with OpenSSL and
    ; Python hmac.new. This prevents a self-signed Form-only MAC test from hiding
    ; canonicalization drift at the host boundary.
    (let external-base
        "@1.1.9.41|@8.4.4.12|8c813801125c46f65576ef356719c7a1f60fe3ed6dd81e3b96edd1c7a1db810f|docs/grounding.form|559aead08264d5795d3909718cdd05abd49572e84fe55590eef31a88a08fdffd|8c813801125c46f65576ef356719c7a1f60fe3ed6dd81e3b96edd1c7a1db810f|a77e39d1098de82a4fa01254f660098a90378b3fb57d2d89a950cbda204be043|1000|1100")
    (let c16 (if (str_eq (fcast-grounding-mac-for key-hex "signed" external-base)
        "d0047cba7580f6374f5e9de9d1ea283cb238c65a8d18d22c6c42a69091b81e89") 65536 0))
    (let c17 (if (not (lt (str_find (fcast-grounding-debug-for-at
        hit-a receipt-a "test-request" query-a-key key-hex 1000)
        "grounding-debug bits:511" 0) 0)) 131072 0))
    (let c18 (if (and (eq (fcr-max-query-bytes) 8192)
                       (eq (fcr-max-receipt-bytes) 16384)) 262144 0))
    (let nul-text (str_concat "A" (str_concat (byte_to_str 0) "λ")))
    (let c19 (if (eq (fcr-text-has-nul? nul-text) 1) 524288 0))
    (let c20 (if (eq (fcr-text-has-nul? "Aλ🙂") 0) 1048576 0))

    (sum (list c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17
        c18 c19 c20)))
