            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-c-growth) (scffeb-pif) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif-malformed) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif-seal-bad) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif-table-bad) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif-source-mismatch) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif-stale) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (list "not-witness") (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (scffeb-nonready-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (scffeb-drift-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (scffeb-pif-forged-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (scffeb-path-forged-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (scffeb-content-forged-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-fkb) (scffeb-pif) (scffeb-witness) (scffeb-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-dylib) (scffeb-pif) (scffeb-witness) (sce-no-dylib)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-dylib) (scffeb-pif) (scffeb-witness) (scffeb-dylib-malformed)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-dylib) (scffeb-pif) (scffeb-witness) (scffeb-dylib-source-mismatch)))
            (scffeb-reason-of (scffe-emission-from-compile (scffeb-compile-envelope) (scffeb-output-dylib) (scffeb-pif) (scffeb-witness) (scffeb-dylib-policy-bad)))))
    (defn scffeb-bit-reason-coverage ()
        (do
            (let c (rcov-coverage (scffe-reason-manifest) (scffeb-observed-reasons)))
            (scffeb-score (rcov-covered? c) 134217728)))
    (defn scffeb-bit-static-and-mirror ()
        (do
            (let text (scffeb-read-file-any "form/form-stdlib/source-compiler-fkb-file-emission.fk"
                                            "../form/form-stdlib/source-compiler-fkb-file-emission.fk"))
            (let grammar (scffeb-read-file-any "grammars/source-compiler-fkb-file-emission.fk"
                                               "../grammars/source-compiler-fkb-file-emission.fk"))
            (scffeb-score
                (and (str_eq text grammar)
                (and (not (scffeb-has? text "pite-table-payload"))
                (and (not (scffeb-has? text "sce-table-payload-match"))
                (and (not (scffeb-has? text "runtime-table-payload"))
                (and (not (scffeb-has? text "rtta-"))
                (and (not (scffeb-has? text "pitw-"))
                (and (not (scffeb-has? text "sce-emission-from-compile"))
                (and (not (scffeb-has? text "write_form_binary"))
                (and (not (scffeb-has? text "read_form_binary"))
                     (not (scffeb-has? text "fk_run")))))))))))
                268435456)))
    (defn scffeb-bit-neighbor-8h5 ()
        (do
            (let w (scffeb-witness))
            (scffeb-score
                (and (pifbf-witness? w)
                (and (str_eq (pifbf-witness-status w) (pifbf-status-ready))
                     (scffe-witness-internal-replay-ok? w)))
                536870912)))
    (defn scffeb-bit-no-table-payload-argument ()
        (do
            (let e (scffeb-emission-ok))
            (scffeb-score
                (and (eq (len e) 9)
                (and (pifbf-witness? (nth e 4))
                     (not (str_eq (nth e 0) "source-compiler-emission"))))
                1073741824)))

    (defn source-compiler-fkb-file-emission-band ()
        (do
            (let _setup (scffeb-setup))
            (let score (sum (list
                (scffeb-bit-manifest-1)
                (scffeb-bit-manifest-2)
                (scffeb-bit-reason-manifest)
                (scffeb-bit-happy-no-dylib)
                (scffeb-bit-happy-with-dylib)
                (scffeb-bit-fkb-route)
                (scffeb-bit-witness-carried)
                (scffeb-bit-output-no-fkb)
                (scffeb-bit-output-missing-table-payload)
                (scffeb-bit-output-c-growth)
                (scffeb-bit-malformed-witness)
                (scffeb-bit-nonready-witness)
                (scffeb-bit-witness-drift)
                (scffeb-bit-witness-pif-mismatch)
                (scffeb-bit-witness-path-mismatch)
                (scffeb-bit-witness-content-mismatch)
                (scffeb-bit-malformed-pif)
                (scffeb-bit-pif-seal)
                (scffeb-bit-pif-table)
                (scffeb-bit-source-mismatch)
                (scffeb-bit-pif-stale)
                (scffeb-bit-dylib-not-requested)
                (scffeb-bit-dylib-requested-missing)
                (scffeb-bit-malformed-dylib)
                (scffeb-bit-dylib-source-mismatch)
                (scffeb-bit-dylib-policy)
                (scffeb-bit-row-accessors)
                (scffeb-bit-reason-coverage)
                (scffeb-bit-static-and-mirror)
                (scffeb-bit-neighbor-8h5)
                (scffeb-bit-no-table-payload-argument))))
            (let _cleanup (scffeb-cleanup))
            score))

    (source-compiler-fkb-file-emission-band))
