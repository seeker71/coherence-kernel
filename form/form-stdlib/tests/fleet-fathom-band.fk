; preludes: form-stdlib/core.fk form-stdlib/obs-verify.fk form-stdlib/trust-decay.fk form-stdlib/channel-interface.fk form-stdlib/satsang.fk form-stdlib/satsang-field.fk form-stdlib/persistence.fk form-stdlib/world-module-model.fk form-stdlib/world-model-growth.fk form-stdlib/loop-stewardship.fk form-stdlib/loop-ledger-host.fk form-stdlib/fleet-fathom.fk
;
; fleet-fathom-band — the fleet muster over a REAL fixture store (fs-crud
; discipline: real tree on the live OS, asserted, torn down): one calm lane,
; one deep lane, one ghost lane; the astern list surfaces exactly the deep
; lane.
;
; Verdict 63 when every claim lands:
;   1     the muster returns one row per lane, names kept in order
;   2     the calm lane reads (shipped 3, witnessed 2, lag 1, level 3)
;   4     the deep lane reads level 1 (lag 5 past the max-4 budget)
;   8     astern surfaces exactly the deep lane
;   16    all-abreast? answers 0 with the deep lane, 1 without it
;   32    the fixture tree tears down clean
(do
    (let root (str_concat (temp_dir) "/fleet-fathom-band"))
    (let calm-in (str_concat root "/calm-in"))
    (let calm-kept (str_concat root "/calm-kept"))
    (let deep-in (str_concat root "/deep-in"))
    (let deep-kept (str_concat root "/deep-kept"))

    ;; clean slate, then the store
    (fs_remove (str_concat calm-in "/a"))
    (fs_remove (str_concat calm-kept "/k1"))
    (fs_remove (str_concat calm-kept "/k2"))
    (fs_remove (str_concat deep-in "/a"))
    (fs_remove (str_concat deep-in "/b"))
    (fs_remove (str_concat deep-in "/c"))
    (fs_remove (str_concat deep-in "/d"))
    (fs_remove (str_concat deep-in "/e"))
    (fs_rmdir calm-in)
    (fs_rmdir calm-kept)
    (fs_rmdir deep-in)
    (fs_rmdir deep-kept)
    (fs_rmdir root)
    (fs_mkdir root)
    (fs_mkdir calm-in)
    (fs_mkdir calm-kept)
    (fs_mkdir deep-in)
    (fs_mkdir deep-kept)
    (write_file_text (str_concat calm-in "/a") "A")
    (write_file_text (str_concat calm-kept "/k1") "1")
    (write_file_text (str_concat calm-kept "/k2") "2")
    (write_file_text (str_concat deep-in "/a") "A")
    (write_file_text (str_concat deep-in "/b") "B")
    (write_file_text (str_concat deep-in "/c") "C")
    (write_file_text (str_concat deep-in "/d") "D")
    (write_file_text (str_concat deep-in "/e") "E")

    (let lanes
        (list
            (ffm-lane "calm" calm-in calm-kept 4 2)
            (ffm-lane "deep" deep-in deep-kept 4 2)
            (ffm-lane "ghost" (str_concat root "/no-in") (str_concat root "/no-kept") 4 2)))
    (let rows (ffm-muster lanes))
    (let calm-row (nth rows 0))
    (let deep-row (nth rows 1))

    (let c0
        (if (and (eq (len rows) 3)
             (and (str_eq (ffm-row-name calm-row) "calm")
              (and (str_eq (ffm-row-name deep-row) "deep")
                   (str_eq (ffm-row-name (nth rows 2)) "ghost")))) 1 0))
    (let c1
        (if (and (eq (nth calm-row 1) 3)
             (and (eq (nth calm-row 2) 2)
              (and (eq (ffm-row-lag calm-row) 1)
                   (eq (ffm-row-level calm-row) 3)))) 2 0))
    (let c2 (if (eq (ffm-row-level deep-row) 1) 4 0))
    (let astern (ffm-astern rows))
    (let c3
        (if (and (eq (len astern) 1)
                 (str_eq (ffm-row-name (head astern)) "deep")) 8 0))
    (let calm-only (ffm-muster (list (ffm-lane "calm" calm-in calm-kept 4 2))))
    (let c4
        (if (and (eq (ffm-all-abreast? rows) 0)
                 (eq (ffm-all-abreast? calm-only) 1)) 16 0))

    ;; tear down
    (fs_remove (str_concat calm-in "/a"))
    (fs_remove (str_concat calm-kept "/k1"))
    (fs_remove (str_concat calm-kept "/k2"))
    (fs_remove (str_concat deep-in "/a"))
    (fs_remove (str_concat deep-in "/b"))
    (fs_remove (str_concat deep-in "/c"))
    (fs_remove (str_concat deep-in "/d"))
    (fs_remove (str_concat deep-in "/e"))
    (fs_rmdir calm-in)
    (fs_rmdir calm-kept)
    (fs_rmdir deep-in)
    (fs_rmdir deep-kept)
    (fs_rmdir root)
    (let c5 (if (eq (fs_exists root) 0) 32 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 c5))))))
