; runtime-real-grammar-capsules-band.fk - existing BMF dialects as runtime capsules.
;
; Real language and media grammars are registered dynamically as recipe
; capsules. Runtime selection uses surfaces and capability nodes; grammar
; execution uses bmf-dialect data carried by the capsule/request.
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk form-stdlib/grammars/python-bmf.fk form-stdlib/grammars/typescript-bmf.fk form-stdlib/grammars/go-bmf.fk form-stdlib/grammars/rust-bmf.fk form-stdlib/grammars/natural-bmf.fk form-stdlib/grammars/image-bmf.fk form-stdlib/grammars/audio-bmf.fk form-stdlib/grammars/video-bmf.fk form-stdlib/grammars/document-bmf.fk

section [form.action] {
    def proof_ok(capability) = 1;
    def node_child(node, index) = nth(node_children(node), index);
    def parsed_object(result) = form-adapter-plan-result-value(result);
    def parsed_node(result) = bmf-object-value(parsed_object(result));
    def parsed_kind(result) = bmf-object-kind(parsed_object(result));
    def node_score(value, want, score) = if node_eq(value, want) then score else 0;
    def str_score(value, want, score) = if str_eq(value, want) then score else 0;
    def int_score(value, want, score) = if eq(value, want) then score else 0;
    def parse_req(anchor, dialect, rule_name, source) = bmf-runtime-grammar-request(anchor, dialect, rule_name, source);
    def emit_req(anchor, dialect, rule_name, object) = bmf-runtime-grammar-object-request(anchor, dialect, rule_name, object);

    let runtime_root = form-capsule-root(111, 1, 9, 1);
    let kind_role = form-dynamic-kind(runtime_root, 1);
    let kind_surface = form-dynamic-kind(runtime_root, 2);
    let kind_capability = form-dynamic-kind(runtime_root, 3);
    let kind_contract = form-dynamic-kind(runtime_root, 4);
    let kind_proof = form-dynamic-kind(runtime_root, 5);
    let role_runtime = form-dynamic-ref(runtime_root, kind_role, 1);
    let lens_runtime = form-dynamic-ref(runtime_root, kind_role, 2);
    let parse_kind = form-dynamic-ref(runtime_root, kind_capability, 1);
    let emit_kind = form-dynamic-ref(runtime_root, kind_capability, 2);
    let effect_pure = form-dynamic-ref(runtime_root, kind_contract, 1);
    let reversible_yes = form-dynamic-ref(runtime_root, kind_contract, 2);
    let lossless_yes = form-dynamic-ref(runtime_root, kind_contract, 3);
    let deterministic_yes = form-dynamic-ref(runtime_root, kind_contract, 4);
    let proof_roundtrip = form-dynamic-ref(runtime_root, kind_proof, 1);

    let py_source_surface = form-dynamic-ref(runtime_root, kind_surface, 1);
    let py_form_surface = form-dynamic-ref(runtime_root, kind_surface, 2);
    let ts_source_surface = form-dynamic-ref(runtime_root, kind_surface, 3);
    let ts_form_surface = form-dynamic-ref(runtime_root, kind_surface, 4);
    let go_source_surface = form-dynamic-ref(runtime_root, kind_surface, 5);
    let go_form_surface = form-dynamic-ref(runtime_root, kind_surface, 6);
    let rust_source_surface = form-dynamic-ref(runtime_root, kind_surface, 7);
    let rust_form_surface = form-dynamic-ref(runtime_root, kind_surface, 8);
    let natural_source_surface = form-dynamic-ref(runtime_root, kind_surface, 9);
    let natural_form_surface = form-dynamic-ref(runtime_root, kind_surface, 10);
    let image_source_surface = form-dynamic-ref(runtime_root, kind_surface, 11);
    let image_form_surface = form-dynamic-ref(runtime_root, kind_surface, 12);
    let audio_source_surface = form-dynamic-ref(runtime_root, kind_surface, 13);
    let audio_form_surface = form-dynamic-ref(runtime_root, kind_surface, 14);
    let video_source_surface = form-dynamic-ref(runtime_root, kind_surface, 15);
    let video_form_surface = form-dynamic-ref(runtime_root, kind_surface, 16);
    let document_source_surface = form-dynamic-ref(runtime_root, kind_surface, 17);
    let document_form_surface = form-dynamic-ref(runtime_root, kind_surface, 18);
    let bml_source_surface = form-dynamic-ref(runtime_root, kind_surface, 19);
    let bml_form_surface = form-dynamic-ref(runtime_root, kind_surface, 20);

    let py_capsule = bmf-runtime-dialect-capsule(form-capsule-root(112, 1, 9, 1), python-bmf-dialect, py_source_surface, py_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let ts_capsule = bmf-runtime-dialect-capsule(form-capsule-root(113, 1, 9, 1), typescript-bmf-dialect, ts_source_surface, ts_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let go_capsule = bmf-runtime-dialect-capsule(form-capsule-root(114, 1, 9, 1), go-bmf-dialect, go_source_surface, go_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let rust_capsule = bmf-runtime-dialect-capsule(form-capsule-root(115, 1, 9, 1), rust-bmf-dialect, rust_source_surface, rust_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let natural_capsule = bmf-runtime-dialect-capsule(form-capsule-root(116, 1, 9, 1), natural-bmf-dialect, natural_source_surface, natural_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let image_capsule = bmf-runtime-dialect-capsule(form-capsule-root(117, 1, 9, 1), image-bmf-dialect, image_source_surface, image_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let audio_capsule = bmf-runtime-dialect-capsule(form-capsule-root(118, 1, 9, 1), audio-bmf-dialect, audio_source_surface, audio_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let video_capsule = bmf-runtime-dialect-capsule(form-capsule-root(119, 1, 9, 1), video-bmf-dialect, video_source_surface, video_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let document_capsule = bmf-runtime-dialect-capsule(form-capsule-root(120, 1, 9, 1), document-bmf-dialect, document_source_surface, document_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);
    let bml_capsule = bmf-runtime-dialect-capsule(form-capsule-root(121, 1, 9, 1), bml-bmf-dialect, bml_source_surface, bml_form_surface, parse_kind, emit_kind, effect_pure, reversible_yes, lossless_yes, deterministic_yes, proof_roundtrip, proof_ok, 1);

    let registry0 = form-recipe-registry-empty();
    let registry1 = form-recipe-registry-add-capsule(registry0, py_capsule);
    let registry2 = form-recipe-registry-add-capsule(registry1, ts_capsule);
    let registry3 = form-recipe-registry-add-capsule(registry2, go_capsule);
    let registry4 = form-recipe-registry-add-capsule(registry3, rust_capsule);
    let registry5 = form-recipe-registry-add-capsule(registry4, natural_capsule);
    let registry6 = form-recipe-registry-add-capsule(registry5, image_capsule);
    let registry7 = form-recipe-registry-add-capsule(registry6, audio_capsule);
    let registry8 = form-recipe-registry-add-capsule(registry7, video_capsule);
    let registry9 = form-recipe-registry-add-capsule(registry8, document_capsule);
    let registry = form-recipe-registry-add-capsule(registry9, bml_capsule);
    let ctx = bmf-symbol-context(role_runtime, lens_runtime, empty);

    let py_result = form-recipe-registry-run-flex(registry, py_source_surface, py_form_surface, parse_req("py", python-bmf-dialect, "assign-int", list(py-name("count"), py-op("="), py-int("13"))), "py", ctx, 2, empty);
    let ts_result = form-recipe-registry-run-flex(registry, ts_source_surface, ts_form_surface, parse_req("ts", typescript-bmf-dialect, "export-const", list(ts-src-keyword("export"), ts-src-keyword("const"), ts-src-name("answer"), ts-src-op("="), ts-src-name("value"), ts-src-op(";"))), "ts", ctx, 2, empty);
    let go_result = form-recipe-registry-run-flex(registry, go_source_surface, go_form_surface, parse_req("go", go-bmf-dialect, "var-int", list(go-src-keyword("var"), go-src-name("count"), go-src-op("="), go-src-int("13"))), "go", ctx, 2, empty);
    let rust_result = form-recipe-registry-run-flex(registry, rust_source_surface, rust_form_surface, parse_req("rust", rust-bmf-dialect, "fn0", list(rust-src-keyword("fn"), rust-src-name("main"), rust-src-op("("), rust-src-op(")"), rust-src-op("{"), rust-src-op("}"))), "rust", ctx, 2, empty);
    let natural_result = form-recipe-registry-run-flex(registry, natural_source_surface, natural_form_surface, parse_req("natural", natural-bmf-dialect, "fact-is", list(natural-src-word("count"), natural-src-word("is"), natural-src-int("13"), natural-src-punct("."))), "natural", ctx, 2, empty);
    let image_result = form-recipe-registry-run-flex(registry, image_source_surface, image_form_surface, parse_req("image", image-bmf-dialect, "svg-viewbox", list(image-src-keyword("svg"), image-src-int("320"), image-src-keyword("x"), image-src-int("240"), image-src-keyword("viewBox"), image-src-string("0 0 320 240"))), "image", ctx, 2, empty);
    let audio_result = form-recipe-registry-run-flex(registry, audio_source_surface, audio_form_surface, parse_req("audio", audio-bmf-dialect, "flac", list(audio-src-keyword("flac"), audio-src-int("96000"), audio-src-keyword("hz"), audio-src-int("2"), audio-src-keyword("channels"), audio-src-int("24"), audio-src-keyword("bits"))), "audio", ctx, 2, empty);
    let video_result = form-recipe-registry-run-flex(registry, video_source_surface, video_form_surface, parse_req("video", video-bmf-dialect, "webm-duration", list(video-src-keyword("webm"), video-src-int("1280"), video-src-keyword("x"), video-src-int("720"), video-src-keyword("fps"), video-src-int("60"), video-src-keyword("duration"), video-src-int("654321"), video-src-keyword("ms"))), "video", ctx, 2, empty);
    let document_result = form-recipe-registry-run-flex(registry, document_source_surface, document_form_surface, parse_req("document", document-bmf-dialect, "cfbf", list(document-src-keyword("cfbf"), document-src-keyword("sector"), document-src-int("9"), document-src-keyword("mini"), document-src-int("6"), document-src-keyword("fat"), document-src-int("2"), document-src-keyword("dir"), document-src-int("1"))), "document", ctx, 2, empty);
    let bml_result = form-recipe-registry-run-flex(registry, bml_source_surface, bml_form_surface, parse_req("bml", bml-bmf-dialect, "return-int", list(bml-src-keyword("return"), bml-src-int("13"), bml-src-op(";"))), "bml", ctx, 2, empty);
    let bml_choice = form-recipe-registry-run-flex-with-receipt(registry, bml_source_surface, bml_form_surface, parse_req("bml", bml-bmf-dialect, "return-int", list(bml-src-keyword("return"), bml-src-int("13"), bml-src-op(";"))), "bml", ctx, 2, empty);
    let bml_choice_receipt = form-recipe-flex-choice-receipt(bml_choice);
    let bml_choice_signature = form-recipe-flex-choice-signature(bml_choice);

    let py_reverse = form-recipe-registry-run-flex(registry, py_form_surface, py_source_surface, emit_req("py", python-bmf-dialect, "assign-int", parsed_object(py_result)), "py", ctx, 2, empty);
    let image_reverse = form-recipe-registry-run-flex(registry, image_form_surface, image_source_surface, emit_req("image", image-bmf-dialect, "svg-viewbox", parsed_object(image_result)), "image", ctx, 2, empty);
    let bml_reverse = form-recipe-registry-run-flex(registry, bml_form_surface, bml_source_surface, emit_req("bml", bml-bmf-dialect, "return-int", parsed_object(bml_result)), "bml", ctx, 2, empty);
    let py_reverse_source = form-adapter-plan-result-value(py_reverse);
    let image_reverse_source = form-adapter-plan-result-value(image_reverse);
    let bml_reverse_source = form-adapter-plan-result-value(bml_reverse);

    let registry_score = sum(list(int_score(len(form-recipe-registry-capsules(registry)), 10, 100), int_score(len(form-recipe-registry-capabilities(registry)), 20, 200), int_score(len(form-recipe-registry-contracts(registry)), 20, 300), int_score(len(form-recipe-registry-proofs(registry)), 20, 400)));
    let language_score = sum(list(str_score(parsed_kind(py_result), "assign-int", 500), str_score(node_value(node_child(parsed_node(py_result), 0)), "count", 600), int_score(node_value(node_child(parsed_node(py_result), 1)), 13, 700), str_score(parsed_kind(ts_result), "export-const", 800), str_score(node_value(node_child(parsed_node(ts_result), 0)), "answer", 900), str_score(parsed_kind(go_result), "var-int", 1000), str_score(parsed_kind(rust_result), "fn0", 1100), str_score(node_value(node_child(parsed_node(rust_result), 0)), "main", 1200), str_score(parsed_kind(bml_result), "return-int", 2200), int_score(node_value(node_child(node_child(parsed_node(bml_result), 0), 0)), 13, 2300)));
    let media_score = sum(list(str_score(parsed_kind(natural_result), "fact-is", 1300), str_score(parsed_kind(image_result), "svg-viewbox", 1400), str_score(parsed_kind(audio_result), "flac", 1500), str_score(parsed_kind(video_result), "webm-duration", 1600), str_score(parsed_kind(document_result), "cfbf", 1700)));
    let reverse_score = sum(list(int_score(len(py_reverse_source), 3, 1800), str_score(bmf-object-value(nth(py_reverse_source, 0)), "count", 1900), int_score(len(image_reverse_source), 6, 2000), str_score(bmf-object-value(nth(image_reverse_source, 4)), "viewBox", 2100), int_score(len(bml_reverse_source), 3, 2400), str_score(bmf-object-value(nth(bml_reverse_source, 0)), "return", 2500), str_score(bmf-object-value(nth(bml_reverse_source, 2)), ";", 2600)));
    let receipt_score = sum(list(if form-recipe-flex-choice?(bml_choice) then 2700 else 0, if form-recipe-choice-receipt-valid?(bml_choice_receipt) then 2800 else 0, if form-recipe-choice-signature?(bml_choice_signature) then 2900 else 0, int_score(form-recipe-choice-signature-route-count(bml_choice_signature), 1, 3000), node_score(form-adapter-capability-kind(form-recipe-choice-receipt-selected(bml_choice_receipt)), parse_kind, 3100)));

    sum(list(registry_score, language_score, media_score, reverse_score, receipt_score));
}
