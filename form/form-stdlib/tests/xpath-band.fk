; tests/xpath-band.fk — xpath evaluator sibling-witness band.
;
; preludes: form-stdlib/symbols.fk form-stdlib/xpath.fk
;
; Validates the path-string parser + evaluator across every step kind
; and every predicate shape the spec promises:
;
;   /cat:N           category-by-inst step
;   /name:s          name-match step
;   /*               wildcard step
;   /text()          trivial-value access
;   //step           descendant-or-self
;   [N]              positional predicate
;   [@inst=N]        inst-equality predicate
;   [text()='foo']   trivial-text predicate
;   [count()=N]      arity predicate
;
; The verdict is the sum of nine 0/1 attestations; three sibling
; kernels agree on the number when every step and predicate carries
; the same meaning through the Form evaluator.

(do
    ;; Build a SYMBOL-TABLE with three bindings, wrapped in a parent
    ;; so /cat: steps can descend from the root.
    (let v1 (intern_trivial_int 11))
    (let v2 (intern_trivial_int 22))
    (let v3 (intern_trivial_int 33))

    (let tbl
        (symbol-table
            (list (symbol-bind "alpha" v1)
                  (symbol-bind "beta"  v2)
                  (symbol-bind "gamma" v3))))

    (let root (intern_node (make_nodeid 1 1 14 0) (list tbl)))

    ;; 1. /cat:1731 finds the table.
    (let r1 (xpath "/cat:1731" root))
    (let a1 (if (eq (len r1) 1) 1 0))

    ;; 2. /cat:1731/* yields three SYMBOL-BINDs.
    (let r2 (xpath "/cat:1731/*" root))
    (let a2 (if (eq (len r2) 3) 1 0))

    ;; 3. /cat:1731/cat:1730[0] selects the first binding only.
    (let r3 (xpath "/cat:1731/cat:1730[0]" root))
    (let a3 (if (eq (len r3) 1) 1 0))

    ;; 4. /cat:1731/cat:1730[count()=2] — every bind has 2 children
    ;;    (name + value), so all three match.
    (let r4 (xpath "/cat:1731/cat:1730[count()=2]" root))
    (let a4 (if (eq (len r4) 3) 1 0))

    ;; 5. //cat:1730 descendant-or-self pulls every binding regardless
    ;;    of intermediate structure.
    (let r5 (xpath "//cat:1730" root))
    (let a5 (if (eq (len r5) 3) 1 0))

    ;; 6. /cat:1731/cat:1730[0]/*[0]/text() reads the first binding's
    ;;    name leaf as a trivial string.
    (let r6 (xpath "/cat:1731/cat:1730[0]/*[0]/text()" root))
    (let r6-first
        (if (eq (len r6) 0) (intern_trivial_string "")
            (head r6)))
    (let a6 (if (str_eq (node_value r6-first) "alpha") 1 0))

    ;; 7. /cat:1731/cat:1730[0]/*[text()='alpha'] — text predicate
    ;;    inside the bind narrows to the name leaf.
    (let r7 (xpath "/cat:1731/cat:1730[0]/*[text()='alpha']" root))
    (let a7 (if (eq (len r7) 1) 1 0))

    ;; 8. xpath-first on a miss returns the sentinel; xpath-found?
    ;;    distinguishes hit from miss.
    (let miss (xpath-first "/cat:9999" root))
    (let a8 (if (eq (xpath-found? miss) 0) 1 0))

    ;; 9. xpath-first on a hit returns a real NodeID.
    (let hit (xpath-first "/cat:1731" root))
    (let a9 (xpath-found? hit))

    ;; Band verdict: 9 when every assertion holds.
    (add a1 (add a2 (add a3 (add a4 (add a5 (add a6 (add a7 (add a8 a9))))))))
)
