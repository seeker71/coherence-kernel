; preludes: form-stdlib/core.fk form-stdlib/slice-merge.fk
;
; slice-merge-band — trust-weighted FedAvg + TIES sign-election over task-vector deltas, three-way.
;
; Two cells offer deltas for the same base slice:
;   A = weight 2, delta [ 3  -2   5]
;   B = weight 1, delta [ 1   4  -5]
; Coordinate by coordinate:
;   j=0:  both "+"           -> elect +;  num = 2·3 + 1·1 = 7,  den = 2+1 = 3
;   j=1:  A:-2 (w2) vs B:+4 (w1) -> "−" wins (2 ≥ 1) -> elect −;  num = 2·(−2) = −4 (only A agrees), den = 2
;   j=2:  A:+5 (w2) vs B:-5 (w1) -> "+" wins -> elect +;  num = 2·5 = 10, den = 2
; The merged delta is the exact rational pairs — division deferred, so the merge is integer-exact and
; identical on Go=Rust=TS (a deterministic federation). A gone peer (weight 0) cannot move it.
;
; Verdict 127 when every claim lands:
;   1   sign election picks "+" where the weight agrees     (sm-elect coord0 == 1)
;   2   sign election picks "−" where the heavier delta is   (sm-elect coord1 == 0)
;   4   FedAvg numerator over the agreeing entries           (sm-num coord0 == 7)
;   8   FedAvg denominator (the summed agreeing weight)       (sm-den coord0 == 3)
;   16  TIES keeps only the elected sign's entries           (sm-num coord1 == −4, B's +4 excluded)
;   32  the merge is order-stable                             (sm-num(A,B,0) == sm-num(B,A,0))
;   64  a gone peer (weight 0) does not move the merge        (adding a w=0 slice leaves num0 == 7)
(do
    (let A (list 2 (list 3 -2 5)))
    (let B (list 1 (list 1 4 -5)))
    (let two (list A B))
    (let two-rev (list B A))
    (let gone (list 0 (list 9 9 9)))
    (let three (list A B gone))
    (let c0 (if (eq (sm-elect two 0) 1) 1 0))
    (let c1 (if (eq (sm-elect two 1) 0) 2 0))
    (let c2 (if (eq (sm-num two 0) 7) 4 0))
    (let c3 (if (eq (sm-den two 0) 3) 8 0))
    (let c4 (if (eq (sm-num two 1) -4) 16 0))
    (let c5 (if (eq (sm-num two-rev 0) 7) 32 0))
    (let c6 (if (eq (sm-num three 0) 7) 64 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
