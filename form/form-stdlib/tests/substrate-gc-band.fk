; substrate-gc-band.fk - heap recipes can be collected from runtime roots.
;
; The execution stack is frames/closures. The substrate heap is interned
; recipes, strings, source attribution, and caches. Collection is mark-sweep
; from roots; explicit release remains only a scoped/resource fast path.

(do
    (let substrate-gc-category (make_nodeid 9 9 9 2))
    (let temp-name (intern_trivial_string (str_concat "temporary-" "gc-object")))
    (let temp-node (intern_node substrate-gc-category (list temp-name (intern_trivial_int 7))))
    ; nothing-guard: on kernels without the substrate_gc primitive (the C seed),
    ; axiom-5 recovers the call to nothing and (head nothing) is nil — the band
    ; must stay honestly red there, not green by nil's word ordering above 0.
    (let gcr (substrate_gc (empty)))
    (if (nothing? gcr) 0 (if (gt (head gcr) 0) 1000 0)))
