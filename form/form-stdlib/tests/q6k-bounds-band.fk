; preludes: form-stdlib/core.fk form-stdlib/format-arith.fk form-stdlib/f16-decode.fk form-stdlib/gguf-read.fk form-stdlib/q4k-dequant.fk form-stdlib/q6k-dequant.fk form-stdlib/weight-load.fk form-stdlib/transformer-numerics.fk form-stdlib/trig.fk form-stdlib/llama-numerics.fk form-stdlib/rope.fk form-stdlib/transformer-block.fk form-stdlib/transformer-mh.fk form-stdlib/gqa-attn.fk form-stdlib/llama-block.fk form-stdlib/llama-gqa-block.fk form-stdlib/block-join.fk
;
; q6k-bounds-band — the superblock wall made falsifiable, both ways: the body now REFUSES an index
; outside one Q6_K block (q6k-at -> form_error) and SERVES any index across blocks (wl-q6k-at-flat /
; bj-row-n / bj-matrix stride the 210-byte block). Before the cell changes this band gates, every
; claim from bit 8 up was silently -0 and still printed green — which is the whole reason it exists.
;
; THE FIXTURE. Two consecutive REAL llama3.2:3b Q6_K superblocks, 420 bytes, transcribed from
; ~/.ollama/models/blobs/sha256-dde5aa3f...ccdff at absolute offset 331055328 (blk.0.ffn_down.weight,
; type Q6_K, tensor data offset 323217664 over a tensor-data base of 7837664). real-gguf-generate-band
; reads that 2 GB blob live and therefore cannot travel; this band CARRIES the bytes, so the stride
; claim runs on any checkout. It is the ~1 KB Q6_K fixture the Stone-1 receipt named as missing.
;
; GROUND TRUTH is ggml's dequantize_row_q6_K over these same 420 bytes, transcribed independently:
;   w[0]   =  0.009149551391601562      w[255] = -0.0015249252319335938
;   w[256] =  0.0192413330078125        w[288] =  0.025485515594482422
; w[255] is the last weight of block 0 and w[256] the first of block 1 — the two sides of the wall.
; w[288] is element (16,16) of a 17x17 matrix: the first weight bj-matrix could not reach. Each pin is
; scaled by 1e6 into a unit-wide window, so no float formatting enters the verdict.
;
; Kin: q6k-dequant.fk (q6k-index-ok? / the refusing q6k-at), weight-load.fk (wl-q6k-at-flat — the
; striding accessor), block-join.fk (bj-row-n / bj-matrix, now striding), real-gguf-generate.fk
; (rgg-weights — the sequential twin of the same 210-byte stride).
;
; Verdict 255 when the wall is both named and crossed:
;   1    the wall is NAMEABLE in-recipe        (q6k-index-ok? 1 at 0 and 255, 0 at 256 and -1)
;   2    the Q4_K wall too                     (q4k-index-ok? same shape — same defect, same heal)
;   4    in-block dequant is UNCHANGED         (wl-q6k-at @0 index 0 -> 9149.55.. — the guard costs no bits)
;   8    flat == in-block INSIDE block 0       (wl-q6k-at-flat 255 -> -1524.925.., block 0's last weight)
;   16   flat CROSSES the wall                 (wl-q6k-at-flat 256 -> 19241.333.., was -0)
;   32   bj-row-n crosses it                   (element 256 of a 257-long row == the crossed weight)
;   64   bj-matrix serves dim=17 > 16          ([16][16] == w[288] = 25485.5156.., was -0)
;   128  the reach is STATED, not discovered   (bj-matrix-max-index 0 17 == 288, and 0 16 == 255)
(do
    (defn q6b-pin (x lo hi) (if (gt x lo) (if (lt x hi) 1 0) 0))

    ; two REAL consecutive Q6_K superblocks (ql[128] qh[64] scales[16] d-f16[2]) x 2 = 420 bytes
    (let bs (list
        72 107 65 50 210 39 121 53 43 55 128 68
        2 15 170 169 243 145 149 63 97 113 161 186
        90 55 104 137 6 58 12 15 183 176 60 97
        217 121 127 119 103 97 81 43 212 243 24 216
        95 217 18 212 183 126 183 204 2 89 112 56
        140 193 138 75 80 14 150 81 155 172 129 64
        129 59 37 192 232 113 81 125 226 187 34 202
        128 212 245 70 19 234 247 119 8 152 68 233
        145 55 214 97 203 188 242 255 127 170 137 137
        4 138 79 15 173 75 208 17 196 238 251 68
        227 192 134 244 64 16 61 41 81 178 223 147
        98 126 169 181 133 167 104 146 142 46 22 29
        85 4 46 245 102 149 150 164 16 114 242 70
        85 42 133 165 171 138 73 162 22 149 75 118
        71 8 182 164 5 150 167 107 118 84 234 40
        84 87 133 234 136 5 110 200 127 35 50 154
        139 128 139 139 95 180 152 103 128 76 128 110
        96 114 135 178 164 0 205 41 5 77 75 244
        16 225 205 55 195 14 239 170 216 122 14 145
        247 131 0 172 18 92 189 112 75 182 138 248
        189 15 77 17 169 209 17 120 116 239 233 41
        56 20 87 133 34 244 131 199 230 47 9 2
        65 119 42 110 115 255 49 147 80 198 218 136
        98 62 33 90 153 210 0 58 193 126 115 166
        221 167 234 9 140 149 208 232 83 157 125 158
        147 171 211 76 81 0 233 51 17 162 24 61
        192 211 132 182 235 101 106 114 185 103 251 150
        15 70 10 107 73 15 39 241 236 49 10 170
        123 79 78 232 233 44 177 18 255 164 94 146
        190 8 197 162 117 41 104 20 38 98 37 153
        139 97 229 105 168 38 96 154 68 173 22 185
        24 166 103 170 114 77 132 132 73 74 137 169
        133 151 39 147 166 109 232 84 155 22 152 81
        3 221 85 154 101 70 128 175 180 77 77 121
        155 189 88 188 157 160 195 169 124 89 194 128))

    ; --- 1: the wall has a name a recipe can ask about (it had none at all before) ---
    (let c0 (if (eq (q6k-index-ok? 0) 1)
            (if (eq (q6k-index-ok? 255) 1)
            (if (eq (q6k-index-ok? 256) 0)
            (if (eq (q6k-index-ok? (sub 0 1)) 0) 1 0) 0) 0) 0))

    ; --- 2: Q4_K carries the identical defect and takes the identical heal ---
    (let c1 (if (eq (q4k-index-ok? 0) 1)
            (if (eq (q4k-index-ok? 255) 1)
            (if (eq (q4k-index-ok? 256) 0)
            (if (eq (q4k-index-ok? (sub 0 1)) 0) 2 0) 0) 0) 0))

    ; --- 4: the guard changes no arithmetic inside the block ---
    (let w0 (mul 1000000.0 (wl-q6k-at bs 0 0)))
    (let c2 (if (eq (q6b-pin w0 9149.55 9149.56) 1) 4 0))

    ; --- 8: the striding door agrees with the in-block door where both are defined ---
    (let w255f (mul 1000000.0 (wl-q6k-at-flat bs 0 255)))
    (let w255b (mul 1000000.0 (wl-q6k-at bs 0 255)))
    (let c3 (if (eq (q6b-pin w255f (sub 0.0 1524.93) (sub 0.0 1524.92)) 1)
            (if (eq (q6b-pin w255b (sub 0.0 1524.93) (sub 0.0 1524.92)) 1) 8 0) 0))

    ; --- 16: THE WALL CROSSED. wl-q6k-at at 256 now refuses out loud; wl-q6k-at-flat strides. ---
    (let w256 (mul 1000000.0 (wl-q6k-at-flat bs 0 256)))
    (let c4 (if (eq (q6b-pin w256 19241.33 19241.34) 1) 16 0))

    ; --- 32: block-join's own row accessor crosses it (this was -0 at full green) ---
    (let row (bj-row-n bs 0 257))
    (let r256 (mul 1000000.0 (nth row 256)))
    (let c5 (if (eq (len row) 257)
            (if (eq (q6b-pin r256 19241.33 19241.34) 1) 32 0) 0))

    ; --- 64: bj-matrix at dim=17 (289 weights) — one row past the old dim<=16 ceiling ---
    (let m17 (bj-matrix bs 0 0 17))
    (let m288 (mul 1000000.0 (nth (nth m17 16) 16)))
    (let c6 (if (eq (len m17) 17)
            (if (eq (len (nth m17 16)) 17)
            (if (eq (q6b-pin m288 25485.51 25485.52) 1) 64 0) 0) 0))

    ; --- 128: the reach a caller asks for, stated instead of discovered as zeros ---
    (let c7 (if (eq (bj-matrix-max-index 0 17) 288)
            (if (eq (bj-matrix-max-index 0 16) 255) 128 0) 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
