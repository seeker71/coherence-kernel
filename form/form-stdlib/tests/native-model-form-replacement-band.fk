; native-model-form-replacement-band.fk — executable replacement proof.
;
; The band exercises Form-owned scoring, semantic identities, seal/provenance,
; privacy-minimized atomic event append, schedule admission, measured training
; closure, served-artifact integration, exact route accounting, and daily
; progress.  No raw prompt/output is written to the event ledger.
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/native-model-control-plane.fk form-stdlib/native-model-live-loop.fk form-stdlib/native-model-evidence.fk form-stdlib/native-model-eval-form.fk form-stdlib/native-model-seal-form.fk form-stdlib/native-model-event-form.fk form-stdlib/native-model-ledger-form.fk form-stdlib/native-model-daily-form.fk
;
; Verdict: 262143 (18 independent bits).

(do
    (let heldout
        (list (list "prompt-a" "turn left")
              (list "prompt-b" "stay still")))
    (let training
        (list (list "prompt-c" "turn right")
              (list "prompt-d" "move now")))
    (let scope (nmfs-dataset-scope heldout training))
    (let consent-digest (nmfe-sha256 "consent-receipt"))
    (let license-digest (nmfe-sha256 "license-receipt"))
    (let consent-file
        (nmfs-host-file "/private/consent.json" 1 0 600 100 900 consent-digest))
    (let license-file
        (nmfs-host-file "/private/license.json" 1 0 600 100 900 license-digest))
    (let consent
        (nmfs-receipt "native-model-consent-receipt-v1" "form-knowledge"
            "native-model-training-and-heldout" scope 1 "urs" 1 consent-file))
    (let license
        (nmfs-receipt "native-model-license-receipt-v1" "form-knowledge"
            "native-model-training-and-heldout" scope 1 "spdx-source" 1 license-file))
    (let evaluator (nmfe-sha256 "native-model-evaluator-v1"))
    (let config (nmfe-sha256 "evaluation-config-v1"))
    (let seal
        (nmfs-seal "form-knowledge" 1000 heldout training evaluator config 64
                   consent license))
    (let candidate-artifact (nmfe-sha256 "candidate-artifact-v1"))
    (let incumbent-artifact (nmfe-sha256 "incumbent-artifact-v1"))
    (let trained-artifact (nmfe-sha256 "candidate-artifact-v2"))
    (let training-receipt (nmfe-sha256 "training-receipt-v1"))
    (let split-a (nmfe-sha256 "split-a"))
    (let split-b (nmfe-sha256 "split-b"))
    (let split-c (nmfe-sha256 "split-c"))
    (let data (nmfe-dataset-sha256 heldout))

    (let c1
        (if (and (str_eq (nmfe-normalize "  Hello\t WÖRLD  ") "hello wÖrld")
                 (and (eq (len (nmfe-tokens "Hello, WÖRLD!")) 4)
                      (and (str_eq (nth (nmfe-tokens "Hello, WÖRLD!") 1) ",")
                           (str_eq (nth (nmfe-tokens "Hello, WÖRLD!") 2) "wÖrld"))))
            1 0))
    (let c2
        (if (and (eq (nmfe-token-f1-ppm "a b" "a c") 500000)
                 (and (eq (nmfe-sequence-ppm "a b" "b a") 0)
                      (and (eq (nmfe-exact-ppm " A  B " "a b") 1000000)
                           (eq (nmfe-token-f1-ppm "" "") 1000000))))
            2 0))
    (let c3
        (if (and (str_eq (nmfe-sha256 "abc")
                    "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
                 (and (eq (str_len data) 64)
                      (and (eq (nmfe-isolated? heldout training) 1)
                           (eq (len (nmfe-rotating-slice heldout 1 "20260715")) 1))))
            4 0))

    (let candidate-rows
        (list (list "prompt-a" "turn left" "turn left" 12 0)
              (list "prompt-b" "stay still" "stay still" 14 0)))
    (let incumbent-rows
        (list (list "prompt-a" "turn left" "turn right" 10 0)
              (list "prompt-b" "stay still" "move now" 11 0)))
    (let candidate-observations (nmfv-score-rows candidate-rows))
    (let incumbent-observations (nmfv-score-rows incumbent-rows))
    (let candidate
        (nmfv-result "candidate" "form-knowledge" "local-finetuned" 20260715
            split-a data evaluator "sealed-task-complete" "rotating-final-audit"
            candidate-artifact candidate-artifact 1 1 training-receipt
            candidate-observations))
    (let incumbent
        (nmfv-result "incumbent" "form-knowledge" "local-native" 20260715
            split-a data evaluator "sealed-task-complete" "rotating-final-audit"
            incumbent-artifact incumbent-artifact 1 1 ""
            incumbent-observations))
    (let c4
        (if (and (eq (nmfv-clean? candidate) 1)
                 (and (eq (nmfv-clean? incumbent) 1)
                      (and (eq (nmfv-paired? candidate incumbent) 1)
                           (gt (nmfv-promotion-score candidate)
                               (nmfv-promotion-score incumbent)))))
            8 0))
    (let drifted
        (nmfv-result "candidate" "form-knowledge" "local-finetuned" 20260715
            split-a data evaluator "diagnostic" "fixed" candidate-artifact
            trained-artifact 1 1 training-receipt candidate-observations))
    (let unpaired
        (nmfv-result "incumbent" "form-knowledge" "local-native" 20260715
            split-b data evaluator "sealed-task-complete" "rotating-final-audit"
            incumbent-artifact incumbent-artifact 1 1 "" incumbent-observations))
    (let c5
        (if (and (eq (nmfv-clean? drifted) 0)
                 (eq (nmfv-paired? candidate unpaired) 0)) 16 0))

    (let c6
        (if (and (eq (nmfs-seal-valid? seal) 1)
                 (and (eq (nmfs-seal-exact-overlap seal) 0)
                      (eq (nmfs-seal-prompt-overlap seal) 0))) 32 0))
    (let overlapping (list (list "prompt-a" "different expected")))
    (let overlap-scope (nmfs-dataset-scope heldout overlapping))
    (let overlap-consent
        (nmfs-receipt "native-model-consent-receipt-v1" "form-knowledge"
            "native-model-training-and-heldout" overlap-scope 1 "urs" 1 consent-file))
    (let overlap-license
        (nmfs-receipt "native-model-license-receipt-v1" "form-knowledge"
            "native-model-training-and-heldout" overlap-scope 1 "spdx" 1 license-file))
    (let overlap-seal
        (nmfs-seal "form-knowledge" 1000 heldout overlapping evaluator config 64
                   overlap-consent overlap-license))
    (let public-consent-file
        (nmfs-host-file "/public/consent.json" 1 0 644 100 900 consent-digest))
    (let public-consent
        (nmfs-receipt "native-model-consent-receipt-v1" "form-knowledge"
            "native-model-training-and-heldout" scope 1 "urs" 1 public-consent-file))
    (let c7
        (if (and (eq (nmfs-seal-valid? overlap-seal) 0)
                 (eq (nmfs-receipt-valid? public-consent
                    "native-model-consent-receipt-v1" "form-knowledge" scope) 0))
            64 0))

    (let anchor (nmfs-anchor 1100 (nmfs-seal-digest seal)
                    (nmfs-seal-training seal) 1))
    (let candidate-file
        (nmfs-host-file "/models/candidate" 1 0 600 2048 1200 candidate-artifact))
    (let authorization
        (nmfs-git-row "owner-authorization.json" 1 1 1
                      (nmfe-sha256 "owner-authorization")))
    (let build
        (nmfs-git-row "build-receipt.json" 1 1 1
                      (nmfe-sha256 "build-receipt")))
    (let promotion-seal-ready
        (nmfs-promotion-ready? seal anchor candidate-file authorization build))
    (let c8 (if (eq promotion-seal-ready 1) 128 0))

    (let model-row (nth (nmcp-registry) 14))
    (let task-digest (nmfe-sha256 "private-task-text"))
    (let output-digest (nmfe-sha256 "private-output-text"))
    (let event
        (nmfr-event 20260715 (mul 1784090 1000000) "local-finetuned"
            "llm.form-llama-lora" "form-knowledge" "inference"
            "production-final" "accepted" 1 candidate-artifact task-digest
            output-digest 26 18 0 "" "" "" training-receipt
            (nth authorization 5) ""))
    (let c9
        (if (and (eq (nmfr-event-valid? event) 1)
                 (eq (nmfr-event-matches-model? event model-row) 1)) 256 0))
    (let bad-lineage
        (nmfr-event 20260715 (mul 1784090 1000000) "local-finetuned"
            "llm.form-llama-lora" "form-knowledge" "inference"
            "production-final" "accepted" 1 candidate-artifact task-digest
            output-digest 26 18 0 "" "" "" "" "" ""))
    (let bad-raw-metadata
        (nmfr-event 20260715 (mul 1784090 1000000) "local-native" "raw prompt here"
            "form-knowledge" "inference" "production-final" "accepted" 1
            incumbent-artifact task-digest output-digest 20 10 0 "" "" "" "" "" ""))
    (let diagnostic-without-authority
        (nmfr-event 20260715 (mul 1784090 1000000) "local-finetuned"
            "llm.form-llama-lora" "form-knowledge" "evaluation" "evaluation"
            "accepted" 1 candidate-artifact task-digest output-digest 20 10 0
            "" "" "" "" "" ""))
    (let c10
        (if (and (eq (nmfr-event-valid? bad-lineage) 0)
                 (and (eq (nmfr-event-valid? bad-raw-metadata) 0)
                      (eq (nmfr-event-valid? diagnostic-without-authority) 1))) 512 0))

    (let ledger (str_concat (temp_dir) "/native-model-form-replacement-band.jsonl"))
    (fs_remove ledger)
    (let appended (nmfr-append-event ledger event))
    (let ledger-text (read_file ledger))
    (let ledger-line (substring ledger-text 0 (sub (str_len ledger-text) 1)))
    (let tally
        (nmfr-tally-result
            (nmfr-count-observed-event (nmfr-zero-counts) event ledger-line)))
    (let tampered-tally
        (nmfr-tally-result
            (nmfr-count-observed-event (nmfr-zero-counts) event
                (str_concat ledger-line " "))))
    (let c11
        (if (and (eq (nth appended 1) 1)
                 (and (eq (nth tally 1) 1)
                      (and (eq (nth tally 3) 1)
                           (and (eq (nth tally 7) 1)
                                (and (eq (nth tally 9) 1)
                                     (and (eq (nmfr-owned-final-share-ppm tally)
                                              1000000)
                                          (and (eq (nth tampered-tally 1) 0)
                                               (and (eq (nth tampered-tally 13) 1)
                                                    (and (eq (nmfr-owned-final-share-ppm
                                                              tampered-tally) -1)
                                                         (eq (str_find ledger-text
                                                               "private-task-text" 0)
                                                             -1))))))))))
            1024 0))
    (fs_remove ledger)

    (let integrity (nmfd-integrity 1 42 55 15 11111 1 1 1))
    (let host (nmfd-host 1 1 1 1 100))
    (let c12
        (if (and (eq (nmfd-integrity-ready? integrity) 1)
                 (eq (nmfd-host-valid? host) 1)) 2048 0))
    (let plan
        (nmfd-plan 20260715 2 integrity host seal anchor candidate-file
            authorization build candidate incumbent (list candidate)
            (list incumbent) 64))
    (let c13
        (if (and (str_eq (nmfd-plan-decision plan) "execute-bounded-job")
                 (str_eq (nmfd-plan-lane plan) "form-knowledge")) 4096 0))
    (let training-result
        (nmfd-training-result 20260715 "form-knowledge"
            "train-bounded-lora-challenger" (mul 1784090 1000000)
            (add (mul 1784090 1000000) 60000) 64 10
            candidate-artifact trained-artifact training-receipt 1))
    (let overlong-result
        (nmfd-training-result 20260715 "form-knowledge"
            "train-bounded-lora-challenger" (mul 1784090 1000000)
            (add (mul 1784090 1000000) 10000000) 64 10
            candidate-artifact trained-artifact training-receipt 1))
    (let c14
        (if (and (eq (nmfd-training-closes-plan? plan training-result) 1)
                 (eq (nmfd-training-closes-plan? plan overlong-result) 0)) 8192 0))
    (let integration
        (nmfd-integration "form-llama:latest" "local-finetuned"
            trained-artifact trained-artifact 1 1 (nmfr-digest event) 1))
    (let wrong-integration
        (nmfd-integration "form-llama:latest" "local-finetuned"
            trained-artifact candidate-artifact 1 1 (nmfr-digest event) 1))
    (let c15
        (if (and (eq (nmfd-integration-valid? integration) 1)
                 (eq (nmfd-integration-valid? wrong-integration) 0)) 16384 0))

    (let occurrence-a
        (nmll-occurrence 20260715 1 "form-native" "transformer-core"
            "production-final" 1 candidate-artifact task-digest output-digest 3))
    (let occurrence-b
        (nmll-occurrence 20260715 2 "local-finetuned" "form-llama:latest"
            "production-final" 1 trained-artifact task-digest output-digest 26))
    (let occurrence-c
        (nmll-occurrence 20260715 3 "local-native" "llama3.2:3b"
            "production-final" 0 incumbent-artifact task-digest output-digest 20))
    (let occurrence-d
        (nmll-occurrence 20260715 4 "local-oracle" "ollama-teacher"
            "training" 1 incumbent-artifact task-digest output-digest 20))
    (let occurrence-e
        (nmll-occurrence 20260715 5 "remote-oracle" "remote-teacher"
            "production-final" 1 incumbent-artifact task-digest output-digest 50))
    (let occurrences
        (list occurrence-a occurrence-b occurrence-c occurrence-d occurrence-e))
    (let snapshot
        (nmfd-snapshot 20260715 integrity (nmcp-registry) occurrences
                       (list candidate incumbent) 64 2))
    (let c16
        (if (and (eq (nmcp-snapshot-valid? snapshot) 1)
                 (and (eq (nmcp-snapshot-aggregates-exact? snapshot 3 1) 1)
                      (and (eq (nmcp-day-form snapshot) 1)
                           (and (eq (nmcp-day-finetuned snapshot) 1)
                                (eq (nmcp-day-native snapshot) 0)))))
            32768 0))
    (let yesterday
        (nmcp-snapshot 20260714 1 (len (nmcp-registry))
            (nmcp-fresh-count (nmcp-registry) 20260714)
            1 0 1 0 1 1 0 2 2 64 2 (nmfe-sha256 "yesterday")))
    (let progress (nmfd-progress snapshot yesterday))
    (let c17
        (if (and (eq (nth progress 1) 333333)
                 (and (eq (nth progress 2) 0)
                      (and (eq (nth progress 3) 0)
                           (eq (nth progress 4) 1)))) 65536 0))
    (let replacements (nmfd-replacement-map))
    (let c18
        (if (and (eq (len replacements) 9)
                 (and (str_eq (nth (nth replacements 0) 1) "form")
                      (str_eq (nth (nth replacements 1) 1) "host-observation")))
            131072 0))

    (sum (list c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17 c18)))
