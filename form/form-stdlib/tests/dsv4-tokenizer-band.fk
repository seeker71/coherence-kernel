; dsv4-tokenizer-band.fk — proof of the DeepSeek V4 Flash tokenizer (Stone 31).
;
; THE ORACLE IS ds4 ITSELF (selfgauge). Every encode id asserted here was read from
;   /Users/ursmuff/models/ds4-engine/ds4 -m <ds4flash.gguf> --dump-tokens -p "<prompt>"
; and every decode is the byte-exact inverse. Nothing here is a guess; a wrong merge order or byte
; map produces a wrong id and this band goes red.
;
; RADIUS THIS BAND EXERCISES (aporon, unispan — never one sample):
;   - the gpt2 byte alphabet, both directions, at its four hinge points (space, an ascii self byte,
;     the lone 173, a >=174 self byte)
;   - decode of a real multi-token id sequence, compared BYTE-EXACT (not as a rendered string)
;   - the joyai-llm pre-split at its load-bearing corners: a digit run capped at 3, a letter run then
;     a punctuation split, a leading space that joins the next word
;   - encode matched to ds4's ids across a LETTER run, a DIGIT run, PUNCTUATION, a leading-SPACE word,
;     and a CJK run (the >= 128-byte path the byte-value design exists for)
;
; WHY IT RUNS ON THE GO KERNEL, not fkwu --src. It reads the 85 GB model file's header through
; eqr-of-file and walks 127 741 merges per encoded piece; it is a file-reading, compute-heavy proof
; like native/metal/metal_first_token.sh, not an arithmetic band. Run it resolver-driven:
;   FILES=$(walk `; preludes:` of this file); form-kernel-go/bin-go $FILES
; A helper is committed at form-stdlib/tests/run-dsv4-tokenizer-band.sh. Encode is O(max merge rank)
; per piece on a tree-walking kernel — this band takes ~1-2 min; bands are correctness, not timing.
;
; VERDICT 8191 (2^13 - 1) when every one of the 13 claims holds.
;
; preludes: form-stdlib/dsv4-tokenizer.fk

(do
    (defn tkzb-score (ok bit) (if ok bit 0))
    (defn tkzb-file () "/Users/ursmuff/models/ds4/ds4flash-v5mx-reap25-type40-mxfp8lt-dspark-v1.gguf")

    ; ---- list equality over int lists (ids, or decoded byte values) ----
    (defn tkzb-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (eq (head a) (head b)) (tkzb-eq (tail a) (tail b)) 0))
            0))

    (let src (tkz-src (tkzb-file)))

    ; ---- the byte alphabet, both ways, at its hinges ----
    (let c1 (tkzb-score (eq (tkz-b2cp 32) 288) 1))              ; space -> U+0120
    (let c2 (tkzb-score (eq (tkz-cp2b 288) 32) 2))              ; and back
    (let c3 (tkzb-score (if (eq (tkz-b2cp 173) 323) (eq (tkz-cp2b 323) 173) 0) 4)) ; the lone 173
    (let c4 (tkzb-score (if (eq (tkz-b2cp 255) 255) (eq (tkz-cp2b 200) 200) 0) 8)) ; >=174 self, both ways

    ; ---- decode a real id sequence, BYTE-EXACT ----
    ; ds4: "The capital of France is" -> [671 6102 294 8760 344]. Decode must reproduce its exact bytes.
    (let c5 (tkzb-score
        (tkzb-eq (tkz-decode-bytes src (list 671 6102 294 8760 344))
                 (string_bytes "The capital of France is")) 16))

    ; ---- the joyai-llm pre-split, at its corners ----
    ; "2025": a digit run is capped at 3, so the first piece ends at byte 3 ("202").
    (let c6 (tkzb-score (eq (tkz-next-piece "2025" 4 0) 3) 32))
    ; "Hi!": a letter run, then punctuation splits — first piece ends at 2 ("Hi"), next at 3 ("!").
    (let c7 (tkzb-score (if (eq (tkz-next-piece "Hi!" 3 0) 2) (eq (tkz-next-piece "Hi!" 3 2) 3) 0) 64))
    ; " of": a single leading space joins the following word — the whole thing is one piece.
    (let c8 (tkzb-score (eq (tkz-next-piece " of" 3 0) 3) 128))

    ; ---- encode matched to ds4's ids, across the radius ----
    (let c9  (tkzb-score (tkzb-eq (tkz-encode src "The")  (list 671))        256))   ; letter run
    (let c10 (tkzb-score (tkzb-eq (tkz-encode src "2025") (list 939 23))     512))   ; digit triple + tail
    (let c11 (tkzb-score (tkzb-eq (tkz-encode src "Hi!")  (list 23166 3))    1024))  ; punctuation
    (let c12 (tkzb-score (tkzb-eq (tkz-encode src " of")  (list 294))        2048))  ; leading-space word
    (let c13 (tkzb-score (tkzb-eq (tkz-encode src "世界") (list 3427))       4096))  ; CJK, >=128 path

    (let verdict (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 (add c8
                 (add c9 (add c10 (add c11 (add c12 c13)))))))))))))
    (print (str_concat "Verdict " (int_to_str verdict)))
    verdict)
