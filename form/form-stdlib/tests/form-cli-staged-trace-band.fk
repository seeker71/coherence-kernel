; form-cli-staged-trace-band.fk — protected trust attestations over one hit.
;
; preludes: form-stdlib/core.fk form-stdlib/line-grammar.fk form-stdlib/str-byte-at.fk
; preludes: form-stdlib/sha256.fk form-stdlib/hmac-sha256.fk form-stdlib/hex.fk
; preludes: form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
; preludes: form-stdlib/rag-index-codec.fk form-stdlib/rag-retrieve.fk
; preludes: form-stdlib/rag-ask.fk form-stdlib/form-cli-router.fk
; preludes: form-stdlib/form-cli-judge.fk form-stdlib/form-cli-sufficiency.fk
; preludes: form-stdlib/form-freq-check.fk form-stdlib/trust-row.fk
; preludes: form-stdlib/form-cli-ask-gate.fk form-stdlib/form-cli-staged-trace.fk
;
; Verdict 2097151 proves 21 independent claim groups, including that public
; hashes, wrong/missing/rotated keys, field or certificate mutation, query and
; request replay, future issuance, expiry, and overlong lifetime cannot
; manufacture grounding or observation.

(do
    (defn fcst-ground-base (ref ctor source-key source-path answer-key persisted query-key issued expires)
        (fcast-cat (list ref "|" ctor "|" source-key "|" source-path "|"
            answer-key "|" persisted "|" query-key "|" issued "|" expires)))
    (defn fcst-ground-for (key-hex request-id ref ctor source-key source-path answer-key persisted query-key issued expires)
        (do
            (let base (fcst-ground-base ref ctor source-key source-path answer-key
                persisted query-key issued expires))
            (str_concat base (str_concat "|"
                (fcast-grounding-mac-for key-hex request-id base)))))
    (defn fcst-ground (key-hex ref ctor source-key source-path answer-key persisted query-key issued expires)
        (fcst-ground-for key-hex "staged" ref ctor source-key source-path
            answer-key persisted query-key issued expires))
    (defn fcst-no-cert (ground)
        (str_concat ground "|none|none|none|none|0|0|none|none"))
    (defn fcst-cert-with-evidence-for (key-hex request-id ground cert-ref ctor answer-key evidence issued expires result)
        (do
            (let base (fcast-cat (list ground "|" cert-ref "|" ctor "|" answer-key
                "|" evidence "|" issued "|" expires "|" result)))
            (str_concat base (str_concat "|"
                (fcast-frequency-mac-for key-hex request-id base)))))
    (defn fcst-cert-for (key-hex request-id ground cert-ref ctor answer-key issued expires result)
        (fcst-cert-with-evidence-for key-hex request-id ground cert-ref ctor
            answer-key
            (fcast-frequency-certificate-key-for cert-ref ctor answer-key result)
            issued expires result))
    (defn fcst-cert (key-hex ground cert-ref ctor answer-key issued expires result)
        (fcst-cert-for key-hex "staged" ground cert-ref ctor answer-key
            issued expires result))
    (defn fcst-cert-with-evidence (key-hex ground cert-ref ctor answer-key evidence issued expires result)
        (fcst-cert-with-evidence-for key-hex "staged" ground cert-ref ctor
            answer-key evidence issued expires result))

    (let key-hex "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f")
    (let wrong-key "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff")
    (let ref "@1.1.9.101")
    (let ctor "@8.4.4.22")
    (let source-key "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    (let source-path "docs/current-answer.form")
    (let answer-hex "41")
    (let answer-key (ra-answer-key-of-hex answer-hex))
    (let persisted "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    (let query-a "is the kernel deployed")
    (let query-b "garden moisture")
    (let binary-unicode-message
        (str_concat "A" (str_concat (byte_to_str 0) "λ🙂")))
    (let query-a-key (fcast-query-key query-a))
    (let query-b-key (fcast-query-key query-b))
    (let entry (append-1 (rag-grounded-binding-entry
        ref ctor source-path source-key answer-key answer-hex (list 4 1000005) 1)
        persisted))
    (let hit (ra-hit-row "hit" entry 4 1 4 75))
    (let tied-hit (ra-hit-row "hit" entry 4 4 4 0))
    (let ground (fcst-ground key-hex ref ctor source-key source-path answer-key
        persisted query-a-key "990" "1100"))
    (let no-cert (fcst-no-cert ground))
    (let cert (fcst-cert key-hex ground ref ctor answer-key
        "990" "1100" "success"))
    (let no-cert-result (fcast-result-at hit no-cert query-a-key key-hex 1000))
    (let full-result (fcast-result-at hit cert query-a-key key-hex 1000))

    (let public-base (fcst-ground-base ref ctor source-key source-path answer-key
        persisted query-a-key "990" "1100"))
    (let public-forge (fcst-no-cert (str_concat public-base
        (str_concat "|" (fcast-sha256-hex (fcast-grounding-canonical public-base))))))
    (let ref-mutation (fcst-no-cert (fcst-ground key-hex "@1.1.9.102" ctor source-key
        source-path answer-key persisted query-a-key "990" "1100")))
    (let persisted-mutated-base (fcst-ground-base ref ctor source-key source-path answer-key
        "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        query-a-key "990" "1100"))
    (let persisted-mutation (fcst-no-cert (str_concat persisted-mutated-base
        (str_concat "|" (fcast-grounding-mac key-hex ground)))))
    (let expired-ground (fcst-no-cert (fcst-ground key-hex ref ctor source-key
        source-path answer-key persisted query-a-key "800" "900")))
    (let future-ground (fcst-no-cert (fcst-ground key-hex ref ctor source-key
        source-path answer-key persisted query-a-key "1031" "1100")))
    (let long-ground (fcst-no-cert (fcst-ground key-hex ref ctor source-key
        source-path answer-key persisted query-a-key "900" "1201")))
    (let failed-cert (fcst-cert key-hex ground ref ctor answer-key
        "990" "1100" "failure"))
    (let expired-cert (fcst-cert key-hex ground ref ctor answer-key
        "800" "900" "success"))
    (let other-ref-cert (fcst-cert key-hex ground "@1.1.9.900" ctor answer-key
        "990" "1100" "success"))
    (let other-ctor-cert (fcst-cert key-hex ground ref "@8.4.4.23" answer-key
        "990" "1100" "success"))
    (let other-answer-cert (fcst-cert key-hex ground ref ctor
        "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        "990" "1100" "success"))
    (let evidence-mutation-cert (fcst-cert-with-evidence key-hex ground ref ctor
        answer-key
        "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        "990" "1100" "success"))
    (let evidence-shape-cert (fcst-cert-with-evidence key-hex ground ref ctor
        answer-key "witness:health" "990" "1100" "success"))
    (let wrong-frequency-mac-cert (fcst-cert wrong-key ground ref ctor answer-key
        "990" "1100" "success"))

    ; Request ids and key generations are independently HMAC-bound.  A receipt
    ; works under exactly the request and key generation that issued it.
    (let request-ground (fcst-ground-for key-hex "request-a" ref ctor source-key
        source-path answer-key persisted query-a-key "990" "1100"))
    (let request-cert (fcst-cert-for key-hex "request-a" request-ground ref ctor
        answer-key "990" "1100" "success"))
    (let rotated-ground (fcst-ground wrong-key ref ctor source-key source-path
        answer-key persisted query-a-key "990" "1100"))
    (let rotated-cert (fcst-cert wrong-key rotated-ground ref ctor answer-key
        "990" "1100" "success"))
    (let rotated-result (fcast-result-at hit rotated-cert query-a-key wrong-key 1000))

    (let c0 (if (eq (fcast-grounding-attested-at? hit no-cert query-a-key key-hex 1000) 1) 1 0))
    (let c1 (if (eq (fca-grounded? (fcast-grounding-at hit no-cert query-a-key key-hex 1000)) 1) 2 0))
    (let c2 (if (and (eq (fca-result-frequency no-cert-result) 2)
                      (str_eq (fca-result-freq-source no-cert-result) "unmeasured")) 4 0))
    (let c3 (if (and (eq (fca-result-sufficient no-cert-result) 1)
                      (eq (fca-result-observed no-cert-result) 0)) 8 0))
    (let c4 (if (and (eq (fcast-frequency-certificate-valid? cert) 1)
                      (and (str_eq (fcast-arg cert 13 "")
                              "d5aa291fbf72f066d5f0b387bc1279de101291c703f0fe902e57a84950bccf12")
                        (and (str_eq (fcast-hmac-hex key-hex binary-unicode-message)
                                  "bf350d0641a407659cbc3189c4938314bbcfacd1f2864c2dc8f2684f449cbe7f")
                          (and (eq (fcast-frequency-attested-at? hit cert key-hex 1000) 1)
                               (eq (fcast-frequency-attested-at? hit wrong-frequency-mac-cert key-hex 1000) 0))))) 16 0))
    (let c5 (if (eq (fca-result-observed full-result) 1) 32 0))
    (let c6 (if (eq (fcast-grounding-attested-at? hit public-forge query-a-key key-hex 1000) 0) 64 0))
    (let c7 (if (eq (fcast-grounding-attested-at? hit ref-mutation query-a-key key-hex 1000) 0) 128 0))
    (let c8 (if (eq (fcast-grounding-attested-at? hit persisted-mutation query-a-key key-hex 1000) 0) 256 0))
    (let c9 (if (and (eq (fcast-grounding-attested-at? hit no-cert query-b-key key-hex 1000) 0)
                      (and (eq (fcast-grounding-attested-for-at? hit request-cert "request-a" query-a-key key-hex 1000) 1)
                           (and (eq (fcast-grounding-attested-for-at? hit request-cert "request-b" query-a-key key-hex 1000) 0)
                                (and (eq (fca-result-observed (fcast-result-for-at hit request-cert "request-a" query-a-key key-hex 1000)) 1)
                                     (eq (fca-result-observed (fcast-result-for-at hit request-cert "request-b" query-a-key key-hex 1000)) 0))))) 512 0))
    (let c10 (if (eq (fcast-grounding-attested-at? hit expired-ground query-a-key key-hex 1000) 0) 1024 0))
    (let c11 (if (eq (fcast-grounding-attested-at? hit future-ground query-a-key key-hex 1000) 0) 2048 0))
    (let c12 (if (eq (fcast-grounding-attested-at? hit long-ground query-a-key key-hex 1000) 0) 4096 0))
    (let c13 (if (and (eq (fcast-grounding-attested-at? hit no-cert query-a-key wrong-key 1000) 0)
                       (and (eq (fca-result-observed rotated-result) 1)
                            (and (eq (fca-result-observed (fcast-result-at hit rotated-cert query-a-key key-hex 1000)) 0)
                                 (eq (fca-result-observed (fcast-result-at hit cert query-a-key wrong-key 1000)) 0)))) 8192 0))
    (let c14 (if (eq (fcast-grounding-attested-at? hit no-cert query-a-key "" 1000) 0) 16384 0))
    (let c15 (if (and (eq (fcast-frequency-attested-at? hit failed-cert key-hex 1000) 0)
                       (and (eq (fcast-frequency-attested-at? hit evidence-mutation-cert key-hex 1000) 0)
                            (eq (fcast-frequency-attested-at? hit evidence-shape-cert key-hex 1000) 0))) 32768 0))
    (let c16 (if (eq (fcast-frequency-attested-at? hit expired-cert key-hex 1000) 0) 65536 0))
    (let c17 (if (and (eq (fcast-frequency-attested-at? hit other-ref-cert key-hex 1000) 0)
                       (and (eq (fcast-frequency-attested-at? hit other-ctor-cert key-hex 1000) 0)
                            (eq (fcast-frequency-attested-at? hit other-answer-cert key-hex 1000) 0))) 131072 0))
    (let c18 (if (str_eq (fcast-trace-hit-at hit cert query-a-key key-hex 1000)
                  (str_concat
                    "trust  path:native  grounded:yes  freq:yes  freq-source:certified-form  suffic:yes  observed:yes  -> OBSERVED  decision:accept  reason:ok\n"
                    (ra-hit-output hit))) 262144 0))
    (let c19 (if (str_eq (fcast-trace-hit-at (ra-miss) "" query-a-key key-hex 1000)
                  "trust  path:rented  grounded:no  freq:unknown  freq-source:unmeasured  suffic:no  observed:no  -> rented  decision:escalate  reason:empty\ngrounded:miss") 524288 0))
    (let tied-result (fcast-result-at tied-hit cert query-a-key key-hex 1000))
    (let c20 (if (and (eq (fca-result-sufficient tied-result) 0)
                       (eq (fca-result-observed tied-result) 0)) 1048576 0))

    (sum (list c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15
        c16 c17 c18 c19 c20)))
