; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/form-fs.fk form-stdlib/format-arith.fk form-stdlib/f16-decode.fk form-stdlib/gguf-read.fk form-stdlib/q4k-dequant.fk form-stdlib/q6k-dequant.fk form-stdlib/weight-load.fk form-stdlib/equireach.fk form-stdlib/equireach-gguf.fk
;
; PROOF LEVEL: TWO-ARM (fkwu + go). Not rostered four-way, and the reason is a defect in the other two
; arms rather than in this band: `read_file_slice` over a BINARY file is byte-faithful on fkwu and on
; the Go kernel, and LOSSY on rust and ts — both hand back 767 bytes for this 420-byte fixture, having
; UTF-8-replaced every invalid byte with U+FFFD (ef bf bd). Byte 4 reads 239 instead of 210 there. Any
; recipe that reads binary through those two arms is silently reading a different file, so this band
; refuses to launder that into a green four-way row. q6k-bounds-band.fk carries the same fixture as a
; transcribed LIST and does cross four-way (255) — the arithmetic travels; only the byte door does not.
;
; equireach-band — the new carrier made falsifiable the only way that counts: it must agree with the
; four-way-proven list lane BIT FOR BIT, on real llama3.2:3b Q6_K bytes, at every one of 512 weights
; spanning two superblocks. A faster carrier that disagreed anywhere would be worthless; a carrier
; that agrees everywhere has earned the right to replace the reach.
;
; What it cannot prove in-band is the COST curve — a verdict bit cannot time itself, and fkwu
; constant-folds a band into its .fkb, so a second run measures cache load and not computation. The
; curve is measured by the Stone-2 receipt's harness (10M reads at the last byte of windows from 64 KB
; to 16 MB, .fkb cleared, three runs each: 0.44 / 0.43 / 0.43 / 0.44 / 0.43 s — flat) and is recorded
; in receipts/2026-07-21-equireach-carrier-metal-resident.md, not asserted here.
;
; THE FIXTURE is q6k-bounds-band's: two consecutive REAL llama3.2:3b Q6_K superblocks (420 bytes) from
; ~/.ollama/models/blobs/sha256-dde5aa3f...ccdff at absolute offset 331055328 (blk.0.ffn_down.weight).
; It arrives TWICE and independently — as the transcribed byte list below (the list carrier's food) and
; as form-stdlib/tests/fixtures/q6k-two-superblocks.bin, sha256 d44993f2...e8c1 (the equireach window's).
; Claim 1 is that the two agree in all 420 bytes, so neither carrier can be right by accident. The .bin
; is the committed Q6_K fixture the Stone-1 receipt named as missing; the band needs no 2 GB blob.
;
; Kin: equireach.fk (the source), equireach-gguf.fk (the reach path under test), weight-load.fk
; (wl-q6k-at-flat — the list twin it must equal), q6k-bounds-band.fk (the same bytes, the wall claim).
;
; Verdict 511 when the new carrier is honest:
;   1    the window IS the transcribed bytes    (eqr-len 420, and all 420 bytes equal the list)
;   2    the window's edge is named, not guessed  (eqr-in? 419 -> 1, 420 -> 0, -1 -> 0)
;   4    little-endian decode agrees with gg-le   (eqr-le == gg-le at 4 widths on the same offset)
;   8    the super-scale d agrees                 (ewl-d == wl-q6k-d, both from the file's own f16)
;   16   in-block weights agree                   (ewl-at == wl-q6k-at at i=0, 1, 255)
;   32   the flat accessor crosses the wall       (ewl-flat-at 256 -> 19241.333.., not -0)
;   64   ALL 512 WEIGHTS AGREE, bit for bit       (fold over both carriers, no epsilon, no sampling)
;   128  the materialized list is the same list   (ewl-weights 512 agrees elementwise with the fold)
;   256  matrices carve identically               (ewl-mat 17x17 [16][16] == w[288] = 25485.5156..)
(do
    (defn eqb-pin (x lo hi) (if (gt x lo) (if (lt x hi) 1 0) 0))
    ; elementwise agreement between the two carriers over [i, n) — no epsilon: the claim is equality
    (defn eqb-agree (src bs base i n)
        (if (ge i n) 1
            (if (eq (ewl-flat-at src base i) (wl-q6k-at-flat bs base i))
                (eqb-agree src bs base (add i 1) n)
                0)))
    ; the equireach window against the transcribed byte list, byte for byte
    (defn eqb-bytes-eq (src bs i n)
        (if (ge i n) 1
            (if (eq (eqr-at src i) (nth bs i))
                (eqb-bytes-eq src bs (add i 1) n)
                0)))
    ; the same, against an already-materialized list
    (defn eqb-agree-list (ws src base i n)
        (if (ge i n) 1
            (if (eq (head ws) (ewl-flat-at src base i))
                (eqb-agree-list (tail ws) src base (add i 1) n)
                0)))

    ; two REAL consecutive Q6_K superblocks (ql[128] qh[64] scales[16] d-f16[2]) x 2 = 420 bytes
    (let bs (list
        72 107 65 50 210 39 121 53 43 55 128 68
        2 15 170 169 243 145 149 63 97 113 161 186
        90 55 104 137 6 58 12 15 183 176 60 97
        217 121 127 119 103 97 81 43 212 243 24 216
        95 217 18 212 183 126 183 204 2 89 112 56
        140 193 138 75 80 14 150 81 155 172 129 64
        129 59 37 192 232 113 81 125 226 187 34 202
        128 212 245 70 19 234 247 119 8 152 68 233
        145 55 214 97 203 188 242 255 127 170 137 137
        4 138 79 15 173 75 208 17 196 238 251 68
        227 192 134 244 64 16 61 41 81 178 223 147
        98 126 169 181 133 167 104 146 142 46 22 29
        85 4 46 245 102 149 150 164 16 114 242 70
        85 42 133 165 171 138 73 162 22 149 75 118
        71 8 182 164 5 150 167 107 118 84 234 40
        84 87 133 234 136 5 110 200 127 35 50 154
        139 128 139 139 95 180 152 103 128 76 128 110
        96 114 135 178 164 0 205 41 5 77 75 244
        16 225 205 55 195 14 239 170 216 122 14 145
        247 131 0 172 18 92 189 112 75 182 138 248
        189 15 77 17 169 209 17 120 116 239 233 41
        56 20 87 133 34 244 131 199 230 47 9 2
        65 119 42 110 115 255 49 147 80 198 218 136
        98 62 33 90 153 210 0 58 193 126 115 166
        221 167 234 9 140 149 208 232 83 157 125 158
        147 171 211 76 81 0 233 51 17 162 24 61
        192 211 132 182 235 101 106 114 185 103 251 150
        15 70 10 107 73 15 39 241 236 49 10 170
        123 79 78 232 233 44 177 18 255 164 94 146
        190 8 197 162 117 41 104 20 38 98 37 153
        139 97 229 105 168 38 96 154 68 173 22 185
        24 166 103 170 114 77 132 132 73 74 137 169
        133 151 39 147 166 109 232 84 155 22 152 81
        3 221 85 154 101 70 128 175 180 77 77 121
        155 189 88 188 157 160 195 169 124 89 194 128))

    ; the SAME bytes as an equireach window. It is read from the COMMITTED fixture file rather than
    ; round-tripped through host-abi-bytes-to-string, and that was forced by a witness: on the Go
    ; kernel `byte_to_str` UTF-8-ENCODES a byte >= 128 (210 becomes 0xC3 0x92), so a 420-byte list
    ; comes back as a 435-byte string and every offset after the first high byte is wrong. The list
    ; below and the file are therefore two independent transcriptions of the same 420 real bytes, and
    ; claim 1 is exactly the statement that they agree — a mistyped digit in either falsifies it.
    (let src (eqr-of-file "form-stdlib/tests/fixtures/q6k-two-superblocks.bin" 0 420))

    ; --- 1: the window is the bytes it was given — all 420, not a sample ---
    (let c0 (if (eq (eqr-len src) 420)
            (if (eq (eqb-bytes-eq src bs 0 420) 1) 1 0) 0))

    ; --- 2: the edge is named, not guessed ---
    (let c1 (if (eq (eqr-in? src 419) 1)
            (if (eq (eqr-in? src 420) 0)
            (if (eq (eqr-in? src (sub 0 1)) 0) 2 0) 0) 0))

    ; --- 4: little-endian decode agrees with the four-way-proven gg-le at every width ---
    (let c2 (if (eq (eqr-le src 4 1) (gg-le bs 4 1))
            (if (eq (eqr-le src 4 2) (gg-le bs 4 2))
            (if (eq (eqr-u32 src 4) (gg-le bs 4 4))
            (if (eq (eqr-u64 src 4) (gg-le bs 4 8)) 4 0) 0) 0) 0))

    ; --- 8: the super-scale d, decoded from the file's own f16 bytes on both lanes ---
    (let c3 (if (eq (ewl-d src 0) (wl-q6k-d bs 0))
            (if (eq (ewl-d src 210) (wl-q6k-d bs 210)) 8 0) 0))

    ; --- 16: in-block weights agree ---
    (let c4 (if (eq (ewl-at src 0 0) (wl-q6k-at bs 0 0))
            (if (eq (ewl-at src 0 1) (wl-q6k-at bs 0 1))
            (if (eq (ewl-at src 0 255) (wl-q6k-at bs 0 255)) 16 0) 0) 0))

    ; --- 32: the flat accessor crosses the superblock wall (pinned to ggml's own value) ---
    (let w256 (mul 1000000.0 (ewl-flat-at src 0 256)))
    (let c5 (if (eq (eqb-pin w256 19241.33 19241.34) 1) 32 0))

    ; --- 64: ALL 512 weights, both carriers, no epsilon and no sampling ---
    (let c6 (if (eq (eqb-agree src bs 0 0 512) 1) 64 0))

    ; --- 128: the materialized flat list is that same list ---
    (let ws (ewl-weights src 0 512))
    (let c7 (if (eq (len ws) 512)
            (if (eq (eqb-agree-list ws src 0 0 512) 1) 128 0) 0))

    ; --- 256: matrices carve identically at a width the old lane could not reach ---
    (let m17 (ewl-mat ws 17 17))
    (let m288 (mul 1000000.0 (nth (nth m17 16) 16)))
    (let c8 (if (eq (len m17) 17)
            (if (eq (eqb-pin m288 25485.51 25485.52) 1) 256 0) 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 c8)))))))))
