  (defn wr-vd (a b) (if (eq (len a) 0) 0.0 (do (let d (wr-abs (sub (head a) (head b)))) (let r (wr-vd (tail a) (tail b))) (if (gt d r) d r))))
  (defn wr-md (as bs) (if (eq (len as) 0) 0.0 (do (let d (wr-vd (head as) (head bs))) (let r (wr-md (tail as) (tail bs))) (if (gt d r) d r))))
