; source-artifact-descriptor-band.fk -- witness Layer 8b artifact descriptors.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk
;
; Expected: 2147483647
;
; Bits:
;   1         manifest declares source-identity-required
;   2         manifest declares program-image-fkb-kind
;   4         manifest declares optional-native-dylib-kind
;   8         manifest declares artifact-identity-fields
;   16        manifest declares seal-is-declared-not-verified
;   32        manifest declares proof-status-for-dylib
;   64        manifest declares derives-sac-state
;   128       manifest declares no-disk-io
;   256       manifest declares not-parsed-data-fkb
;   512       manifest declares no-runtime-selector
;   1024      manifest declares routing-owned-by-sac
;   2048      manifest declares no-c-seed-growth
;   4096      well-formed descriptor bundle validates
;   8192      invalid source descriptor fails validation
;   16384     unknown artifact kind rejects
;   32768     parsed-data fkb kind rejects
;   65536     fresh program-image fkb routes to fkb
;   131072    stale-mtime fkb routes to source compile
;   262144    source-hash mismatch routes to source compile
;   524288    seal-bad fkb routes to source compile
;   1048576   version mismatch routes to source compile
;   2097152   fresh proven dylib with current fkb routes to dylib
;   4194304   unproven dylib falls back to fkb
;   8388608   fresh dylib with stale fkb routes to source compile
;   16777216  missing artifacts route to source compile
;   33554432  equal-mtime fkb boundary is fresh
;   67108864  source-newer-than-artifacts routes to source compile
;   134217728 compile-output intent reuses sac policy, including nonlowerable
;   268435456 invalid descriptor does not route as source compile
;   536870912 descriptor-derived routes match hand-built sac-state routes
;   1073741824 seal-bad dylib quarantines the bundle and routes to compile

(do
    (defn sadb-score (ok bit) (if ok bit 0))
    (defn sadb-manifest-has (name)
        (source-artifact-descriptor-manifest-has? name (source-artifact-descriptor-manifest)))
    (defn sadb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn sadb-source-newer () (sad-source "src/kernel.fk" "sha:src-a" 200))
    (defn sadb-invalid-source () (sad-source "" "sha:src-a" 100))
    (defn sadb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn sadb-fkb-equal ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 100 1 1))
    (defn sadb-fkb-stale ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 99 1 1))
    (defn sadb-fkb-hash-bad ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:old-src" "sha:fkb-a" 101 1 1))
    (defn sadb-fkb-seal-bad ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 0 1))
    (defn sadb-fkb-version-bad ()
        (sad-program-image-fkb "program-image-v0" "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn sadb-fkb-unknown ()
        (sad-artifact "compiler-image-fkb" "compiler-image-v1" "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 0 0 0 1))
    (defn sadb-fkb-parsed-data ()
        (sad-artifact (sad-kind-parsed-data-fkb) "parsed-data-v1" "src/data.fkb" "sha:src-a" "sha:data-a" 101 1 0 0 0 1))
    (defn sadb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn sadb-dylib-unproven ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 0 1 1))
    (defn sadb-dylib-seal-bad ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 0 1 1 1))
    (defn sadb-dylib-nonlowerable ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 0))

    (defn sadb-route (fkb dylib)
        (sad-route (sadb-source) fkb dylib))
    (defn sadb-route-newer (fkb dylib)
        (sad-route (sadb-source-newer) fkb dylib))
    (defn sadb-output-native ()
        (sad-compile-output-from-dylib (sadb-dylib-fresh)))
    (defn sadb-output-nonlowerable ()
        (sad-compile-output-from-dylib (sadb-dylib-nonlowerable)))

    (defn source-artifact-descriptor-band ()
        (sum (list
            (sadb-score (eq (sadb-manifest-has "source-identity-required") 1) 1)
            (sadb-score (eq (sadb-manifest-has "program-image-fkb-kind") 1) 2)
            (sadb-score (eq (sadb-manifest-has "optional-native-dylib-kind") 1) 4)
            (sadb-score (eq (sadb-manifest-has "artifact-identity-fields") 1) 8)
            (sadb-score (eq (sadb-manifest-has "seal-is-declared-not-verified") 1) 16)
            (sadb-score (eq (sadb-manifest-has "proof-status-for-dylib") 1) 32)
            (sadb-score (eq (sadb-manifest-has "derives-sac-state") 1) 64)
            (sadb-score (eq (sadb-manifest-has "no-disk-io") 1) 128)
            (sadb-score (eq (sadb-manifest-has "not-parsed-data-fkb") 1) 256)
            (sadb-score (eq (sadb-manifest-has "no-runtime-selector") 1) 512)
            (sadb-score (eq (sadb-manifest-has "routing-owned-by-sac") 1) 1024)
            (sadb-score (eq (sadb-manifest-has "no-c-seed-growth") 1) 2048)
            (sadb-score (sad-valid? (sadb-source) (sadb-fkb-fresh) (sadb-dylib-fresh)) 4096)
            (sadb-score (not (sad-valid? (sadb-invalid-source) (sadb-fkb-fresh) (sad-no-artifact))) 8192)
            (sadb-score (not (sad-artifact-option-valid? (sadb-fkb-unknown))) 16384)
            (sadb-score
                (and (sad-parsed-data-kind? (sad-artifact-kind (sadb-fkb-parsed-data)))
                     (not (sad-artifact-option-valid? (sadb-fkb-parsed-data))))
                32768)
            (sadb-score (eq (sadb-route (sadb-fkb-fresh) (sad-no-artifact)) (sac-run-fkb)) 65536)
            (sadb-score (eq (sadb-route (sadb-fkb-stale) (sad-no-artifact)) (sac-run-source-compile)) 131072)
            (sadb-score (eq (sadb-route (sadb-fkb-hash-bad) (sad-no-artifact)) (sac-run-source-compile)) 262144)
            (sadb-score (eq (sadb-route (sadb-fkb-seal-bad) (sad-no-artifact)) (sac-run-source-compile)) 524288)
            (sadb-score (eq (sadb-route (sadb-fkb-version-bad) (sad-no-artifact)) (sac-run-source-compile)) 1048576)
            (sadb-score (eq (sadb-route (sadb-fkb-fresh) (sadb-dylib-fresh)) (sac-run-dylib)) 2097152)
            (sadb-score (eq (sadb-route (sadb-fkb-fresh) (sadb-dylib-unproven)) (sac-run-fkb)) 4194304)
            (sadb-score (eq (sadb-route (sadb-fkb-stale) (sadb-dylib-fresh)) (sac-run-source-compile)) 8388608)
            (sadb-score (eq (sadb-route (sad-no-artifact) (sad-no-artifact)) (sac-run-source-compile)) 16777216)
            (sadb-score (eq (sadb-route (sadb-fkb-equal) (sad-no-artifact)) (sac-run-fkb)) 33554432)
            (sadb-score (eq (sadb-route-newer (sadb-fkb-fresh) (sadb-dylib-fresh)) (sac-run-source-compile)) 67108864)
            (sadb-score
                (and (eq (sac-output-writes-fkb (sadb-output-native)) 1)
                     (and (eq (sac-output-writes-dylib (sadb-output-native)) 1)
                          (and (eq (sac-output-embeds-table-payload (sadb-output-native)) 1)
                               (and (eq (sac-output-no-c-growth (sadb-output-native)) 1)
                                    (eq (sac-output-writes-dylib (sadb-output-nonlowerable)) 0)))))
                134217728)
            (sadb-score (eq (sad-route (sadb-invalid-source) (sadb-fkb-fresh) (sad-no-artifact)) (sad-route-invalid)) 268435456)
            (sadb-score
                (and (eq (sadb-route (sadb-fkb-fresh) (sad-no-artifact))
                         (sac-route (sac-state 100 101 -1 1 0 0 0 0 1)))
                     (and (eq (sadb-route (sadb-fkb-stale) (sad-no-artifact))
                              (sac-route (sac-state 100 99 -1 1 0 0 0 0 1)))
                          (and (eq (sadb-route (sadb-fkb-fresh) (sadb-dylib-fresh))
                                   (sac-route (sac-state 100 101 102 1 1 1 1 1 1)))
                               (and (eq (sadb-route (sadb-fkb-fresh) (sadb-dylib-unproven))
                                        (sac-route (sac-state 100 101 102 1 1 1 0 1 1)))
                                    (eq (sadb-route (sad-no-artifact) (sad-no-artifact))
                                        (sac-route (sac-state 100 -1 -1 0 0 0 0 0 1)))))))
                536870912)
            (sadb-score
                (and (eq (sadb-route (sadb-fkb-fresh) (sadb-dylib-seal-bad)) (sac-run-source-compile))
                     (not (eq (sadb-route (sadb-fkb-fresh) (sadb-dylib-seal-bad)) (sac-run-fkb))))
                1073741824))))

    (source-artifact-descriptor-band))
