; preludes:
;   form-stdlib/somatic-coherence-loop.fk
;   form-stdlib/form-cli-router.fk
;   form-stdlib/form-cli-sufficiency.fk
;   form-stdlib/observed-auto-learning.fk
;
; observed-auto-learning-band -- live observation changes the algorithm.
;
; Verdict 4095:
;   1    ungrounded still routes to ground
;   2    no consent still routes to ask-consent
;   4    closed choice holds the experiment
;   8    fail stops the branch
;   16   undo rolls back the last change
;   32   cut prunes the branch
;   64   timeout is treated as nothing
;   128  A/B challenger promotion wins over ordinary routing
;   256  posterior retry stays local
;   512  routed oracle asks the agent lane
;   1024 local route + sufficient answer runs local
;   2048 live control changes the mode from batch-search to online-reversible-ab

(do
    (defn oal-band-score (cond bit) (if cond bit 0))

    (defn oal-band-open () (oal-controls 1 0 0 0 0))
    (defn oal-band-closed () (oal-controls 0 0 0 0 0))
    (defn oal-band-fail () (oal-controls 1 1 0 0 0))
    (defn oal-band-undo () (oal-controls 1 0 0 1 0))
    (defn oal-band-cut () (oal-controls 1 0 1 0 0))
    (defn oal-band-timeout () (oal-controls 1 0 0 0 1))

    (defn oal-band-local-route ()
        (fcr-route
            (fcr-backend-learned "form-native" 90 80 100 9 10)
            (fcr-backend-learned "agent-cli" 40 95 100 8 10)))
    (defn oal-band-agent-route ()
        (fcr-route
            (fcr-backend-learned "form-native" 90 80 0 0 10)
            (fcr-backend-learned "agent-cli" 40 95 100 8 10)))

    (defn oal-band-accept () (fsuf-verdict (fsuf-signals 1 1 80 80 80 0)))
    (defn oal-band-retry () (fsuf-verdict (fsuf-signals 0 1 80 80 80 1)))
    (defn oal-band-challenger () (oal-ab-authority 9 9 10 10 0))
    (defn oal-band-champion () (oal-ab-authority 8 5 10 10 0))

    (defn oal-band-c0 () (oal-band-score
        (str_eq (oal-next 0 1 1 1 1 1 (oal-band-open) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "ground")
        1))
    (defn oal-band-c1 () (oal-band-score
        (str_eq (oal-next 1 1 0 1 1 1 (oal-band-open) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "ask-consent")
        2))
    (defn oal-band-c2 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-closed) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "hold-choice")
        4))
    (defn oal-band-c3 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-fail) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "fail-stop")
        8))
    (defn oal-band-c4 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-undo) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "undo-last-change")
        16))
    (defn oal-band-c5 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-cut) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "cut-branch")
        32))
    (defn oal-band-c6 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-timeout) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "timeout-as-nothing")
        64))
    (defn oal-band-c7 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-open) (oal-band-local-route) (oal-band-accept) (oal-band-challenger)) "ab-promote-challenger")
        128))
    (defn oal-band-c8 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-open) (oal-band-local-route) (oal-band-retry) (oal-band-champion)) "retry-local")
        256))
    (defn oal-band-c9 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-open) (oal-band-agent-route) (oal-band-accept) (oal-band-champion)) "ask-oracle")
        512))
    (defn oal-band-c10 () (oal-band-score
        (str_eq (oal-next 1 1 1 1 1 1 (oal-band-open) (oal-band-local-route) (oal-band-accept) (oal-band-champion)) "run-local")
        1024))
    (defn oal-band-c11 () (oal-band-score
        (and (str_eq (oal-mode 0 (oal-band-open) 1) "batch-search")
             (str_eq (oal-mode 1 (oal-band-open) 1) "online-reversible-ab"))
        2048))

    (defn observed-auto-learning-band ()
        (add (add (add (add (oal-band-c0) (oal-band-c1)) (add (oal-band-c2) (oal-band-c3)))
                  (add (add (oal-band-c4) (oal-band-c5)) (add (oal-band-c6) (oal-band-c7))))
             (add (add (oal-band-c8) (oal-band-c9)) (add (oal-band-c10) (oal-band-c11)))))

    (observed-auto-learning-band))
