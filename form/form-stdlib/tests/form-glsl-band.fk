; preludes: form-stdlib/core.fk form-stdlib/form-glsl.fk
;
; form-glsl-band - the Form->GLSL emitter proven three-way: the emitted matvec compute shader is
; byte-identical across kernels (str_eq vs the canonical proven matvec.comp), the workgroup size
; parameterizes cleanly, and emission is deterministic. The GLSL mints to SPIR-V that runs bit-
; exact on Vulkan (native/vulkan/matvec_vk.c, RTX + Android-portable); this band gates the text.
;
; Verdict 7 when the emission lands:
;   1   the full emitted GLSL at local_size 64 equals the canonical shader
;   2   a different workgroup size (32) lands in the same frame (emission is a function)
;   4   two emissions of the same size are str_eq (deterministic)
(do
    (let want "#version 450\n\n// form-native matvec compute shader (Android/Vulkan lane, prototyped on RTX).\n// One invocation per output row; serial DOWNWARD right-fold (j = cols-1..0), the same\n// op order as jte-matvec-msl / fptx-matvec / tb-dot. `precise` -> NoContraction so the\n// driver does NOT fuse mul+add into FMA -> bit-exact to the CPU right-fold and to the\n// PTX/MSL lanes. Do NOT call fma(); do NOT run spirv-opt (its MergeMulAddArithmetic\n// re-fuses on Adreno). The same .spv runs on Adreno/Mali.\nlayout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;\n\nlayout(std430, binding = 0) readonly  buffer W { float w[]; };   // rows*cols\nlayout(std430, binding = 1) readonly  buffer X { float x[]; };   // cols\nlayout(std430, binding = 2) writeonly buffer Y { float y[]; };   // rows\n\nlayout(push_constant) uniform Push { uint rows; uint cols; } pc;\n\nvoid main() {\n    uint i = gl_GlobalInvocationID.x;\n    if (i >= pc.rows) return;\n    precise float acc = 0.0;\n    for (int j = int(pc.cols) - 1; j >= 0; --j) {\n        precise float prod = w[i * pc.cols + uint(j)] * x[uint(j)];\n        acc = prod + acc;\n    }\n    y[i] = acc;\n}\n")
    (let got (fglsl-matvec "64"))
    (let other (fglsl-matvec "32"))
    (let c0 (if (str_eq got want) 1 0))
    (let c1 (if (str_eq other (str_concat "#version 450\n\n// form-native matvec compute shader (Android/Vulkan lane, prototyped on RTX).\n// One invocation per output row; serial DOWNWARD right-fold (j = cols-1..0), the same\n// op order as jte-matvec-msl / fptx-matvec / tb-dot. `precise` -> NoContraction so the\n// driver does NOT fuse mul+add into FMA -> bit-exact to the CPU right-fold and to the\n// PTX/MSL lanes. Do NOT call fma(); do NOT run spirv-opt (its MergeMulAddArithmetic\n// re-fuses on Adreno). The same .spv runs on Adreno/Mali.\nlayout(local_size_x = " (str_concat "32" ", local_size_y = 1, local_size_z = 1) in;\n\nlayout(std430, binding = 0) readonly  buffer W { float w[]; };   // rows*cols\nlayout(std430, binding = 1) readonly  buffer X { float x[]; };   // cols\nlayout(std430, binding = 2) writeonly buffer Y { float y[]; };   // rows\n\nlayout(push_constant) uniform Push { uint rows; uint cols; } pc;\n\nvoid main() {\n    uint i = gl_GlobalInvocationID.x;\n    if (i >= pc.rows) return;\n    precise float acc = 0.0;\n    for (int j = int(pc.cols) - 1; j >= 0; --j) {\n        precise float prod = w[i * pc.cols + uint(j)] * x[uint(j)];\n        acc = prod + acc;\n    }\n    y[i] = acc;\n}\n"))) 2 0))
    (let c2 (if (str_eq (fglsl-matvec "64") got) 4 0))
    (add c0 (add c1 c2)))
