            (rpiftcb-score
                (and (rpiftc-join? j)
                (and (rale-envelope? (rpiftc-join-envelope j))
                (and (pifbd-admission? (rpiftc-join-admission j))
                (and (rpiwt-trace? (rpiftc-join-trace j))
                (and (rpiwt-bridge? (rpiftc-join-trace-bridge j))
                     (rpifc-join? (rpiftc-join-capability-join j)))))))
                32)))
    (defn rpiftcb-bit-9f-9c-ok ()
        (do
            (let j (rpiftcb-ok-join))
            (let r (rpiftcb-receipt-from-join j))
            (let o (rpiftcb-outcome-from-join j))
            (rpiftcb-score
