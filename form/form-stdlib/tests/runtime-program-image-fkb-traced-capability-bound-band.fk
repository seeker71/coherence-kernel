            (let r (rpiftcb-receipt-from-join j))
            (rpiftcb-score
                (and (rpiftcb-has? (raar-receipt-detail r) (rpiwt-marker))
                     (rpiftcb-has? (raar-receipt-detail r) "stop=completed"))
                128)))
    (defn rpiftcb-bit-invalid-trace-no-capability ()
        (do
            (let j (rpiftcb-join-from (rpiftcb-readiness) (rpiftcb-invalid-trace)))
            (rpiftcb-score
                (and (or (rpiftcb-investigate? j) (rpiftcb-refused? j))
                (and (rpiftcb-reason? j (rpiftc-reason-trace-not-ready))
                (and (rpiftcb-no-capability-join? j)
                     (rpiftcb-no-attempt? j))))
                256)))
    (defn rpiftcb-bit-malformed-bridges ()
        (do
            (let t (rpiwt-bridge-from-trace (rpiftcb-envelope) (rpiftcb-admission) (rpiftcb-ok-trace)))
            (let bad-t (rpiftc-join-from-bridges (rpiftcb-envelope) (rpiftcb-readiness) (rpiftcb-admission)
                                                 (rpiftcb-ok-trace) (list "bad-trace-bridge") (rpiftcb-capability-join-for t)))
            (let bad-c (rpiftc-join-from-bridges (rpiftcb-envelope) (rpiftcb-readiness) (rpiftcb-admission)
                                                 (rpiftcb-ok-trace) t (list "bad-capability-join")))
            (rpiftcb-score
                (and (rpiftcb-refused? bad-t)
                (and (rpiftcb-reason? bad-t (rpiftc-reason-malformed-trace-bridge))
                     (rpiftcb-reason? bad-c (rpiftc-reason-malformed-capability-join))))
                512)))
    (defn rpiftcb-bit-current-floor-no-capability ()
        (do
            (let floor (rpiftcb-join-from (rpiftcb-current-floor-readiness) (rpiftcb-ok-trace)))
            (let none (rpiftcb-join-from (rpiftcb-no-capability-readiness) (rpiftcb-ok-trace)))
            (rpiftcb-score
                (and (rpiftcb-unavailable? floor)
                (and (rpiftcb-no-attempt? floor)
                (and (rpiftcb-reason? floor (raec-reason-capability-unavailable))
                (and (rpiftcb-unavailable? none)
                     (rpiftcb-reason? none (raec-reason-no-capability-supplied))))))
                1024)))
    (defn rpiftcb-bit-stale-inadequate-forbidden ()
        (do
            (let stale (rpiftcb-join-from (rpiftcb-stale-readiness) (rpiftcb-ok-trace)))
            (let weak (rpiftcb-join-from (rpiftcb-inadequate-readiness) (rpiftcb-ok-trace)))
            (let forbid (rpiftcb-join-from (rpiftcb-forbidden-readiness) (rpiftcb-ok-trace)))
            (rpiftcb-score
                (and (rpiftcb-investigate? stale)
                (and (rpiftcb-reason? stale (raec-reason-capability-stale))
                (and (rpiftcb-investigate? weak)
                (and (rpiftcb-reason? weak (raec-reason-evidence-inadequate))
                (and (rpiftcb-refused? forbid)
