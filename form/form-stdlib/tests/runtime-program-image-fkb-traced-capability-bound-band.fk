    (defn rpiftcb-bit-version ()
        (rpiftcb-score (str_eq (rpiftc-version) "runtime-program-image-fkb-traced-capability-bound-v1") 4))
    (defn rpiftcb-bit-happy-bound ()
        (do
            (let j (rpiftcb-ok-join))
            (rpiftcb-score
                (and (rpiftcb-bound? j)
                (and (rpiftcb-reason? j (rpiftc-reason-bound))
                (and (rpiwt-bridge? (rpiftc-join-trace-bridge j))
                (and (rpifc-join? (rpiftc-join-capability-join j))
                     (not (rpiftcb-no-attempt? j))))))
                8)))
    (defn rpiftcb-bit-top-attempt-agrees ()
        (do
