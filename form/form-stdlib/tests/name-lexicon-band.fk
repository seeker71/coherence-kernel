; preludes: form-stdlib/core.fk form-stdlib/name-lexicon.fk
;
; name-lexicon-band.fk — three dramatic tongues as wide as English, by proof.
;
; A real s-expr fragment renders into 中文, العربية, and संस्कृतम् name
; surfaces and back: render must CHANGE the text (the tongue is really
; there), accept(render(x)) must equal x exactly (nothing lost), for all
; three tongues — plus the parity witness (every seated row carries all four
; columns non-empty) and the floor count (>= 40 rows; the seated head covers
; 42% of all identifier occurrences in the body, measured 2026-07-17).
; The walk splits only at ASCII delimiters so no kernel slices inside a
; multibyte char: this band is a four-way candidate by construction.
;
; Bits: for each tongue (changed, round-trip) x 3 = 6; bits 6-7 the SAME
; pair for "nsym" — the neutral y<k> spelling itself (the body's code in a
; tongue no language owns); bit 8 parity (all five columns full); bit 9
; count now EXACT (64 — the working world closes at the hexagram count);
; bit 10: the layer boundaries 3,4,5,7,8,12,13 each close their core domain
; language. Verdict 2047.
(do
    (let src "(defn head-or-empty (xs) (if (nil? xs) (empty) (head xs)))")

    (defn chpair (tongue s bit-lo)
        (do (let r (nlx-render tongue s))
            (add (if (str_eq r s) 0 bit-lo)
                 (if (str_eq (nlx-accept tongue r) s) (mul bit-lo 2) 0))))

    (let c-zh (chpair "zh" src 1))
    (let c-ar (chpair "ar" src 4))
    (let c-sa (chpair "sa" src 16))
    ;; the tongue-free spelling: every seated name renders to its neutral
    ;; y<k> symbol and back — the body's code has a spelling no language owns
    (let c-nsym (chpair "nsym" src 64))
    (let c-parity (if (eq (nlx-parity?) 1) 256 0))
    (let c-count (if (eq (nlx-count) 64) 512 0))
    ;; the layer boundaries: the first 3,4,5,7,8,12,13 symbols each close a
    ;; core domain language (structural triad; sequence; discernment;
    ;; existence+joining; first look inside; the list world; language about
    ;; language), and 64 closes the working world.
    (defn nlx-en-at (k) (nth (nth (nlx-rows) k) 1))
    (let c-layers (if (and (str_eq (nlx-en-at 0) "defn")
                      (and (str_eq (nlx-en-at 1) "let")
                      (and (str_eq (nlx-en-at 2) "if")
                      (and (str_eq (nlx-en-at 3) "do")
                      (and (str_eq (nlx-en-at 4) "eq")
                      (and (str_eq (nlx-en-at 6) "cons")
                      (and (str_eq (nlx-en-at 7) "head")
                      (and (str_eq (nlx-en-at 11) "list")
                           (str_eq (nlx-en-at 12) "grammar"))))))))) 1024 0))

    (add c-zh (add c-ar (add c-sa (add c-nsym (add c-parity (add c-count c-layers)))))))
