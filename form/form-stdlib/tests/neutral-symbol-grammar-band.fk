; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/name-lexicon.fk form-stdlib/neutral-symbol-grammar.fk
;
; neutral-symbol-grammar-band.fk — the dictionary emerges from its own grammar.
;
; PROOF LEVEL: FOURTH-ARM ONLY (the entry grammar's cursor walks multibyte
; zh/ar/sa surfaces — the same cross-kernel string-unit seam nl-many-band
; names; the delimiter-walk renderer in name-lexicon-band stays the four-way
; floor). When cursor unit parity opens, this band's roster row is part of
; the acceptance.
;
; Bits: 1 a known line parses to the right row; 2 a parsed row emits back to
; the identical line; 4 EVERY table row survives emit->parse->row identity
; (all 44 — the whole dictionary emerges from its grammar); 8 the emerged
; count equals the table count exactly. Verdict 15.
(do
    (let line "y9 head 首 رأس शिरस् .")
    (let row (nsg-parse-entry line))

    (let c0 (if (and (str_eq (nth row 0) "y9")
                (and (str_eq (nth row 1) "head")
                     (and (str_eq (nth row 2) "首")
                          (and (str_eq (nth row 3) "رأس") (str_eq (nth row 4) "शिरस्"))))) 1 0))
    (let c1 (if (str_eq (nsg-emit-row row) line) 2 0))
    (let c2 (if (eq (nsg-emerged-count) (nlx-count)) 4 0))
    (let c3 (if (eq (nlx-count) 44) 8 0))

    (add c0 (add c1 (add c2 c3))))
