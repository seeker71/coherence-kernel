; form-asm-fam-exp-band — exp(x) END-TO-END as Form->asm BYTES: the first COMPOSED transcendental FUNCTION on
; the native asm lane, four-way + byte-identical to the M4 assembler oracle, no rustc/clang.
;
; Every exp-lane PART was already proven four-way as a standalone program ending in ret — the range reduction
; (fam-exp-reduce: k=round(x*log2e), r=x-k*ln2, #3935), 2^k (fam-pow2, #3940), and the exp(r) Taylor evaluator
; (fam-exp-poly over a self-contained pool, #3941) — but NONE composed into exp itself. fam-exp chains them:
; exp(x) = 2^k * exp(r). It is genuinely NEW instruction shape, not a concatenation — the sub-programs share
; d0/d1/d2 and each ended in ret, so fam-exp re-lays the register allocation to carry k (fcvtzs into x9) and
; 2^k (parked in d3) ACROSS the poly, which clobbers d1,d2:
;   reduce:  x8=log2e; d1=x*log2e; d1=k_float=frintn; x9=k_int=fcvtzs(d1); x8=-ln2; d0=r=fma(d1,-ln2,x)
;   2^k:     x9=k_int+1023; x9<<=52; d3=2^k (fmov-d-x reinterpret) — 2^k parked in d3, survives the poly
;   exp(r):  degree-6 Horner over the pool -> d0=exp(r)  (d1,d2 scratch; d3 untouched)
;   combine: d0 = d0 * d3 = exp(r) * 2^k = exp(x); ret; then the 7-f64 pool
; ABI: d0 = x, returns d0 = exp(x). Accuracy is the poly's on r in [-ln2/2, ln2/2] (|err| < ~1.2e-7) times an
; EXACT 2^k, so the whole exp tracks libm within ~1.2e-7 relative across the finite range (the hardware witness,
; scripts/form_asm_fam_exp_witness.sh). 32 code words + a 56-byte 7-f64 pool = 184 bytes.
;
; The pool offsets are DERIVED from the coefficient count, not hardcoded: the poly sits after a 17-word prologue
; and before a 2-word epilogue (fmul + ret) between its final fmadd and the pool, so relative to standalone
; fam-horner-list (epilogue = just ret) every PC-relative literal-load distance grows by 1 -> LEAD = 2n+1,
; TAIL = 2n+2 (n=7 -> 15/16). Confirmed against the M4 otool oracle: leading ldr d1 = 5c0001e1 (imm19 15),
; every tail ldr d2 = 5c000202 (imm19 16). The pool coefficients are computed by f64-bytes so ANY value fills
; the pool (1/720 = 0x3f56c16c16c16c17, an irregular mantissa no hand pattern writes).
;
; Verdict 7 when every claim lands:
;   1   the composed exp program is 184 bytes (32 code words + a 7-quad pool)         (len == 184)
;   2   the FULL 184-byte program byte-equals the M4 assembler oracle                 (fa-conviction == 1)
;   4   coefficients are DATA — f64-bytes fills the pool with the exp Taylor series    (fa-conviction == 1)
;
; preludes: form-stdlib/format-arith.fk form-stdlib/f64-bytes.fk form-stdlib/form-asm.fk form-stdlib/form-asm-matvec.fk
(do
    (let prog (fam-exp))
    (let oracle (list
        200 95 144 210    104 165 172 242    232 168 194 242    232 254 231 242
        1 1 103 158       1 8 97 30          33 64 100 30       41 0 120 158
        232 61 135 210    72 223 191 242     72 200 197 242     200 252 247 242
        2 1 103 158       32 0 66 31         41 253 15 145      41 45 76 211
        35 1 103 158      225 1 0 92         2 2 0 92           33 8 64 31
        2 2 0 92          33 8 64 31         2 2 0 92           33 8 64 31
        2 2 0 92          33 8 64 31         2 2 0 92           33 8 64 31
        2 2 0 92          32 8 64 31         0 8 99 30          192 3 95 214
        23 108 193 22 108 193 86 63    17 17 17 17 17 17 129 63
        85 85 85 85 85 85 165 63       85 85 85 85 85 85 197 63
        0 0 0 0 0 0 224 63             0 0 0 0 0 0 240 63           0 0 0 0 0 0 240 63))
    (let pool-oracle (list
        23 108 193 22 108 193 86 63    17 17 17 17 17 17 129 63
        85 85 85 85 85 85 165 63       85 85 85 85 85 85 197 63
        0 0 0 0 0 0 224 63             0 0 0 0 0 0 240 63           0 0 0 0 0 0 240 63))
    (let c1 (if (eq (len prog) 184)                                    1 0))
    (let c2 (if (eq (fa-conviction prog oracle)                   1)   2 0))
    (let c3 (if (eq (fa-conviction (fhl-pool (fam-exp-coeffs))
                                   pool-oracle)                   1)   4 0))
    (add c1 (add c2 c3)))
