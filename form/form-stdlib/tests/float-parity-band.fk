; float-parity-band.fk — every even word is an int; floats live on odd words.
;
; Until 2026-07-17 float boxes were EVEN words (fk_fbase - (fp<<1)), so a
; deep-negative int (x < -(2^62-1)/2, tagged word at/below fk_fbase) aliased
; float slot (fk_fbase - 2x)/2 at every kind-dispatched door once the pool
; held that many floats. Witnessed before the heal: after boxing two 7.0s,
; (sub 0 4500000000000000002) PRINTED as 7 and (add a 1) returned the float
; 8.0. The heal moves float boxes to odd words (fk_fbase - (fp<<1) - 1) and
; teaches fk_isf parity — ints (even) can never alias the pool again. The
; odd-negative neighbours stay disjoint by band: nothing = fk_fbase+1, fn
; values ~ -8e18, the tailcall sentinel -7.5e18-1, cons positive-odd.
;
; The float pool is deliberately POPULATED FIRST (f1/f2 = 7.0) so every
; deep-int row below runs with the aliasing window open: a's word lands on
; slot 2 and b's on slot 1 — exactly the pre-heal wound shape. a and b are
; minted INDEPENDENTLY by sub-of-literals (which computes exact regardless),
; so no row compares a wounded door against itself — pre-heal, both operands
; read back as 7.0 and every deep-int row below went red.
;
; Self-contained — kernel verbs only, no preludes. Verdict 255.
(do
    (let f1 7.0)
    (let f2 7.0)
    (let a (sub 0 4500000000000000002))
    (let b (sub 0 4500000000000000001))
    ; c0 — the wound row: add on a deep-negative int stays INT arithmetic.
    ;      Pre-heal, (add a 1) returned the float 8.0, not the int b.
    (let c0 (if (eq (add a 1) b) 1 0))
    ; c1 — adjacent deep ints are not equal (pre-heal both aliased 7.0 and
    ;      compared EQUAL — the Codex-example shape), and order exactly.
    (let c1 (if (eq a b) 0 2))
    (let c2 (if (and (lt a b) (le a b)) 4 0))
    ; c3 — sub stays exact when its INPUTS sit in the (formerly aliased)
    ;      band: pre-heal this computed 7.0 - 7.0 = 0.0, not -1.
    (let c3 (if (eq (sub a b) (sub 0 1)) 8 0))
    ; c4 — floats still box, add, and compare through IEEE.
    (let c4 (if (eq (add 0.5 0.25) 0.75) 16 0))
    ; c5 — mixed int/float still promotes: 2.0 = 2, 1.5 < 2.
    (let c5 (if (and (eq 2.0 2) (lt 1.5 2)) 32 0))
    ; c6 — float division answers float: 7.0/2 = 3.5.
    (let c6 (if (eq (div 7.0 2) 3.5) 64 0))
    ; c7 — the first floats boxed (slots 1-2, the old alias targets) still
    ;      read back as their own values.
    (let c7 (if (and (eq f1 7.0) (eq f2 f1)) 128 0))
    (add (add (add c0 c1) (add c2 c3))
         (add (add c4 c5) (add c6 c7))))
