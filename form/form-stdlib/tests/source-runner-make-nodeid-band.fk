; source-runner-make-nodeid-band.fk -- direct-source make_nodeid carrier lowering.
;
; This pins the temporary C-seed parser repair that lowers `(make_nodeid a b c d)`
; into the list carrier shape already consumed by the runtime evaluator.
;
; Expected: 31

(do
    (let n (make_nodeid 4 3 2 1))
    (let cell (intern_node n (list (intern_trivial_int 7))))
    (let b1 (if (eq (node_pkg n) 4) 1 0))
    (let b2 (if (eq (node_level n) 3) 2 0))
    (let b3 (if (eq (node_type n) 2) 4 0))
    (let b4 (if (eq (node_inst n) 1) 8 0))
    (let b5 (if (node_eq (node_category cell) n) 16 0))
    (add b1 (add b2 (add b3 (add b4 b5)))))
