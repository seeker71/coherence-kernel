; edge-categories-band.fk - edge reputation and reflex-pain shape.
;
; Re-grounded 2026-07-18: the real-source probes originally read four lc-*
; concept pages that live in the Coherence-Network checkout and never
; traveled into this body. The public body carries one concept page —
; lc-satsang-circle — so the real inbound/fanout senses now read it: its
; body mentions lc-trust-over-fear (inbound count 1), and its 11
; cross-refs fan out warm with lc-chakra-column at the head. The
; synthetic category/cluster/pain shapes are unchanged.
;
; preludes: form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/concept-corpus.fk form-stdlib/edge-categories.fk

(do
    ; honest degrade: if the surviving page is absent, one stable verdict.
    (if (eq (fs_exists (concept-source-path "lc-satsang-circle")) 0)
        "edge-categories-band-input-absent"
        (do
    (let category
        (ec-category
            "concept_contains_concept"
            "concept"
            "concept"
            40
            40
            1
            "R_Compose.CROSS_REF(body)"
            "heart/meaning"))

    (let cluster
        (ec-cluster
            "concept:lc-coherence-over-control:concept_contains_concept:inbound"
            "concept_contains_concept"
            "inbound"
            "concept"
            "lc-coherence-over-control"
            40
            40
            1
            (ec-temperature 40)
            "heart/meaning"
            (list "lc-assemblage-point" "lc-bioelectric-pattern")))

    (let pain
        (ec-reflex-pain
            "python"
            "form"
            "observer-first-python"
            "not-surprised"
            "edge-category-sensing"))

    (let real-sources
        (list
            "lc-satsang-circle"))
    (let real-inbound
        (ec-concept-inbound-category
            real-sources
            "lc-trust-over-fear"))
    (let real-fanout
        (ec-concept-cross-ref-fanout-cluster "lc-satsang-circle"))

    (sum
        (list
            (if (ec-category? category) 1 0)
            (if (str_eq (ec-category-name category) "concept_contains_concept") 2 0)
            (if (eq (ec-category-edge-reputation category) 40) 4 0)
            (if (str_eq (ec-category-felt category) "heart/meaning") 8 0)
            (if (ec-cluster? cluster) 16 0)
            (if (str_eq (ec-cluster-temperature cluster) "hot") 32 0)
            (if (eq (len (ec-cluster-examples cluster)) 2) 64 0)
            (if (ec-reflex-pain? pain) 128 0)
            (if (eq (ec-reflex-pain-score-value pain) 100) 256 0)
            (if (str_eq (ec-reflex-pain-temperature-value pain) "hot") 512 0)
            (if (ec-reflex-wants-release? pain) 1024 0)
            (if (str_eq (ec-reflex-release-target pain) "form-substrate-cell") 2048 0)
            (if (eq (ec-category-edge-reputation real-inbound) 1) 4096 0)
            (if (gt (ec-cluster-edge-reputation real-fanout) 5) 8192 0)
            (if (str_eq (ec-cluster-temperature real-fanout) "warm") 16384 0)
            (if (str_eq (head (ec-cluster-examples real-fanout)) "lc-chakra-column") 32768 0)))))
    ; expected verdict 65535 when the synthetic shapes hold and the
    ; satsang-grounded inbound/fanout senses land
    )
