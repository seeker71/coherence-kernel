; form-asm-exp-reduce-band — exp's ARGUMENT RANGE REDUCTION emits four-way as Form->asm BYTES, no rustc.
; The FIRST COMPOSED transcendental step on the native asm lane: every prior brick was a single primitive
; ending in ret (fam-frintn 8 bytes, fam-fmov-bits 8 bytes, fam-rsqrt 16 bytes); this CHAINS a materialized
; constant + fmul + frintn + fmadd into a real function x -> r = x - round(x*log2e)*ln2. exp(x) = 2^k*exp(r)
; with k = round(x*log2e), r in [-ln2/2, ln2/2] (the interval a short Horner poly converges over); this is the
; k-and-r half, the precondition of the exp/softmax lane.
;
; It is the first CONSUMER of two just-landed pieces: fam-fmov-bits' fa-fmov-d-x (#3933, "the last missing
; piece of the exp lane") and the new fa-mov-imm64. clang -O2 does NOT pool these two constants — it
; materializes each f64 bit pattern with movz + 3 movk into x8, then fmov d,x8 (BIT REINTERPRET), so the
; byte-exact path is mov-imm64 -> fmov-d-x, NOT a literal pool. fa-mov-imm64 is the reusable "materialize any
; 64-bit constant" primitive every inlined-constant nonlinear op needs (and the 2^k step: (k+1023)<<52 then
; fmov d,x). fa-movk-x carries the halfword SHIFT as DATA — one encoder for all four positions, so fa-movk-x-16
; is exactly the hw=1 case (core-abstraction-first, no parallel path). Pooling -ln2 lets the reduction use the
; already-proven fa-fmadd (k*(-ln2)+x = x-k*ln2) rather than a new fmsub encoder.
;
; The 14-instruction / 56-byte program, otool -tvVj of the clang -O2 oracle
; (`double reduce(double x){ double k=__builtin_roundeven(x*0x1.71547652b82fep0);
;                            return __builtin_fma(k,-0x1.62e42fefa39efp-1,x); }`):
;   0  d2905fc8 mov x8,#0x82fe   4  f2aca568 movk x8,#0x652b,lsl16   8  f2c2a8e8 movk x8,#0x1547,lsl32
;   c  f2e7fee8 movk x8,#0x3ff7,lsl48   10 9e670101 fmov d1,x8   14 1e610801 fmul d1,d0,d1
;   18 1e644021 frintn d1,d1   1c d2873de8 mov x8,#0x39ef   20 f2bfdf48 movk x8,#0xfefa,lsl16
;   24 f2c5c848 movk x8,#0x2e42,lsl32   28 f2f7fcc8 movk x8,#0xbfe6,lsl48   2c 9e670102 fmov d2,x8
;   30 1f420020 fmadd d0,d1,d2,d0   34 d65f03c0 ret
;
; Verdict 31 when every claim lands:
;   1    the program is 14 instructions = 56 bytes                                      (len == 56)
;   2    the FULL 56-byte program byte-equals the clang -O2 oracle                      (fa-conviction == 1)
;   4    fa-mov-imm64 builds log2e's 16-byte movz+3movk (all four halfwords)            (fa-conviction == 1)
;   8    fa-mov-imm64 builds -ln2's 16-byte image — the SIGN bit flows through f64-bytes (fa-conviction == 1)
;   16   the generic fa-movk-x at hw=1 IS fa-movk-x-16 (shift as DATA, no parallel path) (fa-conviction == 1)
;
; preludes: form-stdlib/format-arith.fk form-stdlib/f64-bytes.fk form-stdlib/form-asm.fk form-stdlib/form-asm-matvec.fk
(do
    (let prog (fam-exp-reduce))
    (let oracle (list
        200 95 144 210    104 165 172 242   232 168 194 242   232 254 231 242
        1 1 103 158       1 8 97 30         33 64 100 30      232 61 135 210
        72 223 191 242    72 200 197 242    200 252 247 242   2 1 103 158
        32 0 66 31        192 3 95 214))
    (let log2e-img (list
        200 95 144 210    104 165 172 242   232 168 194 242   232 254 231 242))
    (let negln2-img (list
        232 61 135 210    72 223 191 242    72 200 197 242    200 252 247 242))
    (let c1 (if (eq (len prog) 56)                                                          1 0))
    (let c2 (if (eq (fa-conviction prog oracle)                                       1)   2 0))
    (let c3 (if (eq (fa-conviction (fa-mov-imm64 8 (f64-bytes 1.4426950408889634))
                                   log2e-img)                                         1)   4 0))
    (let c4 (if (eq (fa-conviction (fa-mov-imm64 8 (f64-bytes -0.6931471805599453))
                                   negln2-img)                                        1)   8 0))
    (let c5 (if (eq (fa-conviction (fa-movk-x 8 25899 1) (fa-movk-x-16 8 25899))      1)  16 0))
    (add c1 (add c2 (add c3 (add c4 c5)))))
