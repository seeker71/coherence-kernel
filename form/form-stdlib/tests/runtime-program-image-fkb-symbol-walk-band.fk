; runtime-program-image-fkb-symbol-walk-band.fk -- Layer 9h6 symbol walk proof.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-attempt-receipt.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-fkb-byte-container.fk form-stdlib/program-image-fkb-byte-file-witness.fk form-stdlib/program-image-fkb-byte-decode.fk form-stdlib/runtime-program-image-fkb-attempt.fk form-stdlib/program-image-symbol-entry.fk form-stdlib/runtime-program-image-fkb-walker-trace.fk form-stdlib/reason-coverage.fk form-stdlib/runtime-program-image-fkb-micro-walker.fk form-stdlib/runtime-program-image-fkb-symbol-walk.fk
;
; Expected: 268435455

(do
    (defn rpswb-score (ok bit) (if ok bit 0))
    (defn rpswb-manifest-has (name)
        (runtime-program-image-fkb-symbol-walk-manifest-has? name (runtime-program-image-fkb-symbol-walk-manifest)))
    (defn rpswb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rpswb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))
    (defn rpswb-none-of? (text needles)
        (if (nil? needles)
            1
            (if (rpswb-has? text (head needles))
                0
                (rpswb-none-of? text (tail needles)))))

    (defn rpswb-source-hash () "sha:src-symbol")
    (defn rpswb-content-hash () "sha:content-symbol")
    (defn rpswb-artifact-path () "cache/symbol.fkb")
    (defn rpswb-other-artifact-path () "cache/other-symbol.fkb")

    (defn rpswb-nodes ()
        (list
            (pif-node-row 1 42 0 0)
            (pif-node-row 1 40 0 0)
            (pif-node-row 1 2 0 0)
            (pif-node-row 3 1 2 0)
            (pif-node-row 1 50 0 0)
            (pif-node-row 1 8 0 0)
            (pif-node-row 4 4 5 0)
            (pif-node-row 1 6 0 0)
            (pif-node-row 1 7 0 0)
            (pif-node-row 42 7 8 0)
            (pif-node-row 1 1 0 0)
            (pif-node-row 2 0 0 0)
            (pif-node-row 5 11 10 0)
            (pif-node-row 1 111 0 0)
            (pif-node-row 1 222 0 0)
            (pif-node-row 6 12 13 14)
            (pif-node-row 99 0 0 0)
            (pif-node-row 3 0 99 0)
            (pif-node-row 3 3 9 0)))
    (defn rpswb-roots ()
        (list 0 3 6 9 15 18 16 17))
    (defn rpswb-duplicate-roots ()
        (list 0 0 3 6 9 15 18 16 17))
    (defn rpswb-table ()
        (pif-table-image (len (rpswb-roots))
                         (rpswb-roots)
                         (len (rpswb-nodes))
                         (rpswb-nodes)
                         0
                         (empty)))
    (defn rpswb-duplicate-root-table ()
        (pif-table-image (len (rpswb-duplicate-roots))
                         (rpswb-duplicate-roots)
                         (len (rpswb-nodes))
                         (rpswb-nodes)
                         0
                         (empty)))
    (defn rpswb-symbol-rows ()
        (list (pif-symbol-row 0 "core/lit42")
              (pif-symbol-row 1 "core/add42")
              (pif-symbol-row 2 "core/sub42")
              (pif-symbol-row 3 "core/mul42")
              (pif-symbol-row 4 "core/choose")
              (pif-symbol-row 5 "core/nested")
              (pif-symbol-row 6 "core/bad-tag")
              (pif-symbol-row 7 "core/bad-child")
              (pif-symbol-row 8 "core/orphan")
              (pif-symbol-row 9 "core/local-lit")))
    (defn rpswb-duplicate-key-symbol-rows ()
        (list (pif-symbol-row 0 "dup")
              (pif-symbol-row 1 "dup")
              (pif-symbol-row 2 "core/sub42")
              (pif-symbol-row 3 "core/mul42")
              (pif-symbol-row 4 "core/choose")
              (pif-symbol-row 5 "core/nested")
              (pif-symbol-row 6 "core/bad-tag")
              (pif-symbol-row 7 "core/bad-child")
              (pif-symbol-row 8 "core/orphan")
              (pif-symbol-row 9 "core/local-lit")))
    (defn rpswb-node-symbol-rows ()
        (list
            (pif-node-symbol-row 0 0 (empty))
            (pif-node-symbol-row 1 9 (empty))
            (pif-node-symbol-row 3 1 (empty))
            (pif-node-symbol-row 6 2 (empty))
            (pif-node-symbol-row 9 3 (empty))
            (pif-node-symbol-row 15 4 (empty))
            (pif-node-symbol-row 16 6 (empty))
            (pif-node-symbol-row 17 7 (empty))
            (pif-node-symbol-row 18 5 (list (pif-symbol-dependency-target 1 3)
                                            (pif-symbol-dependency-target 3 9)))))
    (defn rpswb-symbol-image ()
        (pif-symbol-image 10 (rpswb-symbol-rows) 9 (rpswb-node-symbol-rows)))
    (defn rpswb-duplicate-key-symbol-image ()
        (pif-symbol-image 10 (rpswb-duplicate-key-symbol-rows) 9 (rpswb-node-symbol-rows)))
    (defn rpswb-pif-with (artifact-path content-hash seal-ok table symbol-image)
        (pif-envelope-with-symbols "src/symbol.fk" (rpswb-source-hash) 100
                                   artifact-path content-hash 101
                                   seal-ok table symbol-image))
    (defn rpswb-pif ()
        (rpswb-pif-with (rpswb-artifact-path) (rpswb-content-hash) 1
                        (rpswb-table) (rpswb-symbol-image)))
    (defn rpswb-other-pif ()
        (rpswb-pif-with (rpswb-other-artifact-path) "sha:other-content" 1
                        (rpswb-table) (rpswb-symbol-image)))
    (defn rpswb-invalid-pif ()
        (rpswb-pif-with (rpswb-artifact-path) (rpswb-content-hash) 0
                        (rpswb-table) (rpswb-symbol-image)))
    (defn rpswb-duplicate-key-pif ()
        (rpswb-pif-with (rpswb-artifact-path) (rpswb-content-hash) 1
                        (rpswb-table) (rpswb-duplicate-key-symbol-image)))
    (defn rpswb-duplicate-root-pif ()
        (rpswb-pif-with (rpswb-artifact-path) (rpswb-content-hash) 1
                        (rpswb-duplicate-root-table) (rpswb-symbol-image)))

    (defn rpswb-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rpswb-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rpswb-envelope-for-pif (pif)
        (do
            (let src (rpswb-source-for-pif pif))
            (let fkb (rpswb-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rpswb-envelope () (rpswb-envelope-for-pif (rpswb-pif)))
    (defn rpswb-other-envelope () (rpswb-envelope-for-pif (rpswb-other-pif)))
    (defn rpswb-non-program-envelope ()
        (rale-envelope (pif-source-from-envelope (rpswb-pif))
                       (sad-no-artifact)
                       (rap-act-compile-source)
                       (sac-run-source-compile)
                       "none"
                       ""
                       (rpswb-source-hash)
                       ""
                       (list "selection")
                       (rale-no-retry)
                       (rale-no-compile-output)
                       (rale-status-request-ready)
                       "synthetic-non-program-envelope"))
    (defn rpswb-payload-for-pif (pif)
        (pifbd-payload (pif-envelope-source-path pif)
                       (pif-envelope-source-hash pif)
                       (pif-envelope-source-mtime pif)
                       (pif-envelope-artifact-path pif)
                       (pif-envelope-seal-ok pif)
                       (pif-envelope-table pif)
                       (pif-envelope-symbol-image pif)))
    (defn rpswb-decode-for-pif (pif)
        (pifbd-decoded-row (rpswb-payload-for-pif pif) 123))
    (defn rpswb-admission-for-pif (pif)
        (pifbd-admission (list "runtime-program-image-fkb-symbol-walk-synthetic-admission")
                         (rpswb-decode-for-pif pif)
                         pif
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpswb-admission () (rpswb-admission-for-pif (rpswb-pif)))
    (defn rpswb-other-admission () (rpswb-admission-for-pif (rpswb-other-pif)))
    (defn rpswb-non-admitted-admission ()
        (pifbd-admission (list "non-admitted")
                         (rpswb-decode-for-pif (rpswb-pif))
                         (rpswb-pif)
                         (pifbd-status-investigate)
                         (pifbd-reason-non-ready-witness)))
    (defn rpswb-not-decoded-admission ()
        (pifbd-admission (list "not-decoded")
                         (pifbd-refused-decode 0 (pifbd-reason-bad-magic))
                         (rpswb-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpswb-invalid-pif-admission ()
        (pifbd-admission (list "invalid-pif")
                         (rpswb-decode-for-pif (rpswb-pif))
                         (rpswb-invalid-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpswb-decode-mismatch-admission ()
        (pifbd-admission (list "decode-mismatch")
                         (rpswb-decode-for-pif (rpswb-other-pif))
                         (rpswb-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpswb-duplicate-key-admission ()
        (rpswb-admission-for-pif (rpswb-duplicate-key-pif)))
    (defn rpswb-duplicate-root-admission ()
        (rpswb-admission-for-pif (rpswb-duplicate-root-pif)))

    (defn rpswb-walk (request budget input)
        (rpsw-walk-symbol (rpswb-envelope) (rpswb-admission) request budget input))
    (defn rpswb-walk-key (key budget input)
        (rpswb-walk (pise-request-by-canonical-key key) budget input))
    (defn rpswb-good ()
        (rpswb-walk-key "core/add42" 10 0))
    (defn rpswb-good-resolution () (rpsw-receipt-symbol-resolution (rpswb-good)))
    (defn rpswb-good-micro () (rpsw-receipt-micro-walk (rpswb-good)))
    (defn rpswb-good-trace () (rpsw-receipt-trace (rpswb-good)))
    (defn rpswb-good-request () (rpsw-receipt-symbol-request (rpswb-good)))

    (defn rpswb-resolution-with-pif (resolution pif)
        (pise-resolution pif
                         (pise-resolution-request resolution)
                         (pise-resolution-symbol-id resolution)
                         (pise-resolution-canonical-key resolution)
                         (pise-resolution-symbol-row resolution)
                         (pise-resolution-node-symbol-row resolution)
                         (pise-resolution-dependency-targets resolution)
                         (pise-resolution-entry-index resolution)
                         (pise-resolution-root-node resolution)
                         (pise-resolution-status resolution)
                         (pise-resolution-reason resolution)))
    (defn rpswb-resolution-with-request (resolution request)
        (pise-resolution (pise-resolution-pif resolution)
                         request
                         (pise-resolution-symbol-id resolution)
                         (pise-resolution-canonical-key resolution)
                         (pise-resolution-symbol-row resolution)
                         (pise-resolution-node-symbol-row resolution)
                         (pise-resolution-dependency-targets resolution)
                         (pise-resolution-entry-index resolution)
                         (pise-resolution-root-node resolution)
                         (pise-resolution-status resolution)
                         (pise-resolution-reason resolution)))
    (defn rpswb-micro-copy (micro envelope admission entry root budget input trace)
        (rpmw-receipt-row envelope admission entry root budget input trace
                          (rpmw-receipt-result micro)
                          (rpmw-receipt-status micro)
                          (rpmw-receipt-reason micro)))
    (defn rpswb-trace-copy (trace artifact-path entry-kind entry root budget)
        (rpiwt-trace artifact-path
                     (rpiwt-trace-source-hash trace)
                     (rpiwt-trace-content-hash trace)
                     entry-kind
                     entry
                     root
                     budget
                     (rpiwt-trace-steps-used trace)
                     (rpiwt-trace-output-count trace)
                     (rpiwt-trace-first-value trace)
                     (rpiwt-trace-exit-code trace)
                     (rpiwt-trace-status trace)
                     (rpiwt-trace-stop-reason trace)
                     (rpiwt-trace-detail trace)))
    (defn rpswb-audit-row (resolution micro trace)
        (rpsw-receipt-row (rpswb-envelope)
                          (rpswb-admission)
                          (rpswb-good-request)
                          (rpmw-receipt-step-budget (rpswb-good-micro))
                          (rpmw-receipt-input-value (rpswb-good-micro))
                          resolution
                          micro
                          trace
                          (rpsw-status-trace-produced)
                          "audit"))
    (defn rpswb-audit-reason (resolution micro trace)
        (rpsw-receipt-agreement-reason (rpswb-audit-row resolution micro trace)))
    (defn rpswb-good-audit-reason ()
        (rpswb-audit-reason (rpswb-good-resolution) (rpswb-good-micro) (rpswb-good-trace)))

    (defn rpswb-bit-manifest-1 ()
        (rpswb-score
            (and (eq (rpswb-manifest-has "layer-9h6-symbol-resolved-micro-walk") 1)
            (and (eq (rpswb-manifest-has "consumes-9e-envelope-8h6-admission-and-8h8-symbol-request") 1)
            (and (eq (rpswb-manifest-has "resolves-symbol-before-walk") 1)
            (and (eq (rpswb-manifest-has "symbol-resolution-computed-internally") 1)
            (and (eq (rpswb-manifest-has "runtime-requests-symbol-id-canonical-key-or-id-key") 1)
                 (eq (rpswb-manifest-has "diagnostic-node-request-rejected-for-runtime") 1))))))
            1))
    (defn rpswb-bit-manifest-2 ()
        (rpswb-score
            (and (eq (rpswb-manifest-has "calls-9h5-computed-micro-walker") 1)
            (and (eq (rpswb-manifest-has "only-ready-symbol-resolution-walks") 1)
            (and (eq (rpswb-manifest-has "resolution-micro-walk-and-trace-must-agree") 1)
            (and (eq (rpswb-manifest-has "computed-trace-not-supplied-evidence") 1)
            (and (eq (rpswb-manifest-has "dependency-targets-carried-not-walked") 1)
            (and (eq (rpswb-manifest-has "9g-capability-binding-deferred") 1)
            (and (eq (rpswb-manifest-has "no-raw-entry-runtime-api") 1)
            (and (eq (rpswb-manifest-has "no-supplied-run-or-trace-input") 1)
            (and (eq (rpswb-manifest-has "no-9h3-or-9h4-consumption") 1)
            (and (eq (rpswb-manifest-has "no-table-payload-authority") 1)
            (and (eq (rpswb-manifest-has "no-presentation-lens-authority") 1)
            (and (eq (rpswb-manifest-has "no-artifact-io") 1)
            (and (eq (rpswb-manifest-has "no-generated-table-authority") 1)
            (and (eq (rpswb-manifest-has "no-selector-storage-or-champion-mutation") 1)
                 (eq (rpswb-manifest-has "no-c-seed-growth") 1)))))))))))))))
            2))
    (defn rpswb-bit-version-row ()
        (do
            (let r (rpswb-good))
            (rpswb-score
                (and (str_eq (rpsw-version) "runtime-program-image-fkb-symbol-walk-v1")
                (and (rpsw-receipt? r)
                (and (pise-resolution? (rpsw-receipt-symbol-resolution r))
                (and (rpmw-receipt? (rpsw-receipt-micro-walk r))
                     (rpiwt-trace? (rpsw-receipt-trace r))))))
                4)))
    (defn rpswb-bit-happy-by-id ()
        (do
            (let r (rpswb-walk (pise-request-by-symbol-id 0) 10 0))
            (let t (rpsw-receipt-trace r))
            (rpswb-score
                (and (str_eq (rpsw-receipt-status r) (rpsw-status-trace-produced))
                (and (str_eq (rpsw-receipt-reason r) (rpmw-reason-walk-completed))
                (and (eq (rpiwt-trace-entry-index t) 0)
                (and (eq (rpiwt-trace-root-node t) 0)
                     (eq (rpiwt-trace-first-value t) 42)))))
                8)))
    (defn rpswb-bit-happy-by-key-nonzero ()
        (do
            (let r (rpswb-walk-key "core/add42" 10 0))
            (let resolution (rpsw-receipt-symbol-resolution r))
            (let t (rpsw-receipt-trace r))
            (rpswb-score
                (and (eq (pise-resolution-entry-index resolution) 1)
                (and (eq (pise-resolution-root-node resolution) 3)
                (and (eq (rpiwt-trace-entry-index t) 1)
                (and (eq (rpiwt-trace-root-node t) 3)
                     (eq (rpiwt-trace-first-value t) 42)))))
                16)))
    (defn rpswb-bit-happy-id-key-input ()
        (do
            (let a (rpswb-walk (pise-request-by-symbol-id-key 4 "core/choose") 20 1))
            (let b (rpswb-walk (pise-request-by-symbol-id-key 4 "core/choose") 20 2))
            (rpswb-score
                (and (eq (rpiwt-trace-first-value (rpsw-receipt-trace a)) 111)
                (and (eq (rpiwt-trace-first-value (rpsw-receipt-trace b)) 222)
                     (eq (rpmw-receipt-input-value (rpsw-receipt-micro-walk b)) 2)))
                32)))
    (defn rpswb-bit-nested-and-deps ()
        (do
            (let r (rpswb-walk-key "core/nested" 20 0))
            (let resolution (rpsw-receipt-symbol-resolution r))
            (let deps (pise-resolution-dependency-targets resolution))
            (rpswb-score
                (and (eq (rpiwt-trace-first-value (rpsw-receipt-trace r)) 84)
                (and (eq (len deps) 2)
                (and (eq (pif-symbol-dependency-target-symbol (head deps)) 1)
                     (eq (pif-symbol-dependency-target-node (nth deps 1)) 9))))
                64)))
    (defn rpswb-bit-agreement-fields ()
        (do
            (let r (rpswb-good))
            (let resolution (rpsw-receipt-symbol-resolution r))
            (let micro (rpsw-receipt-micro-walk r))
            (let trace (rpsw-receipt-trace r))
            (rpswb-score
                (and (rpsw-receipt-agrees? r)
                (and (rpsw-pif-matches? (pise-resolution-pif resolution) (pifbd-admission-pif (rpswb-admission)))
                (and (rpsw-request-matches? (pise-resolution-request resolution) (rpsw-receipt-symbol-request r))
                (and (eq (pise-resolution-entry-index resolution) (rpmw-receipt-entry-index micro))
                (and (eq (rpmw-receipt-entry-index micro) (rpiwt-trace-entry-index trace))
                (and (eq (pise-resolution-root-node resolution) (rpmw-receipt-root-node micro))
                (and (eq (rpmw-receipt-root-node micro) (rpiwt-trace-root-node trace))
                (and (eq (rpmw-receipt-step-budget micro) (rpiwt-trace-step-budget trace))
                     (rpsw-trace-fields-match? trace (rpmw-receipt-trace micro))))))))))
                128)))
    (defn rpswb-bit-diagnostic-rejected ()
        (do
            (let r (rpswb-walk (pise-diagnostic-request-by-node 3) 10 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-status r) (rpsw-status-refused))
                (and (str_eq (rpsw-receipt-reason r) (rpsw-reason-diagnostic-node-not-runtime-request))
                (and (rpsw-no-resolution? (rpsw-receipt-symbol-resolution r))
                (and (rpsw-no-micro-walk? (rpsw-receipt-micro-walk r))
                     (not (rpiwt-trace? (rpsw-receipt-trace r)))))))
                256)))
    (defn rpswb-bit-resolution-refusals ()
        (do
            (let malformed (rpswb-walk (list "bad-request") 10 0))
            (let invalid-id (rpswb-walk (pise-request-by-symbol-id 99) 10 0))
            (let empty-key (rpswb-walk (pise-request-by-canonical-key "") 10 0))
            (let missing-key (rpswb-walk (pise-request-by-canonical-key "core/missing") 10 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-reason malformed) (pise-reason-malformed-request))
                (and (str_eq (rpsw-receipt-reason invalid-id) (pise-reason-invalid-symbol-id))
                (and (str_eq (rpsw-receipt-reason empty-key) (pise-reason-empty-canonical-key))
                     (str_eq (rpsw-receipt-reason missing-key) (pise-reason-canonical-key-not-found)))))
                512)))
    (defn rpswb-bit-resolution-investigations ()
        (do
            (let dup-key (rpsw-walk-symbol (rpswb-envelope-for-pif (rpswb-duplicate-key-pif))
                                           (rpswb-duplicate-key-admission)
                                           (pise-request-by-canonical-key "dup") 10 0))
            (let mismatch (rpswb-walk (pise-request-by-symbol-id-key 0 "core/add42") 10 0))
            (let orphan (rpswb-walk (pise-request-by-symbol-id 8) 10 0))
            (let nonroot (rpswb-walk (pise-request-by-symbol-id 9) 10 0))
            (let dup-root (rpsw-walk-symbol (rpswb-envelope-for-pif (rpswb-duplicate-root-pif))
                                            (rpswb-duplicate-root-admission)
                                            (pise-request-by-symbol-id 0) 10 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-reason dup-key) (pise-reason-duplicate-canonical-key))
                (and (str_eq (rpsw-receipt-reason mismatch) (pise-reason-symbol-id-key-mismatch))
                (and (str_eq (rpsw-receipt-reason orphan) (pise-reason-symbol-not-defined-by-node))
                (and (str_eq (rpsw-receipt-reason nonroot) (pise-reason-defined-node-not-function-root))
                     (str_eq (rpsw-receipt-reason dup-root) (pise-reason-duplicate-function-root))))))
                1024)))
    (defn rpswb-bit-envelope-admission-preguards ()
        (do
            (let bad-envelope (rpsw-walk-symbol (list "bad-envelope") (rpswb-admission) (pise-request-by-symbol-id 0) 10 0))
            (let nonprogram (rpsw-walk-symbol (rpswb-non-program-envelope) (rpswb-admission) (pise-request-by-symbol-id 0) 10 0))
            (let bad-admission (rpsw-walk-symbol (rpswb-envelope) (list "bad-admission") (pise-request-by-symbol-id 0) 10 0))
            (let nonadmitted (rpsw-walk-symbol (rpswb-envelope) (rpswb-non-admitted-admission) (pise-request-by-symbol-id 0) 10 0))
            (let notdecoded (rpsw-walk-symbol (rpswb-envelope) (rpswb-not-decoded-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-reason bad-envelope) (rpmw-reason-malformed-envelope))
                (and (str_eq (rpsw-receipt-reason nonprogram) (rpmw-reason-non-program-image-envelope))
                (and (str_eq (rpsw-receipt-reason bad-admission) (rpmw-reason-malformed-admission))
                (and (str_eq (rpsw-receipt-reason nonadmitted) (rpmw-reason-non-admitted-admission))
                     (str_eq (rpsw-receipt-reason notdecoded) (rpmw-reason-admission-decode-not-decoded))))))
                2048)))
    (defn rpswb-bit-decode-identity-preguards ()
        (do
            (let invalidpif (rpsw-walk-symbol (rpswb-envelope) (rpswb-invalid-pif-admission) (pise-request-by-symbol-id 0) 10 0))
            (let mismatch (rpsw-walk-symbol (rpswb-envelope) (rpswb-decode-mismatch-admission) (pise-request-by-symbol-id 0) 10 0))
            (let identity (rpsw-walk-symbol (rpswb-other-envelope) (rpswb-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-reason invalidpif) (rpmw-reason-admission-invalid-pif))
                (and (str_eq (rpsw-receipt-reason mismatch) (rpmw-reason-admission-decode-pif-mismatch))
                     (str_eq (rpsw-receipt-reason identity) (rpmw-reason-artifact-identity-mismatch))))
                4096)))
    (defn rpswb-bit-negative-budget ()
        (do
            (let r (rpswb-walk-key "core/add42" (sub 0 1) 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-status r) (rpsw-status-refused))
                (and (str_eq (rpsw-receipt-reason r) (rpmw-reason-negative-step-budget))
                (and (pise-resolution? (rpsw-receipt-symbol-resolution r))
                     (rpmw-receipt? (rpsw-receipt-micro-walk r)))))
                8192)))
    (defn rpswb-bit-timeout ()
        (do
            (let r (rpswb-walk-key "core/add42" 2 0))
            (let t (rpsw-receipt-trace r))
            (rpswb-score
                (and (str_eq (rpsw-receipt-status r) (rpsw-status-trace-produced))
                (and (str_eq (rpsw-receipt-reason r) (rpmw-reason-step-budget-exhausted))
                (and (str_eq (rpiwt-trace-status t) (rao-obs-timeout))
                     (str_eq (rpiwt-trace-stop-reason t) (rpiwt-stop-timeout)))))
                16384)))
    (defn rpswb-bit-runtime-errors ()
        (do
            (let unsupported (rpswb-walk-key "core/bad-tag" 10 0))
            (let child (rpswb-walk-key "core/bad-child" 10 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-reason unsupported) (rpmw-reason-unsupported-tag))
                (and (str_eq (rpiwt-trace-status (rpsw-receipt-trace unsupported)) (rao-obs-error))
                (and (str_eq (rpsw-receipt-reason child) (rpmw-reason-child-out-of-range))
                     (str_eq (rpiwt-trace-status (rpsw-receipt-trace child)) (rao-obs-error)))))
                32768)))
    (defn rpswb-bit-downstream-trace-compatible ()
        (do
            (let r (rpswb-good))
            (let bridge (rpiwt-bridge-from-trace (rpswb-envelope) (rpswb-admission) (rpsw-receipt-trace r)))
            (rpswb-score
                (and (rpiwt-bridge? bridge)
                (and (str_eq (rpiwt-bridge-status bridge) (rpiwt-status-trace-ready))
                     (str_eq (rpiwt-bridge-reason bridge) (rpiwt-reason-trace-lowered))))
                65536)))
    (defn rpswb-forbidden-needles ()
        (list "rpifa-supplied-run" "rpifa-bridge-from-run"
              "raar-supplied-attempt" "rpiwt-bridge-from-trace"
              "rpsw-walk-after-ready-resolution"
              "rpsw-walk-after-admission-ready"
              "rpiftc-" "rpifc-" "rtta-" ".payload" ".sym"
              "program-image-table-payload-emit" "pif-table-numeric-stream"
              "read_file" "read_file_slice" "write_file" "append_file"
              "remove_file" "fk_run" "form-eval" "dlopen"
              "bp_table" "bpTable" "BP_TABLE"))
    (defn rpswb-bit-static-source ()
        (do
            (let text (rpswb-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-walk.fk"
                                           "../form/form-stdlib/runtime-program-image-fkb-symbol-walk.fk"))
            (rpswb-score (rpswb-none-of? text (rpswb-forbidden-needles)) 131072)))
    (defn rpswb-bit-mirror ()
        (do
            (let text (rpswb-read-file-any "form/form-stdlib/runtime-program-image-fkb-symbol-walk.fk"
                                           "../form/form-stdlib/runtime-program-image-fkb-symbol-walk.fk"))
            (let grammar (rpswb-read-file-any "grammars/runtime-program-image-fkb-symbol-walk.fk"
                                              "../grammars/runtime-program-image-fkb-symbol-walk.fk"))
            (rpswb-score (str_eq text grammar) 262144)))
    (defn rpswb-bit-architecture-receipt ()
        (do
            (let arch (rpswb-read-file-any "../receipts/2026-07-03-core-layer-architecture-map.md"
                                           "receipts/2026-07-03-core-layer-architecture-map.md"))
            (let receipt (rpswb-read-file-any "../receipts/2026-07-04-runtime-program-image-fkb-symbol-walk-layer-review.md"
                                              "receipts/2026-07-04-runtime-program-image-fkb-symbol-walk-layer-review.md"))
            (rpswb-score
                (and (rpswb-has? arch "9h6. Runtime program-image `.fkb` symbol walk")
                (and (rpswb-has? arch "symbol-id/canonical-key/id+key request")
                (and (rpswb-has? receipt "Layer 9h6")
                (and (rpswb-has? receipt "diagnostic-node rejected")
                (and (rpswb-has? receipt "9g remains deferred")
                     (rpswb-has? receipt "table authority rejected"))))))
                524288)))

    (defn rpswb-audit-reasons ()
        (do
            (let resolution (rpswb-good-resolution))
            (let micro (rpswb-good-micro))
            (let trace (rpswb-good-trace))
            (let other-trace (rpswb-trace-copy trace (rpswb-other-artifact-path)
                                               (rpiwt-entry-kind-function-root)
                                               (rpiwt-trace-entry-index trace)
                                               (rpiwt-trace-root-node trace)
                                               (rpiwt-trace-step-budget trace)))
            (let kind-trace (rpswb-trace-copy trace (rpswb-artifact-path)
                                              "not-function-root"
                                              (rpiwt-trace-entry-index trace)
                                              (rpiwt-trace-root-node trace)
                                              (rpiwt-trace-step-budget trace)))
            (let entry-trace (rpswb-trace-copy trace (rpswb-artifact-path)
                                               (rpiwt-entry-kind-function-root)
                                               0
                                               (rpiwt-trace-root-node trace)
                                               (rpiwt-trace-step-budget trace)))
            (let root-trace (rpswb-trace-copy trace (rpswb-artifact-path)
                                              (rpiwt-entry-kind-function-root)
                                              (rpiwt-trace-entry-index trace)
                                              0
                                              (rpiwt-trace-step-budget trace)))
            (let budget-trace (rpswb-trace-copy trace (rpswb-artifact-path)
                                                (rpiwt-entry-kind-function-root)
                                                (rpiwt-trace-entry-index trace)
                                                (rpiwt-trace-root-node trace)
                                                99))
            (list
                (rpsw-receipt-reason (rpswb-walk (pise-diagnostic-request-by-node 3) 10 0))
                (rpswb-audit-reason (list "bad-resolution") micro trace)
                (rpswb-audit-reason (rpswb-resolution-with-pif resolution (rpswb-other-pif)) micro trace)
                (rpswb-audit-reason (rpswb-resolution-with-request resolution (pise-request-by-symbol-id 0)) micro trace)
                (rpswb-audit-reason resolution (list "bad-micro") trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpswb-other-envelope) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       trace)
                                    trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpswb-other-admission)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       trace)
                                    trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) 99 trace)
                                    trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       99 (rpmw-receipt-input-value micro) trace)
                                    trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       0 (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       trace)
                                    trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) 0
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       trace)
                                    trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       (list "bad-trace"))
                                    trace)
                (rpswb-audit-reason resolution micro other-trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       other-trace)
                                    other-trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       kind-trace)
                                    kind-trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       entry-trace)
                                    entry-trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       root-trace)
                                    root-trace)
                (rpswb-audit-reason resolution
                                    (rpswb-micro-copy micro (rpmw-receipt-envelope micro) (rpmw-receipt-admission micro)
                                                       (rpmw-receipt-entry-index micro) (rpmw-receipt-root-node micro)
                                                       (rpmw-receipt-step-budget micro) (rpmw-receipt-input-value micro)
                                                       budget-trace)
                                    budget-trace))))
    (defn rpswb-resolution-reasons ()
        (list
            (pise-resolution-reason (rpswb-good-resolution))
            (rpsw-receipt-reason (rpswb-walk (list "bad-request") 10 0))
            (rpsw-receipt-reason (rpswb-walk (pise-request-by-symbol-id 99) 10 0))
            (rpsw-receipt-reason (rpswb-walk (pise-request-by-canonical-key "") 10 0))
            (rpsw-receipt-reason (rpswb-walk (pise-request-by-canonical-key "core/missing") 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope-for-pif (rpswb-duplicate-key-pif))
                                                   (rpswb-duplicate-key-admission)
                                                   (pise-request-by-canonical-key "dup") 10 0))
            (rpsw-receipt-reason (rpswb-walk (pise-request-by-symbol-id-key 0 "core/add42") 10 0))
            (rpsw-receipt-reason (rpswb-walk (pise-request-by-symbol-id 8) 10 0))
            (rpsw-receipt-reason (rpswb-walk (pise-request-by-symbol-id 9) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope-for-pif (rpswb-duplicate-root-pif))
                                                   (rpswb-duplicate-root-admission)
                                                   (pise-request-by-symbol-id 0) 10 0))))
    (defn rpswb-walk-reasons ()
        (list
            (rpsw-receipt-reason (rpswb-good))
            (rpsw-receipt-reason (rpswb-walk-key "core/add42" 2 0))
            (rpsw-receipt-reason (rpswb-walk-key "core/bad-tag" 10 0))
            (rpsw-receipt-reason (rpswb-walk-key "core/bad-child" 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (list "bad-envelope") (rpswb-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-non-program-envelope) (rpswb-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope) (list "bad-admission") (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope) (rpswb-non-admitted-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope) (rpswb-not-decoded-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope) (rpswb-invalid-pif-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-envelope) (rpswb-decode-mismatch-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpsw-walk-symbol (rpswb-other-envelope) (rpswb-admission) (pise-request-by-symbol-id 0) 10 0))
            (rpsw-receipt-reason (rpswb-walk-key "core/add42" (sub 0 1) 0))))
    (defn rpswb-observed-reasons ()
        (append (rpswb-audit-reasons)
                (append (rpswb-resolution-reasons)
                        (rpswb-walk-reasons))))
    (defn rpswb-bit-reason-coverage ()
        (do
            (let coverage (rcov-coverage (rpsw-reason-manifest) (rpswb-observed-reasons)))
            (rpswb-score (rcov-covered? coverage) 1048576)))
    (defn rpswb-bit-resolution-failure-no-walk ()
        (do
            (let r (rpswb-walk (pise-request-by-symbol-id 99) 10 0))
            (rpswb-score
                (and (pise-resolution? (rpsw-receipt-symbol-resolution r))
                (and (rpsw-no-micro-walk? (rpsw-receipt-micro-walk r))
                     (not (rpiwt-trace? (rpsw-receipt-trace r)))))
                2097152)))
    (defn rpswb-bit-resolution-failure-carries-reason ()
        (do
            (let r (rpswb-walk (pise-request-by-symbol-id-key 0 "core/add42") 10 0))
            (let resolution (rpsw-receipt-symbol-resolution r))
            (rpswb-score
                (and (str_eq (pise-resolution-status resolution) (pise-status-investigate))
                (and (str_eq (pise-resolution-reason resolution) (pise-reason-symbol-id-key-mismatch))
                     (str_eq (rpsw-receipt-reason r) (pise-reason-symbol-id-key-mismatch))))
                4194304)))
    (defn rpswb-bit-audit-defensive-1 ()
        (do
            (let reasons (rpswb-audit-reasons))
            (rpswb-score
                (and (rcov-member? (rpsw-reason-malformed-symbol-resolution) reasons)
                (and (rcov-member? (rpsw-reason-resolution-pif-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-resolution-request-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-malformed-micro-walk-receipt) reasons)
                (and (rcov-member? (rpsw-reason-micro-walk-envelope-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-micro-walk-admission-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-micro-walk-input-mismatch) reasons)
                     (rcov-member? (rpsw-reason-micro-walk-budget-mismatch) reasons))))))))
                8388608)))
    (defn rpswb-bit-audit-defensive-2 ()
        (do
            (let reasons (rpswb-audit-reasons))
            (rpswb-score
                (and (rcov-member? (rpsw-reason-micro-walk-entry-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-micro-walk-root-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-micro-walk-trace-malformed) reasons)
                (and (rcov-member? (rpsw-reason-micro-walk-trace-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-trace-identity-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-trace-entry-kind-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-trace-entry-mismatch) reasons)
                (and (rcov-member? (rpsw-reason-trace-root-mismatch) reasons)
                     (rcov-member? (rpsw-reason-trace-budget-mismatch) reasons)))))))))
                16777216)))
    (defn rpswb-bit-preserves-nested-status-reason ()
        (do
            (let timeout (rpswb-walk-key "core/add42" 2 0))
            (let unsupported (rpswb-walk-key "core/bad-tag" 10 0))
            (let bad-budget (rpswb-walk-key "core/add42" (sub 0 1) 0))
            (rpswb-score
                (and (str_eq (rpsw-receipt-status timeout) (rpmw-receipt-status (rpsw-receipt-micro-walk timeout)))
                (and (str_eq (rpsw-receipt-reason timeout) (rpmw-receipt-reason (rpsw-receipt-micro-walk timeout)))
                (and (str_eq (rpsw-receipt-reason unsupported) (rpmw-receipt-reason (rpsw-receipt-micro-walk unsupported)))
                     (str_eq (rpsw-receipt-reason bad-budget) (rpmw-receipt-reason (rpsw-receipt-micro-walk bad-budget))))))
                33554432)))
    (defn rpswb-bit-no-fake-output-on-failure ()
        (do
            (let timeout (rpsw-receipt-trace (rpswb-walk-key "core/add42" 2 0)))
            (let unsupported (rpsw-receipt-trace (rpswb-walk-key "core/bad-tag" 10 0)))
            (rpswb-score
                (and (eq (rpiwt-trace-output-count timeout) 0)
                (and (eq (rpiwt-trace-first-value timeout) 0)
                (and (eq (rpiwt-trace-output-count unsupported) 0)
                     (eq (rpiwt-trace-first-value unsupported) 0))))
                67108864)))
    (defn rpswb-bit-request-surface ()
        (rpswb-score
            (and (str_eq (pise-request-mode (pise-request-by-symbol-id 0)) (pise-mode-symbol-id))
            (and (str_eq (pise-request-mode (pise-request-by-canonical-key "core/add42")) (pise-mode-canonical-key))
            (and (str_eq (pise-request-mode (pise-request-by-symbol-id-key 1 "core/add42")) (pise-mode-id-key))
            (and (str_eq (pise-request-mode (pise-diagnostic-request-by-node 3)) (pise-mode-diagnostic-node))
                 (eq (rpswb-manifest-has "no-raw-entry-runtime-api") 1)))))
            134217728))

    (defn runtime-program-image-fkb-symbol-walk-band ()
        (sum (list
            (rpswb-bit-manifest-1)
            (rpswb-bit-manifest-2)
            (rpswb-bit-version-row)
            (rpswb-bit-happy-by-id)
            (rpswb-bit-happy-by-key-nonzero)
            (rpswb-bit-happy-id-key-input)
            (rpswb-bit-nested-and-deps)
            (rpswb-bit-agreement-fields)
            (rpswb-bit-diagnostic-rejected)
            (rpswb-bit-resolution-refusals)
            (rpswb-bit-resolution-investigations)
            (rpswb-bit-envelope-admission-preguards)
            (rpswb-bit-decode-identity-preguards)
            (rpswb-bit-negative-budget)
            (rpswb-bit-timeout)
            (rpswb-bit-runtime-errors)
            (rpswb-bit-downstream-trace-compatible)
            (rpswb-bit-static-source)
            (rpswb-bit-mirror)
            (rpswb-bit-architecture-receipt)
            (rpswb-bit-reason-coverage)
            (rpswb-bit-resolution-failure-no-walk)
            (rpswb-bit-resolution-failure-carries-reason)
            (rpswb-bit-audit-defensive-1)
            (rpswb-bit-audit-defensive-2)
            (rpswb-bit-preserves-nested-status-reason)
            (rpswb-bit-no-fake-output-on-failure)
            (rpswb-bit-request-surface))))

    (runtime-program-image-fkb-symbol-walk-band))
