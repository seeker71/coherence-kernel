; source-artifact-proof-band.fk -- Layer 8f proof receipt witness.
;
; Expected: 2147483647
;
; This band proves proof receipt admission over a sealed native dylib identity.
; It does not prove dlopen, dlsym, native execution, callable admission, binary
; file hashing, compiler emission, cache writes, route ownership, selector
; installation, source-runner admission, or C seed growth.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/sha256.fk form/form-stdlib/hex.fk form/form-stdlib/hmac-sha256.fk form/form-stdlib/form-fs.fk form/form-stdlib/source-artifact-cache.fk form/form-stdlib/source-artifact-descriptor.fk form/form-stdlib/runtime-artifact-plan.fk form/form-stdlib/source-artifact-probe.fk form/form-stdlib/source-artifact-identity.fk form/form-stdlib/source-artifact-seal.fk form/form-stdlib/source-artifact-proof.fk

(do
    (defn saprb-score (ok bit) (if ok bit 0))
    (defn saprb-manifest-has (name)
        (source-artifact-proof-manifest-has? name (source-artifact-proof-manifest)))
    (defn saprb-key () (sai-string-bytes "seal-key"))
    (defn saprb-source-hash ()
        "sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    (defn saprb-fkb-hash ()
        "sha256:573dbb57d6af3d54263620b016da6212869e4aadb8a867ad9d78ba2b15cba1d1")
    (defn saprb-dylib-hash ()
        "sha256:6ca4c50d821f7f130312f82d37d2d8062256f9dcc0db409fd7323651167069b3")
    (defn saprb-dylib-seal ()
        "hmac-sha256:379bc7bcaaa870931e3f60218dfb64e5ad43e26236259141d222a46f7d9269c9")
    (defn saprb-source-vouch ()
        (sai-vouch-source-bytes "src/kernel.fk" (saprb-source-hash) (list 97 98 99)))
    (defn saprb-source-vouch-bad ()
        (sai-vouch-source-bytes "src/kernel.fk" "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" (list 97 98 99)))
    (defn saprb-dylib-vouch ()
        (sai-vouch-content-bytes "src/kernel.dylib" (saprb-dylib-hash) (sai-string-bytes "dylib")))
    (defn saprb-dylib-vouch-bad ()
        (sai-vouch-content-bytes "src/kernel.dylib" (saprb-fkb-hash) (sai-string-bytes "dylib")))
    (defn saprb-fkb-vouch ()
        (sai-vouch-content-bytes "src/kernel.fkb" (saprb-fkb-hash) (sai-string-bytes "fkb")))
    (defn saprb-dylib-seal-row ()
        (sas-native-dylib-seal "src/kernel.dylib" (saprb-source-vouch) (saprb-dylib-vouch) 1 (saprb-key) (saprb-dylib-seal)))
    (defn saprb-dylib-seal-bad ()
        (sas-native-dylib-seal "src/kernel.dylib" (saprb-source-vouch) (saprb-dylib-vouch) 1 (sai-string-bytes "other-key") (saprb-dylib-seal)))
    (defn saprb-dylib-seal-paired-to-other-hash ()
        (sas-seal-row (sad-kind-native-dylib)
                      (sad-version-native-dylib)
                      "src/kernel.dylib"
                      (sas-key-evidence-supplied-bytes)
                      (sai-status-match)
                      (sai-status-match)
                      "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
                      (saprb-dylib-hash)
                      (saprb-dylib-seal)
                      (saprb-dylib-seal)
                      (sas-status-match)
                      1))
    (defn saprb-receipt ()
        (sapr-proof-receipt (sad-kind-native-dylib)
                            (sad-version-native-dylib)
                            "src/kernel.dylib"
                            (saprb-source-hash)
                            (saprb-dylib-hash)
                            (saprb-dylib-seal)
                            1
                            "lowering-parity"
                            "receipt-band"
                            "recipe-dylib-band:pass"
                            "recipe-dylib-band:pass"
                            1
                            1))
    (defn saprb-proof ()
        (sapr-admit-proof (saprb-receipt) (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row)))

    (defn saprb-bit-manifest-1 ()
        (sum (list
            (saprb-score (eq (saprb-manifest-has "proof-receipt-validation") 1) 1)
            (saprb-score (eq (saprb-manifest-has "proof-is-receipt-not-native-exec") 1) 2)
            (saprb-score (eq (saprb-manifest-has "consumes-sai-vouch-status") 1) 4)
            (saprb-score (eq (saprb-manifest-has "consumes-sas-seal-status") 1) 8)
            (saprb-score (eq (saprb-manifest-has "native-dylib-proof-only") 1) 16)
            (saprb-score (eq (saprb-manifest-has "proof-receipt-validated-sets-proof") 1) 32)
            (saprb-score (eq (saprb-manifest-has "callable-left-untouched") 1) 64)
            (saprb-score (eq (saprb-manifest-has "lowerable-left-untouched") 1) 128)
            (saprb-score (eq (saprb-manifest-has "length-prefixed-proof-message-v1") 1) 256)
            (saprb-score (eq (saprb-manifest-has "structural-not-signature") 1) 512)
            (saprb-score (eq (saprb-manifest-has "no-native-execution") 1) 1024))))

    (defn saprb-bit-manifest-2 ()
        (sum (list
            (saprb-score (eq (saprb-manifest-has "no-callable-admission") 1) 2048)
            (saprb-score (eq (saprb-manifest-has "no-binary-file-hash") 1) 4096)
            (saprb-score (eq (saprb-manifest-has "read-file-bytes-not-checkout-witness") 1) 8192)
            (saprb-score (eq (saprb-manifest-has "no-artifact-load") 1) 16384)
            (saprb-score (eq (saprb-manifest-has "no-runtime-selector") 1) 32768)
            (saprb-score (eq (saprb-manifest-has "no-compiler-emission") 1) 65536)
            (saprb-score (eq (saprb-manifest-has "no-cache-write") 1) 131072)
            (saprb-score (eq (saprb-manifest-has "no-sac-route-fork") 1) 262144)
            (saprb-score (eq (saprb-manifest-has "no-source-runner-admission-change") 1) 524288)
            (saprb-score (eq (saprb-manifest-has "no-c-seed-growth") 1) 1048576))))

    (defn saprb-bit-message ()
        (do
            (let r (saprb-receipt))
            (let m (sapr-receipt-message r))
            (let c1 (sapr-proof-message-v1 "ab" "c" "p" "s" "h" "seal" 1 "pk" "wk" "ok" "ok" 1 1))
            (let c2 (sapr-proof-message-v1 "a" "bc" "p" "s" "h" "seal" 1 "pk" "wk" "ok" "ok" 1 1))
            (saprb-score
                (and (str_eq (substring m 0 7) "7:sapr-")
                     (not (str_eq c1 c2)))
                2097152)))
    (defn saprb-bit-match ()
        (do
            (let p (saprb-proof))
            (saprb-score
                (and (str_eq (sapr-proof-status p) (sapr-status-match))
                     (eq (sapr-proof-ok-bit p) 1))
                4194304)))
    (defn saprb-bit-negatives ()
        (do
            (let mismatch (sapr-admit-proof
                (sapr-proof-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saprb-source-hash) (saprb-dylib-hash) (saprb-dylib-seal) 1 "lowering-parity" "receipt-band" "expected" "actual" 1 1)
                (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row)))
            (let insufficient (sapr-admit-proof
                (sapr-proof-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saprb-source-hash) (saprb-dylib-hash) (saprb-dylib-seal) 1 "lowering-parity" "receipt-band" "ok" "ok" 2 1)
                (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row)))
            (let unsealed (sapr-admit-proof (saprb-receipt) (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-bad)))
            (let unvouched-source (sapr-admit-proof (saprb-receipt) (saprb-source-vouch-bad) (saprb-dylib-vouch) (saprb-dylib-seal-row)))
            (let unvouched-content (sapr-admit-proof (saprb-receipt) (saprb-source-vouch) (saprb-dylib-vouch-bad) (saprb-dylib-seal-row)))
            (let malformed (sapr-admit-proof
                (sapr-proof-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" "sha256:ABC" (saprb-dylib-hash) (saprb-dylib-seal) 1 "lowering-parity" "receipt-band" "ok" "ok" 1 1)
                (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row)))
            (let hash-pairing (sapr-admit-proof
                (saprb-receipt)
                (saprb-source-vouch)
                (saprb-dylib-vouch)
                (saprb-dylib-seal-paired-to-other-hash)))
            (let bad-bit (sapr-admit-proof
                (sapr-proof-receipt (sad-kind-native-dylib) (sad-version-native-dylib) "src/kernel.dylib" (saprb-source-hash) (saprb-dylib-hash) (saprb-dylib-seal) 2 "lowering-parity" "receipt-band" "ok" "ok" 1 1)
                (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row)))
            (let refused (sapr-admit-proof
                (sapr-proof-receipt (sad-kind-program-image-fkb) (sad-version-program-image-fkb) "src/kernel.fkb" (saprb-source-hash) (saprb-fkb-hash) (saprb-dylib-seal) 1 "lowering-parity" "receipt-band" "ok" "ok" 1 1)
                (saprb-source-vouch) (saprb-fkb-vouch) (saprb-dylib-seal-row)))
            (saprb-score
                (and (str_eq (sapr-proof-status mismatch) (sapr-status-mismatch))
                     (and (str_eq (sapr-proof-status insufficient) (sapr-status-insufficient-witness))
                          (and (str_eq (sapr-proof-status unsealed) (sapr-status-unsealed))
                                    (and (str_eq (sapr-proof-status unvouched-source) (sapr-status-unvouched))
                                        (and (str_eq (sapr-proof-status unvouched-content) (sapr-status-unvouched))
                                         (and (str_eq (sapr-proof-status malformed) (sapr-status-malformed))
                                              (and (str_eq (sapr-proof-status hash-pairing) (sapr-status-mismatch))
                                                   (and (str_eq (sapr-proof-status bad-bit) (sapr-status-malformed))
                                                        (str_eq (sapr-proof-status refused) (sapr-status-role-refused)))))))))
                8388608)))
    (defn saprb-bit-field-sensitivity ()
        (do
            (let r (saprb-receipt))
            (let base (sapr-receipt-message r))
            (let kind (sapr-proof-message-v1 "native-dylib-x" (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let path (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) "src/other.dylib" (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let source (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let content (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (saprb-fkb-hash) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let seal (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) "hmac-sha256:67be7f4549fb6d950a6bd4bf335a5e140898dd16488f2ffed695266119c74d92" (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let proof-kind (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) "other-proof" (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let witness-kind (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) "other-witness" (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let expected (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) "other-result" (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let actual (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) "other-result" (sapr-receipt-min-witnesses r) (sapr-receipt-witness-count r)))
            (let min (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) 2 (sapr-receipt-witness-count r)))
            (let count (sapr-proof-message-v1 (sapr-receipt-kind r) (sapr-receipt-version r) (sapr-receipt-path r) (sapr-receipt-source-hash r) (sapr-receipt-content-hash r) (sapr-receipt-seal-value r) (sapr-receipt-artifact-bit r) (sapr-receipt-proof-kind r) (sapr-receipt-witness-kind r) (sapr-receipt-expected-result r) (sapr-receipt-actual-result r) (sapr-receipt-min-witnesses r) 2))
            (saprb-score
                (and (not (str_eq base kind))
                     (and (not (str_eq base path))
                          (and (not (str_eq base source))
                               (and (not (str_eq base content))
                                    (and (not (str_eq base seal))
                                         (and (not (str_eq base proof-kind))
                                              (and (not (str_eq base witness-kind))
                                                   (and (not (str_eq base expected))
                                                        (and (not (str_eq base actual))
                                                             (and (not (str_eq base min))
                                                                  (not (str_eq base count))))))))))))
                16777216)))
    (defn saprb-bit-enrichment-matrix ()
        (do
            (let ok (saprb-proof))
            (let bad (sapr-admit-proof (saprb-receipt) (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-bad)))
            (let obs-ok (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row) ok 0 1))
            (let obs-bad (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-bad) bad 0 1))
            (saprb-score
                (and (eq (sap-observation-proof obs-ok) 1)
                     (and (eq (sap-observation-callable obs-ok) 0)
                          (and (eq (sap-observation-lowerable obs-ok) 1)
                               (eq (sap-observation-proof obs-bad) 0))))
                33554432)))
    (defn saprb-bit-no-native-admission ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (saprb-source-hash)))
            (let fkb (sap-program-image-fkb-observation "src/kernel.fkb" 1 3 101 (saprb-source-hash) (saprb-fkb-hash) 1 1))
            (let dylib (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row) (saprb-proof) 0 1))
            (let p (sap-plan-from-probe (sap-bundle source fkb dylib)))
            (saprb-score
                (and (str_eq (rap-plan-primary p) (rap-act-run-program-image))
                     (not (str_eq (rap-plan-primary p) (rap-act-run-native))))
                67108864)))
    (defn saprb-bit-mtime-insensitive ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (saprb-source-hash)))
            (let fkb (sap-program-image-fkb-observation "src/kernel.fkb" 1 3 101 (saprb-source-hash) (saprb-fkb-hash) 1 1))
            (let fresh (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row) (saprb-proof) 0 1))
            (let stale (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 99 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row) (saprb-proof) 0 1))
            (let p-fresh (sap-plan-from-probe (sap-bundle source fkb fresh)))
            (let p-stale (sap-plan-from-probe (sap-bundle source fkb stale)))
            (saprb-score
                (and (str_eq (sapr-proof-status (saprb-proof)) (sapr-status-match))
                     (and (not (str_eq (rap-plan-primary p-fresh) (rap-act-run-native)))
                          (not (str_eq (rap-plan-primary p-stale) (rap-act-run-native)))))
                134217728)))
    (defn saprb-bit-proof-does-not-set-callable ()
        (do
            (let obs (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row) (saprb-proof) 0 0))
            (saprb-score
                (and (eq (sap-observation-proof obs) 1)
                     (and (eq (sap-observation-callable obs) 0)
                          (eq (sap-observation-lowerable obs) 0)))
                268435456)))
    (defn saprb-bit-fkb-proof-refused ()
        (do
            (let refused (sapr-admit-proof
                (sapr-proof-receipt (sad-kind-program-image-fkb) (sad-version-program-image-fkb) "src/kernel.fkb" (saprb-source-hash) (saprb-fkb-hash) (saprb-dylib-seal) 1 "lowering-parity" "receipt-band" "ok" "ok" 1 1)
                (saprb-source-vouch) (saprb-fkb-vouch) (saprb-dylib-seal-row)))
            (saprb-score
                (str_eq (sapr-proof-status refused) (sapr-status-role-refused))
                536870912)))
    (defn saprb-bit-native-requires-callable-later ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (saprb-source-hash)))
            (let fkb (sap-program-image-fkb-observation "src/kernel.fkb" 1 3 101 (saprb-source-hash) (saprb-fkb-hash) 1 1))
            (let callable-dylib (sapr-native-dylib-observation-from-proof "src/kernel.dylib" 1 5 102 (saprb-source-vouch) (saprb-dylib-vouch) (saprb-dylib-seal-row) (saprb-proof) 1 1))
            (let p (sap-plan-from-probe (sap-bundle source fkb callable-dylib)))
            (saprb-score
                (str_eq (rap-plan-primary p) (rap-act-run-native))
                1073741824)))

    (defn source-artifact-proof-band ()
        (sum (list
            (saprb-bit-manifest-1)
            (saprb-bit-manifest-2)
            (saprb-bit-message)
            (saprb-bit-match)
            (saprb-bit-negatives)
            (saprb-bit-field-sensitivity)
            (saprb-bit-enrichment-matrix)
            (saprb-bit-no-native-admission)
            (saprb-bit-mtime-insensitive)
            (saprb-bit-proof-does-not-set-callable)
            (saprb-bit-fkb-proof-refused)
            (saprb-bit-native-requires-callable-later))))

    (source-artifact-proof-band))
