; import "../form-cli-inquiry.fk"
; Process 2: reload learned state; distinguish node/unknown/timeout/miss.
; [[learned ack,reason], [unknown ack,reason], [timeout ack,reason],
;  [ordinary miss ack,reason], computed-edge-count]
; witnessed: 2026-07-22 ->
; [[[1,8,5],0],[nothing,1],[nothing,2],[0,0],11]
(do
  (let learned (fci-requires 8 5 100))
  (let unknown (fci-requires 99 5 100))
  (let timeout (fci-requires 8 5 0))
  (let miss (fci-requires 8 6 100))
  (list (list (fci-ack learned) (fci-reason learned))
        (list (fci-ack unknown) (fci-reason unknown))
        (list (fci-ack timeout) (fci-reason timeout))
        (list (fci-ack miss) (fci-reason miss))
        (len (fci-edges))))
