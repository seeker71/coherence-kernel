; substrate-write.fk — exercise the substrate-write natives from Form.
;
; The kernel now exposes 8 natives that let Form code construct AND walk
; recipes — closing gaps W1-W3 from form-runtime-in-form. This file
; demonstrates each surface and returns an aggregate integer that both
; kernels must agree on.
;
; Surfaces under test:
;   make_nodeid            — construct a raw NodeID
;   intern_trivial_int     — int → trivial NodeID
;   intern_node            — (category, children-list) → composite NodeID
;   walk_recipe            — evaluate a NodeID, return its value
;   node_category          — read a composite's category
;   node_children          — read a composite's children
;   node_value             — decode a trivial leaf

(do
    ;; --- Category constants (from kernel substrate numbering) ---------
    ;; Level=2 (BASIC), Type=12 (MATH), Type=13 (COMPARE)
    (let math-plus  (make_nodeid 1 2 12 1))   ; MATH.PLUS
    (let math-mul   (make_nodeid 1 2 12 3))   ; MATH.MULTIPLY

    ;; --- Test 1: build (1 + 2) from Form, walk it, expect 3 ----------
    (let one   (intern_trivial_int 1))
    (let two   (intern_trivial_int 2))
    (let plus-recipe (intern_node math-plus (list one two)))
    (let r1    (walk_recipe plus-recipe))       ; expected 3

    ;; --- Test 2: build (3 * 4) from Form, walk, expect 12 ------------
    (let three (intern_trivial_int 3))
    (let four  (intern_trivial_int 4))
    (let mul-recipe (intern_node math-mul (list three four)))
    (let r2    (walk_recipe mul-recipe))        ; expected 12

    ;; --- Test 3: content-addressing — building (1+2) twice yields
    ;;     the same NodeID. Verify by comparing the inst slots
    ;;     (node_value would error on composites, so we compare
    ;;     by walking node_category which is trivially equal). -----
    (let plus-recipe-2 (intern_node math-plus (list (intern_trivial_int 1)
                                                     (intern_trivial_int 2))))
    ;; If content-addressing works, plus-recipe and plus-recipe-2 are
    ;; the SAME NodeID. Walk both, results are equal.
    (let r3    (walk_recipe plus-recipe-2))     ; expected 3 (same recipe!)

    ;; --- Test 4: introspect — read the children of plus-recipe and
    ;;     walk each, summing the results. Should be 1 + 2 = 3. ----
    (let kids  (node_children plus-recipe))
    (let r4    (add (walk_recipe (head kids))
                    (walk_recipe (head (tail kids)))))  ; expected 3

    ;; --- Test 5: deeper composition — build ((1 + 2) * 3),
    ;;     walk, expect 9 -----------------------------------------
    (let nested (intern_node math-mul (list plus-recipe three)))
    (let r5    (walk_recipe nested))            ; expected 9

    ;; --- Aggregate: 3 + 12 + 3 + 3 + 9 = 30 ---------------------------
    (add r1 (add r2 (add r3 (add r4 r5)))))
