; tests/flatten-pool-marker-band.fk — the pool keeps marker-colliding literals.
;
; preludes: form-stdlib/form-parse.fk form-stdlib/form-flatten.fk
;
; The wound this band locks shut (witnessed 2026-07-17): dicts ride on plain
; lists tagged with the string "__dict__", and the tag is IN-BAND — any list
; may carry that string as ordinary data. The flatten string pool does: the
; moment flt-scan interns the "__dict__" literal (fourth-shim.fk's _dict_new
; carries one), the pool's suffix at that cell is a one-element list whose
; head is the marker. A kernel whose `len` sniffs the marker (Python len(d)
; pair-count sugar) reads that suffix as EMPTY — flt-append's
; (eq (len xs) 0) base case then REPLACES the marker cell with the next
; literal instead of appending past it, and "__dict__" silently vanishes
; from the pool. Every emitted carrier then holds an orphan slit row
; (24 -1 0 0) where the literal's pool index should be: telecom calls data
; that the channel mistakes for its own control signal "falsing", and this
; was exactly that, one layer down.
;
; The law: `len` is an HONEST cell count on every arm; dict pair-count is
; the python-adapter's _len (underscore family, beside _get/_iter/_in).
; This band proves both faces four-way — and its own source carries the
; "__dict__" literal through the fks pool, so a relapsing kernel fails it
; twice: once by verdict, once by flattening this very table wrong.
;
; Band verdict 31 when the pool holds:
;   1   len is honest: the one-cell marker list has length 1, not 0 pairs
;   2   flt-append appends PAST an interned marker instead of replacing it
;   4   flt-pool-add dedup still lands: the marker pools once, at its index
;   8   flt-src-pool of source code carrying the marker literal pools it
;       (the exact _dict_new wound shape: marker first, another literal after)
;   16  _len answers the python lane: dict PAIRS through the tag, honest
;       cells on a plain list

(do
    ; ── 1: honest len on the marker-headed one-cell list ──
    (let marker-only (cons "__dict__" (empty)))
    (let c0 (if (eq (len marker-only) 1) 1 0))

    ; ── 2: flt-append walks past the marker cell ──
    (let walked (flt-append (flt-append (flt-append (list) "a") "__dict__") "b"))
    (let c1 (if (and (eq (len walked) 3)
                 (and (str_eq (nth walked 1) "__dict__")
                      (str_eq (nth walked 2) "b")))
                2 0))

    ; ── 4: flt-pool-add dedup keeps one marker at a stable index ──
    (let pool (flt-pool-add (flt-pool-add (flt-pool-add (list) "__dict__") "x") "__dict__"))
    (let c2 (if (and (eq (len pool) 2)
                 (and (eq (flt-sidx pool "__dict__" 0) 0)
                      (eq (flt-sidx pool "x" 0) 1)))
                4 0))

    ; ── 8: the wound shape — source code interning the marker, then more ──
    (let src-pool (flt-src-pool "(defn d () (cons \"__dict__\" (empty))) (d \"tail-lit\")"))
    (let c3 (if (and (eq (flt-sidx src-pool "__dict__" 0) 0)
                     (eq (flt-sidx src-pool "tail-lit" 0) 1))
                8 0))

    ; ── 16: _len carries the python lane's pair count; lists stay cells ──
    (let dict-one-pair (cons "__dict__" (cons "a" (cons 1 (empty)))))
    (let c4 (if (and (eq (_len dict-one-pair) 1)
                 (and (eq (_len marker-only) 0)
                      (eq (_len (list 1 2 3)) 3)))
                16 0))

    ;; Band verdict: 31 when the pool never loses a marker-colliding literal.
    (add c0 (add c1 (add c2 (add c3 c4)))))
