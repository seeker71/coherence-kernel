; tests/http-parse-band.fk — HTTP/1.1 lexer sibling-witness band.
;
; preludes: form-stdlib/kernel-http.fk form-stdlib/http-parse.fk
;
; Validates that the Form-recipe HTTP/1.1 lexer (in form-stdlib/http-parse.fk)
; walks the wire bytes into the request's PARTS — method, full path (query still
; attached), the headers already as kh-header values, the body — across every
; kernel that carries the string natives. The lexer interns nothing: it builds
; values with string ops alone, so there is no substrate node and the band
; crosses four-way (Go/Rust/TS + the emitted fkwu arm).
;
; Three vectors — one per shape variant:
;   - minimal request (no headers, no body)
;   - request with body
;   - multi-header request (and a query string on the request-target)
;
; Each assertion compares a deterministic int or a string against the expected
; literal. Eleven checks; band verdict is 11 when every kernel lexes every
; vector to spec.

(do
    (let req1 "GET / HTTP/1.1\n\n")
    (let req2 "POST /api/echo HTTP/1.1\nContent-Type: text/plain\nContent-Length: 5\n\nhello")
    (let req3 "GET /api/health?x=1 HTTP/1.1\nHost: example.com\nAccept: application/json\n\n")

    (let p1 (http-parse-parts req1))
    (let p2 (http-parse-parts req2))
    (let p3 (http-parse-parts req3))

    ;; Request 1 — minimal. method, full path, no headers, empty body.
    (let a1 (if (str_eq (hp-parts-method p1)    "GET")       1 0))
    (let a2 (if (str_eq (hp-parts-full-path p1) "/")         1 0))
    (let a3 (if (eq (len (hp-parts-headers p1)) 0)           1 0))
    (let a4 (if (eq (str_len (hp-parts-body p1)) 0)          1 0))
    (let a5 (if (hp-parts? p1)                               1 0))

    ;; Request 2 — body. method, the body bytes, two headers.
    (let b1 (if (str_eq (hp-parts-method p2) "POST")         1 0))
    (let b2 (if (str_eq (hp-parts-body p2)   "hello")        1 0))
    (let b3 (if (eq (len (hp-parts-headers p2)) 2)           1 0))

    ;; Request 3 — multi-header + query on the target. The first header lexes to
    ;; a kh-header(Host, example.com); the query stays on the full path for the
    ;; Request adapter to split.
    (let h0 (head (hp-parts-headers p3)))
    (let c1 (if (str_eq (kh-header-name h0)  "Host")              1 0))
    (let c2 (if (str_eq (kh-header-value h0) "example.com")       1 0))
    (let c3 (if (str_eq (hp-parts-full-path p3) "/api/health?x=1") 1 0))

    ;; Band verdict: 11 when every kernel lexes every vector to spec.
    (add a1 (add a2 (add a3 (add a4 (add a5
        (add b1 (add b2 (add b3
            (add c1 (add c2 c3)))))))))))
