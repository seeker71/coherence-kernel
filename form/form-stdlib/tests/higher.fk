; higher.fk - exercises higher-order patterns + list shape transforms.
; Returns an integer that aggregates several expected results; both
; kernels must agree.
;
; Components:
;   (sum (reverse [1 2 3 4 5]))           -> 15
;   (sum (append [1 2 3] [4 5 6]))        -> 21
;   (sum (take 3 [1 2 3 4 5]))            -> 6
;   (sum (drop 3 [1 2 3 4 5]))            -> 9
;   (if (any? even? [1 3 4]) 1 0)         -> 1
;   (if (all? even? [2 4 6]) 1 0)         -> 1
;   (if (any? even? [1 3 5]) 1 0)         -> 0
;   (if (all? even? [1 2 4]) 1 0)         -> 0
;   Total                                  -> 53

section [form.action] {
    def b->i(b) = if b then 1 else 0;

    let list-a = list(1, 2, 3, 4, 5);
    let list-b = list(1, 2, 3);
    let list-c = list(4, 5, 6);
    let shape-score = add(sum(reverse(list-a)), add(sum(append(list-b, list-c)), add(sum(take(3, list-a)), sum(drop(3, list-a)))));
    let truth-score = add(b->i(any?(even?, list(1, 3, 4))), add(b->i(all?(even?, list(2, 4, 6))), add(b->i(any?(even?, list(1, 3, 5))), b->i(all?(even?, list(1, 2, 4))))));
    add(shape-score, truth-score);
}
