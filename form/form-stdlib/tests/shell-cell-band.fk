; shell-cell-band.fk — proves the recipe -> blueprint -> cell pipeline: a shell
; source lowers to an addressable CELL whose ctor IS the parsed recipe, and the
; cell runs to the right output. Verdict = 15, asserted on the 4th kernel.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk form-stdlib/shell-lower.fk

(do
    (let src "seq 3 | grep 2 ; echo done")
    (let c (sh-lower "demo" src))

    (let l1 (if (str_eq (sh-cell-name c) "demo") 1 0))
    (let l2 (if (str_eq (sh-cell-domain c) "fsh") 2 0))
    (let l3 (if (node_eq (sh-cell-ctor c) (sh-parse src)) 4 0))
    (let l4 (if (str_eq (sh-cell-run c) "2\ndone\n") 8 0))

    ; expected total: 15
    (add l1 (add l2 (add l3 l4))))
