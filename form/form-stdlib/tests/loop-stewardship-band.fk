; preludes: form-stdlib/obs-verify.fk form-stdlib/trust-decay.fk form-stdlib/channel-interface.fk form-stdlib/satsang.fk form-stdlib/satsang-field.fk form-stdlib/persistence.fk form-stdlib/world-module-model.fk form-stdlib/world-model-growth.fk form-stdlib/loop-stewardship.fk
;
; loop-stewardship-band — the loop-engineering teaching runnable over
; world-model growth: the lag read as trust-decay grace (the witness receipt
; is the heartbeat, shipping is the clock), the trust ladder deciding whether
; wmg-embody may run, drift stepping a loop down to report-only. The ladder
; decides WHETHER embodiment runs; the trusted core still decides the
; embodiment.
;
; Verdict 4095 when every claim lands:
;   1     a fresh declared ledger stands at level 3 with zero lag
;   2     shipping within the half budget keeps level 3
;   4     lag past half steps down to level 2
;   8     lag past the full budget steps down to level 1
;   16    witness receipts restore: level 2 on partial, 3 when abreast
;   32    one undeclared action is drift -> level 1 despite low lag
;   64    a witness with nothing shipped changes nothing
;   128   level 3 embodies through wmg (trusted core follows)
;   256   level 2 without the keeper's word holds: awaiting-keeper
;   512   level 2 with the keeper's word embodies
;   1024  level 1 holds report-only and next action reports to keeper
;   2048  level 3 cannot bypass the body's refusal: hidden gap holds
(do
    (let offer (sat-circle-interface))
    (let identity-readings (list (ov-reading 1 1 5) (ov-reading 1 1 6)))
    (let live-identity (wmm-identity "core:self" 10 12 10 5 identity-readings))
    (let field
        (list
            (sf-member "trusted-core" (list (m-witness) (m-reflect) (m-be-seen) (m-invite)))
            (sf-member "world-module" (list (m-be-seen) (m-invite)))))
    (let claim (ov-reading 1 1 5))
    (let vulnerability
        (wmm-vulnerability
            "uncertain-lane"
            (ov-reading 1 1 7)
            10
            3
            (m-be-seen)
            "model names the gap before asking to be followed"))
    (let hidden-vulnerability
        (wmm-vulnerability
            "hidden-gap"
            (ov-reading 0 0 0)
            10
            3
            (m-be-seen)
            "silence is not a reveal"))
    (let model (wmm-model "world-module" live-identity claim 10 (list vulnerability) field 91 80))
    (let hidden-model (wmm-model "world-module" live-identity claim 10 (list hidden-vulnerability) field 91 80))
    (let s0 (wmg-empty "self-world" model))
    (let sense-observed (wmg-sense "mic-window" "audio" (ov-reading 1 1 5) 10 "voice-trace"))
    (let digested (wmg-digest (wmg-ingest s0 sense-observed) offer))
    (let hidden-state
        (wmg-state "self-world" hidden-model
            (wmg-state-senses (wmg-ingest s0 sense-observed))
            (empty) "ingested" "observed"))

    ; the ledger walk: budget max 4, half 2
    (let decl (list "sense" "digest"))
    (let l0 (lsw-fresh decl))
    (let l2s (lsw-ship (lsw-ship l0 "sense") "sense"))
    (let l3s (lsw-ship l2s "digest"))
    (let l5s (lsw-ship (lsw-ship l3s "sense") "sense"))
    (let lw2 (lsw-witness (lsw-witness l5s)))
    (let lw4 (lsw-witness (lsw-witness lw2)))
    (let ldrift (lsw-ship l0 "delete"))
    (let lnowit (lsw-witness l0))

    ; the growth-gate walk
    (let g3 (lsw-growth-step digested offer 3 0))
    (let g2h (lsw-growth-step digested offer 2 0))
    (let g2a (lsw-growth-step digested offer 2 1))
    (let g1 (lsw-growth-step digested offer 1 1))
    (let gh (lsw-growth-step hidden-state offer 3 0))

    (let c0 (if (and (eq (lsw-level l0 4 2) 3) (eq (lsw-lag l0) 0)) 1 0))
    (let c1 (if (and (eq (lsw-level l2s 4 2) 3) (eq (lsw-lag l2s) 2)) 2 0))
    (let c2 (if (eq (lsw-level l3s 4 2) 2) 4 0))
    (let c3 (if (eq (lsw-level l5s 4 2) 1) 8 0))
    (let c4 (if (and (eq (lsw-level lw2 4 2) 2) (eq (lsw-level lw4 4 2) 3)) 16 0))
    (let c5 (if (and (eq (lsw-drift? ldrift) 1) (eq (lsw-level ldrift 4 2) 1)) 32 0))
    (let c6 (if (eq (lsw-witnessed lnowit) 0) 64 0))
    (let c7
        (if (and (str_eq (wmg-state-status g3) "embodied")
                 (str_eq (wmg-state-reason g3) "follow")) 128 0))
    (let c8
        (if (and (str_eq (wmg-state-status g2h) "held")
             (and (str_eq (wmg-state-reason g2h) "awaiting-keeper")
                  (eq (len (wmg-state-parts g2h)) 0))) 256 0))
    (let c9 (if (str_eq (wmg-state-status g2a) "embodied") 512 0))
    (let c10
        (if (and (str_eq (wmg-state-reason g1) "report-only")
             (and (str_eq (lsw-next-action g1 1) "report-to-keeper")
                  (str_eq (lsw-next-action g3 3) "grow-from-embodied-truth"))) 1024 0))
    (let c11
        (if (and (str_eq (wmg-state-status gh) "held")
                 (str_eq (wmg-state-reason gh) "vulnerability-not-revealed")) 2048 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7
        (add c8 (add c9 (add c10 c11))))))))))))
