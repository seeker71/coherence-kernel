; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/pareto.fk form-stdlib/autoresearch-loop.fk form-stdlib/nearest-shape.fk form-stdlib/classifier-eval.fk form-stdlib/native-training-receipt.fk form-stdlib/real-mesh-training-carrier.fk form-stdlib/real-mesh-training-emitter.fk
;
; real-mesh-training-emitter-band - real host emitter pass/block receipt floor.
;
; Verdict 65535:
;   1   live sources with hashes are accepted
;   2   complete active emitter window passes the hard floor
;   4   blocked windows with explicit reasons are accepted as honest
;   8   below-floor active claims are rejected
;   16  active claims with incomplete lanes are rejected
;   32  active claims with weak process receipts are rejected
;   64  source byte sum must cover train + heldout bytes
;   128 invalid blocked receipts without reasons are rejected
;   256 loopback/wifi/bluetooth/audio/video/screen runtime channels satisfy communication without adb
;   512 adb install-only receipts do not satisfy runtime communication
;   1024 presence-only channels are evidence but not enough for bidirectional training
;   2048 active live-cycle projection requires heldout, capability, native win, and embodied growth
;   4096 blocked live-cycle projections are accepted when reasons are explicit
;   8192 malformed blocked live-cycle projections are rejected
;   16384 native teacher receipt wins only with sample floor and oracle reach
;   32768 world-growth receipt embodies only with followed parts and hash

(do
    (let lanes (rmt-required-lanes))
    (let sources
        (list
            (rmt-emitter-source "mac-witness-http-state" "http-localhost" "live" 125829120 120000 "sha256:mac-witness-http-state")
            (rmt-emitter-source "android-witness-state" "wifi-mesh" "live" 209715200 480000 "sha256:android-witness-state")
            (rmt-emitter-source "heldout-resource-store" "file-content-addressed" "live" 104857600 12000 "sha256:heldout-resource-store")))
    (let adb-install-only-sources
        (list
            (rmt-emitter-source "android-install-provisioning" "adb-usb-install" "live" 209715200 480000 "sha256:android-install-provisioning")
            (rmt-emitter-source "heldout-resource-store" "file-content-addressed" "live" 104857600 12000 "sha256:heldout-resource-store")))
    (let channel-family-sources
        (list
            (rmt-emitter-source "local-loopback-channel" "websocket-loopback" "live" 52428800 10000 "sha256:local-loopback-channel")
            (rmt-emitter-source "bluetooth-gatt-channel" "bluetooth-le-gatt" "live" 52428800 10000 "sha256:bluetooth-gatt-channel")
            (rmt-emitter-source "ultrasonic-audio-channel" "audio-ultrasonic" "live" 52428800 10000 "sha256:ultrasonic-audio-channel")
            (rmt-emitter-source "screen-camera-optical-channel" "screen-camera-optical" "live" 52428800 10000 "sha256:screen-camera-optical-channel")
            (rmt-emitter-source "wifi-direct-channel" "wifi-direct" "live" 52428800 10000 "sha256:wifi-direct-channel")
            (rmt-emitter-source "heldout-resource-store" "file-content-addressed" "live" 209715200 12000 "sha256:heldout-resource-store")))
    (let presence-only-sources
        (list
            (rmt-emitter-source "ble-presence-only" "ble-presence" "live" 314572800 10000 "sha256:ble-presence-only")
            (rmt-emitter-source "heldout-resource-store" "file-content-addressed" "live" 104857600 12000 "sha256:heldout-resource-store")))
    (let processes
        (list
            (rmt-process "speech-to-text" "whisper-cli -m local -f capture.wav" "local-whisper" "whisper.cpp-local" 0 4096 128 3200 "completed")
            (rmt-process "text-to-speech" "say -o sample.aiff text" "macos-say" "say-system-voice" 0 2048 0 900 "completed")
            (rmt-process "nl-to-nl" "ollama run llama3.2:3b" "local-ollama" "llama3.2:3b" 0 8192 256 5100 "completed")))
    (let active-window
        (rmt-emitter-window
            "real-host-window-001"
            "active"
            314572800
            104857600
            10000
            sources
            processes
            lanes
            (list)
            "sha256:real-host-window-001"))
    (let blocked-window
        (rmt-emitter-window
            "blocked-host-window-001"
            "blocked"
            83886080
            0
            12
            (list (rmt-emitter-source "mac-witness-http-state" "http-localhost" "live" 4096 4 "sha256:tiny-state"))
            (list)
            lanes
            (list
                (rmt-emitter-block "runtime_channel_missing" "no loopback wifi mesh audio video or screen runtime channel is live")
                (rmt-emitter-block "below_training_floor" "captured bytes are below 300 MiB"))
            "sha256:blocked-host-window-001"))
    (let tiny-active
        (rmt-emitter-window
            "tiny-active"
            "active"
            1048576
            1048576
            12
            sources
            processes
            lanes
            (list)
            "sha256:tiny-active"))
    (let incomplete-lanes
        (rmt-emitter-window
            "incomplete-lanes"
            "active"
            314572800
            104857600
            10000
            sources
            processes
            (list "speech-to-text" "text-to-speech")
            (list)
            "sha256:incomplete-lanes"))
    (let weak-process
        (rmt-emitter-window
            "weak-process"
            "active"
            314572800
            104857600
            10000
            sources
            (list (rmt-process "nl-to-nl" "ollama run tiny" "local-ollama" "llama3.2:3b" 0 4 0 1 "completed"))
            lanes
            (list)
            "sha256:weak-process"))
    (let weak-source-sum
        (rmt-emitter-window
            "weak-source-sum"
            "active"
            314572800
            104857600
            10000
            (list (rmt-emitter-source "short-store" "file" "live" 10485760 10000 "sha256:short-store"))
            processes
            lanes
            (list)
            "sha256:weak-source-sum"))
    (let adb-install-only-window
        (rmt-emitter-window
            "adb-install-only-window"
            "active"
            314572800
            104857600
            10000
            adb-install-only-sources
            processes
            lanes
            (list)
            "sha256:adb-install-only-window"))
    (let channel-family-window
        (rmt-emitter-window
            "channel-family-window"
            "active"
            314572800
            104857600
            10000
            channel-family-sources
            processes
            lanes
            (list)
            "sha256:channel-family-window"))
    (let presence-only-window
        (rmt-emitter-window
            "presence-only-window"
            "active"
            314572800
            104857600
            10000
            presence-only-sources
            processes
            lanes
            (list)
            "sha256:presence-only-window"))
    (let empty-blocked
        (rmt-emitter-window
            "empty-blocked"
            "blocked"
            0
            0
            0
            (list)
            (list)
            lanes
            (list)
            "sha256:empty-blocked"))
    (let active-cycle
        (rmt-emitter-cycle-projection
            "cycle-active"
            "emitted"
            5
            1
            0
            12
            1
            1
            "embodied"
            "form/form-stdlib/world-model-live-sense.fk#wmls-training-cycle"
            (list)))
    (let blocked-cycle
        (rmt-emitter-cycle-projection
            "cycle-blocked"
            "blocked"
            3
            0
            1
            4
            1
            0
            "held"
            "form/form-stdlib/world-model-live-sense.fk#wmls-training-cycle"
            (list
                (rmt-emitter-block "heldout_window_missing" "cycle has fewer than twelve heldout rows")
                (rmt-emitter-block "native_teacher_retirement_unproven" "native challenger has not reached the oracle yet"))))
    (let malformed-cycle
        (rmt-emitter-cycle-projection
            "cycle-malformed"
            "blocked"
            3
            0
            1
            4
            1
            0
            "held"
            "form/form-stdlib/world-model-live-sense.fk#wmls-training-cycle"
            (list)))
    (let native-teacher-win
        (rmt-native-teacher-receipt
            "native-teacher:stt"
            "won"
            12
            12
            0
            12
            12
            "sha256:native-teacher-stt"))
    (let native-teacher-behind
        (rmt-native-teacher-receipt
            "native-teacher:stt"
            "won"
            12
            12
            0
            10
            12
            "sha256:native-teacher-stt-behind"))
    (let native-teacher-too-small
        (rmt-native-teacher-receipt
            "native-teacher:stt"
            "won"
            4
            12
            0
            4
            4
            "sha256:native-teacher-stt-small"))
    (let world-growth-embodied
        (rmt-world-growth-receipt
            "world-growth:cycle"
            "embodied"
            "follow"
            3
            "sha256:world-growth-cycle"))
    (let world-growth-held
        (rmt-world-growth-receipt
            "world-growth:cycle"
            "held"
            "vulnerability-not-revealed"
            0
            "sha256:world-growth-held"))
    (let world-growth-thin
        (rmt-world-growth-receipt
            "world-growth:cycle"
            "embodied"
            "follow"
            2
            "sha256:world-growth-thin"))

    (let c0 (if (eq (rmt-emitter-sources-live? sources) 1) 1 0))
    (let c1 (if (eq (rmt-emitter-active? active-window) 1) 2 0))
    (let c2 (if (str_eq (rmt-emitter-verdict blocked-window) "blocked-honest-receipt") 4 0))
    (let c3 (if (eq (rmt-emitter-active? tiny-active) 0) 8 0))
    (let c4 (if (eq (rmt-emitter-active? incomplete-lanes) 0) 16 0))
    (let c5 (if (eq (rmt-emitter-active? weak-process) 0) 32 0))
    (let c6 (if (eq (rmt-emitter-active? weak-source-sum) 0) 64 0))
    (let c7 (if (str_eq (rmt-emitter-verdict empty-blocked) "invalid-receipt") 128 0))
    (let c8
        (if (and
                (eq (rmt-emitter-active? channel-family-window) 1)
                (str_eq
                    (rmt-emitter-communication-verdict channel-family-window)
                    "bidirectional-runtime-channel-ready"))
            256
            0))
    (let c9
        (if (and
                (eq (rmt-emitter-active? adb-install-only-window) 0)
                (str_eq
                    (rmt-emitter-communication-verdict adb-install-only-window)
                    "adb-install-only-not-runtime"))
            512
            0))
    (let c10
        (if (and
                (eq (rmt-emitter-active? presence-only-window) 0)
                (str_eq
                    (rmt-emitter-communication-verdict presence-only-window)
                    "runtime-channel-one-way-only"))
            1024
            0))
    (let c11
        (if (and
                (eq (rmt-emitter-cycle-active? active-cycle) 1)
                (str_eq (rmt-emitter-cycle-verdict active-cycle) "cycle-emitted"))
            2048
            0))
    (let c12
        (if (and
                (eq (rmt-emitter-cycle-blocked? blocked-cycle) 1)
                (str_eq (rmt-emitter-cycle-verdict blocked-cycle) "cycle-blocked-honestly"))
            4096
            0))
    (let c13
        (if (str_eq (rmt-emitter-cycle-verdict malformed-cycle) "cycle-invalid")
            8192
            0))
    (let c14
        (if (and
                (eq (rmt-native-teacher-wins? native-teacher-win) 1)
                (and
                    (eq (rmt-native-teacher-wins? native-teacher-behind) 0)
                    (eq (rmt-native-teacher-wins? native-teacher-too-small) 0)))
            16384
            0))
    (let c15
        (if (and
                (eq (rmt-world-growth-embodied? world-growth-embodied) 1)
                (and
                    (eq (rmt-world-growth-embodied? world-growth-held) 0)
                    (eq (rmt-world-growth-embodied? world-growth-thin) 0)))
            32768
            0))

    (sum (list c0 c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15)))
