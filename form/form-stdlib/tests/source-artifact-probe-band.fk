; source-artifact-probe-band.fk -- Layer 8c probe-to-descriptor witness.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/form-fs.fk form/form-stdlib/source-artifact-cache.fk form/form-stdlib/source-artifact-descriptor.fk form/form-stdlib/runtime-artifact-plan.fk form/form-stdlib/source-artifact-probe.fk
;
; Expected: 536870911
;
; This band proves observation-row construction, descriptor delegation, and one
; read-only fs-stat face. It does not prove byte hashing, seal verification,
; source parsing, program-image loading, dylib loading/calling, selector
; installation, or compiler emission.
;
; The witness is intentionally split into small bit functions, inheriting the
; source-shape pressure lesson from the Layer 9a runtime-artifact-plan band.
;
; Bits:
;   1         manifest declares constructs-sad-descriptors
;   2         manifest declares delegates-routing-to-sac
;   4         manifest declares delegates-validation-to-sad
;   8         manifest declares delegates-plan-to-rap
;   16        manifest declares observed-fields-are-declarations
;   32        manifest declares present-unvouched-degrades-to-missing
;   64        manifest declares absent-artifact-is-cache-miss
;   128       manifest declares contradictory-observation-investigates
;   256       manifest declares no-seal-verification
;   512       manifest declares no-artifact-load
;   1024      manifest declares no-runtime-selector
;   2048      manifest declares read-only-no-disk-write
;   4096      manifest declares form-fs-doors-only
;   8192      manifest declares no-kind-from-extension
;   16384     manifest declares no-byte-hash
;   32768     manifest declares no-c-seed-growth
;   65536     complete bundle constructs valid sad descriptors
;   131072    missing artifacts compile and do not skip parse
;   262144    fresh fkb plans run-program-image with compile fallback
;   524288    fresh proven dylib plans native with fkb fallback
;   1048576   absent artifact maps to sad-no-artifact and compile
;   2097152   present-unvouched artifact is not run and no hash is fabricated
;   4194304   contradictory observation investigates, not compile
;   8388608   unidentifiable source investigates
;   16777216  declared seal-bad or source-hash mismatch quarantines to compile
;   33554432  proof/callable zero cannot yield native
;   67108864  probe delegation matches hand-built sad/rap routes
;   134217728 live form-fs stat observes existence, mtime, and unvouched no-run
;   268435456 parsed-data or unknown role cannot become program-image descriptor

(do
    (defn sapb-score (ok bit) (if ok bit 0))
    (defn sapb-manifest-has (name)
        (source-artifact-probe-manifest-has? name (source-artifact-probe-manifest)))

    (defn sapb-source ()
        (sap-source-observation "src/kernel.fk" 1 40 100 "sha:src-a"))
    (defn sapb-source-unhashable ()
        (sap-source-observation "src/kernel.fk" 1 40 100 ""))
    (defn sapb-source-hand ()
        (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn sapb-fkb-missing ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 0 -1 -1 "" "" 0 0))
    (defn sapb-dylib-missing ()
        (sap-native-dylib-observation "src/kernel.dylib" 0 -1 -1 "" "" 0 0 0 0))
    (defn sapb-fkb-fresh ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 1 80 101 "sha:src-a" "sha:fkb-a" 1 1))
    (defn sapb-fkb-equal ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 1 80 100 "sha:src-a" "sha:fkb-a" 1 1))
    (defn sapb-fkb-stale ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 1 80 99 "sha:src-a" "sha:fkb-a" 1 1))
    (defn sapb-fkb-unvouched ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 1 80 101 "" "sha:fkb-a" 1 1))
    (defn sapb-fkb-source-mismatch ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 1 80 101 "sha:other" "sha:fkb-a" 1 1))
    (defn sapb-fkb-seal-bad ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 1 80 101 "sha:src-a" "sha:fkb-a" 0 1))
    (defn sapb-fkb-contradictory ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 0 -1 101 "sha:src-a" "sha:fkb-a" 1 1))
    (defn sapb-fkb-parsed-data-role ()
        (sap-observation (sad-kind-parsed-data-fkb) "src/kernel.fkb" 1 80 101 "sha:src-a" "sha:fkb-a" 1 0 0 0 1))
    (defn sapb-dylib-fresh ()
        (sap-native-dylib-observation "src/kernel.dylib" 1 90 102 "sha:src-a" "sha:dylib-a" 1 1 1 1))
    (defn sapb-dylib-unproven ()
        (sap-native-dylib-observation "src/kernel.dylib" 1 90 102 "sha:src-a" "sha:dylib-a" 1 0 1 1))
    (defn sapb-dylib-noncallable ()
        (sap-native-dylib-observation "src/kernel.dylib" 1 90 102 "sha:src-a" "sha:dylib-a" 1 1 0 1))
    (defn sapb-dylib-seal-bad ()
        (sap-native-dylib-observation "src/kernel.dylib" 1 90 102 "sha:src-a" "sha:dylib-a" 0 1 1 1))

    (defn sapb-bundle (fkb dylib)
        (sap-bundle (sapb-source) fkb dylib))
    (defn sapb-plan (fkb dylib)
        (sap-plan-from-probe (sapb-bundle fkb dylib)))
    (defn sapb-primary? (p action) (str_eq (rap-plan-primary p) action))
    (defn sapb-fallback? (p action) (str_eq (rap-plan-fallback p) action))
    (defn sapb-triple (fkb dylib)
        (sap-descriptor-triple (sapb-bundle fkb dylib)))

    (defn sapb-bit-manifest-1 ()
        (sum (list
            (sapb-score (eq (sapb-manifest-has "constructs-sad-descriptors") 1) 1)
            (sapb-score (eq (sapb-manifest-has "delegates-routing-to-sac") 1) 2)
            (sapb-score (eq (sapb-manifest-has "delegates-validation-to-sad") 1) 4)
            (sapb-score (eq (sapb-manifest-has "delegates-plan-to-rap") 1) 8)
            (sapb-score (eq (sapb-manifest-has "observed-fields-are-declarations") 1) 16)
            (sapb-score (eq (sapb-manifest-has "present-unvouched-degrades-to-missing") 1) 32)
            (sapb-score (eq (sapb-manifest-has "absent-artifact-is-cache-miss") 1) 64)
            (sapb-score (eq (sapb-manifest-has "contradictory-observation-investigates") 1) 128))))

    (defn sapb-bit-manifest-2 ()
        (sum (list
            (sapb-score (eq (sapb-manifest-has "no-seal-verification") 1) 256)
            (sapb-score (eq (sapb-manifest-has "no-artifact-load") 1) 512)
            (sapb-score (eq (sapb-manifest-has "no-runtime-selector") 1) 1024)
            (sapb-score (eq (sapb-manifest-has "read-only-no-disk-write") 1) 2048)
            (sapb-score (eq (sapb-manifest-has "form-fs-doors-only") 1) 4096)
            (sapb-score (eq (sapb-manifest-has "no-kind-from-extension") 1) 8192)
            (sapb-score (eq (sapb-manifest-has "no-byte-hash") 1) 16384)
            (sapb-score (eq (sapb-manifest-has "no-c-seed-growth") 1) 32768))))

    (defn sapb-bit-valid-descriptors ()
        (do
            (let t (sapb-triple (sapb-fkb-fresh) (sapb-dylib-fresh)))
            (sapb-score
                (and (sad-valid? (sap-triple-source t) (sap-triple-fkb t) (sap-triple-dylib t))
                     (and (str_eq (sad-source-path (sap-triple-source t)) "src/kernel.fk")
                          (str_eq (sad-artifact-kind (sap-triple-fkb t)) (sad-kind-program-image-fkb))))
                65536)))

    (defn sapb-bit-missing-compile ()
        (do
            (let p (sapb-plan (sapb-fkb-missing) (sapb-dylib-missing)))
            (sapb-score
                (and (sapb-primary? p (rap-act-compile-source))
                     (eq (rap-plan-skip-parse p) 0))
                131072)))

    (defn sapb-bit-fkb-plan ()
        (do
            (let p (sapb-plan (sapb-fkb-fresh) (sapb-dylib-missing)))
            (sapb-score
                (and (sapb-primary? p (rap-act-run-program-image))
                     (sapb-fallback? p (rap-act-compile-source)))
                262144)))

    (defn sapb-bit-native-plan ()
        (do
            (let p (sapb-plan (sapb-fkb-fresh) (sapb-dylib-fresh)))
            (sapb-score
                (and (sapb-primary? p (rap-act-run-native))
                     (and (sapb-fallback? p (rap-act-run-program-image))
                          (eq (rap-plan-deopt-anchor p) 1)))
                524288)))

    (defn sapb-bit-absent-artifact ()
        (do
            (let t (sapb-triple (sapb-fkb-missing) (sapb-dylib-missing)))
            (let p (sapb-plan (sapb-fkb-missing) (sapb-dylib-missing)))
            (sapb-score
                (and (sad-no-artifact? (sap-triple-fkb t))
                     (and (sad-no-artifact? (sap-triple-dylib t))
                          (sapb-primary? p (rap-act-compile-source))))
                1048576)))

    (defn sapb-bit-unvouched ()
        (do
            (let fkb (sapb-fkb-unvouched))
            (let t (sapb-triple (sapb-fkb-unvouched) (sapb-dylib-missing)))
            (let p (sapb-plan (sapb-fkb-unvouched) (sapb-dylib-missing)))
            (sapb-score
                (and (sad-no-artifact? (sap-triple-fkb t))
                     (and (not (sapb-primary? p (rap-act-run-program-image)))
                          (and (str_eq (sap-observation-source-hash fkb) "")
                               (str_eq (sap-observation-content-hash fkb) "sha:fkb-a"))))
                2097152)))

    (defn sapb-bit-contradictory ()
        (do
            (let p (sapb-plan (sapb-fkb-contradictory) (sapb-dylib-missing)))
            (sapb-score
                (and (sapb-primary? p (rap-act-investigate))
                     (not (sapb-primary? p (rap-act-compile-source))))
                4194304)))

    (defn sapb-bit-unidentifiable-source ()
        (do
            (let p (sap-plan-from-probe (sap-bundle (sapb-source-unhashable) (sapb-fkb-fresh) (sapb-dylib-missing))))
            (sapb-score
                (sapb-primary? p (rap-act-investigate))
                8388608)))

    (defn sapb-bit-quarantine ()
        (do
            (let p1 (sapb-plan (sapb-fkb-seal-bad) (sapb-dylib-missing)))
            (let p2 (sapb-plan (sapb-fkb-fresh) (sapb-dylib-seal-bad)))
            (let p3 (sapb-plan (sapb-fkb-source-mismatch) (sapb-dylib-missing)))
            (sapb-score
                (and (sapb-primary? p1 (rap-act-compile-source))
                     (and (sapb-primary? p2 (rap-act-compile-source))
                          (and (sapb-primary? p3 (rap-act-compile-source))
                               (not (sapb-primary? p2 (rap-act-run-native))))))
                16777216)))

    (defn sapb-bit-no-native-upgrade ()
        (sapb-score
            (and (not (sapb-primary? (sapb-plan (sapb-fkb-fresh) (sapb-dylib-unproven)) (rap-act-run-native)))
                 (not (sapb-primary? (sapb-plan (sapb-fkb-fresh) (sapb-dylib-noncallable)) (rap-act-run-native))))
            33554432))

    (defn sapb-valid-route-plan-parity? (fkb dylib)
        (do
            (let t (sapb-triple fkb dylib))
            (let p-probe (sap-plan-from-probe (sapb-bundle fkb dylib)))
            (let p-hand (rap-plan-from-descriptors (sap-triple-source t) (sap-triple-fkb t) (sap-triple-dylib t)))
            (and (eq (sap-delegated-route (sapb-bundle fkb dylib))
                     (sad-route (sap-triple-source t) (sap-triple-fkb t) (sap-triple-dylib t)))
                 (and (eq (rap-plan-route p-probe) (rap-plan-route p-hand))
                      (and (str_eq (rap-plan-primary p-probe) (rap-plan-primary p-hand))
                           (eq (rap-plan-skip-parse p-probe) (rap-plan-skip-parse p-hand)))))))

    (defn sapb-bit-delegation-parity ()
        (sapb-score
            (and (sapb-valid-route-plan-parity? (sapb-fkb-fresh) (sapb-dylib-missing))
                 (and (sapb-valid-route-plan-parity? (sapb-fkb-fresh) (sapb-dylib-fresh))
                      (and (sapb-valid-route-plan-parity? (sapb-fkb-stale) (sapb-dylib-missing))
                           (sapb-valid-route-plan-parity? (sapb-fkb-equal) (sapb-dylib-missing)))))
            67108864))

    (defn sapb-bit-live-fs-stat ()
        (do
            (let root (fs-path-join (fs-temp-dir) "source-artifact-probe-band"))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let fpath (fs-path-join root "artifact.fkb"))
            (let _w (fs-write-text fpath "fkb"))
            (let obs (sap-observe-program-image-fkb fpath "sha:src-a" "sha:fkb-a" 1 1))
            (let unvouched (sap-observe-program-image-fkb fpath "" "" 1 1))
            (let unvouched-triple (sap-descriptor-triple (sap-bundle (sapb-source) unvouched (sapb-dylib-missing))))
            (let missing (sap-observe-program-image-fkb (fs-path-join root "missing.fkb") "" "" 0 0))
            (let _rm (fs-remove-file fpath))
            (let _rt (fs-remove-tree root))
            (sapb-score
                (and (eq (sap-observation-exists obs) 1)
                     (and (gt (sap-observation-mtime obs) 0)
                          (and (eq (sap-observation-exists missing) 0)
                               (and (eq (sap-observation-absent? missing) 1)
                                    (sad-no-artifact? (sap-triple-fkb unvouched-triple))))))
                134217728)))

    (defn sapb-bit-kind-rejection ()
        (do
            (let p-parsed (sap-plan-from-probe (sap-bundle (sapb-source) (sapb-fkb-parsed-data-role) (sapb-dylib-missing))))
            (let bad-role (sap-observation "compiler-image-fkb" "src/kernel.fkb" 1 80 101 "sha:src-a" "sha:fkb-a" 1 0 0 0 1))
            (let p-unknown (sap-plan-from-probe (sap-bundle (sapb-source) bad-role (sapb-dylib-missing))))
            (sapb-score
                (and (sapb-primary? p-parsed (rap-act-investigate))
                     (sapb-primary? p-unknown (rap-act-investigate)))
                268435456)))

    (defn source-artifact-probe-band ()
        (sum (list
            (sapb-bit-manifest-1)
            (sapb-bit-manifest-2)
            (sapb-bit-valid-descriptors)
            (sapb-bit-missing-compile)
            (sapb-bit-fkb-plan)
            (sapb-bit-native-plan)
            (sapb-bit-absent-artifact)
            (sapb-bit-unvouched)
            (sapb-bit-contradictory)
            (sapb-bit-unidentifiable-source)
            (sapb-bit-quarantine)
            (sapb-bit-no-native-upgrade)
            (sapb-bit-delegation-parity)
            (sapb-bit-live-fs-stat)
            (sapb-bit-kind-rejection))))

    (source-artifact-probe-band))
