; go-jit-band.fk — sibling-parity attestation for the JIT lattice.
;
; Same recipe; four kernels; four dispatch paths (or honest stub);
; same answer. The band's verdict is the count of correct results
; across the recipe-walk + post-JIT calls. The number 8 says: every
; assertions matched the expected values on every kernel.

(do
    ;; A recursive int64-typed recipe in the supported JIT subset.
    (defn fact (n)
        (if (le n 1) 1
            (mul n (fact (sub n 1)))))

    ;; Recipe-walk baseline.
    (let r0 (fact 6))                ; 720

    ;; Compile. TS=1 (V8), Go=1 (this walk), Rust=0 (next walk).
    ;; The band only prints the boolean "compile happened at API level"
    ;; — that's 1 everywhere because every kernel returns ≥ 0.
    (let compiled (jit_compile "fact"))
    (let attempted (if (ge compiled 0) 1 0))

    ;; Post-JIT dispatches:
    (let r1 (fact 6))                ; 720
    (let r2 (fact 7))                ; 5040
    (let r3 (fact 0))                ; 1 (base case)

    ;; Logic ops (and/or/not) now in the typed i64 JIT subset (gap #3).
    ;; Produces 0/1 consistent with compare/cond in int subset; used in guards.
    (defn in-range (x) (if (and (ge x 0) (le x 5)) 1 0))
    (let compiled-logic (jit_compile "in-range"))
    (let rlog1 (in-range 3))   ; 1 (true and)
    (let rlog2 (in-range 6))   ; 0
    (let rlog3 (in-range -1))  ; 0

    ;; Sibling-parity verdict.
    (add attempted
         (add (if (eq r0 720) 1 0)
              (add (if (eq r1 720) 1 0)
                   (add (if (eq r2 5040) 1 0)
                        (add (if (eq r3 1) 1 0)
                             (add (if (eq rlog1 1) 1 0)
                                  (add (if (eq rlog2 0) 1 0)
                                       (if (eq rlog3 0) 1 0)))))))))
