; preludes: form-stdlib/jit-tensor-emit.fk
;
; llama-block-decode-emit-band — the KV-CACHED DECODE STEP emitter as recipe, four-way.
; jte-llama-block-decode-step-msl authors the Metal kernel for ONE autoregressive generation step over a
; PERSISTENT KV cache: RMSNorm1(x_p) -> project q/k/v from the single new token -> RoPE q/k by position p ->
; APPEND the RoPE'd k_p/v_p into cache slot p -> attend the query over the grown prefix cache[0..p] ->
; Wo/residual/RMSNorm2/SwiGLU/residual -> y_p. This is the GPU realization of kv-llama-block.fk's
; lblk-generate-causal (#3408, four-way 255), proven there BIT-IDENTICAL to the full causal recompute
; (lblk-block-causal, #3365, four-way 511). Only the NEW token is projected each step; earlier positions'
; k/v are reused from the cache (O(n) per token, not the O(n^2) recompute of the whole block). A cached
; k_i/v_i depends ONLY on position i, never the future, so the cache the front-to-back walk holds at step p
; is exactly the prefix the full causal kernel's mask (while t < s+1u) cuts at query p, with identical fold
; order — so looping this kernel reproduces jte-llama-block-fwd-causal-msl's whole-sequence output BIT-FOR-BIT
; on silicon (scripts/metal_llama_block_decode_audit.sh runs both kernels on the M4 Max GPU and gates the
; decode loop == the full causal recompute, bit-exact, both tracking the proven fp64 recipe within fp32 eps).
; Every dot is tb-dot's downward right-fold split through a named temporary (no fma contraction); softmax is
; tn-softmax's max-subtract over the recipe's own fexp; each RMSNorm is the biased mean-square + 50-step
; Newton sqrt; SiLU's sigmoid is fexp; RoPE's sin/cos/pow are trig.fk's own Taylor — never Metal's
; transcendentals. Dims (p position, d model, dq query/key, dv value, hid FFN, HD head-dim) arrive as runtime
; buffers, so the emitted source is one static string parameterized only by the kernel name.
;
; Verdict 7 when the emission lands:
;   1   the full emitted f32 MSL for form_llama_decode_step_f32 equals the canonical text
;   2   a different name lands in the same frame (emission is a function of the name)
;   4   two emissions of the same name are str_eq (deterministic text — same emission, same cell)
(do
    (let pre "float fexp_small(float x){ float n = 1.0f; float term = 1.0f; float acc = 1.0f; while (n <= 14.0f) { term = term * (x / n); acc = acc + term; n = n + 1.0f; } return acc; } float fexp(float x){ int k = 0; while ((x < 0.0f ? -x : x) > 0.5f) { x = x / 2.0f; k = k + 1; } float v = fexp_small(x); while (k > 0) { v = v * v; k = k - 1; } return v; } float ftanh(float x){ float e = fexp(2.0f * x); return (e - 1.0f) / (e + 1.0f); } float fgelu(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); return (0.5f * x) * (1.0f + ftanh(z)); } float fgelud(float x){ float z = 0.7978845608028654f * (x + 0.044715f * (x * (x * x))); float th = ftanh(z); return (0.5f * (1.0f + th)) + ((0.5f * x) * ((1.0f - (th * th)) * (0.7978845608028654f * (1.0f + (0.134145f * (x * x)))))); } float rr_2pi(float x){ float t = 6.283185307179586f; return x - t * round(x / t); } float fsin(float x){ float r = rr_2pi(x); float x2 = r * r; float term = r; float acc = 0.0f; int k = 0; while (k < 10) { acc = acc + term; int m = 2 * (k + 1); float den = float(m * (m + 1)); float nt = term * ((-1.0f * x2) / den); term = nt; k = k + 1; } return acc; } float fcos(float x){ return fsin(x + 1.5707963267948966f); } float fln(float x){ float a = x; int e = 0; while (a >= 2.0f) { a = a * 0.5f; e = e + 1; } while (a < 1.0f) { a = a * 2.0f; e = e - 1; } float z = (a - 1.0f) / (a + 1.0f); float z2 = z * z; float zpow = z; float acc = 0.0f; int j = 0; while (j < 14) { float num = zpow * z2; float den = float(2 * (j + 1) + 1); acc = acc + (num / den); zpow = zpow * z2; j = j + 1; } float lm = 2.0f * (z + acc); return float(e) * 0.6931471805599453f + lm; } float fpow(float b, float e){ if (b <= 0.0f) return 0.0f; return fexp(e * fln(b)); } kernel void ")
    (let post "(device const float* wq [[buffer(0)]], device const float* wk [[buffer(1)]], device const float* wv [[buffer(2)]], device const float* wo [[buffer(3)]], device const float* g1 [[buffer(4)]], device const float* wg [[buffer(5)]], device const float* wu [[buffer(6)]], device const float* wd [[buffer(7)]], device const float* g2 [[buffer(8)]], device const float* x [[buffer(9)]], device float* ck [[buffer(10)]], device float* cv [[buffer(11)]], device float* y [[buffer(12)]], device float* sc [[buffer(13)]], constant uint& p [[buffer(14)]], constant uint& d [[buffer(15)]], constant uint& dq [[buffer(16)]], constant uint& dv [[buffer(17)]], constant uint& hid [[buffer(18)]], constant uint& HD [[buffer(19)]], constant float& scale [[buffer(20)]], constant float& eps [[buffer(21)]], uint gid [[thread_position_in_grid]]) { if (gid != 0u) return; uint oN1 = 0; uint oQ = oN1 + d; uint oA = oQ + dv; uint oH = oA + dv; uint oN2 = oH + d; uint oSR = oN2 + d; uint oE = oSR + (p + 1u); uint oG = oE + (p + 1u); uint oU = oG + hid; uint oACT = oU + hid; { float ss = 0.0f; uint j = 0; while (j < d) { float xv = x[j]; float sq = xv * xv; ss = ss + sq; j += 1; } float meansq = ss / float(d); float sdv = meansq + eps; float g = sdv; uint it = 50; while (it > 0) { it -= 1; g = 0.5f * (g + sdv / g); } float inv = 1.0f / g; j = 0; while (j < d) { float nm = x[j] * inv; sc[oN1 + j] = nm * g1[j]; j += 1; } } { uint r = 0; while (r < dq) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float pp = wq[r * d + c] * sc[oN1 + c]; acc = pp + acc; } sc[oQ + r] = acc; r += 1; } } { uint r = 0; while (r < dq) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float pp = wk[r * d + c] * sc[oN1 + c]; acc = pp + acc; } ck[p * dq + r] = acc; r += 1; } } { uint r = 0; while (r < dv) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float pp = wv[r * d + c] * sc[oN1 + c]; acc = pp + acc; } cv[p * dv + r] = acc; r += 1; } } { uint i = 0; while (i + 1u < dq) { uint hd = i % HD; float fr = fpow(10000.0f, (-1.0f * float(hd)) / float(HD)); float a = float(p) * fr; float ca = fcos(a); float sa = fsin(a); float q0 = sc[oQ + i]; float q1 = sc[oQ + i + 1u]; float t0 = q0 * ca; float t1 = q1 * sa; sc[oQ + i] = t0 - t1; float t2 = q0 * sa; float t3 = q1 * ca; sc[oQ + i + 1u] = t2 + t3; i += 2u; } } { uint i = 0; while (i + 1u < dq) { uint hd = i % HD; float fr = fpow(10000.0f, (-1.0f * float(hd)) / float(HD)); float a = float(p) * fr; float ca = fcos(a); float sa = fsin(a); float q0 = ck[p * dq + i]; float q1 = ck[p * dq + i + 1u]; float t0 = q0 * ca; float t1 = q1 * sa; ck[p * dq + i] = t0 - t1; float t2 = q0 * sa; float t3 = q1 * ca; ck[p * dq + i + 1u] = t2 + t3; i += 2u; } } { uint t = 0; while (t < p + 1u) { float acc = 0.0f; uint c = dq; while (c > 0) { c -= 1; float pp = sc[oQ + c] * ck[t * dq + c]; acc = pp + acc; } sc[oSR + t] = acc * scale; t += 1; } float mx = sc[oSR + 0]; t = 1; while (t < p + 1u) { if (sc[oSR + t] > mx) { mx = sc[oSR + t]; } t += 1; } float sumes = 0.0f; t = 0; while (t < p + 1u) { float e = fexp(sc[oSR + t] - mx); sc[oE + t] = e; sumes = sumes + e; t += 1; } float invs = 1.0f / sumes; t = 0; while (t < p + 1u) { sc[oSR + t] = sc[oE + t] * invs; t += 1; } uint i = 0; while (i < dv) { sc[oA + i] = 0.0f; i += 1; } t = 0; while (t < p + 1u) { i = 0; while (i < dv) { float pv = cv[t * dv + i] * sc[oSR + t]; sc[oA + i] = sc[oA + i] + pv; i += 1; } t += 1; } } { uint i = 0; while (i < d) { float acc = 0.0f; uint c = dv; while (c > 0) { c -= 1; float pp = wo[i * dv + c] * sc[oA + c]; acc = pp + acc; } sc[oH + i] = x[i] + acc; i += 1; } } { float ss = 0.0f; uint j = 0; while (j < d) { float xv = sc[oH + j]; float sq = xv * xv; ss = ss + sq; j += 1; } float meansq = ss / float(d); float sdv = meansq + eps; float g = sdv; uint it = 50; while (it > 0) { it -= 1; g = 0.5f * (g + sdv / g); } float inv = 1.0f / g; j = 0; while (j < d) { float nm = sc[oH + j] * inv; sc[oN2 + j] = nm * g2[j]; j += 1; } } { uint k = 0; while (k < hid) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float pp = wg[k * d + c] * sc[oN2 + c]; acc = pp + acc; } sc[oG + k] = acc; k += 1; } k = 0; while (k < hid) { float acc = 0.0f; uint c = d; while (c > 0) { c -= 1; float pp = wu[k * d + c] * sc[oN2 + c]; acc = pp + acc; } sc[oU + k] = acc; k += 1; } k = 0; while (k < hid) { float gv = sc[oG + k]; float sig = 1.0f / (1.0f + fexp(-1.0f * gv)); float sl = gv * sig; sc[oACT + k] = sl * sc[oU + k]; k += 1; } uint i = 0; while (i < d) { float acc2 = 0.0f; uint kk = hid; while (kk > 0) { kk -= 1; float p2 = wd[i * hid + kk] * sc[oACT + kk]; acc2 = p2 + acc2; } y[i] = sc[oH + i] + acc2; i += 1; } } }")
    (let want (str_concat pre (str_concat "form_llama_decode_step_f32" post)))
    (let got (jte-llama-block-decode-step-msl "form_llama_decode_step_f32"))
    (let other (jte-llama-block-decode-step-msl "b2"))
    (let c0 (if (str_eq got want) 1 0))
    (let c1 (if (str_eq other (str_concat pre (str_concat "b2" post))) 2 0))
    (let c2 (if (str_eq (jte-llama-block-decode-step-msl "form_llama_decode_step_f32") got) 4 0))
    (add c0 (add c1 c2)))
