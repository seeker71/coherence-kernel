; blueprint-authority-band.fk -- witness blueprint authority policy.
;
; preludes: form-stdlib/core.fk form-stdlib/blueprint-authority.fk
; Expected: 65535
;
; Bit legend:
;   1     manifest carries the authority split
;   2     reviewed bootstrap rows are current runtime authority
;   4     registry JSON is authoring/generator source, not runtime authority
;   8     generated sibling bp tables are projection-only
;   16    generated table admission refuses runtime-authority claims
;   32    program-image .fkb is target executable authority, not current loader
;   64    .sym is presentation lens only and cannot carry executable deps
;   128   unknown names investigate/refuse without fake NodeID
;   256   C-seed growth is refused
;   512   manifest refuses runtime JSON and host-table authority
;   1024  source has no runtime read/import of host tables or C seed
;   2048  registry doc names the current honest split
;   4096  generated sibling files are generated projections
;   8192  architecture map preserves .fkb/.sym boundary
;   16384 version is stable
;   32768 row predicates are total on malformed input

(do
    (defn bpab-score (ok bit) (if ok bit 0))
    (defn bpab-manifest-has (name)
        (blueprint-authority-manifest-has? name (blueprint-authority-manifest)))
    (defn bpab-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn bpab-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn bpab-bit-manifest ()
        (bpab-score
            (and (eq (bpab-manifest-has "reviewed-bootstrap-runtime-authority") 1)
            (and (eq (bpab-manifest-has "registry-json-authoring-generator-source") 1)
            (and (eq (bpab-manifest-has "generated-sibling-tables-projection-only") 1)
            (and (eq (bpab-manifest-has "go-rust-ts-proof-siblings-not-runtime") 1)
            (and (eq (bpab-manifest-has "program-image-fkb-executable-symbol-truth") 1)
            (and (eq (bpab-manifest-has "program-image-fkb-target-not-current-loader") 1)
            (and (eq (bpab-manifest-has "sym-locale-domain-presentation-lens") 1)
            (and (eq (bpab-manifest-has "unknown-name-refuse-or-investigate") 1)
            (and (eq (bpab-manifest-has "no-fake-nodeid-fallback") 1)
            (and (eq (bpab-manifest-has "no-runtime-json-registry-read") 1)
            (and (eq (bpab-manifest-has "no-host-table-authority") 1)
                 (eq (bpab-manifest-has "no-c-seed-growth") 1))))))))))))
            1))
    (defn bpab-bit-bootstrap ()
        (bpab-score
            (and (bpa-runtime-authority? (bpa-bootstrap-row))
            (and (bpa-executable-dependency-authority? (bpa-bootstrap-row))
            (and (not (bpa-projection-only? (bpa-bootstrap-row)))
                 (not (bpa-presentation-lens-only? (bpa-bootstrap-row))))))
            2))
    (defn bpab-bit-registry-json ()
        (bpab-score
            (and (bpa-authoring-source? (bpa-registry-json-row))
            (and (not (bpa-runtime-authority? (bpa-registry-json-row)))
                 (not (bpa-executable-dependency-authority? (bpa-registry-json-row)))))
            4))
    (defn bpab-bit-generated-projection ()
        (bpab-score
            (and (bpa-projection-only? (bpa-generated-sibling-row))
            (and (not (bpa-runtime-authority? (bpa-generated-sibling-row)))
                 (not (bpa-executable-dependency-authority? (bpa-generated-sibling-row)))))
            8))
    (defn bpab-bit-generated-admission ()
        (bpab-score
            (and (eq (bpa-generated-table-admitted? 1 1 0) 1)
            (and (eq (bpa-generated-table-admitted? 1 1 1) 0)
            (and (eq (bpa-generated-table-admitted? 1 0 0) 0)
                 (eq (bpa-generated-table-admitted? 0 1 0) 0))))
            16))
    (defn bpab-bit-fkb-authority ()
        (bpab-score
            (and (not (bpa-runtime-authority? (bpa-program-image-fkb-row)))
            (and (bpa-executable-dependency-authority? (bpa-program-image-fkb-row))
                 (not (bpa-projection-only? (bpa-program-image-fkb-row)))))
            32))
    (defn bpab-bit-sym-lens ()
        (bpab-score
            (and (bpa-presentation-lens-only? (bpa-sym-lens-row))
            (and (eq (bpa-sym-lens-admitted? 1 0) 1)
            (and (eq (bpa-sym-lens-admitted? 1 1) 0)
                 (not (bpa-executable-dependency-authority? (bpa-sym-lens-row))))))
            64))
    (defn bpab-bit-unknown ()
        (bpab-score (bpa-unknown-refuses-nodeid?) 128))
    (defn bpab-bit-c-seed ()
        (bpab-score (bpa-c-seed-growth-refused? (bpa-c-seed-growth-row)) 256))
    (defn bpab-bit-manifest-refusals ()
        (bpab-score
            (and (eq (bpab-manifest-has "no-runtime-json-registry-read") 1)
                 (eq (bpab-manifest-has "no-host-table-authority") 1))
            512))
    (defn bpab-bit-source-static ()
        (do
            (let source (bpab-read-file-any
                "form-stdlib/blueprint-authority.fk"
                "../form/form-stdlib/blueprint-authority.fk"))
            (bpab-score
                (and (not (bpab-has? source "read_file"))
                (and (not (bpab-has? source "bpTable"))
                (and (not (bpab-has? source "BP_TABLE"))
                (and (not (bpab-has? source "BP_ENTRIES"))
                     (not (bpab-has? source "runtime/fkwu-uni.c"))))))
                1024)))
    (defn bpab-bit-doc-honesty ()
        (do
            (let doc (bpab-read-file-any
                "user-blueprint-registry.md"
                "../form/user-blueprint-registry.md"))
            (bpab-score
                (and (bpab-has? doc "Current honest split")
                (and (bpab-has? doc "does not runtime-parse")
                (and (bpab-has? doc "proof-sibling projections")
                (and (bpab-has? doc ".sym")
                     (not (bpab-has? doc "can read at load time"))))))
                2048)))
    (defn bpab-bit-generated-files ()
        (do
            (let go (bpab-read-file-any
                "form-kernel-go/bp_table.go"
                "../form/form-kernel-go/bp_table.go"))
            (let rust (bpab-read-file-any
                "form-kernel-rust/src/bp_table.rs"
                "../form/form-kernel-rust/src/bp_table.rs"))
            (let ts (bpab-read-file-any
                "form-kernel-ts/src/bp_table.ts"
                "../form/form-kernel-ts/src/bp_table.ts"))
            (bpab-score
                (and (bpab-has? go "Code generated")
                (and (bpab-has? rust "Code generated")
                     (bpab-has? ts "Code generated")))
                4096)))
    (defn bpab-bit-architecture ()
        (do
            (let arch (bpab-read-file-any
                "../receipts/2026-07-03-core-layer-architecture-map.md"
                "receipts/2026-07-03-core-layer-architecture-map.md"))
            (bpab-score
                (and (bpab-has? arch "Blueprint authority")
                (and (bpab-has? arch "generated proof-sibling bp tables")
                (and (bpab-has? arch "program-image `.fkb`")
                     (bpab-has? arch "`.sym`"))))
                8192)))
    (defn bpab-bit-version ()
        (bpab-score (str_eq (bpa-version) "blueprint-authority-v1") 16384))
    (defn bpab-bit-malformed-total ()
        (bpab-score
            (and (eq (bpa-row? (list "not-a-row")) 0)
            (and (eq (bpa-runtime-authority? (list "not-a-row")) 0)
            (and (eq (bpa-authoring-source? (list "not-a-row")) 0)
            (and (eq (bpa-projection-only? (list "not-a-row")) 0)
            (and (eq (bpa-presentation-lens-only? (list "not-a-row")) 0)
                 (eq (bpa-executable-dependency-authority? (list "not-a-row")) 0))))))
            32768))

    (defn blueprint-authority-band ()
        (sum (list
            (bpab-bit-manifest)
            (bpab-bit-bootstrap)
            (bpab-bit-registry-json)
            (bpab-bit-generated-projection)
            (bpab-bit-generated-admission)
            (bpab-bit-fkb-authority)
            (bpab-bit-sym-lens)
            (bpab-bit-unknown)
            (bpab-bit-c-seed)
            (bpab-bit-manifest-refusals)
            (bpab-bit-source-static)
            (bpab-bit-doc-honesty)
            (bpab-bit-generated-files)
            (bpab-bit-architecture)
            (bpab-bit-version)
            (bpab-bit-malformed-total))))

    (blueprint-authority-band))
