; http-negotiate-band.fk — proof of REST content-negotiation (Accept-header
; parsing and best-representation selection).
;
; preludes: form-stdlib/core.fk form-stdlib/http-negotiate.fk
;
; Closes the named gap: "no Accept/Content-Type-aware dispatch exists —
; Content-Type is a hardcoded application/json on every response." This is
; the negotiation ALGORITHM, fully verified via bare `fkwu --src` — see
; http-negotiate.fk's own header for why it's deliberately independent of
; kernel-http.fk/http-adapter.fk (those are BML-authored, and this
; checkout has no working BML flatten pipeline at all; confirmed directly,
; not assumed).
;
; Covers: no Accept header (defaults to server's first preference), an
; exact match, an unsupported type (falls back to first preference, never
; silently produces nothing), q-value-weighted preference between two
; acceptable types (including a case where the SECOND-listed type wins on
; a higher q), and both wildcard forms (`*/*` and `type/*`).
;
; Verdict 127 when every assertion holds.

(do
    (defn hnb-score (ok bit) (if ok bit 0))
    (defn http-negotiate-band ()
        (do
    (let avail (list "application/json" "application/xml"))
    (let c0 (hnb-score (str_eq (hn-negotiate "" avail) "application/json") 1))
    (let c1 (hnb-score (str_eq (hn-negotiate "application/xml" avail) "application/xml") 2))
    (let c2 (hnb-score (str_eq (hn-negotiate "text/plain" avail) "application/json") 4))
    (let c3 (hnb-score (str_eq (hn-negotiate "application/xml;q=0.9, application/json;q=0.5" avail) "application/xml") 8))
    (let c4 (hnb-score (str_eq (hn-negotiate "application/json;q=0.9, application/xml;q=0.95" avail) "application/xml") 16))
    (let c5 (hnb-score (str_eq (hn-negotiate "*/*" avail) "application/json") 32))
    (let c6 (hnb-score (str_eq (hn-negotiate "application/*" avail) "application/json") 64))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
    )
    (http-negotiate-band))
