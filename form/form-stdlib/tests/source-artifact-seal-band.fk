; source-artifact-seal-band.fk -- Layer 8e keyed seal witness.
;
; preludes: form/form-stdlib/core.fk form/form-stdlib/str-byte-at.fk form/form-stdlib/string-byte-fold-src-shim.fk form/form-stdlib/sha256.fk form/form-stdlib/hex.fk form/form-stdlib/hmac-sha256.fk form/form-stdlib/form-fs.fk form/form-stdlib/source-artifact-cache.fk form/form-stdlib/source-artifact-descriptor.fk form/form-stdlib/runtime-artifact-plan.fk form/form-stdlib/source-artifact-probe.fk form/form-stdlib/source-artifact-identity.fk form/form-stdlib/source-artifact-seal.fk
;
; Expected: 2147483647

(do
    (defn sasb-score (ok bit) (if ok bit 0))
    (defn sasb-manifest-has (name)
        (source-artifact-seal-manifest-has? name (source-artifact-seal-manifest)))
    (defn sasb-key () (sai-string-bytes "seal-key"))
    (defn sasb-other-key () (sai-string-bytes "other-key"))
    (defn sasb-source-hash ()
        "sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    (defn sasb-fkb-hash ()
        "sha256:573dbb57d6af3d54263620b016da6212869e4aadb8a867ad9d78ba2b15cba1d1")
    (defn sasb-dylib-hash ()
        "sha256:6ca4c50d821f7f130312f82d37d2d8062256f9dcc0db409fd7323651167069b3")
    (defn sasb-fkb-seal ()
        "hmac-sha256:67be7f4549fb6d950a6bd4bf335a5e140898dd16488f2ffed695266119c74d92")
    (defn sasb-dylib-seal ()
        "hmac-sha256:379bc7bcaaa870931e3f60218dfb64e5ad43e26236259141d222a46f7d9269c9")
    (defn sasb-source-vouch ()
        (sai-vouch-source-bytes "src/kernel.fk" (sasb-source-hash) (list 97 98 99)))
    (defn sasb-source-vouch-other ()
        (sai-vouch-source-bytes "src/kernel.fk" "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" (list 97 98 99)))
    (defn sasb-fkb-vouch ()
        (sai-vouch-content-bytes "src/kernel.fkb" (sasb-fkb-hash) (sai-string-bytes "fkb")))
    (defn sasb-fkb-vouch-other ()
        (sai-vouch-content-bytes "src/kernel.fkb" (sasb-dylib-hash) (sai-string-bytes "fkb")))
    (defn sasb-dylib-vouch ()
        (sai-vouch-content-bytes "src/kernel.dylib" (sasb-dylib-hash) (sai-string-bytes "dylib")))
    (defn sasb-fkb-good ()
        (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch) (sasb-fkb-vouch) 1 (sasb-key) (sasb-fkb-seal)))
    (defn sasb-fkb-wrong-key ()
        (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch) (sasb-fkb-vouch) 1 (sasb-other-key) (sasb-fkb-seal)))
    (defn sasb-dylib-good ()
        (sas-native-dylib-seal "src/kernel.dylib" (sasb-source-vouch) (sasb-dylib-vouch) 1 (sasb-key) (sasb-dylib-seal)))

    (defn sasb-bit-manifest-1 ()
        (sum (list
            (sasb-score (eq (sasb-manifest-has "hmac-sha256-seal-hex") 1) 1)
            (sasb-score (eq (sasb-manifest-has "seal-is-keyed-mac-not-signature") 1) 2)
            (sasb-score (eq (sasb-manifest-has "short-identity-message-only") 1) 4)
            (sasb-score (eq (sasb-manifest-has "length-prefixed-message-v1") 1) 8)
            (sasb-score (eq (sasb-manifest-has "consumes-sai-vouch-status") 1) 16)
            (sasb-score (eq (sasb-manifest-has "artifact-roles-only") 1) 32)
            (sasb-score (eq (sasb-manifest-has "seal-verified-sets-seal-ok") 1) 64)
            (sasb-score (eq (sasb-manifest-has "identity-match-alone-not-seal-ok") 1) 128)
            (sasb-score (eq (sasb-manifest-has "no-proof-callable-native-admission") 1) 256)
            (sasb-score (eq (sasb-manifest-has "no-binary-file-hash") 1) 512)
            (sasb-score (eq (sasb-manifest-has "read-file-bytes-not-checkout-witness") 1) 1024))))

    (defn sasb-bit-manifest-2 ()
        (sum (list
            (sasb-score (eq (sasb-manifest-has "no-key-storage-or-secret-retrieval") 1) 2048)
            (sasb-score (eq (sasb-manifest-has "no-ed25519-or-codesign") 1) 4096)
            (sasb-score (eq (sasb-manifest-has "no-artifact-load") 1) 8192)
            (sasb-score (eq (sasb-manifest-has "no-runtime-selector") 1) 16384)
            (sasb-score (eq (sasb-manifest-has "no-compiler-emission") 1) 32768)
            (sasb-score (eq (sasb-manifest-has "no-cache-write") 1) 65536)
            (sasb-score (eq (sasb-manifest-has "no-sac-route-fork") 1) 131072)
            (sasb-score (eq (sasb-manifest-has "no-c-seed-growth") 1) 262144)
            (sasb-score (eq (sasb-manifest-has "read-only-no-disk-write") 1) 524288)
            (sasb-score (eq (sasb-manifest-has "no-sai-import-cycle") 1) 1048576))))

    (defn sasb-bit-canonical-message ()
        (do
            (let m (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
            (let c1 (sas-seal-message-v1 "ab" "c" "p" "s" "h" 1))
            (let c2 (sas-seal-message-v1 "a" "bc" "p" "s" "h" 1))
            (sasb-score
                (and (str_eq m "6:sas-v117:program-image-fkb16:program-image-v114:src/kernel.fkb71:sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad71:sha256:573dbb57d6af3d54263620b016da6212869e4aadb8a867ad9d78ba2b15cba1d11:1")
                     (not (str_eq c1 c2)))
                2097152)))
    (defn sasb-bit-hmac-vector ()
        (sasb-score
            (str_eq (sas-hmac-seal (sasb-key) (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
                    (sasb-fkb-seal))
            4194304))
    (defn sasb-bit-row-match ()
        (do
            (let row (sasb-fkb-good))
            (sasb-score
                (and (str_eq (sas-seal-status row) (sas-status-match))
                     (and (str_eq (sas-seal-key-evidence-kind row) (sas-key-evidence-supplied-bytes))
                          (and (str_eq (sas-seal-source-hash row) (sasb-source-hash))
                               (and (str_eq (sas-seal-content-hash row) (sasb-fkb-hash))
                                    (and (eq (sas-seal-artifact-bit row) 1)
                                         (eq (sas-seal-ok-bit row) 1))))))
                8388608)))
    (defn sasb-bit-negatives ()
        (do
            (let undeclared (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch) (sasb-fkb-vouch) 1 (sasb-key) ""))
            (let malformed (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch) (sasb-fkb-vouch) 1 (sasb-key) "hmac-sha256:ABC"))
            (let upper (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch) (sasb-fkb-vouch) 1 (sasb-key) "hmac-sha256:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"))
            (let wrong-key (sasb-fkb-wrong-key))
            (let unvouched (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch-other) (sasb-fkb-vouch) 1 (sasb-key) (sasb-fkb-seal)))
            (let unvouched-content (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch) (sasb-fkb-vouch-other) 1 (sasb-key) (sasb-fkb-seal)))
            (sasb-score
                (and (str_eq (sas-seal-status undeclared) (sas-status-undeclared))
                     (and (str_eq (sas-seal-status malformed) (sas-status-malformed))
                          (and (str_eq (sas-seal-status upper) (sas-status-malformed))
                               (and (str_eq (sas-seal-status wrong-key) (sas-status-mismatch))
                                    (and (str_eq (sas-seal-status unvouched) (sas-status-unvouched))
                                         (and (str_eq (sas-seal-actual unvouched) "")
                                              (and (str_eq (sas-seal-status unvouched-content) (sas-status-unvouched))
                                                   (str_eq (sas-seal-actual unvouched-content) ""))))))))
                16777216)))
    (defn sasb-bit-field-sensitivity ()
        (do
            (let base (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
            (let kind (sas-seal-message-v1 (sad-kind-native-dylib) (sad-version-program-image-fkb) "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
            (let version (sas-seal-message-v1 (sad-kind-program-image-fkb) "program-image-v2" "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
            (let path (sas-program-image-fkb-message "src/other.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
            (let source (sas-program-image-fkb-message "src/kernel.fkb" "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" (sasb-fkb-hash) 1))
            (let content (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-dylib-hash) 1))
            (let bit (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 0))
            (let dylib-lowerable (sas-native-dylib-message "src/kernel.dylib" (sasb-source-hash) (sasb-dylib-hash) 0))
            (let dylib-base (sas-native-dylib-message "src/kernel.dylib" (sasb-source-hash) (sasb-dylib-hash) 1))
            (sasb-score
                (and (not (str_eq base kind))
                     (and (not (str_eq base version))
                          (and (not (str_eq base path))
                               (and (not (str_eq base source))
                                    (and (not (str_eq base content))
                                         (and (not (str_eq base bit))
                                              (not (str_eq dylib-base dylib-lowerable))))))))
                33554432)))
    (defn sasb-bit-mtime-insensitive ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (sasb-source-hash)))
            (let fkb1 (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) (sasb-fkb-good) 1))
            (let fkb2 (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 99 (sasb-source-vouch) (sasb-fkb-vouch) (sasb-fkb-good) 1))
            (let p1 (sap-plan-from-probe (sap-bundle source fkb1 (sap-native-dylib-observation "src/kernel.dylib" 0 -1 -1 "" "" 0 0 0 0))))
            (let p2 (sap-plan-from-probe (sap-bundle source fkb2 (sap-native-dylib-observation "src/kernel.dylib" 0 -1 -1 "" "" 0 0 0 0))))
            (sasb-score
                (and (str_eq (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1)
                             (sas-program-image-fkb-message "src/kernel.fkb" (sasb-source-hash) (sasb-fkb-hash) 1))
                     (and (str_eq (rap-plan-primary p1) (rap-act-run-program-image))
                          (str_eq (rap-plan-primary p2) (rap-act-compile-source))))
                67108864)))
    (defn sasb-bit-enrichment-matrix ()
        (do
            (let good (sasb-fkb-good))
            (let seal-bad (sasb-fkb-wrong-key))
            (let vouch-bad (sas-program-image-fkb-seal "src/kernel.fkb" (sasb-source-vouch-other) (sasb-fkb-vouch) 1 (sasb-key) (sasb-fkb-seal)))
            (let obs-good (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) good 1))
            (let obs-seal-bad (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) seal-bad 1))
            (let obs-vouch-bad (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch-other) (sasb-fkb-vouch) vouch-bad 1))
            (sasb-score
                (and (eq (sap-observation-seal-ok obs-good) 1)
                     (and (eq (sap-observation-seal-ok obs-seal-bad) 0)
                          (and (eq (sap-observation-seal-ok obs-vouch-bad) 0)
                               (str_eq (sap-observation-source-hash obs-vouch-bad) ""))))
                134217728)))
    (defn sasb-bit-fkb-routing ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (sasb-source-hash)))
            (let good (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) (sasb-fkb-good) 1))
            (let bad (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) (sasb-fkb-wrong-key) 1))
            (let p-good (sap-plan-from-probe (sap-bundle source good (sap-native-dylib-observation "src/kernel.dylib" 0 -1 -1 "" "" 0 0 0 0))))
            (let p-bad (sap-plan-from-probe (sap-bundle source bad (sap-native-dylib-observation "src/kernel.dylib" 0 -1 -1 "" "" 0 0 0 0))))
            (sasb-score
                (and (str_eq (rap-plan-primary p-good) (rap-act-run-program-image))
                     (str_eq (rap-plan-primary p-bad) (rap-act-compile-source)))
                268435456)))
    (defn sasb-bit-no-native-admission ()
        (do
            (let source (sap-source-observation "src/kernel.fk" 1 3 100 (sasb-source-hash)))
            (let fkb (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) (sasb-fkb-good) 1))
            (let dylib (sas-native-dylib-observation-from-seal "src/kernel.dylib" 1 5 102 (sasb-source-vouch) (sasb-dylib-vouch) (sasb-dylib-good) 0 0 1))
            (let p (sap-plan-from-probe (sap-bundle source fkb dylib)))
            (sasb-score
                (and (str_eq (rap-plan-primary p) (rap-act-run-program-image))
                     (not (str_eq (rap-plan-primary p) (rap-act-run-native))))
                536870912)))
    (defn sasb-bit-source-role-refusal ()
        (do
            (let r (sas-source-role-refusal "src/kernel.fk" (sasb-fkb-seal)))
            (let r2 (sas-artifact-seal (sap-role-source) "" "src/kernel.fk" (sasb-source-vouch) (sasb-fkb-vouch) 0 (sasb-key) (sasb-fkb-seal)))
            (let obs (sas-program-image-fkb-observation-from-seal "src/kernel.fkb" 1 3 101 (sasb-source-vouch) (sasb-fkb-vouch) r 1))
            (sasb-score
                (and (str_eq (sas-seal-status r) (sas-status-role-refused))
                     (and (str_eq (sas-seal-status r2) (sas-status-role-refused))
                          (eq (sap-observation-seal-ok obs) 0)))
                1073741824)))

    (defn source-artifact-seal-band ()
        (sum (list
            (sasb-bit-manifest-1)
            (sasb-bit-manifest-2)
            (sasb-bit-canonical-message)
            (sasb-bit-hmac-vector)
            (sasb-bit-row-match)
            (sasb-bit-negatives)
            (sasb-bit-field-sensitivity)
            (sasb-bit-mtime-insensitive)
            (sasb-bit-enrichment-matrix)
            (sasb-bit-fkb-routing)
            (sasb-bit-no-native-admission)
            (sasb-bit-source-role-refusal))))

    (source-artifact-seal-band))
