; native-model-session-world-band.fk -- streaming count-state semantics.
; The executable carrier supplies real session episodes; these fixed rows prove
; classification, count updates, chronological splitting, prediction,
; abstention, dataset/model identity, invalid-row accounting, and baseline
; comparison without granting the fixture any model authority.
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/native-model-evidence.fk form-stdlib/native-model-session-world.fk
;
; Verdict 4095.

(do
    (defn nmswb-row (n a b c)
        (nmsw-episode (int_to_str n) "session-digest" a b c))
    (let rows
        (list
            (nmswb-row 1 "exec_command" "apply_patch" "exec_command")
            (nmswb-row 2 "apply_patch" "exec_command" "exec_command")
            (nmswb-row 3 "exec_command" "exec_command" "apply_patch")
            (nmswb-row 4 "exec_command" "apply_patch" "exec_command")
            (nmswb-row 5 "apply_patch" "exec_command" "exec_command")
            (nmswb-row 6 "exec_command" "exec_command" "apply_patch")
            (nmswb-row 7 "exec_command" "apply_patch" "exec_command")
            (nmswb-row 8 "apply_patch" "exec_command" "exec_command")
            (nmswb-row 9 "exec_command" "apply_patch" "exec_command")
            (nmswb-row 10 "apply_patch" "exec_command" "exec_command")))
    (let report (nmsw-report rows 1))
    (let train (nmsw-take rows 8))
    (let model (nmsw-count-rows train (nmsw-empty-count-state)))
    (let seen (nmsw-predict-index model 0 1))
    (let unseen (nmsw-predict-index model 5 6))
    (let invalid
        (nmsw-count-observe model (nmswb-row 11 "" "exec_command" "wait")))
    (let c1 (if (str_eq (nmsw-class "exec_command") "observe") 1 0))
    (let c2 (if (str_eq (nmsw-class "apply_patch") "mutate") 2 0))
    (let c3 (if (eq (nth seen 0) 0) 4 0))
    (let c4 (if (gt (nth seen 1) 0) 8 0))
    (let c5 (if (eq (nth unseen 0) -1) 16 0))
    (let c6 (if (and (eq (nth report 1) 8) (eq (nth report 2) 2)) 32 0))
    (let c7 (if (eq (nth report 3) 2) 64 0))
    (let c8 (if (eq (nth report 7) 1000000) 128 0))
    (let c9 (if (and (nmfe-sha256? (nth report 12))
                     (nmfe-sha256? (nth report 13))) 256 0))
    (let c10 (if (and (eq (nth report 14) 1)
                       (eq (nth (nmsw-report rows 0) 14) 0)) 512 0))
    (let c11 (if (and (eq (nmsw-state-valid model) 8)
                       (eq (nmsw-state-invalid model) 0)) 1024 0))
    (let c12 (if (and (eq (nmsw-state-valid invalid) 8)
                       (eq (nmsw-state-invalid invalid) 1)) 2048 0))
    (sum (list c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12)))
