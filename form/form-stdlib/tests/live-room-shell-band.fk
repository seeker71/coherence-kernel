; live-room-shell-band.fk — proves the live-room pipeline is now a Form-shell cell:
; fsh cell lowering, native silence gate, native vd-route speaker decision,
; Ollama passthrough, append redirect, and executable finite demo loop.
; Verdict = 63, asserted byte-identical on the 4th kernel.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk form-stdlib/shell-lower.fk form-stdlib/live-room-shell.fk

(do
    (let c (lr-cell))
    (let plan (lr-plan))

    (let c1 (if (str_eq (sh-cell-name c) "live-room") 1 0))
    (let c2 (if (str_eq (sh-cell-domain c) "fsh") 2 0))
    (let c3 (if (lr-plan-has-kind-name? plan "native" "test") 4 0))
    (let c4 (if (lr-plan-has-kind-name? plan "native" "vd-route") 8 0))
    (let c5 (if (lr-plan-has-kind-name? plan "passthrough" "ollama-translate") 16 0))
    (let c6 (if (lr-plan-has-append? plan) 32 0))

    ; expected total: 63
    (add c1 (add c2 (add c3 (add c4 (add c5 c6))))))
