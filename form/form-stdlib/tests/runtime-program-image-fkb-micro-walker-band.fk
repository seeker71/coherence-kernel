    (defn runtime-program-image-fkb-micro-walker-band ()
        (sum (list
            (rpmwb-bit-manifest-1)
            (rpmwb-bit-manifest-2)
            (rpmwb-bit-version-row)
            (rpmwb-bit-lit)
            (rpmwb-bit-add)
            (rpmwb-bit-sub)
            (rpmwb-bit-mul)
            (rpmwb-bit-le-if)
            (rpmwb-bit-nested-entry)
            (rpmwb-bit-budget-timeout)
