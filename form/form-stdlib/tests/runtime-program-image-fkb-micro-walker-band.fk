            (rpmwb-bit-envelope-refusals)
            (rpmwb-bit-admission-refusals)
            (rpmwb-bit-decode-and-identity-refusals)
            (rpmwb-bit-trace-fields)
            (rpmwb-bit-reason-coverage)
            (rpmwb-bit-static-source)
            (rpmwb-bit-architecture-receipt)
            (rpmwb-bit-downstream-trace-compatible)
            (rpmwb-bit-result-accessors)
            (rpmwb-bit-admission-pif-source)
            (rpmwb-bit-no-fake-output-on-failure))))

    (runtime-program-image-fkb-micro-walker-band))
