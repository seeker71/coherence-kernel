(do
    (defn rpmwb-score (ok bit) (if ok bit 0))
    (defn rpmwb-manifest-has (name)
        (runtime-program-image-fkb-micro-walker-manifest-has? name (runtime-program-image-fkb-micro-walker-manifest)))
    (defn rpmwb-has? (text needle)
        (if (str_eq (value_kind text) "string")
            (ge (str_find text needle 0) 0)
            0))
    (defn rpmwb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn rpmwb-source-hash () "sha:src-42")
    (defn rpmwb-content-hash () "sha:content-42")
    (defn rpmwb-artifact-path () "cache/micro.fkb")

    (defn rpmwb-nodes ()
        (list
            (pif-node-row 1 42 0 0)
            (pif-node-row 1 40 0 0)
            (pif-node-row 1 2 0 0)
            (pif-node-row 3 1 2 0)
            (pif-node-row 1 50 0 0)
            (pif-node-row 1 8 0 0)
            (pif-node-row 4 4 5 0)
            (pif-node-row 1 6 0 0)
            (pif-node-row 1 7 0 0)
            (pif-node-row 42 7 8 0)
            (pif-node-row 1 1 0 0)
            (pif-node-row 2 0 0 0)
            (pif-node-row 5 11 10 0)
            (pif-node-row 1 111 0 0)
            (pif-node-row 1 222 0 0)
            (pif-node-row 6 12 13 14)
            (pif-node-row 99 0 0 0)
            (pif-node-row 3 0 99 0)
            (pif-node-row 3 3 9 0)))
    (defn rpmwb-roots ()
        (list 0 3 6 9 15 18 16 17))
    (defn rpmwb-table ()
        (pif-table-image (len (rpmwb-roots))
                         (rpmwb-roots)
                         (len (rpmwb-nodes))
                         (rpmwb-nodes)
                         0
                         (empty)))
    (defn rpmwb-pif ()
        (pif-envelope "src/micro.fk" (rpmwb-source-hash) 100
                      (rpmwb-artifact-path) (rpmwb-content-hash) 101
                      1
                      (rpmwb-table)))
    (defn rpmwb-bad-root-pif ()
        (pif-envelope "src/micro.fk" (rpmwb-source-hash) 100
                      (rpmwb-artifact-path) (rpmwb-content-hash) 101
                      1
                      (pif-table-image 1 (list 99) 1 (list (pif-node-row 1 42 0 0)) 0 (empty))))
    (defn rpmwb-invalid-pif ()
        (pif-envelope "src/micro.fk" (rpmwb-source-hash) 100
                      (rpmwb-artifact-path) (rpmwb-content-hash) 101
                      0
                      (rpmwb-table)))
    (defn rpmwb-other-pif ()
        (pif-envelope "src/micro.fk" (rpmwb-source-hash) 100
                      "cache/other.fkb" "sha:other" 101
                      1
                      (rpmwb-table)))
    (defn rpmwb-source-for-pif (pif) (pif-source-from-envelope pif))
    (defn rpmwb-fkb-for-pif (pif) (pif-descriptor-from-envelope pif))
    (defn rpmwb-envelope-for-pif (pif)
        (do
            (let src (rpmwb-source-for-pif pif))
            (let fkb (rpmwb-fkb-for-pif pif))
            (rale-envelope-from-selection
                src fkb (sad-no-artifact)
                (ras-selection-from-plan
                    (rap-plan-from-descriptors src fkb (sad-no-artifact))))))
    (defn rpmwb-envelope () (rpmwb-envelope-for-pif (rpmwb-pif)))
    (defn rpmwb-non-program-envelope ()
        (rale-envelope (pif-source-from-envelope (rpmwb-pif))
                       (sad-no-artifact)
                       (rap-act-compile-source)
                       (sac-run-source-compile)
                       "none"
                       ""
                       (rpmwb-source-hash)
                       ""
                       (list "selection")
                       (rale-no-retry)
                       (rale-no-compile-output)
                       (rale-status-request-ready)
                       "synthetic-compile-source-envelope"))
    (defn rpmwb-payload-for-pif (pif)
        (pifbd-payload (pif-envelope-source-path pif)
                       (pif-envelope-source-hash pif)
                       (pif-envelope-source-mtime pif)
                       (pif-envelope-artifact-path pif)
                       (pif-envelope-seal-ok pif)
                       (pif-envelope-table pif)
                       (pif-envelope-symbol-image pif)))
    (defn rpmwb-decode-for-pif (pif) (pifbd-decoded-row (rpmwb-payload-for-pif pif) 123))
    (defn rpmwb-admission-for-pif (pif)
        (pifbd-admission (list "runtime-program-image-fkb-micro-walker-synthetic-admission")
                         (rpmwb-decode-for-pif pif)
                         pif
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))
    (defn rpmwb-admission () (rpmwb-admission-for-pif (rpmwb-pif)))
    (defn rpmwb-non-admitted-admission ()
        (pifbd-admission (list "non-admitted")
