                         (pifbd-reason-admitted)))
    (defn rpmwb-decode-mismatch-admission ()
        (pifbd-admission (list "decode-mismatch")
                         (rpmwb-decode-for-pif (rpmwb-other-pif))
                         (rpmwb-pif)
                         (pifbd-status-admitted)
                         (pifbd-reason-admitted)))

    (defn rpmwb-walk (entry budget input)
