import "../active-learning-tier-cycle.fk"
; Local held-out error: 10 - 3v. Native held-out error: 12 - 2v.
; threshold=1, minimum three variants, bounded search=20.
(do
  (let result (alt-simulate 20 12 2 10 3 1 3))
  (list result
    (if (and (eq (nth result 0) 3)
      (and (eq (nth result 1) 6)
      (and (eq (nth result 2) 3)
      (and (eq (nth result 5) 0)
      (and (eq (nth result 7) 0)
           (eq (nth (nth result 4) 2) 3)))))) 1 0)))
