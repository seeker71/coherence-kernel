; runtime-artifact-executor-capability-band.fk -- Layer 9g capability witness.
;
; Expected: 2147483647
;
; This band proves executor capability/readiness rows over supplied capability
; evidence and 9e envelopes. It does not produce 9f attempts or 9c
; observations, read disk, hash bytes, reverify seals/proofs or callability,
; load or walk `.fkb`, load or call `.dylib`, execute source/native code,
; choose fallback, retry, decide admission, install a selector, or grow the C
; seed.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/runtime-artifact-executor-capability.fk

(do
    (defn raecb-score (ok bit) (if ok bit 0))
    (defn raecb-manifest-has (name)
        (runtime-artifact-executor-capability-manifest-has? name (runtime-artifact-executor-capability-manifest)))

    (defn raecb-source () (sad-source "src/kernel.fk" "sha:src-a" 100))
    (defn raecb-fkb-fresh ()
        (sad-program-image-fkb (sad-version-program-image-fkb) "src/kernel.fkb" "sha:src-a" "sha:fkb-a" 101 1 1))
    (defn raecb-dylib-fresh ()
        (sad-native-dylib (sad-version-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a" 102 1 1 1 1))
    (defn raecb-native-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raecb-source) (raecb-fkb-fresh) (raecb-dylib-fresh))))
    (defn raecb-fkb-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raecb-source) (raecb-fkb-fresh) (sad-no-artifact))))
    (defn raecb-compile-selection ()
        (ras-selection-from-plan (rap-plan-from-descriptors (raecb-source) (sad-no-artifact) (sad-no-artifact))))
    (defn raecb-native-envelope ()
        (rale-envelope-from-selection (raecb-source) (raecb-fkb-fresh) (raecb-dylib-fresh) (raecb-native-selection)))
    (defn raecb-fkb-envelope ()
        (rale-envelope-from-selection (raecb-source) (raecb-fkb-fresh) (sad-no-artifact) (raecb-fkb-selection)))
    (defn raecb-compile-envelope ()
        (rale-envelope-from-selection (raecb-source) (sad-no-artifact) (sad-no-artifact) (raecb-compile-selection)))
    (defn raecb-investigate-envelope ()
        (rale-envelope-from-selection
            (raecb-source)
            (raecb-fkb-fresh)
            (sad-no-artifact)
            (ras-selection (sad-route-invalid) (rap-act-investigate) (rap-act-none) (ras-status-investigate) 0 0 (ras-reason-upstream-investigate))))
    (defn raecb-refused-envelope ()
        (rale-envelope-from-selection
            (raecb-source)
            (raecb-fkb-fresh)
            (sad-no-artifact)
            (ras-selection (sad-route-invalid) (rap-act-none) (rap-act-none) (ras-status-refused) 0 0 (ras-reason-malformed-plan))))

    (defn raecb-cap-for-envelope (e name)
        (raec-capability name
                         (rale-envelope-action e)
                         (rale-envelope-route e)
                         (rale-envelope-artifact-kind e)
                         (raec-availability-available)
                         (raec-evidence-supplied-current)
                         (raec-authority-attempt-supplier)
                         (raec-freshness-current)
                         "supplied-current-capability"))
    (defn raecb-native-cap ()
        (raecb-cap-for-envelope (raecb-native-envelope) (raec-cap-native-dylib-caller)))
    (defn raecb-fkb-cap ()
        (raecb-cap-for-envelope (raecb-fkb-envelope) (raec-cap-program-image-walker)))
    (defn raecb-source-cap ()
        (raecb-cap-for-envelope (raecb-compile-envelope) (raec-cap-source-compiler-front-door)))
    (defn raecb-status? (r status) (str_eq (raec-readiness-status r) status))
    (defn raecb-reason? (r reason) (str_eq (raec-readiness-reason r) reason))
    (defn raecb-ready? (r) (raecb-status? r (raec-status-ready)))
    (defn raecb-no-rao? (r)
        (not (str_eq (nth r 0) "runtime-artifact-run-observation")))

    (defn raecb-bit-manifest-1 ()
        (sum (list
            (raecb-score (eq (raecb-manifest-has "executor-capability-not-execution") 1) 1)
            (raecb-score (eq (raecb-manifest-has "supplied-capability-rows-only") 1) 2)
            (raecb-score (eq (raecb-manifest-has "ready-is-not-execution-success") 1) 4)
            (raecb-score (eq (raecb-manifest-has "closed-action-route-kind-table") 1) 8)
            (raecb-score (eq (raecb-manifest-has "future-9h-consumes-ready") 1) 16)
            (raecb-score (eq (raecb-manifest-has "no-9f-attempt-or-rao-observation") 1) 32)
            (raecb-score (eq (raecb-manifest-has "unavailable-for-no-matching-capability") 1) 64)
            (raecb-score (eq (raecb-manifest-has "investigate-for-stale-or-inadequate-evidence") 1) 128))))

    (defn raecb-bit-manifest-2 ()
        (sum (list
            (raecb-score (eq (raecb-manifest-has "refused-for-malformed-or-forbidden-authority") 1) 256)
            (raecb-score (eq (raecb-manifest-has "current-floor-fkb-dylib-unavailable") 1) 512)
            (raecb-score (eq (raecb-manifest-has "no-disk-io") 1) 1024)
            (raecb-score (eq (raecb-manifest-has "no-byte-hashing") 1) 2048)
            (raecb-score (eq (raecb-manifest-has "no-seal-proof-callable-reverify") 1) 4096)
            (raecb-score (eq (raecb-manifest-has "no-fkb-walk-or-dylib-call") 1) 8192)
            (raecb-score (eq (raecb-manifest-has "no-admission-policy-or-selector-install") 1) 16384)
            (raecb-score (eq (raecb-manifest-has "no-c-seed-growth") 1) 32768))))

    (defn raecb-bit-native-ready ()
        (do
            (let e (raecb-native-envelope))
            (let r (raec-readiness-from-envelope-capability e (raecb-native-cap)))
            (raecb-score
                (and (raecb-ready? r)
                     (and (str_eq (raec-readiness-required-capability r) (raec-cap-native-dylib-caller))
                          (and (str_eq (raec-readiness-action r) (rap-act-run-native))
                               (eq (raec-readiness-route r) (sac-run-dylib)))))
                65536)))

    (defn raecb-bit-fkb-ready ()
        (do
            (let e (raecb-fkb-envelope))
            (let r (raec-readiness-from-envelope-capability e (raecb-fkb-cap)))
            (raecb-score
                (and (raecb-ready? r)
                     (and (str_eq (raec-readiness-required-capability r) (raec-cap-program-image-walker))
                          (and (str_eq (raec-readiness-artifact-kind r) (sad-kind-program-image-fkb))
                               (str_eq (raec-readiness-action r) (rap-act-run-program-image)))))
                131072)))

    (defn raecb-bit-source-ready ()
        (do
            (let e (raecb-compile-envelope))
            (let r (raec-readiness-from-envelope-capability e (raecb-source-cap)))
            (raecb-score
                (and (raecb-ready? r)
                     (and (str_eq (raec-readiness-required-capability r) (raec-cap-source-compiler-front-door))
                          (and (str_eq (raec-readiness-artifact-kind r) (rale-kind-source))
                               (str_eq (raec-readiness-action r) (rap-act-compile-source)))))
                262144)))

    (defn raecb-bit-no-capability-unavailable ()
        (do
            (let r (raec-readiness-from-envelope-no-capability (raecb-native-envelope)))
            (raecb-score
                (and (raecb-status? r (raec-status-unavailable))
                     (and (raecb-reason? r (raec-reason-no-capability-supplied))
                          (str_eq (raec-readiness-required-capability r) (raec-cap-native-dylib-caller))))
                524288)))

    (defn raecb-bit-current-floor-unavailable ()
        (do
            (let n (raec-readiness-from-envelope-capability (raecb-native-envelope) (raec-current-floor-native-unavailable)))
            (let f (raec-readiness-from-envelope-capability (raecb-fkb-envelope) (raec-current-floor-program-image-unavailable)))
            (raecb-score
                (and (raecb-status? n (raec-status-unavailable))
                     (and (raecb-status? f (raec-status-unavailable))
                          (and (str_eq (raec-readiness-evidence-kind n) (raec-evidence-current-floor-unavailable))
                               (and (str_eq (raec-readiness-detail f) "2026-07-03-form-fs-read-bytes-canary-0")
                                    (raecb-reason? f (raec-reason-capability-unavailable))))))
                1048576)))

    (defn raecb-bit-stale-and-inadequate-investigate ()
        (do
            (let e (raecb-native-envelope))
            (let stale (raec-capability (raec-cap-native-dylib-caller) (rap-act-run-native) (sac-run-dylib) (sad-kind-native-dylib)
                                        (raec-availability-available) (raec-evidence-supplied-stale)
                                        (raec-authority-attempt-supplier) (raec-freshness-current) "stale-supplied-row"))
            (let weak (raec-capability (raec-cap-native-dylib-caller) (rap-act-run-native) (sac-run-dylib) (sad-kind-native-dylib)
                                       (raec-availability-unknown) (raec-evidence-inadequate)
                                       (raec-authority-attempt-supplier) (raec-freshness-unknown) "inadequate-supplied-row"))
            (let sr (raec-readiness-from-envelope-capability e stale))
            (let wr (raec-readiness-from-envelope-capability e weak))
            (raecb-score
                (and (raecb-status? sr (raec-status-investigate))
                     (and (raecb-reason? sr (raec-reason-capability-stale))
                          (and (raecb-status? wr (raec-status-investigate))
                               (raecb-reason? wr (raec-reason-evidence-inadequate)))))
                2097152)))

    (defn raecb-bit-refused-forbidden-and-malformed ()
        (do
            (let e (raecb-native-envelope))
            (let forbid (raec-capability (raec-cap-native-dylib-caller) (rap-act-run-native) (sac-run-dylib) (sad-kind-native-dylib)
                                         (raec-availability-available) (raec-evidence-supplied-current)
                                         (raec-authority-forbidden-execution) (raec-freshness-current) "claims-execution-here"))
            (let fr (raec-readiness-from-envelope-capability e forbid))
            (let mr (raec-readiness-from-envelope-capability e (list "runtime-artifact-executor-capability" 1)))
            (raecb-score
                (and (raecb-status? fr (raec-status-refused))
                     (and (raecb-reason? fr (raec-reason-forbidden-authority))
                          (and (raecb-status? mr (raec-status-refused))
                               (raecb-reason? mr (raec-reason-malformed-capability)))))
                4194304)))

    (defn raecb-bit-mismatch-unavailable ()
        (do
            (let e (raecb-native-envelope))
            (let name (raec-capability (raec-cap-program-image-walker) (rap-act-run-native) (sac-run-dylib) (sad-kind-native-dylib)
                                       (raec-availability-available) (raec-evidence-supplied-current)
                                       (raec-authority-attempt-supplier) (raec-freshness-current) "wrong-name"))
            (let action (raec-capability (raec-cap-native-dylib-caller) (rap-act-run-program-image) (sac-run-dylib) (sad-kind-native-dylib)
                                         (raec-availability-available) (raec-evidence-supplied-current)
                                         (raec-authority-attempt-supplier) (raec-freshness-current) "wrong-action"))
            (let route (raec-capability (raec-cap-native-dylib-caller) (rap-act-run-native) (sac-run-fkb) (sad-kind-native-dylib)
                                        (raec-availability-available) (raec-evidence-supplied-current)
                                        (raec-authority-attempt-supplier) (raec-freshness-current) "wrong-route"))
            (let kind (raec-capability (raec-cap-native-dylib-caller) (rap-act-run-native) (sac-run-dylib) (sad-kind-program-image-fkb)
                                       (raec-availability-available) (raec-evidence-supplied-current)
                                       (raec-authority-attempt-supplier) (raec-freshness-current) "wrong-kind"))
            (let nr (raec-readiness-from-envelope-capability e name))
            (let ar (raec-readiness-from-envelope-capability e action))
            (let rr (raec-readiness-from-envelope-capability e route))
            (let kr (raec-readiness-from-envelope-capability e kind))
            (raecb-score
                (and (raecb-status? nr (raec-status-unavailable))
                     (and (raecb-reason? nr (raec-reason-capability-name-mismatch))
                          (and (raecb-reason? ar (raec-reason-capability-action-mismatch))
                               (and (raecb-reason? rr (raec-reason-capability-route-mismatch))
                                    (raecb-reason? kr (raec-reason-capability-kind-mismatch))))))
                8388608)))

    (defn raecb-bit-terminal-envelopes ()
        (do
            (let i (raec-readiness-from-envelope-capability (raecb-investigate-envelope) (raecb-fkb-cap)))
            (let f (raec-readiness-from-envelope-capability (raecb-refused-envelope) (raecb-fkb-cap)))
            (raecb-score
                (and (raecb-status? i (raec-status-investigate))
                     (and (raecb-reason? i (raec-reason-envelope-investigates))
                          (and (raecb-status? f (raec-status-refused))
                               (raecb-reason? f (raec-reason-envelope-refused)))))
                16777216)))

    (defn raecb-bit-nonready-and-malformed-envelope ()
        (do
            (let e (rale-envelope (raecb-source) (sad-no-artifact) (rap-act-run-native) (sac-run-dylib)
                                  (sad-kind-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a"
                                  (raecb-native-selection) (rale-no-retry) (rale-no-compile-output)
                                  "surprise-status" "surprise"))
            (let n (raec-readiness-from-envelope-capability e (raecb-native-cap)))
            (let m (raec-readiness-from-envelope-capability (list "runtime-artifact-load-envelope" 1) (raecb-native-cap)))
            (raecb-score
                (and (raecb-status? n (raec-status-investigate))
                     (and (raecb-reason? n (raec-reason-non-ready-envelope))
                          (and (raecb-status? m (raec-status-refused))
                               (raecb-reason? m (raec-reason-malformed-envelope)))))
                33554432)))

    (defn raecb-bit-unsupported-envelope ()
        (do
            (let e (rale-envelope (raecb-source) (sad-no-artifact) (rap-act-run-native) (sac-run-fkb)
                                  (sad-kind-native-dylib) "src/kernel.dylib" "sha:src-a" "sha:dylib-a"
                                  (raecb-native-selection) (rale-no-retry) (rale-no-compile-output)
                                  (rale-status-request-ready) "hand-built-unsupported"))
            (let r (raec-readiness-from-envelope-capability e (raecb-native-cap)))
            (raecb-score
                (and (raecb-status? r (raec-status-investigate))
                     (raecb-reason? r (raec-reason-unsupported-envelope)))
                67108864)))

    (defn raecb-bit-ready-not-execution ()
        (do
            (let r (raec-readiness-from-envelope-capability (raecb-native-envelope) (raecb-native-cap)))
            (raecb-score
                (and (raecb-ready? r)
                     (and (raec-readiness? r)
                          (and (raecb-no-rao? r)
                               (not (str_eq (raec-readiness-status r) (rao-status-complete))))))
                134217728)))

    (defn raecb-bit-evidence-fields ()
        (do
            (let r (raec-readiness-from-envelope-capability (raecb-native-envelope) (raecb-native-cap)))
            (let f (raec-readiness-from-envelope-capability (raecb-fkb-envelope) (raec-current-floor-program-image-unavailable)))
            (raecb-score
                (and (str_eq (raec-readiness-evidence-kind r) (raec-evidence-supplied-current))
                     (and (str_eq (raec-readiness-authority r) (raec-authority-attempt-supplier))
                          (and (str_eq (raec-readiness-freshness r) (raec-freshness-current))
                               (str_eq (raec-readiness-detail f) "2026-07-03-form-fs-read-bytes-canary-0"))))
                268435456)))

    (defn raecb-bit-idempotent ()
        (do
            (let e (raecb-native-envelope))
            (let c (raecb-native-cap))
            (let a (raec-readiness-from-envelope-capability e c))
            (let b (raec-readiness-from-envelope-capability e c))
            (raecb-score
                (and (str_eq (raec-readiness-status a) (raec-readiness-status b))
                     (and (str_eq (raec-readiness-reason a) (raec-readiness-reason b))
                          (and (str_eq (raec-readiness-required-capability a) (raec-readiness-required-capability b))
                               (eq (raec-readiness-route a) (raec-readiness-route b)))))
                536870912)))

    (defn raecb-bit-closed-table ()
        (raecb-score
            (and (str_eq (raec-required-capability-for (rap-act-run-native) (sac-run-dylib) (sad-kind-native-dylib)) (raec-cap-native-dylib-caller))
                 (and (str_eq (raec-required-capability-for (rap-act-run-program-image) (sac-run-fkb) (sad-kind-program-image-fkb)) (raec-cap-program-image-walker))
                      (and (str_eq (raec-required-capability-for (rap-act-compile-source) (sac-run-source-compile) (rale-kind-source)) (raec-cap-source-compiler-front-door))
                           (eq (str_len (raec-required-capability-for (rap-act-run-native) (sac-run-fkb) (sad-kind-native-dylib))) 0))))
            1073741824))

    (defn runtime-artifact-executor-capability-band ()
        (sum (list
            (raecb-bit-manifest-1)
            (raecb-bit-manifest-2)
            (raecb-bit-native-ready)
            (raecb-bit-fkb-ready)
            (raecb-bit-source-ready)
            (raecb-bit-no-capability-unavailable)
            (raecb-bit-current-floor-unavailable)
            (raecb-bit-stale-and-inadequate-investigate)
            (raecb-bit-refused-forbidden-and-malformed)
            (raecb-bit-mismatch-unavailable)
            (raecb-bit-terminal-envelopes)
            (raecb-bit-nonready-and-malformed-envelope)
            (raecb-bit-unsupported-envelope)
            (raecb-bit-ready-not-execution)
            (raecb-bit-evidence-fields)
            (raecb-bit-idempotent)
            (raecb-bit-closed-table))))

    (runtime-artifact-executor-capability-band))
