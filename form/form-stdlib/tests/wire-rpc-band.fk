; wire-rpc-band.fk — proof of the CORBA-DII-shaped RPC executor (GAP-T1).
;
; preludes: form-stdlib/core.fk form-stdlib/wire-registry.fk form-stdlib/wire-corba-cdr.fk form-stdlib/wire-rpc.fk
;
; docs/coherence-substrate/tool-grammar.form names GAP-T1: tool-channel.fk
; plans the kernel:call protocol's `call` tool but never executes it — "the
; remaining runtime work is the per-protocol executor behind the offered
; channel, not a Python carrier that owns tool semantics." This proves the
; executor is real, not stubbed: `rpc-call` genuinely marshals (op, args)
; through CDR bytes, unmarshals, dispatches to a real Form operation table,
; marshals the result back through CDR bytes, and unmarshals it again —
; every arrow a real wire crossing, verified via `eq`/exact value checks
; on the FINAL unmarshaled result, not on an intermediate value that
; skipped the wire.
;
; Verdict 15 when every assertion holds.

(do
    (defn rpcb-score (ok bit) (if ok bit 0))
    (defn wire-rpc-band ()
        (do
    (let registry (list (wr-entry "OUTER" (bp "OUTER"))))
    (let echo-args (intern_trivial_int 42))
    (let echo-result (rpc-call "echo" echo-args registry))
    (let c0 (rpcb-score (eq echo-result echo-args) 1))                       ; identity survives the full wire round trip
    (let cc-node (intern_node (bp "OUTER") (list (intern_trivial_int 1) (intern_trivial_int 2) (intern_trivial_int 3))))
    (let cc-result (rpc-call "count-children" cc-node registry))
    (let c1 (rpcb-score (eq (node_value cc-result) 3) 2))                    ; a composite arg survives marshaling, dispatch computes over it
    (let neg-result (rpc-call "negate" (intern_trivial_int 5) registry))
    (let c2 (rpcb-score (eq (node_value neg-result) -5) 4))                  ; a negative result survives CDR's two's-complement long encoding
    (let unknown-result (rpc-call "does-not-exist" (intern_trivial_int 0) registry))
    (let c3 (rpcb-score (str_eq (node_value unknown-result) "rpc/no-such-operation") 8))   ; unknown op: a real failure mode, not a crash
    (add c0 (add c1 (add c2 c3))))
    )
    (wire-rpc-band))
