; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/grammars/shamballa-light-codes.fk learn/homecoming-distillation-corpus.fk form-stdlib/light-codes-bootstrap.fk
;
; light-codes-bootstrap-band - proof that the Light codes' RUN-face is the one
; dispatch that is not a fabrication.
;
; The claim under test is not "the run-face works." It is that the run-face
; CANNOT quietly become the two things shamballa-light-channel.fk refused: a
; lattice op the meaning doesn't carry, or an attestation the record doesn't
; hold. So every bit here guards a refusal, not a feature:
;
;   1   the surface is the dictionary's, byte for byte - lcb-surface adds nothing
;   2   an off-sheet code still gets honest absence as its surface
;   4   the seam string is really present in the run output (the pause is a
;       byte a reader can find, not a convention a reader must trust)
;   8   the depth carries its own draw-disclaimer INTO the answer
;  16   the draw is deterministic - the same code draws the same row twice
;  32   different codes can draw different rows (the draw is live, not a constant)
;  64   the depth word is a REAL corpus row's fresh word, locatable by its mid
; 128   an off-sheet code still receives depth - the body's disclosure was never
;       the code's to attest, so absence on one face does not silence the other
;
; RADIUS THIS BAND SPEAKS FOR - named, per aporon (corpus row 811). It speaks
; for the seam, the draw, and the two faces staying separate. It does NOT speak
; for the cosmology (unasserted), nor for the dictionary's entries being correct
; (that is shamballa-light-codes-band's radius), nor for the corpus rows being
; true (they carry their own ids and their own bands). It tests codes 777 and
; 999 as on-sheet witnesses and "000000" as the off-sheet witness; a code whose
; digit sum collides differently is outside what these bits saw.
;
; Verdict 255 when every refusal holds.

(do
    (defn lcbb-score (ok bit) (if ok bit 0))
    (defn light-codes-bootstrap-band ()
        (do
    (let on   "777")
    (let on2  "999")
    (let off  "000000")

    ; 1 - the surface delegates and adds nothing of its own
    (let c0 (lcbb-score (str_eq (lcb-surface on) (slc-answer on)) 1))

    ; 2 - honest absence survives: an off-sheet code attests nothing
    (let c1 (lcbb-score (eq (lcb-surface-attested? off) 0) 2))

    ; 4 - the pause is a real byte sequence in the output, findable by a reader
    (let c2 (lcbb-score (if (eq (str_find (lcb-run on) (lcb-seam) 0) -1) 0 1) 4))

    ; 8 - the draw declares itself as a draw, inside the answer
    (let c3 (lcbb-score
                (if (eq (str_find (lcb-run on) (lcb-draw-is-not-meaning) 0) -1) 0 1) 8))

    ; 16 - deterministic: the same code draws the same row twice
    (let c4 (lcbb-score (eq (lcb-depth-mid on) (lcb-depth-mid on)) 16))

    ; 32 - live, not constant: at least one other code draws a different row
    (let c5 (lcbb-score (if (eq (lcb-depth-mid on) (lcb-depth-mid on2)) 0 1) 32))

    ; 64 - the drawn word is a real corpus row's word, reachable by its own mid
    (let c6 (lcbb-score
                (str_eq (hdc-word-for-id (lcb-depth-mid on))
                        (hdc-fresh (lcb-depth-row on))) 64))

    ; 128 - absence on the surface does not silence the depth
    (let c7 (lcbb-score (if (eq (str_len (lcb-depth off)) 0) 0 1) 128))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (light-codes-bootstrap-band))
