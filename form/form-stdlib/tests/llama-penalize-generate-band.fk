; preludes: form-stdlib/core.fk form-stdlib/transformer-numerics.fk form-stdlib/trig.fk form-stdlib/llama-numerics.fk form-stdlib/rope.fk form-stdlib/transformer-block.fk form-stdlib/transformer-mh.fk form-stdlib/gqa-attn.fk form-stdlib/llama-block.fk form-stdlib/llama-gqa-block.fk form-stdlib/kv-cache.fk form-stdlib/kv-llama-block.fk form-stdlib/kv-gqa-llama-block.fk form-stdlib/multi-layer-stack.fk form-stdlib/gqa-multi-layer-stack.fk form-stdlib/greedy-decode.fk form-stdlib/llama-generate.fk form-stdlib/sampling.fk form-stdlib/penalties.fk form-stdlib/llama-sample-generate.fk form-stdlib/llama-penalize-generate.fk
;
; llama-penalize-generate-band — the llama (decoder-only, GQA) autoregressive PENALIZED-SAMPLED loop
; lifted to the four-kernel floor: the sampled loop (#3654) with a MEMORY of what it emitted, so a local
; llama stops looping. Wires the four-way token repetition penalties (penalties.fk, #3677, pen-apply over
; the last-n window) into the four-way sampled generation loop — the named next stone from #3677's receipt.
;
; Grounded two ways (the llama-sample-generate-band discipline):
;   (A) EQUIVALENCE to loops already proven four-way: the penalty (penalty_repeat=1, penalty_freq=0,
;       penalty_present=0) is the IDENTITY, so lg-generate-penalized(1,0,0) == lg-generate-sampled (#3654)
;       for any seed/t/k; with k=1 that further reduces to greedy lg-generate (#3649). A window of win=0 is
;       the empty window, identity even with big knobs. These reductions ground the whole penalized
;       stack+logits+penalty+filter+selection by equivalence — no new reference, including REAL GQA
;       (n_q=2 n_kv=1 theta-500000).
;   (B) The genuine PENALTY path (the new behavior): with a repetition penalty active the loop that would
;       emit [0,1,1,1,1] (token 1 forever) breaks the loop — penalized k=1 (pr=100) generate(seed [0,1],3)
;       = [0,1,3,3,3] (step-0 argmax flips 1->3). The drawn tokens, the frequency-scales-with-count
;       ordering, and the single-step compose are pinned against the independent libm+llama.cpp reference
;       scripts/llama_penalize_generate_reference.py (self-checked to reproduce causal-attention-band's
;       pins 1893731/-1069281/1648117, MINSTD's published seq, and the penalty identity).
;
; The embed/unembed table is tied and chosen so embed([0,1]) == the band's published x fixture (identical
; fixture to llama-sample-generate-band), so the stack inside the loop reuses the already-four-way pins.
;
; Verdict 255 when the llama GQA PENALIZED-SAMPLED generation loop lands four-way:
;   1    pid == su             (CONSOLIDATION A single-head cfg10: identity penalty (1,0,0) == lg-generate-sampled, genuine draw k=V)
;   2    pgq == sgq            (CONSOLIDATION A REAL GQA n_q=2 n_kv=1 theta-500000: identity penalty == lg-generate-sampled — grouped)
;   4    pk1 == g3             (CONSOLIDATION B: identity penalty + k=1 == greedy [0,1,1,1,1] — peaked draw reduces to argmax)
;   8    pw0 == g3             (WINDOW: win=0 empty window == greedy even with (pr=100,pf=5,pp=5) — nothing counted)
;   16   pnl == [0,1,3,3,3]    (NON-LOOPING: penalized k=1 (pr=100) breaks [0,1,1,1,1]; step-0 argmax flips 1->3 — pinned to reference)
;   32   d1 == dref            (the loop's full-trio penalized step-1 draw == smp-sample(lgsp-probs, uniform(minstd seed)): no double-advance)
;   64   r1>p1c1 && p1c1>p1c2  (FREQUENCY scales with the window count: raw logit[1] > freq count-1 > freq count-2 — count*penalty_freq)
;   128  dA != dB             (INPUT-DEPENDENCE: same penalty + PRNG seed, prompt [0,1] -> 1 vs [1,0] -> 0 — selection follows the prompt)
(do
    ; --- flat int-list equality ---
    (defn ls-ieq (a b)
      (if (eq (len a) 0) (if (eq (len b) 0) 1 0)
          (if (eq (len b) 0) 0
              (if (eq (head a) (head b)) (ls-ieq (tail a) (tail b)) 0))))
    ; --- element at index 1 ---
    (defn at1 (xs) (head (tail xs)))

    ; --- layer 0: the causal-attention-band / llama-block-band fixture (d=4) ---
    (let g1 (list 0.9 1.1 1.0 0.95))   (let g2 (list 1.05 0.95 1.0 0.9))
    (let wq (list (list 0.5 -0.25 0.1 0.3) (list 0.2 0.4 -0.3 0.1) (list -0.1 0.2 0.5 -0.2) (list 0.3 0.0 -0.15 0.25)))
    (let wk (list (list 0.2 0.4 -0.3 0.1) (list 0.3 -0.2 0.25 0.5) (list 0.1 0.15 -0.05 0.2) (list -0.25 0.3 0.4 -0.1)))
    (let wv (list (list 0.3 -0.2 0.25 0.5) (list 0.6 0.1 -0.2 0.4) (list 0.05 -0.1 0.3 0.2) (list 0.15 0.35 -0.25 0.1)))
    (let wo (list (list 0.6 0.1 -0.2 0.4) (list -0.2 0.4 0.3 0.1) (list 0.25 -0.15 0.5 0.05) (list 0.1 0.2 -0.3 0.45)))
    (let wg (list (list 0.5 -0.3 0.2 0.1) (list 0.2 0.7 -0.4 0.3) (list -0.1 0.25 0.4 -0.2) (list 0.3 0.1 -0.15 0.5)))
    (let wu (list (list 0.25 -0.15 0.3 0.05) (list 0.1 0.4 -0.2 0.15) (list 0.35 0.2 -0.1 0.25) (list -0.2 0.3 0.15 0.4)))
    (let wd (list (list 0.4 -0.2 0.3 0.1) (list 0.15 0.5 -0.25 0.2) (list -0.3 0.1 0.45 -0.15) (list 0.2 -0.1 0.35 0.3)))
    ; --- layer 1: a SECOND, distinct weight bundle ---
    (let g1b (list 1.0 0.9 1.05 1.1))  (let g2b (list 0.95 1.1 0.9 1.0))
    (let wqb (list (list 0.1 0.3 -0.2 0.4) (list -0.3 0.2 0.5 -0.1) (list 0.4 -0.1 0.2 0.3) (list 0.0 0.25 -0.35 0.15)))
    (let wkb (list (list 0.3 -0.2 0.4 0.1) (list 0.15 0.5 -0.1 0.2) (list -0.05 0.3 0.25 -0.15) (list 0.4 -0.25 0.1 0.35)))
    (let wvb (list (list 0.2 0.4 -0.15 0.3) (list 0.5 -0.1 0.2 0.45) (list -0.2 0.35 0.1 -0.05) (list 0.25 0.15 -0.3 0.2)))
    (let wob (list (list 0.4 -0.3 0.2 0.5) (list 0.1 0.45 -0.15 0.2) (list -0.25 0.3 0.4 0.05) (list 0.35 -0.1 0.25 -0.2)))
    (let wgb (list (list 0.3 0.2 -0.4 0.1) (list 0.5 -0.3 0.15 0.25) (list -0.1 0.4 0.3 -0.2) (list 0.2 0.05 -0.25 0.45)))
    (let wub (list (list 0.15 0.35 -0.2 0.1) (list 0.4 -0.15 0.25 0.3) (list -0.25 0.2 0.35 -0.1) (list 0.3 0.1 -0.05 0.4)))
    (let wdb (list (list 0.35 -0.15 0.25 0.2) (list 0.2 0.4 -0.3 0.1) (list -0.2 0.15 0.5 -0.25) (list 0.1 -0.05 0.3 0.45)))
    (let eps 0.00001)
    (let L0 (list g1 wq wk wv wo g2 wg wu wd))
    (let L1 (list g1b wqb wkb wvb wob g2b wgb wub wdb))
    (let layers2 (list L0 L1))

    ; --- the tied embed/unembed table (V=4): rows 0,1 == the x fixture; rows 2,3 are further tokens. ---
    (let tok (list (list 1.0 -0.5 0.5 2.0) (list -1.0 0.25 1.5 -0.75)
                   (list 0.5 1.0 -0.5 0.25) (list 0.25 -1.0 0.75 -0.5)))
    (let gf (list 1.1 0.9 1.0 1.05))
    (let seed  (list 0 1))   ; embeds to the band's x fixture exactly
    (let seedb (list 1 0))   ; the x fixture with rows swapped

    (let cfg10 (rope-cfg 10000.0 32.0 1.0 4.0 8192.0))
    (let sc4 (div 1.0 (tn-sqrt 4.0)))
    (let cfgl3 (rope-cfg-llama3))
    (let sc2 (div 1.0 (tn-sqrt 2.0)))

    ; --- greedy baseline (== lg-generate, #3649): [0 1 1 1 1] single-head cfg10 — the degenerate loop ---
    (let g3 (lg-generate seed tok layers2 gf tok eps sc4 1 1 4 cfg10 3))

    ; --- claim 1: CONSOLIDATION A single-head cfg10 — identity penalty (1,0,0) == lg-generate-sampled, genuine draw k=V ---
    (let su  (lg-generate-sampled   seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1 3))
    (let pid (lg-generate-penalized seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1.0 0.0 0.0 64 1 3))
    (let c0 (if (eq (ls-ieq pid su) 1) 1 0))

    ; --- claim 2: CONSOLIDATION A REAL GQA sharing (n_q=2 n_kv=1 HD=2 theta-500000) — identity penalty == sampled ---
    (let sgq (lg-generate-sampled   seed tok layers2 gf tok eps sc2 2 1 2 cfgl3 1.0 1 12345 3))
    (let pgq (lg-generate-penalized seed tok layers2 gf tok eps sc2 2 1 2 cfgl3 1.0 1 1.0 0.0 0.0 64 12345 3))
    (let c1 (if (eq (ls-ieq pgq sgq) 1) 2 0))

    ; --- claim 3: CONSOLIDATION B — identity penalty + k=1 == greedy [0,1,1,1,1] (peaked draw reduces to argmax) ---
    (let pk1 (lg-generate-penalized seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 1 1.0 0.0 0.0 64 7 3))
    (let c2 (if (eq (ls-ieq pk1 g3) 1) 4 0))

    ; --- claim 4: WINDOW — win=0 empty window == greedy even with big knobs (nothing counted) ---
    (let pw0 (lg-generate-penalized seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 1 100.0 5.0 5.0 0 1 3))
    (let c3 (if (eq (ls-ieq pw0 g3) 1) 8 0))

    ; --- claim 5: NON-LOOPING — penalized k=1 (pr=100) breaks [0,1,1,1,1] -> [0,1,3,3,3] (step-0 argmax flips 1->3) ---
    (let pnl (lg-generate-penalized seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 1 100.0 0.0 0.0 64 1 3))
    (let c4 (if (eq (if (eq (ls-ieq pnl (list 0 1 3 3 3)) 1) (if (eq (ls-ieq pnl g3) 0) 1 0) 0) 1) 16 0))

    ; --- claim 6: single-step compose — loop's full-trio penalized step-1 draw == smp-sample(lgsp-probs, uniform(minstd seed)) ---
    (let probs0 (lgsp-probs seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1.2 0.1 0.05 64))
    (let dref (smp-sample probs0 (smp-uniform (smp-minstd 100000))))
    (let d1 (lg-last (lg-generate-penalized seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1.2 0.1 0.05 64 100000 1)))
    (let c5 (if (eq d1 dref) 32 0))

    ; --- claim 7: FREQUENCY scales with the window count — raw logit[1] > freq-penalized count-1 > count-2 ---
    (let lg0 (lg-logits (lgqa-stack-causal (lg-embed tok seed) layers2 eps sc4 1 1 4 cfg10) gf tok eps))
    (let r1  (at1 lg0))
    (let p1c1 (at1 (pen-apply lg0 (list 0 1)     1.0 1.0 0.0)))
    (let p1c2 (at1 (pen-apply lg0 (list 0 1 2 1) 1.0 1.0 0.0)))
    (let c6 (if (eq (if (gt r1 p1c1) (if (gt p1c1 p1c2) 1 0) 0) 1) 64 0))

    ; --- claim 8: INPUT-DEPENDENCE — same penalty + PRNG seed, prompt [0,1] -> 1 vs [1,0] -> 0, differ ---
    (let dA (lg-last (lg-generate-penalized seed  tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1.2 0.1 0.05 64 100000 1)))
    (let dB (lg-last (lg-generate-penalized seedb tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1.2 0.1 0.05 64 100000 1)))
    (let c7 (if (eq dA dB) 0 128))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
