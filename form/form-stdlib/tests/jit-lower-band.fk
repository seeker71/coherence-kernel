; preludes: form-stdlib/minimal-surface.fk form-stdlib/hati-os-kernel.fk form-stdlib/jit-lower.fk
;
; jit-lower-band — portable JIT logic lowering proven on the fourth lane:
; the lowering recipe (jit-lower.fk) rewrites the direct IF expansion of
; and/or/not guards into the unboxed LOGIC lane (tags 70..72), and the
; lowered tree walks to the same 0/1 as its source — the body-owned version
; of the logic feature (gap #3 reference semantics from the Go typed
; hardcode), exactly the host-kernel.form intent: JIT as a composite of a
; recipe, no host-specific JIT code in the kernel.
;
; Verdict 15 when the lowering holds:
;   1   the IF expansion of (and (le arg 5) (le 0 arg)) lowers to LOGIC-AND
;       at the root — the recipe recognized the shape, not just rebuilt it
;   2   lowered and direct walk to the same answer at arg 3 (inside the
;       range), arg 0 (the lower edge), and arg 9 (outside)
;   4   the not shape IF c 0 1 lowers to LOGIC-NOT and agrees with its
;       source at args 0 and 7
;   8   a guard over literals only folds all the way down to a literal cell
;       that walks to 1 — fold and dead-branch compose through the logic lane
(do
    (let guard-direct (fk-if (fk-le (fk-arg) (fk-lit 5))
                             (fk-if (fk-le (fk-lit 0) (fk-arg)) (fk-lit 1) (fk-lit 0))
                             (fk-lit 0)))
    (let lowered (jit-lower-tree guard-direct))
    (let c0 (if (eq (fk-tag lowered) 70) 1 0))
    (let c1 (if (eq (fk-run lowered 3) (fk-run guard-direct 3))
                (if (eq (fk-run lowered 0) (fk-run guard-direct 0))
                    (if (eq (fk-run lowered 9) (fk-run guard-direct 9)) 2 0) 0) 0))

    (let not-direct (fk-if (fk-le (fk-arg) (fk-lit 5)) (fk-lit 0) (fk-lit 1)))
    (let not-lowered (jit-lower-tree not-direct))
    (let c2 (if (eq (fk-tag not-lowered) 72)
                (if (eq (fk-run not-lowered 0) (fk-run not-direct 0))
                    (if (eq (fk-run not-lowered 7) (fk-run not-direct 7)) 4 0) 0) 0))

    (let const-guard (fk-if (fk-le (fk-lit 3) (fk-lit 5))
                            (fk-if (fk-le (fk-lit 0) (fk-lit 3)) (fk-lit 1) (fk-lit 0))
                            (fk-lit 0)))
    (let folded (jit-lower-tree const-guard))
    (let c3 (if (eq (jit-lit-node? folded) 1) (if (eq (fk-run folded 0) 1) 8 0) 0))

    (add c0 (add c1 (add c2 c3))))
