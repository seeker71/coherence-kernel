; json-category-consumers-band.fk — JSON category consumers receive NodeIDs.
;
; preludes: form-stdlib/core.fk form-stdlib/language-model.fk form-stdlib/json.fk form-stdlib/codec.fk form-stdlib/structured-codec.fk form-stdlib/json-codec.fk form-stdlib/cache.fk form-stdlib/i18n.fk form-stdlib/self-witness.fk form-stdlib/i18n-parity.fk
;
; Band verdict: 7 when the BML codec, self-witness emitter, and i18n parity
; walker all call the zero-argument JSON category recipes before node_eq.

section [form.bml] {
    def jcc_score(ok, bit) = if ok then bit else 0;

    def json_category_consumers_band_score() {
        let nested = json-node-object(list(json-node-pair("leaf", json-node-int(7))));
        let nested_pair = json-node-pair("nested", nested);
        let document = json-node-object(list(nested_pair, json-node-pair("nil", json-node-null())));
        let codec_expected = "{\"nested\":{\"leaf\":7},\"nil\":null}";
        let witness_expected = "{\"nested\":{\"leaf\":\"7\"},\"nil\":null}";
        sum(list(jcc_score(str_eq(json_response_body(document), codec_expected), 1), jcc_score(str_eq(emit-json-value(document), witness_expected), 2), jcc_score(eq(i18n-leaf-count-pair(nested_pair), 1), 4)));
    }

    json_category_consumers_band_score();
}
