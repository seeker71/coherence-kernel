; source-artifact-cache-band.fk -- witness the source -> artifact route policy.
;
; preludes: form-stdlib/core.fk form-stdlib/source-artifact-cache.fk
; Expected: 2097151
;
; Bit legend:
;   1      manifest declares source-authority
;   2      manifest declares program-image-fkb-cache
;   4      manifest declares program-image-embeds-table-payload
;   8      manifest declares dylib-native-cache
;   16     policy: fresh program-image fkb routes to parsed image
;   32     stale fkb routes to source compile
;   64     policy: fresh verified dylib wins over fkb
;   128    dylib without native proof falls back to fkb
;   256    missing fkb routes to source compile
;   512    compile output writes fkb
;   1024   compile output writes dylib only when lowerable and proven
;   2048   compile output carries the embedded parsed table payload
;   4096   equal mtime is fresh
;   8192   source-newer invalidates fkb and dylib
;   16384  policy: fresh fkb would skip source parse
;   32768  policy: fresh dylib would skip recompute
;   65536  manifest declares mtime-signature-freshness
;   131072 manifest declares compile-on-stale
;   262144 manifest declares no-c-seed-growth
;   524288 policy: dylib cannot win without a ready program-image fkb
;   1048576 policy: sig-ok=0 invalidates otherwise fresh artifacts

(do
    (defn sacb-score (ok bit) (if ok bit 0))
    (defn sacb-fkb-fresh () (sac-state 100 101 -1 1 0 0 0 0 1))
    (defn sacb-fkb-stale () (sac-state 100 99 -1 1 0 0 0 0 1))
    (defn sacb-dylib-fresh () (sac-state 100 101 102 1 1 1 1 1 1))
    (defn sacb-sig-bad () (sac-state 100 101 102 1 1 1 1 1 0))
    (defn sacb-dylib-unproven () (sac-state 100 101 102 1 1 1 0 1 1))
    (defn sacb-dylib-with-stale-fkb () (sac-state 100 99 102 1 1 1 1 1 1))
    (defn sacb-missing () (sac-state 100 -1 -1 0 0 0 0 0 1))
    (defn sacb-source-newer () (sac-state 200 100 100 1 1 1 1 1 1))
    (defn sacb-compiled-native () (sac-compile-output 1 1))

    (defn source-artifact-cache-band ()
        (do
            (let manifest (source-artifact-cache-manifest))
            (let out (sacb-compiled-native))
            (sum (list
                (sacb-score (eq (sac-manifest-has? "source-authority" manifest) 1) 1)
                (sacb-score (eq (sac-manifest-has? "program-image-fkb-cache" manifest) 1) 2)
                (sacb-score (eq (sac-manifest-has? "program-image-embeds-table-payload" manifest) 1) 4)
                (sacb-score (eq (sac-manifest-has? "dylib-native-cache" manifest) 1) 8)
                (sacb-score (eq (sac-route (sacb-fkb-fresh)) (sac-run-fkb)) 16)
                (sacb-score (eq (sac-route (sacb-fkb-stale)) (sac-run-source-compile)) 32)
                (sacb-score (eq (sac-route (sacb-dylib-fresh)) (sac-run-dylib)) 64)
                (sacb-score (eq (sac-route (sacb-dylib-unproven)) (sac-run-fkb)) 128)
                (sacb-score (eq (sac-route (sacb-missing)) (sac-run-source-compile)) 256)
                (sacb-score (eq (sac-output-writes-fkb out) 1) 512)
                (sacb-score (eq (sac-output-writes-dylib out) 1) 1024)
                (sacb-score (eq (sac-output-embeds-table-payload out) 1) 2048)
                (sacb-score (eq (sac-fresh? 100 100 1) 1) 4096)
                (sacb-score (eq (sac-route (sacb-source-newer)) (sac-run-source-compile)) 8192)
                (sacb-score (eq (sac-skips-parse? (sacb-fkb-fresh)) 1) 16384)
                (sacb-score (eq (sac-skips-recompute? (sacb-dylib-fresh)) 1) 32768)
                (sacb-score (eq (sac-manifest-has? "mtime-signature-freshness" manifest) 1) 65536)
                (sacb-score (eq (sac-manifest-has? "compile-on-stale" manifest) 1) 131072)
                (sacb-score (eq (sac-manifest-has? "no-c-seed-growth" manifest) 1) 262144)
                (sacb-score (eq (sac-route (sacb-dylib-with-stale-fkb)) (sac-run-source-compile)) 524288)
                (sacb-score (eq (sac-route (sacb-sig-bad)) (sac-run-source-compile)) 1048576)))))

    (source-artifact-cache-band))
