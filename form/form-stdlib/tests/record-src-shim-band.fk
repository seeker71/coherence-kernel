; record-src-shim-band.fk — proof of the --src record_new door.
;
; preludes: form-stdlib/core.fk form-stdlib/record-src-shim.fk form-stdlib/str-byte-at.fk form-stdlib/text-tokenize.fk form-stdlib/rag-embed.fk
;
; Scoped to the fkwu --src surface (the shim's own scope; the family is
; native on the flatten lane and the sibling kernels).
;
; verdict 15:
;   1   record_new resolves and answers the empty record
;   2   the empty record stays honestly empty: native set cannot seed it,
;       has answers 0, get answers 0 — no phantom bindings ever
;   4   rag-embed's concept lane DEGRADES rather than dies: a known concept
;       word ("deploy") falls to its conservative stem, not to its authored
;       __concept_deploy pair — observed, not hidden
;   8   the lexical lane is untouched: re-vec still embeds real words
;
; run: cat form/form-stdlib/core.fk form/form-stdlib/record-src-shim.fk \
;          form/form-stdlib/str-byte-at.fk form/form-stdlib/text-tokenize.fk \
;          form/form-stdlib/rag-embed.fk \
;          form/form-stdlib/tests/record-src-shim-band.fk > /tmp/rss.fk
;      ./fkwu --src /tmp/rss.fk    ; -> 15

(do
    (defn rsb-list-eq (a b)
        (if (eq (len a) (len b))
            (if (eq (len a) 0) 1
                (if (eq (head a) (head b)) (rsb-list-eq (tail a) (tail b)) 0))
            0))
    (defn rsb-sum (xs acc)
        (if (eq (len xs) 0) acc (rsb-sum (tail xs) (add acc (head xs)))))

    (let r (record_new (make_nodeid 1 2 99 2088)))
    (let resolves (if (eq (len r) 0) 1 0))
    (let r1 (record_set r "k" "v"))
    (let empty-honest (if (and (eq (record_has r1 "k") 0)
                               (eq (record_get r1 "k") 0)) 2 0))
    (let degraded (if (rsb-list-eq (re-semantic-vec "deploy")
                                   (re-feature-codes "deploy")) 1 0))
    (let degrades (mul degraded 4))
    (let lexical (if (gt (rsb-sum (re-vec "deploy evidence kernel") 0) 0) 8 0))
    (add resolves (add empty-honest (add degrades lexical))))
