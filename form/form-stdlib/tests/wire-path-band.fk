; wire-path-band.fk — proof of the path-select query over cell graphs.
;
; preludes: form-stdlib/core.fk form-stdlib/wire-registry.fk form-stdlib/wire-xml.fk form-stdlib/wire-path.fk
;
; Closes the "xmlpath/xpath is a shell-applet, not a native parser" gap
; named for tool-channel.fk — this proves the native replacement actually
; works: multi-match breadth at one path segment (`INNER` selects every
; INNER child, not just the first), multi-segment chaining (`INNER/LEAF`
; walks through all matched INNER nodes to their LEAF children), identity
; preservation (the selected nodes ARE the original cells, via `eq`, not
; equal-looking copies), and the xmlpath half (select over cell trees
; produced by parsing real XML text, via wire-xml.fk).
;
; Verdict 63 when every assertion holds.

(do
    (defn wpb-score (ok bit) (if ok bit 0))
    (defn wire-path-band ()
        (do
    (let registry (list (wr-entry "OUTER" (bp "OUTER")) (wr-entry "INNER" (bp "INNER")) (wr-entry "LEAF" (bp "LEAF"))))
    (let leaf1 (intern_node (bp "LEAF") (list (intern_trivial_int 1))))
    (let leaf2 (intern_node (bp "LEAF") (list (intern_trivial_int 2))))
    (let leaf3 (intern_node (bp "LEAF") (list (intern_trivial_int 3))))
    (let inner1 (intern_node (bp "INNER") (list leaf1 leaf2)))
    (let inner2 (intern_node (bp "INNER") (list leaf3)))
    (let root (intern_node (bp "OUTER") (list inner1 inner2)))
    (let all-inner (wp-select root "INNER" registry))
    (let c0 (wpb-score (eq (len all-inner) 2) 1))                    ; breadth: both INNER siblings match
    (let all-leaf (wp-select root "INNER/LEAF" registry))
    (let c1 (wpb-score (eq (len all-leaf) 3) 2))                     ; multi-segment: all 3 LEAF grandchildren
    (let c2 (wpb-score (eq (nth all-leaf 0) leaf1) 4))                ; identity, not equal-looking
    (let c3 (wpb-score (eq (nth all-leaf 1) leaf2) 8))
    (let c4 (wpb-score (eq (nth all-leaf 2) leaf3) 16))
    (let xml-text (cell-to-xml root registry))
    (let xml-sel (wp-select-xml xml-text "INNER/LEAF" registry))     ; the xmlpath half: text -> parse -> select
    (let c5 (wpb-score (eq (len xml-sel) 3) 32))
    (add c0 (add c1 (add c2 (add c3 (add c4 c5))))))
    )
    (wire-path-band))
