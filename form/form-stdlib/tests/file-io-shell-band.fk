; file-io-shell-band.fk — proves the BML file-I/O proof orchestration is now a
; Form-shell cell: fsh lowering, the native test/echo VERDICT gate (both PASS and
; FAIL branches computed in Form), and the passthrough bootstrap steps + append
; redirect of the witness. Verdict = 255, asserted byte-identical on the 4th kernel.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk form-stdlib/shell-lower.fk form-stdlib/file-io-shell.fk

(do
    (let c (fio-cell))
    (let plan (fio-plan))

    (let c1 (if (str_eq (sh-cell-name c) "file-io-proof") 1 0))
    (let c2 (if (str_eq (sh-cell-domain c) "fsh") 2 0))
    (let c3 (if (fio-plan-has-kind-name? plan "native" "test") 4 0))
    (let c4 (if (fio-plan-has-kind-name? plan "native" "echo") 8 0))
    (let c5 (if (fio-plan-has-kind-name? plan "passthrough" "fkwu-run") 16 0))
    (let c6 (if (fio-plan-has-kind-name? plan "passthrough" "fkc-emit-bml") 32 0))
    (let c7 (if (fio-plan-has-append? plan) 64 0))
    (let c8 (if (and (and (str_eq (fio-verdict "255") "PASS\n")
                          (str_eq (fio-verdict "7") "FAIL\n"))
                     (and (eq (fio-verdict-code "255") 1)
                          (eq (fio-verdict-code "7") 0))) 128 0))

    ; expected total: 255
    (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 (add c7 c8))))))))
