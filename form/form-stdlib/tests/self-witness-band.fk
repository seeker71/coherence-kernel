; self-witness-band.fk — proves parse → walk → re-emit preserves the
; substrate skeleton on a real corpus (form-kernel-ts/package.json).
;
; Re-grounded 2026-07-18: the original corpus (web/messages/en.json) is
; Coherence-Network tissue and never traveled into this body when the
; form kernel became canonical here. The witness is about skeleton
; preservation, not about i18n — so it now walks a JSON corpus the body
; itself carries: form-kernel-ts/package.json, narrowed to its flat
; "exports" object (5 string pairs, 1 outer brace). Same pipeline, same
; invariants, same three-kernel agreement bar.
;
; The witness: parse package.json with json_parse_body (direct — no .fkb
; cache layer, so the run is deterministic on every arm; the old
; read_with_cache path made the fourth-arm verdict flip between cold and
; warm cache, which kept this band unregistered), walk the parsed Recipe
; through self-witness's toy JSON emitter, and compare structural counts
; between the source and the emission.
;
; What this proves: the parser hands a Recipe to the witness; the
; witness re-emits without re-reading the source bytes; every
; JSON-OBJECT, JSON-PAIR, and trivial leaf the parser produced makes
; it back out the other side. The skeleton round-trips.
;
; What it does NOT prove: byte-identity. The emitter writes no
; whitespace, doesn't preserve key order across kernels with
; different reduce semantics (today they agree, but the witness
; doesn't depend on it), and quotes every leaf — fine for a section
; that's all strings. Byte-identity would require sibling cells
; for whitespace and number/bool preservation.
;
; What's next: the autoresearch loop — mutate the encoder Recipe
; (currently authored by hand in self-witness.fk) and watch the
; delta drop toward zero on more corpora than just JSON. The witness
; this file embodies is the loss function the mutator will minimize.
;
; preludes: form-stdlib/language-model.fk form-stdlib/json.fk form-stdlib/codec.fk form-stdlib/structured-codec.fk form-stdlib/json-codec.fk form-stdlib/cache.fk form-stdlib/i18n.fk form-stdlib/self-witness.fk

(do
    (let source-path "form-kernel-ts/package.json")
    ; honest degrade: if the corpus is absent, one stable verdict, not a
    ; crash (the bml-thesis idiom).
    (if (eq (fs_exists source-path) 0)
        "self-witness-band-input-absent"
        (do
            ;; --- load the corpus, narrow to the "exports" section ----
            ;; The full package.json nests objects; exports is a flat
            ;; object of 5 string pairs — small enough to walk in any
            ;; kernel and shaped to prove every layer of the witness
            ;; pipeline: object dispatch, pair emission, leaf
            ;; escape-and-quote, brace counting.

            (let corpus (json_parse_body source-path (read_file source-path)))
            (let exports (json-object-get corpus "exports"))

            ;; --- structural ground truth from the Recipe -------------
            ;; Pair count via node_children is the parser's view of how
            ;; many entries exports holds. JSON-OBJECT counter recurses;
            ;; for a flat section it returns 1 (just the outer object).

            (let exports-pair-count (self-witness-pair-count exports))
            (let original-objects (self-witness-count-objects exports))

            ;; --- round-trip: walk the Recipe through the emitter -----
            ;; Two structural invariants the witness checks:
            ;;
            ;;   brace-count(emitted) == JSON-OBJECT count in Recipe
            ;;   comma-count(emitted) + 1 == pair count in Recipe
            ;;     (true for a single flat object; the +1 is the
            ;;     implicit first pair which has no leading comma)

            (let emitted (emit-json-value exports))
            (let emitted-braces (self-witness-count-char emitted 123))
            (let emitted-commas (self-witness-count-char emitted 44))

            (defn match-flag (a b) (if (eq a b) 1 0))
            (let brace-match (match-flag original-objects emitted-braces))
            (let comma-match (match-flag (add emitted-commas 1) exports-pair-count))

            ;; --- witness composite -----------------------------------
            ;; The three kernels must agree on every term:
            ;;   brace-match (0 or 1) × 1000     → 1000
            ;;   comma-match (0 or 1) × 100      →  100
            ;;   exports-pair-count               →    5
            ;;   exports-braces (emitted)         →    1
            ;; --------------------------------------------
            ;; Expected total: 1000 + 100 + 5 + 1 = 1106
            ;;
            ;; Any drift in parse, walk, or emit changes the total —
            ;; making this single integer a tight witness for
            ;; forward/inverse skeleton preservation across the
            ;; sibling kernels.

            (add (mul brace-match 1000)
                (add (mul comma-match 100)
                    (add exports-pair-count emitted-braces))))))
