; preludes: form-stdlib/core.fk form-stdlib/obs-verify.fk form-stdlib/trust-decay.fk form-stdlib/channel-interface.fk form-stdlib/satsang.fk form-stdlib/satsang-field.fk form-stdlib/persistence.fk form-stdlib/world-module-model.fk form-stdlib/world-model-growth.fk form-stdlib/loop-stewardship.fk form-stdlib/loop-ledger-host.fk
;
; loop-ledger-host-band — a loop's stewardship ledger fathomed from a REAL
; filesystem store (the fs-crud-band discipline: real tree on the live OS,
; asserted, then torn down). Inbox depth is the lag; kept entries are the
; witnesses.
;
; Verdict 63 when every claim lands:
;   1     real counts: inbox 3 + kept 2 -> shipped 5, witnessed 2, lag 3
;   2     lag 3 inside budget (max 4, half 2) reads level 2
;   4     drained inbox reads lag 0, level 3
;   8     missing stores read as honest zeros: fresh ledger, level 3
;   16    inbox past the full budget reads level 1
;   32    the fixture tree tears down clean
(do
    (let root (str_concat (temp_dir) "/loop-ledger-host-band"))
    (let inbox (str_concat root "/inbox"))
    (let kept (str_concat root "/kept"))
    (let decl (list "sense" "distill"))

    ;; clean slate, then a real store: 3 inbox units, 2 kept units
    (fs_remove (str_concat inbox "/a.wav"))
    (fs_remove (str_concat inbox "/b.wav"))
    (fs_remove (str_concat inbox "/c.wav"))
    (fs_remove (str_concat inbox "/d.wav"))
    (fs_remove (str_concat inbox "/e.wav"))
    (fs_remove (str_concat kept "/one.rec"))
    (fs_remove (str_concat kept "/two.rec"))
    (fs_rmdir inbox)
    (fs_rmdir kept)
    (fs_rmdir root)
    (fs_mkdir root)
    (fs_mkdir inbox)
    (fs_mkdir kept)
    (write_file_text (str_concat inbox "/a.wav") "A")
    (write_file_text (str_concat inbox "/b.wav") "B")
    (write_file_text (str_concat inbox "/c.wav") "C")
    (write_file_text (str_concat kept "/one.rec") "1")
    (write_file_text (str_concat kept "/two.rec") "2")

    (let f (llh-fathom inbox kept decl 4 2))
    (let c0
        (if (and (eq (nth f 0) 5)
             (and (eq (nth f 1) 2) (eq (nth f 2) 3))) 1 0))
    (let c1 (if (eq (nth f 3) 2) 2 0))

    ;; drain the inbox: the distill loop caught up
    (fs_remove (str_concat inbox "/a.wav"))
    (fs_remove (str_concat inbox "/b.wav"))
    (fs_remove (str_concat inbox "/c.wav"))
    (let drained (llh-fathom inbox kept decl 4 2))
    (let c2 (if (and (eq (nth drained 2) 0) (eq (nth drained 3) 3)) 4 0))

    ;; missing stores are honest zeros
    (let ghost (llh-fathom (str_concat root "/no-inbox") (str_concat root "/no-kept") decl 4 2))
    (let c3 (if (and (eq (nth ghost 0) 0) (eq (nth ghost 3) 3)) 8 0))

    ;; refill past the full budget: 5 unwitnessed units
    (write_file_text (str_concat inbox "/a.wav") "A")
    (write_file_text (str_concat inbox "/b.wav") "B")
    (write_file_text (str_concat inbox "/c.wav") "C")
    (write_file_text (str_concat inbox "/d.wav") "D")
    (write_file_text (str_concat inbox "/e.wav") "E")
    (let deep (llh-fathom inbox kept decl 4 2))
    (let c4 (if (eq (nth deep 3) 1) 16 0))

    ;; tear down
    (fs_remove (str_concat inbox "/a.wav"))
    (fs_remove (str_concat inbox "/b.wav"))
    (fs_remove (str_concat inbox "/c.wav"))
    (fs_remove (str_concat inbox "/d.wav"))
    (fs_remove (str_concat inbox "/e.wav"))
    (fs_remove (str_concat kept "/one.rec"))
    (fs_remove (str_concat kept "/two.rec"))
    (fs_rmdir inbox)
    (fs_rmdir kept)
    (fs_rmdir root)
    (let c5 (if (eq (fs_exists root) 0) 32 0))

    (add c0 (add c1 (add c2 (add c3 (add c4 c5))))))
