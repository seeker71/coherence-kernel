; grammar-loader-band.fk -- layer witness for the ontology-free named grammar registry.
;
; preludes: form-stdlib/core.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk
;
; Bit legend:
;   1      manifest declares named-registry
;   2      manifest declares parse-by-name
;   4      manifest declares ontology-free
;   8      manifest declares no-line-grammar
;   16     empty registry count is 0
;   32     one registered grammar count is 1
;   64     gl-has? finds the registered name
;   128    gl-names exposes the registered name
;   256    gl-parse-with parses "hello"
;   512    gl-parse by name parses "hello"
;   1024   missing grammar returns NO-SUCH-GRAMMAR
;   2048   gl-ok? rejects missing grammar sentinel
;   4096   bad source returns PARSE-FAIL
;   8192   gl-ok? rejects parse-failure sentinel
;   16384  newest registered grammar shadows older grammar
;   32768  adding a second name gives count 2

(do
    (defn glp-score (ok bit) (if ok bit 0))

    (defn glp-g ()
        (grammar "word"
            (list
                (rule3 "word"
                    (p-cap "v" (p-run "alpha"))
                    (t-splice "v")))))

    (defn glp-g2 ()
        (grammar "word"
            (list
                (rule3 "word"
                    (p-lit "hi")
                    (t-const "shadow")))))

    (defn glp-reg1 () (gl-register (gl-empty) "word" (glp-g)))
    (defn glp-reg2 () (gl-register (glp-reg1) "word" (glp-g2)))
    (defn glp-reg2b () (gl-register (glp-reg1) "other" (glp-g2)))

    (defn grammar-loader-band-probe ()
        (do
            (let manifest (grammar-loader-language-manifest))
            (sum (list
                (glp-score (eq (grammar-loader-manifest-has? "named-registry" manifest) 1) 1)
                (glp-score (eq (grammar-loader-manifest-has? "parse-by-name" manifest) 1) 2)
                (glp-score (eq (grammar-loader-manifest-has? "ontology-free" manifest) 1) 4)
                (glp-score (eq (grammar-loader-manifest-has? "no-line-grammar" manifest) 1) 8)
                (glp-score (eq (gl-count (gl-empty)) 0) 16)
                (glp-score (eq (gl-count (glp-reg1)) 1) 32)
                (glp-score (gl-has? (glp-reg1) "word") 64)
                (glp-score (str_eq (head (gl-names (glp-reg1))) "word") 128)
                (glp-score (str_eq (node_value (gl-parse-with (glp-g) "hello")) "hello") 256)
                (glp-score (str_eq (node_value (gl-parse (glp-reg1) "word" "hello")) "hello") 512)
                (glp-score (str_eq (node_value (gl-parse (glp-reg1) "missing" "hello")) "NO-SUCH-GRAMMAR") 1024)
                (glp-score (not (gl-ok? (gl-parse (glp-reg1) "missing" "hello"))) 2048)
                (glp-score (str_eq (node_value (gl-parse (glp-reg1) "word" "123")) "PARSE-FAIL") 4096)
                (glp-score (not (gl-ok? (gl-parse (glp-reg1) "word" "123"))) 8192)
                (glp-score (str_eq (node_value (gl-parse (glp-reg2) "word" "hi")) "shadow") 16384)
                (glp-score (eq (gl-count (glp-reg2b)) 2) 32768)))))

    (grammar-loader-band-probe))
