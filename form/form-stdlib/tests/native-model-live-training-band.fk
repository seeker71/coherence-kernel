; native-model-live-training-band.fk -- actual bounded Form training remains
; measured and cannot be mislabeled as a persisted native LLM.
;
; preludes: form-stdlib/core.fk form-stdlib/transformer-numerics.fk form-stdlib/transformer-block.fk form-stdlib/transformer-backprop.fk form-stdlib/transformer-corpus-train.fk form-stdlib/neural-lm.fk form-stdlib/native-model-live-training.fk
;
; Verdict 255.

(do
    (let transformer (nmlt-transformer-run))
    (let lm (nmlt-lm-run))
    (let rendered (str_concat (nmlt-render-transformer transformer)
                               (nmlt-render-lm lm)))

    (let c1 (if (eq (nmlt-transformer-valid? transformer) 1) 1 0))
    (let c2 (if (and (eq (nth transformer 1) 13)
                     (eq (nth transformer 2) 5)) 2 0))
    (let c3 (if (lt (nth transformer 5) (nth transformer 4)) 4 0))
    (let c4 (if (and (lt (nth transformer 7) (nth transformer 6))
                     (lt (nth transformer 7) (nth transformer 8))) 8 0))
    (let c5 (if (gt (nth transformer 9) 0) 16 0))
    (let c6 (if (eq (nmlt-lm-valid? lm) 1) 32 0))
    (let c7 (if (and (lt (nth lm 4) (nth lm 5))
                     (eq (nth lm 5) 6)) 64 0))
    (let c8 (if (and (ge (str_find rendered "not-native-llm-checkpoint" 0) 0)
                     (ge (str_find rendered "not-large-language-model" 0) 0)) 128 0))

    (sum (list c1 c2 c3 c4 c5 c6 c7 c8)))
