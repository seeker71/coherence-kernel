; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk
;
; fsh-lexicon-probe — the terminate-word question, asked with the body's OWN grep.
;
; On 2026-07-22 19:1x the orchestrating mind answered "is `separate` seated in
; the neutral lexicon?" by shelling out to external grep, twice, while
; sh-bi-grep sat proven and unused. This asks it again through shell-exec.
;
; Returns 1000*(seated y-rows) + 100*(hits for "separate") + 10*(hits for "cut")
;         + (hits for "divide") — one int carrying all four answers.

(do
    (let src (read_file "form-stdlib/name-lexicon.fk"))
    (let rows (str_to_int (head (sh-bi-grep (list "-c" "(list \"y") src))))
    (let sep  (str_to_int (head (sh-bi-grep (list "-c" "\"separate\"") src))))
    (let cut  (str_to_int (head (sh-bi-grep (list "-c" "\"cut\"") src))))
    (let div  (str_to_int (head (sh-bi-grep (list "-c" "\"divide\"") src))))
    (add (mul rows 1000) (add (mul sep 100) (add (mul cut 10) div))))
