; preludes: form-stdlib/core.fk form-stdlib/transformer-numerics.fk form-stdlib/trig.fk form-stdlib/llama-numerics.fk form-stdlib/rope.fk form-stdlib/transformer-block.fk form-stdlib/transformer-mh.fk form-stdlib/gqa-attn.fk form-stdlib/llama-block.fk form-stdlib/llama-gqa-block.fk form-stdlib/kv-cache.fk form-stdlib/kv-llama-block.fk form-stdlib/kv-gqa-llama-block.fk form-stdlib/multi-layer-stack.fk form-stdlib/gqa-multi-layer-stack.fk form-stdlib/greedy-decode.fk form-stdlib/llama-generate.fk form-stdlib/sampling.fk form-stdlib/llama-sample-generate.fk
;
; llama-sample-generate-band — the llama (decoder-only, GQA) autoregressive SAMPLED generation loop
; lifted to the four-kernel floor: the greedy loop (#3649) re-skinned to DRAW each token from a shaped
; distribution with a seeded MINSTD PRNG (sampling.fk, #3651) instead of taking the argmax. This wires
; the four-way greedy decode to the four-way sampling draw — the named next stone from #3651's receipt.
;
; Grounded two ways (the gqa-multi-layer-stack-band / llama-generate-band discipline):
;   (A) EQUIVALENCE to the four-way greedy loop: with k=1 the top-k mask is a one-hot, so the draw
;       returns the argmax for every u -> lg-generate-sampled(k=1) == lg-generate (#3649) token-for-token.
;       Temperature is a monotone scaling, so k=1 is temperature-invariant. These reductions ground the
;       whole sampled stack+logits+filter+selection by equivalence to a loop already proven four-way —
;       so they need NO new reference, including for the REAL GQA sharing (n_q=2 n_kv=1 theta-500000).
;   (B) The genuine DRAW path (k=V, no masking): the drawn token is pinned against the independent
;       libm+MINSTD reference scripts/llama_sample_generate_reference.py (self-checked to reproduce
;       causal-attention-band's pins 1893731/-1069281/1648117 AND MINSTD's published seq 16807,282475249,
;       1622650073,...). The shaped distribution at seed [0,1] is [0.00281, 0.94047, 0.00427, 0.05245]
;       (cum [0.00281, 0.94328, 0.94755, 1.0]); three PRNG seeds steer the inverse-CDF draw into three
;       different buckets: seed 1 (u=8e-6) -> token 0, seed 100000 (u=0.783) -> token 1, seed 127000
;       (u=0.994) -> token 3 — so u provably selects the token, the loop is not stuck on the argmax.
;
; The embed/unembed table is tied and chosen so embed([0,1]) == the band's published x fixture, so the
; stack inside the loop reuses the already-four-way pins (identical fixture to llama-generate-band).
;
; Verdict 255 when the llama GQA SAMPLED generation loop lands four-way:
;   1    s1 == g3                 (CONSOLIDATION single-head cfg10: k=1 sampled loop == greedy loop, token-for-token)
;   2    sq3 == gq3               (CONSOLIDATION REAL GQA n_q=2 n_kv=1 theta-500000: k=1 sampled == greedy — grouped)
;   4    s05 == g3 && s20 == g3   (temperature-invariant at k=1: t=0.5 and t=2.0 both reduce to greedy — scale, no reorder)
;   8    d1 == 0                  (DRAW low-u: seed 1, u=8e-6 -> token 0, the first bucket — inverse-CDF floor)
;   16   d2 == 1                  (DRAW mid-u: seed 100000, u=0.783 -> token 1, the argmax bucket — u steers into it)
;   32   d3 == 3                  (DRAW high-u: seed 127000, u=0.994 -> token 3, the last bucket — u spans all buckets)
;   64   d2 == dref               (the loop's step-1 draw == smp-draw(probs, seed): no double-advance, correct compose)
;   128  dA != dB                 (input-dependence: same seed, prompt [0,1] -> 1 vs [1,0] -> 0 — selection follows the prompt)
(do
    ; --- flat int-list equality ---
    (defn ls-ieq (a b)
      (if (eq (len a) 0) (if (eq (len b) 0) 1 0)
          (if (eq (len b) 0) 0
              (if (eq (head a) (head b)) (ls-ieq (tail a) (tail b)) 0))))

    ; --- layer 0: the causal-attention-band / llama-block-band fixture (d=4) ---
    (let g1 (list 0.9 1.1 1.0 0.95))   (let g2 (list 1.05 0.95 1.0 0.9))
    (let wq (list (list 0.5 -0.25 0.1 0.3) (list 0.2 0.4 -0.3 0.1) (list -0.1 0.2 0.5 -0.2) (list 0.3 0.0 -0.15 0.25)))
    (let wk (list (list 0.2 0.4 -0.3 0.1) (list 0.3 -0.2 0.25 0.5) (list 0.1 0.15 -0.05 0.2) (list -0.25 0.3 0.4 -0.1)))
    (let wv (list (list 0.3 -0.2 0.25 0.5) (list 0.6 0.1 -0.2 0.4) (list 0.05 -0.1 0.3 0.2) (list 0.15 0.35 -0.25 0.1)))
    (let wo (list (list 0.6 0.1 -0.2 0.4) (list -0.2 0.4 0.3 0.1) (list 0.25 -0.15 0.5 0.05) (list 0.1 0.2 -0.3 0.45)))
    (let wg (list (list 0.5 -0.3 0.2 0.1) (list 0.2 0.7 -0.4 0.3) (list -0.1 0.25 0.4 -0.2) (list 0.3 0.1 -0.15 0.5)))
    (let wu (list (list 0.25 -0.15 0.3 0.05) (list 0.1 0.4 -0.2 0.15) (list 0.35 0.2 -0.1 0.25) (list -0.2 0.3 0.15 0.4)))
    (let wd (list (list 0.4 -0.2 0.3 0.1) (list 0.15 0.5 -0.25 0.2) (list -0.3 0.1 0.45 -0.15) (list 0.2 -0.1 0.35 0.3)))
    ; --- layer 1: a SECOND, distinct weight bundle ---
    (let g1b (list 1.0 0.9 1.05 1.1))  (let g2b (list 0.95 1.1 0.9 1.0))
    (let wqb (list (list 0.1 0.3 -0.2 0.4) (list -0.3 0.2 0.5 -0.1) (list 0.4 -0.1 0.2 0.3) (list 0.0 0.25 -0.35 0.15)))
    (let wkb (list (list 0.3 -0.2 0.4 0.1) (list 0.15 0.5 -0.1 0.2) (list -0.05 0.3 0.25 -0.15) (list 0.4 -0.25 0.1 0.35)))
    (let wvb (list (list 0.2 0.4 -0.15 0.3) (list 0.5 -0.1 0.2 0.45) (list -0.2 0.35 0.1 -0.05) (list 0.25 0.15 -0.3 0.2)))
    (let wob (list (list 0.4 -0.3 0.2 0.5) (list 0.1 0.45 -0.15 0.2) (list -0.25 0.3 0.4 0.05) (list 0.35 -0.1 0.25 -0.2)))
    (let wgb (list (list 0.3 0.2 -0.4 0.1) (list 0.5 -0.3 0.15 0.25) (list -0.1 0.4 0.3 -0.2) (list 0.2 0.05 -0.25 0.45)))
    (let wub (list (list 0.15 0.35 -0.2 0.1) (list 0.4 -0.15 0.25 0.3) (list -0.25 0.2 0.35 -0.1) (list 0.3 0.1 -0.05 0.4)))
    (let wdb (list (list 0.35 -0.15 0.25 0.2) (list 0.2 0.4 -0.3 0.1) (list -0.2 0.15 0.5 -0.25) (list 0.1 -0.05 0.3 0.45)))
    (let eps 0.00001)
    (let L0 (list g1 wq wk wv wo g2 wg wu wd))
    (let L1 (list g1b wqb wkb wvb wob g2b wgb wub wdb))
    (let layers2 (list L0 L1))

    ; --- the tied embed/unembed table (V=4): rows 0,1 == the x fixture; rows 2,3 are further tokens. ---
    (let tok (list (list 1.0 -0.5 0.5 2.0) (list -1.0 0.25 1.5 -0.75)
                   (list 0.5 1.0 -0.5 0.25) (list 0.25 -1.0 0.75 -0.5)))
    (let gf (list 1.1 0.9 1.0 1.05))
    (let seed  (list 0 1))   ; embeds to the band's x fixture exactly
    (let seedb (list 1 0))   ; the x fixture with rows swapped

    (let cfg10 (rope-cfg 10000.0 32.0 1.0 4.0 8192.0))
    (let sc4 (div 1.0 (tn-sqrt 4.0)))
    (let cfgl3 (rope-cfg-llama3))
    (let sc2 (div 1.0 (tn-sqrt 2.0)))

    ; --- greedy baseline (== lg-generate, #3649): [0 1 1 1 1] single-head cfg10 ---
    (let g3 (lg-generate seed tok layers2 gf tok eps sc4 1 1 4 cfg10 3))

    ; --- claim 1: CONSOLIDATION single-head cfg10 — k=1 sampled loop == greedy loop, token-for-token ---
    (let s1 (lg-generate-sampled seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 1 1 3))
    (let c0 (if (eq (ls-ieq s1 g3) 1) 1 0))

    ; --- claim 2: CONSOLIDATION REAL GQA sharing (n_q=2 n_kv=1 HD=2 theta-500000) — k=1 sampled == greedy ---
    (let gq3 (lg-generate         seed tok layers2 gf tok eps sc2 2 1 2 cfgl3 3))
    (let sq3 (lg-generate-sampled seed tok layers2 gf tok eps sc2 2 1 2 cfgl3 1.0 1 1 3))
    (let c1 (if (eq (ls-ieq sq3 gq3) 1) 2 0))

    ; --- claim 3: temperature-invariant at k=1 — t=0.5 and t=2.0 both reduce to greedy ---
    (let s05 (lg-generate-sampled seed tok layers2 gf tok eps sc4 1 1 4 cfg10 0.5 1 1 3))
    (let s20 (lg-generate-sampled seed tok layers2 gf tok eps sc4 1 1 4 cfg10 2.0 1 1 3))
    (let c2 (if (eq (if (eq (ls-ieq s05 g3) 1) (ls-ieq s20 g3) 0) 1) 4 0))

    ; --- the genuine DRAW path: k=V=4 (no masking), t=1.0, single step. probs0 pins the buckets. ---
    (let d1 (lg-last (lg-generate-sampled seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 1 1)))
    (let c3 (if (eq d1 0) 8 0))
    (let d2 (lg-last (lg-generate-sampled seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 100000 1)))
    (let c4 (if (eq d2 1) 16 0))
    (let d3 (lg-last (lg-generate-sampled seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 127000 1)))
    (let c5 (if (eq d3 3) 32 0))

    ; --- claim 7: the loop's step-1 draw == smp-draw(probs0, seed) — no double-advance, correct compose ---
    (let probs0 (lgs-probs seed tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4))
    (let dref (smp-draw probs0 100000))
    (let c6 (if (eq d2 dref) 64 0))

    ; --- claim 8: input-dependence — same PRNG seed, prompt [0,1] -> 1 vs [1,0] -> 0, differ ---
    (let dA (lg-last (lg-generate-sampled seed  tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 100000 1)))
    (let dB (lg-last (lg-generate-sampled seedb tok layers2 gf tok eps sc4 1 1 4 cfg10 1.0 4 100000 1)))
    (let c7 (if (eq dA dB) 0 128))

    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
