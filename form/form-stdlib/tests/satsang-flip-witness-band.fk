; preludes: form-stdlib/channel-interface.fk form-stdlib/satsang.fk form-stdlib/satsang-flip-witness.fk
;
; satsang-flip-witness-band -- the flip as witnessed, knowable truth.
;
; Band verdict: 4095 when the public-gate canary is embodied through both the
; agent board and satsang protocol:
;   1    board plus satsang protocol are present
;   2    treatment selects native-kernel
;   4    public Traefik no-header control stays outside native default
;   8    decision plus rollback receipts make the gate reversible
;   16   public Traefik default boundary is held
;   32   public evidence source is named
;   64   the circle witnesses and the answer survives
;   128  the answer is not self-certified
;   256  dissent remains visible
;   512  projection/invasion is dropped
;   1024 choice markers carry 0, 1, silence, protocol, fail, stop, bma
;   2048 the final state names witnessed native public-gate canary

(do
    (defn satsang-flip-witness-band ()
        (do
    (let r (sfw-public-canary-observation))
    (let w (sfw-witness-flip (sfw-public-canary-attestations)))
    (let markers (sfw-choice-markers))
    (let c0 (if (sfw-board-protocol? r) 1 0))
    (let c1 (if (sfw-treatment-native? r) 2 0))
    (let c2 (if (sfw-public-control-outside-native? r) 4 0))
    (let c3 (if (sfw-reversible? r) 8 0))
    (let c4 (if (sfw-ordinary-boundary-kept? r) 16 0))
    (let c5 (if (sfw-public-evidence-present? r) 32 0))
    (let c6 (if (and (eq (sat-welcome "can the flip be witnessed as true?") 1) (sat-survives? w)) 64 0))
    (let c7 (if (sfw-not-self-certified? w) 128 0))
    (let c8 (if (sfw-dissent-visible? w) 256 0))
    (let c9 (if (sfw-projection-dropped? w) 512 0))
    (let c10 (if (sfw-choice-markers-complete? markers) 1024 0))
    (let c11 (if (str_eq (sfw-witnessed-state r w) "witnessed-native-public-gate-canary") 2048 0))
    (add
        (add
            (add (add c0 c1) (add c2 c3))
            (add (add c4 c5) (add c6 c7)))
        (add (add c8 c9) (add c10 c11))))
    )
    (satsang-flip-witness-band))
