; Real-flow schema/ranker band.  Verdict 4095 when all twelve claims hold.
; preludes: form-stdlib/core.fk form-stdlib/record-src-shim.fk form-stdlib/rag-embed.fk form-stdlib/rag-retrieve.fk form-stdlib/native-model-session-grounding.fk

(do
    (defn nmsgb-observation-bits (observation)
        (do
            (let report (nth observation 0))
            (let results (nth observation 1))
            (let c3 (if (eq (nth report 4) 3) 8 0))
            (let c4 (if (eq (nth report 5) 3) 16 0))
            (let c5 (if (eq (nth report 6) 3) 32 0))
            (let c7 (if (eq (nmsg-digest? (nth report 12)) 1) 128 0))
            (let c8 (if (eq (len results) 3) 256 0))
            (let c9 (if (and (eq (nmsg-delta 500000 400000) 100000)
                             (eq (nth report 13) 1)) 512 0))
            (add c3 (add c4 (add c5 (add c7 (add c8 c9)))))))
    (defn nmsgb-result-bits (result)
        (if (and (eq (nmsg-digest? (nmsg-result-query result)) 1)
                 (eq (len (nmsg-result-top result)) 2)) 64 0))
    (defn nmsgb-string-list-equal? (a b)
        (if (eq (len a) 0) (if (eq (len b) 0) 1 0)
            (if (eq (len b) 0) 0
                (if (str_eq (head a) (head b))
                    (nmsgb-string-list-equal? (tail a) (tail b)) 0))))
    (defn nmsgb-ranker-equivalent-bit ()
        (do
            (let q (list 0 0))
            (let tie-index (list
                (rag-entry "tie-first" (list 0 1))
                (rag-entry "tie-second" (list 1 0))
                (rag-entry "two-first" (list 0 2))
                (rag-entry "two-second" (list 2 0))
                (rag-entry "far" (list 4 4))
                (rag-entry "farther" (list 5 5))))
            (let non-tie-index (list
                (rag-entry "zero" (list 0 0))
                (rag-entry "one" (list 0 1))
                (rag-entry "three" (list 1 2))
                (rag-entry "six" (list 3 3))
                (rag-entry "ten" (list 5 5))
                (rag-entry "fourteen" (list 7 7))))
            (if (and
                    (eq (nmsgb-string-list-equal?
                            (nmsg-top5 q tie-index)
                            (rag-topk q tie-index 5)) 1)
                    (eq (nmsgb-string-list-equal?
                            (nmsg-top5 q non-tie-index)
                            (rag-topk q non-tie-index 5)) 1)) 1024 0)))
    (defn nmsgb-daily-aggregate-bit (candidates episodes digest)
        (do
            (let summary
                (nmsg-daily-summary candidates episodes
                    (nmsg-daily-context digest digest digest -1 0
                                        9 3 12 3 99)))
            (if (and (ge (str_find summary "top5_hits=3" 0) 0)
                     (and (ge (str_find summary "detail_rows=0" 0) 0)
                          (and (ge (str_find summary "replay_valid=1" 0) 0)
                               (lt (str_find summary "query_1_" 0) 0)))) 2048 0)))
    (let digest "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef")
    (let candidates (list
        (nmsg-candidate "form/form-stdlib/core.fk" "core cell list arithmetic")
        (nmsg-candidate "form/form-stdlib/oracle-catalog.fk" "local remote oracle catalog")
        (nmsg-candidate "docs/coherence-substrate/form-cli-north-star.form" "native form cli north star")))
    (let episodes (list
        (nmsg-episode "2026-01-01T00:00:00Z" "where is the oracle catalog" digest (list "form/form-stdlib/oracle-catalog.fk"))
        (nmsg-episode "2026-01-02T00:00:00Z" "native form cli north star" digest (list "docs/coherence-substrate/form-cli-north-star.form"))
        (nmsg-episode "2026-01-03T00:00:00Z" "core cell list arithmetic" digest (list "form/form-stdlib/core.fk"))))
    (let bad (nmsg-candidate "../breach" "bad"))
    (let c0 (if (eq (nmsg-candidates-valid? candidates) 1) 1 0))
    (let c1 (if (eq (nmsg-candidate-valid? bad) 0) 2 0))
    (let c2 (if (eq (nmsg-episodes-valid? episodes candidates) 1) 4 0))
    (add c0
        (add c1
            (add c2
                (add (nmsgb-observation-bits
                         (nmsg-observe candidates episodes digest digest))
                     (add (nmsgb-result-bits
                              (nmsg-result digest
                                  (list "form/form-stdlib/core.fk")
                                  (list "form/form-stdlib/core.fk"
                                        "form/form-stdlib/oracle-catalog.fk") 1))
                          (add (nmsgb-ranker-equivalent-bit)
                               (nmsgb-daily-aggregate-bit candidates episodes digest)))))))
