; program-image-recipe-carrier-band.fk -- Layer 8h1 live recipe carrier witness.
;
; preludes: form-stdlib/form-ontology-loader.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-recipe-carrier.fk form-stdlib/reason-coverage.fk
;
; Expected: 2147483647

(do
    (defn pircb-score (ok bit) (if ok bit 0))
    (defn pircb-manifest-has (name)
        (program-image-recipe-carrier-manifest-has? name
            (program-image-recipe-carrier-manifest)))
    (defn pircb-has? (text needle)
        (ge (str_find text needle 0) 0))
    (defn pircb-read-file-any (primary fallback)
        (do
            (let first (read_file primary))
            (if (str_eq (value_kind first) "string")
                first
                (read_file fallback))))

    (defn pircb-table ()
        (pif-table-image 2
                         (list 0 3)
                         2
                         (list (pif-node-row 1 42 0 0)
                               (pif-node-row 12 0 0 0))
                         2
                         (list (list 65 66) (list 0 255))))
    (defn pircb-symbol-image ()
        (pif-symbol-image 2
                          (list (pif-symbol-row 0 "core/main")
                                (pif-symbol-row 1 "core/add"))
                          2
                          (list (pif-node-symbol-row 0 0 (list (pif-symbol-dependency-target 1 1)))
                                (pif-node-symbol-row 1 1 (empty)))))
    (defn pircb-envelope ()
        (pif-envelope-with-symbols "src/kernel.fk" "sha:src-a" 100
                                   "src/kernel.fkb" "sha:fkb-a" 101
                                   1
                                   (pircb-table)
                                   (pircb-symbol-image)))
    (defn pircb-carrier ()
        (pirc-carrier-from-envelope (pircb-envelope)))
    (defn pircb-recipe ()
        (pirc-carrier-recipe (pircb-carrier)))
    (defn pircb-table-node ()
        (nth (node_children (pircb-recipe)) 8))
    (defn pircb-symbol-image-node ()
        (nth (node_children (pircb-recipe)) 9))
    (defn pircb-node-symbol-rows-node ()
        (nth (node_children (pircb-symbol-image-node)) 3))
    (defn pircb-dependency-target-node ()
        (do
            (let node-symbol-row0 (nth (node_children (pircb-node-symbol-rows-node)) 0))
            (let targets-node (nth (node_children node-symbol-row0) 2))
            (nth (node_children targets-node) 0)))
    (defn pircb-fn-roots-node ()
        (nth (node_children (pircb-table-node)) 1))
    (defn pircb-node-rows-node ()
        (nth (node_children (pircb-table-node)) 3))
    (defn pircb-string-rows-node ()
        (nth (node_children (pircb-table-node)) 5))

    (defn pircb-bad-seal ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      0
                      (pircb-table)))
    (defn pircb-bad-counts ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pif-table-image 3 (list 0 3) 2
                                       (list (pif-node-row 1 42 0 0)
                                             (pif-node-row 12 0 0 0))
                                       2
                                       (list (list 65 66) (list 0 255)))))
    (defn pircb-bad-row ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pif-table-image 1 (list 0) 1
                                       (list (list 1 42 0))
                                       1
                                       (list (list 65)))))
    (defn pircb-bad-byte ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pif-table-image 1 (list 0) 1
                                       (list (pif-node-row 1 42 0 0))
                                       1
                                       (list (list 65 300)))))
    (defn pircb-non-int-root ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pif-table-image 1 (list "0") 1
                                       (list (pif-node-row 1 42 0 0))
                                       1
                                       (list (list 65)))))
    (defn pircb-non-int-node-cell ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pif-table-image 1 (list 0) 1
                                       (list (pif-node-row "1" 42 0 0))
                                       1
                                       (list (list 65)))))
    (defn pircb-non-int-byte-cell ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pif-table-image 1 (list 0) 1
                                       (list (pif-node-row 1 42 0 0))
                                       1
                                       (list (list "65")))))
    (defn pircb-non-string-source-path ()
        (pif-envelope 99 "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (pircb-table)))
    (defn pircb-non-string-envelope-tag ()
        (list 99 (pif-version) "src/kernel.fk" "sha:src-a" 100
              "src/kernel.fkb" "sha:fkb-a" 101 1 (pircb-table)))
    (defn pircb-non-string-table-tag ()
        (pif-envelope "src/kernel.fk" "sha:src-a" 100
                      "src/kernel.fkb" "sha:fkb-a" 101
                      1
                      (list 99 1 (list 0) 1
                            (list (pif-node-row 1 42 0 0))
                            1
                            (list (list 65)))))
    (defn pircb-malformed ()
        (list "program-image-fkb-envelope" 1))

    (defn pircb-malformed-row? (c)
        (and (str_eq (pirc-carrier-status c) (pirc-status-refused))
             (and (str_eq (pirc-carrier-reason c) (pirc-reason-malformed-pif-envelope))
                  (pirc-no-recipe? (pirc-carrier-recipe c)))))
    (defn pircb-invalid-row? (c)
        (and (str_eq (pirc-carrier-status c) (pirc-status-investigate))
             (and (str_eq (pirc-carrier-reason c) (pirc-reason-invalid-pif-envelope))
                  (pirc-no-recipe? (pirc-carrier-recipe c)))))
    (defn pircb-non-carrierable-row? (c)
        (and (str_eq (pirc-carrier-status c) (pirc-status-investigate))
             (and (str_eq (pirc-carrier-reason c) (pirc-reason-non-carrierable-table))
                  (pirc-no-recipe? (pirc-carrier-recipe c)))))

    (defn pircb-bit-manifest-1 ()
        (sum (list
            (pircb-score (eq (pircb-manifest-has "pif-envelope-to-recipe-node") 1) 1)
            (pircb-score (eq (pircb-manifest-has "registered-blueprint-categories") 1) 2)
            (pircb-score (and (eq (pircb-manifest-has "collection-nodes-preserve-table-sections") 1)
                          (and (eq (pircb-manifest-has "symbol-image-node-preserved") 1)
                               (eq (pircb-manifest-has "symbol-dependency-target-nodes-preserved") 1))) 4)
            (pircb-score (eq (pircb-manifest-has "all-leaves-trivial-nodes") 1) 8)
            (pircb-score (eq (pircb-manifest-has "string-byte-rows-as-byte-int-children") 1) 16)
            (pircb-score (eq (pircb-manifest-has "carrierable-scalar-gate") 1) 32)
            (pircb-score (and (eq (pircb-manifest-has "carrier-ready-not-load-ready") 1)
                              (eq (pircb-manifest-has "direct-fkwu-carrier-readiness-deferred") 1)) 64)
            (pircb-score (eq (pircb-manifest-has "no-recipe-sentinel") 1) 128)
            (pircb-score (eq (pircb-manifest-has "reason-manifest-covered") 1) 256)
            (pircb-score (eq (pircb-manifest-has "no-form-binary-io") 1) 512)
            (pircb-score (eq (pircb-manifest-has "no-disk-io") 1) 1024)
            (pircb-score (eq (pircb-manifest-has "no-table-payload-parse-or-execution") 1) 2048)
            (pircb-score (eq (pircb-manifest-has "no-runtime-load-call") 1) 4096)
            (pircb-score (eq (pircb-manifest-has "no-attempt-or-observation-row") 1) 8192)
            (pircb-score (eq (pircb-manifest-has "no-selector-install") 1) 16384)
            (pircb-score (eq (pircb-manifest-has "no-c-seed-growth") 1) 32768))))
    (defn pircb-bit-registered-bp ()
        (pircb-score
            (and (node_eq (pirc-envelope-bp) (make_nodeid 8 45 6 40))
            (and (node_eq (pirc-table-bp) (make_nodeid 8 45 6 41))
            (and (node_eq (pirc-fn-roots-bp) (make_nodeid 8 45 6 42))
            (and (node_eq (pirc-node-rows-bp) (make_nodeid 8 45 6 43))
            (and (node_eq (pirc-node-row-bp) (make_nodeid 8 45 6 44))
            (and (node_eq (pirc-string-rows-bp) (make_nodeid 8 45 6 45))
            (and (node_eq (pirc-string-row-bp) (make_nodeid 8 45 6 46))
            (and (node_eq (pirc-symbol-image-bp) (make_nodeid 8 45 6 67))
            (and (node_eq (pirc-symbol-rows-bp) (make_nodeid 8 45 6 68))
            (and (node_eq (pirc-symbol-row-bp) (make_nodeid 8 45 6 69))
            (and (node_eq (pirc-node-symbol-rows-bp) (make_nodeid 8 45 6 70))
            (and (node_eq (pirc-node-symbol-row-bp) (make_nodeid 8 45 6 71))
            (and (node_eq (pirc-symbol-dependency-targets-bp) (make_nodeid 8 45 6 72))
                 (node_eq (pirc-symbol-dependency-target-bp) (make_nodeid 8 45 6 73)))))))))))))))
            65536))
    (defn pircb-bit-ready-carrier ()
        (pircb-score
            (and (pirc-carrier? (pircb-carrier))
            (and (str_eq (pirc-carrier-status (pircb-carrier)) (pirc-status-carrier-ready))
            (and (str_eq (pirc-carrier-reason (pircb-carrier)) (pirc-reason-carrier-ready))
                 (not (pirc-no-recipe? (pirc-carrier-recipe (pircb-carrier)))))))
            131072))
    (defn pircb-bit-envelope-node ()
        (do
            (let kids (node_children (pircb-recipe)))
            (let target-kids (node_children (pircb-dependency-target-node)))
            (pircb-score
                (eq (sum (list
                    (pircb-score (node_eq (node_category (pircb-recipe)) (pirc-envelope-bp)) 1)
                    (pircb-score (eq (len kids) 10) 1)
                    (pircb-score (str_eq (node_value (nth kids 0)) (pif-version)) 1)
                    (pircb-score (str_eq (node_value (nth kids 1)) "src/kernel.fk") 1)
                    (pircb-score (str_eq (node_value (nth kids 2)) "sha:src-a") 1)
                    (pircb-score (eq (node_value (nth kids 3)) 100) 1)
                    (pircb-score (str_eq (node_value (nth kids 4)) "src/kernel.fkb") 1)
                    (pircb-score (str_eq (node_value (nth kids 5)) "sha:fkb-a") 1)
                    (pircb-score (eq (node_value (nth kids 6)) 101) 1)
                    (pircb-score (eq (node_value (nth kids 7)) 1) 1)
                    (pircb-score (node_eq (node_category (nth kids 9)) (pirc-symbol-image-bp)) 1)
                    (pircb-score (node_eq (node_category (pircb-node-symbol-rows-node)) (pirc-node-symbol-rows-bp)) 1)
                    (pircb-score (node_eq (node_category (pircb-dependency-target-node)) (pirc-symbol-dependency-target-bp)) 1)
                    (pircb-score (eq (node_value (nth target-kids 0)) 1) 1)
                    (pircb-score (eq (node_value (nth target-kids 1)) 1) 1)))
                    15)
                262144)))
    (defn pircb-bit-table-node ()
        (do
            (let kids (node_children (pircb-table-node)))
            (pircb-score
                (and (node_eq (node_category (pircb-table-node)) (pirc-table-bp))
                (and (eq (len kids) 6)
                (and (eq (node_value (nth kids 0)) 2)
                (and (node_eq (node_category (nth kids 1)) (pirc-fn-roots-bp))
                (and (eq (node_value (nth kids 2)) 2)
                (and (node_eq (node_category (nth kids 3)) (pirc-node-rows-bp))
                (and (eq (node_value (nth kids 4)) 2)
                     (node_eq (node_category (nth kids 5)) (pirc-string-rows-bp)))))))))
                524288)))
    (defn pircb-bit-node-rows ()
        (do
            (let rows (node_children (pircb-node-rows-node)))
            (let row0 (nth rows 0))
            (let row1 (nth rows 1))
            (pircb-score
                (and (eq (len rows) 2)
                (and (node_eq (node_category row0) (pirc-node-row-bp))
                (and (node_eq (node_category row1) (pirc-node-row-bp))
                (and (eq (node_value (nth (node_children row0) 0)) 1)
                (and (eq (node_value (nth (node_children row0) 1)) 42)
                     (eq (node_value (nth (node_children row1) 0)) 12))))))
                1048576)))
    (defn pircb-bit-string-rows ()
        (do
            (let rows (node_children (pircb-string-rows-node)))
            (let row0 (nth rows 0))
            (let row1 (nth rows 1))
            (pircb-score
                (and (eq (len rows) 2)
                (and (node_eq (node_category row0) (pirc-string-row-bp))
                (and (node_eq (node_category row1) (pirc-string-row-bp))
                (and (eq (node_value (nth (node_children row0) 0)) 65)
                (and (eq (node_value (nth (node_children row0) 1)) 66)
                (and (eq (node_value (nth (node_children row1) 0)) 0)
                     (eq (node_value (nth (node_children row1) 1)) 255)))))))
                2097152)))
    (defn pircb-bit-fn-roots-and-stability ()
        (do
            (let roots (node_children (pircb-fn-roots-node)))
            (pircb-score
                (and (eq (len roots) 2)
                (and (eq (node_value (nth roots 0)) 0)
                (and (eq (node_value (nth roots 1)) 3)
                     (node_eq (pircb-recipe) (pirc-carrier-recipe (pirc-carrier-from-envelope (pircb-envelope)))))))
                4194304)))
    (defn pircb-bit-distinct-source-changes-node ()
        (do
            (let other (pif-envelope "src/other.fk" "sha:src-b" 100
                                     "src/kernel.fkb" "sha:fkb-a" 101
                                     1
                                     (pircb-table)))
            (pircb-score
                (not (node_eq (pircb-recipe)
                              (pirc-carrier-recipe (pirc-carrier-from-envelope other))))
                8388608)))
    (defn pircb-bit-malformed-refused ()
        (do
            (let c (pirc-carrier-from-envelope (pircb-malformed)))
            (pircb-score
                (and (pircb-malformed-row? c)
                     (pircb-malformed-row? (pirc-carrier-from-envelope (pircb-non-string-envelope-tag))))
                16777216)))
    (defn pircb-bit-invalid-seal ()
        (pircb-score
            (and (pircb-invalid-row? (pirc-carrier-from-envelope (pircb-bad-seal)))
                 (pircb-invalid-row? (pirc-carrier-from-envelope (pircb-non-string-source-path))))
            33554432))
    (defn pircb-bit-invalid-table-shapes ()
        (pircb-score
            (and (pircb-invalid-row? (pirc-carrier-from-envelope (pircb-bad-counts)))
            (and (pircb-invalid-row? (pirc-carrier-from-envelope (pircb-bad-row)))
                 (pircb-invalid-row? (pirc-carrier-from-envelope (pircb-bad-byte)))))
            67108864))
    (defn pircb-bit-non-int-root ()
        (pircb-score
            (and (pif-envelope-valid? (pircb-non-int-root))
                 (pircb-non-carrierable-row? (pirc-carrier-from-envelope (pircb-non-int-root))))
            134217728))
    (defn pircb-bit-non-int-node-cell ()
        (pircb-score
            (and (pircb-non-carrierable-row? (pirc-carrier-from-envelope (pircb-non-int-node-cell)))
            (and (pircb-non-carrierable-row? (pirc-carrier-from-envelope (pircb-non-int-byte-cell)))
                 (pircb-non-carrierable-row? (pirc-carrier-from-envelope (pircb-non-string-table-tag)))))
            268435456))
    (defn pircb-bit-reason-coverage ()
        (do
            (let observed
                (list
                    (pirc-carrier-reason (pircb-carrier))
                    (pirc-carrier-reason (pirc-carrier-from-envelope (pircb-malformed)))
                    (pirc-carrier-reason (pirc-carrier-from-envelope (pircb-bad-seal)))
                    (pirc-carrier-reason (pirc-carrier-from-envelope (pircb-non-int-root)))
                    (pirc-reason-native-raw-kind-floor)))
            (pircb-score (rcov-covered? (rcov-coverage (pirc-reason-manifest) observed)) 536870912)))
    (defn pircb-bit-static-and-mirror ()
        (do
            (let text (pircb-read-file-any "form/form-stdlib/program-image-recipe-carrier.fk"
                                           "../form/form-stdlib/program-image-recipe-carrier.fk"))
            (let grammar (pircb-read-file-any "grammars/program-image-recipe-carrier.fk"
                                              "../grammars/program-image-recipe-carrier.fk"))
            (let registry (pircb-read-file-any "form/form-stdlib/blueprint-registry.json"
                                               "../form/form-stdlib/blueprint-registry.json"))
            (pircb-score
                (and (str_eq text grammar)
                (and (pircb-has? registry "PROGRAM-IMAGE-RECIPE-ENVELOPE")
                (and (pircb-has? registry "PROGRAM-IMAGE-RECIPE-STRING-ROW")
                (and (not (pircb-has? text "write_form_binary"))
                (and (not (pircb-has? text "read_form_binary"))
                (and (not (pircb-has? text "recipe_to_bytes"))
                (and (not (pircb-has? text "bytes_to_recipe"))
                (and (not (pircb-has? text "runtime-table-payload"))
                (and (not (pircb-has? text "walk_recipe"))
                (and (not (pircb-has? text "fk_run"))
                (and (not (pircb-has? text "dlopen"))
                     (not (pircb-has? text "dlsym")))))))))))))
                1073741824)))

    (defn program-image-recipe-carrier-band ()
        (sum (list
            (pircb-bit-manifest-1)
            (pircb-bit-registered-bp)
            (pircb-bit-ready-carrier)
            (pircb-bit-envelope-node)
            (pircb-bit-table-node)
            (pircb-bit-node-rows)
            (pircb-bit-string-rows)
            (pircb-bit-fn-roots-and-stability)
            (pircb-bit-distinct-source-changes-node)
            (pircb-bit-malformed-refused)
            (pircb-bit-invalid-seal)
            (pircb-bit-invalid-table-shapes)
            (pircb-bit-non-int-root)
            (pircb-bit-non-int-node-cell)
            (pircb-bit-reason-coverage)
            (pircb-bit-static-and-mirror))))

    (program-image-recipe-carrier-band))
