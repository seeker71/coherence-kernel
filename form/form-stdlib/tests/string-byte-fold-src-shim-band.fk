; string-byte-fold-src-shim-band.fk — the shim's fold IS the native's fold.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/string-byte-fold-src-shim.fk
;
; Verdict: 7 when
;   bit 1 — empty string folds to the seed untouched
;   bit 2 — "abc" byte-sum folds to 294 (97+98+99), order-independent check
;   bit 4 — order witnessed: "abc" folded as acc*1000+byte reads 97098099,
;           so the step saw 97 then 98 then 99, left to right
;
; --src surface only: on the sibling kernels the native carries this name,
; and this band's preludes would shadow it with the same contract.

(do
    (defn sbfb-sum-step (acc b) (add acc b))
    (defn sbfb-ord-step (acc b) (add (mul acc 1000) b))

    (defn sbfb-bit-empty ()
        (if (eq (string_byte_fold "" 42 sbfb-sum-step) 42) 1 0))
    (defn sbfb-bit-sum ()
        (if (eq (string_byte_fold "abc" 0 sbfb-sum-step) 294) 2 0))
    (defn sbfb-bit-order ()
        (if (eq (string_byte_fold "abc" 0 sbfb-ord-step) 97098099) 4 0))

    (add (sbfb-bit-empty) (add (sbfb-bit-sum) (sbfb-bit-order))))
