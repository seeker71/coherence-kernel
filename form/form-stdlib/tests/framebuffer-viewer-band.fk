; framebuffer-viewer-band.fk — produce framebuffer activity for the viewer,
; and prove the framebuffer four-way (Go/Rust/TS/fkwu).
;
; Every kernel records source-attributed cell creations in the framebuffer:
; each intern_node_at call writes one (file line col) entry keyed by NodeID and
; appends the NodeID to the ordered roots list. framebuffer-clear resets that
; window; framebuffer-events returns the roots. This band clears the framebuffer
; (so prelude/parse attribution is wiped and the window starts empty on EVERY
; kernel), bursts a deterministic set of attributed cells, and counts them.
;
; The score is (len (framebuffer-events)) = 100. Clearing first makes the count
; absolute (no kernel-specific prelude baseline to subtract), and because intern
; is content-addressed, each distinct line yields a distinct composite NodeID, so
; the 100 cells are 100 distinct entries on all four kernels.
;
; The framebuffer this band exercises is reachable live on the C-bootstrapped
; form-cli through its `diagnose` verb (the op-dispatch side, kernel_stat tag 127)
; and through framebuffer-events / node_source (the source-attribution side,
; tags 129/130) for any Form program running on fkwu.

(do
    ;; A single category for every cell — keeps the viewer's "Top Blueprint"
    ;; pane focused on one (pkg, level, type) signature so the visualization
    ;; clearly shows where the burst landed.
    (defn cell-cat (_x) (make_nodeid 1 2 12 1))

    ;; emit-one: intern a composite with the line number as its child trivial.
    ;; The child differs across lines, so each call produces a distinct composite
    ;; NodeID and a fresh framebuffer entry.
    (defn emit-one (file line)
        (intern_node_at (cell-cat 0)
                        (list (intern_trivial_int line))
                        file line 1))

    ;; emit-range: walk lines [start, end) issuing one cell per line.
    (defn emit-range (file start end)
        (if (ge start end) 0
            (do
                (emit-one file start)
                (emit-range file (add start 1) end))))

    ;; Clear first — the window now starts empty on every kernel (the prelude's
    ;; parse-time attribution is wiped), so the final count is absolute, not a
    ;; kernel-specific delta.
    (framebuffer-clear)

    ;; Burst: 100 cells across one synthetic file, distinct line nums (so
    ;; distinct composites, distinct framebuffer entries).
    (emit-range "viewer/burst.fk" 1 101)

    ;; The witness: 100 — one entry per emit-one call.
    (len (framebuffer-events)))
