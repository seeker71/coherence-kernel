; core-waist-language-band.fk -- core layer names its native string trust waist.
;
; preludes: form-stdlib/core.fk
;
; This is the layer-appropriate language abstraction for core: a queryable
; native dependency boundary, not a separate parser, tokenizer, line grammar, or
; BMF cursor surface. BMF cursor grammars begin in the grammar layer above core.
;
; run: cat form/form-stdlib/core.fk \
;          form/form-stdlib/tests/core-waist-language-band.fk > /tmp/core-waist.fk
;      ./fkwu --src /tmp/core-waist.fk    ; -> 255
;
; Bits:
;   1   four waist ops are declared
;   2   str_len is in the waist
;   4   str_byte_at is in the waist
;   8   byte_to_str is in the waist
;   16  str_concat is in the waist
;   32  substring is not in the waist
;   64  substring is in the composed string inventory
;   128 core still has four semantic classes, not a smuggled grammar class

(do
    (defn cwl-score (ok bit) (if ok bit 0))
    (defn core-waist-language-band ()
        (do
            (let waist (core-native-string-waist))
            (let composed (core-composed-string-ops))
            (let c0 (cwl-score (eq (len waist) 4) 1))
            (let c1 (cwl-score (eq (core-waist-has? "str_len" waist) 1) 2))
            (let c2 (cwl-score (eq (core-waist-has? "str_byte_at" waist) 1) 4))
            (let c3 (cwl-score (eq (core-waist-has? "byte_to_str" waist) 1) 8))
            (let c4 (cwl-score (eq (core-waist-has? "str_concat" waist) 1) 16))
            (let c5 (cwl-score (eq (core-waist-has? "substring" waist) 0) 32))
            (let c6 (cwl-score (eq (core-name-in? "substring" composed) 1) 64))
            (let c7 (cwl-score (eq (core-class-count) 4) 128))
            (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7)))))))))

    (core-waist-language-band))
