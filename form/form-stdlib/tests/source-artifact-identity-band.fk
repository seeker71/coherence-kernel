; source-artifact-identity-band.fk -- Layer 8d digest/vouch witness.
;
; preludes: form-stdlib/core.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/form-fs.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk
;
; Expected: 2147483647
;
; This band proves supplied-byte digest identity, scoped text-source identity
; with an observed-size guard, and enrichment into 8c observations. It does not
; prove binary file hashing, seal/signature verification, native proof,
; callable admission, artifact load/call, runtime selector installation,
; compiler emission, cache writes, or C seed growth.
;
; Bits:
;   1          manifest declares byte-list-sha256-hex
;   2          manifest declares declared-content-hash-verify
;   4          manifest declares declared-source-hash-verify
;   8          manifest declares evidence-kind-carried
;   16         manifest declares supplied-byte-list-evidence
;   32         manifest declares text-source-helper-scoped
;   64         manifest declares text-size-must-match-observed
;   128        manifest declares emits-observations-for-sap
;   256        manifest declares identity-match-does-not-set-seal-ok
;   512        manifest declares no-seal-verification
;   1024       manifest declares no-proof-callable-native-admission
;   2048       manifest declares no-artifact-load
;   4096       manifest declares no-runtime-selector
;   8192       manifest declares no-compiler-emission
;   16384      manifest declares no-cache-write
;   32768      manifest declares no-c-seed-growth
;   65536      manifest declares no-binary-file-hash
;   131072     manifest declares read-file-bytes-not-checkout-witness
;   262144     manifest declares does-not-derive-sac-state-or-route
;   524288     manifest declares read-only-no-disk-write
;   1048576    manifest declares no-sap-import-cycle
;   2097152    empty byte-list SHA-256 vector matches
;   4194304    abc byte-list SHA-256 vector matches
;   8388608    56-byte padding/two-block vector matches
;   16777216   declared hash match and mismatch are distinct
;   33554432   undeclared/malformed/uppercase policy is conservative
;   67108864   vouch row carries target, evidence kind, and sizes
;   134217728  text helper and live text observation accept size match and refuse mismatch
;   268435456  8c enrichment preserves separate seal evidence
;   536870912  digest match cannot admit native without proof/callable
;   1073741824 read_file_bytes checkout gap canary: 3-byte file is not a byte list

(do
    (defn saib-score (ok bit) (if ok bit 0))
    (defn saib-manifest-has (name)
        (source-artifact-identity-manifest-has? name (source-artifact-identity-manifest)))
    (defn saib-empty-hash ()
        "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")
    (defn saib-abc-hash ()
        "sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    (defn saib-two-block-text ()
        "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
    (defn saib-two-block-hash ()
        "sha256:248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1")
    (defn saib-fkb-hash ()
        "sha256:573dbb57d6af3d54263620b016da6212869e4aadb8a867ad9d78ba2b15cba1d1")
    (defn saib-dylib-hash ()
        "sha256:6ca4c50d821f7f130312f82d37d2d8062256f9dcc0db409fd7323651167069b3")

    (defn saib-source-vouch ()
        (sai-vouch-source-bytes "src/kernel.fk" (saib-abc-hash) (list 97 98 99)))
    (defn saib-fkb-vouch ()
        (sai-vouch-content-bytes "src/kernel.fkb" (saib-fkb-hash) (sai-string-bytes "fkb")))
    (defn saib-dylib-vouch ()
        (sai-vouch-content-bytes "src/kernel.dylib" (saib-dylib-hash) (sai-string-bytes "dylib")))
    (defn saib-missing-fkb ()
        (sap-program-image-fkb-observation "src/kernel.fkb" 0 -1 -1 "" "" 0 0))

    (defn saib-bit-manifest-1 ()
        (sum (list
            (saib-score (eq (saib-manifest-has "byte-list-sha256-hex") 1) 1)
            (saib-score (eq (saib-manifest-has "declared-content-hash-verify") 1) 2)
            (saib-score (eq (saib-manifest-has "declared-source-hash-verify") 1) 4)
            (saib-score (eq (saib-manifest-has "evidence-kind-carried") 1) 8)
            (saib-score (eq (saib-manifest-has "supplied-byte-list-evidence") 1) 16)
            (saib-score (eq (saib-manifest-has "text-source-helper-scoped") 1) 32)
            (saib-score (eq (saib-manifest-has "text-size-must-match-observed") 1) 64)
            (saib-score (eq (saib-manifest-has "emits-observations-for-sap") 1) 128)
            (saib-score (eq (saib-manifest-has "identity-match-does-not-set-seal-ok") 1) 256)
            (saib-score (eq (saib-manifest-has "no-seal-verification") 1) 512)
            (saib-score (eq (saib-manifest-has "no-proof-callable-native-admission") 1) 1024))))

    (defn saib-bit-manifest-2 ()
        (sum (list
            (saib-score (eq (saib-manifest-has "no-artifact-load") 1) 2048)
            (saib-score (eq (saib-manifest-has "no-runtime-selector") 1) 4096)
            (saib-score (eq (saib-manifest-has "no-compiler-emission") 1) 8192)
            (saib-score (eq (saib-manifest-has "no-cache-write") 1) 16384)
            (saib-score (eq (saib-manifest-has "no-c-seed-growth") 1) 32768)
            (saib-score (eq (saib-manifest-has "no-binary-file-hash") 1) 65536)
            (saib-score (eq (saib-manifest-has "read-file-bytes-not-checkout-witness") 1) 131072)
            (saib-score (eq (saib-manifest-has "does-not-derive-sac-state-or-route") 1) 262144)
            (saib-score (eq (saib-manifest-has "read-only-no-disk-write") 1) 524288)
            (saib-score (eq (saib-manifest-has "no-sap-import-cycle") 1) 1048576))))

    (defn saib-bit-empty-vector ()
        (saib-score
            (str_eq (sai-sha256-hex (list)) (saib-empty-hash))
            2097152))
    (defn saib-bit-abc-vector ()
        (saib-score
            (str_eq (sai-sha256-hex (list 97 98 99)) (saib-abc-hash))
            4194304))
    (defn saib-bit-two-block-vector ()
        (saib-score
            (and (eq (str_len (saib-two-block-text)) 56)
                 (str_eq (sai-sha256-string (saib-two-block-text)) (saib-two-block-hash)))
            8388608))
    (defn saib-bit-match-mismatch ()
        (do
            (let good (sai-vouch-source-bytes "src/kernel.fk" (saib-abc-hash) (list 97 98 99)))
            (let bad (sai-vouch-source-bytes "src/kernel.fk" (saib-empty-hash) (list 97 98 99)))
            (saib-score
                (and (str_eq (sai-vouch-status good) (sai-status-match))
                     (and (str_eq (sai-vouch-status bad) (sai-status-mismatch))
                          (str_eq (sai-vouch-actual-hash bad) (saib-abc-hash))))
                16777216)))
    (defn saib-bit-malformed-policy ()
        (do
            (let undeclared (sai-vouch-source-bytes "src/kernel.fk" "" (list 97 98 99)))
            (let short (sai-vouch-source-bytes "src/kernel.fk" "sha256:abc" (list 97 98 99)))
            (let upper (sai-vouch-source-bytes "src/kernel.fk" "sha256:BA7816BF8F01CFEA414140DE5DAE2223B00361A396177A9CB410FF61F20015AD" (list 97 98 99)))
            (saib-score
                (and (str_eq (sai-vouch-status undeclared) (sai-status-undeclared))
                     (and (str_eq (sai-vouch-status short) (sai-status-malformed))
                          (str_eq (sai-vouch-status upper) (sai-status-malformed))))
                33554432)))
    (defn saib-bit-vouch-row ()
        (do
            (let v (saib-source-vouch))
            (saib-score
                (and (str_eq (sai-vouch-target v) (sai-target-source-hash))
                     (and (str_eq (sai-vouch-evidence-kind v) (sai-evidence-supplied-bytes))
                          (and (eq (sai-vouch-observed-size v) 3)
                               (eq (sai-vouch-material-size v) 3))))
                67108864)))
    (defn saib-bit-text-helper-size ()
        (do
            (let good (sai-vouch-text-source "src/kernel.fk" 3 (saib-abc-hash) "abc"))
            (let bad (sai-vouch-text-source "src/kernel.fk" 4 (saib-abc-hash) "abc"))
            (let root (fs-path-join (fs-temp-dir) "source-artifact-identity-text-band"))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let fpath (fs-path-join root "source.fk"))
            (let missing-path (fs-path-join root "missing.fk"))
            (let _w (fs-write-text fpath "abc"))
            (let live-obs (sap-observe-source fpath ""))
            (let live-good (sai-vouch-text-source-observation live-obs (saib-abc-hash)))
            (let live-bad-obs (sap-source-observation fpath 1 4 (sap-observation-mtime live-obs) ""))
            (let live-bad (sai-vouch-text-source-observation live-bad-obs (saib-abc-hash)))
            (let live-missing (sai-vouch-text-source-observation (sap-source-observation missing-path 0 -1 -1 "") (saib-abc-hash)))
            (let _rm (fs-remove-file fpath))
            (let _rt (fs-remove-tree root))
            (saib-score
                (and (str_eq (sai-vouch-status good) (sai-status-match))
                     (and (str_eq (sai-vouch-evidence-kind good) (sai-evidence-text-source))
                          (and (str_eq (sai-vouch-status bad) (sai-status-size-mismatch))
                               (and (str_eq (sai-vouch-actual-hash bad) "")
                                    (and (str_eq (sai-vouch-status live-good) (sai-status-match))
                                         (and (str_eq (sai-vouch-status live-bad) (sai-status-size-mismatch))
                                              (str_eq (sai-vouch-status live-missing) (sai-status-unobserved))))))))
                134217728)))
    (defn saib-bit-sap-enrichment-seal-separate ()
        (do
            (let source-v (saib-source-vouch))
            (let content-v (saib-fkb-vouch))
            (let src (sai-source-observation-from-vouch "src/kernel.fk" 1 3 100 source-v))
            (let fkb (sai-program-image-fkb-observation-from-vouches "src/kernel.fkb" 1 3 101 source-v content-v 0 1))
            (let p (sap-plan-from-probe (sap-bundle src fkb (sap-native-dylib-observation "src/kernel.dylib" 0 -1 -1 "" "" 0 0 0 0))))
            (saib-score
                (and (str_eq (sap-observation-source-hash fkb) (saib-abc-hash))
                     (and (str_eq (sap-observation-content-hash fkb) (saib-fkb-hash))
                          (and (eq (sap-observation-seal-ok fkb) 0)
                               (not (str_eq (rap-plan-primary p) (rap-act-run-program-image))))))
                268435456)))
    (defn saib-bit-no-native-admission ()
        (do
            (let source-v (saib-source-vouch))
            (let fkb-v (saib-fkb-vouch))
            (let dylib-v (saib-dylib-vouch))
            (let src (sai-source-observation-from-vouch "src/kernel.fk" 1 3 100 source-v))
            (let fkb (sai-program-image-fkb-observation-from-vouches "src/kernel.fkb" 1 3 101 source-v fkb-v 1 1))
            (let dylib (sai-native-dylib-observation-from-vouches "src/kernel.dylib" 1 5 102 source-v dylib-v 1 0 0 1))
            (let p (sap-plan-from-probe (sap-bundle src fkb dylib)))
            (saib-score
                (and (not (str_eq (rap-plan-primary p) (rap-act-run-native)))
                     (str_eq (rap-plan-primary p) (rap-act-run-program-image)))
                536870912)))
    (defn saib-bit-read-file-bytes-gap ()
        (do
            (let root (fs-path-join (fs-temp-dir) "source-artifact-identity-band"))
            (let _pre (fs-remove-tree root))
            (let _mk (fs-mkdir root))
            (let fpath (fs-path-join root "bytes.txt"))
            (let _w (fs-write-text fpath "abc"))
            (let bytes (fs-read-bytes fpath))
            (let bytes-len (len bytes))
            (let _rm (fs-remove-file fpath))
            (let _rt (fs-remove-tree root))
            (saib-score
                (eq bytes-len 0)
                1073741824)))

    (defn source-artifact-identity-band ()
        (sum (list
            (saib-bit-manifest-1)
            (saib-bit-manifest-2)
            (saib-bit-empty-vector)
            (saib-bit-abc-vector)
            (saib-bit-two-block-vector)
            (saib-bit-match-mismatch)
            (saib-bit-malformed-policy)
            (saib-bit-vouch-row)
            (saib-bit-text-helper-size)
            (saib-bit-sap-enrichment-seal-separate)
            (saib-bit-no-native-admission)
            (saib-bit-read-file-bytes-gap))))

    (source-artifact-identity-band))
