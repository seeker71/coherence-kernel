; preludes: form-stdlib/core.fk form-stdlib/hati-os-targets.fk
;
; hati-os-targets-band - host OS implementation and distribution catalog proof.
; Verdict 8388607 when macOS, Android, Windows ARM64, Windows amd64, and
; Windows x86_64 target rows, oracle surfaces, Form-native object/executable
; emitters or explicit pending ARM64 PE/COFF gaps, arm64/x64 JIT runtime rows,
; Windows x64 DLL bootstrap exe rows, implementation rows, and hati.earth
; download coordinates are discoverable.

(do
    (let c0 (if (eq (len (hos-targets)) 5)
                (if (eq (len (hos-artifacts)) 5) 1 0)
                0))

    (let mac (hos-target-by-name "macos-arm64"))
    (let android (hos-target-by-name "android-arm64"))
