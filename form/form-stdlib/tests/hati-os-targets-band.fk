                            0)
                        0)
                    0)
                0))
    (let c21 (if (str_eq (hos-target-form-native-object win64) "form-pe-coff")
                (if (str_eq (hos-target-form-native-executable win64) "form-pe-coff+dll-bootstrap-exe")
