                        0)
                    0)
                0))
    (let c22 (if (str_eq (hos-target-binary-format win64) "pe-coff")
                (if (str_eq (hos-target-assembly-surface win64) "pe-coff+x64-asm")
                    (if (str_eq (hos-target-jit-runtime win64) "fkwu-self-jit-no-runtime-toolchain") 4194304 0)
                    0)
                0))

    (let total0 (add c0 c1))
    (let total1 (add total0 c2))
    (let total2 (add total1 c3))
    (let total3 (add total2 c4))
    (let total4 (add total3 c5))
    (let total5 (add total4 c6))
    (let total6 (add total5 c7))
    (let total7 (add total6 c8))
    (let total8 (add total7 c9))
    (let total9 (add total8 c10))
    (let total10 (add total9 c11))
    (let total11 (add total10 c12))
    (let total12 (add total11 c13))
    (let total13 (add total12 c14))
    (let total14 (add total13 c15))
    (let total15 (add total14 c16))
    (let total16 (add total15 c17))
    (let total17 (add total16 c18))
    (let total18 (add total17 c19))
    (let total19 (add total18 c20))
