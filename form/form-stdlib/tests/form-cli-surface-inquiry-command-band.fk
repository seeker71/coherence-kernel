; form-cli-surface-inquiry-command-band.fk — source-resolved form-cli verb
; witness.  The offered lineage is queried through fc-respond itself.
;
; import "form/form-stdlib/form-cli.fk"

(do
    (defn fscic-bit (condition bit) (if condition bit 0))
    (defn form-cli-surface-inquiry-command-check ()
        (do
            (let line "surface-inquiry 31|PL|form|form-cli|surface,channel,lineage,evidence|ephemeral|rq-31|rs-32|grounded|fb-32|lineage")
            (let answer (fc-respond line))
            (let denied (fc-respond "surface-inquiry 31|PL|form|form-cli|surface|ephemeral|rq-31|rs-32|grounded|fb-32|lineage"))
            ; Verdict 3: fc-respond reaches the declared lineage and denies an
            ; unoffered relation; neither route retains request/response text.
            (add (fscic-bit (str_eq answer "surface-inquiry|relation=lineage|answer=rs-32,31,31|framebuffer-events=2") 1)
                 (fscic-bit (str_eq denied "surface-inquiry:miss") 2))))
    (form-cli-surface-inquiry-command-check))
