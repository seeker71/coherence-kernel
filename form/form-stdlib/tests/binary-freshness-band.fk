; binary-freshness-band.fk — is the ./fkwu binary you are holding actually
; built from the runtime source you are reading?
;
; preludes: NONE — deliberately. This band must not be confoundable by a
; missing or drifted prelude; every check below uses only native ops and
; plain defns.
;
; Exists because of a real, expensive failure (receipts/2026-07-01-stale-
; binary-root-cause.md): ./fkwu is gitignored — a local build artifact —
; and after a large upstream merge moved runtime/fkwu-uni.c far ahead, the
; stale local binary kept passing ground.fk (42 is an old contract) while
; silently lacking newer evaluator capabilities. A day of work then
; "discovered" evaluator constraints — forward references and mutual
; recursion between defns never resolve, intern_trivial_bool true/false
; construct the same node — that were never true of the current source at
; all, and real code got restructured around them. ground.fk alone cannot
; catch this class of failure; this band checks the exact capabilities
; that were missing, so a stale binary fails HERE, by name, before it can
; masquerade as an interpreter bug. If this band does not return 15:
; rebuild first, investigate second —
;
;     cc -O2 -o fkwu runtime/fkwu-uni.c
;
; Verdict 15 when the binary is fresh enough.

(do
    ; true/false literals (the stale binary parsed `true` as an unbound
    ; symbol -> 0; current source maps it to 1 in the bare-symbol arm)
    (defn bfb-true-literal () (if (eq true 1) 1 0))

    ; forward reference: a defn calling a defn defined LATER (current
    ; source pre-scans all defns; the stale binary resolved at definition
    ; time and silently called nothing)
    (defn bfb-fwd-caller () (bfb-fwd-callee))
    (defn bfb-fwd-callee () 2)

    ; mutual recursion between two different defns
    (defn bfb-even? (n) (if (eq n 0) 1 (bfb-odd? (sub n 1))))
    (defn bfb-odd?  (n) (if (eq n 0) 0 (bfb-even? (sub n 1))))

    ; trivial bools are two DISTINCT nodes (the stale binary, fed 0 for
    ; both true and false, interned one node for both)
    (defn bfb-bool-distinct ()
        (if (eq (intern_trivial_bool true) (intern_trivial_bool false)) 0 8))

    (defn binary-freshness-band ()
        (add (bfb-true-literal)
        (add (bfb-fwd-caller)
        (add (if (eq (bfb-even? 4) 1) 4 0)
             (bfb-bool-distinct)))))
    (binary-freshness-band))
