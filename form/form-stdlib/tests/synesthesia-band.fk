; tests/synesthesia-band.fk — cross-domain same-shape proof.
;
; preludes: form-stdlib/json.fk form-stdlib/synesthesia.fk
;
; The proof: an AUDIO chord and an IMAGE triangle built from the same ratio
; (4, 5, 6) share the SAME shape-NodeID, while their outer domain-tagged
; Recipes differ. A second triangle (3, 4, 5) carries a different shape.
;
; Scoring — sum to 4 for a clean witness:
;   1  cross-domain same shape: (audio-chord 4 5 6) and (image-triangle 4 5 6)
;                               share shape-of → node_eq = true
;   1  domain Blueprints differ: the outer Recipes are NOT node_eq (different
;                                domain tag, same child)
;   1  intra-domain different shape: (image-triangle 4 5 6) and
;                                    (image-triangle 3 4 5) do NOT share shape
;   1  shape-recipe content-address: ratio-recipe(4,5,6) called twice returns
;                                    the SAME NodeID (interning works)

(do
    (let audio-456    (audio-chord 4 5 6))
    (let image-456    (image-triangle 4 5 6))
    (let image-345    (image-triangle 3 4 5))

    ;; (1) Cross-domain SAME SHAPE — the load-bearing proof.
    (let cross-same   (if (same-shape? audio-456 image-456) 1 0))

    ;; (2) Domain Blueprints differ — outer Recipes are NOT node_eq even
    ;; though their single child (the ratio-Recipe) is identical.
    (let outer-diff   (if (node_eq audio-456 image-456) 0 1))

    ;; (3) Intra-domain DIFFERENT SHAPE — same domain, different ratio
    ;; → shape-of returns different NodeIDs.
    (let intra-diff   (if (same-shape? image-456 image-345) 0 1))

    ;; (4) Content-addressing on the shape — calling ratio-recipe twice with
    ;; the same args returns one NodeID. This is the substrate doing the
    ;; synesthesia: no projection table, just dedup.
    (let r1           (ratio-recipe 4 5 6))
    (let r2           (ratio-recipe 4 5 6))
    (let intern-dedup (if (node_eq r1 r2) 1 0))

    (add cross-same (add outer-diff (add intra-diff intern-dedup))))
