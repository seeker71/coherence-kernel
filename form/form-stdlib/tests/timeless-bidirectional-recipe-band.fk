import "../timeless-bidirectional-recipe.fk"
(do
  (framebuffer-clear)
  (let recipe (tbr-recipe 81 (list (tbr-step 0 7) (tbr-step 2 -4) (tbr-step 1 11))))
  (let a (list 3 5 8))
  (let b (list 101 -20 44))
  (let exchange (tbr-exchange recipe a b))
  (let good-backward (tbr-send-backward recipe b a))
  (let tampered-inbound (tbr-envelope recipe 1 b (nth good-backward 3) 0))
  (let events (framebuffer-events))
  (list
    (tbr-forward recipe a)
    (tbr-backward recipe (tbr-forward recipe a))
    (tbr-backward recipe b)
    (tbr-forward recipe (tbr-backward recipe b))
    (nth exchange 2)
    (tbr-correlated? (tbr-send-forward recipe a b) tampered-inbound)
    (len events)
    (if (and (eq (tbr-proven? recipe a b) 1)
      (and (eq (nth exchange 2) 1)
      (and (eq (tbr-correlated? (tbr-send-forward recipe a b) tampered-inbound) 0)
           (eq (len events) 2)))) 1 0)))
