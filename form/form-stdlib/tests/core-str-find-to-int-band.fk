; core-str-find-to-int-band.fk — proof of Form-native str_find / str_to_int.
;
; preludes: form-stdlib/core.fk
;
; Both built over the string narrow waist (str_len/str_byte_at/byte_to_str/
; str_concat via substring), verified against fkwu's native behavior exactly
; before it was retired: str_find's -1-not-found convention, an
; empty-needle immediate match, a `from` offset mid-string, and str_to_int's
; sign handling.
;
; Verdict 255 when every assertion holds.

(do
    (defn cfti-score (ok bit) (if ok bit 0))
    (defn core-str-find-to-int-band ()
        (do
    (let c0 (cfti-score (eq (str_find "hello world" "world" 0) 6) 1))
    (let c1 (cfti-score (eq (str_find "hello world" "xyz" 0) -1) 2))
    (let c2 (cfti-score (eq (str_find "hello world" "o" 5) 7) 4))
    (let c3 (cfti-score (eq (str_find "hello" "" 0) 0) 8))
    (let c4 (cfti-score (eq (str_find "hello" "hello" 0) 0) 16))
    (let c5 (cfti-score (eq (str_to_int "42") 42) 32))
    (let c6 (cfti-score (eq (str_to_int "-7") -7) 64))
    (let c7 (cfti-score (eq (str_to_int "0") 0) 128))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 (add c6 c7))))))))
    )
    (core-str-find-to-int-band))
