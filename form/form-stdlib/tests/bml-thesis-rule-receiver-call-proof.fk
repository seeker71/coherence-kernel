; tests/bml-thesis-rule-receiver-call-proof.fk - source receiver call execution
;
; preludes: form-stdlib/core.fk form-stdlib/json.fk form-stdlib/cache.fk form-stdlib/form-ontology-loader.fk form-stdlib/engine.fk form-stdlib/compiler.fk form-stdlib/source-compiler.fk form-stdlib/grammars/bml.fk
;
; Proves a receiver method call parsed from the original thesis companion
; container-Rule.bml executes through native method dispatch:
; hEnv.StartResultStack();

(do
    (defn bool-score (b bit)
        (if b bit 0))

    (defn int-score (actual expected bit)
        (if (eq actual expected) bit 0))

    (defn str-score (actual expected bit)
        (if (str_eq actual expected) bit 0))

    (let path "../docs/field/urs/artifacts/master-thesis-2000/companion/source-samples/container-Rule.bml")
    (let parsed (bml-source-file-parse-declarations path))
    (let model (bml-source-declaration-model parsed))
    (let rule-class (bml-model-find-class model "Rule"))
    (let match-method
        (bml-find-method
            (bml-class-own-methods rule-class)
            "Match"))
    (let match-body (bml-method-body match-method))

    (let ReceiverRuleBP (make_nodeid 1 2 99 9230))
    (let ReceiverEnvBP (make_nodeid 1 2 99 9231))
    (let ReceiverCallEnvBP (bml-constructor-env-blueprint 0))
    (let env-object (record_new ReceiverEnvBP "started" 0))
    (let env (record_new ReceiverCallEnvBP "hEnv" env-object))
    (let rule-instance (record_new ReceiverRuleBP))

    (defn env-start-result-stack-dispatch (self)
        (record_set self "started" 1))

    (defn env-end-result-stack-dispatch (self tag)
        (record_set self "endedTag" tag))

    (defn rule-get-tag-dispatch (self tag)
        tag)

    (let before-started (record_get env-object "started"))
    (method_define ReceiverEnvBP "StartResultStack" env-start-result-stack-dispatch)
    (method_define ReceiverEnvBP "EndResultStack" env-end-result-stack-dispatch)
    (method_define ReceiverRuleBP "GetTag" rule-get-tag-dispatch)
    (let exec-result
        (bml-body-source-exec-receiver-call0
            match-body
            rule-instance
            env))
    (let after-started (record_get env-object "started"))

    (let second-env-object (record_new ReceiverEnvBP "started" 0))
    (let second-env
        (record_new
            ReceiverCallEnvBP
            "hEnv" second-env-object
            "strTag" "receiver-proof-tag"))
    (bml-body-source-exec match-body rule-instance second-env)

    (sum
        (list
            (bool-score (bml-source-exec-parse-ok? parsed) 1)
            (str-score (bml-method-return match-method) "void" 2)
            (str-score (bml-method-name match-method) "Match" 4)
            (bool-score (bml-body-source-contains? match-body "hEnv") 8)
            (bool-score (bml-body-source-contains? match-body "StartResultStack") 16)
            (int-score (bml-body-source-receiver-call0-count match-body) 1 32)
            (bool-score (method_has ReceiverEnvBP "StartResultStack") 64)
            (int-score before-started 0 128)
            (int-score after-started 1 256)
            (bool-score (record_has env-object "started") 512)
            (int-score (record_get second-env-object "started") 1 1024))))
