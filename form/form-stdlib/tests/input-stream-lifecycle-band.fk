import "../input-stream-lifecycle.fk"
(do
  (framebuffer-clear)
  (let stop (isl-stop-signal 7 10 701))
  (let handoff (isl-handoff-signal 7 11 9001 702))
  (let offline (isl-offline-signal 7 12 703))
  (let unacked-stop (isl-signal 7 13 (isl-stop) (nothing) 704 0))
  (let nothing-signal (isl-signal 7 14 (isl-nothing) (nothing) 705 (nothing)))
  (let close (isl-close-with-stop 7 15 706))
  (let handed (isl-close-with-handoff 7 16 9001 707))
  (let events (framebuffer-events))
  ; [stop,handoff,offline,pre-timeout silence,timeout,nothing,unacked,event-count,success]
  (list
    (isl-transition 0 stop 0 1000)
    (isl-transition 0 handoff 0 1000)
    (isl-transition 0 offline 0 1000)
    (isl-transition 0 (nothing) 999 1000)
    (isl-transition 0 (nothing) 1000 1000)
    (isl-transition 0 nothing-signal 1000 1000)
    (isl-transition 0 unacked-stop 0 1000)
    (len events)
    (if (and (eq (isl-transition 0 stop 0 1000) 1)
      (and (eq (isl-transition 0 handoff 0 1000) 2)
      (and (eq (isl-transition 0 offline 0 1000) 3)
      (and (eq (isl-transition 0 (nothing) 999 1000) 0)
      (and (eq (isl-transition 0 (nothing) 1000 1000) 4)
      (and (eq (isl-transition 0 nothing-signal 1000 1000) 5)
      (and (eq (isl-transition 0 unacked-stop 0 1000) 6)
           (eq (len events) 2)))))))) 1 0)))
