import "../local-llm-active-learning.fk"
(do
  (let variants (list
    (lla-episode 101 (nothing) 201 400 500 300 1 1)
    (lla-episode 102 0 202 300 450 400 1 1)
    (lla-episode 103 (nothing) 203 350 400 350 1 1)
    (lla-episode 104 0 204 450 450 450 1 1)
    (lla-episode 105 1 205 500 500 500 1 1)
    (lla-episode 106 (nothing) 206 500 500 500 0 1)))
  (let transfer (lla-cycle variants 1000 4 (lla-eval 4 4 4 4 2 1) 750 4 4))
  (let memorizer (lla-cycle variants 1000 4 (lla-eval 4 4 1 4 2 1) 750 1 4))
  (list transfer memorizer
    (if (and (eq (nth transfer 2) 4)
      (and (eq (nth transfer 4) 1)
      (and (eq (nth transfer 5) 1)
      (and (eq (nth transfer 6) 0)
           (eq (nth memorizer 4) 0))))) 1 0)))
