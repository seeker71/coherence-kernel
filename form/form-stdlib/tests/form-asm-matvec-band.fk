; preludes: form-stdlib/form-asm.fk form-stdlib/form-asm-matvec.fk
;
; form-asm-matvec-band — the native dot kernel (matvec inner product) emits the exact program BYTES,
; no rustc/clang. Each instruction's fa-* encoding is byte-identical to the clang oracle (the values are
; the same ones form-asm-float-band pins, extended to this kernel's registers/offsets), and the composed
; 8-instruction image is the concatenation in order. Four-way = Go/Rust/TS/fkwu emit identical bytes.
;
; Oracle words (little-endian 4-byte images, derived from the arm64 encoding form-asm proves):
;   ldr d1,[x0,#8] =fd400401  ldr d2,[x0,#24]=fd400c02  fmul d0,d1,d2=1e620820
;   ldr d1,[x0,#0] =fd400001  ldr d2,[x0,#16]=fd400802  fmul d1,d1,d2=1e620821
;   fadd d0,d1,d0  =1e602820  ret           =d65f03c0
;
; Verdict 127 when every claim lands:
;   1    fmul d0,d1,d2 is oracle-correct          (fa-conviction == 1)
;   2    fmul d1,d1,d2 (accumulate reg) correct    (fa-conviction == 1)
;   4    fadd d0,d1,d0 (downward fold) correct      (fa-conviction == 1)
;   8    ldr d1,[x0,#8] (scaled imm) correct        (fa-conviction == 1)
;   16   ldr d2,[x0,#16] correct                    (fa-conviction == 1)
;   32   the kernel is 8 instructions = 32 bytes    (len == 32)
;   64   the WHOLE composed program is byte-exact   (fa-conviction fam-dot2 vs the full image)
(do
    (let prog (fam-dot2))
    (let full (list 1 4 64 253  2 12 64 253  32 8 98 30  1 0 64 253
                    2 8 64 253  33 8 98 30  32 40 96 30  192 3 95 214))
    (let c0 (if (eq (fa-conviction (fa-fmul 0 1 2) (list 32 8 98 30))  1)  1 0))
    (let c1 (if (eq (fa-conviction (fa-fmul 1 1 2) (list 33 8 98 30))  1)  2 0))
    (let c2 (if (eq (fa-conviction (fa-fadd 0 1 0) (list 32 40 96 30)) 1)  4 0))
    (let c3 (if (eq (fa-conviction (fa-ldr-d 1 0 1) (list 1 4 64 253)) 1)  8 0))
    (let c4 (if (eq (fa-conviction (fa-ldr-d 2 0 2) (list 2 8 64 253)) 1) 16 0))
    (let c5 (if (eq (len prog) 32)                                       32 0))
    (let c6 (if (eq (fa-conviction prog full) 1)                         64 0))
    (add c0 (add c1 (add c2 (add c3 (add c4 (add c5 c6)))))))
