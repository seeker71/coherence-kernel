; program-image-recipe-carrier.fk -- carry a valid program image as live recipe data.
;
; This layer bridges the 8h program-image envelope into registered NodeID
; carrier nodes. It is carrier-ready only: structurally inspectable through
; node_category/node_children/node_value, not a runtime load or execution path.
; Direct fkwu carrier readiness is deferred until raw value kinds are exact.
;
; preludes: form-stdlib/core.fk
;           form-stdlib/form-ontology-loader.fk
;           form-stdlib/source-artifact-cache.fk
;           form-stdlib/source-artifact-descriptor.fk
;           form-stdlib/program-image-fkb.fk

(do
    (defn pirc-version () "program-image-recipe-carrier-v1")

    (defn pirc-feature (name status) (list "program-image-recipe-carrier-feature" name status))
    (defn pirc-feature-name (f) (nth f 1))
    (defn pirc-feature-status (f) (nth f 2))
    (defn program-image-recipe-carrier-manifest ()
        (list
            (pirc-feature "pif-envelope-to-recipe-node" 1)
            (pirc-feature "registered-blueprint-categories" 1)
            (pirc-feature "collection-nodes-preserve-table-sections" 1)
            (pirc-feature "symbol-image-node-preserved" 1)
            (pirc-feature "symbol-dependency-target-nodes-preserved" 1)
            (pirc-feature "all-leaves-trivial-nodes" 1)
            (pirc-feature "string-byte-rows-as-byte-int-children" 1)
            (pirc-feature "carrierable-scalar-gate" 1)
            (pirc-feature "carrier-ready-not-load-ready" 1)
            (pirc-feature "direct-fkwu-carrier-readiness-deferred" 1)
            (pirc-feature "no-recipe-sentinel" 1)
            (pirc-feature "reason-manifest-covered" 1)
            (pirc-feature "no-form-binary-io" 1)
            (pirc-feature "no-disk-io" 1)
            (pirc-feature "no-table-text-parse-or-execution" 1)
            (pirc-feature "no-runtime-load-call" 1)
            (pirc-feature "no-attempt-or-observation-row" 1)
            (pirc-feature "no-selector-install" 1)
            (pirc-feature "no-c-seed-growth" 1)))
    (defn program-image-recipe-carrier-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (pirc-feature-name (head fs)) name)
                     (eq (pirc-feature-status (head fs)) 1))
                1
                (program-image-recipe-carrier-manifest-has? name (tail fs)))))

    (defn pirc-status-carrier-ready () "carrier-ready")
    (defn pirc-status-investigate () "investigate")
    (defn pirc-status-refused () "refused")

    (defn pirc-reason-carrier-ready () "carrier-ready")
    (defn pirc-reason-malformed-pif-envelope () "malformed-pif-envelope")
    (defn pirc-reason-invalid-pif-envelope () "invalid-pif-envelope")
    (defn pirc-reason-non-carrierable-table () "non-carrierable-table")
    (defn pirc-reason-native-raw-kind-floor () "native-raw-kind-floor")
    (defn pirc-reason-manifest ()
        (list
            (pirc-reason-carrier-ready)
            (pirc-reason-malformed-pif-envelope)
            (pirc-reason-invalid-pif-envelope)
            (pirc-reason-non-carrierable-table)
            (pirc-reason-native-raw-kind-floor)))

    (defn pirc-envelope-bp () (bp "PROGRAM-IMAGE-RECIPE-ENVELOPE"))
    (defn pirc-table-bp () (bp "PROGRAM-IMAGE-RECIPE-TABLE"))
    (defn pirc-fn-roots-bp () (bp "PROGRAM-IMAGE-RECIPE-FN-ROOTS"))
    (defn pirc-node-rows-bp () (bp "PROGRAM-IMAGE-RECIPE-NODE-ROWS"))
    (defn pirc-node-row-bp () (bp "PROGRAM-IMAGE-RECIPE-NODE-ROW"))
    (defn pirc-string-rows-bp () (bp "PROGRAM-IMAGE-RECIPE-STRING-ROWS"))
    (defn pirc-string-row-bp () (bp "PROGRAM-IMAGE-RECIPE-STRING-ROW"))
    (defn pirc-symbol-image-bp () (bp "PROGRAM-IMAGE-RECIPE-SYMBOL-IMAGE"))
    (defn pirc-symbol-rows-bp () (bp "PROGRAM-IMAGE-RECIPE-SYMBOL-ROWS"))
    (defn pirc-symbol-row-bp () (bp "PROGRAM-IMAGE-RECIPE-SYMBOL-ROW"))
    (defn pirc-node-symbol-rows-bp () (bp "PROGRAM-IMAGE-RECIPE-NODE-SYMBOL-ROWS"))
    (defn pirc-node-symbol-row-bp () (bp "PROGRAM-IMAGE-RECIPE-NODE-SYMBOL-ROW"))
    (defn pirc-symbol-dependency-targets-bp () (bp "PROGRAM-IMAGE-RECIPE-SYMBOL-DEPENDENCY-TARGETS"))
    (defn pirc-symbol-dependency-target-bp () (bp "PROGRAM-IMAGE-RECIPE-SYMBOL-DEPENDENCY-TARGET"))

    (defn pirc-no-recipe () (list "program-image-recipe-no-recipe"))
    (defn pirc-no-recipe? (x)
        (if (eq (len x) 1)
            (str_eq (nth x 0) "program-image-recipe-no-recipe")
            0))

    (defn pirc-carrier-row (pif-envelope recipe status reason)
        (list "program-image-recipe-carrier" pif-envelope recipe status reason))
    (defn pirc-carrier? (row)
        (if (eq (len row) 5)
            (str_eq (nth row 0) "program-image-recipe-carrier")
            0))
    (defn pirc-carrier-pif-envelope (row) (nth row 1))
    (defn pirc-carrier-recipe (row) (nth row 2))
    (defn pirc-carrier-status (row) (nth row 3))
    (defn pirc-carrier-reason (row) (nth row 4))

    (defn pirc-fkwu-scalar-carrierable? (x)
        (eq (len x) 0))
    (defn pirc-string-carrierable? (x)
        (do
            (let k (value_kind x))
            (if (str_eq k "string")
                1
                (if (str_eq k "int")
                    0
                    (if (str_eq k "list")
                        0
                        (if (str_eq k "null")
                            0
                            (gt (str_len x) 0)))))))
    (defn pirc-list-carrierable? (x)
        (do
            (let k (value_kind x))
            (if (str_eq k "list")
                1
                (if (str_eq k "int")
                    0
                    (if (str_eq k "string")
                        0
                        (if (str_eq k "null")
                            0
                            (if (nil? x) 1 (gt (len x) 0))))))))
    (defn pirc-int-carrierable? (x)
        (do
            (let k (value_kind x))
            (if (str_eq k "int")
                1
                (if (str_eq k "string")
                    0
                    (if (str_eq k "list")
                        0
                    (if (str_eq k "null")
                        0
                        (pirc-fkwu-scalar-carrierable? x)))))))

    (defn pirc-exact-kind-floor? ()
        (and (str_eq (value_kind 0) "int")
        (and (str_eq (value_kind "x") "string")
             (str_eq (value_kind (list 1)) "list"))))

    (defn pirc-envelope-shape? (e)
        (if (and (pirc-list-carrierable? e) (eq (len e) 11))
            (if (pirc-string-carrierable? (nth e 0))
                (str_eq (nth e 0) "program-image-fkb-envelope")
                0)
            0))
    (defn pirc-symbol-image-shape? (img)
        (if (and (pirc-list-carrierable? img) (eq (len img) 5))
            (if (pirc-string-carrierable? (nth img 0))
                (str_eq (nth img 0) "program-image-symbol-image")
                0)
            0))
    (defn pirc-table-shape? (t)
        (if (and (pirc-list-carrierable? t) (eq (len t) 7))
            (if (pirc-string-carrierable? (nth t 0))
                (str_eq (nth t 0) "program-image-table")
                0)
            0))

    (defn pirc-int-list-carrierable? (xs)
        (if (nil? xs)
            1
            (if (pirc-int-carrierable? (head xs))
                (pirc-int-list-carrierable? (tail xs))
                0)))
    (defn pirc-node-row-carrierable? (row)
        (if (pirc-list-carrierable? row)
            (pirc-int-list-carrierable? row)
            0))
    (defn pirc-node-rows-carrierable? (rows)
        (if (pirc-list-carrierable? rows)
            (if (nil? rows)
                1
                (if (pirc-node-row-carrierable? (head rows))
                    (pirc-node-rows-carrierable? (tail rows))
                    0))
            0))
    (defn pirc-byte-carrierable? (b)
        (pirc-int-carrierable? b))
    (defn pirc-byte-list-carrierable? (xs)
        (if (pirc-list-carrierable? xs)
            (if (nil? xs)
                1
                (if (pirc-byte-carrierable? (head xs))
                    (pirc-byte-list-carrierable? (tail xs))
                    0))
            0))
    (defn pirc-string-rows-carrierable? (rows)
        (if (pirc-list-carrierable? rows)
            (if (nil? rows)
                1
                (if (pirc-byte-list-carrierable? (head rows))
                    (pirc-string-rows-carrierable? (tail rows))
                    0))
            0))
    (defn pirc-symbol-row-carrierable? (row)
        (if (pirc-list-carrierable? row)
            (if (eq (len row) 2)
                (and (pirc-int-carrierable? (pif-symbol-row-id row))
                     (pirc-string-carrierable? (pif-symbol-row-key row)))
                0)
            0))
    (defn pirc-symbol-rows-carrierable? (rows)
        (if (pirc-list-carrierable? rows)
            (if (nil? rows)
                1
                (if (pirc-symbol-row-carrierable? (head rows))
                    (pirc-symbol-rows-carrierable? (tail rows))
                    0))
            0))
    (defn pirc-symbol-dependency-target-carrierable? (target)
        (if (pirc-list-carrierable? target)
            (if (eq (len target) 2)
                (and (pirc-int-carrierable? (pif-symbol-dependency-target-symbol target))
                     (pirc-int-carrierable? (pif-symbol-dependency-target-node target)))
                0)
            0))
    (defn pirc-symbol-dependency-targets-carrierable? (targets)
        (if (pirc-list-carrierable? targets)
            (if (nil? targets)
                1
                (if (pirc-symbol-dependency-target-carrierable? (head targets))
                    (pirc-symbol-dependency-targets-carrierable? (tail targets))
                    0))
            0))
    (defn pirc-node-symbol-row-carrierable? (row)
        (if (pirc-list-carrierable? row)
            (if (eq (len row) 3)
                (and (pirc-int-carrierable? (pif-node-symbol-row-node row))
                (and (pirc-int-carrierable? (pif-node-symbol-row-defined row))
                     (pirc-symbol-dependency-targets-carrierable? (pif-node-symbol-row-dependency-targets row))))
                0)
            0))
    (defn pirc-node-symbol-rows-carrierable? (rows)
        (if (pirc-list-carrierable? rows)
            (if (nil? rows)
                1
                (if (pirc-node-symbol-row-carrierable? (head rows))
                    (pirc-node-symbol-rows-carrierable? (tail rows))
                    0))
            0))
    (defn pirc-symbol-image-carrierable? (img)
        (if (pirc-symbol-image-shape? img)
            (and (pirc-int-carrierable? (pif-symbol-image-count img))
            (and (pirc-symbol-rows-carrierable? (pif-symbol-image-rows img))
            (and (pirc-int-carrierable? (pif-symbol-image-node-count img))
                 (pirc-node-symbol-rows-carrierable? (pif-symbol-image-node-rows img)))))
            0))
    (defn pirc-table-carrierable? (t)
        (if (pirc-table-shape? t)
            (if (pirc-int-carrierable? (pif-table-nf t))
                (if (pirc-list-carrierable? (pif-table-fn-roots t))
                    (if (pirc-int-list-carrierable? (pif-table-fn-roots t))
                        (if (pirc-int-carrierable? (pif-table-nr t))
                            (if (pirc-list-carrierable? (pif-table-node-rows t))
                                (if (pirc-node-rows-carrierable? (pif-table-node-rows t))
                                    (if (pirc-int-carrierable? (pif-table-ns t))
                                        (if (pirc-list-carrierable? (pif-table-string-byte-rows t))
                                            (pirc-string-rows-carrierable? (pif-table-string-byte-rows t))
                                            0)
                                        0)
                                    0)
                                0)
                            0)
                        0)
                    0)
                0)
            0))

    (defn pirc-envelope-metadata-carrierable? (e)
        (if (pirc-envelope-shape? e)
            (and (pirc-string-carrierable? (pif-envelope-version e))
            (and (pirc-string-carrierable? (pif-envelope-source-path e))
            (and (pirc-string-carrierable? (pif-envelope-source-hash e))
            (and (pirc-int-carrierable? (pif-envelope-source-mtime e))
            (and (pirc-string-carrierable? (pif-envelope-artifact-path e))
            (and (pirc-string-carrierable? (pif-envelope-content-hash e))
            (and (pirc-int-carrierable? (pif-envelope-artifact-mtime e))
                 (pirc-int-carrierable? (pif-envelope-seal-ok e)))))))))
            0))

    (defn pirc-int-node (x) (intern_trivial_int x))
    (defn pirc-string-node (s) (intern_trivial_string s))
    (defn pirc-int-nodes (xs)
        (if (nil? xs)
            (empty)
            (cons (pirc-int-node (head xs)) (pirc-int-nodes (tail xs)))))
    (defn pirc-node-row-recipe (row)
        (intern_node (pirc-node-row-bp) (pirc-int-nodes row)))
    (defn pirc-node-row-recipes (rows)
        (if (nil? rows)
            (empty)
            (cons (pirc-node-row-recipe (head rows))
                  (pirc-node-row-recipes (tail rows)))))
    (defn pirc-string-row-recipe (row)
        (intern_node (pirc-string-row-bp) (pirc-int-nodes row)))
    (defn pirc-string-row-recipes (rows)
        (if (nil? rows)
            (empty)
            (cons (pirc-string-row-recipe (head rows))
                  (pirc-string-row-recipes (tail rows)))))
    (defn pirc-fn-roots-recipe (roots)
        (intern_node (pirc-fn-roots-bp) (pirc-int-nodes roots)))
    (defn pirc-node-rows-recipe (rows)
        (intern_node (pirc-node-rows-bp) (pirc-node-row-recipes rows)))
    (defn pirc-string-rows-recipe (rows)
        (intern_node (pirc-string-rows-bp) (pirc-string-row-recipes rows)))
    (defn pirc-symbol-row-recipe (row)
        (intern_node (pirc-symbol-row-bp)
            (list
                (pirc-int-node (pif-symbol-row-id row))
                (pirc-string-node (pif-symbol-row-key row)))))
    (defn pirc-symbol-row-recipes (rows)
        (if (nil? rows)
            (empty)
            (cons (pirc-symbol-row-recipe (head rows))
                  (pirc-symbol-row-recipes (tail rows)))))
    (defn pirc-symbol-rows-recipe (rows)
        (intern_node (pirc-symbol-rows-bp) (pirc-symbol-row-recipes rows)))
    (defn pirc-symbol-dependency-target-recipe (target)
        (intern_node (pirc-symbol-dependency-target-bp)
            (list
                (pirc-int-node (pif-symbol-dependency-target-symbol target))
                (pirc-int-node (pif-symbol-dependency-target-node target)))))
    (defn pirc-symbol-dependency-target-recipes (targets)
        (if (nil? targets)
            (empty)
            (cons (pirc-symbol-dependency-target-recipe (head targets))
                  (pirc-symbol-dependency-target-recipes (tail targets)))))
    (defn pirc-symbol-dependency-targets-recipe (targets)
        (intern_node (pirc-symbol-dependency-targets-bp)
            (pirc-symbol-dependency-target-recipes targets)))
    (defn pirc-node-symbol-row-recipe (row)
        (intern_node (pirc-node-symbol-row-bp)
            (list
                (pirc-int-node (pif-node-symbol-row-node row))
                (pirc-int-node (pif-node-symbol-row-defined row))
                (pirc-symbol-dependency-targets-recipe (pif-node-symbol-row-dependency-targets row)))))
    (defn pirc-node-symbol-row-recipes (rows)
        (if (nil? rows)
            (empty)
            (cons (pirc-node-symbol-row-recipe (head rows))
                  (pirc-node-symbol-row-recipes (tail rows)))))
    (defn pirc-node-symbol-rows-recipe (rows)
        (intern_node (pirc-node-symbol-rows-bp)
            (pirc-node-symbol-row-recipes rows)))
    (defn pirc-symbol-image-recipe (img)
        (intern_node (pirc-symbol-image-bp)
            (list
                (pirc-int-node (pif-symbol-image-count img))
                (pirc-symbol-rows-recipe (pif-symbol-image-rows img))
                (pirc-int-node (pif-symbol-image-node-count img))
                (pirc-node-symbol-rows-recipe (pif-symbol-image-node-rows img)))))
    (defn pirc-table-recipe (t)
        (intern_node (pirc-table-bp)
            (list
                (pirc-int-node (pif-table-nf t))
                (pirc-fn-roots-recipe (pif-table-fn-roots t))
                (pirc-int-node (pif-table-nr t))
                (pirc-node-rows-recipe (pif-table-node-rows t))
                (pirc-int-node (pif-table-ns t))
                (pirc-string-rows-recipe (pif-table-string-byte-rows t)))))
    (defn pirc-envelope-recipe (e)
        (intern_node (pirc-envelope-bp)
            (list
                (pirc-string-node (pif-envelope-version e))
                (pirc-string-node (pif-envelope-source-path e))
                (pirc-string-node (pif-envelope-source-hash e))
                (pirc-int-node (pif-envelope-source-mtime e))
                (pirc-string-node (pif-envelope-artifact-path e))
                (pirc-string-node (pif-envelope-content-hash e))
                (pirc-int-node (pif-envelope-artifact-mtime e))
                (pirc-int-node (pif-envelope-seal-ok e))
                (pirc-table-recipe (pif-envelope-table e))
                (pirc-symbol-image-recipe (pif-envelope-symbol-image e)))))

    (defn pirc-carrier-from-envelope (e)
        (if (not (pirc-envelope-shape? e))
            (pirc-carrier-row e (pirc-no-recipe) (pirc-status-refused)
                              (pirc-reason-malformed-pif-envelope))
            (if (not (pirc-exact-kind-floor?))
                (pirc-carrier-row e (pirc-no-recipe) (pirc-status-investigate)
                                  (pirc-reason-native-raw-kind-floor))
                (if (not (pirc-envelope-metadata-carrierable? e))
                    (pirc-carrier-row e (pirc-no-recipe) (pirc-status-investigate)
                                      (pirc-reason-invalid-pif-envelope))
                    (if (not (pirc-table-carrierable? (pif-envelope-table e)))
                        (pirc-carrier-row e (pirc-no-recipe) (pirc-status-investigate)
                                          (pirc-reason-non-carrierable-table))
                        (if (not (pirc-symbol-image-carrierable? (pif-envelope-symbol-image e)))
                            (pirc-carrier-row e (pirc-no-recipe) (pirc-status-investigate)
                                              (pirc-reason-invalid-pif-envelope))
                            (if (not (pif-envelope-valid? e))
                                (pirc-carrier-row e (pirc-no-recipe) (pirc-status-investigate)
                                                  (pirc-reason-invalid-pif-envelope))
                                (pirc-carrier-row e (pirc-envelope-recipe e)
                                                  (pirc-status-carrier-ready)
                                                  (pirc-reason-carrier-ready)))))))))
)
