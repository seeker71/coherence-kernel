; grammars/rust.fk — Rust parser (file-header subset)
;
; Compost target: form/form-kernel-ts/src/lang-rust.ts (2377 lines).
;
; Subset supported (the patterns most common at the top of .rs files):
;   - use module::path;
;   - pub use module::path;
;   - mod name;
;   - pub mod name;
;   - fn name(args) -> ReturnType {  (header line)
;   - pub fn name() {}
;   - struct Name { ... }
;   - impl Name { ... }
;   - // line comments
;
; Skipped: full expression grammar, body parsing, generics, traits,
; lifetimes, macros, attributes, derive, async/await, match expressions.

(do

    ;; --- shared line helpers (parallel to python.fk / typescript.fk) ---

    (defn substr (s a b)
        (if (ge a b) ""
            (str_concat (char_at s a) (substr s (add a 1) b))))

    (defn lines-from-source (s)
        (lines-loop s 0 0 1 (empty)))

    (defn lines-loop (s i start line acc)
        (if (eq i (str_len s))
            (if (gt i start)
                (reverse-acc (cons (list (substr s start i) line) acc))
                (reverse-acc acc))
            (if (eq (ord (char_at s i)) 10)
                (lines-loop s (add i 1) (add i 1) (add line 1)
                            (cons (list (substr s start i) line) acc))
                (lines-loop s (add i 1) start line acc))))

    (defn reverse-acc (xs) (foldl rev-step (empty) xs))
    (defn rev-step (acc x) (cons x acc))

    (defn line-text (ln) (head ln))
    (defn line-num  (ln) (head (tail ln)))

    (defn is-ws-cp (cp)
        (or (eq cp 32) (or (eq cp 9) (or (eq cp 10) (eq cp 13)))))

    (defn trim-leading-ws (s)
        (if (eq (str_len s) 0) s
            (if (is-ws-cp (ord (char_at s 0)))
                (trim-leading-ws (substr s 1 (str_len s)))
                s)))

    (defn trim-trailing-ws (s)
        (if (eq (str_len s) 0) s
            (if (is-ws-cp (ord (char_at s (sub (str_len s) 1))))
                (trim-trailing-ws (substr s 0 (sub (str_len s) 1)))
                s)))

    (defn trim (s) (trim-leading-ws (trim-trailing-ws s)))

    (defn is-blank? (text) (eq (str_len (trim text)) 0))

    (defn is-line-comment? (text)
        (do
            (let trimmed (trim-leading-ws text))
            (and (ge (str_len trimmed) 2)
                 (and (eq (ord (char_at trimmed 0)) 47)
                      (eq (ord (char_at trimmed 1)) 47)))))

    (defn starts-with? (text prefix)
        (if (lt (str_len text) (str_len prefix)) false
            (str_eq (substr text 0 (str_len prefix)) prefix)))

    (defn starts-with-keyword? (text kw)
        (and (starts-with? text kw)
             (and (gt (str_len text) (str_len kw))
                  (is-ws-cp (ord (char_at text (str_len kw)))))))

    (defn find-from (s needle start)
        (find-loop s needle start))

    (defn find-loop (s needle i)
        (if (gt (add i (str_len needle)) (str_len s)) (sub 0 1)
            (if (str_eq (substr s i (add i (str_len needle))) needle) i
                (find-loop s needle (add i 1)))))

    (defn strip-trailing-semi (s)
        (if (eq (str_len s) 0) s
            (if (eq (ord (char_at s (sub (str_len s) 1))) 59)
                (trim (substr s 0 (sub (str_len s) 1)))
                s)))

    ;; --- statement parsers ----------------------------------------

    (defn parse-use (text line-no source-path)
        (do
            (let after (trim (substr text 4 (str_len text))))
            (intern_node_at RS-USE
                            (list (intern_trivial_string (strip-trailing-semi after)))
                            source-path line-no 1)))

    (defn parse-pub-use (text line-no source-path)
        ;; "pub use ..." → strip "pub " then parse-use
        (parse-use (trim (substr text 4 (str_len text))) line-no source-path))

    (defn parse-mod (text line-no source-path)
        (do
            (let after (trim (substr text 4 (str_len text))))
            (intern_node_at RS-MOD
                            (list (intern_trivial_string (strip-trailing-semi after)))
                            source-path line-no 1)))

    (defn parse-fn (text line-no source-path)
        (do
            (let after (trim (substr text 3 (str_len text))))   ; strip "fn"
            (let open-paren (find-from after "(" 0))
            (let close-paren (find-from after ")" 0))
            (if (or (lt open-paren 0) (lt close-paren 0))
                (intern_node_at RS-FN-DECL
                                (list (intern_trivial_string after)
                                      (intern_trivial_string ""))
                                source-path line-no 1)
                (intern_node_at RS-FN-DECL
                                (list (intern_trivial_string (trim (substr after 0 open-paren)))
                                      (intern_trivial_string (trim (substr after (add open-paren 1) close-paren))))
                                source-path line-no 1))))

    (defn parse-struct (text line-no source-path)
        (do
            (let after (trim (substr text 7 (str_len text))))   ; strip "struct "
            (let space-pos (find-from after " " 0))
            (let brace-pos (find-from after "{" 0))
            (let end (pick-min space-pos brace-pos (str_len after)))
            (intern_node_at RS-STRUCT-DECL
                            (list (intern_trivial_string (trim (substr after 0 end))))
                            source-path line-no 1)))

    (defn pick-min (a b fallback)
        (if (lt a 0)
            (if (lt b 0) fallback b)
            (if (lt b 0) a
                (if (lt a b) a b))))

    (defn parse-impl (text line-no source-path)
        (do
            (let after (trim (substr text 4 (str_len text))))   ; strip "impl"
            (let space-pos (find-from after " " 0))
            (let brace-pos (find-from after "{" 0))
            (let end (pick-min space-pos brace-pos (str_len after)))
            (intern_node_at RS-IMPL-BLOCK
                            (list (intern_trivial_string (trim (substr after 0 end))))
                            source-path line-no 1)))

    (defn parse-pub-stmt (text line-no source-path)
        (do
            (let after (trim (substr text 4 (str_len text))))   ; strip "pub "
            (parse-stmt-text after line-no source-path)))

    (defn parse-stmt-text (text line-no source-path)
        (if (starts-with-keyword? text "use")
            (parse-use text line-no source-path)
            (if (starts-with-keyword? text "mod")
                (parse-mod text line-no source-path)
                (if (starts-with-keyword? text "fn")
                    (parse-fn text line-no source-path)
                    (if (starts-with-keyword? text "struct")
                        (parse-struct text line-no source-path)
                        (if (starts-with-keyword? text "impl")
                            (parse-impl text line-no source-path)
                            (intern_trivial_string text)))))))

    (defn rs-parse-block (ln source-path)
        (do
            (let text (line-text ln))
            (let line-no (line-num ln))
            (let trimmed (trim-leading-ws text))
            (if (starts-with-keyword? trimmed "pub")
                (parse-pub-stmt trimmed line-no source-path)
                (parse-stmt-text trimmed line-no source-path))))

    (defn rs-rs-parse-blocks (lines source-path acc)
        (if (nil? lines) (reverse-acc acc)
            (do
                (let ln (head lines))
                (let text (line-text ln))
                (if (or (is-blank? text) (is-line-comment? text))
                    (rs-rs-parse-blocks (tail lines) source-path acc)
                    (rs-rs-parse-blocks (tail lines) source-path
                                  (cons (rs-parse-block ln source-path) acc))))))

    (defn parse-rust (source-path text)
        (do
            (let lines (lines-from-source text))
            (let blocks (rs-rs-parse-blocks lines source-path (empty)))
            (intern_node_at RS-FILE blocks source-path 1 1)))
)
