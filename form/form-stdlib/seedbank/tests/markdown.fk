; tests/markdown.fk — exercise markdown parser end-to-end
;
; preludes: form-stdlib/seedbank/cell-trace.fk form-stdlib/seedbank/blueprint-symbol-sections.fk form-stdlib/seedbank/grammars/markdown.fk
;
; (Note: this loads grammars/markdown.fk explicitly since the
; validate.sh convention loads form-stdlib/<base>.fk
; but markdown lives under form-stdlib/seedbank/grammars/. Invoke via:
;   bin-go core.fk cell-trace.fk blueprint-symbol-sections.fk grammars/markdown.fk tests/markdown.fk
;
; The probe parses a small Markdown document with all three supported
; block types — heading, paragraph, code block — then checks that:
;   - the right number of blocks are produced
;   - source attribution is recorded per block
;   - explain-cell can trace any block back to its source line

(do
    (let sample-md
        (str_concat "# Coherence Network"
        (str_concat "

" (str_concat "The substrate carries every cell as a content-addressed Recipe."
        (str_concat "

" (str_concat "## Architecture"
        (str_concat "

" (str_concat "Three sibling kernels in Rust, Go, TypeScript."
        (str_concat "

" "## Status")))))))))

    (let doc (parse-markdown "README.md" sample-md))

    ;; --- probe 1: root document has children ----------------------
    (let kids (node_children doc))
    (let probe-1 (len kids))                              ; → 4 (H1, para, H2, para, H2 = wait 5)

    ;; --- probe 2: each block carries source attribution -----------
    ;; (we just count how many of the children have non-empty source)
    (defn count-attributed (xs)
        (if (nil? xs) 0
            (if (str_eq (cell-source (head xs)) "")
                (count-attributed (tail xs))
                (add 1 (count-attributed (tail xs))))))
    (let probe-2 (count-attributed kids))                 ; → 4 (all blocks attributed)

    ;; --- probe 3: root document carries its own attribution -------
    (let probe-3 (str_len (cell-source doc)))             ; → length of "README.md:1:1" = 13

    ;; sum: 4 + 4 + 13 = 21 (depending on exact line layout)
    (add probe-1 (add probe-2 probe-3)))
