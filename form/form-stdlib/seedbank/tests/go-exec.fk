; tests/go-exec.fk — Go EXECUTE pipeline proof
;
; preludes: form-stdlib/engine.fk form-stdlib/seedbank/grammar-bnf.fk form-stdlib/seedbank/blueprint-symbol-sections.fk form-stdlib/seedbank/grammars/go.bnf.fk form-stdlib/seedbank/grammars/go-exec.fk
;
; Parses a real multi-statement Go file shape and executes — package,
; import, type, var, const, func all flow through go-execute walker.

(do
    (let result (parse-go-bnf "main.go" "package main
import \"fmt\"
type Kernel struct{}
var Version = 1
const Tag = 2
func main() { }"))
    (let count (go-execute result))                       ; → 5
    count)
