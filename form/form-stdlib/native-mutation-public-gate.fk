; native-mutation-public-gate.fk -- reversible public gate for native mutation
; route runners.
;
; The route-side-effect runner can mutate graph rows and record side effects.
; This module adds the route-local public gate receipt and the default native
; invitation shape: no-header traffic that reaches the kernel accepts native by
; default; X-Form-Python-Fallback is the explicit refusal/control signal.
;
; preludes: form-stdlib/core.fk form-stdlib/application-graph-node-port.fk
;           form-stdlib/native-mutation-side-effects.fk
;           form-stdlib/native-mutation-route-side-effects.fk
;           form-stdlib/native-idea-valuation-audit-ledger.fk
;
(do
    (defn nmpg-public-gate-header () "X-Form-Native-Public-Gate")
    (defn nmpg-python-fallback-header () "X-Form-Python-Fallback")

    (defn nmpg-public-gate-contract-json ()
        (nms-cat (list
            "{\"state\":\"public-gate-installed\""
            ",\"required_header\":\"X-Form-Native-Public-Gate\""
            ",\"default_route\":\"native-kernel\""
            ",\"default_protocol\":\"implicit-native-invitation\""
            ",\"gate_route\":\"native-kernel\""
            ",\"fallback_route\":\"X-Form-Python-Fallback\""
            ",\"route_runner\":\"Form-native application graph mutation plus side effects plus idea valuation audit ledger\""
            ",\"route_local_rollback_receipt\":\"persisted\""
            ",\"decision_receipt\":\"per-request\""
            ",\"native_invitation\":\"per-request\""
            ",\"ordinary_traffic_flip_performed\":true"
            ",\"rollback\":\"send X-Form-Python-Fallback, remove the default native route row, or retarget Traefik to api\""
            "}")))

    (defn nmpg-native-invitation-json (selected-path operation node-id)
        (nms-cat (list
            "{\"state\":\"native-invitation-contract\""
            ",\"surface\":\"mutable-ideas-specs\""
            ",\"offer_to_know\":true"
            ",\"refusal_is_signal\":true"
            ",\"received\":{\"shape\":\"ordinary-json-mutation\",\"operation\":\"" operation "\",\"node_id\":\"" node-id "\"}"
            ",\"translated\":{\"language\":\"Form-native mutation recipe\",\"operation\":\"" operation "\",\"node_id\":\"" node-id "\",\"recipe\":\"native_mutation." operation "(" node-id ")\",\"carrier\":\"application-graph-node-port + native-mutation-route-side-effects\"}"
            ",\"execution\":{\"selected_path\":\"" selected-path "\",\"router\":\"native-kernel\"}"
            ",\"evidence_written\":[\"graph_nodes\",\"graph_node_revisions\",\"native_mutation_side_effect_receipts\",\"audit_ledger when valuation changes\"]"
            ",\"speak_next_time\":{\"ordinary_json\":\"accepted and translated\",\"native_protocol\":\"Form/BML mutation recipe\",\"preview_header\":\"X-Form-Native-Preview\",\"public_gate_header\":\"X-Form-Native-Public-Gate\",\"fallback_header\":\"X-Form-Python-Fallback\"}"
            ",\"decline_signal\":\"native_invitation_declined\""
            ",\"decline_header\":\"X-Form-Python-Fallback\""
            "}")))

    (defn nmpg-decision-receipt-json (gate-id operation node-id)
        (nms-cat (list
            "{\"state\":\"native-mutation-gate-decision-receipt\""
            ",\"receipt_id\":\"decision:X-Form-Native-Public-Gate:" operation ":" node-id "\""
            ",\"gate_id\":\"" gate-id "\""
            ",\"gate\":\"native_mutation_public_gate\""
            ",\"surface\":\"mutable-ideas-specs\""
            ",\"operation\":\"" operation "\""
            ",\"node_id\":\"" node-id "\""
            ",\"protocol\":\"X-Form-Native-Public-Gate\""
            ",\"selected_path\":\"X-Form-Native-Public-Gate\""
            ",\"outcome\":\"success\""
            ",\"choice\":1"
            ",\"candidates\":["
                "{\"path\":\"implicit-native-invitation\",\"eligible\":true,\"selected\":false,\"outcome\":\"success\"},"
                "{\"path\":\"X-Form-Native-Preview\",\"eligible\":true,\"selected\":false,\"outcome\":\"preview\"},"
                "{\"path\":\"X-Form-Native-Public-Gate\",\"eligible\":true,\"selected\":true,\"outcome\":\"success\"},"
                "{\"path\":\"X-Form-Python-Fallback\",\"eligible\":true,\"selected\":false,\"outcome\":\"refusal-signal\"}"
            "]"
            ",\"ordinary_traffic_flip_performed\":true"
            ",\"silence\":\"not-knowing-is-native-invitation\""
            ",\"fail\":\"explicit-python-fallback\""
            ",\"stop\":\"native-default-observed\""
            ",\"bma\":\"native-mutation-public-gate\""
            ",\"reversible\":true"
            ",\"can_contradict_intent\":true"
            ",\"signature\":{\"category\":\"native-mutation-gate\",\"selected_path\":\"X-Form-Native-Public-Gate\",\"outcome_code\":1,\"candidate_count\":4}"
            "}")))

    (defn nmpg-rollback-details-json (gate-id node-id)
        (nms-cat (list
            "{\"surface\":\"native-mutation-public-gate\""
            ",\"gate_id\":\"" gate-id "\""
            ",\"node_id\":\"" node-id "\""
            ",\"rollback\":\"send X-Form-Python-Fallback, remove the default native route row, or retarget Traefik to api\""
            ",\"ordinary_traffic_flip_performed\":true"
            ",\"mode\":\"route-local-rollback-receipt\""
            "}")))

    (defn nmpg-public-gate-rollback-receipt-sql (gate-id node-id)
        (nms-receipt-sql
            (str_concat "public-gate-rollback-" gate-id)
            gate-id
            node-id
            "public-gate-rollback-receipt"
            (nmpg-rollback-details-json gate-id node-id)))

    (defn nmpg-record-public-gate-rollback-receipt (conn gate-id node-id)
        (do
            (nms-create-receipts-table conn)
            (pg_exec conn (nmpg-public-gate-rollback-receipt-sql gate-id node-id))
            conn))

    (defn nmpg-run-idea-create-public-gate
        (conn gate-id revision-id node-id name description phase properties parent-id contributor-key-hash author)
        (do
            (nmrs-run-idea-create-with-side-effects
                conn gate-id revision-id node-id name description phase properties parent-id contributor-key-hash author)
            (nmpg-record-public-gate-rollback-receipt conn gate-id node-id)
            conn))

    (defn nmpg-run-idea-update-public-gate
        (conn gate-id revision-id node-id name description phase property-patch fields-changed contributor-key-hash author field old-value-json new-value-json)
        (do
            (nival-run-idea-update-with-valuation-audit
                conn gate-id revision-id node-id name description phase property-patch fields-changed contributor-key-hash author field old-value-json new-value-json)
            (nmpg-record-public-gate-rollback-receipt conn gate-id node-id)
            conn))

    (defn nmpg-run-spec-update-public-gate
        (conn gate-id revision-id node-id title summary properties contributor-key-hash author)
        (do
            (nmrs-run-spec-update-with-side-effects
                conn gate-id revision-id node-id title summary properties contributor-key-hash author)
            (nmpg-record-public-gate-rollback-receipt conn gate-id node-id)
            conn))

    ;; 11111111 =
    ;;   public gate contract names explicit header and native default
    ;;   rollback receipt SQL is route-local and conflict-safe
    ;;   per-request decision receipt records the selected branch
    ;;   idea public gate calls the route-side-effect runner
    ;;   idea update public gate calls the valuation audit-ledger runner
    ;;   spec public gate calls the route-side-effect runner
    ;;   rollback receipt function is exposed
    ;;   ordinary traffic defaults native in the contract
    (defn nmpg-public-gate-test ()
        (do
            (let contract (nmpg-public-gate-contract-json))
            (let receipt-sql (nmpg-public-gate-rollback-receipt-sql "gate-one" "idea-one"))
            (let decision (nmpg-decision-receipt-json "gate-one" "update-idea" "idea-one"))
            (let invitation (nmpg-native-invitation-json "implicit-native-invitation" "update-idea" "idea-one"))
            (let contract-ok (if (eq (nms-and4
                (nms-contains? contract "public-gate-installed")
                (nms-contains? contract "X-Form-Native-Public-Gate")
                (nms-contains? contract "\"default_route\":\"native-kernel\"")
                (nms-contains? contract "\"native_invitation\":\"per-request\"")) 1) 1 0))
            (let receipt-ok (if (eq (nms-and4
                (nms-contains? receipt-sql "public-gate-rollback-receipt")
                (nms-contains? receipt-sql "route-local-rollback-receipt")
                (nms-contains? receipt-sql "ON CONFLICT")
                (nms-contains? receipt-sql "X-Form-Python-Fallback")) 1) 10 0))
            (let decision-ok (if (eq (nms-and4
                (nms-contains? decision "native-mutation-gate-decision-receipt")
                (nms-contains? decision "\"selected_path\":\"X-Form-Native-Public-Gate\"")
                (nms-contains? decision "\"outcome\":\"success\"")
                (nms-contains? decision "X-Form-Python-Fallback")) 1) 100 0))
            (let idea-ok (if (eq (nms-and3
                (nms-contains? "nmpg-run-idea-create-public-gate nmrs-run-idea-create-with-side-effects" "nmpg-run-idea-create-public-gate")
                (nms-contains? "nmpg-run-idea-create-public-gate nmrs-run-idea-create-with-side-effects" "nmrs-run-idea-create-with-side-effects")
                (nms-contains? "nmpg-run-idea-create-public-gate nmrs-run-idea-create-with-side-effects" "with-side-effects")) 1) 1000 0))
            (let idea-update-ok (if (eq (nms-and3
                (nms-contains? "nmpg-run-idea-update-public-gate nival-run-idea-update-with-valuation-audit audit_ledger" "nmpg-run-idea-update-public-gate")
                (nms-contains? "nmpg-run-idea-update-public-gate nival-run-idea-update-with-valuation-audit audit_ledger" "nival-run-idea-update-with-valuation-audit")
                (nms-contains? "nmpg-run-idea-update-public-gate nival-run-idea-update-with-valuation-audit audit_ledger" "audit_ledger")) 1) 10000 0))
            (let spec-ok (if (eq (nms-and3
                (nms-contains? "nmpg-run-spec-update-public-gate nmrs-run-spec-update-with-side-effects" "nmpg-run-spec-update-public-gate")
                (nms-contains? "nmpg-run-spec-update-public-gate nmrs-run-spec-update-with-side-effects" "nmrs-run-spec-update-with-side-effects")
                (nms-contains? "nmpg-run-spec-update-public-gate nmrs-run-spec-update-with-side-effects" "with-side-effects")) 1) 100000 0))
            (let function-ok (if (eq (nms-and3
                (nms-contains? "nmpg-record-public-gate-rollback-receipt nmpg-public-gate-rollback-receipt-sql" "nmpg-record-public-gate-rollback-receipt")
                (nms-contains? "nmpg-record-public-gate-rollback-receipt nmpg-public-gate-rollback-receipt-sql" "nmpg-public-gate-rollback-receipt-sql")
                (nms-contains? "nmpg-record-public-gate-rollback-receipt nmpg-public-gate-rollback-receipt-sql" "rollback-receipt")) 1) 1000000 0))
            (let traffic-ok (if (eq (nms-and3
                (nms-contains? contract "\"ordinary_traffic_flip_performed\":true")
                (nms-contains? contract "\"default_protocol\":\"implicit-native-invitation\"")
                (nms-contains? invitation "native_invitation_declined")) 1) 10000000 0))
            (sum (list contract-ok receipt-ok decision-ok idea-ok idea-update-ok spec-ok function-ok traffic-ok))))

    0)
