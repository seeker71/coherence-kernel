; source-compiler-file-persistence.fk -- 8j emission through file-backed 8k.
;
; This layer is the read-only seam between source-compiler emission and
; source-compiler persistence. It projects paths, expected hashes, and declared
; artifact policy bits from an 8j emission, builds a file-backed 8c1 probe
; bundle, then delegates persistence status entirely to 8k.
;
; It does not compile, write artifacts, execute table text, load or walk program
; images, call native artifacts, install a selector, mint new persistence
; reasons, or grow the C seed. Callers hand the nested `scp-persistence` row to
; 9i; 9i does not depend on this carrier.
;
; preludes: form-stdlib/core.fk form-stdlib/form-fs.fk form-stdlib/str-byte-at.fk form-stdlib/sha256.fk form-stdlib/hex.fk form-stdlib/file-byte-window.fk form-stdlib/source-artifact-cache.fk form-stdlib/source-artifact-descriptor.fk form-stdlib/runtime-artifact-plan.fk form-stdlib/source-artifact-probe.fk form-stdlib/source-artifact-identity.fk form-stdlib/file-byte-digest.fk form-stdlib/source-artifact-file-probe.fk form-stdlib/runtime-artifact-selector.fk form-stdlib/runtime-artifact-outcome.fk form-stdlib/runtime-artifact-retry.fk form-stdlib/runtime-artifact-load-envelope.fk form-stdlib/program-image-fkb.fk form-stdlib/program-image-tbl-emit.fk form-stdlib/source-compiler-emission.fk form-stdlib/source-compiler-persistence.fk

(do
    (defn scfp-version () "source-compiler-file-persistence-v1")
    (defn scfp-status-no-probe () "no-probe")

    (defn scfp-feature (name status) (list "source-compiler-file-persistence-feature" name status))
    (defn scfp-feature-name (f) (nth f 1))
    (defn scfp-feature-status (f) (nth f 2))
    (defn source-compiler-file-persistence-manifest ()
        (list
            (scfp-feature "emission-to-file-backed-persistence" 1)
            (scfp-feature "uses-source-artifact-file-probe" 1)
            (scfp-feature "delegates-status-reason-to-scp" 1)
            (scfp-feature "nested-scp-persistence-row" 1)
            (scfp-feature "probe-bundle-replayable-to-scp" 1)
            (scfp-feature "no-probe-for-malformed-emission" 1)
            (scfp-feature "no-probe-for-non-emitted-emission" 1)
            (scfp-feature "original-emission-preserved" 1)
            (scfp-feature "uniform-max-byte-cap" 1)
            (scfp-feature "no-dylib-path-sniffing" 1)
            (scfp-feature "dylib-policy-bits-from-emission" 1)
            (scfp-feature "fkb-policy-bits-from-emission" 1)
            (scfp-feature "observed-mtime-owned-by-probe" 1)
            (scfp-feature "no-new-persistence-reasons" 1)
            (scfp-feature "no-compiler-execution" 1)
            (scfp-feature "no-table-text-execution" 1)
            (scfp-feature "no-disk-write" 1)
            (scfp-feature "no-form-binary-io" 1)
            (scfp-feature "no-artifact-load-walk-call" 1)
            (scfp-feature "no-selector-install" 1)
            (scfp-feature "no-c-seed-growth" 1)))
    (defn source-compiler-file-persistence-manifest-has? (name fs)
        (if (nil? fs)
            0
            (if (and (str_eq (scfp-feature-name (head fs)) name)
                     (eq (scfp-feature-status (head fs)) 1))
                1
                (source-compiler-file-persistence-manifest-has? name (tail fs)))))

    (defn scfp-source-absent-observation ()
        (sap-source-observation "" 0 -1 -1 ""))
    (defn scfp-fkb-absent-observation ()
        (sap-program-image-fkb-observation "" 0 -1 -1 "" "" 0 0))
    (defn scfp-dylib-absent-observation ()
        (sap-native-dylib-observation "" 0 -1 -1 "" "" 0 0 0 0))
    (defn scfp-empty-source-probe ()
        (safp-source-probe-row (scfp-source-absent-observation)
                               (safp-empty-source-vouch "")
                               (scfp-status-no-probe)))
    (defn scfp-empty-fkb-probe ()
        (safp-artifact-probe-row (sap-role-program-image-fkb)
                                 (scfp-fkb-absent-observation)
                                 (safp-empty-source-vouch "")
                                 (safp-empty-content-vouch "")
                                 (scfp-status-no-probe)))
    (defn scfp-empty-dylib-probe ()
        (safp-artifact-probe-row (sap-role-native-dylib)
                                 (scfp-dylib-absent-observation)
                                 (safp-empty-source-vouch "")
                                 (safp-empty-content-vouch "")
                                 (scfp-status-no-probe)))
    (defn scfp-empty-safp-probe-bundle ()
        (do
            (let source-probe (scfp-empty-source-probe))
            (let fkb-probe (scfp-empty-fkb-probe))
            (let dylib-probe (scfp-empty-dylib-probe))
            (let bundle (sap-bundle (safp-source-probe-observation source-probe)
                                    (safp-artifact-probe-observation fkb-probe)
                                    (safp-artifact-probe-observation dylib-probe)))
            (safp-probe-bundle-row source-probe fkb-probe dylib-probe bundle (scfp-status-no-probe))))

    (defn scfp-row (emission probe-bundle persistence)
        (list "source-compiler-file-persistence"
              emission
              probe-bundle
              persistence
              (scp-persistence-status persistence)
              (scp-persistence-reason persistence)))
    (defn scfp-row? (r)
        (if (eq (len r) 6)
            (str_eq (nth r 0) "source-compiler-file-persistence")
            0))
    (defn scfp-row-emission (r) (nth r 1))
    (defn scfp-row-probe-bundle (r) (nth r 2))
    (defn scfp-row-persistence (r) (nth r 3))
    (defn scfp-row-status (r) (nth r 4))
    (defn scfp-row-reason (r) (nth r 5))

    (defn scfp-no-probe-row (emission)
        (do
            (let probe (scfp-empty-safp-probe-bundle))
            (let persistence (scp-persistence-from-probe emission (safp-probe-bundle-sap probe)))
            (scfp-row emission probe persistence)))

    (defn scfp-native-dylib-probeable? (dylib)
        (if (sad-artifact? dylib)
            (if (sad-artifact-option-valid? dylib)
                (str_eq (sad-artifact-kind dylib) (sad-kind-native-dylib))
                0)
            0))
    (defn scfp-dylib-expected? (dylib)
        (if (sce-no-dylib? dylib) 0 1))
    (defn scfp-dylib-probe-from-emission (source-vouch dylib max-bytes)
        (if (sce-no-dylib? dylib)
            (safp-missing-native-dylib-probe "")
            (if (scfp-native-dylib-probeable? dylib)
                (safp-native-dylib-file-probe
                    (sad-artifact-path dylib)
                    source-vouch
                    (sad-artifact-content-hash dylib)
                    (sad-artifact-seal-ok dylib)
                    (sad-artifact-proof dylib)
                    (sad-artifact-callable dylib)
                    (sad-artifact-lowerable dylib)
                    max-bytes)
                (scfp-empty-dylib-probe))))

    (defn scfp-bundle-status-from (source-probe fkb-probe dylib-probe dylib-expected)
        (if (not (str_eq (safp-source-probe-status source-probe) (sai-status-match)))
            (safp-source-probe-status source-probe)
            (if (not (str_eq (safp-artifact-probe-status fkb-probe) (sai-status-match)))
                (safp-artifact-probe-status fkb-probe)
                (if (eq dylib-expected 1)
                    (if (str_eq (safp-artifact-probe-status dylib-probe) (sai-status-match))
                        (safp-status-ready)
                        (safp-artifact-probe-status dylib-probe))
                    (safp-status-ready)))))
    (defn scfp-probe-bundle-from-emission (emission max-bytes)
        (do
            (let source (scp-source-from-emission emission))
            (let fkb (scp-fkb-from-emission emission))
            (let dylib (scp-dylib-from-emission emission))
            (let source-probe
                (safp-source-file-probe
                    (sad-source-path source)
                    (sad-source-hash source)
                    max-bytes))
            (let fkb-probe
                (safp-program-image-fkb-file-probe
                    (sad-artifact-path fkb)
                    (safp-source-probe-vouch source-probe)
                    (sad-artifact-content-hash fkb)
                    (sad-artifact-seal-ok fkb)
                    (sad-artifact-includes-tbl fkb)
                    max-bytes))
            (let dylib-probe
                (scfp-dylib-probe-from-emission
                    (safp-source-probe-vouch source-probe)
                    dylib
                    max-bytes))
            (let bundle (sap-bundle (safp-source-probe-observation source-probe)
                                    (safp-artifact-probe-observation fkb-probe)
                                    (safp-artifact-probe-observation dylib-probe)))
            (safp-probe-bundle-row source-probe
                                   fkb-probe
                                   dylib-probe
                                   bundle
                                   (scfp-bundle-status-from source-probe
                                                            fkb-probe
                                                            dylib-probe
                                                            (scfp-dylib-expected? dylib))))))
    (defn scfp-file-persistence-from-emission (emission max-bytes)
        (if (not (sce-emission? emission))
            (scfp-no-probe-row emission)
            (if (not (sce-emitted? emission))
                (scfp-no-probe-row emission)
                (do
                    (let probe (scfp-probe-bundle-from-emission emission max-bytes))
                    (let persistence (scp-persistence-from-probe emission (safp-probe-bundle-sap probe)))
                    (scfp-row emission probe persistence)))))
