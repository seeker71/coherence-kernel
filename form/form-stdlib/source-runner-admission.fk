    (defn sra-current-source-artifact-descriptor-gate ()
        (sra-gate "source-artifact-descriptor-band" "composition" "prelude+program" (sra-status-green) "ok"
            "core.fk + source-artifact-cache.fk + source-artifact-descriptor.fk + source-artifact-descriptor-band.fk" "2147483647" "2147483647"))
    (defn sra-current-runtime-artifact-plan-gate ()
        (sra-gate "runtime-artifact-plan-band" "composition" "prelude+program" (sra-status-green) "ok"
            "core.fk + source-artifact-cache.fk + source-artifact-descriptor.fk + runtime-artifact-plan.fk + runtime-artifact-plan-band.fk" "67108863" "67108863"))
    (defn sra-current-source-artifact-probe-gate ()
        (sra-gate "source-artifact-probe-band" "composition" "prelude+program" (sra-status-green) "ok"
            "core.fk + form-fs.fk + source-artifact-cache.fk + source-artifact-descriptor.fk + runtime-artifact-plan.fk + source-artifact-probe.fk + source-artifact-probe-band.fk" "536870911" "536870911"))
    (defn sra-current-top-do-defn-gate ()
        (sra-gate "source-runner-do-defn-band" "parity" "program" (sra-status-green) "ok"
            "form/form-stdlib/tests/source-runner-do-defn-band.fk" "127" "127"))
    (defn sra-current-root-do-gate ()
        (sra-gate "source-runner-root-do-band" "parity" "prelude+program" (sra-status-green) "ok"
            "core.fk + json.fk + bmf-core.fk + source-runner-root-do-band.fk" "31" "31"))
    (defn sra-current-ontology-gate ()
        (sra-gate "form-ontology-loader-bp" "parity" "program" (sra-status-green) "ok"
            "form/form-stdlib/form-ontology-loader.fk + bp(add) probe" "13" "13"))
    (defn sra-current-ontology-ast-gate ()
        (sra-current-ontology-gate))
    (defn sra-current-bmf-integration-gate ()
        (sra-gate "bmf-core-band" "composition" "prelude+program" (sra-status-green) "ok"
            "core.fk + json.fk + cache.fk + form-ontology-loader.fk + line-grammar.fk + bmf-core.fk + bmf-core-band.fk" "600" "600"))
    (defn sra-current-homecoming-prelude-gate ()
        (sra-gate "homecoming-core-prelude" "composition" "prelude+program" (sra-status-green) "ok"
            "form/form-stdlib/core.fk + learn/homecoming-distillation-corpus.fk" "band 511" "band 511"))
    (defn sra-current-oom-gate ()
        (sra-gate "oom-killed" "health" "kernel" (sra-status-green) "ok"
            "current layer probes" "no OOM/killed" "no OOM/killed"))
    (defn sra-current-c-growth-gate ()
        (sra-gate "c-seed-growth" "remediation" "runtime/fkwu-uni.c" (sra-status-green) "ok"
            "runtime/fkwu-uni.c" "no AST-cap growth" "source-runner repairs receipted"))

    (defn sra-current-gates ()
        (list
            (sra-gate "binary-freshness-band" "health" "kernel" (sra-status-green) "ok"
                "form/form-stdlib/tests/binary-freshness-band.fk" "15" "15")
            (sra-gate "native-vs-rented" "health" "kernel" (sra-status-green) "ok"
                "observe/native-vs-rented.fk" "11111" "11111")
            (sra-gate "minimal-let-parity" "parity" "program" (sra-status-green) "ok"
                "(do (let x 40) (add x 2))" "42" "42")
            (sra-gate "defdata-module-constant" "parity" "program" (sra-status-green) "ok"
                "(let rows (list 1 2 3)) + (defn rows-f () rows)" "3" "3")
            (sra-gate "defdata-language-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + defdata.fk + defdata-language.fk + defdata-language-band.fk" "8191" "8191")
            (sra-gate "defdata-recipe-language-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + defdata.fk + defdata-language.fk + defdata-recipe-language.fk + defdata-recipe-language-band.fk" "134217727" "134217727")
            (sra-gate "form-definition-language-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + defdata.fk + form-definition-language.fk + form-definition-language-band.fk" "65535" "65535")
            (sra-gate "source-compiler-grammar-bridge-band" "composition" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + defdata.fk + form-definition-language.fk + source-compiler-emission.fk + source-compiler-grammar-bridge.fk + source-compiler-grammar-bridge-band.fk" "32767" "32767")
            (sra-gate "form-definition-language-floor-band" "parity" "program" (sra-status-green) "ok"
                "form/form-stdlib/tests/form-definition-language-floor-band.fk" "10" "10")
            (sra-gate "domain-grammar-core-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + grammar-loader.fk + domain-grammar-core.fk + domain-grammar-core-band.fk" "268435455" "268435455")
            (sra-gate "grammar-authoring-language-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + grammar-loader.fk + domain-grammar-core.fk + grammar-authoring-language.fk + grammar-authoring-language-band.fk" "134217727" "134217727")
            (sra-gate "sibling-ref-authoring-language-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + grammar-loader.fk + domain-grammar-core.fk + grammar-authoring-language.fk + sibling-ref-authoring-language.fk + sibling-ref-authoring-language-band.fk" "2147483647" "2147483647")
            (sra-gate "domain-semantic-bridge-band" "parity" "prelude+program" (sra-status-green) "ok"
                "core.fk + bmf-core.fk + bmf-grammar.fk + grammar-loader.fk + domain-grammar-core.fk + semantic-stdlib.fk + domain-semantic-bridge.fk + domain-semantic-bridge-band.fk" "268435455" "268435455")
            (sra-gate "source-artifact-descriptor-band" "composition" "prelude+program" (sra-status-green) "ok"
                "core.fk + source-artifact-cache.fk + source-artifact-descriptor.fk + source-artifact-descriptor-band.fk" "2147483647" "2147483647")
            (sra-gate "runtime-artifact-plan-band" "composition" "prelude+program" (sra-status-green) "ok"
