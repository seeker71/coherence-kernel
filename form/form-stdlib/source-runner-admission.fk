            (sra-gate "form-ontology-loader-bp" "parity" "program" (sra-status-green) "ok"
                "form/form-stdlib/form-ontology-loader.fk + bp(add) probe" "13" "13")
            (sra-gate "bmf-core-band" "composition" "prelude+program" (sra-status-green) "ok"
                "core.fk + json.fk + cache.fk + form-ontology-loader.fk + line-grammar.fk + bmf-core.fk + bmf-core-band.fk" "600" "600")
