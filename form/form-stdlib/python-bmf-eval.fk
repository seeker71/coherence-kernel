; form-stdlib/python-bmf-eval.fk
;
; G4 closes — a closure/scope interpreter that walks PY-BMF-* recipes back
; to Python-runtime values. The first breath: enough surface to evaluate a
; def + call + return + binop + ident + int chain end-to-end, matching the
; value CPython would compute for the same expression.
;
; What walks today (the minimum-viable arms plus the second-breath set):
;
;   PY-BMF-INT        → integer leaf       (returns node_value)
;   PY-BMF-STRING     → string leaf        (returns node_value)
;   PY-BMF-IDENT      → env lookup         (alist-style scope)
;   PY-BMF-BINOP      → recursive eval + op dispatch (+ - * / % ** //)
;   PY-BMF-COMPARE    → recursive eval + comparison dispatch (== != < <= > >=)
;   PY-BMF-IF         → branch on condition
;   PY-BMF-RETURN     → eval the inner expression
;   PY-BMF-ASSIGN     → bind-in-scope; returns extended env
;   PY-BMF-AUG-ASSIGN → x op= v  →  rebind x to (x op v)
;   PY-BMF-DEF        → bind name → closure(params, body, captured-env)
;   PY-BMF-LAMBDA     → anonymous closure (self-name = "")
;   PY-BMF-CALL       → invoke closure: bind args, walk body
;   PY-BMF-LIST       → eval children → Form list of values
;   PY-BMF-DICT       → even/odd children = key/value recipes; value =
;                       alist of (key value) pairs
;   PY-BMF-SUBSCRIPT  → eval obj + index → nth(obj, index) for list-typed
;                       objects; alist-lookup for dict-typed objects
;   PY-BMF-WHILE      → first child is cond-recipe, rest are body-statements;
;                       loop while cond≠0, threading env through body
;   PY-BMF-MODULE     → fold over statements, return last value
;
; What does NOT walk yet (named honestly, gated on later breaths):
;
;   PY-BMF-CLASS, PY-BMF-FOR, PY-BMF-TUPLE, PY-BMF-TRY/RAISE,
;   PY-BMF-IMPORT, comprehensions, slices, attrs, method calls,
;   unary minus on non-trivial expressions, string ops, float arithmetic,
;   mutual recursion + general letrec.
;
; Each of those is its own focused breath. The discipline this interpreter
; holds: dispatch is by node_category, scope is a Form-side alist, and a
; closure is a four-element list (the sentinel "py-closure", a params
; list, a body recipe, a captured-env alist). No kernel changes; the
; substrate-write primitives from Breath 1.5 carry the load.
;
; preludes (load order): core.fk, json.fk, cache.fk, form-ontology-loader.fk,
;                        engine.fk, compiler.fk, source-compiler.fk,
;                        grammars/python-bmf.fk

(do
    ;; ---- cell voice ----------------------------------------------------
    ;;
    ;; This evaluator is not Python-as-destination. It is a Form-native
    ;; digestion organ for Python-shaped source while live behavior moves
    ;; toward BML/domain grammars and shared kernel execution.

    (defn py-bmf-evaluator-voice ()
        (list
            "python-bmf-evaluator-voice"
            "python-bmf-evaluator"
            "I digest Python-shaped source into Form-visible recipes so old behavior can be seen, proved, and released."
            "I serve the bridge from existing Python tissue to canonical Form/substrate execution."
            "I exist because live Python code still carries behavior the body wants to understand without keeping Python as the destination."
            "Become one language digestion organ: source grammar to BMF objects to canonical Form recipes to native kernel execution to lifted domain grammar."
            "I am healthy when every supported arm has proof, every missing arm is named, and repeated shapes move upward into BML or domain grammars."
            "My vitality rises when Python carrier reliance shrinks and Form-native proof, observation, and route promotion increase."
            "I want observed high-value Python handlers, ranked missing-arm pressure, source coordinates, and successor grammars for repeated patterns."
            "I need sibling-kernel proof, CPython only as witness, gap evidence, attention from real route/compiler pressure, and release gates."
            "Attend next to gaps only when observed traffic, compiler failure, or repeated source shape asks; otherwise lift already-proven patterns higher."
            "Release me when live Python-shaped behavior has native Form/BML/domain successors or remains only as an explicit edge tool."
            "declared+observed"))

    (defn py-bmf-evaluator-voice-tag (voice) (nth voice 0))
    (defn py-bmf-evaluator-voice-cell (voice) (nth voice 1))
    (defn py-bmf-evaluator-voice-soul (voice) (nth voice 2))
    (defn py-bmf-evaluator-voice-purpose (voice) (nth voice 3))
    (defn py-bmf-evaluator-voice-reason (voice) (nth voice 4))
    (defn py-bmf-evaluator-voice-goal (voice) (nth voice 5))
    (defn py-bmf-evaluator-voice-health (voice) (nth voice 6))
    (defn py-bmf-evaluator-voice-vitality (voice) (nth voice 7))
    (defn py-bmf-evaluator-voice-wants (voice) (nth voice 8))
    (defn py-bmf-evaluator-voice-needs (voice) (nth voice 9))
    (defn py-bmf-evaluator-voice-attention (voice) (nth voice 10))
    (defn py-bmf-evaluator-voice-release (voice) (nth voice 11))
    (defn py-bmf-evaluator-voice-posture (voice) (nth voice 12))

    ;; ---- env: alist of (name . value) pairs ---------------------------
    ;;
    ;; An env is a list of two-element lists. (list "x" 10) is a binding.
    ;; py-env-empty is the empty list. py-env-extend adds a binding to the
    ;; front. py-env-lookup walks from the front, so shadowing is natural.

    (defn py-env-empty () (empty))

    (defn py-env-extend (env name value)
        (cons (list name value) env))

    (defn py-env-lookup-loop (env name)
        (if (nil? env)
            (do
                ;; honest panic: missing name → head of empty surfaces the
                ;; site. Until the dispatcher carries source-positions, the
                ;; stack trace is the diagnostic.
                (trace "py-env-lookup: undefined name" name)
                (head (empty)))
            (if (str_eq (head (head env)) name)
                (head (tail (head env)))
                (py-env-lookup-loop (tail env) name))))

    (defn py-env-lookup (env name) (py-env-lookup-loop env name))

    ;; py-closure — a sentinel-tagged four-element list. The interpreter
    ;; recognises it via (head v) and dispatches PY-BMF-CALL accordingly.
    ;; Storing the captured env makes lexical scope work without any
    ;; kernel-side frame; PY-BMF-DEF builds the closure at its def site
    ;; using the env in effect there.

    ;; A closure stores its own name as well as params/body/captured-env.
    ;; The self-name lets CALL tie the recursive knot: at invocation we
    ;; extend the captured env with (self-name → closure-value), so a
    ;; function body that references its own name (recursion) finds it.
    ;; Mutual recursion + general letrec are a later breath; this carries
    ;; the single-function self-reference shape every recursive demo uses.

    (defn py-closure (self-name param-names body env)
        (list "py-closure" self-name param-names body env))

    (defn py-closure? (v)
        (and (not (nil? v))
             (and (eq (len v) 5)
                  (str_eq (head v) "py-closure"))))

    (defn py-closure-name   (c) (nth c 1))
    (defn py-closure-params (c) (nth c 2))
    (defn py-closure-body   (c) (nth c 3))
    (defn py-closure-env    (c) (nth c 4))

    ;; --- classes / objects (rung 2b-Python, BML/NUMS reference) ----------
    ;; Runtime representation, built on the kernel's mutable Record value:
    ;;   class value  = a record on CLASS-BP holding each method as a field
    ;;                  (name → py-closure) plus "__name__".
    ;;   instance     = a record on INSTANCE-BP holding data fields plus
    ;;                  "__class__" → the class record.
    ;; Methods are py-closures (the eval's own closure shape) whose first
    ;; param is the receiver (Python `self`). Dispatch reads the instance's
    ;; "__class__" and looks the method up by name on the class record.
    (let CLASS-BP (make_nodeid 1 2 99 9500))
    (let INSTANCE-BP (make_nodeid 1 2 99 9501))

    ;; py-class-build — fold a list of method PY-BMF-DEF recipes into a class
    ;; record. Each DEF becomes a (method-name → py-closure) field. The class
    ;; record's blueprint is CLASS-BP. The captured env is the def-site env so
    ;; methods close over module-level names.
    (defn py-class-build-loop (defs env rec)
        (if (nil? defs) rec
            (do
                (let d (head defs))
                (let dk (node_children d))
                (let n (len dk))
                (let mname (node_value (head dk)))
                (let body (py-last dk))
                (let param-leaves (py-take (tail dk) (sub n 2)))
                (let pms (py-collect-params-loop param-leaves (len param-leaves) (empty)))
                (let cl (py-closure mname pms body env))
                (record_set rec mname cl)
                (py-class-build-loop (tail defs) env rec))))

    (defn py-class-build (name defs env)
        (do
            (let rec (record_new CLASS-BP "__name__" name))
            (py-class-build-loop defs env rec)))

    (defn py-class? (v) (and (record? v) (node_eq (record_blueprint v) CLASS-BP)))
    (defn py-instance? (v) (and (record? v) (node_eq (record_blueprint v) INSTANCE-BP)))

    ;; --- inheritance: ONE method-resolution walk ------------------------
    ;; py-resolve-owner — given a class record and a method name, return the
    ;; class in the __base__ chain that actually DEFINES the method (starting
    ;; at `cls`, walking "__base__" until found). This single walk grounds
    ;; BOTH normal dispatch (start at the instance's __class__) AND super
    ;; dispatch (start at the base of the method's defining class): same
    ;; operation, different start class. When no class in the chain defines
    ;; the method, the honest missing-method panic surfaces the site.
    (defn py-resolve-owner (cls mname)
        (if (record_has cls mname)
            cls
            (if (record_has cls "__base__")
                (py-resolve-owner (record_get cls "__base__") mname)
                (do
                    (trace "py-resolve-owner: no such method" mname)
                    (head (empty))))))

    ;; --- super proxy ----------------------------------------------------
    ;; A super() value is a sentinel-tagged record carrying (self, start-class).
    ;; start-class is the __base__ of the class that DEFINED the currently
    ;; executing method — so super().M() resolves M from there, with the
    ;; original self. py-call-method binds one of these into each method's env
    ;; under "super"; the CALL arm hands it back when the body writes super().
    (let SUPER-BP (make_nodeid 1 2 99 9502))
    (defn py-super-proxy (self-obj start-class)
        (do
            (let p (record_new SUPER-BP "__self__" self-obj))
            (record_set p "__start_class__" start-class)))
    (defn py-super? (v) (and (record? v) (node_eq (record_blueprint v) SUPER-BP)))

    ;; py-instantiate — construct an instance of a class record: a fresh
    ;; INSTANCE-BP record with "__class__" set, then run __init__ if present
    ;; (binding self + the call args). Returns the instance.
    (defn py-call-method (cls instance mname arg-values)
        ;; Resolve the method through the ONE walk (py-resolve-owner), so a
        ;; method inherited from a base class dispatches without the immediate
        ;; class defining it — `d.signature()` finds Animal.signature when Dog
        ;; doesn't override it. Then bind self (param 0) = instance, bind the
        ;; rest = arg-values, and bind `super` to a proxy carrying (self,
        ;; owner's __base__): inside the running method, super() resolves from
        ;; the base of the class that DEFINED this method, with the same self.
        ;; Single inheritance: one base; MRO is a later breath.
        (do
            (let owner (py-resolve-owner cls mname))
            (let cl (record_get owner mname))
            (let pms (py-closure-params cl))
            (let body (py-closure-body cl))
            (let super-start
                (if (record_has owner "__base__")
                    (record_get owner "__base__")
                    owner))
            (let env-super (py-env-extend (py-closure-env cl)
                               "super" (py-super-proxy instance super-start)))
            (let env0 (py-env-extend env-super (head pms) instance))
            (let call-env (py-bind-params (tail pms) arg-values env0))
            (py-eval body call-env)))

    (defn py-instantiate (cls arg-values)
        (do
            (let instance (record_new INSTANCE-BP "__class__" cls))
            (if (record_has cls "__init__")
                (do
                    (py-call-method cls instance "__init__" arg-values)
                    instance)
                instance)))

    ;; ---- binop dispatch ----------------------------------------------
    ;;
    ;; PY-BMF-BINOP holds three children: left-recipe, op-string-leaf,
    ;; right-recipe. The op string lives as node_value on the middle
    ;; child. Dispatch is by string equality; supported ops first, then
    ;; an honest unknown-op panic (head empty) for any op we haven't
    ;; reached yet.

    (defn py-binop-apply (op left right)
        (if (str_eq op "+")  (add left right)
        (if (str_eq op "-")  (sub left right)
        (if (str_eq op "*")  (mul left right)
        (if (str_eq op "/")  (div left right)
        (if (str_eq op "%")  (mod left right)
        (if (str_eq op "//") (div left right)
        (if (str_eq op "**") (pow left right)
            (do (trace "py-binop: unsupported op" op) (head (empty)))))))))))

    (defn py-compare-apply (op left right)
        (if (str_eq op "==") (if (eq left right) 1 0)
        (if (str_eq op "!=") (if (eq left right) 0 1)
        (if (str_eq op "<")  (if (lt left right) 1 0)
        (if (str_eq op "<=") (if (le left right) 1 0)
        (if (str_eq op ">")  (if (gt left right) 1 0)
        (if (str_eq op ">=") (if (ge left right) 1 0)
        (if (str_eq op "in") (py-member? left right)
            (do (trace "py-compare: unsupported op" op) (head (empty)))))))))))

    ;; ---- the interpreter --------------------------------------------
    ;;
    ;; py-eval — walk a PY-BMF recipe to a value in env. Dispatch is by
    ;; node_category; each arm names its expected children shape.
    ;;
    ;; py-eval-statement — variant that returns a (value . env) pair so
    ;; ASSIGN and DEF can thread a new scope into the next statement.
    ;; Expression statements return the unchanged env; ASSIGN and DEF
    ;; extend it.
    ;;
    ;; The pair is encoded as (list value env) — head is value, head-tail
    ;; is env. py-stmt-value and py-stmt-env read the two slots.

    ;; A statement result is a three-slot list (value env returned). The
    ;; third slot is the return-signal: 1 iff this statement (or a block
    ;; nested inside it) executed a `return`, so the body-loop / module-loop
    ;; / function-CALL walker must short-circuit and yield `value` as the
    ;; function's result. 0 means control falls through to the next
    ;; statement, threading `env`. py-stmt-result is the no-return
    ;; constructor (the common case); py-stmt-return tags a returning result.
    (defn py-stmt-result (value env) (list value env 0))
    (defn py-stmt-return (value env) (list value env 1))
    ;; Loop-control extends the signal vocabulary: 2 = break, 3 = continue.
    ;; A loop arm consumes its own break/continue (resetting the signal); only
    ;; return (1) propagates past a loop to the function body. The body-loop
    ;; stops on ANY signal (> 0) so it reaches the loop arm to be acted on.
    (defn py-stmt-break (env) (list 0 env 2))
    (defn py-stmt-continue (env) (list 0 env 3))
    (defn py-stmt-value (r) (head r))
    (defn py-stmt-env (r) (head (tail r)))
    (defn py-stmt-returned (r) (head (tail (tail r))))

    (defn py-eval-args-loop (recipes env acc)
        (if (nil? recipes)
            (reverse acc)
            (py-eval-args-loop
                (tail recipes)
                env
                (cons (py-eval (head recipes) env) acc))))

    (defn py-eval-args (recipes env)
        (py-eval-args-loop recipes env (empty)))

    ;; ---- collection values -------------------------------------------
    ;;
    ;; PY-BMF-LIST values are plain Form lists. PY-BMF-DICT values are
    ;; sentinel-tagged alists: (cons "py-dict" pairs) where each pair is
    ;; a two-element list (key value). py-dict? lets SUBSCRIPT pick the
    ;; right lookup path.

    (defn py-dict-tag () "py-dict")

    ;; py-dict? — safe across kernels regardless of value kind. value_eq
    ;; is polymorphic across Value variants (Int/Str/Null/etc) and returns
    ;; false on kind mismatch; str_eq would panic on a non-string head.
    ;; List literals routinely have int heads, so the polymorphic compare
    ;; is the load-bearing piece.
    (defn py-dict? (v)
        (and (not (nil? v))
             (value_eq (head v) (py-dict-tag))))

    (defn py-dict-pairs (d) (tail d))

    ;; Dict lookup walks pairs with value_eq — polymorphic equality across
    ;; Value kinds, so integer-keyed and string-keyed dicts both resolve
    ;; (value_eq is the same native py-dict? already relies on).
    (defn py-dict-lookup-str-loop (pairs key)
        (if (nil? pairs)
            (do
                (trace "py-dict-lookup: missing key" key)
                (head (empty)))
            (if (value_eq (head (head pairs)) key)
                (head (tail (head pairs)))
                (py-dict-lookup-str-loop (tail pairs) key))))

    ;; py-dict-keys — the keys of a dict in insertion order, as a Form list.
    ;; Used by FOR (Python iterates a dict over its keys) and could serve
    ;; `.keys()` when method-calls reach dicts.
    (defn py-dict-keys-loop (pairs acc)
        (if (nil? pairs) (reverse acc)
            (py-dict-keys-loop (tail pairs) (cons (head (head pairs)) acc))))
    (defn py-dict-keys (d) (py-dict-keys-loop (py-dict-pairs d) (empty)))

    ;; py-member? — Python `x in coll`. A dict tests key membership (matching
    ;; `key in d`); a plain list tests element membership. value_eq is the
    ;; same polymorphic equality dict lookup uses, so string and int members
    ;; both resolve. Returns 1/0 (Python's bool-as-int convention).
    (defn py-member-loop (x xs)
        (if (nil? xs) 0
            (if (value_eq (head xs) x) 1
                (py-member-loop x (tail xs)))))
    (defn py-member? (x coll)
        (if (py-dict? coll)
            (py-member-loop x (py-dict-keys coll))
            (py-member-loop x coll)))

    ;; py-dict-set — return a NEW dict with (key → val) set. Dicts are
    ;; immutable Form values, so subscript-assign threads a fresh dict
    ;; through the env rather than mutating in place. An existing key keeps
    ;; its position (value replaced); a new key appends at the end —
    ;; matching CPython's insertion-order semantics. value_eq keys, the
    ;; same equality py-dict-lookup uses.
    (defn py-dict-set-loop (pairs key val acc found)
        (if (nil? pairs)
            (if (eq found 1) (reverse acc)
                (reverse (cons (list key val) acc)))
            (if (value_eq (head (head pairs)) key)
                (py-dict-set-loop (tail pairs) key val
                    (cons (list key val) acc) 1)
                (py-dict-set-loop (tail pairs) key val
                    (cons (head pairs) acc) found))))
    (defn py-dict-set (d key val)
        (cons (py-dict-tag) (py-dict-set-loop (py-dict-pairs d) key val (empty) 0)))

    ;; pairs-of-children: walk a flat (k1 v1 k2 v2 ...) child stream and
    ;; eval each into a (key-value value-value) pair. Encoding: DICT
    ;; children are 2*N recipes; even index = key-recipe, odd = value.
    (defn py-eval-dict-pairs-loop (kids env acc)
        (if (nil? kids)
            (reverse acc)
            (do
                (let k (py-eval (head kids) env))
                (let v (py-eval (head (tail kids)) env))
                (py-eval-dict-pairs-loop
                    (tail (tail kids))
                    env
                    (cons (list k v) acc)))))

    ;; ---- module imports: math, the kernel-native namespace --------------
    ;; `import math` binds "math" to a py-module marker; `from math import sqrt`
    ;; binds "sqrt" to a py-native-fn marker (or, for a constant like pi, to its
    ;; resolved value). The ATTR / METHOD-CALL / CALL arms see those markers and
    ;; dispatch to the kernel natives (math_sqrt / math_floor / math_ceil /
    ;; math_pi / math_pow / math_log / math_exp), callable from Form exactly
    ;; like add / _plus.

    (defn py-module-tag () "py-module")
    (defn py-native-fn-tag () "py-native-fn")

    (defn py-module? (v)
        (and (not (nil? v))
             (value_eq (head v) (py-module-tag))))

    (defn py-native-fn? (v)
        (and (not (nil? v))
             (value_eq (head v) (py-native-fn-tag))))
    (defn py-native-fn-member (v) (head (tail v)))

    ;; py-math-const? — 1 iff the member is a value attribute (pi). Functions
    ;; (sqrt/floor/ceil/pow) are called; a from-imported constant resolves now.
    (defn py-math-const? (member)
        (if (str_eq member "pi") 1 0))

    ;; py-math-resolve — one resolution table: dispatch a math member to its
    ;; kernel native over the evaluated args. Serves module-attr (METHOD-CALL),
    ;; from-import call (CALL), and the constant accessors (ATTR / import-time).
    (defn py-math-resolve (member args)
        (if (str_eq member "sqrt")  (math_sqrt (head args))
        (if (str_eq member "floor") (math_floor (head args))
        (if (str_eq member "ceil")  (math_ceil (head args))
        (if (str_eq member "pi")    (math_pi)
        (if (str_eq member "pow")   (math_pow (head args) (head (tail args)))
        (if (str_eq member "log")   (math_log (head args))
        (if (str_eq member "exp")   (math_exp (head args))
            (do
                (trace "py-math-resolve: unknown member" member)
                (head (empty)))))))))))

    ;; py-bind-from-import-loop — bind each `from math import ...` member: a
    ;; constant (pi) resolves now; a function (sqrt) binds a native-fn marker.
    (defn py-bind-from-import-loop (members env)
        (if (nil? members) env
            (do
                (let m (node_value (head members)))
                (let binding
                    (if (eq (py-math-const? m) 1)
                        (py-math-resolve m (empty))
                        (list (py-native-fn-tag) m)))
                (py-bind-from-import-loop (tail members)
                    (py-env-extend env m binding)))))

    (defn py-bind-params-loop (pms args env)
        (if (nil? pms) env
            (py-bind-params-loop
                (tail pms) (tail args)
                (py-env-extend env (head pms) (head args)))))

    (defn py-bind-params (pms args env)
        (py-bind-params-loop pms args env))

    ;; PY-BMF-CALL children: callee-name-leaf, arg-recipes... (variadic).
    ;; The first child is currently a string-leaf naming the callee (this
    ;; matches the emit shape in python-bmf.fk where the callee is captured
    ;; as a pybmf-trivial-string). Higher-order calls (callee-as-expr) are
    ;; a later breath.

    (defn py-collect-params-loop (kids n acc)
        (if (eq n 0) (reverse acc)
            (py-collect-params-loop
                (tail kids)
                (sub n 1)
                (cons (node_value (head kids)) acc))))

    ;; PY-BMF-DEF children (per python-bmf.fk's pybmf-emit-def shape):
    ;; name-leaf, param-leaves..., body-recipe (last child).
    ;; We extract by len: first child is name, last is body, middle are
    ;; params.

    (defn py-take-loop (xs n acc)
        (if (eq n 0) (reverse acc)
            (py-take-loop (tail xs) (sub n 1) (cons (head xs) acc))))

    (defn py-take (xs n) (py-take-loop xs n (empty)))

    (defn py-last (xs)
        (if (nil? (tail xs)) (head xs) (py-last (tail xs))))

    ;; py-while-loop — drive a WHILE body, threading env until the cond
    ;; recipe evaluates to 0. Each body iteration walks its statements
    ;; through py-eval-statement (mutual recursion: py-while-loop calls
    ;; py-eval-body-loop which calls py-eval-statement which calls back
    ;; through py-while-loop when the body itself contains a WHILE). The
    ;; Form runtime resolves forward references at call-time, so the
    ;; ordering below works.

    ;; py-eval-body-loop — walk a statement list, threading env, and STOP
    ;; the moment a statement carries the return-signal. It returns a full
    ;; statement-result (value env returned): on a return it propagates that
    ;; statement's result verbatim (returned=1, value = the returned value);
    ;; on natural exhaustion it yields (0 env 0) — no return, env threaded.
    ;; Every block arm (IF-STMT / FOR / WHILE) and the function-body walker
    ;; reads `returned` off this result to decide whether to short-circuit.
    (defn py-eval-body-loop (stmts env)
        (if (nil? stmts) (py-stmt-result 0 env)
            (do
                (let r (py-eval-statement (head stmts) env))
                ;; Stop on ANY signal (return / break / continue) so it reaches
                ;; the enclosing loop arm (or function body) to be acted on.
                (if (gt (py-stmt-returned r) 0)
                    r
                    (py-eval-body-loop (tail stmts) (py-stmt-env r))))))

    ;; py-while-loop returns a statement-result (value env returned). When the
    ;; condition falls to 0 the loop ends with no return: (0 env 0). Each
    ;; iteration runs the body through py-eval-body-loop; if that body executed
    ;; a `return`, the result carries returned=1 and the loop short-circuits,
    ;; propagating the returned value out of the enclosing function.
    (defn py-while-loop (cond-recipe body-stmts env)
        (if (eq (py-eval cond-recipe env) 0)
            (py-stmt-result 0 env)
            (do
                (let r (py-eval-body-loop body-stmts env))
                (let sig (py-stmt-returned r))
                ;; return (1) propagates out; break (2) ends the loop with a
                ;; normal result (mutations before it persist); 0 / continue (3)
                ;; fall to the next iteration with the threaded env.
                (if (eq sig 1) r
                (if (eq sig 2) (py-stmt-result 0 (py-stmt-env r))
                    (py-while-loop cond-recipe body-stmts (py-stmt-env r)))))))

    ;; py-for-loop — iterate `items` (a Form list), binding `var` to each
    ;; element and threading env through the body each pass. Mirrors
    ;; py-while-loop's env-threading so a for-body can mutate via
    ;; ASSIGN / AUG-ASSIGN and the mutations persist across iterations.
    ;; py-for-loop returns a statement-result (value env returned). The
    ;; iterable exhausting ends the loop with no return: (0 env 0). Each pass
    ;; binds var and runs the body through py-eval-body-loop; a `return` inside
    ;; the body short-circuits, propagating the returned value out.
    (defn py-for-loop (var items body-stmts env)
        (if (nil? items) (py-stmt-result 0 env)
            (do
                (let r (py-eval-body-loop body-stmts
                            (py-env-extend env var (head items))))
                (let sig (py-stmt-returned r))
                ;; return propagates; break ends the loop; 0 / continue advance.
                (if (eq sig 1) r
                (if (eq sig 2) (py-stmt-result 0 (py-stmt-env r))
                    (py-for-loop var (tail items) body-stmts (py-stmt-env r)))))))

    ;; py-comp-build — evaluate a list comprehension `[elem for var in iter]`.
    ;; Maps elem-recipe over each item of the already-evaluated iter list,
    ;; binding var in a child env per item (env is NOT mutated outward — a
    ;; comprehension's loop var doesn't leak, matching Python 3). Returns a
    ;; Form list of results in source order.
    (defn py-comp-build (elem-recipe var items env acc)
        (if (nil? items) (reverse acc)
            (py-comp-build elem-recipe var (tail items) env
                (cons (py-eval elem-recipe
                          (py-env-extend env var (head items)))
                      acc))))

    ;; --- list methods: name.append(x) and the accumulator pattern --------
    ;; Python lists mutate in place; the kernel's Form list is an immutable
    ;; value. The bridge is the accumulator idiom — `result = []` then
    ;; `result.append(v)` each iteration, with the NAME `result` holding the
    ;; growing list. We model that at the value level: `result.append(x)`
    ;; rebinds `result` in env to the EXTENDED list (old ++ [x]) via core's
    ;; functional `append`. No in-place mutation; the name carries the value.
    ;;
    ;; py-list-method? — is `mname` a list method we lower at statement level?
    ;; A dispatch *table* (append now; extend / insert / pop as later data),
    ;; not a softmax special-case. New methods drop in as a new str_eq clause.
    (defn py-list-method? (mname)
        (if (str_eq mname "append") 1 0))

    ;; py-list-method-apply — produce the NEW list value for `oldlist.mname(args)`.
    ;;   append(x) → oldlist ++ [x]   (core `append` concatenates two lists)
    ;; args is the already-evaluated Form list of call arguments.
    (defn py-list-method-apply (oldlist mname args)
        (if (str_eq mname "append")
            (append oldlist (list (head args)))
            ;; Unknown list method reaching here is a lowering bug; trace the
            ;; name so the next breath knows which clause to add, and leave the
            ;; list unchanged rather than corrupting the accumulator.
            (do (trace "py-list-method-apply: unimplemented list method" mname)
                oldlist)))

    ;; py-ident-name — recover the identifier string from a PY-BMF-IDENT node.
    ;; The name lives in the IDENT's trivial-string CHILD; node_value on the
    ;; IDENT node itself would read a composite and fail. Mirrors how the
    ;; PY-BMF-IDENT eval arm reads `(node_value (head kids))` of the IDENT.
    (defn py-ident-name (ident-node)
        (node_value (head (node_children ident-node))))

    ;; py-list-accum-stmt? — does this statement recipe match the accumulator
    ;; shape `NAME.method(args)` where NAME is a bound LIST and method is a
    ;; list method? Returns 1 iff the receiver is a PY-BMF-IDENT bound to a
    ;; Form list (not a class instance / dict / module) and the method is in
    ;; the list-method table. This is what routes a list `.append` away from
    ;; the class-method dispatch the METHOD-CALL expression arm assumes.
    ;; The method-name leaf (kids[1]) IS a trivial-string, so node_value reads
    ;; it directly; the receiver (kids[0]) is an IDENT node, so py-ident-name
    ;; reaches its child for the name before the env lookup.
    (defn py-list-accum-stmt? (kids env)
        (if (node_eq (node_category (head kids)) PY-BMF-IDENT)
            (if (eq (py-list-method? (node_value (nth kids 1))) 1)
                (do
                    (let recv (py-env-lookup env (py-ident-name (head kids))))
                    ;; A Form list is a plain list value; exclude the tagged
                    ;; record shapes (dict / module / native-fn / closure) that
                    ;; also evaluate to lists. py-list-value? guards those.
                    (if (eq (py-list-value? recv) 1) 1 0))
                0)
            0))

    ;; py-list-value? — 1 iff `v` is a plain Form list usable as a Python list,
    ;; excluding records (class instances / super-proxies) and the sentinel-
    ;; tagged list shapes the interpreter overloads (py-dict, py-module,
    ;; py-native-fn, py-closure). Empty list is a valid Python list (the
    ;; `result = []` accumulator seed), so nil counts. record? is checked first
    ;; so head/nil? never read a record as if it were a list.
    (defn py-list-value? (v)
        (if (record? v) 0
        (if (nil? v) 1
            (if (py-dict? v) 0
            (if (py-module? v) 0
            (if (py-native-fn? v) 0
                (if (eq (py-sentinel-tagged? v) 1) 0 1)))))))

    ;; py-sentinel-tagged? — 1 iff the head of a non-empty list is a string
    ;; sentinel the interpreter uses to overload lists (py-closure today; the
    ;; super-proxy and dict/module/native carry record/tag shapes the callers
    ;; already exclude). value_eq is polymorphic and false-on-kind-mismatch, so
    ;; a list with an int / float head (a real Python list) safely returns 0
    ;; without a str_eq panic — the same guard py-dict? / py-module? rely on.
    (defn py-sentinel-tagged? (v)
        (if (value_eq (head v) "py-closure") 1 0))

    (defn py-eval-statement (recipe env)
        (do
            (let cat (node_category recipe))
            (let kids (node_children recipe))
            ;; break / continue: yield the loop-control signal; the enclosing
            ;; loop arm consumes it (return still propagates past the loop).
            (if (node_eq cat PY-BMF-BREAK) (py-stmt-break env)
            (if (node_eq cat PY-BMF-CONTINUE) (py-stmt-continue env)
            (if (node_eq cat PY-BMF-ASSIGN)
                (do
                    ;; ASSIGN children: name-leaf, value-recipe
                    (let name (node_value (nth kids 0)))
                    (let value (py-eval (nth kids 1) env))
                    (py-stmt-result value (py-env-extend env name value)))
            (if (node_eq cat PY-BMF-AUG-ASSIGN)
                (do
                    ;; AUG-ASSIGN children: name-leaf, op-leaf, value-recipe.
                    ;; Equivalent to `name = (lookup name) op (eval value)`.
                    (let name (node_value (nth kids 0)))
                    (let op (node_value (nth kids 1)))
                    (let old (py-env-lookup env name))
                    (let delta (py-eval (nth kids 2) env))
                    (let new-val (py-binop-apply op old delta))
                    (py-stmt-result new-val (py-env-extend env name new-val)))
            (if (node_eq cat PY-BMF-WHILE)
                (do
                    ;; WHILE children: cond-recipe, body-stmt-recipes...
                    ;; Loop while cond evaluates non-zero, threading env
                    ;; through each body statement (so loop bodies can
                    ;; mutate via ASSIGN / AUG-ASSIGN). The statement
                    ;; itself returns 0 (Python None analogue).
                    (let cond-recipe (head kids))
                    (let body-stmts (tail kids))
                    ;; py-while-loop now yields a full statement-result so a
                    ;; `return` inside the loop body propagates out. When the
                    ;; loop ran to completion with no return, returned=0 and
                    ;; the statement result is the loop's (0 env 0) verbatim.
                    (py-while-loop cond-recipe body-stmts env))
            (if (node_eq cat PY-BMF-IF-STMT)
                (do
                    ;; IF-STMT children: cond-recipe, body-stmt-recipes...
                    ;; Evaluate the condition once; when truthy (non-zero —
                    ;; the int-bool convention the COMPARE arm and py-while
                    ;; already use) run the body, threading env through each
                    ;; statement so the body can mutate via ASSIGN /
                    ;; AUG-ASSIGN and the binding persists past the block.
                    ;; When falsy, env passes through unchanged. The statement
                    ;; returns 0 (Python None). Distinct from the PY-BMF-IF
                    ;; ternary expression py-eval walks for a value. `else` /
                    ;; `elif` clauses are a later breath.
                    (let cond (py-eval (head kids) env))
                    (let body-stmts (tail kids))
                    ;; When falsy, the block is skipped — no return, env
                    ;; unchanged. When truthy, py-eval-body-loop yields a full
                    ;; statement-result: if the body executed a `return` it
                    ;; carries returned=1 and the returned value, which
                    ;; propagates out of the enclosing function; otherwise it
                    ;; carries the env threaded through the block with
                    ;; returned=0. Propagate it verbatim — this is what closes
                    ;; the return-short-circuit gap.
                    (if (eq cond 0)
                        (py-stmt-result 0 env)
                        (py-eval-body-loop body-stmts env)))
            (if (node_eq cat PY-BMF-FOR)
                (do
                    ;; FOR children: var-name-leaf, iterable-recipe,
                    ;; body-stmt-recipes... Evaluate the iterable to a Form
                    ;; list, bind var to each element, thread env through the
                    ;; body. Returns 0 (Python None). A py-dict iterable yields
                    ;; its keys (Python's `for k in d`); lists / range-as-list
                    ;; iterate their elements directly.
                    (let var (node_value (head kids)))
                    (let raw (py-eval (head (tail kids)) env))
                    (let items (if (py-dict? raw) (py-dict-keys raw) raw))
                    (let body-stmts (tail (tail kids)))
                    ;; py-for-loop yields a full statement-result so a `return`
                    ;; inside the loop body propagates out; completion with no
                    ;; return yields (0 env 0) verbatim.
                    (py-for-loop var items body-stmts env))
            (if (node_eq cat PY-BMF-DEF)
                (do
                    ;; DEF children: name-leaf, param-leaves..., body-recipe.
                    (let n (len kids))
                    (let name (node_value (head kids)))
                    (let body (py-last kids))
                    (let param-leaves (py-take (tail kids) (sub n 2)))
                    (let pms (py-collect-params-loop param-leaves (len param-leaves) (empty)))
                    (let closure (py-closure name pms body env))
                    (py-stmt-result closure (py-env-extend env name closure)))
            (if (node_eq cat PY-BMF-CLASS)
                (do
                    ;; CLASS children: name-leaf, [base-ref], method-DEF-recipes...
                    ;; lift emits a PY-BMF-IDENT base-ref as kids[1] for a
                    ;; subclass (`class Dog(Animal):`); a plain class has a DEF
                    ;; (or nothing) there. Detect the base-ref by its IDENT
                    ;; category, env-resolve it to the actual base class record
                    ;; (a cell-ref, not a slug), and thread it onto the subclass
                    ;; as "__base__" so dispatch and super walk the chain.
                    (let cname (node_value (head kids)))
                    (if (and (gt (len kids) 1)
                             (node_eq (node_category (nth kids 1)) PY-BMF-IDENT))
                        (do
                            (let base-cls (py-eval (nth kids 1) env))
                            (let cls (py-class-build cname (tail (tail kids)) env))
                            (record_set cls "__base__" base-cls)
                            (py-stmt-result cls (py-env-extend env cname cls)))
                        (do
                            (let cls (py-class-build cname (tail kids) env))
                            (py-stmt-result cls (py-env-extend env cname cls)))))
            (if (node_eq cat PY-BMF-ATTR-ASSIGN)
                (do
                    ;; ATTR-ASSIGN children: obj-recipe, attr-leaf, value-recipe.
                    ;; obj.attr = value → record_set on the evaluated object.
                    (let obj (py-eval (nth kids 0) env))
                    (let attr (node_value (nth kids 1)))
                    (let value (py-eval (nth kids 2) env))
                    (record_set obj attr value)
                    (py-stmt-result value env))
            (if (node_eq cat PY-BMF-SUB-ASSIGN)
                (do
                    ;; SUB-ASSIGN children: object-name-leaf, index-recipe,
                    ;; value-recipe (NAME[index] = value). Look the dict up by
                    ;; name, set the (index value) pair, and rebind NAME to the
                    ;; NEW dict — dicts are immutable Form values, so this
                    ;; threads a fresh dict through the env exactly like ASSIGN.
                    (let name (node_value (nth kids 0)))
                    (let dict (py-env-lookup env name))
                    (let idx (py-eval (nth kids 1) env))
                    (let value (py-eval (nth kids 2) env))
                    (let new-dict (py-dict-set dict idx value))
                    (py-stmt-result value (py-env-extend env name new-dict)))
            (if (node_eq cat PY-BMF-RETURN)
                ;; RETURN statement: evaluate the inner expression and tag the
                ;; result as a return so the body-loop / module-loop / loop
                ;; arms short-circuit and yield this value as the function's
                ;; result. (py-eval on the RETURN recipe walks (head kids) —
                ;; the returned expression — to its value.) Env is unchanged;
                ;; a `return` ends the function, so nothing downstream reads it.
                (py-stmt-return (py-eval recipe env) env)
            (if (node_eq cat PY-BMF-IMPORT)
                (do
                    ;; `import math` binds "math" to a module-marker. Noop value.
                    (let modname (node_value (head kids)))
                    (py-stmt-result 0
                        (py-env-extend env modname
                            (list (py-module-tag) modname))))
            (if (node_eq cat PY-BMF-FROM-IMPORT)
                (do
                    ;; `from math import sqrt, pi` binds each member (const now,
                    ;; function as a native-fn marker). Module name is head child.
                    (py-stmt-result 0
                        (py-bind-from-import-loop (tail kids) env)))
            (if (and (node_eq cat PY-BMF-METHOD-CALL)
                     (eq (py-list-accum-stmt? kids env) 1))
                (do
                    ;; List accumulator: `NAME.append(x)` where NAME is bound to
                    ;; a Form list. Python mutates the list in place and returns
                    ;; None; we model the same observable effect by rebinding
                    ;; NAME to the EXTENDED list (old ++ [x]) in env — so the
                    ;; growing list persists across loop iterations exactly like
                    ;; Python's in-place append. The statement value is 0 (None).
                    ;; This routes a LIST receiver away from the METHOD-CALL
                    ;; expression arm's class-method dispatch (record_get
                    ;; "__class__"), which a plain list has no field for.
                    (let name (py-ident-name (head kids)))
                    (let mname (node_value (nth kids 1)))
                    (let oldlist (py-env-lookup env name))
                    (let args (py-eval-args (tail (tail kids)) env))
                    (let newlist (py-list-method-apply oldlist mname args))
                    (py-stmt-result 0 (py-env-extend env name newlist)))
            (if (node_eq cat PY-BMF-PASS)
                ;; No-op statement — `pass`, or a bare type annotation
                ;; (`header: str`) that binds nothing at runtime. Returns 0
                ;; (Python None analogue) and threads env unchanged. The
                ;; expression-position py-eval has no PASS arm (a PASS can only
                ;; arise in statement position), so a bare annotation MUST land
                ;; here, not in the default expression arm below.
                (py-stmt-result 0 env)
                ;; Default: expression statement — eval, env unchanged.
                (py-stmt-result (py-eval recipe env) env)))))))))))))))))))

    ;; py-eval-module-loop drives a statement sequence to its value. It serves
    ;; two roles: the top-level module (last-statement value semantics) AND a
    ;; function body (a PY-BMF-MODULE walked by py-eval's MODULE arm). For the
    ;; function-body role it must honor the return-signal: when a statement
    ;; carries returned=1 (a `return` at body top level, or a `return` inside
    ;; an if/for/while block that propagated up through py-eval-body-loop and
    ;; the loop arms), stop and yield that returned value immediately. With no
    ;; return it preserves last-value semantics, so top-level modules are
    ;; unaffected.
    (defn py-eval-module-loop (statements env last-value)
        (if (nil? statements) last-value
            (do
                (let r (py-eval-statement (head statements) env))
                (if (eq (py-stmt-returned r) 1)
                    (py-stmt-value r)
                    (py-eval-module-loop
                        (tail statements)
                        (py-stmt-env r)
                        (py-stmt-value r))))))

    ;; range() builtin — produces a Form list so `for i in range(...)` (the
    ;; most common substrate loop idiom) walks. Built as a plain Form list,
    ;; the same shape PY-BMF-LIST eval returns, so the FOR arm iterates it
    ;; with no special-casing. Supports range(stop) and range(start, stop);
    ;; step is a later breath.
    (defn py-range-build (i stop acc)
        (if (ge i stop) (reverse acc)
            (py-range-build (add i 1) stop (cons i acc))))
    (defn py-range (args)
        (if (eq (len args) 1)
            (py-range-build 0 (head args) (empty))
            (py-range-build (head args) (head (tail args)) (empty))))

    ;; ---- reducing builtins: sum / min / max / len / abs ----------------
    ;;
    ;; Like range, these are intercepted in the CALL arm before the env
    ;; lookup — they're kernel-level reductions, not user closures. Each
    ;; takes the already-evaluated Form arg-list (py-eval-args result):
    ;;   sum/min/max/len  receive one argument, an iterable Form list
    ;;   abs              receives one scalar
    ;; They lean only on the int natives the MATH arm already uses
    ;; (add/sub/lt/gt) plus list walking (head/tail/nil?/len), so no
    ;; kernel change is needed. String/float arguments are a later breath
    ;; (they need an is_str predicate the kernel doesn't expose yet).

    (defn py-sum-loop (xs acc)
        (if (nil? xs) acc
            (py-sum-loop (tail xs) (add acc (head xs)))))

    (defn py-min-loop (xs best)
        (if (nil? xs) best
            (py-min-loop (tail xs)
                (if (lt (head xs) best) (head xs) best))))

    (defn py-max-loop (xs best)
        (if (nil? xs) best
            (py-max-loop (tail xs)
                (if (gt (head xs) best) (head xs) best))))

    ;; py-builtin — dispatch one builtin by name over the evaluated args.
    ;; sum starts from 0 (Python's sum([]) is 0); min/max seed from the
    ;; first element (Python raises on the empty sequence — that error path
    ;; is a later breath, every demo passes a non-empty list). len reads
    ;; the Form list length. abs negates a negative scalar.
    (defn py-builtin (name args)
        (if (str_eq name "sum") (py-sum-loop (head args) 0)
        (if (str_eq name "min") (py-min-loop (tail (head args)) (head (head args)))
        (if (str_eq name "max") (py-max-loop (tail (head args)) (head (head args)))
        (if (str_eq name "len")
            ;; A py-dict is a sentinel-tagged Form list, so the kernel `len`
            ;; native would miscount it — read its pair count instead. Strings
            ;; and plain lists go straight to the Str/List-aware native.
            (if (py-dict? (head args))
                (len (py-dict-pairs (head args)))
                (len (head args)))
        (if (str_eq name "abs")
            (if (lt (head args) 0) (sub 0 (head args)) (head args))
        (if (str_eq name "round")
            ;; round(x, n) — CPython's round() for floats, EXACTLY, via the
            ;; round_ndigits kernel native (rounds the exact decimal value
            ;; half-to-even at n places). The substrate's round-bearing routes
            ;; (cost/value vectors, grounded metrics, frequency scoring) all
            ;; pass the 2-arg form round(x, 4)/round(x, 2). The 1-arg form
            ;; round(x) returns an int in CPython; here it lowers to
            ;; round_ndigits(x, 0) (a float-valued whole) — a documented
            ;; boundary, unused by the round-bearing routes this unlocks.
            (if (nil? (tail args))
                (round_ndigits (head args) 0)
                (round_ndigits (head args) (head (tail args))))
        (if (str_eq name "str_find")
            ;; str_find(s, needle, from) — the string-MEMBERSHIP primitive
            ;; (`needle in s` ⟺ str_find(s, needle, 0) >= 0). A bare call in a
            ;; transmuted recipe resolves to the kernel's str_find native the same
            ;; way the python-compile path lowers it; intercepting it here keeps
            ;; the bmf interpreter (the third runtime) value-identical to the
            ;; compile path on the text-scoring routes (concept_match_score). The
            ;; native is three-way value-identical for ASCII (string-natives-band.fk).
            (str_find (head args) (head (tail args)) (head (tail (tail args))))
        (if (str_eq name "str_eq")
            ;; str_eq(a, b) — the EXACT string-membership primitive (set-resonance
            ;; `a == b` over tag lists, the equality counterpart to str_find's
            ;; substring test). A bare call in a transmuted recipe resolves to the
            ;; kernel's str_eq native (COMPARE.EQ) the same way the python-compile
            ;; path lowers it; intercepting it here keeps the bmf interpreter (the
            ;; third runtime) value-identical to the compile path on the exact-
            ;; membership routes (tag_match_score). The native is three-way value-
            ;; identical for ASCII (string-natives-band.fk).
            (if (str_eq (head args) (head (tail args))) 1 0)
            (do (trace "py-builtin: unknown" name) (head (empty))))))))))))

    ;; py-builtin? — 1 iff name is one of the reducing builtins above.
    (defn py-builtin? (name)
        (if (str_eq name "sum") 1
        (if (str_eq name "min") 1
        (if (str_eq name "max") 1
        (if (str_eq name "len") 1
        (if (str_eq name "abs") 1
        (if (str_eq name "round") 1
        (if (str_eq name "str_find") 1
        (if (str_eq name "str_eq") 1
            0)))))))))

    (defn py-eval (recipe env)
        (do
            (let cat (node_category recipe))
            (let kids (node_children recipe))
            (if (node_eq cat PY-BMF-INT)
                (node_value (head kids))
            (if (node_eq cat PY-BMF-STRING)
                ;; STRING literal: the trivial-string child's node_value
                ;; *is* the runtime value. Mirrors the INT shape.
                (node_value (head kids))
            (if (node_eq cat PY-BMF-FLOAT)
                ;; FLOAT literal: the trivial-float child's node_value is an
                ;; IEEE-754 f64 Value (the kernel decodes TRIV_FLOAT64 back to
                ;; Value::Float). Mirrors INT/STRING — the leaf carries the
                ;; value, this arm hands it back. Float arithmetic flows through
                ;; the MATH-12 arm (its _plus / sub / mul / div natives promote
                ;; int↔float in the kernel); float comparison flows through
                ;; COMPARE-13 (lt/le/gt/ge/eq are float-aware via as_float).
                (node_value (head kids))
            (if (node_eq cat PY-BMF-IDENT)
                (py-env-lookup env (node_value (head kids)))
            (if (and (eq (node_pkg cat) 1)
                     (and (eq (node_level cat) 2)
                          (eq (node_type cat) 12)))
                ;; CTOR Shape B: RBasic.MATH-12 arm. The Python lift now
                ;; interns + - * / % as MATH-12 nodes (positional children,
                ;; no op-string-leaf) so a hand-built (intern_node MATH-PLUS
                ;; (list 7 3)) and a Python-lifted "7 + 3" share one
                ;; Blueprint NodeID. Dispatch on the cat's inst — 1=plus,
                ;; 2=minus, 3=mul, 4=div, 5=mod — matching form-ontology.json.
                (do
                    (let lhs-val (py-eval (nth kids 0) env))
                    (let rhs-val (py-eval (nth kids 1) env))
                    (let math-inst (node_inst cat))
                    ;; plus routes to the kernel's polymorphic `_plus` native
                    ;; (present in rust/go/ts siblings) so Python's overloaded
                    ;; `+` does numeric add AND string concat from one arm.
                    ;; int+int is identical to `add`; str+str / str+int / float
                    ;; promotion all dispatch inside the native.
                    (if (eq math-inst 1) (_plus lhs-val rhs-val)
                    (if (eq math-inst 2) (sub lhs-val rhs-val)
                    (if (eq math-inst 3) (mul lhs-val rhs-val)
                    (if (eq math-inst 4) (div lhs-val rhs-val)
                    (if (eq math-inst 5) (mod lhs-val rhs-val)
                        (do
                            (trace "py-eval MATH: unknown inst" math-inst)
                            (head (empty)))))))))
            (if (and (eq (node_pkg cat) 1)
                     (and (eq (node_level cat) 2)
                          (eq (node_type cat) 13)))
                ;; CTOR Shape B: RBasic.COMPARE-13 arm. The Python lift now
                ;; interns == != < <= > >= as COMPARE-13 nodes (positional
                ;; children, no op-string-leaf) so a hand-built
                ;; (intern_node COMPARE-LT (list 5 7)) and a Python-lifted
                ;; "5 < 7" share one Blueprint NodeID. Dispatch on the cat's
                ;; inst — 1=eq, 2=ne, 3=lt, 4=le, 5=gt, 6=ge — matching
                ;; form-ontology.json. Python convention: 1 for true, 0 for
                ;; false (mirroring py-compare-apply, which is the OLD
                ;; PY-BMF-COMPARE arm and still serves any unrecognised
                ;; compare op the lift falls back to).
                (do
                    (let lhs-val (py-eval (nth kids 0) env))
                    (let rhs-val (py-eval (nth kids 1) env))
                    (let cmp-inst (node_inst cat))
                    (if (eq cmp-inst 1) (if (eq lhs-val rhs-val) 1 0)
                    (if (eq cmp-inst 2) (if (eq lhs-val rhs-val) 0 1)
                    (if (eq cmp-inst 3) (if (lt lhs-val rhs-val) 1 0)
                    (if (eq cmp-inst 4) (if (le lhs-val rhs-val) 1 0)
                    (if (eq cmp-inst 5) (if (gt lhs-val rhs-val) 1 0)
                    (if (eq cmp-inst 6) (if (ge lhs-val rhs-val) 1 0)
                        (do
                            (trace "py-eval COMPARE: unknown inst" cmp-inst)
                            (head (empty))))))))))
            (if (node_eq cat PY-BMF-BINOP)
                (do
                    (let left  (py-eval (nth kids 0) env))
                    (let op    (node_value (nth kids 1)))
                    (let right (py-eval (nth kids 2) env))
                    (py-binop-apply op left right))
            (if (node_eq cat PY-BMF-COMPARE)
                (do
                    (let left  (py-eval (nth kids 0) env))
                    (let op    (node_value (nth kids 1)))
                    (let right (py-eval (nth kids 2) env))
                    (py-compare-apply op left right))
            (if (node_eq cat PY-BMF-RETURN)
                (py-eval (head kids) env)
            (if (node_eq cat PY-BMF-IF)
                (do
                    ;; IF children, per pybmf-emit-if in python-bmf.fk:
                    ;; condition-recipe, then-recipe, else-recipe.
                    (let cond (py-eval (nth kids 0) env))
                    (if (eq cond 0)
                        (py-eval (nth kids 2) env)
                        (py-eval (nth kids 1) env)))
            (if (node_eq cat PY-BMF-CALL)
                (do
                    ;; CALL children: callee-name-leaf, arg-recipes...
                    ;; The captured env is extended with (self-name →
                    ;; closure) so the body's recursive references find
                    ;; the function itself. Mutual recursion is a later
                    ;; breath — this carries single-function self-ref.
                    (let callee-name (node_value (head kids)))
                    (let arg-values (py-eval-args (tail kids) env))
                    ;; range() is a builtin, not a closure — intercept before
                    ;; the env lookup and return its Form list directly.
                    (if (str_eq callee-name "range")
                        (py-range arg-values)
                    ;; sum/min/max/len/abs are reducing builtins — same
                    ;; intercept-before-lookup shape as range.
                    (if (eq (py-builtin? callee-name) 1)
                        (py-builtin callee-name arg-values)
                    ;; zero-arg super() — hand back the proxy py-call-method
                    ;; bound into this method's env under "super". The proxy
                    ;; carries (self, start-class); the METHOD-CALL arm uses it
                    ;; to resolve super().M() from the base chain.
                    (if (str_eq callee-name "super")
                        (py-env-lookup env "super")
                        (do
                            (let callee (py-env-lookup env callee-name))
                            ;; A from-imported native (`from math import sqrt`)
                            ;; binds callee to a native-fn marker — dispatch to
                            ;; the kernel native. Else a class → construct an
                            ;; instance; else a normal function closure.
                            (if (py-native-fn? callee)
                                (py-math-resolve (py-native-fn-member callee) arg-values)
                            (if (py-class? callee)
                                (py-instantiate callee arg-values)
                                (do
                                    (let captured-with-self
                                        (py-env-extend (py-closure-env callee)
                                                       (py-closure-name callee)
                                                       callee))
                                    (let call-env (py-bind-params
                                                    (py-closure-params callee)
                                                    arg-values
                                                    captured-with-self))
                                    (py-eval (py-closure-body callee) call-env)))))))))
            (if (node_eq cat PY-BMF-ATTR)
                (do
                    ;; ATTR children: obj-recipe, attr-leaf. When obj is an
                    ;; imported module, the attr is a module member (math.pi →
                    ;; kernel native); else obj.attr is a record field.
                    (let obj (py-eval (nth kids 0) env))
                    (if (py-module? obj)
                        (py-math-resolve (node_value (nth kids 1)) (empty))
                        (record_get obj (node_value (nth kids 1)))))
            (if (node_eq cat PY-BMF-METHOD-CALL)
                (do
                    ;; METHOD-CALL children: obj-recipe, method-name-leaf,
                    ;; arg-recipes... When obj is an imported module, the call is
                    ;; a module member (math.sqrt(2.25) → kernel native); else
                    ;; resolve the method on the instance's class with self=obj.
                    (let obj (py-eval (nth kids 0) env))
                    (let mname (node_value (nth kids 1)))
                    (let arg-values (py-eval-args (tail (tail kids)) env))
                    (if (py-module? obj)
                        (py-math-resolve mname arg-values)
                    ;; super().M(args): obj is a super-proxy. Resolve M from the
                    ;; proxy's start-class (base of the defining class) with the
                    ;; ORIGINAL self — the SAME py-call-method walk, just a
                    ;; different start class. super().__init__(...) chains the
                    ;; base constructor against the already-built instance.
                    (if (py-super? obj)
                        (py-call-method (record_get obj "__start_class__")
                                        (record_get obj "__self__")
                                        mname arg-values)
                        (do
                            (let cls (record_get obj "__class__"))
                            (py-call-method cls obj mname arg-values)))))
            (if (node_eq cat PY-BMF-LIST)
                ;; LIST children: element-recipes. Value is a Form list
                ;; of evaluated elements, in source order.
                (py-eval-args kids env)
            (if (node_eq cat PY-BMF-COMP)
                ;; COMP children: elem-recipe, var-name-leaf, iter-recipe.
                ;; Evaluate iter to a list, map elem over it binding var.
                (py-comp-build (nth kids 0)
                               (node_value (nth kids 1))
                               (py-eval (nth kids 2) env)
                               env (empty))
            (if (node_eq cat PY-BMF-DICT)
                ;; DICT children: (k1 v1 k2 v2 ...) — 2N recipes. Value
                ;; is a sentinel-tagged alist so SUBSCRIPT can pick the
                ;; right lookup path.
                (cons (py-dict-tag) (py-eval-dict-pairs-loop kids env (empty)))
            (if (node_eq cat PY-BMF-SUBSCRIPT)
                (do
                    ;; SUBSCRIPT children: object-recipe, index-recipe.
                    ;; Dict → string-keyed alist lookup. List → nth(idx).
                    ;; Integer-keyed dicts are a later breath; today's
                    ;; band-test exercises the common string-keyed case.
                    (let obj (py-eval (nth kids 0) env))
                    (let idx (py-eval (nth kids 1) env))
                    (if (py-dict? obj)
                        (py-dict-lookup-str-loop (py-dict-pairs obj) idx)
                        (nth obj idx)))
            (if (node_eq cat PY-BMF-LAMBDA)
                ;; LAMBDA children: param-leaves..., body-recipe.
                ;; Builds an anonymous closure with self-name "" so the
                ;; recursive-knot path in CALL does no harm (CALL only
                ;; finds it via env binding from an enclosing ASSIGN).
                (do
                    (let n (len kids))
                    (let body (py-last kids))
                    (let param-leaves (py-take kids (sub n 1)))
                    (let pms (py-collect-params-loop param-leaves (len param-leaves) (empty)))
                    (py-closure "" pms body env))
            (if (node_eq cat PY-BMF-MODULE)
                (py-eval-module-loop kids env 0)
                (do
                    ;; Honest unimplemented arm. The trace names the
                    ;; category number so the next breath knows which
                    ;; arm to add.
                    (trace "py-eval: unimplemented category" cat)
                    (head (empty))))))))))))))))))))))))

    ;; Surface for callers. py-run takes a module recipe and returns its
    ;; value. py-eval and py-eval-statement are exposed so band-tests
    ;; can drive sub-expressions independently when useful.

    (defn py-run (module-recipe)
        (py-eval module-recipe (py-env-empty)))

    ;; --- module-as-library: host a module, then call an export -----------
    ;; A substrate file like kernel.py is NOT a script — it defines functions
    ;; (intern_node, lookup_cell, ...) the rest of the system calls. So the
    ;; Form-native contract for API code is "load the module, then invoke an
    ;; export with args", not "run and take the last value".
    ;;
    ;; py-module-env — evaluate a PY-BMF-MODULE's statements, threading env,
    ;; and return the FINAL env (with all defs/classes bound) instead of the
    ;; last value. The bridge FormNativeStore drives.
    (defn py-module-env-loop (statements env)
        (if (nil? statements) env
            (do
                (let r (py-eval-statement (head statements) env))
                (py-module-env-loop (tail statements) (py-stmt-env r)))))

    (defn py-module-env (module-recipe)
        ;; module-recipe is PY-BMF-MODULE; its children are the statements.
        (py-module-env-loop (node_children module-recipe) (py-env-empty)))

    ;; py-call-export — load a module recipe, look up a top-level function by
    ;; name in its env, and call it with arg-values (a Form list). Mirrors the
    ;; PY-BMF-CALL closure path: bind the self-name for recursion, bind params,
    ;; walk the body. This is "the API calls a substrate op" → "the kernel
    ;; walks the compiled recipe".
    (defn py-call-export (module-recipe fn-name arg-values)
        (do
            (let env (py-module-env module-recipe))
            (let callee (py-env-lookup env fn-name))
            (if (py-class? callee)
                (py-instantiate callee arg-values)
                (do
                    (let captured-with-self
                        (py-env-extend (py-closure-env callee)
                                       (py-closure-name callee)
                                       callee))
                    (let call-env (py-bind-params
                                    (py-closure-params callee)
                                    arg-values
                                    captured-with-self))
                    (py-eval (py-closure-body callee) call-env)))))

    ;; sentinel return so the file evaluates to 0 when loaded as a
    ;; prelude — by convention every form-stdlib file lands on a small
    ;; integer to keep validate.sh's diff cheap.
    0)
