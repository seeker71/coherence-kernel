; live-room-shell.fk — the live-room per-turn pipeline as a Form-shell cell.
;
; The cell carries the orchestration shape that live-room.sh used to hold in Bash:
; loop over capture windows, gate silence with native `test`, route speaker identity
; through voice-diarize.fk's vd-route, pass translation to the local Ollama carrier,
; and append through the shell redirect node (`__append__`). Host tools remain
; passthrough; decisions stay in Form.
;
; preludes: form-stdlib/core.fk form-stdlib/form-ontology-loader.fk form-stdlib/line-grammar.fk form-stdlib/bmf-core.fk form-stdlib/bmf-grammar.fk form-stdlib/grammar-loader.fk form-stdlib/shell-grammar.fk form-stdlib/voice-traits.fk form-stdlib/feature-vector.fk form-stdlib/nearest-shape.fk form-stdlib/voice-diarize.fk form-stdlib/shell-exec.fk form-stdlib/shell-lower.fk

(do
    (defn lr-fsh-source ()
        "for window in live-window ; do record-window $window ; sense-rms $window ; test 2500 -gt 1500 && vd-route 125 2 2 2 3 Voz3 && whisper $window | ollama-translate >> live-room/turns.json ; done")

    (defn lr-cell () (sh-lower "live-room" (lr-fsh-source)))
    (defn lr-plan () (sh-plan (sh-cell-ctor (lr-cell))))
    (defn lr-demo-out () (sh-cell-run (lr-cell)))

    (defn lr-plan-has-name? (steps name)
        (if (nil? steps) false
            (if (str_eq (sh-step-name (head steps)) name) true
                (lr-plan-has-name? (tail steps) name))))

    (defn lr-plan-has-kind-name? (steps kind name)
        (if (nil? steps) false
            (if (and (str_eq (sh-step-kind (head steps)) kind)
                     (str_eq (sh-step-name (head steps)) name))
                true
                (lr-plan-has-kind-name? (tail steps) kind name))))

    (defn lr-redirs-has-append? (redirs)
        (if (nil? redirs) false
            (if (str_eq (head (head redirs)) "__append__") true
                (lr-redirs-has-append? (tail redirs)))))

    (defn lr-plan-has-append? (steps)
        (if (nil? steps) false
            (if (lr-redirs-has-append? (sh-step-redirs (head steps))) true
                (lr-plan-has-append? (tail steps)))))

    0)
