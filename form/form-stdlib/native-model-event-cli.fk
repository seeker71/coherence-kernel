; native-model-event-cli.fk -- stdin membrane for privacy-safe local events.
;
; The POSIX carrier supplies only host observations, one per line.  This cell
; finds the registered model, derives its class/lane and the purpose from the
; event kind, then delegates validation, content addressing, JSON encoding and
; the atomic append to native-model-event-form.fk.  Raw prompt/output text is
; never accepted by this interface: only their SHA-256 identities cross it.
;
; preludes: form-stdlib/core.fk form-stdlib/sha256.fk form-stdlib/native-model-control-plane.fk form-stdlib/native-model-live-loop.fk form-stdlib/native-model-evidence.fk form-stdlib/native-model-event-form.fk

(do
    (defn nmfr-cli-find-model (id rows)
        (if (eq (len rows) 0) (list)
            (if (str_eq id (nmcp-id (head rows))) (head rows)
                (nmfr-cli-find-model id (tail rows)))))

    (defn nmfr-cli-purpose (kind)
        (if (str_eq kind "inference") "production-final"
            (if (str_eq kind "evaluation") "evaluation"
                (if (str_eq kind "integration-probe") "integration-probe"
                    "invalid"))))

    ; stdin lines:
    ; ledger, day, epoch-ms, registered-model-id, kind, observed-call-success,
    ; artifact-before, artifact-after, identity-before, identity-after,
    ; input-sha, output-sha, latency-ms, output-units, lineage-sha-or-empty,
    ; authorization-sha-or-empty. Form derives identity stability, accepted
    ; success, and outcome; the carrier cannot relabel an unstable crossing.
    (let ledger (read_line))
    (let day (str_to_int (read_line)))
    (let epoch (str_to_int (read_line)))
    (let model-id (read_line))
    (let kind (read_line))
    (let observed-success (str_to_int (read_line)))
    (let artifact-before (read_line))
    (let artifact-after (read_line))
    (let identity-before (str_to_int (read_line)))
    (let identity-after (str_to_int (read_line)))
    (let input (read_line))
    (let output (read_line))
    (let latency (str_to_int (read_line)))
    (let units (str_to_int (read_line)))
    (let lineage (read_line))
    (let authorization (read_line))
    (let model-row (nmfr-cli-find-model model-id (nmcp-registry)))
    (let identity-stable
        (if (and (eq identity-before 1) (eq identity-after 1))
            (if (str_eq artifact-before artifact-after) 1 0) 0))
    (let success
        (if (and (eq observed-success 1) (eq identity-stable 1)) 1 0))
    (let outcome (if (eq success 1) "accepted" "failed"))
    (let result
        (if (eq (len model-row) 0)
            (list "native-model-event-append-v1" 0 -1 "")
            (nmfr-append-registered-at ledger model-row day epoch
                (nmcp-class model-row) model-id (nmcp-lane model-row) kind
                (nmfr-cli-purpose kind) outcome success artifact-before input output
                latency units 0 "" "" "" lineage authorization "")))
    (print_str
        (str_concat "append_ok="
        (str_concat (int_to_str (nth result 1))
        (str_concat "\nidentity_stable="
        (str_concat (int_to_str identity-stable)
        (str_concat "\nevent_success="
        (str_concat (int_to_str success)
        (str_concat "\nledger_size="
        (str_concat (int_to_str (nth result 2))
        (str_concat "\nevent_sha256="
        (str_concat (nth result 3) "\n"))))))))))))
