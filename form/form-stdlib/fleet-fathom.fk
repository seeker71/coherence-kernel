; fleet-fathom.fk — the whole fleet's stewardship read in one muster: every
; live loop's lane (name, inbox, kept store, grace budget) fathomed by
; loop-ledger-host.fk into a (name shipped witnessed lag level) row, with
; the astern lanes surfaced — the covenant's surface-on-surprise made a
; value the body can hand its keeper.
;
; Honest floor: the roster is data the caller passes (the mac fleet's real
; lanes live in the probe and the receipt, not hardcoded here); fs_list
; reads at most 16384 entries per listing — the named reader cap, so deep
; kept stores under-read deterministically while the LEVEL stays cap-proof
; (the lag is the inbox depth alone, and inboxes live far below the cap).
;
; Composes: loop-ledger-host.fk (llh-fathom) over a lane roster.
; Proven by: form-stdlib/tests/fleet-fathom-band.fk
; witnessed: 2026-07-16 -> band 63 four-way; live muster of the mac fleet
;            the same evening (audio abreast; vision + face astern)

(do
    (defn ffm-lane (name inbox kept max half)
        (list name inbox kept max half))
    (defn ffm-lane-name  (l) (nth l 0))
    (defn ffm-lane-inbox (l) (nth l 1))
    (defn ffm-lane-kept  (l) (nth l 2))
    (defn ffm-lane-max   (l) (nth l 3))
    (defn ffm-lane-half  (l) (nth l 4))

    ; one lane fathomed: (name shipped witnessed lag level)
    (defn ffm-row (lane)
        (do
            (let f (llh-fathom
                       (ffm-lane-inbox lane)
                       (ffm-lane-kept lane)
                       (list "sense" "distill")
                       (ffm-lane-max lane)
                       (ffm-lane-half lane)))
            (list (ffm-lane-name lane)
                  (nth f 0) (nth f 1) (nth f 2) (nth f 3))))
    (defn ffm-row-name  (r) (nth r 0))
    (defn ffm-row-lag   (r) (nth r 3))
    (defn ffm-row-level (r) (nth r 4))

    (defn ffm-muster (lanes)
        (if (eq (len lanes) 0)
            (empty)
            (cons (ffm-row (head lanes)) (ffm-muster (tail lanes)))))

    ; the lanes whose understanding has fallen astern — the surfacing list
    (defn ffm-astern (rows)
        (if (eq (len rows) 0)
            (empty)
            (if (lt (ffm-row-level (head rows)) 3)
                (cons (head rows) (ffm-astern (tail rows)))
                (ffm-astern (tail rows)))))

    (defn ffm-all-abreast? (rows)
        (if (eq (len (ffm-astern rows)) 0) 1 0))

    0)
