; sampling.fk — token-SAMPLING filters for serving: temperature, softmax, top-k, top-p (nucleus).
;
; preludes: form-stdlib/transformer-numerics.fk
;
; transformer-generate.fk closes the decode loop with tb-argmax — greedy, the single most-likely
; token. Serving needs the rung above greedy: shape the distribution BEFORE the choice. This stone is
; the deterministic half of sampling — the part the recipe owns bit-for-bit. It produces the filtered
; distribution; drawing from it is the RNG's job (one uniform draw against the cumulative), and the RNG
; is not a recipe — so the band proves the FILTERED DISTRIBUTION, which is fully determined by the
; logits and the cutoffs. No randomness here: every value below is a fold the kernels must agree on.
;
; All fp64, float-counted (no int/float mixing), pure list-walk recursion — same discipline as
; transformer-numerics.fk. Reuses tn-max / tn-exp-map / tn-sub-scalar / tn-sum / tn-scale so softmax
; computes the SAME bits as tn-softmax (same reduction order, same Taylor exp). top-k / top-p need a
; descending order and the Form DSL has no sort native, so selection is built as a recipe below
; (repeated-max extraction — O(n²), fine for a vocabulary slice; determinism, not speed, is the point).

; --- temperature: divide every logit by t (t<1 sharpens, t>1 flattens). Pure scale by 1/t. ---
(defn smp-temperature (logits t) (tn-scale logits (div 1.0 t)))

; --- softmax: SAME op order as tn-softmax — subtract max (stability), exp each, normalize by sum. ---
; Kept as its own name so callers read sampling.fk as the one surface; the bits are tn-softmax's.
(defn smp-softmax (logits)
  (tn-scale (tn-exp-map (tn-sub-scalar logits (tn-max logits)))
            (div 1.0 (tn-sum (tn-exp-map (tn-sub-scalar logits (tn-max logits)))))))

; --- selection primitives (no sort native: extract the running maximum, fold the rest) ---
; smp-kth-largest: the value at rank k (0-based) in descending order. Find the max, then recurse on
; the list with that one occurrence removed, k times. Ties: each pass removes one occurrence, so a
; repeated max is consumed rank by rank (k=0 → largest, k=1 → second copy of it if it repeats).
(defn smp-drop-one (xs v)
  (if (eq (len xs) 0) (empty)
      (if (eq (head xs) v) (tail xs)
          (cons (head xs) (smp-drop-one (tail xs) v)))))
(defn smp-kth-largest (xs k)
  (if (eq k 0) (tn-max xs)
      (smp-kth-largest (smp-drop-one xs (tn-max xs)) (sub k 1))))

; --- renormalize: scale a (masked) distribution back to sum 1. Sum is over the kept mass only. ---
(defn smp-renorm (xs) (tn-scale xs (div 1.0 (tn-sum xs))))

; --- top-k mask: keep the k largest probabilities, zero the rest, renormalize. ---
; Threshold = the k-th-largest value (rank k-1). Every prob >= threshold survives; the rest go to 0.
; (Boundary ties at the threshold are kept — matches "keep the k largest" when values repeat there;
;  exactly k survive when the top-k values are distinct, the common serving case.)
(defn smp-topk-keep (xs thr)
  (if (eq (len xs) 0) (empty)
      (cons (if (ge (head xs) thr) (head xs) 0.0) (smp-topk-keep (tail xs) thr))))
(defn smp-topk-mask (probs k)
  (smp-renorm (smp-topk-keep probs (smp-kth-largest probs (sub k 1)))))

; --- top-p (nucleus) mask: in descending-prob order, keep the smallest prefix whose cumulative ---
; --- prob >= p; zero the rest; renormalize. ---
; The cutoff is a VALUE threshold: walk ranks high→low accumulating mass until it reaches p; the
; value at the last rank added is the threshold. Then keep every prob >= that threshold (the same
; value-mask shape as top-k — order-independent, so masking the original positions is exact).
; smp-topp-thr: descend by rank from the running max; stop at the first rank whose cumulative >= p
; and return that rank's value. n = list length, guards the walk from over-running.
(defn smp-topp-thr-acc (xs cum p k n)
  (do
    (let v (smp-kth-largest xs k))
    (let cum2 (add cum v))
    (if (ge cum2 p) v
        (if (ge (add k 1) n) v
            (smp-topp-thr-acc xs cum2 p (add k 1) n)))))
(defn smp-topp-thr (probs p) (smp-topp-thr-acc probs 0.0 p 0 (len probs)))
(defn smp-topp-keep (xs thr)
  (if (eq (len xs) 0) (empty)
      (cons (if (ge (head xs) thr) (head xs) 0.0) (smp-topp-keep (tail xs) thr))))
(defn smp-topp-mask (probs p)
  (smp-renorm (smp-topp-keep probs (smp-topp-thr probs p))))

; --- min-p mask: keep tokens whose prob >= p_min * max_prob; zero the rest; renormalize. ---
; The cutoff is RELATIVE TO THE PEAK (llama.cpp's min_p) — not cumulative (top-p) nor by rank (top-k):
; a flat distribution keeps many tokens, a peaked one keeps few. threshold = p * max(probs); the
; kept-mask is the same value-threshold shape as top-k / top-p (>= thr survives, 0 otherwise), so it
; reuses smp-topk-keep — one value-mask serves all three samplers, no parallel path. p=0 keeps
; everything (identity); p=1 keeps only the peak (collapses to greedy argmax, no parallel path).
(defn smp-minp-mask (probs p)
  (smp-renorm (smp-topk-keep probs (mul p (tn-max probs)))))

; === the DRAW: a filtered distribution → an actual token id. The half sampling.fk above punts. ===
; The header says "the RNG is not a recipe" — that is the one thing here that is NOT true. A COUNTER
; PRNG is pure integer arithmetic with no host entropy: fully deterministic, reproducible bit-for-bit,
; and so four-way provable like every other fold above. MINSTD (Park-Miller) is the canonical
; minimal-standard generator: state' = (16807 * state) mod (2^31 - 1). Its sequence from seed 1 is a
; PUBLISHED reference (16807, 282475249, 1622650073, …) — the band grounds the PRNG against an
; authority OUTSIDE our own recipe, not values we emitted ourselves.
;
; Integer mod via floor-div — q4k-dequant.fk's proven pattern (no bitwise/mod primitive needed):
; state, 16807, and their product are non-negative integers, so div truncates and
; mod = a - (a/n)*n. The product reaches ~3.6e13 < 2^53, so it stays an exact fp64 integer.
(defn smp-imod (a n) (sub a (mul (div a n) n)))
(defn smp-minstd (state) (smp-imod (mul 16807 state) 2147483647))

; u in [0,1): the state as a fraction of the modulus. The ONE float step; everything above is integer.
(defn smp-uniform (state) (div state 2147483647.0))

; inverse-CDF draw: walk the distribution accumulating mass; the first bucket whose CUMULATIVE mass
; exceeds u is the drawn index. probs is a filtered distribution from the masks above (sums to ~1).
; idx threads the position, cum the running mass; the last bucket catches u rounded up to total mass.
(defn smp-cdf-pick (probs u idx cum)
  (if (eq (len probs) 0) (sub idx 1)
      (do
        (let cum2 (add cum (head probs)))
        (if (gt cum2 u) idx
            (smp-cdf-pick (tail probs) u (add idx 1) cum2)))))
(defn smp-sample (probs u) (smp-cdf-pick probs u 0 0.0))

; one draw from a PRNG state: advance the generator, map to u, pick the bucket. Returns the token id.
; A PEAKED distribution (all mass on one index) draws THAT index for every u — so the draw reduces to
; greedy argmax with no parallel path, exactly as temperature→0 collapses sampling to greedy.
(defn smp-draw (probs state) (smp-sample probs (smp-uniform (smp-minstd state))))

; a generation of n draws: thread the PRNG state, collect token ids. Deterministic from the seed —
; same seed, same token sequence, every kernel. This is the sampling analog of greedy-decode's loop.
(defn smp-draw-seq (probs state n)
  (if (eq n 0) (empty)
      (do
        (let st2 (smp-minstd state))
        (cons (smp-sample probs (smp-uniform st2)) (smp-draw-seq probs st2 (sub n 1))))))
