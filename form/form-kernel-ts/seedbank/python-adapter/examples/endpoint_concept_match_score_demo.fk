(do (defn match_count (needles haystack) (do (let hits 0.0) (do (do (defn _for_0 (_remaining hits) (if (eq (len _remaining) 0) hits (do (let needle (head _remaining)) (if (ge (str_find haystack needle 0) 0) (let hits (_plus hits 1.0)) false) (_for_0 (tail _remaining) hits)))) (let hits (_for_0 (_iter needles) hits))) hits))) (defn score (keywords concept_text concept_keywords idea_text name_lower) (do (let forward_hits (match_count keywords concept_text)) (do (let forward_score (div forward_hits (len keywords))) (do (let reverse_score 0.0) (if (gt (len concept_keywords) 0) (do (let reverse_hits (match_count concept_keywords idea_text)) (let reverse_score (div reverse_hits (len concept_keywords))) (do (let name_bonus 0.0) (if (ge (str_find idea_text name_lower 0) 0) (do (let name_bonus 0.3) (do (let raw (_plus (_plus (mul 0.5 forward_score) (mul 0.3 reverse_score)) name_bonus)) (if (gt raw 1.0) (do (let raw 1.0) (round_ndigits raw 4)) (round_ndigits raw 4)))) (do (let raw (_plus (_plus (mul 0.5 forward_score) (mul 0.3 reverse_score)) name_bonus)) (if (gt raw 1.0) (do (let raw 1.0) (round_ndigits raw 4)) (round_ndigits raw 4)))))) (do (let name_bonus 0.0) (if (ge (str_find idea_text name_lower 0) 0) (do (let name_bonus 0.3) (do (let raw (_plus (_plus (mul 0.5 forward_score) (mul 0.3 reverse_score)) name_bonus)) (if (gt raw 1.0) (do (let raw 1.0) (round_ndigits raw 4)) (round_ndigits raw 4)))) (do (let raw (_plus (_plus (mul 0.5 forward_score) (mul 0.3 reverse_score)) name_bonus)) (if (gt raw 1.0) (do (let raw 1.0) (round_ndigits raw 4)) (round_ndigits raw 4)))))))))) (let keywords (list "energy" "flow" "coherence" "xyz")) (let concept_text "energy flows as coherence through the body field") (let concept_keywords (list "energy" "tissue")) (let idea_text "energy flow coherence xyz") (let name_lower "energy flow") (score keywords concept_text concept_keywords idea_text name_lower))
