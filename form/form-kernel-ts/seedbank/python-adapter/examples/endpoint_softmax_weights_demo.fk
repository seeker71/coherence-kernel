(do
  (defn list_max_from (values current)
    (if (eq (len values) 0)
      current
      (list_max_from
        (tail values)
        (if (gt (head values) current) (head values) current))))
  (defn deterministic_weights (scores max_score)
    (if (eq (len scores) 0)
      (list)
      (cons
        (if (eq (head scores) max_score) 1.0 0.0)
        (deterministic_weights (tail scores) max_score))))
  (defn exp_weights (scores max_score temperature)
    (if (eq (len scores) 0)
      (list)
      (cons
        (math_exp (div (sub (head scores) max_score) temperature))
        (exp_weights (tail scores) max_score temperature))))
  (defn sum_floats_from (values total)
    (if (eq (len values) 0)
      total
      (sum_floats_from (tail values) (add total (head values)))))
  (defn sum_floats (values)
    (sum_floats_from values 0.0))
  (defn constant_weights (count value)
    (if (le count 0)
      (list)
      (cons value (constant_weights (sub count 1) value))))
  (defn normalize_weights (values total)
    (if (eq (len values) 0)
      (list)
      (cons (div (head values) total)
            (normalize_weights (tail values) total))))
  (defn softmax_weights (scores temperature)
    (if (eq (len scores) 0)
      (list)
      (do
        (let max_score (list_max_from (tail scores) (head scores)))
        (if (le temperature 0.0)
          (deterministic_weights scores max_score)
          (do
            (let exps (exp_weights scores max_score temperature))
            (let total (sum_floats exps))
            (if (eq total 0.0)
              (constant_weights (len scores) (div 1.0 (len scores)))
              (normalize_weights exps total)))))))
  (let scores (list 1.0 2.0 3.0))
  (let temperature 1.0)
  (softmax_weights scores temperature))
