(do (defn marginal_from_idea (idea) (do (let pv (_get idea "potential_value")) (do (let av (_get idea "actual_value")) (do (let conf (_get idea "confidence")) (do (let ec (_get idea "estimated_cost")) (do (let ac (_get idea "actual_cost")) (do (let rr (_get idea "resistance_risk")) (do (let value_gap (sub pv av)) (if (lt value_gap 0.0) (do (let value_gap 0.0) (do (let remaining_cost (sub ec ac)) (if (lt remaining_cost 0.1) (do (let remaining_cost 0.1) (round_ndigits (div (mul (mul value_gap conf) conf) (_plus remaining_cost (mul rr 0.5))) 6)) (round_ndigits (div (mul (mul value_gap conf) conf) (_plus remaining_cost (mul rr 0.5))) 6)))) (do (let remaining_cost (sub ec ac)) (if (lt remaining_cost 0.1) (do (let remaining_cost 0.1) (round_ndigits (div (mul (mul value_gap conf) conf) (_plus remaining_cost (mul rr 0.5))) 6)) (round_ndigits (div (mul (mul value_gap conf) conf) (_plus remaining_cost (mul rr 0.5))) 6)))))))))))) (let idea (_dict_new "potential_value" 8.0 "actual_value" 3.0 "confidence" 0.8 "estimated_cost" 4.0 "actual_cost" 1.0 "resistance_risk" 2.0)) (marginal_from_idea idea))
