(do (defn sum_ints (counts) (do (let total 0) (do (let i 0) (do (let n (len counts)) (do (do (defn _while_0 (total i) (if (lt i n) (do (do (let total (_plus total (_get counts i))) (let i (_plus i 1))) (_while_0 total i)) (list total i))) (let _while_1_result (_while_0 total i)) (let total (nth _while_1_result 0)) (let i (nth _while_1_result 1))) total))))) (defn sum_sq_proportions (counts total_f) (do (let acc 0.0) (do (let p 0.0) (do (let i 0) (do (let n (len counts)) (do (do (defn _while_1 (p acc i) (if (lt i n) (do (do (let p (div (_get counts i) total_f)) (let acc (_plus acc (mul p p))) (let i (_plus i 1))) (_while_1 p acc i)) (list p acc i))) (let _while_2_result (_while_1 p acc i)) (let p (nth _while_2_result 0)) (let acc (nth _while_2_result 1)) (let i (nth _while_2_result 2))) acc)))))) (defn simpson_diversity (counts) (do (let total (sum_ints counts)) (if (le total 0) 0.0 (do (let total_f (_plus total 0.0)) (sub 1.0 (sum_sq_proportions counts total_f)))))) (let counts (list 2 1 1)) (simpson_diversity counts))
