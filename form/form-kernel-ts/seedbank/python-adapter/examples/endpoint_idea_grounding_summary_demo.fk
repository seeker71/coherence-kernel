(do (defn spec_count (specs) (do (let n 0) (do (do (defn _for_0 (_remaining n) (if (eq (len _remaining) 0) n (do (let s (head _remaining)) (let n (_plus n 1)) (_for_0 (tail _remaining) n)))) (let n (_for_0 (_iter specs) n))) n))) (defn total_event_count (specs) (do (let total 0) (do (do (defn _for_1 (_remaining total) (if (eq (len _remaining) 0) total (do (let s (head _remaining)) (let total (_plus total (_get s "event_count"))) (_for_1 (tail _remaining) total)))) (let total (_for_1 (_iter specs) total))) total))) (defn specs_with_value_count (specs) (do (let c 0) (do (do (defn _for_2 (_remaining c) (if (eq (len _remaining) 0) c (do (let s (head _remaining)) (if (gt (_get s "actual_value") 0) (let c (_plus c 1)) false) (_for_2 (tail _remaining) c)))) (let c (_for_2 (_iter specs) c))) c))) (defn max_event_count (specs) (do (let mx 0) (do (do (defn _for_3 (_remaining mx) (if (eq (len _remaining) 0) mx (do (let s (head _remaining)) (if (gt (_get s "event_count") mx) (let mx (_get s "event_count")) false) (_for_3 (tail _remaining) mx)))) (let mx (_for_3 (_iter specs) mx))) mx))) (defn grounding_summary (specs) (list (spec_count specs) (total_event_count specs) (specs_with_value_count specs) (max_event_count specs))) (let specs (list (_dict_new "event_count" 3 "actual_value" 1.5) (_dict_new "event_count" 0 "actual_value" 0.0) (_dict_new "event_count" 7 "actual_value" 2.25))) (grounding_summary specs))
