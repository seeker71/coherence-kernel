(do (defn entropy (p_gas p_water p_ice) (do (let acc 0.0) (if (gt p_gas 0.0) (do (let acc (_plus acc (mul p_gas (math_log p_gas)))) (if (gt p_water 0.0) (do (let acc (_plus acc (mul p_water (math_log p_water)))) (if (gt p_ice 0.0) (do (let acc (_plus acc (mul p_ice (math_log p_ice)))) (mul (sub 0 1.0) acc)) (mul (sub 0 1.0) acc))) (if (gt p_ice 0.0) (do (let acc (_plus acc (mul p_ice (math_log p_ice)))) (mul (sub 0 1.0) acc)) (mul (sub 0 1.0) acc)))) (if (gt p_water 0.0) (do (let acc (_plus acc (mul p_water (math_log p_water)))) (if (gt p_ice 0.0) (do (let acc (_plus acc (mul p_ice (math_log p_ice)))) (mul (sub 0 1.0) acc)) (mul (sub 0 1.0) acc))) (if (gt p_ice 0.0) (do (let acc (_plus acc (mul p_ice (math_log p_ice)))) (mul (sub 0 1.0) acc)) (mul (sub 0 1.0) acc)))))) (defn breath_balance (gas water ice) (do (let total (_plus (_plus gas water) ice)) (if (le total 0) 0.0 (do (let total_f (_plus total 0.0)) (do (let p_gas (div gas total_f)) (do (let p_water (div water total_f)) (do (let p_ice (div ice total_f)) (do (let h (entropy p_gas p_water p_ice)) (do (let h_max (math_log 3.0)) (div h h_max)))))))))) (let gas 1) (let water 1) (let ice 1) (breath_balance gas water ice))
