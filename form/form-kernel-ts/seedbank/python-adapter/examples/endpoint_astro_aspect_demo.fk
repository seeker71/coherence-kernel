(do (defn absv (x) (if (lt x 0) (sub 0 x) x)) (defn sep (a b) (do (let d (absv (sub a b))) (if (gt d 180) (sub 360 d) d))) (defn within (d target orb) (lt (absv (sub d target)) (add orb 1))) (defn aspect (a b orb) (do (let d (sep a b)) (if (within d 0 orb) 0 (if (within d 60 orb) 1 (if (within d 90 orb) 2 (if (within d 120 orb) 3 (if (within d 180 orb) 4 -1))))))) (let a 13) (let b 133) (let orb 6) (aspect a b orb))
