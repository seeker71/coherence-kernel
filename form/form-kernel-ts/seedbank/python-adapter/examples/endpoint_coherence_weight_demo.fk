(do (defn weighted_score (value position) (if (eq position 0) (mul value 100) (if (eq position 1) (mul value 50) (if (eq position 2) (mul value 25) (mul value 10))))) (defn coherence_score (values threshold) (do (let total 0) (do (let position 0) (do (do (defn _for_0 (_remaining total position) (if (eq (len _remaining) 0) (list total position) (do (let v (head _remaining)) (if (ge v threshold) (do (let total (_plus total (weighted_score v position))) (let position (_plus position 1))) false) (_for_0 (tail _remaining) total position)))) (let _for_1_result (_for_0 (_iter values) total position)) (let total (nth _for_1_result 0)) (let position (nth _for_1_result 1))) total)))) (defn count_above (values threshold) (do (let n 0) (do (do (defn _for_1 (_remaining n) (if (eq (len _remaining) 0) n (do (let v (head _remaining)) (if (ge v threshold) (let n (_plus n 1)) false) (_for_1 (tail _remaining) n)))) (let n (_for_1 (_iter values) n))) n))) (defn coherence_weight (values threshold) (do (let above (count_above values threshold)) (do (let coherence (coherence_score values threshold)) (_plus (mul above 100) coherence)))) (let values (list 72 38 91 55 28 67 84 45 95 12)) (let threshold 50) (coherence_weight values threshold))
