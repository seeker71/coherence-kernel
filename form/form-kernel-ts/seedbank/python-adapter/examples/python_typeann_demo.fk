(do (defn add (a b) (_plus a b)) (defn scale (value factor) (mul value factor)) (defn sum_list (xs) (do (let total 0) (do (do (defn _for_0 (_remaining total) (if (eq (len _remaining) 0) total (do (let x (head _remaining)) (let total (_plus total x)) (_for_0 (tail _remaining) total)))) (let total (_for_0 xs total))) total))) (defn sum_grid (grid) (do (let out 0) (do (do (defn _for_1 (_remaining out) (if (eq (len _remaining) 0) out (do (let row (head _remaining)) (do (defn _for_2 (_remaining out) (if (eq (len _remaining) 0) out (do (let v (head _remaining)) (let out (_plus out v)) (_for_2 (tail _remaining) out)))) (let out (_for_2 row out))) (_for_1 (tail _remaining) out)))) (let out (_for_1 grid out))) out))) false (let base 10) (let multiplier 2.5) (let sum_a (add 3 4)) (let sum_b (scale 2.0 0.5)) (let sum_c (sum_list (list 1 2 3 4))) (let sum_d (sum_grid (list (list 1 2) (list 3 4) (list 5 6)))) (let weighted (mul base multiplier)) (_plus (_plus (_plus (_plus sum_a sum_b) sum_c) sum_d) weighted))
