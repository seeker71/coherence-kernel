(do (defn contains_exact (needle haystack) (do (let found false) (do (do (defn _for_0 (_remaining found) (if (eq (len _remaining) 0) found (do (let item (head _remaining)) (if (str_eq item needle) (let found true) false) (_for_0 (tail _remaining) found)))) (let found (_for_0 (_iter haystack) found))) found))) (defn match_count (needles haystack) (do (let hits 0.0) (do (do (defn _for_1 (_remaining hits) (if (eq (len _remaining) 0) hits (do (let needle (head _remaining)) (if (contains_exact needle haystack) (let hits (_plus hits 1.0)) false) (_for_1 (tail _remaining) hits)))) (let hits (_for_1 (_iter needles) hits))) hits))) (defn score (contributor_tags idea_tags) (if (eq (len contributor_tags) 0) 0.5 (if (eq (len idea_tags) 0) 0.5 (do (let matched (match_count contributor_tags idea_tags)) (do (let ratio (div matched (len contributor_tags))) (if (gt ratio 1.0) (do (let ratio 1.0) (if (lt ratio 0.0) (do (let ratio 0.0) ratio) ratio)) (if (lt ratio 0.0) (do (let ratio 0.0) ratio) ratio))))))) (let contributor_tags (list "energy" "flow" "coherence" "field")) (let idea_tags (list "energy" "flow")) (score contributor_tags idea_tags))
