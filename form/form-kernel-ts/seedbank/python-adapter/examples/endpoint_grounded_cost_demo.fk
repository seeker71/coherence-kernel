(do (defn min2 (a b) (if (gt a b) b a)) (defn max2 (a b) (if (gt a b) a b)) (defn sum_actual_cost (specs) (do (let total 0.0) (do (do (defn _for_0 (_remaining total) (if (eq (len _remaining) 0) total (do (let s (head _remaining)) (let total (_plus total (_get s "actual_cost"))) (_for_0 (tail _remaining) total)))) (let total (_for_0 (_iter specs) total))) total))) (defn sum_estimated_cost (specs) (do (let total 0.0) (do (do (defn _for_1 (_remaining total) (if (eq (len _remaining) 0) total (do (let s (head _remaining)) (let total (_plus total (_get s "estimated_cost"))) (_for_1 (tail _remaining) total)))) (let total (_for_1 (_iter specs) total))) total))) (defn commit_cost (c) (do (let base (_plus (_plus 0.1 (mul (_get c "change_files") 0.15)) (mul (_get c "lines_added") 0.002))) (max2 0.05 (min2 10.0 base)))) (defn sum_commit_cost (commits) (do (let total 0.0) (do (do (defn _for_2 (_remaining total) (if (eq (len _remaining) 0) total (do (let c (head _remaining)) (let total (_plus total (commit_cost c))) (_for_2 (tail _remaining) total)))) (let total (_for_2 (_iter commits) total))) total))) (defn sum_lineage_cost (links) (do (let total 0.0) (do (do (defn _for_3 (_remaining total) (if (eq (len _remaining) 0) total (do (let l (head _remaining)) (let total (_plus total (_get l "estimated_cost"))) (_for_3 (tail _remaining) total)))) (let total (_for_3 (_iter links) total))) total))) (defn grounded_cost (specs commits links runtime_cost) (do (let spec_actual_cost_sum (sum_actual_cost specs)) (do (let spec_estimated_cost_sum (sum_estimated_cost specs)) (do (let commit_cost_sum (sum_commit_cost commits)) (do (let lineage_estimated_cost (sum_lineage_cost links)) (do (let computed_actual_cost (_plus (_plus spec_actual_cost_sum runtime_cost) commit_cost_sum)) (list spec_actual_cost_sum spec_estimated_cost_sum runtime_cost commit_cost_sum lineage_estimated_cost computed_actual_cost))))))) (let specs (list (_dict_new "actual_cost" 3.5 "estimated_cost" 4.25) (_dict_new "actual_cost" 1.25 "estimated_cost" 2.5))) (let commits (list (_dict_new "change_files" 3 "lines_added" 100))) (let links (list (_dict_new "estimated_cost" 5.25) (_dict_new "estimated_cost" 1.5))) (let runtime_cost 2.25) (grounded_cost specs commits links runtime_cost))
