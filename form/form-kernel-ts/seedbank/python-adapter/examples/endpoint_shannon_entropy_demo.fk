(do (defn shannon_entropy_normalized (gas water ice) (do (let total (_plus (_plus gas water) ice)) (if (eq total 0) 0.0 (do (let max_entropy (math_log 3)) (do (let total_f (_plus total 0.0)) (do (let entropy 0.0) (if (gt gas 0) (do (let p (div gas total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt water 0) (do (let p (div water total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt ice 0) (do (let p (div ice total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0)) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0))) (if (gt ice 0) (do (let p (div ice total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0)) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0)))) (if (gt water 0) (do (let p (div water total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt ice 0) (do (let p (div ice total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0)) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0))) (if (gt ice 0) (do (let p (div ice total_f)) (let entropy (sub entropy (mul p (math_log p)))) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0)) (if (gt max_entropy 0) (round_ndigits (div entropy max_entropy) 4) 0.0)))))))))) (let gas 1) (let water 1) (let ice 1) (shannon_entropy_normalized gas water ice))
