; go-jit.fk — Form recipe → host-native Go via `go build -buildmode=plugin`.
;
; The shape (Urs):
;   "we want just primitives in the kernel. and form native code to
;    host native assembly using JIT to have generic cross kernel
;    functions with host native performance for channel protocol and
;    other core support"
;
; This walk lands the Go side of the JIT lattice:
;
;   • TypeScript : compileNode emits a JS function; V8 JITs to native
;                  on first call. compile-status returns 1.
;   • Go         : emits Go source, runs `go build -buildmode=plugin`
;                  to produce a .so, loads via plugin.Open, dispatches
;                  through plugin.Lookup("Fn") on subsequent FNCALLs.
;                  compile-status returns 1.
;   • Rust       : returns 0 today; cranelift integration is the next
;                  walk (Form-AST → cranelift IR → x86_64/aarch64).
;
; Whichever path each kernel takes, the OUTPUT converges: the recipe
; is canonical truth and every dispatch path evaluates it. The compile
; status is honest per-kernel divergence — the meaning is universal.

(do
    ;; A recursive recipe in the supported subset (arithmetic + compare
    ;; + if + recursive self-call + int64 params).
    (defn double-and-sum (n)
        (if (eq n 0) 0
            (add (mul n 2) (double-and-sum (sub n 1)))))

    ;; Recipe-walk baseline. Every kernel produces the same number
    ;; through tree-walking.
    (let r1 (double-and-sum 5))
    (print "recipe-walk:" r1)            ; 30 (2+4+6+8+10)

    ;; Compile attempt. TS=1 (V8 JIT), Go=1 (this walk), Rust=0 (next walk).
    ;; We print only "compile-attempted: 1" — that's 1 everywhere because
    ;; the call always succeeds at the API level (returns ≥ 0). The raw
    ;; status diverges and would break sibling-parity.
    (let compiled (jit_compile "double-and-sum"))
    (print "compile-attempted:" (if (ge compiled 0) 1 0))

    ;; Subsequent calls. In TS, dispatch through compiled JS. In Go,
    ;; dispatch through the loaded plugin.so. In Rust, recipe walks.
    ;; Same answer every time — the substrate is the truth.
    (let r2 (double-and-sum 5))
    (print "post-jit-call:" r2)          ; 30

    (let r3 (double-and-sum 10))
    (print "post-jit-10:" r3)            ; 110 (2+4+6+...+20)

    ;; Verdict — same answer regardless of dispatch path.
    (add (if (eq r1 30) 1 0)
         (add (if (eq r2 30) 1 0)
              (if (eq r3 110) 1 0))))
