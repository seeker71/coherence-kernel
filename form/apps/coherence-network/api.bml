    def inventory-flow-connected(conn, idea_id, include_internal_ideas, runtime_window_seconds, list_item_limit) {
        let include_internal_sql = if include_internal_ideas then 1 else 0;
        let summary_rows = pg_query_rows(conn, inventory-flow-summary-sql(), list(idea_id, include_internal_sql, runtime_window_seconds));
        let item_rows = pg_query_rows(conn, inventory-flow-items-sql(), list(idea_id, include_internal_sql, runtime_window_seconds, list_item_limit));
