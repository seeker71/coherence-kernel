    def api_inventory_flow_observe(request) {
        let warm_count = observe-warm-count(kh-query-int-or(request, "warm", 0));
        let warmed = observe-warm-inventory-flow(request, warm_count);
        let cleared = framebuffer-clear();
        let t0 = now_unix_ms();
        let response = api_inventory_flow(request);
        let t1 = now_unix_ms();
        let events = framebuffer-events();
        let event_limit = observe-event-limit(kh-query-int-or(request, "event_limit", 1000));
        let jit_rows = jit-stats();
        inventory-flow-observe-response(response, events, event_limit, jit_rows, warm_count, request, t0, t1);
    }

    def api-feed-personal-sql() = "WITH my_reactions AS (SELECT id FROM reactions WHERE $1 <> '' AND author_id = $1), my_concepts AS (SELECT DISTINCT concept_id FROM concept_voices WHERE $1 <> '' AND author_id = $1), items AS (SELECT 'concept' AS entity_type, concept_id AS entity_id, 'voice' AS kind, concept_id AS title, left(COALESCE(body,''),200) AS snippet, COALESCE(author_name,'') AS actor_name, 'i_voiced' AS reason, created_at FROM concept_voices WHERE (($1 <> '' AND author_id = $1) OR ($1 = '' AND $2 <> '' AND author_name = $2)) UNION ALL SELECT entity_type, entity_id, 'reaction' AS kind, entity_id AS title, left(COALESCE(NULLIF(comment,''), emoji, ''),200) AS snippet, COALESCE(author_name,'') AS actor_name, 'i_reacted' AS reason, created_at FROM reactions WHERE (($1 <> '' AND author_id = $1) OR ($1 = '' AND $2 <> '' AND author_name = $2)) AND COALESCE(comment,'') <> '' UNION ALL SELECT CASE WHEN COALESCE(resolved_as_idea_id,'') <> '' THEN 'idea' ELSE 'proposal' END AS entity_type, CASE WHEN COALESCE(resolved_as_idea_id,'') <> '' THEN resolved_as_idea_id ELSE id END AS entity_id, 'proposal' AS kind, title, left(COALESCE(body,''),200) AS snippet, COALESCE(author_name,'') AS actor_name, CASE WHEN COALESCE(resolved_as_idea_id,'') <> '' THEN 'lifted_from_my_proposal' ELSE 'i_proposed' END AS reason, COALESCE(resolved_at, created_at) AS created_at FROM proposals WHERE (($1 <> '' AND author_id = $1) OR ($1 = '' AND $2 <> '' AND author_name = $2)) UNION ALL SELECT r.entity_type, r.entity_id, 'reply_to_me' AS kind, r.entity_id AS title, left(COALESCE(NULLIF(r.comment,''), r.emoji, ''),200) AS snippet, COALESCE(r.author_name,'') AS actor_name, 'replied_to_me' AS reason, r.created_at FROM reactions r WHERE $1 <> '' AND r.parent_reaction_id IN (SELECT id FROM my_reactions) UNION ALL SELECT r.entity_type, r.entity_id, 'reaction_on_my_voice' AS kind, r.entity_id AS title, left(COALESCE(NULLIF(r.comment,''), r.emoji, ''),200) AS snippet, COALESCE(r.author_name,'') AS actor_name, 'reaction_on_my_voice' AS reason, r.created_at FROM reactions r WHERE $1 <> '' AND r.entity_type = 'concept' AND r.entity_id IN (SELECT concept_id FROM my_concepts) AND COALESCE(r.author_id,'') <> $1) SELECT entity_type, entity_id, kind, title, snippet, actor_name, reason, replace(created_at::text, ' ', 'T') AS created_at FROM items ORDER BY created_at DESC LIMIT $3";
    def api-feed-label-en(reason) = if str_eq(reason, "i_voiced") then "You voiced this" else if str_eq(reason, "i_reacted") then "You reacted here" else if str_eq(reason, "i_proposed") then "You proposed this" else if str_eq(reason, "replied_to_me") then "Someone replied to you" else if str_eq(reason, "reaction_on_my_voice") then "Someone reacted to your voice" else if str_eq(reason, "lifted_from_my_proposal") then "Your proposal became this idea" else "This touched your field";
    def api-feed-label(row, locale) = api-feed-label-en(idea-row("reason", row));
    def api-feed-row-json(row, locale) = json-node-object(list(json-node-pair("entity_type", json-node-string(idea-row("entity_type", row))), json-node-pair("entity_id", json-node-string(idea-row("entity_id", row))), json-node-pair("kind", json-node-string(idea-row("kind", row))), json-node-pair("title", json-node-string(idea-row("title", row))), json-node-pair("snippet", json-node-string(idea-row("snippet", row))), json-node-pair("actor_name", api-json-nullable-string(idea-row("actor_name", row))), json-node-pair("reason", json-node-string(idea-row("reason", row))), json-node-pair("reason_label", json-node-string(api-feed-label(row, locale))), json-node-pair("created_at", api-json-nullable-string(idea-row("created_at", row)))));
    def api-feed-rows-json(rows, locale) = if nil?(rows) then empty else cons(api-feed-row-json(head(rows), locale), api-feed-rows-json(tail(rows), locale));
    def api-feed-personal-connected(conn, contributor_id, author_name, limit, locale) {
        let rows = pg_query_rows(conn, api-feed-personal-sql(), list(contributor_id, author_name, limit));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if query_failed then api-service-unavailable("persistence", query_error) else api-native-ok-json("api_feed_personal", json-node-object(list(json-node-pair("items", json-node-array(api-feed-rows-json(rows, locale))), json-node-pair("count", json-node-int(len(rows))), json-node-pair("locale", json-node-string(locale)), json-node-pair("native_observation", json-node-object(list(json-node-pair("grammar", json-node-string("BML")), json-node-pair("handler", json-node-string("api_feed_personal")), json-node-pair("union_arms", json-node-int(5))))))));
    }
    def api_feed_personal(request) {
        let contributor_id = kh-query-value-or(request, "contributor_id", "");
        let author_name = kh-query-value-or(request, "author_name", "");
        let limit = api-clamp-limit(kh-query-int-or(request, "limit", 40), 200);
        let locale = kh-query-value-or(request, "lang", "en");
        if and(str_eq(contributor_id, ""), str_eq(author_name, "")) then api-native-ok-json("api_feed_personal", json-node-object(list(json-node-pair("items", json-node-array(empty)), json-node-pair("count", json-node-int(0)), json-node-pair("locale", json-node-string(locale))))) else api-feed-personal-ready(contributor_id, author_name, limit, locale);
    }
    def api-feed-personal-ready(contributor_id, author_name, limit, locale) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-feed-personal-connected(conn, contributor_id, author_name, limit, locale);
    }

    def api-household-nullable-number(value) = if str_eq(value, "") then json-node-null() else json-node-float-text(value);
    def api-household-requests-sql() = "SELECT n.id, COALESCE(n.properties->>'kind','other') AS kind, COALESCE(NULLIF(n.properties->>'detail',''), n.description, '') AS detail, COALESCE(NULLIF(n.properties->>'items_json',''), '[]') AS items_json, COALESCE(n.properties->>'location','') AS location, COALESCE(n.properties->>'when_text','') AS when_text, COALESCE(n.properties->>'status','open') AS status, COALESCE(n.properties->>'requester_id','') AS requester_id, COALESCE(n.properties->>'requester_name','') AS requester_name, COALESCE(n.properties->>'acknowledged_by_name','') AS acknowledged_by_name, COALESCE(n.properties->>'completed_by_name','') AS completed_by_name, COALESCE(CASE WHEN COALESCE(n.properties->>'cost_amount','') ~ '^[0-9]+(\\.[0-9]+)?$' THEN (n.properties->>'cost_amount') ELSE '' END, '') AS cost_amount, COALESCE(n.properties->>'cost_currency','IDR') AS cost_currency, COALESCE(n.properties->>'cost_note','') AS cost_note, COALESCE(n.properties->>'cost_status','none') AS cost_status, COALESCE(n.properties->>'paid_by_name','') AS paid_by_name, COALESCE(n.properties->>'created_at', replace(n.created_at::text, ' ', 'T')) AS created_at, COALESCE(n.properties->>'updated_at', n.properties->>'created_at', replace(n.updated_at::text, ' ', 'T')) AS updated_at FROM graph_nodes n WHERE n.type = 'service_request' AND ($1 = '' OR COALESCE(n.properties->>'status','open') = $1) ORDER BY COALESCE(n.properties->>'created_at', replace(n.created_at::text, ' ', 'T')) DESC LIMIT $2";
    def api-household-request-sql() = "SELECT n.id, COALESCE(n.properties->>'kind','other') AS kind, COALESCE(NULLIF(n.properties->>'detail',''), n.description, '') AS detail, COALESCE(NULLIF(n.properties->>'items_json',''), '[]') AS items_json, COALESCE(n.properties->>'location','') AS location, COALESCE(n.properties->>'when_text','') AS when_text, COALESCE(n.properties->>'status','open') AS status, COALESCE(n.properties->>'requester_id','') AS requester_id, COALESCE(n.properties->>'requester_name','') AS requester_name, COALESCE(n.properties->>'acknowledged_by_name','') AS acknowledged_by_name, COALESCE(n.properties->>'completed_by_name','') AS completed_by_name, COALESCE(CASE WHEN COALESCE(n.properties->>'cost_amount','') ~ '^[0-9]+(\\.[0-9]+)?$' THEN (n.properties->>'cost_amount') ELSE '' END, '') AS cost_amount, COALESCE(n.properties->>'cost_currency','IDR') AS cost_currency, COALESCE(n.properties->>'cost_note','') AS cost_note, COALESCE(n.properties->>'cost_status','none') AS cost_status, COALESCE(n.properties->>'paid_by_name','') AS paid_by_name, COALESCE(n.properties->>'created_at', replace(n.created_at::text, ' ', 'T')) AS created_at, COALESCE(n.properties->>'updated_at', n.properties->>'created_at', replace(n.updated_at::text, ' ', 'T')) AS updated_at FROM graph_nodes n WHERE n.type = 'service_request' AND n.id = $1 LIMIT 1";
    def api-household-request-json(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("kind", json-node-string(idea-row("kind", row))), json-node-pair("detail", json-node-string(idea-row("detail", row))), json-node-pair("items", parse-json("household.items", idea-row("items_json", row))), json-node-pair("location", api-json-nullable-string(idea-row("location", row))), json-node-pair("when_text", api-json-nullable-string(idea-row("when_text", row))), json-node-pair("status", json-node-string(idea-row("status", row))), json-node-pair("requester_id", json-node-string(idea-row("requester_id", row))), json-node-pair("requester_name", json-node-string(idea-row("requester_name", row))), json-node-pair("acknowledged_by_name", api-json-nullable-string(idea-row("acknowledged_by_name", row))), json-node-pair("completed_by_name", api-json-nullable-string(idea-row("completed_by_name", row))), json-node-pair("cost_amount", api-household-nullable-number(idea-row("cost_amount", row))), json-node-pair("cost_currency", json-node-string(idea-row("cost_currency", row))), json-node-pair("cost_note", api-json-nullable-string(idea-row("cost_note", row))), json-node-pair("cost_status", json-node-string(idea-row("cost_status", row))), json-node-pair("paid_by_name", api-json-nullable-string(idea-row("paid_by_name", row))), json-node-pair("created_at", json-node-string(idea-row("created_at", row))), json-node-pair("updated_at", json-node-string(idea-row("updated_at", row)))));
    def api-household-request-rows-json(rows) = if nil?(rows) then empty else cons(api-household-request-json(head(rows)), api-household-request-rows-json(tail(rows)));
    def api-household-requests-connected(conn, request) {
        let status = kh-query-value-or(request, "status", "");
        let limit = api-clamp-limit(kh-query-int-or(request, "limit", 200), 500);
        let rows = pg_query_rows(conn, api-household-requests-sql(), list(status, limit));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if query_failed then api-service-unavailable("persistence", query_error) else api-native-ok-json("api_household_requests", json-node-array(api-household-request-rows-json(rows)));
    }
    def api_household_requests(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-household-requests-connected(conn, request);
    }
    def api-household-request-id(request) {
        let path = kh-request-path(request);
        if le(str_len(path), 24) then "" else substring(path, 24, str_len(path));
    }
    def api-household-request-detail-connected(conn, request_id) {
        let rows = pg_query_rows(conn, api-household-request-sql(), list(request_id));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if query_failed then api-service-unavailable("persistence", query_error) else if nil?(rows) then api-not-found(str_concat("request not found: ", request_id)) else api-native-ok-json("api_household_request_detail", api-household-request-json(head(rows)));
    }
    def api_household_request_detail(request) {
        let request_id = api-household-request-id(request);
        let conn = pg_connect(config_database_url());
        if str_eq(request_id, "") then api-error-json(422, "request_id is required") else if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-household-request-detail-connected(conn, request_id);
    }

    def api-household-members-sql() = "SELECT n.id, n.name, COALESCE(n.properties->>'role','member') AS role, COALESCE((n.properties->>'write_access')::boolean,false) AS write_access, COALESCE(n.properties->>'status','active') AS status, COALESCE(n.properties->>'invited_by_name','') AS invited_by_name, COALESCE(n.properties->>'created_at', replace(n.created_at::text, ' ', 'T')) AS created_at FROM graph_nodes n WHERE n.type = 'household_member' AND ($1 = '' OR COALESCE(n.properties->>'role','member') = $1) ORDER BY COALESCE(n.properties->>'created_at', replace(n.created_at::text, ' ', 'T')) ASC LIMIT 1000";
