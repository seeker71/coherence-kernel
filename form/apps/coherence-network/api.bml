    def api-query-failed?() = gt(str_len(pg_last_error()), 0);
    def api-workspaces-sql() = "SELECT id, name, description, CASE WHEN jsonb_typeof(properties->'pillars') = 'array' THEN (properties->'pillars')::text WHEN COALESCE(properties->>'pillars','') = '' THEN '[]' ELSE to_jsonb(string_to_array(properties->>'pillars', ','))::text END AS pillars_json, COALESCE(properties->>'owner_contributor_id','') AS owner_contributor_id, COALESCE(NULLIF(properties->>'visibility',''), 'public') AS visibility, COALESCE(properties->>'bundle_path','') AS bundle_path, COALESCE(properties->>'repo_url','') AS repo_url, COALESCE(properties->>'default_provider','') AS default_provider, CASE WHEN jsonb_typeof(properties->'provider_config') = 'object' THEN (properties->'provider_config')::text ELSE 'null' END AS provider_config_json, replace(created_at::text, ' ', 'T') AS created_at, replace(updated_at::text, ' ', 'T') AS updated_at FROM graph_nodes WHERE type = 'workspace' ORDER BY updated_at DESC LIMIT 500";
    def api-workspace-row-json(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("name", json-node-string(idea-row("name", row))), json-node-pair("description", json-node-string(idea-row("description", row))), json-node-pair("pillars", parse-json("workspace.pillars", idea-row("pillars_json", row))), json-node-pair("owner_contributor_id", api-json-nullable-string(idea-row("owner_contributor_id", row))), json-node-pair("visibility", json-node-string(idea-row("visibility", row))), json-node-pair("bundle_path", api-json-nullable-string(idea-row("bundle_path", row))), json-node-pair("repo_url", api-json-nullable-string(idea-row("repo_url", row))), json-node-pair("default_provider", api-json-nullable-string(idea-row("default_provider", row))), json-node-pair("provider_config", parse-json("workspace.provider_config", idea-row("provider_config_json", row))), json-node-pair("created_at", json-node-string(idea-row("created_at", row))), json-node-pair("updated_at", json-node-string(idea-row("updated_at", row)))));
    def api-workspace-rows-json(rows) = if nil?(rows) then empty else cons(api-workspace-row-json(head(rows)), api-workspace-rows-json(tail(rows)));
    def api-workspaces-connected(conn) {
        let rows = pg_query_rows(conn, api-workspaces-sql(), list());
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
