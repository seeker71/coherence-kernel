    def inventory-flow-item-json(row) = json-node-object(list(json-node-pair("idea_id", json-node-string(idea-row("idea_id", row))), json-node-pair("idea_name", json-node-string(idea-row("idea_name", row))), json-node-pair("idea_classification", json-node-object(list(json-node-pair("internal", json-node-bool(api-json-db-bool(idea-row("is_internal", row)))), json-node-pair("actionable", json-node-bool(not(api-json-db-bool(idea-row("is_internal", row)))))))), json-node-pair("spec", inventory-flow-spec-json(row)), json-node-pair("process", inventory-flow-process-json(row)), json-node-pair("implementation", inventory-flow-implementation-json(row)), json-node-pair("validation", inventory-flow-validation-json(row)), json-node-pair("contributors", inventory-flow-contributors-json(row)), json-node-pair("contributions", inventory-flow-contributions-json(row)), json-node-pair("assets", inventory-flow-assets-json(row)), json-node-pair("chain", inventory-flow-chain-json(row)), json-node-pair("interdependencies", inventory-flow-interdependencies-json(row)), json-node-pair("idea_signals", inventory-flow-signals-json(row))));
