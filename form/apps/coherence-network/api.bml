    def api_household_members(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-household-members-connected(conn, request);
    }
    def api-household-events-empty-json() = json-node-array(empty);
    def api-household-events-response() = kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", "api_household_events"), kh-header("X-Form-Python-Authority", "false"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(api-household-events-empty-json()));
    def api-household-events-valid-limit?(limit) = and(ge(limit, 1), le(limit, 200));
    def api_household_events(request) {
        let limit = kh-query-int-or(request, "limit", 50);
        if not(api-household-events-valid-limit?(limit)) then api-error-status-json(422, "limit must be between 1 and 200") else api-household-events-response();
    }

    def api-kernel-status-json() = json-node-object(list(json-node-pair("active", json-node-string("native-kernel")), json-node-pair("inline_available", json-node-bool(false)), json-node-pair("binary_available", json-node-bool(true)), json-node-pair("available", json-node-bool(true)), json-node-pair("binary_path", json-node-string("form-kernel-rust")), json-node-pair("router", json-node-string("native-kernel")), json-node-pair("python_authority", json-node-bool(false)), json-node-pair("runtime", json-node-string(kernel_runtime_name()))));
    def api_kernel_status(request) = kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", "api_kernel_status"), kh-header("X-Form-Python-Authority", "false"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(api-kernel-status-json()));

    def api-attention-int(request, key) = kh-query-int-or(request, key, 0);
    def api-attention-str(request, key) = kh-query-value-or(request, key, "");
    def api-attention-clamp01(value) = if lt(value, 0.0) then 0.0 else if gt(value, 1.0) then 1.0 else value;
    def api-attention-ratio(numerator, denominator) = if gt(denominator, 0) then api-attention-clamp01(div(add(numerator, 0.0), denominator)) else 0.0;
    def api-attention-measurements-json(request) = json-node-object(list(json-node-pair("native_route_count", json-node-int(api-attention-int(request, "__router_native_route_count__"))), json-node-pair("observed_native_route_count", json-node-int(api-attention-int(request, "__router_observed_native_route_count__"))), json-node-pair("observed_path_count", json-node-int(api-attention-int(request, "__router_observed_path_count__"))), json-node-pair("observed_fanout_path_count", json-node-int(api-attention-int(request, "__router_observed_fanout_path_count__"))), json-node-pair("total_requests", json-node-int(api-attention-int(request, "__router_total_requests__"))), json-node-pair("native_requests", json-node-int(api-attention-int(request, "__router_native_requests__"))), json-node-pair("fanout_requests", json-node-int(api-attention-int(request, "__router_fanout_requests__"))), json-node-pair("choice_attempts", json-node-int(api-attention-int(request, "__router_choice_attempts__"))), json-node-pair("choice_successes", json-node-int(api-attention-int(request, "__router_choice_successes__"))), json-node-pair("choice_failures", json-node-int(api-attention-int(request, "__router_choice_failures__"))), json-node-pair("fanout_path_counts", json-node-array(empty))));
    def api-attention-matrix-json(request) {
        let native_route_count = api-attention-int(request, "__router_native_route_count__");
        let observed_native_route_count = api-attention-int(request, "__router_observed_native_route_count__");
        let total_requests = api-attention-int(request, "__router_total_requests__");
        let native_requests = api-attention-int(request, "__router_native_requests__");
        let fanout_requests = api-attention-int(request, "__router_fanout_requests__");
        let native_coverage = api-attention-ratio(observed_native_route_count, native_route_count);
        let fanout_pressure = api-attention-ratio(fanout_requests, total_requests);
        let unobserved_native_pressure = api-attention-clamp01(sub(1.0, native_coverage));
        let native_pressure = api-attention-ratio(native_requests, total_requests);
        json-node-array(list(json-node-array(list(api-json-number(native_coverage), api-json-number(fanout_pressure))), json-node-array(list(api-json-number(unobserved_native_pressure), api-json-number(native_pressure)))));
    }
    def api-attention-candidate-json(request) {
        let total_requests = api-attention-int(request, "__router_total_requests__");
        let candidate_requests = api-attention-int(request, "__router_next_bml_candidate_requests__");
        json-node-object(list(json-node-pair("path", json-node-string(api-attention-str(request, "__router_next_bml_candidate_path__"))), json-node-pair("requests", json-node-int(candidate_requests)), json-node-pair("source", json-node-string(api-attention-str(request, "__router_next_bml_candidate_source__"))), json-node-pair("pressure", api-json-number(api-attention-ratio(candidate_requests, total_requests)))));
    }
    def api-attention-native-observation-json() = json-node-object(list(json-node-pair("grammar", json-node-string("BML")), json-node-pair("handler", json-node-string("api_attention_kernel_runtime")), json-node-pair("front_door_service", json-node-string("coherence-api-kernel-bml-front-door")), json-node-pair("python_authority", json-node-bool(false))));
    def api-attention-kernel-runtime-json(request) = json-node-object(list(json-node-pair("source", json-node-string("kernel-router:live-metrics")), json-node-pair("measurements", api-attention-measurements-json(request)), json-node-pair("matrix", api-attention-matrix-json(request)), json-node-pair("next_bml_candidate", api-attention-candidate-json(request)), json-node-pair("native_observation", api-attention-native-observation-json())));
    def api_attention_kernel_runtime(request) = api-native-ok-json("api_attention_kernel_runtime", api-attention-kernel-runtime-json(request));

    def api-error-json(status, detail) = kh-response(status, list(kh-header("Content-Type", "application/json"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(json-node-object(list(json-node-pair("detail", json-node-string(detail))))));
    def api-presence-window-ms() = 90000;
    def api-presence-supported?(entity_type) = or(str_eq(entity_type, "concept"), or(str_eq(entity_type, "idea"), or(str_eq(entity_type, "spec"), or(str_eq(entity_type, "contributor"), or(str_eq(entity_type, "community"), or(str_eq(entity_type, "workspace"), or(str_eq(entity_type, "asset"), or(str_eq(entity_type, "contribution"), or(str_eq(entity_type, "story"), or(str_eq(entity_type, "config"), or(str_eq(entity_type, "insight"), or(str_eq(entity_type, "agent_task"), or(str_eq(entity_type, "agent_run"), or(str_eq(entity_type, "proposal"), or(str_eq(entity_type, "voice"), str_eq(entity_type, "blog")))))))))))))));
    def api-presence-tail(request) {
        let path = kh-request-path(request);
        if le(str_len(path), 14) then "" else substring(path, 14, str_len(path));
    }
    def api-presence-split(tail) = str_find(tail, "/", 0);
    def api-presence-entity-type-from-tail(tail) {
        let slash = api-presence-split(tail);
        if eq(slash, -1) then tail else substring(tail, 0, slash);
    }
    def api-presence-entity-id-from-tail(tail) {
        let slash = api-presence-split(tail);
        if eq(slash, -1) then "" else substring(tail, add(slash, 1), str_len(tail));
    }
    def api-presence-entity-type(request) = api-presence-entity-type-from-tail(api-presence-tail(request));
    def api-presence-entity-id(request) = api-presence-entity-id-from-tail(api-presence-tail(request));
    def api-presence-body-fingerprint(request) = json-string-value(json-object-get(parse-json("presence-request-body", kh-request-body(request)), "fingerprint"));
    def api-presence-key(entity_type, entity_id, fingerprint) = str_concat(entity_type, str_concat("|", str_concat(entity_id, str_concat("|", fingerprint))));
    def api-presence-value(entity_type, entity_id, fingerprint) = list(entity_type, entity_id, fingerprint);
    def api-presence-row-value(row) = nth(row, 1);
    def api-presence-row-entity-type(row) = nth(api-presence-row-value(row), 0);
    def api-presence-row-entity-id(row) = nth(api-presence-row-value(row), 1);
    def api-presence-row-fingerprint(row) = nth(api-presence-row-value(row), 2);
    def api-presence-row-matches?(row, entity_type, entity_id) = and(str_eq(api-presence-row-entity-type(row), entity_type), str_eq(api-presence-row-entity-id(row), entity_id));
    def api-presence-count-rows(rows, entity_type, entity_id) = if nil?(rows) then 0 else if api-presence-row-matches?(head(rows), entity_type, entity_id) then add(1, api-presence-count-rows(tail(rows), entity_type, entity_id)) else api-presence-count-rows(tail(rows), entity_type, entity_id);
    def api-presence-others-rows(rows, entity_type, entity_id, fingerprint) = if nil?(rows) then 0 else if api-presence-row-matches?(head(rows), entity_type, entity_id) then if and(gt(str_len(fingerprint), 0), str_eq(api-presence-row-fingerprint(head(rows)), fingerprint)) then api-presence-others-rows(tail(rows), entity_type, entity_id, fingerprint) else add(1, api-presence-others-rows(tail(rows), entity_type, entity_id, fingerprint)) else api-presence-others-rows(tail(rows), entity_type, entity_id, fingerprint);
    def api-presence-cutoff() = sub(now_unix_ms(), api-presence-window-ms());
    def api-presence-live-rows() {
        let cutoff = api-presence-cutoff();
        let pruned = volatile_cell_prune_before("presence", cutoff);
        volatile_cell_scan_since("presence", cutoff);
    }
    def api-presence-count-json(rows, entity_type, entity_id, fingerprint) = json-node-object(list(json-node-pair("present", json-node-int(api-presence-count-rows(rows, entity_type, entity_id))), json-node-pair("others", json-node-int(api-presence-others-rows(rows, entity_type, entity_id, fingerprint)))));
    def api-presence-beat-json(rows, entity_type, entity_id) = json-node-object(list(json-node-pair("present", json-node-int(api-presence-count-rows(rows, entity_type, entity_id)))));
    def api-presence-upsert-summary(acc, entity_type, entity_id) = if nil?(acc) then list(list(entity_type, entity_id, 1)) else if and(str_eq(nth(head(acc), 0), entity_type), str_eq(nth(head(acc), 1), entity_id)) then cons(list(entity_type, entity_id, add(nth(head(acc), 2), 1)), tail(acc)) else cons(head(acc), api-presence-upsert-summary(tail(acc), entity_type, entity_id));
    def api-presence-summary-acc(rows, acc) = if nil?(rows) then acc else api-presence-summary-acc(tail(rows), api-presence-upsert-summary(acc, api-presence-row-entity-type(head(rows)), api-presence-row-entity-id(head(rows))));
    def api-presence-insert-summary(row, rows) = if nil?(rows) then list(row) else if gt(nth(row, 2), nth(head(rows), 2)) then cons(row, rows) else cons(head(rows), api-presence-insert-summary(row, tail(rows)));
    def api-presence-sort-summary(rows) = if nil?(rows) then empty else api-presence-insert-summary(head(rows), api-presence-sort-summary(tail(rows)));
    def api-presence-summary-row-json(row) = json-node-object(list(json-node-pair("entity_type", json-node-string(nth(row, 0))), json-node-pair("entity_id", json-node-string(nth(row, 1))), json-node-pair("present", json-node-int(nth(row, 2)))));
    def api-presence-summary-row-jsons(rows) = if nil?(rows) then empty else cons(api-presence-summary-row-json(head(rows)), api-presence-summary-row-jsons(tail(rows)));
    def api_presence_summary(request) {
        let rows = api-presence-live-rows();
        let summary_rows = api-presence-sort-summary(api-presence-summary-acc(rows, empty));
        api-native-ok-json("api_presence_summary", json-node-object(list(json-node-pair("total_entities", json-node-int(len(summary_rows))), json-node-pair("top", json-node-array(api-presence-summary-row-jsons(take(20, summary_rows)))))));
    }
    def api_presence_count(request) {
        let entity_type = api-presence-entity-type(request);
        let entity_id = api-presence-entity-id(request);
        let fingerprint = kh-query-value-or(request, "fingerprint", "");
        if api-presence-supported?(entity_type) then api-native-ok-json("api_presence_count", api-presence-count-json(api-presence-live-rows(), entity_type, entity_id, fingerprint)) else api-error-json(400, str_concat("Unsupported entity_type '", str_concat(entity_type, "'")));
    }
    def api_presence_heartbeat(request) {
        let entity_type = api-presence-entity-type(request);
        let entity_id = api-presence-entity-id(request);
        let fingerprint = api-presence-body-fingerprint(request);
        if api-presence-supported?(entity_type) then if or(str_eq(entity_id, ""), lt(str_len(fingerprint), 4)) then api-error-json(422, "fingerprint must be at least 4 characters") else api_presence_heartbeat_valid(entity_type, entity_id, fingerprint) else api-error-json(400, str_concat("Unsupported entity_type '", str_concat(entity_type, "'")));
    }
    def api_presence_heartbeat_valid(entity_type, entity_id, fingerprint) {
        let wrote = volatile_cell_put("presence", api-presence-key(entity_type, entity_id, fingerprint), api-presence-value(entity_type, entity_id, fingerprint));
        api-ok-json(api-presence-beat-json(api-presence-live-rows(), entity_type, entity_id));
    }

    def api-not-found(detail) = api-error-json(404, detail);
    def api-repo-path(path) = str_concat(repo_root(), str_concat("/", path));
    def api-field-tail(request) {
        let path = kh-request-path(request);
        if le(str_len(path), 19) then "" else substring(path, 19, str_len(path));
    }
    def api-field-first-segment(text) {
        let slash = str_find(text, "/", 0);
        if eq(slash, -1) then text else substring(text, 0, slash);
    }
    def api-field-after-first-segment(text) {
        let slash = str_find(text, "/", 0);
        if eq(slash, -1) then "" else substring(text, add(slash, 1), str_len(text));
    }
    def api-field-slug(request) = api-field-first-segment(api-field-tail(request));
    def api-field-trace-rest(request) = api-field-after-first-segment(api-field-tail(request));
    def api-field-trace-selector(request) {
        let rest = api-field-trace-rest(request);
        if kh-prefix?(rest, "trace/") then api-field-first-segment(substring(rest, 6, str_len(rest))) else "";
    }
    def api-field-trace-value(request) {
        let rest = api-field-trace-rest(request);
        if kh-prefix?(rest, "trace/") then api-field-after-first-segment(substring(rest, 6, str_len(rest))) else "";
    }
    def api-field-author-line-exact(text, value) = str_find(text, str_concat("\"name\": \"", str_concat(value, "\"")), 0);
    def api-field-author-line-prefix(text, value) {
        let prefix = str_ascii_prefix(value);
        if str_eq(prefix, "") then -1 else str_find(text, str_concat("\"name\": \"", prefix), 0);
    }
    def api-field-author-line(text, value) {
        let exact = api-field-author-line-exact(text, value);
        if eq(exact, -1) then api-field-author-line-prefix(text, value) else exact;
    }
    def api-field-author-result(value) {
        let text = read_file(api-repo-path("docs/field/urs/trace/author_index.jsonl"));
        let idx = api-field-author-line(text, value);
        if eq(idx, -1) then empty else list(parse-json("docs/field/urs/trace/author_index.jsonl", str_line_at(text, idx)));
    }
    def api_field_story_trace(request) {
        let slug = api-field-slug(request);
        let selector = api-field-trace-selector(request);
        let value = api-field-trace-value(request);
        let result = if and(str_eq(slug, "urs-field-story"), str_eq(selector, "author")) then api-field-author-result(value) else empty;
        if nil?(result) then api-not-found("field story trace value not found") else api-native-ok-json("api_field_story_trace", json-node-object(list(json-node-pair("slug", json-node-string(slug)), json-node-pair("selector", json-node-string(selector)), json-node-pair("value", json-node-string(value)), json-node-pair("result", head(result)))));
    }

    0;
}

