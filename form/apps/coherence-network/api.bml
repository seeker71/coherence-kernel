        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if query_failed then api-service-unavailable("persistence", query_error) else if nil?(rows) then api-error-status-json(404, str_concat("sensing '", str_concat(api-sensing-id(request), "' not found"))) else api-native-ok-json("api_sensing_detail", api-sensing-row-json(head(rows)));
    }
    def api_sensing_detail(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-sensing-detail-connected(conn, request);
    }
    def api-translation-time-sql(column_name) = str_concat("to_char(", str_concat(column_name, " AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"')"));
    def api-translation-select-sql() = str_concat("SELECT id, entity_type, entity_id, lang, content_title, content_description, content_markdown, content_hash, author_type, COALESCE(author_id,'') AS author_id, COALESCE(translator_model,'') AS translator_model, COALESCE(translated_from_lang,'') AS translated_from_lang, COALESCE(translated_from_hash,'') AS translated_from_hash, status, COALESCE(notes,'') AS notes, ", str_concat(api-translation-time-sql("created_at"), str_concat(" AS created_at, ", str_concat(api-translation-time-sql("updated_at"), " AS updated_at FROM entity_views"))));
    def api-translations-canonical-sql() = str_concat("SELECT DISTINCT ON (lang) * FROM (", str_concat(api-translation-select-sql(), ") view_rows WHERE entity_type = $1 AND entity_id = $2 AND status = 'canonical' ORDER BY lang, updated_at DESC"));
    def api-translations-history-sql() = str_concat(api-translation-select-sql(), " WHERE entity_type = $1 AND entity_id = $2 AND lang = $3 ORDER BY updated_at DESC");
    def api-translation-row-json(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("entity_type", json-node-string(idea-row("entity_type", row))), json-node-pair("entity_id", json-node-string(idea-row("entity_id", row))), json-node-pair("lang", json-node-string(idea-row("lang", row))), json-node-pair("content_title", json-node-string(idea-row("content_title", row))), json-node-pair("content_description", json-node-string(idea-row("content_description", row))), json-node-pair("content_markdown", json-node-string(idea-row("content_markdown", row))), json-node-pair("content_hash", json-node-string(idea-row("content_hash", row))), json-node-pair("author_type", json-node-string(idea-row("author_type", row))), json-node-pair("author_id", api-json-nullable-string(idea-row("author_id", row))), json-node-pair("translator_model", api-json-nullable-string(idea-row("translator_model", row))), json-node-pair("translated_from_lang", api-json-nullable-string(idea-row("translated_from_lang", row))), json-node-pair("translated_from_hash", api-json-nullable-string(idea-row("translated_from_hash", row))), json-node-pair("status", json-node-string(idea-row("status", row))), json-node-pair("notes", api-json-nullable-string(idea-row("notes", row))), json-node-pair("source_contribution_id", json-node-null()), json-node-pair("created_at", json-node-string(idea-row("created_at", row))), json-node-pair("updated_at", json-node-string(idea-row("updated_at", row)))));
    def api-translation-rows-json(rows) = if nil?(rows) then empty else cons(api-translation-row-json(head(rows)), api-translation-rows-json(tail(rows)));
    def api-translations-response-json(rows) = json-node-object(list(json-node-pair("items", json-node-array(api-translation-rows-json(rows))), json-node-pair("total", json-node-int(len(rows)))));
    def api-translations-tail(request) = api-path-tail(kh-request-path(request), "/api/translations/");
    def api-translations-entity-type(request) = api-path-first-segment(api-translations-tail(request));
    def api-translations-entity-id(request) = api-path-after-first-segment(api-translations-tail(request));
    def api-translations-connected(conn, request) {
        let entity_type = api-translations-entity-type(request);
        let entity_id = api-translations-entity-id(request);
        let lang = kh-query-value-or(request, "lang", "");
        let rows = if str_eq(lang, "") then pg_query_rows(conn, api-translations-canonical-sql(), list(entity_type, entity_id)) else pg_query_rows(conn, api-translations-history-sql(), list(entity_type, entity_id, lang));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if query_failed then api-service-unavailable("persistence", query_error) else api-native-ok-json("api_translations_entity", api-translations-response-json(rows));
    }
    def api_translations_entity(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-translations-connected(conn, request);
    }
    def api-now-iso() = unix_ms_to_iso_utc(now_unix_ms());
    def api-started-at-iso() = unix_ms_to_iso_utc(kernel_started_unix_ms());
    def api-uptime-seconds() = div(sub(now_unix_ms(), kernel_started_unix_ms()), 1000);
    def api-version() = "1.0.0";
    def api-string-or(value, default_value) = if str_eq(value_kind(value), "null") then default_value else value;
    def api-config-string-or(path, default_value) = api-string-or(config_value_or(path, default_value), default_value);
    def api-deployed-sha() = api-config-string-or("deployed_sha", "");
    def api-deployed-sha-source() = if str_eq(api-deployed-sha(), "") then "" else "config:deployed_sha";
    def api-strip-trailing-slash(s) = if and(gt(str_len(s), 0), char_at(s, sub(str_len(s), 1)) == "/") then substring(s, 0, sub(str_len(s), 1)) else s;
    def api-gate-main-head-cache-key(repo, branch) = str_concat(repo, str_concat("|", branch));
    def api-gate-main-head-cache-ttl-ms() = mul(config_value_or("release_gates.branch_head_sha_cache_ttl_seconds", 45.0), 1000.0);
    def api-gate-main-head-cache-fresh?(cached) = if value_kind(cached) == "list" then lt(sub(now_unix_ms(), nth(cached, 1)), api-gate-main-head-cache-ttl-ms()) else false;
    def api-gate-main-head-cache-sha(cached) = if api-gate-main-head-cache-fresh?(cached) then nth(cached, 0) else "";
    def api-gate-main-head-cache-get(repo, branch) = api-gate-main-head-cache-sha(volatile_cell_get("github.branch_head_sha", api-gate-main-head-cache-key(repo, branch)));
    def api-gate-main-head-cache-put(repo, branch, sha) {
        let stored = volatile_cell_put("github.branch_head_sha", api-gate-main-head-cache-key(repo, branch), list(sha, now_unix_ms()));
        sha;
    }
    def api-gate-github-token() {
        let token = config_value_or("github.token", "");
        if token == "" then config_value_or("github.api_token", config_value_or("github_token", config_value_or("keys.github.token", config_value_or("keys.github_token", "")))) else token;
    }
    def api-gate-github-api-base() = api-strip-trailing-slash(config_value_or("github.api_base", ""));
    def api-gate-github-headers() {
        let token = api-gate-github-token();
        let headers = list(kh-header("Accept", "application/vnd.github+json"), kh-header("X-GitHub-Api-Version", "2022-11-28"), kh-header("User-Agent", "CoherenceNetworkNativeKernel/1.0"));
        if token == "" then headers else _list_append(headers, kh-header("Authorization", str_concat("Bearer ", token)));
    }
    def api-gate-main-head-timeout-seconds(request) {
        let default_timeout = value_str(config_value_or("release_gates.branch_head_sha_timeout_seconds", 6.0));
        let raw = kh-query-value-or(request, "timeout_seconds", default_timeout);
        let seconds = str_to_float(raw);
        if lt(seconds, 1.0) then 1.0 else if gt(seconds, 60.0) then 60.0 else seconds;
    }
    def api-gate-main-head-timeout-ms(request) = mul(api-gate-main-head-timeout-seconds(request), 1000.0);
