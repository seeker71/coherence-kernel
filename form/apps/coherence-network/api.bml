    def api-path-tail(path, prefix) = if le(str_len(path), str_len(prefix)) then "" else substring(path, str_len(prefix), str_len(path));
    def api-path-first-segment(text) {
        let slash = str_find(text, "/", 0);
        if eq(slash, -1) then text else substring(text, 0, slash);
    }
    def api-path-after-first-segment(text) {
        let slash = str_find(text, "/", 0);
        if eq(slash, -1) then "" else substring(text, add(slash, 1), str_len(text));
    }
    def api-sensing-list-sql() = "SELECT id, COALESCE(properties->>'sensing_kind','') AS kind, COALESCE(NULLIF(properties->>'summary',''), name) AS summary, COALESCE(properties->>'content','') AS content, COALESCE(NULLIF(properties->>'source',''), 'unknown') AS source, COALESCE(NULLIF(properties->>'observed_at',''), to_char(created_at AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"')) AS observed_at, CASE WHEN jsonb_typeof(properties->'related_to') = 'array' THEN (properties->'related_to')::text ELSE '[]' END AS related_to_json, CASE WHEN jsonb_typeof(properties->'metadata') = 'object' THEN (properties->'metadata')::text ELSE '{}' END AS metadata_json FROM graph_nodes WHERE type = 'event' AND COALESCE(properties->>'sensing_kind','') <> '' AND ($1 = '' OR properties->>'sensing_kind' = $1) ORDER BY updated_at DESC LIMIT $2";
    def api-sensing-detail-sql() = "SELECT id, COALESCE(properties->>'sensing_kind','') AS kind, COALESCE(NULLIF(properties->>'summary',''), name) AS summary, COALESCE(properties->>'content','') AS content, COALESCE(NULLIF(properties->>'source',''), 'unknown') AS source, COALESCE(NULLIF(properties->>'observed_at',''), to_char(created_at AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"')) AS observed_at, CASE WHEN jsonb_typeof(properties->'related_to') = 'array' THEN (properties->'related_to')::text ELSE '[]' END AS related_to_json, CASE WHEN jsonb_typeof(properties->'metadata') = 'object' THEN (properties->'metadata')::text ELSE '{}' END AS metadata_json FROM graph_nodes WHERE type = 'event' AND COALESCE(properties->>'sensing_kind','') <> '' AND id = $1 LIMIT 1";
    def api-sensing-row-json(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("kind", json-node-string(idea-row("kind", row))), json-node-pair("summary", json-node-string(idea-row("summary", row))), json-node-pair("content", json-node-string(idea-row("content", row))), json-node-pair("source", json-node-string(idea-row("source", row))), json-node-pair("observed_at", json-node-string(idea-row("observed_at", row))), json-node-pair("related_to", parse-json("sensing.related_to", idea-row("related_to_json", row))), json-node-pair("metadata", parse-json("sensing.metadata", idea-row("metadata_json", row)))));
    def api-sensing-rows-json(rows) = if nil?(rows) then empty else cons(api-sensing-row-json(head(rows)), api-sensing-rows-json(tail(rows)));
    def api-sensing-kind-valid?(kind) = if str_eq(kind, "") then true else if str_eq(kind, "breath") then true else if str_eq(kind, "skin") then true else if str_eq(kind, "wandering") then true else str_eq(kind, "integration");
    def api-sensing-kind-error(kind) = str_concat("unknown kind '", str_concat(kind, "'; expected one of ['breath', 'integration', 'skin', 'wandering']"));
    def api-sensings-connected(conn, request) {
        let kind = kh-query-value-or(request, "kind", "");
        let limit = api-clamp-limit(kh-query-int-or(request, "limit", 20), 100);
        let rows = pg_query_rows(conn, api-sensing-list-sql(), list(kind, limit));
