    def api-household-member-rows-json(rows) = if nil?(rows) then empty else cons(api-household-member-json(head(rows)), api-household-member-rows-json(tail(rows)));
    def api-household-members-connected(conn, request) {
        let role = kh-query-value-or(request, "role", "");
        let rows = pg_query_rows(conn, api-household-members-sql(), list(role));
