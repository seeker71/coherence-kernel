    def inventory-flow-contributions-json(row) = json-node-object(list(json-node-pair("tracked", json-node-bool(inventory-flow-has-contributions?(row))), json-node-pair("usage_events_count", json-node-int(idea-row("contribution_count", row))), json-node-pair("measured_value_total", idea-json-float(idea-row("registry_total_cost", row))), json-node-pair("registry_contribution_count", json-node-int(idea-row("contribution_count", row))), json-node-pair("registry_total_cost", idea-json-float(idea-row("registry_total_cost", row))), json-node-pair("contribution_ids", parse-json("inventory.contribution_ids", idea-row("contribution_ids_json", row))), json-node-pair("contribution_ids_total", json-node-int(idea-row("contribution_count", row))), json-node-pair("contribution_ids_truncated", json-node-bool(false))));
    def inventory-flow-assets-json(row) = json-node-object(list(json-node-pair("tracked", json-node-bool(inventory-flow-has-assets?(row))), json-node-pair("count", json-node-int(idea-row("asset_count", row))), json-node-pair("asset_ids", parse-json("inventory.asset_ids", idea-row("asset_ids_json", row))), json-node-pair("asset_ids_total", json-node-int(idea-row("asset_count", row))), json-node-pair("asset_ids_truncated", json-node-bool(false))));
    def inventory-flow-chain-json(row) = json-node-object(list(json-node-pair("spec", json-node-string(inventory-flow-stage-state(inventory-flow-has-spec?(row)))), json-node-pair("process", json-node-string(inventory-flow-stage-state(inventory-flow-has-process?(row)))), json-node-pair("implementation", json-node-string(inventory-flow-stage-state(inventory-flow-has-implementation?(row)))), json-node-pair("validation", json-node-string(inventory-flow-stage-state(inventory-flow-has-validation?(row)))), json-node-pair("contributors", json-node-string(inventory-flow-stage-state(inventory-flow-has-contributors?(row)))), json-node-pair("contributions", json-node-string(inventory-flow-stage-state(inventory-flow-has-contributions?(row)))), json-node-pair("assets", json-node-string(inventory-flow-stage-state(inventory-flow-has-assets?(row))))));
    def inventory-flow-interdependencies-json(row) {
        let stage = inventory-flow-blocking-stage(row);
        json-node-object(list(json-node-pair("blocked", json-node-bool(not(str_eq(stage, "")))), json-node-pair("blocking_stage", api-json-nullable-string(stage)), json-node-pair("upstream_required", inventory-flow-required-json(stage)), json-node-pair("downstream_blocked", parse-json("inventory.downstream_blocked", idea-row("downstream_blocked_json", row))), json-node-pair("estimated_unblock_cost", idea-json-float(idea-row("estimated_unblock_cost", row))), json-node-pair("estimated_unblock_value", idea-json-float(idea-row("value_gap", row))), json-node-pair("unblock_priority_score", idea-json-float(idea-row("unblock_priority_score", row))), json-node-pair("task_fingerprint", api-json-nullable-string(inventory-flow-task-fingerprint(row, stage))), json-node-pair("next_unblock_task", inventory-flow-stage-task-json(row, stage))));
    }
