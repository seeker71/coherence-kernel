    def api-concept-carried-by-id(request) = api-path-first-segment(api-path-tail(kh-request-path(request), "/api/concepts/"));
    def api-concept-carried-by-sql() = "WITH edges AS (SELECT p.id AS presence_id, COALESCE(NULLIF(p.name,''), p.id) AS presence_name, COALESCE(NULLIF(p.type,''), 'contributor') AS presence_type, NULLIF(p.properties->>'image_url','') AS image_url, CASE WHEN COALESCE(e.properties->>'score','') ~ '^-?[0-9]+(\\.[0-9]+)?$' THEN (e.properties->>'score')::double precision ELSE COALESCE(e.strength, 0.0) END AS score, CASE WHEN jsonb_typeof(e.properties->'shared_tokens') = 'array' THEN e.properties->'shared_tokens' ELSE '[]'::jsonb END AS shared_tokens, COALESCE(NULLIF(e.properties->>'method',''), 'keyword-overlap') AS method FROM graph_edges e JOIN graph_nodes p ON p.id = e.from_id WHERE e.to_id = $1 AND e.type = 'resonates-with' ORDER BY score DESC LIMIT 200) SELECT COALESCE(jsonb_agg(jsonb_build_object('presence_id', presence_id, 'presence_name', presence_name, 'presence_type', presence_type, 'image_url', image_url, 'score', score, 'shared_tokens', shared_tokens, 'method', method) ORDER BY score DESC), '[]'::jsonb)::text AS items_json, count(*)::bigint AS item_count FROM edges";
    def api-concept-carried-by-response-json(rows) = if nil?(rows) then json-node-object(list(json-node-pair("items", json-node-array(empty)), json-node-pair("count", json-node-int(0)))) else json-node-object(list(json-node-pair("items", parse-json("concept-carried-by.items", idea-row("items_json", head(rows)))), json-node-pair("count", json-node-int(idea-row("item_count", head(rows))))));
    def api-concept-carried-by-connected(conn, request) {
