    def api_inventory_flow(request) {
        let idea_id = kh-query-value-or(request, "idea_id", "");
        let include_internal_ideas = kh-query-bool-or(request, "include_internal_ideas", false);
        let runtime_window_seconds = inventory-flow-window(kh-query-int-or(request, "runtime_window_seconds", 86400));
        let list_item_limit = api-clamp-limit(kh-query-int-or(request, "list_item_limit", 12), 200);
        if gt(str_len(idea_id), 255) then api-error-status-json(422, "idea_id must be at most 255 characters") else if inventory-flow-canary?(idea_id) then api-native-ok-json("api_inventory_flow", inventory-flow-canary-response-json(idea_id, include_internal_ideas, runtime_window_seconds)) else api-inventory-flow-db-response(idea_id, include_internal_ideas, runtime_window_seconds, list_item_limit);
    }
    def observe-warm-inventory-flow(request, remaining) {
        if le(remaining, 0) then 0 else observe-warm-inventory-flow-after(request, remaining, api_inventory_flow(request));
    }
    def observe-warm-inventory-flow-after(request, remaining, ignored) = observe-warm-inventory-flow(request, sub(remaining, 1));
    def inventory-flow-observe-event-json-rows(events, remaining) = if nil?(events) then empty else if le(remaining, 0) then empty else cons(api-nodeid-value-json(head(events)), inventory-flow-observe-event-json-rows(tail(events), sub(remaining, 1)));
    def inventory-flow-observe-native-json() = json-node-object(list(json-node-pair("grammar", json-node-string("BML")), json-node-pair("handler", json-node-string("api_inventory_flow_observe")), json-node-pair("observed_handler", json-node-string("api_inventory_flow")), json-node-pair("observation_kind", json-node-string("framebuffer+jit")), json-node-pair("python_authority", json-node-bool(false))));
    def inventory-flow-observe-response-json(response, events, event_nodes, jit_rows, warm_count, request, t0, t1) = json-node-object(list(json-node-pair("route", json-node-string("/api/_form/inventory-flow-observation")), json-node-pair("observed_route", json-node-string("/api/inventory/flow")), json-node-pair("observed_handler", json-node-string("api_inventory_flow")), json-node-pair("observed_idea_id", api-json-nullable-string(kh-query-value-or(request, "idea_id", ""))), json-node-pair("observed_canary", json-node-bool(inventory-flow-canary?(kh-query-value-or(request, "idea_id", "")))), json-node-pair("status", json-node-int(kh-response-status(response))), json-node-pair("body_bytes", json-node-int(str_len(kh-response-body(response)))), json-node-pair("warm_count", json-node-int(warm_count)), json-node-pair("handler_total_ms", json-node-int(sub(t1, t0))), json-node-pair("framebuffer_event_rows", json-node-int(len(events))), json-node-pair("events_returned", json-node-int(len(event_nodes))), json-node-pair("jit_rows", json-node-int(len(jit_rows))), json-node-pair("jit_stats", json-node-array(observe-jit-json-rows(jit_rows))), json-node-pair("events", json-node-array(event_nodes)), json-node-pair("inventory_flow_native_observation", inventory-flow-native-observation-json()), json-node-pair("native_observation", inventory-flow-observe-native-json())));
    def inventory-flow-observe-response(response, events, event_limit, jit_rows, warm_count, request, t0, t1) {
        let event_nodes = inventory-flow-observe-event-json-rows(events, event_limit);
        kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", "api_inventory_flow_observe"), kh-header("X-Form-Python-Authority", "false"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(inventory-flow-observe-response-json(response, events, event_nodes, jit_rows, warm_count, request, t0, t1)));
