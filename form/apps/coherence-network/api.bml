; api.bml — BML-authored front-door API catalog.
;
; Source identity is the API front door. Go/Rust/TS/Python are carriers.
; This catalog is loaded through the Form source compiler into ordinary route
; and handler recipes before any carrier serves requests.

section [form.bml] {
    def idea-clamp-limit(n) = if lt(n, 1) then 1 else if gt(n, 500) then 500 else n;
    def idea-safe-offset(n) = if lt(n, 0) then 0 else n;
    def idea-sort-value(value) = match value { "marginal_cc" => "marginal_cc", _ => "free_energy" };
    def idea-internal-flag(request) = if kh-query-bool-or(request, "include_internal", true) then 1 else 0;
    def idea-row(key, row) = _dict_get(row, key);
    def idea-json-float(value) = json-node-float-text(value_str(value));
    def idea-json-nullable-string(key, value) = json-node-pair(key, if str_eq(value, "") then json-node-null() else json-node-string(value));
    def idea-json-text(path, text) = parse-json(path, text);
    def idea-cost-vector(row) = json-node-object(list(json-node-pair("compute_cc", idea-json-float(mul(idea-row("estimated_cost", row), 0.6))), json-node-pair("infrastructure_cc", idea-json-float(mul(idea-row("estimated_cost", row), 0.15))), json-node-pair("human_attention_cc", idea-json-float(mul(idea-row("estimated_cost", row), 0.25))), json-node-pair("opportunity_cc", json-node-float-text("0.0")), json-node-pair("external_cc", json-node-float-text("0.0")), json-node-pair("total_cc", idea-json-float(idea-row("estimated_cost", row)))));
    def idea-value-vector(row) = json-node-object(list(json-node-pair("adoption_cc", idea-json-float(mul(idea-row("potential_value", row), 0.5))), json-node-pair("lineage_cc", idea-json-float(mul(idea-row("potential_value", row), 0.3))), json-node-pair("friction_avoided_cc", idea-json-float(mul(idea-row("potential_value", row), 0.2))), json-node-pair("revenue_cc", json-node-float-text("0.0")), json-node-pair("total_cc", idea-json-float(idea-row("potential_value", row)))));
    def idea-json-row(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("name", json-node-string(idea-row("name", row))), json-node-pair("description", json-node-string(idea-row("description", row))), json-node-pair("potential_value", idea-json-float(idea-row("potential_value", row))), json-node-pair("actual_value", idea-json-float(idea-row("actual_value", row))), json-node-pair("estimated_cost", idea-json-float(idea-row("estimated_cost", row))), json-node-pair("actual_cost", idea-json-float(idea-row("actual_cost", row))), json-node-pair("resistance_risk", idea-json-float(idea-row("resistance_risk", row))), json-node-pair("confidence", idea-json-float(idea-row("confidence", row))), json-node-pair("manifestation_status", json-node-string(idea-row("manifestation_status", row))), json-node-pair("interfaces", idea-json-text("interfaces", idea-row("interfaces_json", row))), json-node-pair("open_questions", idea-json-text("open_questions", idea-row("open_questions_json", row))), json-node-pair("idea_type", json-node-string(idea-row("idea_type", row))), idea-json-nullable-string("parent_idea_id", idea-row("parent_idea_id", row)), json-node-pair("child_idea_ids", idea-json-text("child_idea_ids", idea-row("child_idea_ids_json", row))), json-node-pair("stage", json-node-string(idea-row("stage", row))), idea-json-nullable-string("work_type", idea-row("work_type", row)), json-node-pair("lifecycle", json-node-string(idea-row("lifecycle", row))), idea-json-nullable-string("duplicate_of", idea-row("duplicate_of", row)), idea-json-nullable-string("last_activity_at", idea-row("last_activity_at", row)), json-node-pair("value_basis", idea-json-text("value_basis", idea-row("value_basis_json", row))), json-node-pair("cost_vector", idea-cost-vector(row)), json-node-pair("value_vector", idea-value-vector(row)), json-node-pair("tags", idea-json-text("tags", idea-row("tags_json", row))), idea-json-nullable-string("workspace_git_url", idea-row("workspace_git_url", row)), json-node-pair("slug", json-node-string(idea-row("slug", row))), json-node-pair("slug_history", idea-json-text("slug_history", idea-row("slug_history_json", row))), json-node-pair("is_curated", json-node-bool(idea-row("is_curated", row))), idea-json-nullable-string("pillar", idea-row("pillar", row)), json-node-pair("workspace_id", json-node-string(idea-row("workspace_id", row))), idea-json-nullable-string("rollup_condition", idea-row("rollup_condition", row)), json-node-pair("free_energy_score", idea-json-float(idea-row("free_energy_score", row))), json-node-pair("value_gap", idea-json-float(idea-row("value_gap", row))), json-node-pair("content_markdown", json-node-string("")), json-node-pair("marginal_cc_score", idea-json-float(idea-row("marginal_cc_score", row))), json-node-pair("selection_weight", idea-json-float(idea-row("selection_weight", row))), json-node-pair("remaining_cost_cc", idea-json-float(idea-row("remaining_cost_cc", row))), json-node-pair("value_gap_cc", idea-json-float(idea-row("value_gap_cc", row))), json-node-pair("roi_cc", idea-json-float(idea-row("roi_cc", row)))));
    def idea-json-rows(rows) = if nil?(rows) then empty else cons(idea-json-row(head(rows)), idea-json-rows(tail(rows)));
    def idea-summary-json(row) = json-node-object(list(json-node-pair("total_ideas", json-node-int(idea-row("total_ideas", row))), json-node-pair("unvalidated_ideas", json-node-int(idea-row("unvalidated_ideas", row))), json-node-pair("validated_ideas", json-node-int(idea-row("validated_ideas", row))), json-node-pair("total_potential_value", idea-json-float(idea-row("total_potential_value", row))), json-node-pair("total_actual_value", idea-json-float(idea-row("total_actual_value", row))), json-node-pair("total_value_gap", idea-json-float(idea-row("total_value_gap", row)))));
    def idea-pagination-json(summary, limit, offset, returned) = json-node-object(list(json-node-pair("total", json-node-int(idea-row("total_ideas", summary))), json-node-pair("limit", json-node-int(limit)), json-node-pair("offset", json-node-int(offset)), json-node-pair("returned", json-node-int(returned)), json-node-pair("has_more", json-node-bool(lt(add(offset, returned), idea-row("total_ideas", summary))))));
    def idea-response-json(summary, rows, limit, offset) = json-node-object(list(json-node-pair("ideas", json-node-array(idea-json-rows(rows))), json-node-pair("summary", idea-summary-json(summary)), json-node-pair("pagination", idea-pagination-json(summary, limit, offset, len(rows)))));
    def idea-error-response(status, code, detail) = kh-response(status, list(kh-header("Content-Type", "application/json"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(json-node-object(list(json-node-pair("error", json-node-string(code)), json-node-pair("detail", json-node-string(detail))))));
    def idea-ok-response(summary, rows, limit, offset) = kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", "api_ideas"), kh-header("X-Form-Python-Authority", "false"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(idea-response-json(summary, rows, limit, offset)));
    def timing-ms(start, stop) = sub(stop, start);
    def idea-timing-json(status, body_bytes, rows_returned, summary_rows, t0, t_config, t_connect, t_params, t_summary, t_page, t_close, t_shape, t_emit) = json-node-object(list(json-node-pair("route", json-node-string("/api/ideas")), json-node-pair("scope", json-node-string("native-handler")), json-node-pair("status", json-node-int(status)), json-node-pair("body_bytes", json-node-int(body_bytes)), json-node-pair("rows_returned", json-node-int(rows_returned)), json-node-pair("summary_rows", json-node-int(summary_rows)), json-node-pair("excluded", json-node-array(list(json-node-string("process_startup"), json-node-string("tcp_accept"), json-node-string("client_network"), json-node-string("response_write")))), json-node-pair("timings_ms", json-node-object(list(json-node-pair("config", json-node-int(timing-ms(t0, t_config))), json-node-pair("connect", json-node-int(timing-ms(t_config, t_connect))), json-node-pair("params", json-node-int(timing-ms(t_connect, t_params))), json-node-pair("summary_query", json-node-int(timing-ms(t_params, t_summary))), json-node-pair("page_query", json-node-int(timing-ms(t_summary, t_page))), json-node-pair("close", json-node-int(timing-ms(t_page, t_close))), json-node-pair("shape_tree", json-node-int(timing-ms(t_close, t_shape))), json-node-pair("json_emit", json-node-int(timing-ms(t_shape, t_emit))), json-node-pair("handler_total", json-node-int(timing-ms(t0, t_emit))))))));
    def idea-timing-response(status, body_bytes, rows_returned, summary_rows, t0, t_config, t_connect, t_params, t_summary, t_page, t_close, t_shape, t_emit) = kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", "api_ideas_timing"), kh-header("X-Form-Python-Authority", "false"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(idea-timing-json(status, body_bytes, rows_returned, summary_rows, t0, t_config, t_connect, t_params, t_summary, t_page, t_close, t_shape, t_emit)));
    def observe-event-limit(n) = if lt(n, 1) then 1 else if gt(n, 250000) then 250000 else n;
    def observe-warm-count(n) = if lt(n, 0) then 0 else if gt(n, 200) then 200 else n;
    def observe-json-string-list(items) = if nil?(items) then empty else cons(json-node-string(head(items)), observe-json-string-list(tail(items)));
    def observe-count-json(row) = json-node-object(list(json-node-pair("file", json-node-string(nth(row, 0))), json-node-pair("line", json-node-int(nth(row, 1))), json-node-pair("col", json-node-int(nth(row, 2))), json-node-pair("count", json-node-int(nth(row, 3)))));
    def observe-count-json-rows(rows) = if nil?(rows) then empty else cons(observe-count-json(head(rows)), observe-count-json-rows(tail(rows)));
    def observe-event-json(row) = json-node-object(list(json-node-pair("seq", json-node-int(nth(row, 0))), json-node-pair("file", json-node-string(nth(row, 1))), json-node-pair("line", json-node-int(nth(row, 2))), json-node-pair("col", json-node-int(nth(row, 3))), json-node-pair("node", json-node-string(nth(row, 4))), json-node-pair("children", json-node-array(observe-json-string-list(nth(row, 5)))), json-node-pair("child_values", json-node-array(observe-json-string-list(nth(row, 6))))));
    def observe-event-json-rows(rows, remaining) = if nil?(rows) then empty else if le(remaining, 0) then empty else cons(observe-event-json(head(rows)), observe-event-json-rows(tail(rows), sub(remaining, 1)));
    def observe-jit-json(row) = json-node-object(list(json-node-pair("kind", json-node-string(nth(row, 0))), json-node-pair("body", json-node-string(nth(row, 1))), json-node-pair("count", json-node-int(nth(row, 2))), json-node-pair("detail", json-node-string(nth(row, 3)))));
    def observe-jit-json-rows(rows) = if nil?(rows) then empty else cons(observe-jit-json(head(rows)), observe-jit-json-rows(tail(rows)));
    def observe-response-json(response, counts, events, event_nodes, jit_rows, warm_count) = json-node-object(list(json-node-pair("route", json-node-string("/api/ideas")), json-node-pair("status", json-node-int(kh-response-status(response))), json-node-pair("body_bytes", json-node-int(str_len(kh-response-body(response)))), json-node-pair("warm_count", json-node-int(warm_count)), json-node-pair("framebuffer_count_rows", json-node-int(len(counts))), json-node-pair("framebuffer_event_rows", json-node-int(len(events))), json-node-pair("events_returned", json-node-int(len(event_nodes))), json-node-pair("jit_rows", json-node-int(len(jit_rows))), json-node-pair("jit_stats", json-node-array(observe-jit-json-rows(jit_rows))), json-node-pair("counts", json-node-array(observe-count-json-rows(counts))), json-node-pair("events", json-node-array(event_nodes))));
    def observe-response(response, counts, events, event_limit, jit_rows, warm_count) {
        let event_nodes = observe-event-json-rows(events, event_limit);
        kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", "api_ideas_observe"), kh-header("X-Form-Python-Authority", "false"), kh-header("Access-Control-Allow-Origin", "*")), json-emit(observe-response-json(response, counts, events, event_nodes, jit_rows, warm_count)));
    }
    def api-ideas-summary-sql() = "WITH raw AS (SELECT n.id, n.name, n.description, COALESCE(NULLIF(n.properties->>'potential_value','')::double precision,0.0) AS potential_value, COALESCE(NULLIF(n.properties->>'actual_value','')::double precision,0.0) AS actual_value, COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision,0.0) AS estimated_cost, COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision,0.0) AS actual_cost, COALESCE(NULLIF(n.properties->>'resistance_risk','')::double precision,1.0) AS resistance_risk, COALESCE(NULLIF(n.properties->>'confidence','')::double precision,0.5) AS confidence, COALESCE(n.properties->>'manifestation_status','none') AS manifestation_status FROM graph_nodes n WHERE n.type = 'idea' AND ($1 = '' OR n.id ILIKE '%' || $1 || '%' OR n.name ILIKE '%' || $1 || '%' OR n.description ILIKE '%' || $1 || '%') AND ($2::bigint = 1 OR NOT (n.id LIKE 'runtime:%' OR n.id LIKE 'runtime-%' OR COALESCE(n.properties->'interfaces','[]'::jsonb) ?| array['internal','system','machine:internal','agent:internal'])) AND (NOT $3 OR COALESCE(n.properties->>'manifestation_status','none') <> 'validated') AND (NOT $4 OR COALESCE((n.properties->>'is_curated')::boolean,false)) AND ($5 = '' OR COALESCE(n.properties->>'pillar','') = $5) AND ($6 = '' OR COALESCE(n.properties->>'workspace_id','coherence-network') = $6) AND ($7 = '' OR COALESCE(n.properties->'tags','[]'::jsonb) ?& string_to_array($7, ','))) SELECT count(*)::bigint AS total_ideas, count(*) FILTER (WHERE manifestation_status <> 'validated')::bigint AS unvalidated_ideas, count(*) FILTER (WHERE manifestation_status = 'validated')::bigint AS validated_ideas, COALESCE(round(sum(potential_value)::numeric, 4), 0)::double precision AS total_potential_value, COALESCE(round(sum(actual_value)::numeric, 4), 0)::double precision AS total_actual_value, COALESCE(round(GREATEST(sum(potential_value) - sum(actual_value), 0)::numeric, 4), 0)::double precision AS total_value_gap FROM raw";
    def api-ideas-page-sql() = "WITH raw AS (SELECT n.id, n.name, n.description, COALESCE(NULLIF(n.properties->>'potential_value','')::double precision,0.0) AS potential_value, COALESCE(NULLIF(n.properties->>'actual_value','')::double precision,0.0) AS actual_value, COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision,0.0) AS estimated_cost, COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision,0.0) AS actual_cost, COALESCE(NULLIF(n.properties->>'resistance_risk','')::double precision,1.0) AS resistance_risk, COALESCE(NULLIF(n.properties->>'confidence','')::double precision,0.5) AS confidence, COALESCE(n.properties->>'manifestation_status','none') AS manifestation_status, COALESCE(n.properties->'interfaces','[]'::jsonb)::text AS interfaces_json, COALESCE(n.properties->'open_questions','[]'::jsonb)::text AS open_questions_json, COALESCE(n.properties->>'idea_type','standalone') AS idea_type, COALESCE(n.properties->>'parent_idea_id','') AS parent_idea_id, COALESCE(n.properties->'child_idea_ids','[]'::jsonb)::text AS child_idea_ids_json, COALESCE(n.properties->>'stage','none') AS stage, COALESCE(n.properties->>'work_type','') AS work_type, COALESCE(n.properties->>'lifecycle','active') AS lifecycle, COALESCE(n.properties->>'duplicate_of','') AS duplicate_of, COALESCE(n.properties->>'last_activity_at','') AS last_activity_at, COALESCE(n.properties->'value_basis','null'::jsonb)::text AS value_basis_json, COALESCE(n.properties->'tags','[]'::jsonb)::text AS tags_json, COALESCE(n.properties->>'workspace_git_url','') AS workspace_git_url, COALESCE(NULLIF(n.properties->>'slug',''), n.id) AS slug, COALESCE(n.properties->'slug_history','[]'::jsonb)::text AS slug_history_json, COALESCE((n.properties->>'is_curated')::boolean,false) AS is_curated, COALESCE(n.properties->>'pillar','') AS pillar, COALESCE(n.properties->>'workspace_id','coherence-network') AS workspace_id, COALESCE(n.properties->>'rollup_condition','') AS rollup_condition FROM graph_nodes n WHERE n.type = 'idea' AND ($1 = '' OR n.id ILIKE '%' || $1 || '%' OR n.name ILIKE '%' || $1 || '%' OR n.description ILIKE '%' || $1 || '%') AND ($2::bigint = 1 OR NOT (n.id LIKE 'runtime:%' OR n.id LIKE 'runtime-%' OR COALESCE(n.properties->'interfaces','[]'::jsonb) ?| array['internal','system','machine:internal','agent:internal'])) AND (NOT $3 OR COALESCE(n.properties->>'manifestation_status','none') <> 'validated') AND (NOT $4 OR COALESCE((n.properties->>'is_curated')::boolean,false)) AND ($5 = '' OR COALESCE(n.properties->>'pillar','') = $5) AND ($6 = '' OR COALESCE(n.properties->>'workspace_id','coherence-network') = $6) AND ($7 = '' OR COALESCE(n.properties->'tags','[]'::jsonb) ?& string_to_array($7, ','))), scored AS (SELECT raw.*, round(((potential_value * confidence) / GREATEST(estimated_cost + resistance_risk, 0.5))::numeric, 4)::double precision AS free_energy_score, round(GREATEST(potential_value - actual_value, 0)::numeric, 4)::double precision AS value_gap, round(((GREATEST(potential_value - actual_value, 0) * confidence * confidence) / (GREATEST(estimated_cost - actual_cost, 0.1) + resistance_risk * 0.5))::numeric, 4)::double precision AS marginal_cc_score, round(GREATEST(estimated_cost - actual_cost, 0)::numeric, 4)::double precision AS remaining_cost_cc, round(GREATEST(potential_value - actual_value, 0)::numeric, 4)::double precision AS value_gap_cc, CASE WHEN GREATEST(estimated_cost - actual_cost, 0) > 0 THEN round((GREATEST(potential_value - actual_value, 0) / GREATEST(estimated_cost - actual_cost, 0))::numeric, 4)::double precision ELSE 0.0 END AS roi_cc FROM raw), ranked AS (SELECT scored.*, CASE WHEN $8 = 'marginal_cc' THEN marginal_cc_score ELSE free_energy_score END AS sort_score FROM scored), weighted AS (SELECT ranked.*, exp(sort_score - max(sort_score) OVER ()) AS exp_score FROM ranked), final AS (SELECT weighted.*, COALESCE(round((exp_score / NULLIF(sum(exp_score) OVER (), 0))::numeric, 6), 0)::double precision AS selection_weight FROM weighted) SELECT * FROM final ORDER BY sort_score DESC, id ASC LIMIT $9 OFFSET $10";
    def api-ideas-summary-params(request) = list(kh-query-value-or(request, "query", ""), idea-internal-flag(request), kh-query-bool-or(request, "only_unvalidated", false), kh-query-bool-or(request, "curated_only", false), kh-query-value-or(request, "pillar", ""), kh-query-value-or(request, "workspace_id", ""), kh-query-value-or(request, "tags", ""));
    def api-ideas-page-params(request, limit, offset) = list(kh-query-value-or(request, "query", ""), idea-internal-flag(request), kh-query-bool-or(request, "only_unvalidated", false), kh-query-bool-or(request, "curated_only", false), kh-query-value-or(request, "pillar", ""), kh-query-value-or(request, "workspace_id", ""), kh-query-value-or(request, "tags", ""), idea-sort-value(kh-query-value-or(request, "sort", "free_energy")), limit, offset);
    def api-ideas-connected(conn, request) {
        let limit = idea-clamp-limit(kh-query-int-or(request, "limit", 200));
        let offset = idea-safe-offset(kh-query-int-or(request, "offset", 0));
        let summary_params = api-ideas-summary-params(request);
        let page_params = api-ideas-page-params(request, limit, offset);
        let summary_rows = pg_query_rows(conn, api-ideas-summary-sql(), summary_params);
        let page_rows = pg_query_rows(conn, api-ideas-page-sql(), page_params);
        let closed = pg_close(conn);
        if nil?(summary_rows) then idea-error-response(500, "persistence", "idea query failed") else idea-ok-response(head(summary_rows), page_rows, limit, offset);
    }
    def api_ideas(request) {
        let database_url = config_database_url();
        let conn = pg_connect(database_url);
        if lt(conn, 0) then idea-error-response(503, "persistence", "database unavailable") else api-ideas-connected(conn, request);
    }
    def api-ideas-timing-error(conn, t0, t_config, t_connect, t_params, t_summary, t_page) {
        let closed = pg_close(conn);
        let t_close = now_unix_ms();
        let response_node = json-node-object(list(json-node-pair("error", json-node-string("persistence")), json-node-pair("detail", json-node-string("idea query failed"))));
        let t_shape = now_unix_ms();
        let body = json-emit(response_node);
        let t_emit = now_unix_ms();
        idea-timing-response(500, str_len(body), 0, 0, t0, t_config, t_connect, t_params, t_summary, t_page, t_close, t_shape, t_emit);
    }
    def api-ideas-timing-success(conn, summary_rows, page_rows, limit, offset, t0, t_config, t_connect, t_params, t_summary, t_page) {
        let closed = pg_close(conn);
        let t_close = now_unix_ms();
        let response_node = idea-response-json(head(summary_rows), page_rows, limit, offset);
        let t_shape = now_unix_ms();
        let body = json-emit(response_node);
        let t_emit = now_unix_ms();
        idea-timing-response(200, str_len(body), len(page_rows), len(summary_rows), t0, t_config, t_connect, t_params, t_summary, t_page, t_close, t_shape, t_emit);
    }
    def api-ideas-timing-connected(conn, request, t0, t_config, t_connect) {
        let limit = idea-clamp-limit(kh-query-int-or(request, "limit", 200));
        let offset = idea-safe-offset(kh-query-int-or(request, "offset", 0));
        let summary_params = api-ideas-summary-params(request);
        let page_params = api-ideas-page-params(request, limit, offset);
        let t_params = now_unix_ms();
        let summary_rows = pg_query_rows(conn, api-ideas-summary-sql(), summary_params);
        let t_summary = now_unix_ms();
        let page_rows = pg_query_rows(conn, api-ideas-page-sql(), page_params);
        let t_page = now_unix_ms();
        if nil?(summary_rows) then api-ideas-timing-error(conn, t0, t_config, t_connect, t_params, t_summary, t_page) else api-ideas-timing-success(conn, summary_rows, page_rows, limit, offset, t0, t_config, t_connect, t_params, t_summary, t_page);
    }
    def api_ideas_timing(request) {
        let t0 = now_unix_ms();
        let database_url = config_database_url();
        let t_config = now_unix_ms();
        let conn = pg_connect(database_url);
        let t_connect = now_unix_ms();
        if lt(conn, 0) then idea-error-response(503, "persistence", "database unavailable") else api-ideas-timing-connected(conn, request, t0, t_config, t_connect);
    }
    def observe-warm-ideas(request, remaining) {
        if le(remaining, 0) then 0 else observe-warm-ideas-after(request, remaining, api_ideas(request));
    }
    def observe-warm-ideas-after(request, remaining, ignored) = observe-warm-ideas(request, sub(remaining, 1));
    def api_ideas_observe(request) {
        let warm_count = observe-warm-count(kh-query-int-or(request, "warm", 0));
        let warmed = observe-warm-ideas(request, warm_count);
        let cleared = framebuffer-clear();
        let started = framebuffer-observe-start();
        let response = api_ideas(request);
        let stopped = framebuffer-observe-stop();
        let counts = framebuffer-counts();
        let events = framebuffer-event-rows();
        let event_limit = observe-event-limit(kh-query-int-or(request, "event_limit", 1000));
        let jit_rows = jit-stats();
        observe-response(response, counts, events, event_limit, jit_rows, warm_count);
    }

