    def api-lenses-json() = list(api-lens-json("artistic", "Artistic", "The artistic lens sees form, beauty, expression, rhythm, and aesthetic composition.", api-lens-axes-artistic()), api-lens-json("economic", "Economic", "The economic lens focuses on value, incentives, costs, and allocation of scarce resources.", api-lens-axes-economic()), api-lens-json("engineer", "Engineer", "The systems engineer lens prioritizes efficiency, scalability, reliability, and explicit trade-offs - what works under load and how to measure it.", api-lens-axes-engineer()), api-lens-json("entrepreneur", "Entrepreneur", "The entrepreneur lens reads ideas as market opportunities: users, timing, monetization, and speed to validated learning.", api-lens-axes-entrepreneur()), api-lens-json("institutionalist", "Institutionalist", "The institutional / policy lens foregrounds governance, compliance, precedent, and risk management - stability and accountability to collective rules.", api-lens-axes-institutionalist()), api-lens-json("libertarian", "Libertarian", "The libertarian / decentralist lens emphasizes individual sovereignty, voluntary cooperation, and resistance to coercion - freedom as a primary design constraint.", api-lens-axes-libertarian()), api-lens-json("philosophical", "Philosophical", "The philosophical lens interrogates existence, truth, ethics, and foundational assumptions.", api-lens-axes-philosophical()), api-lens-json("scientific", "Scientific", "The scientific lens examines measurable patterns, causal mechanisms, and empirical evidence.", api-lens-axes-scientific()), api-lens-json("spiritual", "Spiritual", "The spiritual lens explores meaning, consciousness, resonance, and transcendent connection.", api-lens-axes-spiritual()), api-lens-json("systemic", "Systemic", "The systemic / complexity lens emphasizes feedback loops, emergence, unintended consequences, and leverage points - not just parts but couplings.", api-lens-axes-systemic()));
