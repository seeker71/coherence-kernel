    def api-presence-resonance-id(request) = api-path-first-segment(api-path-tail(kh-request-path(request), "/api/presences/"));
    def api-presence-resonances-sql() = "WITH edges AS (SELECT c.id AS concept_id, COALESCE(NULLIF(c.name,''), c.id) AS concept_name, CASE WHEN jsonb_typeof(c.properties->'sacred_frequency') = 'object' AND jsonb_typeof(c.properties->'sacred_frequency'->'hz') = 'number' THEN c.properties->'sacred_frequency'->'hz' WHEN jsonb_typeof(c.properties->'sacred_frequency') = 'number' THEN c.properties->'sacred_frequency' ELSE 'null'::jsonb END AS hz, CASE WHEN COALESCE(e.properties->>'score','') ~ '^-?[0-9]+(\\.[0-9]+)?$' THEN (e.properties->>'score')::double precision ELSE COALESCE(e.strength, 0.0) END AS score, CASE WHEN jsonb_typeof(e.properties->'shared_tokens') = 'array' THEN e.properties->'shared_tokens' ELSE '[]'::jsonb END AS shared_tokens, COALESCE(NULLIF(e.properties->>'method',''), 'keyword-overlap') AS method FROM graph_edges e JOIN graph_nodes c ON c.id = e.to_id WHERE e.from_id = $1 AND e.type = 'resonates-with' ORDER BY score DESC LIMIT 50) SELECT COALESCE(jsonb_agg(jsonb_build_object('concept_id', concept_id, 'concept_name', concept_name, 'hz', hz, 'score', score, 'shared_tokens', shared_tokens, 'method', method) ORDER BY score DESC), '[]'::jsonb)::text AS items_json, count(*)::bigint AS item_count FROM edges";
    def api-presence-resonances-response-json(rows) = if nil?(rows) then json-node-object(list(json-node-pair("items", json-node-array(empty)), json-node-pair("count", json-node-int(0)))) else json-node-object(list(json-node-pair("items", parse-json("presence-resonances.items", idea-row("items_json", head(rows)))), json-node-pair("count", json-node-int(idea-row("item_count", head(rows))))));
    def api-presence-resonances-connected(conn, request) {
        let presence_id = api-presence-resonance-id(request);
        let rows = pg_query_rows(conn, api-presence-resonances-sql(), list(presence_id));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if str_eq(presence_id, "") then api-error-status-json(422, "presence_id is required") else if query_failed then api-service-unavailable("persistence", query_error) else api-native-ok-json("api_presence_resonances", api-presence-resonances-response-json(rows));
    }
    def api_presence_resonances(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-presence-resonances-connected(conn, request);
    }

    def recent-reaction-row(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("entity_type", json-node-string(idea-row("entity_type", row))), json-node-pair("entity_id", json-node-string(idea-row("entity_id", row))), json-node-pair("author_name", json-node-string(idea-row("author_name", row))), json-node-pair("author_id", api-json-nullable-string(idea-row("author_id", row))), json-node-pair("emoji", api-json-nullable-string(idea-row("emoji", row))), json-node-pair("comment", api-json-nullable-string(idea-row("comment", row))), json-node-pair("locale", json-node-string(idea-row("locale", row))), json-node-pair("parent_reaction_id", api-json-nullable-string(idea-row("parent_reaction_id", row))), json-node-pair("created_at", api-json-nullable-string(idea-row("created_at", row)))));
    def recent-reaction-rows(rows) = if nil?(rows) then empty else cons(recent-reaction-row(head(rows)), recent-reaction-rows(tail(rows)));
    def recent-reactions-connected(conn, request) {
        let limit = api-clamp-limit(kh-query-int-or(request, "limit", 20), 100);
        let rows = pg_query_rows(conn, "SELECT id, entity_type, entity_id, author_name, COALESCE(author_id,'') AS author_id, COALESCE(emoji,'') AS emoji, COALESCE(comment,'') AS comment, locale, COALESCE(parent_reaction_id,'') AS parent_reaction_id, replace(created_at::text, ' ', 'T') AS created_at FROM reactions ORDER BY created_at DESC LIMIT $1", list(limit));
        let closed = pg_close(conn);
        api-native-ok-json("api_reactions_recent", json-node-object(list(json-node-pair("reactions", json-node-array(recent-reaction-rows(rows))))));
    }
    def api_reactions_recent(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else recent-reactions-connected(conn, request);
    }

    def anonymous-trace-item-row(row) = json-node-object(list(json-node-pair("id", json-node-string(idea-row("id", row))), json-node-pair("source_point_id", api-json-nullable-string(idea-row("source_point_id", row))), json-node-pair("session_id", api-json-nullable-string(idea-row("session_id", row))), json-node-pair("first_seen_at", api-json-nullable-string(idea-row("first_seen_at", row))), json-node-pair("last_seen_at", api-json-nullable-string(idea-row("last_seen_at", row))), json-node-pair("duration_ms", api-json-number(idea-row("duration_ms", row))), json-node-pair("duration_bucket", json-node-string(idea-row("duration_bucket", row))), json-node-pair("entry_surface", api-json-nullable-string(idea-row("entry_surface", row))), json-node-pair("surface_count", json-node-int(idea-row("surface_count", row))), json-node-pair("surface_sequence", parse-json("surface_sequence", idea-row("surface_sequence_json", row))), json-node-pair("page_count", json-node-int(idea-row("page_count", row))), json-node-pair("surfaces", parse-json("surfaces", idea-row("surfaces_json", row))), json-node-pair("referrer_domain", api-json-nullable-string(idea-row("referrer_domain", row))), json-node-pair("referrer_domains", parse-json("referrer_domains", idea-row("referrer_domains_json", row))), json-node-pair("folded_into_contributor_id", api-json-nullable-string(idea-row("folded_into_contributor_id", row))), json-node-pair("raw_keys_stored", json-node-bool(api-json-db-bool(idea-row("raw_keys_stored", row))))));
    def anonymous-trace-item-rows(rows) = if nil?(rows) then empty else cons(anonymous-trace-item-row(head(rows)), anonymous-trace-item-rows(tail(rows)));
    def anonymous-traces-sql() = "WITH traces AS (SELECT id, properties, updated_at FROM graph_nodes WHERE type = 'event' AND COALESCE((properties->>'anonymous_meeting_trace')::boolean,false) AND ($1 = '' OR properties->>'source_point_id' = $1) ORDER BY updated_at DESC), items AS (SELECT id, properties->>'source_point_id' AS source_point_id, properties->>'session_id' AS session_id, properties->>'first_seen_at' AS first_seen_at, properties->>'last_seen_at' AS last_seen_at, COALESCE((SELECT sum(COALESCE((s.value->>'duration_ms')::int,0)) FROM jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) s),0)::bigint AS duration_ms, COALESCE(properties->>'entry_surface',(SELECT s.value->>'surface' FROM jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) WITH ORDINALITY s(value, ord) ORDER BY s.ord LIMIT 1)) AS entry_surface, jsonb_array_length(COALESCE(properties->'surfaces','[]'::jsonb))::bigint AS surface_count, COALESCE((SELECT jsonb_agg(surface ORDER BY first_ord) FROM (SELECT s.value->>'surface' AS surface, min(s.ord) AS first_ord FROM jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) WITH ORDINALITY s(value, ord) WHERE COALESCE(s.value->>'surface','') <> '' GROUP BY 1) seq),'[]'::jsonb)::text AS surface_sequence_json, COALESCE(properties->'surfaces','[]'::jsonb)::text AS surfaces_json, COALESCE(properties->>'entry_referrer_domain',(SELECT s.value->>'referrer_domain' FROM jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) WITH ORDINALITY s(value, ord) WHERE COALESCE(s.value->>'referrer_domain','') <> '' ORDER BY s.ord LIMIT 1)) AS referrer_domain, COALESCE((SELECT jsonb_agg(referrer_domain ORDER BY first_ord) FROM (SELECT s.value->>'referrer_domain' AS referrer_domain, min(s.ord) AS first_ord FROM jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) WITH ORDINALITY s(value, ord) WHERE COALESCE(s.value->>'referrer_domain','') <> '' GROUP BY 1) refs),'[]'::jsonb)::text AS referrer_domains_json, COALESCE(properties->>'folded_into_contributor_id','') AS folded_into_contributor_id, ((properties ? 'visitor_key') OR (properties ? 'session_key')) AS raw_keys_stored FROM traces LIMIT $2) SELECT *, CASE WHEN duration_ms < 10000 THEN 'under_10s' WHEN duration_ms < 60000 THEN '10s_to_1m' WHEN duration_ms < 300000 THEN '1m_to_5m' WHEN duration_ms < 900000 THEN '5m_to_15m' ELSE '15m_plus' END AS duration_bucket, jsonb_array_length(surface_sequence_json::jsonb)::bigint AS page_count FROM items";
    def anonymous-traces-summary-sql() = "WITH traces AS (SELECT properties, row_number() OVER (ORDER BY updated_at DESC, id ASC)::bigint AS trace_ord FROM graph_nodes WHERE type = 'event' AND COALESCE((properties->>'anonymous_meeting_trace')::boolean,false) AND ($1 = '' OR properties->>'source_point_id' = $1)), surfaces AS (SELECT surface, min(first_ord) AS first_ord FROM (SELECT s.value->>'surface' AS surface, (trace_ord * 1000000 + s.ord)::bigint AS first_ord FROM traces, jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) WITH ORDINALITY s(value, ord) WHERE COALESCE(s.value->>'surface','') <> '') raw GROUP BY surface), referrers AS (SELECT referrer, min(first_ord) AS first_ord FROM (SELECT s.value->>'referrer_domain' AS referrer, (trace_ord * 1000000 + s.ord)::bigint AS first_ord FROM traces, jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) WITH ORDINALITY s(value, ord) WHERE COALESCE(s.value->>'referrer_domain','') <> '') raw GROUP BY referrer), totals AS (SELECT count(*)::bigint AS meeting_count, count(DISTINCT properties->>'source_point_id')::bigint AS source_point_count, min(properties->>'first_seen_at') AS first_seen_at, max(properties->>'last_seen_at') AS last_seen_at, COALESCE(sum((SELECT sum(COALESCE((s.value->>'duration_ms')::int,0)) FROM jsonb_array_elements(COALESCE(properties->'surfaces','[]'::jsonb)) s)),0)::bigint AS total_duration_ms, max(COALESCE(properties->>'folded_into_contributor_id','')) AS folded_into_contributor_id FROM traces) SELECT $1 AS source_point_id, source_point_count, meeting_count, first_seen_at, last_seen_at, total_duration_ms, CASE WHEN total_duration_ms < 10000 THEN 'under_10s' WHEN total_duration_ms < 60000 THEN '10s_to_1m' WHEN total_duration_ms < 300000 THEN '1m_to_5m' WHEN total_duration_ms < 900000 THEN '5m_to_15m' ELSE '15m_plus' END AS duration_bucket, (SELECT surface FROM surfaces ORDER BY first_ord LIMIT 1) AS entry_surface, COALESCE((SELECT jsonb_agg(surface ORDER BY first_ord) FROM surfaces),'[]'::jsonb)::text AS surfaces_met_json, COALESCE((SELECT jsonb_agg(surface ORDER BY first_ord) FROM surfaces),'[]'::jsonb)::text AS surface_sequence_json, (SELECT count(*)::bigint FROM surfaces) AS page_count, (SELECT referrer FROM referrers ORDER BY first_ord LIMIT 1) AS referrer_domain, COALESCE((SELECT jsonb_agg(referrer ORDER BY first_ord) FROM referrers),'[]'::jsonb)::text AS referrer_domains_json, folded_into_contributor_id, 'source_point_id is a same-browser continuity hint, not identity proof' AS continuity_note FROM totals";
    def anonymous-traces-summary-json(row) = json-node-object(list(json-node-pair("source_point_id", api-json-nullable-string(idea-row("source_point_id", row))), json-node-pair("source_point_count", json-node-int(idea-row("source_point_count", row))), json-node-pair("meeting_count", json-node-int(idea-row("meeting_count", row))), json-node-pair("first_seen_at", api-json-nullable-string(idea-row("first_seen_at", row))), json-node-pair("last_seen_at", api-json-nullable-string(idea-row("last_seen_at", row))), json-node-pair("total_duration_ms", api-json-number(idea-row("total_duration_ms", row))), json-node-pair("duration_bucket", json-node-string(idea-row("duration_bucket", row))), json-node-pair("entry_surface", api-json-nullable-string(idea-row("entry_surface", row))), json-node-pair("surfaces_met", parse-json("surfaces_met", idea-row("surfaces_met_json", row))), json-node-pair("surface_sequence", parse-json("surface_sequence", idea-row("surface_sequence_json", row))), json-node-pair("page_count", json-node-int(idea-row("page_count", row))), json-node-pair("referrer_domain", api-json-nullable-string(idea-row("referrer_domain", row))), json-node-pair("referrer_domains", parse-json("referrer_domains", idea-row("referrer_domains_json", row))), json-node-pair("folded_into_contributor_id", api-json-nullable-string(idea-row("folded_into_contributor_id", row))), json-node-pair("continuity_note", json-node-string(idea-row("continuity_note", row)))));
    def anonymous-traces-connected(conn, request) {
        let limit = api-clamp-limit(kh-query-int-or(request, "limit", 50), 200);
        let source_point_id = kh-query-value-or(request, "source_point_id", "");
        let rows = pg_query_rows(conn, anonymous-traces-sql(), list(source_point_id, limit));
        let summary_rows = pg_query_rows(conn, anonymous-traces-summary-sql(), list(source_point_id));
        let closed = pg_close(conn);
        let summary = if nil?(summary_rows) then anonymous-traces-summary-json(_dict_new("source_point_id", source_point_id, "source_point_count", 0, "meeting_count", 0, "first_seen_at", "", "last_seen_at", "", "total_duration_ms", 0, "duration_bucket", "under_10s", "entry_surface", "", "surfaces_met_json", "[]", "surface_sequence_json", "[]", "page_count", 0, "referrer_domain", "", "referrer_domains_json", "[]", "folded_into_contributor_id", "", "continuity_note", "source_point_id is a same-browser continuity hint, not identity proof")) else anonymous-traces-summary-json(head(summary_rows));
        api-native-ok-json("api_meetings_anonymous_traces", json-node-object(list(json-node-pair("items", json-node-array(anonymous-trace-item-rows(rows))), json-node-pair("summary", summary), json-node-pair("limit", json-node-int(limit)))));
    }
    def api_meetings_anonymous_traces(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else anonymous-traces-connected(conn, request);
    }

    def api-ws-code?(cp) = or(eq(cp, 32), or(eq(cp, 9), or(eq(cp, 10), eq(cp, 13))));
    def api-trim-left-index(s, i) = if ge(i, str_len(s)) then str_len(s) else if api-ws-code?(ord(char_at(s, i))) then api-trim-left-index(s, add(i, 1)) else i;
    def api-trim-right-index(s, i) = if lt(i, 0) then -1 else if api-ws-code?(ord(char_at(s, i))) then api-trim-right-index(s, sub(i, 1)) else i;
    def api-trim(s) {
        let left = api-trim-left-index(s, 0);
        let right = api-trim-right-index(s, sub(str_len(s), 1));
        if lt(right, left) then "" else substring(s, left, add(right, 1));
    }

    def api-locale-supported?(lang) = or(str_eq(lang, "en"), or(str_eq(lang, "de"), or(str_eq(lang, "es"), or(str_eq(lang, "fr"), or(str_eq(lang, "id"), str_eq(lang, "pt-br"))))));
    def api-locale-root(lang) {
        let dash = str_find(lang, "-", 0);
        if eq(dash, -1) then lang else substring(lang, 0, dash);
    }
    def api-locale-without-quality(raw) {
        let semi = str_find(raw, ";", 0);
        if eq(semi, -1) then raw else substring(raw, 0, semi);
    }
    def api-locale-first-token(header) {
        let comma = str_find(header, ",", 0);
        let first = if eq(comma, -1) then header else substring(header, 0, comma);
        kh-ascii-lower(api-trim(api-locale-without-quality(first)));
    }
    def api-locale-normalized(candidate) {
        let root = api-locale-root(candidate);
        if api-locale-supported?(candidate) then candidate else if api-locale-supported?(root) then root else "en";
    }
    def api-caller-lang(request) {
        let query_lang = kh-ascii-lower(api-trim(kh-query-value-or(request, "lang", "")));
        let header_lang = api-locale-first-token(api-request-header-value-or(request, "Accept-Language", ""));
        if api-locale-supported?(query_lang) then query_lang else api-locale-normalized(header_lang);
    }
    def api-spec-select-sql() = "SELECT COALESCE(NULLIF(n.properties->>'spec_id',''), regexp_replace(n.id, '^spec-', '')) AS spec_id, COALESCE(NULLIF(ev.content_title,''), NULLIF(n.name,''), COALESCE(NULLIF(n.properties->>'spec_id',''), regexp_replace(n.id, '^spec-', ''))) AS title, COALESCE(NULLIF(ev.content_description,''), n.description, '') AS summary, COALESCE(NULLIF(n.properties->>'potential_value','')::double precision, 0.0) AS potential_value, COALESCE(NULLIF(n.properties->>'actual_value','')::double precision, 0.0) AS actual_value, COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision, 0.0) AS estimated_cost, COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision, 0.0) AS actual_cost, round(GREATEST(COALESCE(NULLIF(n.properties->>'potential_value','')::double precision, 0.0) - COALESCE(NULLIF(n.properties->>'actual_value','')::double precision, 0.0), 0.0)::numeric, 4)::double precision AS value_gap, round((COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision, 0.0) - COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision, 0.0))::numeric, 4)::double precision AS cost_gap, CASE WHEN COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision, 0.0) <= 0 THEN 0.0 ELSE round((COALESCE(NULLIF(n.properties->>'potential_value','')::double precision, 0.0) / COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision, 0.0))::numeric, 4)::double precision END AS estimated_roi, CASE WHEN COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision, 0.0) <= 0 THEN 0.0 ELSE round((COALESCE(NULLIF(n.properties->>'actual_value','')::double precision, 0.0) / COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision, 0.0))::numeric, 4)::double precision END AS actual_roi, COALESCE(n.properties->>'idea_id','') AS idea_id, COALESCE(n.properties->>'process_summary','') AS process_summary, COALESCE(n.properties->>'pseudocode_summary','') AS pseudocode_summary, COALESCE(n.properties->>'implementation_summary','') AS implementation_summary, COALESCE(n.properties->>'created_by_contributor_id','') AS created_by_contributor_id, COALESCE(n.properties->>'updated_by_contributor_id','') AS updated_by_contributor_id, to_char(n.created_at AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"') AS created_at, to_char(n.updated_at AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"') AS updated_at, COALESCE(n.properties->>'content_path','') AS content_path, COALESCE(n.properties->>'content_hash','') AS content_hash, COALESCE(NULLIF(n.properties->>'workspace_id',''), 'coherence-network') AS workspace_id FROM graph_nodes n LEFT JOIN LATERAL (SELECT content_title, content_description FROM entity_views ev WHERE ev.entity_type = 'spec' AND ev.entity_id = COALESCE(NULLIF(n.properties->>'spec_id',''), regexp_replace(n.id, '^spec-', '')) AND ev.lang = $1 AND ev.status = 'canonical' ORDER BY ev.updated_at DESC LIMIT 1) ev ON true";
    def api-spec-list-sql() = str_concat(api-spec-select-sql(), " WHERE n.type = 'spec' AND ($2 = '' OR COALESCE(NULLIF(n.properties->>'workspace_id',''), 'coherence-network') = $2) ORDER BY n.updated_at DESC LIMIT $3 OFFSET $4");
    def api-spec-list-count-sql() = "SELECT count(*)::bigint AS total FROM graph_nodes n WHERE n.type = 'spec' AND ($1 = '' OR COALESCE(NULLIF(n.properties->>'workspace_id',''), 'coherence-network') = $1)";
    def api-spec-detail-sql() = str_concat(api-spec-select-sql(), " WHERE n.type = 'spec' AND (n.id = $2 OR n.id = ('spec-' || $2) OR COALESCE(NULLIF(n.properties->>'spec_id',''), '') = $2) LIMIT 1");
    def api-spec-idea-exists-sql() = "SELECT count(*)::bigint AS total FROM graph_nodes WHERE type = 'idea' AND id = $1";
    def api-spec-idea-list-sql() = str_concat(api-spec-select-sql(), " WHERE n.type = 'spec' AND COALESCE(n.properties->>'idea_id','') = $2 ORDER BY n.updated_at DESC LIMIT 1000");
    def api-spec-path-id(request) {
        let path = kh-request-path(request);
        api-path-first-segment(api-path-tail(path, "/api/spec-registry/"));
    }
    def api-idea-specs-id(request) {
        let tail = api-path-tail(kh-request-path(request), "/api/ideas/");
        api-path-first-segment(tail);
    }
    def api-spec-row-json(row) = json-node-object(list(json-node-pair("spec_id", json-node-string(idea-row("spec_id", row))), json-node-pair("title", json-node-string(idea-row("title", row))), json-node-pair("summary", json-node-string(idea-row("summary", row))), json-node-pair("potential_value", api-json-number(idea-row("potential_value", row))), json-node-pair("actual_value", api-json-number(idea-row("actual_value", row))), json-node-pair("estimated_cost", api-json-number(idea-row("estimated_cost", row))), json-node-pair("actual_cost", api-json-number(idea-row("actual_cost", row))), json-node-pair("value_gap", api-json-number(idea-row("value_gap", row))), json-node-pair("cost_gap", api-json-number(idea-row("cost_gap", row))), json-node-pair("estimated_roi", api-json-number(idea-row("estimated_roi", row))), json-node-pair("actual_roi", api-json-number(idea-row("actual_roi", row))), json-node-pair("idea_id", api-json-nullable-string(idea-row("idea_id", row))), json-node-pair("process_summary", api-json-nullable-string(idea-row("process_summary", row))), json-node-pair("pseudocode_summary", api-json-nullable-string(idea-row("pseudocode_summary", row))), json-node-pair("implementation_summary", api-json-nullable-string(idea-row("implementation_summary", row))), json-node-pair("created_by_contributor_id", api-json-nullable-string(idea-row("created_by_contributor_id", row))), json-node-pair("updated_by_contributor_id", api-json-nullable-string(idea-row("updated_by_contributor_id", row))), json-node-pair("created_at", json-node-string(idea-row("created_at", row))), json-node-pair("updated_at", json-node-string(idea-row("updated_at", row))), json-node-pair("content_path", api-json-nullable-string(idea-row("content_path", row))), json-node-pair("content_hash", api-json-nullable-string(idea-row("content_hash", row))), json-node-pair("workspace_id", json-node-string(idea-row("workspace_id", row)))));
    def api-spec-rows-json(rows) = if nil?(rows) then empty else cons(api-spec-row-json(head(rows)), api-spec-rows-json(tail(rows)));
    def api-spec-list-response-json(rows) = json-node-array(api-spec-rows-json(rows));
    def api-spec-list-response(handler, count_rows, rows) = kh-response(200, list(kh-header("Content-Type", "application/json"), kh-header("X-Form-Handler", handler), kh-header("X-Form-Python-Authority", "false"), kh-header("x-total-count", value_str(if nil?(count_rows) then 0 else idea-row("total", head(count_rows)))), kh-header("Access-Control-Allow-Origin", "*")), json-emit(api-spec-list-response-json(rows)));
    def api-spec-registry-connected(conn, request) {
        let limit = api-clamp-limit(kh-query-int-or(request, "limit", 200), 1000);
        let offset = idea-safe-offset(kh-query-int-or(request, "offset", 0));
        let workspace_id = kh-query-value-or(request, "workspace_id", "");
        let lang = api-caller-lang(request);
        let count_rows = pg_query_rows(conn, api-spec-list-count-sql(), list(workspace_id));
        let rows = pg_query_rows(conn, api-spec-list-sql(), list(lang, workspace_id, limit, offset));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if query_failed then api-service-unavailable("persistence", query_error) else api-spec-list-response("api_spec_registry", count_rows, rows);
    }
    def api_spec_registry(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-spec-registry-connected(conn, request);
    }
    def api-spec-detail-connected(conn, request) {
        let spec_id = api-spec-path-id(request);
        let rows = pg_query_rows(conn, api-spec-detail-sql(), list(api-caller-lang(request), spec_id));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if str_eq(spec_id, "") then api-error-status-json(422, "spec_id is required") else if query_failed then api-service-unavailable("persistence", query_error) else if nil?(rows) then api-error-status-json(404, str_concat("Spec '", str_concat(spec_id, "' not found"))) else api-native-ok-json("api_spec_registry_detail", api-spec-row-json(head(rows)));
    }
    def api_spec_registry_detail(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-spec-detail-connected(conn, request);
    }
    def api-idea-specs-connected(conn, request) {
        let idea_id = api-idea-specs-id(request);
        let lang = api-caller-lang(request);
        let idea_rows = pg_query_rows(conn, api-spec-idea-exists-sql(), list(idea_id));
        let rows = if nil?(idea_rows) then empty else if le(idea-row("total", head(idea_rows)), 0) then empty else pg_query_rows(conn, api-spec-idea-list-sql(), list(lang, idea_id));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if str_eq(idea_id, "") then api-error-status-json(422, "idea_id is required") else if query_failed then api-service-unavailable("persistence", query_error) else if nil?(idea_rows) then api-service-unavailable("persistence", "idea lookup failed") else if le(idea-row("total", head(idea_rows)), 0) then api-error-status-json(404, "Idea not found") else api-native-ok-json("api_idea_specs", api-spec-list-response-json(rows));
    }
    def api_idea_specs(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-idea-specs-connected(conn, request);
    }
    def api-idea-detail-id(request) = api-path-tail(kh-request-path(request), "/api/ideas/");
    def api-idea-resolve-sql() = "SELECT id FROM graph_nodes WHERE type = 'idea' AND (id = $1 OR COALESCE(NULLIF(properties->>'slug',''), id) = $1) ORDER BY CASE WHEN id = $1 THEN 0 WHEN COALESCE(NULLIF(properties->>'slug',''), id) = $1 THEN 1 ELSE 2 END LIMIT 1";
    def api-idea-detail-sql() = "WITH resolved AS (SELECT id FROM graph_nodes WHERE type = 'idea' AND (id = $1 OR COALESCE(NULLIF(properties->>'slug',''), id) = $1) ORDER BY CASE WHEN id = $1 THEN 0 WHEN COALESCE(NULLIF(properties->>'slug',''), id) = $1 THEN 1 ELSE 2 END LIMIT 1), raw AS (SELECT n.id, COALESCE(NULLIF(view.content_title, ''), n.name) AS name, COALESCE(NULLIF(view.content_description, ''), n.description) AS description, COALESCE(NULLIF(n.properties->>'potential_value','')::double precision,0.0) AS potential_value, COALESCE(NULLIF(n.properties->>'actual_value','')::double precision,0.0) AS actual_value, COALESCE(NULLIF(n.properties->>'estimated_cost','')::double precision,0.0) AS estimated_cost, COALESCE(NULLIF(n.properties->>'actual_cost','')::double precision,0.0) AS actual_cost, COALESCE(NULLIF(n.properties->>'resistance_risk','')::double precision,1.0) AS resistance_risk, COALESCE(NULLIF(n.properties->>'confidence','')::double precision,0.5) AS confidence, COALESCE(n.properties->>'manifestation_status','none') AS manifestation_status, COALESCE(n.properties->'interfaces','[]'::jsonb)::text AS interfaces_json, COALESCE(n.properties->'open_questions','[]'::jsonb)::text AS open_questions_json, COALESCE(n.properties->>'idea_type','standalone') AS idea_type, COALESCE(n.properties->>'parent_idea_id','') AS parent_idea_id, COALESCE(n.properties->'child_idea_ids','[]'::jsonb)::text AS child_idea_ids_json, COALESCE(n.properties->>'stage','none') AS stage, COALESCE(n.properties->>'work_type','') AS work_type, COALESCE(n.properties->>'lifecycle','active') AS lifecycle, COALESCE(n.properties->>'duplicate_of','') AS duplicate_of, COALESCE(n.properties->>'last_activity_at','') AS last_activity_at, COALESCE(n.properties->'value_basis','null'::jsonb)::text AS value_basis_json, COALESCE(n.properties->'tags','[]'::jsonb)::text AS tags_json, COALESCE(n.properties->>'workspace_git_url','') AS workspace_git_url, COALESCE(NULLIF(n.properties->>'slug',''), n.id) AS slug, COALESCE(n.properties->'slug_history','[]'::jsonb)::text AS slug_history_json, COALESCE((n.properties->>'is_curated')::boolean,false) AS is_curated, COALESCE(n.properties->>'pillar','') AS pillar, COALESCE(n.properties->>'workspace_id','coherence-network') AS workspace_id, COALESCE(n.properties->>'rollup_condition','') AS rollup_condition FROM graph_nodes n JOIN resolved r ON n.id = r.id LEFT JOIN LATERAL (SELECT content_title, content_description FROM entity_views WHERE entity_type = 'idea' AND entity_id = n.id AND lang = $2 AND status = 'canonical' ORDER BY updated_at DESC LIMIT 1) view ON true) SELECT raw.*, round(((potential_value * confidence) / GREATEST(estimated_cost + resistance_risk, 0.5))::numeric, 4)::double precision AS free_energy_score, round(GREATEST(potential_value - actual_value, 0)::numeric, 4)::double precision AS value_gap, round(((GREATEST(potential_value - actual_value, 0) * confidence * confidence) / (GREATEST(estimated_cost - actual_cost, 0.1) + resistance_risk * 0.5))::numeric, 4)::double precision AS marginal_cc_score, round(GREATEST(estimated_cost - actual_cost, 0)::numeric, 4)::double precision AS remaining_cost_cc, round(GREATEST(potential_value - actual_value, 0)::numeric, 4)::double precision AS value_gap_cc, CASE WHEN GREATEST(estimated_cost - actual_cost, 0) > 0 THEN round((GREATEST(potential_value - actual_value, 0) / GREATEST(estimated_cost - actual_cost, 0))::numeric, 4)::double precision ELSE 0.0 END AS roi_cc, 1.0::double precision AS selection_weight FROM raw LIMIT 1";
    def api-idea-detail-connected(conn, request) {
        let idea_id = api-idea-detail-id(request);
        let lang = api-caller-lang(request);
        let rows = pg_query_rows(conn, api-idea-detail-sql(), list(idea_id, lang));
        let query_error = pg_last_error();
        let query_failed = gt(str_len(query_error), 0);
        let closed = pg_close(conn);
        if str_eq(idea_id, "") then api-error-status-json(422, "idea_id is required") else if query_failed then api-service-unavailable("persistence", query_error) else if nil?(rows) then api-error-status-json(404, "Idea not found") else api-native-ok-json("api_idea_detail", idea-json-row(head(rows)));
    }
    def api_idea_detail(request) {
        let conn = pg_connect(config_database_url());
        if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-idea-detail-connected(conn, request);
    }
    def api-idea-update-parent-read-sql() = "SELECT COALESCE(properties->>'parent_idea_id','') AS parent_idea_id FROM graph_nodes WHERE id = $1 LIMIT 1";
    def api-idea-update-parent-remove-child-sql() = "WITH input AS (SELECT $1::text AS parent_id, $2::text AS child_id) UPDATE graph_nodes n SET properties = jsonb_set(COALESCE(n.properties,'{}'::jsonb), '{child_idea_ids}', COALESCE((SELECT jsonb_agg(to_jsonb(value)) FROM jsonb_array_elements_text(COALESCE(n.properties->'child_idea_ids','[]'::jsonb)) value WHERE value <> input.child_id), '[]'::jsonb), true), updated_at = now() FROM input WHERE n.id = input.parent_id RETURNING n.id";
    def api-idea-update-parent-add-child-sql() = "WITH input AS (SELECT $1::text AS parent_id, $2::text AS child_id) UPDATE graph_nodes n SET properties = jsonb_set(COALESCE(n.properties,'{}'::jsonb), '{child_idea_ids}', CASE WHEN EXISTS(SELECT 1 FROM jsonb_array_elements_text(COALESCE(n.properties->'child_idea_ids','[]'::jsonb)) value WHERE value = input.child_id) THEN COALESCE(n.properties->'child_idea_ids','[]'::jsonb) ELSE COALESCE(n.properties->'child_idea_ids','[]'::jsonb) || jsonb_build_array(input.child_id) END, true), updated_at = now() FROM input WHERE n.id = input.parent_id RETURNING n.id";
    def api-idea-update-sql() = "WITH input AS (SELECT $1::text AS idea_id, $2::boolean AS apply_actual_value, GREATEST($3::double precision, 0.0) AS actual_value, $4::boolean AS apply_actual_cost, GREATEST($5::double precision, 0.0) AS actual_cost, $6::boolean AS apply_confidence, LEAST(GREATEST($7::double precision, 0.0), 1.0) AS confidence, $8::boolean AS apply_manifestation_status, $9::text AS manifestation_status, $10::boolean AS apply_stage, $11::text AS stage, $12::boolean AS apply_potential_value, GREATEST($13::double precision, 0.0) AS potential_value, $14::boolean AS apply_estimated_cost, GREATEST($15::double precision, 0.0) AS estimated_cost, $16::boolean AS apply_description, left($17::text, 20000) AS description, $18::boolean AS apply_name, left($19::text, 4000) AS name, $20::boolean AS apply_work_type, $21::text AS work_type, $22::boolean AS apply_lifecycle, $23::text AS lifecycle, $24::boolean AS apply_duplicate_of, left($25::text, 4000) AS duplicate_of, $26::boolean AS apply_workspace_git_url, left($27::text, 4000) AS workspace_git_url, $28::boolean AS apply_interfaces, $29::text AS interfaces_json_text, $30::boolean AS apply_parent, left($31::text, 4000) AS parent_idea_id) UPDATE graph_nodes n SET name = CASE WHEN input.apply_name THEN input.name ELSE n.name END, description = CASE WHEN input.apply_description THEN input.description ELSE n.description END, properties = jsonb_strip_nulls(COALESCE(n.properties,'{}'::jsonb) || jsonb_build_object('actual_value', CASE WHEN input.apply_actual_value THEN to_jsonb(input.actual_value) ELSE COALESCE(n.properties->'actual_value', to_jsonb(0.0)) END, 'actual_cost', CASE WHEN input.apply_actual_cost THEN to_jsonb(input.actual_cost) ELSE COALESCE(n.properties->'actual_cost', to_jsonb(0.0)) END, 'confidence', CASE WHEN input.apply_confidence THEN to_jsonb(input.confidence) ELSE COALESCE(n.properties->'confidence', to_jsonb(0.5)) END, 'manifestation_status', to_jsonb(CASE WHEN input.apply_manifestation_status THEN input.manifestation_status ELSE CASE WHEN input.apply_stage AND input.stage = 'specced' THEN 'partial' WHEN input.apply_stage AND input.stage = 'implementing' THEN 'partial' WHEN input.apply_stage AND input.stage = 'complete' THEN 'validated' ELSE COALESCE(NULLIF(n.properties->>'manifestation_status',''), 'none') END END), 'stage', to_jsonb(CASE WHEN input.apply_stage THEN input.stage ELSE COALESCE(NULLIF(n.properties->>'stage',''), 'none') END), 'potential_value', CASE WHEN input.apply_potential_value THEN to_jsonb(input.potential_value) ELSE COALESCE(n.properties->'potential_value', to_jsonb(0.0)) END, 'estimated_cost', CASE WHEN input.apply_estimated_cost THEN to_jsonb(input.estimated_cost) ELSE COALESCE(n.properties->'estimated_cost', to_jsonb(0.0)) END, 'work_type', CASE WHEN input.apply_work_type THEN CASE WHEN input.work_type = '' THEN NULL::jsonb ELSE to_jsonb(input.work_type) END ELSE COALESCE(n.properties->'work_type', NULL::jsonb) END, 'lifecycle', to_jsonb(CASE WHEN input.apply_lifecycle THEN input.lifecycle ELSE COALESCE(NULLIF(n.properties->>'lifecycle',''), 'active') END), 'duplicate_of', CASE WHEN input.apply_duplicate_of THEN CASE WHEN input.duplicate_of = '' THEN NULL::jsonb ELSE to_jsonb(input.duplicate_of) END ELSE COALESCE(n.properties->'duplicate_of', NULL::jsonb) END, 'workspace_git_url', CASE WHEN input.apply_workspace_git_url THEN CASE WHEN input.workspace_git_url = '' THEN NULL::jsonb ELSE to_jsonb(input.workspace_git_url) END ELSE COALESCE(n.properties->'workspace_git_url', NULL::jsonb) END, 'interfaces', CASE WHEN input.apply_interfaces THEN COALESCE(input.interfaces_json_text, '[]')::jsonb ELSE COALESCE(n.properties->'interfaces', '[]'::jsonb) END, 'parent_idea_id', CASE WHEN input.apply_parent THEN CASE WHEN input.parent_idea_id = '' THEN NULL::jsonb ELSE to_jsonb(input.parent_idea_id) END ELSE COALESCE(n.properties->'parent_idea_id', NULL::jsonb) END, 'last_activity_at', to_jsonb(to_char(now() AT TIME ZONE 'UTC', 'YYYY-MM-DD\"T\"HH24:MI:SS.US\"Z\"')))), updated_at = now() FROM input WHERE n.id = input.idea_id RETURNING n.id";
    def api-idea-update-has-updates?(apply_actual_value, apply_actual_cost, apply_confidence, apply_manifestation_status, apply_stage, apply_parent, apply_potential_value, apply_estimated_cost, apply_description, apply_name, apply_work_type, apply_lifecycle, apply_duplicate_of, apply_workspace_git_url, apply_interfaces) {
        if apply_actual_value then true
        else if apply_actual_cost then true
        else if apply_confidence then true
        else if apply_manifestation_status then true
        else if apply_stage then true
        else if apply_parent then true
        else if apply_potential_value then true
        else if apply_estimated_cost then true
        else if apply_description then true
        else if apply_name then true
        else if apply_work_type then true
        else if apply_lifecycle then true
        else if apply_duplicate_of then true
        else if apply_workspace_git_url then true
        else apply_interfaces;
    }
    def api_idea_update(request) {
        let body = parse-json("idea-update-request", kh-request-body(request));
        let idea_id = api-idea-detail-id(request);
        let lang = api-caller-lang(request);
        let apply_actual_value = and(json-object-has?(body, "actual_value"), not(api-json-null-node?(json-object-get(body, "actual_value"))));
        let apply_actual_cost = and(json-object-has?(body, "actual_cost"), not(api-json-null-node?(json-object-get(body, "actual_cost"))));
        let apply_confidence = and(json-object-has?(body, "confidence"), not(api-json-null-node?(json-object-get(body, "confidence"))));
        let apply_manifestation_status = and(json-object-has?(body, "manifestation_status"), not(api-json-null-node?(json-object-get(body, "manifestation_status"))));
        let apply_stage = and(json-object-has?(body, "stage"), not(api-json-null-node?(json-object-get(body, "stage"))));
        let apply_parent = and(json-object-has?(body, "parent_idea_id"), not(api-json-null-node?(json-object-get(body, "parent_idea_id"))));
        let apply_potential_value = and(json-object-has?(body, "potential_value"), not(api-json-null-node?(json-object-get(body, "potential_value"))));
        let apply_estimated_cost = and(json-object-has?(body, "estimated_cost"), not(api-json-null-node?(json-object-get(body, "estimated_cost"))));
        let apply_description = and(json-object-has?(body, "description"), not(api-json-null-node?(json-object-get(body, "description"))));
        let apply_name = and(json-object-has?(body, "name"), not(api-json-null-node?(json-object-get(body, "name"))));
        let apply_work_type = and(json-object-has?(body, "work_type"), not(api-json-null-node?(json-object-get(body, "work_type"))));
        let apply_lifecycle = and(json-object-has?(body, "lifecycle"), not(api-json-null-node?(json-object-get(body, "lifecycle"))));
        let apply_duplicate_of = and(json-object-has?(body, "duplicate_of"), not(api-json-null-node?(json-object-get(body, "duplicate_of"))));
        let apply_workspace_git_url = and(json-object-has?(body, "workspace_git_url"), not(api-json-null-node?(json-object-get(body, "workspace_git_url"))));
        let apply_interfaces = and(json-object-has?(body, "interfaces"), not(api-json-null-node?(json-object-get(body, "interfaces"))));
        let has_updates = api-idea-update-has-updates?(apply_actual_value, apply_actual_cost, apply_confidence, apply_manifestation_status, apply_stage, apply_parent, apply_potential_value, apply_estimated_cost, apply_description, apply_name, apply_work_type, apply_lifecycle, apply_duplicate_of, apply_workspace_git_url, apply_interfaces);
        let conn = pg_connect(config_database_url());
        if str_eq(idea_id, "") then api-error-status-json(422, "idea_id is required") else if not(has_updates) then api-error-status-json(400, "At least one field required") else if lt(conn, 0) then api-service-unavailable("persistence", "database unavailable") else api-idea-update-connected(conn, idea_id, lang, body, apply_actual_value, apply_actual_cost, apply_confidence, apply_manifestation_status, apply_stage, apply_parent, apply_potential_value, apply_estimated_cost, apply_description, apply_name, apply_work_type, apply_lifecycle, apply_duplicate_of, apply_workspace_git_url, apply_interfaces);
    }
    def api-idea-update-connected(conn, idea_id, lang, body, apply_actual_value, apply_actual_cost, apply_confidence, apply_manifestation_status, apply_stage, apply_parent, apply_potential_value, apply_estimated_cost, apply_description, apply_name, apply_work_type, apply_lifecycle, apply_duplicate_of, apply_workspace_git_url, apply_interfaces) {
        let resolved_rows = pg_query_rows(conn, api-idea-resolve-sql(), list(idea_id));
        let resolved_id = if nil?(resolved_rows) then "" else idea-row("id", head(resolved_rows));
        let parent_rows = if str_eq(resolved_id, "") then empty else pg_query_rows(conn, api-idea-update-parent-read-sql(), list(resolved_id));
        let old_parent_id = if nil?(parent_rows) then "" else idea-row("parent_idea_id", head(parent_rows));
        let new_parent_id = api-json-field-value-or(body, "parent_idea_id", "");
        let removed_parent_rows = if and(apply_parent, not(str_eq(old_parent_id, "")), not(str_eq(old_parent_id, new_parent_id))) then pg_query_rows(conn, api-idea-update-parent-remove-child-sql(), list(old_parent_id, resolved_id)) else empty;
        let updated_rows = if str_eq(resolved_id, "") then empty else pg_query_rows(conn, api-idea-update-sql(), list(value_str(resolved_id), apply_actual_value, api-json-field-float-or(body, "actual_value", 0.0), apply_actual_cost, api-json-field-float-or(body, "actual_cost", 0.0), apply_confidence, api-json-field-float-or(body, "confidence", 0.5), apply_manifestation_status, api-json-field-value-or(body, "manifestation_status", ""), apply_stage, api-json-field-value-or(body, "stage", ""), apply_potential_value, api-json-field-float-or(body, "potential_value", 0.0), apply_estimated_cost, api-json-field-float-or(body, "estimated_cost", 0.0), apply_description, api-json-field-value-or(body, "description", ""), apply_name, api-json-field-value-or(body, "name", ""), apply_work_type, api-json-field-value-or(body, "work_type", ""), apply_lifecycle, api-json-field-value-or(body, "lifecycle", ""), apply_duplicate_of, api-json-field-value-or(body, "duplicate_of", ""), apply_workspace_git_url, api-json-field-value-or(body, "workspace_git_url", ""), apply_interfaces, json-emit(api-json-field-node-or(body, "interfaces", json-node-array(empty))), apply_parent, new_parent_id));
        let update_error = pg_last_error();
        let update_failed = gt(str_len(update_error), 0);
        let added_parent_rows = if and(apply_parent, not(str_eq(new_parent_id, ""))) then pg_query_rows(conn, api-idea-update-parent-add-child-sql(), list(new_parent_id, resolved_id)) else empty;
        let detail_rows = if update_failed then empty else if nil?(updated_rows) then empty else pg_query_rows(conn, api-idea-detail-sql(), list(resolved_id, lang));
        let detail_error = pg_last_error();
        let detail_failed = gt(str_len(detail_error), 0);
        let closed = pg_close(conn);
        if update_failed then api-service-unavailable("persistence", update_error) else if detail_failed then api-service-unavailable("persistence", detail_error) else if str_eq(resolved_id, "") then api-error-status-json(404, "Idea not found") else if nil?(detail_rows) then api-service-unavailable("persistence", "idea update returned no row") else api-native-ok-json("api_idea_update", idea-json-row(head(detail_rows)));
    }
    def api-idea-question-id(request) {
        let tail = api-path-tail(kh-request-path(request), "/api/ideas/");
        let marker = str_find(tail, "/questions", 0);
        if eq(marker, -1) then "" else substring(tail, 0, marker);
    }
    def api-idea-question-duplicate-sql() = "SELECT CASE WHEN EXISTS(SELECT 1 FROM jsonb_array_elements(COALESCE(properties->'open_questions','[]'::jsonb)) q WHERE lower(btrim(COALESCE(q->>'question',''))) = lower(btrim($2::text))) THEN 1 ELSE 0 END AS total FROM graph_nodes WHERE id = $1 LIMIT 1";
    def api-idea-question-create-sql() = "WITH input AS (SELECT $1::text AS idea_id, left($2::text, 4000) AS question, GREATEST($3::double precision, 0.0) AS value_to_whole, GREATEST($4::double precision, 0.0) AS estimated_cost), updated AS (UPDATE graph_nodes n SET properties = jsonb_set(COALESCE(n.properties,'{}'::jsonb), '{open_questions}', COALESCE(n.properties->'open_questions','[]'::jsonb) || jsonb_build_array(jsonb_strip_nulls(jsonb_build_object('question', input.question, 'value_to_whole', input.value_to_whole, 'estimated_cost', input.estimated_cost, 'answer', NULL, 'measured_delta', NULL))), true), updated_at = now() FROM input WHERE n.id = input.idea_id RETURNING n.id) SELECT id FROM updated";
    def api-idea-question-exists-sql() = "SELECT CASE WHEN EXISTS(SELECT 1 FROM jsonb_array_elements(COALESCE(properties->'open_questions','[]'::jsonb)) q WHERE COALESCE(q->>'question','') = $2::text) THEN 1 ELSE 0 END AS total FROM graph_nodes WHERE id = $1 LIMIT 1";
    def api-idea-question-answer-sql() = "WITH input AS (SELECT $1::text AS idea_id, left($2::text, 4000) AS question, left($3::text, 4000) AS answer, $4::text::double precision AS measured_delta, $5::boolean AS apply_measured), updated AS (UPDATE graph_nodes n SET properties = jsonb_set(COALESCE(n.properties,'{}'::jsonb), '{open_questions}', (SELECT COALESCE(jsonb_agg(CASE WHEN COALESCE(elem->>'question','') = input.question THEN CASE WHEN input.apply_measured THEN jsonb_set(jsonb_set(elem, '{answer}', to_jsonb(input.answer), true), '{measured_delta}', to_jsonb(input.measured_delta), true) ELSE jsonb_set(elem, '{answer}', to_jsonb(input.answer), true) END ELSE elem END ORDER BY ord), '[]'::jsonb) FROM jsonb_array_elements(COALESCE(n.properties->'open_questions','[]'::jsonb)) WITH ORDINALITY q(elem, ord), input), true), updated_at = now() FROM input WHERE n.id = input.idea_id RETURNING n.id) SELECT id FROM updated";
    def api_idea_question_create(request) {
        let body = parse-json("idea-question-create-request", kh-request-body(request));
        let idea_id = api-idea-question-id(request);
        let question = api-json-field-value-or(body, "question", "");
        let value_to_whole = api-json-field-float-or(body, "value_to_whole", 0.0);
        let estimated_cost = api-json-field-float-or(body, "estimated_cost", 0.0);
